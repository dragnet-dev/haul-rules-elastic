// Dragnet [Ransomware]: dragnet-ransomware-2026-1662 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 7dea4600-5e79-58c7-9d10-49cb2d71fd59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
