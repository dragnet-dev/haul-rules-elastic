// Dragnet [Ransomware]: dragnet-ransomware-2026-0441 — Recovery Inhibition (direwolf)
// Status: test | Level: high | ID: 4e9d1aba-e501-5cee-972d-b0f1628c0ea2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
