// Dragnet [Ransomware]: dragnet-ransomware-2026-1426 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 11c64c9b-6f4e-51bc-bba5-c595e76dfb4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
