// Dragnet [Ransomware]: dragnet-ransomware-2026-3533 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 1a6bfefb-34c1-58fa-a307-68868bdd41e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
