// Dragnet [Ransomware]: dragnet-ransomware-2026-0278 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: e145117e-7909-5ef5-b288-5bc27e13905b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
