// Dragnet [Ransomware]: dragnet-ransomware-2026-0791 — Recovery Inhibition (interlock)
// Status: stable | Level: high | ID: 17903c8a-22d3-5690-84b1-1e0d33e9789f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
