// Dragnet [Ransomware]: dragnet-ransomware-2026-0348 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: 29135bc0-c727-54d2-a35d-c0161147d3dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
