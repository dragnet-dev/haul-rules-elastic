// Dragnet [Ransomware]: dragnet-ransomware-2026-0873 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 2c31f4b6-73b8-56db-bccb-bc212a27362a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
