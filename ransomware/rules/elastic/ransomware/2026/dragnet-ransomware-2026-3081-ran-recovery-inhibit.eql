// Dragnet [Ransomware]: dragnet-ransomware-2026-3081 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: fa87b57d-0aa7-57e8-9e88-33b704a40ffa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
