// Dragnet [Ransomware]: dragnet-ransomware-2026-0996 — Recovery Inhibition (spacebears)
// Status: test | Level: high | ID: 815ab84b-4442-5c1a-a13a-6d6f831437f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
