// Dragnet [Ransomware]: dragnet-ransomware-2026-2955 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: a7e9fcc0-326e-5516-a5ba-7927e2843db6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
