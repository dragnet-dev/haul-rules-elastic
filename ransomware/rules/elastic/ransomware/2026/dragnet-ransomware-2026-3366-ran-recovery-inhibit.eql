// Dragnet [Ransomware]: dragnet-ransomware-2026-3366 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 88e08b1e-96cf-5588-be58-2d8f4c090ffa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
