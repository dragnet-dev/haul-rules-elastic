// Dragnet [Ransomware]: dragnet-ransomware-2026-2987 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: 16d08c27-aabd-5a4a-9d0e-cbb73c1cc7b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
