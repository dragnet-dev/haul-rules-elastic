// Dragnet [Ransomware]: dragnet-ransomware-2026-3506 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1e372547-d8fc-5265-92a5-530d2c20e983

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
