// Dragnet [Ransomware]: dragnet-ransomware-2026-2071 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 05352557-604c-503d-a4ea-821b94bf840b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
