// Dragnet [Ransomware]: dragnet-ransomware-2026-2855 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 6fdb5b4f-e940-592d-8919-83454fa74d69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
