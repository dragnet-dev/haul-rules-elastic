// Dragnet [Ransomware]: dragnet-ransomware-2026-1835 — Recovery Inhibition (benzona)
// Status: deprecated | Level: high | ID: 1a9ec025-fc04-510c-95c1-943b8069647a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
