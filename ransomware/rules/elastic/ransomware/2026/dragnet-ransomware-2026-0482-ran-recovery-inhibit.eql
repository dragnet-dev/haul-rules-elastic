// Dragnet [Ransomware]: dragnet-ransomware-2026-0482 — Recovery Inhibition (m3rx)
// Status: stable | Level: high | ID: 03a6a4da-4b05-5d3d-be5f-c3e67f9dd431

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
