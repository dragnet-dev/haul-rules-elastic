// Dragnet [Ransomware]: dragnet-ransomware-2026-2843 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 0ef88383-1a72-577c-ac5d-af7d47c3cf33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
