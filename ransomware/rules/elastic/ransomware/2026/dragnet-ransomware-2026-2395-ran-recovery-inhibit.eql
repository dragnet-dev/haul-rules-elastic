// Dragnet [Ransomware]: dragnet-ransomware-2026-2395 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 5a8ab17f-4ccf-5c3d-8d33-6f04cfba87e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
