// Dragnet [Ransomware]: dragnet-ransomware-2026-1512 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 8883f990-f670-5823-9b9a-a36e29a0c826

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
