// Dragnet [Ransomware]: dragnet-ransomware-2026-1647 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 379bb6ed-6180-5c1f-ba66-e908369a2ecd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
