// Dragnet [Ransomware]: dragnet-ransomware-2026-0981 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 47b64283-9788-5e3f-b21c-207787f4c241

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
