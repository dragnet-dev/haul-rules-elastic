// Dragnet [Ransomware]: dragnet-ransomware-2026-3373 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: d370c99a-d1d0-579f-879a-748b51308d07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
