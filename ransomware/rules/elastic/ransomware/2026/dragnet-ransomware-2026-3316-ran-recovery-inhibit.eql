// Dragnet [Ransomware]: dragnet-ransomware-2026-3316 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 912bc0c6-83c0-5bff-a230-1428b75aeb67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
