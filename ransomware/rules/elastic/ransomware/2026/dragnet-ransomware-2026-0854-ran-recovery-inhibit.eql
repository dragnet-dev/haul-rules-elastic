// Dragnet [Ransomware]: dragnet-ransomware-2026-0854 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 408fedb6-075e-539f-bdb4-64840eeac097

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
