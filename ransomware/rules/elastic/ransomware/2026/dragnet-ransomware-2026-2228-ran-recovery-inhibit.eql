// Dragnet [Ransomware]: dragnet-ransomware-2026-2228 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 65216ca0-456e-507a-a74c-f6d61ce79240

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
