// Dragnet [Ransomware]: dragnet-ransomware-2026-1652 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 0ffcc912-e872-545d-844a-a41505f336e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
