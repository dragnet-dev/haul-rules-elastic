// Dragnet [Ransomware]: dragnet-ransomware-2026-2192 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 615b83f1-0635-57cb-be6b-002179935b18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
