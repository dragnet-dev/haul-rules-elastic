// Dragnet [Ransomware]: dragnet-ransomware-2026-0590 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 63292fda-afe5-5fb9-a9be-18d7adfb957d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
