// Dragnet [Ransomware]: dragnet-ransomware-2026-1480 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: c07271af-aa1d-5317-a7f2-5d4ddc8466a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
