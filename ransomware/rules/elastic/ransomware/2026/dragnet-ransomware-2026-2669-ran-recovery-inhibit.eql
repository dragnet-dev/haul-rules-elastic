// Dragnet [Ransomware]: dragnet-ransomware-2026-2669 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 1d753bee-7d12-5bed-8da6-ae40dd185d82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
