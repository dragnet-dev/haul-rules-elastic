// Dragnet [Ransomware]: dragnet-ransomware-2026-2433 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: dde6a2e1-ea78-5bc9-9ba0-5c3b8fdcbf36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
