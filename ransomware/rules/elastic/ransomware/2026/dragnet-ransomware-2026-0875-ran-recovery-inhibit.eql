// Dragnet [Ransomware]: dragnet-ransomware-2026-0875 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: a70457f3-63cb-5639-bb5f-855dfa02f6db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
