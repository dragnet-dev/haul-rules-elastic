// Dragnet [Ransomware]: dragnet-ransomware-2026-1945 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 61fd3ad4-13e9-51ed-878f-39fac2ba2af9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
