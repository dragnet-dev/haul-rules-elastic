// Dragnet [Ransomware]: dragnet-ransomware-2026-2308 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d55538f3-c386-5f25-a0d3-e1a817aed8e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
