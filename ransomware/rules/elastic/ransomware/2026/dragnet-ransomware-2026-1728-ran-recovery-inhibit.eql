// Dragnet [Ransomware]: dragnet-ransomware-2026-1728 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 4eae2d98-dc8e-566c-a422-998de5b755ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
