// Dragnet [Ransomware]: dragnet-ransomware-2026-3183 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 6d342a33-bfb4-5648-921e-742372cfb501

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
