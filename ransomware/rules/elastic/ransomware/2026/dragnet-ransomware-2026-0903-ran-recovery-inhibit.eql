// Dragnet [Ransomware]: dragnet-ransomware-2026-0903 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 39b97dd6-1eb3-5719-871d-f10dbc1d7e69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
