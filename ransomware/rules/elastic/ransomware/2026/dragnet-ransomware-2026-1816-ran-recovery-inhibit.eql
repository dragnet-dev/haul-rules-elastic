// Dragnet [Ransomware]: dragnet-ransomware-2026-1816 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 53c6e311-a807-52d7-af35-b09110e1a884

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
