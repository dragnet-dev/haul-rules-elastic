// Dragnet [Ransomware]: dragnet-ransomware-2026-2749 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: ba4849d9-4961-53fa-98f3-c62ed0153aa6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
