// Dragnet [Ransomware]: dragnet-ransomware-2026-2065 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 08131222-7e53-5dd1-a1f5-66b826153f92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
