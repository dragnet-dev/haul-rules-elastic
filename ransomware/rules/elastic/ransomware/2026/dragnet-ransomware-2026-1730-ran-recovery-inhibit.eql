// Dragnet [Ransomware]: dragnet-ransomware-2026-1730 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: d9a8a212-09db-53bd-9ecd-966bd607c7a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
