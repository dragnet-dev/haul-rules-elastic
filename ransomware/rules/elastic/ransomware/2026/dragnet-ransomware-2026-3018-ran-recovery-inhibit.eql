// Dragnet [Ransomware]: dragnet-ransomware-2026-3018 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: f3be0904-8891-5ebb-b46c-c5ab8274a919

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
