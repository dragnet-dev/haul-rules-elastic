// Dragnet [Ransomware]: dragnet-ransomware-2026-1124 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 8cdb4c60-cc68-5256-a440-a754cd1dc597

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
