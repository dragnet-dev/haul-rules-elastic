// Dragnet [Ransomware]: dragnet-ransomware-2026-1195 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a9026f8b-79d3-589f-a2b5-7c93b8e0772d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
