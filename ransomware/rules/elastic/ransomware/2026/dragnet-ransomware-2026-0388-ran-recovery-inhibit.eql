// Dragnet [Ransomware]: dragnet-ransomware-2026-0388 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: f915cd61-6530-5e18-978b-e35f4933d48e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
