// Dragnet [Ransomware]: dragnet-ransomware-2026-1525 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 78280e72-5851-568e-b8e6-918e8f713a35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
