// Dragnet [Ransomware]: dragnet-ransomware-2026-1165 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: c80f95ed-a5ca-53fa-b32f-d6ba161329b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
