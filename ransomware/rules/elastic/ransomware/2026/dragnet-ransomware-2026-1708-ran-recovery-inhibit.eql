// Dragnet [Ransomware]: dragnet-ransomware-2026-1708 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 968b8c55-ad0c-51f3-9cd9-e01bb93e2d92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
