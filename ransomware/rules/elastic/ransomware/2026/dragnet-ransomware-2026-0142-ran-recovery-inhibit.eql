// Dragnet [Ransomware]: dragnet-ransomware-2026-0142 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: cf5bb6c2-f226-592c-a848-a6f18cdfd6c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
