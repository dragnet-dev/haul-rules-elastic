// Dragnet [Ransomware]: dragnet-ransomware-2026-2715 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: fd79ae24-4ab5-56ca-98f7-cb57fc0f1ccf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
