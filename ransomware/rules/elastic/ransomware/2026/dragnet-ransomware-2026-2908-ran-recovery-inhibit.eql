// Dragnet [Ransomware]: dragnet-ransomware-2026-2908 — Recovery Inhibition (insomnia)
// Status: stable | Level: high | ID: d364fa40-9739-5059-b13e-c65ae0817e5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
