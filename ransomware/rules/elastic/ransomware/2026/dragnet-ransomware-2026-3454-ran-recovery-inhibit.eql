// Dragnet [Ransomware]: dragnet-ransomware-2026-3454 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 4b405e5c-c3ed-55fd-9255-d9108912caca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
