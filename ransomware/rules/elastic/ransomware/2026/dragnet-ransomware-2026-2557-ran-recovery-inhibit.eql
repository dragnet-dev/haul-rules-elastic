// Dragnet [Ransomware]: dragnet-ransomware-2026-2557 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: b9c4b0be-c42f-5d87-843e-487b70c1dfe9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
