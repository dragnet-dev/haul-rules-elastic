// Dragnet [Ransomware]: dragnet-ransomware-2026-0995 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0ef2237d-6e10-5f68-aefc-eeefe8bafdd7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
