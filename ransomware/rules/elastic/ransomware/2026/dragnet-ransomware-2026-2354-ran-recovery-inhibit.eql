// Dragnet [Ransomware]: dragnet-ransomware-2026-2354 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: a160afb2-9b06-5374-b09a-42f573956299

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
