// Dragnet [Ransomware]: dragnet-ransomware-2026-0694 — Recovery Inhibition (insomnia)
// Status: test | Level: high | ID: 4e96621d-670a-588c-bc30-b3b9621b2dcd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
