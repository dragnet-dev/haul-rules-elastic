// Dragnet [Ransomware]: dragnet-ransomware-2026-2676 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 24d9231f-24de-544b-a5d2-22d23bcf167a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
