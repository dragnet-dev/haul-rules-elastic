// Dragnet [Ransomware]: dragnet-ransomware-2026-1912 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 79d62c40-4bf0-5936-a120-8f1a1b444d0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
