// Dragnet [Ransomware]: dragnet-ransomware-2026-3109 — Recovery Inhibition (beast)
// Status: test | Level: high | ID: beb317d4-79ef-5244-9166-3571fb979dcb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
