// Dragnet [Ransomware]: dragnet-ransomware-2026-0747 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 98fe6071-2c96-5219-8e95-18f1acde1f60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
