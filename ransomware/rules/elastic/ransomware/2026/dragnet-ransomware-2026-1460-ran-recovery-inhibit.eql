// Dragnet [Ransomware]: dragnet-ransomware-2026-1460 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 735b271c-0a8a-5e7a-b14c-68fd71b3c106

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
