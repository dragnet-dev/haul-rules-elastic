// Dragnet [Ransomware]: dragnet-ransomware-2026-0041 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: 4863c082-d03f-51a5-8e19-6754ec3767b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
