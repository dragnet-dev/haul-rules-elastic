// Dragnet [Ransomware]: dragnet-ransomware-2026-0364 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: bc372309-20c5-547f-8a04-64734aec78bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
