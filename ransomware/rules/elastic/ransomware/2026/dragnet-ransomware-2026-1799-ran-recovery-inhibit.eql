// Dragnet [Ransomware]: dragnet-ransomware-2026-1799 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 7d6ff39a-9e77-53d6-b6cf-2d7bb8d690c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
