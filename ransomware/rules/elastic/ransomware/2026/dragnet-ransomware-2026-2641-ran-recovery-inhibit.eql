// Dragnet [Ransomware]: dragnet-ransomware-2026-2641 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: ccb252d9-135a-5936-b53d-04dc11557e02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
