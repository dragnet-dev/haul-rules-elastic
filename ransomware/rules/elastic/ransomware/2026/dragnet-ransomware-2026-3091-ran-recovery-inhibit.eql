// Dragnet [Ransomware]: dragnet-ransomware-2026-3091 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: dfc7a96d-1d7e-5e8b-a3db-0eaffd991451

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
