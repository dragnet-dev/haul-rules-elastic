// Dragnet [Ransomware]: dragnet-ransomware-2026-2206 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 18b9ef25-85eb-58cf-898c-aaaeee7dcdc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
