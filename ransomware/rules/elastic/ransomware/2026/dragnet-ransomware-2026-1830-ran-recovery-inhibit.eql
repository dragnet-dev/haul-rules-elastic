// Dragnet [Ransomware]: dragnet-ransomware-2026-1830 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 9265cf6b-bb53-5114-af02-ab46c9e5a09d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
