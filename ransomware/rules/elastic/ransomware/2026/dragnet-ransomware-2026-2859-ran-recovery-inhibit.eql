// Dragnet [Ransomware]: dragnet-ransomware-2026-2859 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: e3e43c9e-fb3a-54b3-b889-d22c16f37482

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
