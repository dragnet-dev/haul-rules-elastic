// Dragnet [Ransomware]: dragnet-ransomware-2026-1771 — Recovery Inhibition (lapsus$)
// Status: deprecated | Level: high | ID: 480b5ba2-adf9-5321-8adb-2700a15a092d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
