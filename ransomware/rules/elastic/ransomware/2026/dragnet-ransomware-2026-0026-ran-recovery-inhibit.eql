// Dragnet [Ransomware]: dragnet-ransomware-2026-0026 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: b13d0558-ceae-51c9-a29f-e32fc38eef79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
