// Dragnet [Ransomware]: dragnet-ransomware-2026-1185 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: cf2ede06-c169-51b0-833f-7b1fd7f6e678

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
