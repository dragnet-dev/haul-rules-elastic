// Dragnet [Ransomware]: dragnet-ransomware-2026-1532 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 5709f4df-fea8-5077-9110-7317feb7d702

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
