// Dragnet [Ransomware]: dragnet-ransomware-2026-0036 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 7a5b6692-03b4-5f53-bcb5-7180e717a85f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
