// Dragnet [Ransomware]: dragnet-ransomware-2026-1739 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: a7825fb1-f551-5cd6-925d-62b0fc944979

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
