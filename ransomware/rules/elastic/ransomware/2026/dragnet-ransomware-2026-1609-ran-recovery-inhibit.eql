// Dragnet [Ransomware]: dragnet-ransomware-2026-1609 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 36ca552a-9e3f-5239-82c1-5929b6cb0c15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
