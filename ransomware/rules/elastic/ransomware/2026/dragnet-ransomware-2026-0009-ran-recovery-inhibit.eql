// Dragnet [Ransomware]: dragnet-ransomware-2026-0009 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: a2e5de52-3ade-547d-81ed-ecf0cc907044

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
