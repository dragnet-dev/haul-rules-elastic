// Dragnet [Ransomware]: dragnet-ransomware-2026-2572 — Recovery Inhibition (chaos)
// Status: stable | Level: high | ID: f932999d-0271-5330-95c6-9491162680d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
