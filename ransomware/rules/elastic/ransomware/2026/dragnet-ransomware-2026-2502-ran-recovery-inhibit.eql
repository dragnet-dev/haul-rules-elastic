// Dragnet [Ransomware]: dragnet-ransomware-2026-2502 — Recovery Inhibition (termite)
// Status: stable | Level: high | ID: 12fba38a-6ce9-5741-a140-cc94961e3d38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
