// Dragnet [Ransomware]: dragnet-ransomware-2026-0516 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: a21960c4-cc41-5e7c-b18a-3f63d5af58bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
