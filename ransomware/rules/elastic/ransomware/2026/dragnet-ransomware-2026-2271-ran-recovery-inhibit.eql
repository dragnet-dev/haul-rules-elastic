// Dragnet [Ransomware]: dragnet-ransomware-2026-2271 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: a01e42db-314b-5473-bdb2-acfc284f187e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
