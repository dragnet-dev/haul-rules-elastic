// Dragnet [Ransomware]: dragnet-ransomware-2026-0576 — Recovery Inhibition (nova)
// Status: stable | Level: high | ID: a0019a71-6b82-589a-9121-6c39435e3f5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
