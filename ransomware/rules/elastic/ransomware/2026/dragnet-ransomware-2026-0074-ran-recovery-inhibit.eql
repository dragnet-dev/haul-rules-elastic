// Dragnet [Ransomware]: dragnet-ransomware-2026-0074 — Recovery Inhibition (cipherforce)
// Status: stable | Level: high | ID: 86fce352-9a51-5614-8b0c-447d041915c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
