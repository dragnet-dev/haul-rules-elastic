// Dragnet [Ransomware]: dragnet-ransomware-2026-2949 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 8c2cebaa-d428-5b06-a7d4-526c74e5d148

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
