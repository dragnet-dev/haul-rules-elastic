// Dragnet [Ransomware]: dragnet-ransomware-2026-1806 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: c858f320-0073-5bff-8f21-f0150b4620e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
