// Dragnet [Ransomware]: dragnet-ransomware-2026-2942 — Recovery Inhibition (spacebears)
// Status: test | Level: high | ID: 67af7108-b275-594a-999b-ae3bd9a88033

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
