// Dragnet [Ransomware]: dragnet-ransomware-2026-2924 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 8895e02d-7f0e-5486-a65d-1f4c501003e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
