// Dragnet [Ransomware]: dragnet-ransomware-2026-1759 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 4492caa5-56cf-56f7-8a4e-aefb58391d29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
