// Dragnet [Ransomware]: dragnet-ransomware-2026-3158 — Recovery Inhibition (sinobi)
// Status: stable | Level: high | ID: 524207fc-6ae2-54a5-8fa2-343a3bee8ac3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
