// Dragnet [Ransomware]: dragnet-ransomware-2026-3448 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: e4b92cb5-cea3-5600-8628-7cf3ca8aaa3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
