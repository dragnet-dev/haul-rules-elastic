// Dragnet [Ransomware]: dragnet-ransomware-2026-1130 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 95278036-317b-53fc-a91b-ed1f5340833a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
