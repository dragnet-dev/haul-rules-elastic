// Dragnet [Ransomware]: dragnet-ransomware-2026-0255 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 87da5b88-5b01-54be-8e05-03b5f285201c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
