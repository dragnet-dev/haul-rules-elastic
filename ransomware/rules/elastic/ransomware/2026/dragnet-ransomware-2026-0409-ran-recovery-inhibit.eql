// Dragnet [Ransomware]: dragnet-ransomware-2026-0409 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: a4bfd137-7127-5cfd-bc4f-8b30fdd03a81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
