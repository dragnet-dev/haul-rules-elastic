// Dragnet [Ransomware]: dragnet-ransomware-2026-1146 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 6062741c-34e1-5609-80a7-e8bd3f09ce70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
