// Dragnet [Ransomware]: dragnet-ransomware-2026-1558 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 1e16ee5f-4ece-5293-9f27-24bab4bbc372

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
