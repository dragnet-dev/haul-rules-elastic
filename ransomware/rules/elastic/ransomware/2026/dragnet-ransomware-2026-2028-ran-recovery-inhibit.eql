// Dragnet [Ransomware]: dragnet-ransomware-2026-2028 — Recovery Inhibition (nova)
// Status: stable | Level: high | ID: 50c11037-08c2-580f-a94b-607010683d96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
