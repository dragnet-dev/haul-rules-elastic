// Dragnet [Ransomware]: dragnet-ransomware-2026-0470 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 91b27d38-10e2-51db-af0c-102efd08413f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
