// Dragnet [Ransomware]: dragnet-ransomware-2026-0842 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: d325a82a-f53a-5df7-ae16-ee30057abea3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
