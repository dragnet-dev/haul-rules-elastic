// Dragnet [Ransomware]: dragnet-ransomware-2026-0630 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d76b6c7e-f1f5-51c7-b17d-f7267df02b41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
