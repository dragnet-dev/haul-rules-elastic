// Dragnet [Ransomware]: dragnet-ransomware-2026-3282 — Recovery Inhibition (krybit)
// Status: stable | Level: high | ID: 765711da-66b8-521e-8dc8-799212a22646

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
