// Dragnet [Ransomware]: dragnet-ransomware-2026-2356 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 19df54d7-f182-5e65-8ba8-3a3fbadf4667

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
