// Dragnet [Ransomware]: dragnet-ransomware-2026-3462 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 19b794a6-8da1-5ac9-a2dc-7c15d826d0ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
