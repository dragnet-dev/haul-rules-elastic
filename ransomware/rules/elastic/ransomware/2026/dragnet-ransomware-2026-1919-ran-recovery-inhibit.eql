// Dragnet [Ransomware]: dragnet-ransomware-2026-1919 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 7cd6a753-c09e-544c-b43d-50252385149a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
