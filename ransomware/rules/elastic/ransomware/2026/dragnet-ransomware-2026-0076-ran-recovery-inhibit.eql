// Dragnet [Ransomware]: dragnet-ransomware-2026-0076 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: e62322ba-dacf-5156-aaf3-bb494eb1115c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
