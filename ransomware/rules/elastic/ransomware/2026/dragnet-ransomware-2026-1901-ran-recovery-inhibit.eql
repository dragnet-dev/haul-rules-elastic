// Dragnet [Ransomware]: dragnet-ransomware-2026-1901 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: b7035a33-8ee9-5e6b-a997-2ddad1bd33c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
