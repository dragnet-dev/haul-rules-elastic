// Dragnet [Ransomware]: dragnet-ransomware-2026-2686 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 41204536-1b5d-5756-8aeb-e775c3814e7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
