// Dragnet [Ransomware]: dragnet-ransomware-2026-0397 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 7c14c9c3-7afe-5b99-b650-6fdf1aef25d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
