// Dragnet [Ransomware]: dragnet-ransomware-2026-2187 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 35193b7b-c819-5596-8f6c-f97d0635049b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
