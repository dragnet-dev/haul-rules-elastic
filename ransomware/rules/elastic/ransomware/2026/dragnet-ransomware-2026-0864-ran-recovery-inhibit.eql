// Dragnet [Ransomware]: dragnet-ransomware-2026-0864 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 3bf08929-43e2-5a27-ac37-9a209c44a15f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
