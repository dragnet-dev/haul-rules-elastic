// Dragnet [Ransomware]: dragnet-ransomware-2026-0289 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: 6ccf27ad-2716-57b2-91c2-0f4c04344479

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
