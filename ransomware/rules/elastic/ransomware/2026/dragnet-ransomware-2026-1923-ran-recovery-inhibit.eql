// Dragnet [Ransomware]: dragnet-ransomware-2026-1923 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0bb21971-e2f9-54f0-9588-e06aab2ebc92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
