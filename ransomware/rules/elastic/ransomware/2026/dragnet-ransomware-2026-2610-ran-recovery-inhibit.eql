// Dragnet [Ransomware]: dragnet-ransomware-2026-2610 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: acb558d8-9154-51c0-8025-09b76847b649

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
