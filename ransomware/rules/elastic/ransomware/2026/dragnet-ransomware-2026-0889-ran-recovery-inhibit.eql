// Dragnet [Ransomware]: dragnet-ransomware-2026-0889 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 29349179-3f73-53b7-a1ec-f962e46b0af7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
