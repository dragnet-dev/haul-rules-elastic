// Dragnet [Ransomware]: dragnet-ransomware-2026-2911 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 358aa0cd-25c0-5da0-93fe-ef05034d7eda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
