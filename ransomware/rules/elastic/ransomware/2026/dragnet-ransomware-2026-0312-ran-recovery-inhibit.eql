// Dragnet [Ransomware]: dragnet-ransomware-2026-0312 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: e904d68b-9c08-5583-b1b6-ba377ad22ba5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
