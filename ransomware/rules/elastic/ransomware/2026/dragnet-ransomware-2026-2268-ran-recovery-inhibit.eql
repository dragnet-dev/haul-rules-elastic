// Dragnet [Ransomware]: dragnet-ransomware-2026-2268 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 0d41a5ab-f4a0-562b-b8e1-aaef70ef2b51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
