// Dragnet [Ransomware]: dragnet-ransomware-2026-1491 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 89b6724f-1661-5068-b7c0-f6093c904193

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
