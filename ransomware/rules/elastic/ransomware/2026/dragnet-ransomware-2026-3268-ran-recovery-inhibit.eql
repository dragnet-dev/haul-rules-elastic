// Dragnet [Ransomware]: dragnet-ransomware-2026-3268 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 93173f96-888c-5028-8a7a-c2d2ee50098e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
