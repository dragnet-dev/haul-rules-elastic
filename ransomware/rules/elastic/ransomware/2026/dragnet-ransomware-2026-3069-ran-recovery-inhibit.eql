// Dragnet [Ransomware]: dragnet-ransomware-2026-3069 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: fcf39472-3ffd-5eb2-9900-2491cd33e7a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
