// Dragnet [Ransomware]: dragnet-ransomware-2026-3546 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 0f5f7c77-bbd5-5ef0-be7b-0582908255f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
