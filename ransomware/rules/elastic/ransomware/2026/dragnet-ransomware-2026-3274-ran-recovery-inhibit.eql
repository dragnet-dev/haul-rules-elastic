// Dragnet [Ransomware]: dragnet-ransomware-2026-3274 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 44b73c03-05e8-5a9c-9c4d-461f86d3c9a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
