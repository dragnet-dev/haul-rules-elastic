// Dragnet [Ransomware]: dragnet-ransomware-2026-0073 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: 28196001-5918-5277-8795-90bb947d0aa3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
