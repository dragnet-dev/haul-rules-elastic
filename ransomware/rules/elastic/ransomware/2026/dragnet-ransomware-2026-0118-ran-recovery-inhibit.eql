// Dragnet [Ransomware]: dragnet-ransomware-2026-0118 — Recovery Inhibition (termite)
// Status: stable | Level: high | ID: c64c1893-e000-5be8-8334-b2851af842d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
