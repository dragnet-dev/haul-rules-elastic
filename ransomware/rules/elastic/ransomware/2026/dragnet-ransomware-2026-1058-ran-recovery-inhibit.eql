// Dragnet [Ransomware]: dragnet-ransomware-2026-1058 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: dc7b1c54-7367-57f2-8011-0c33082f1124

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
