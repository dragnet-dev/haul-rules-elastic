// Dragnet [Ransomware]: dragnet-ransomware-2026-0490 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: d249c45a-22db-57d9-b551-3cc966d783b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
