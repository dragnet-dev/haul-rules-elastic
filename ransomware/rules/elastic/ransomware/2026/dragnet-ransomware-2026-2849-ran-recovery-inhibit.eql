// Dragnet [Ransomware]: dragnet-ransomware-2026-2849 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: af9c1668-59b7-5579-b035-8349aff4bd5e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
