// Dragnet [Ransomware]: dragnet-ransomware-2026-1745 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 2cf39c33-e69a-5760-982f-72e3d1bf9be7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
