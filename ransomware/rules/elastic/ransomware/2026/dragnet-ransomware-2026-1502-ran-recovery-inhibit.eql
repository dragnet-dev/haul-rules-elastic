// Dragnet [Ransomware]: dragnet-ransomware-2026-1502 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: f8195246-71c2-5fff-8807-d75ad69fbd55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
