// Dragnet [Ransomware]: dragnet-ransomware-2026-2811 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: f2f26aa7-1be0-523d-bccd-afefd59fc15a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
