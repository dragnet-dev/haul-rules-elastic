// Dragnet [Ransomware]: dragnet-ransomware-2026-0227 — Recovery Inhibition (aurora)
// Status: stable | Level: high | ID: f8bfb6ec-2b3d-5f30-ac59-574250f13bbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
