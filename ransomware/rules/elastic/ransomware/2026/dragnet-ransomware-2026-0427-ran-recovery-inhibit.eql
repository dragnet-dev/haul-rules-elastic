// Dragnet [Ransomware]: dragnet-ransomware-2026-0427 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 3921a968-97cb-57f2-80e5-69b4d93c7958

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
