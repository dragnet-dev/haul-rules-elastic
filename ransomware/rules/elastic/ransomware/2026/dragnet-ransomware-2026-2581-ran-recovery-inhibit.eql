// Dragnet [Ransomware]: dragnet-ransomware-2026-2581 — Recovery Inhibition (beast)
// Status: test | Level: high | ID: 813cc71b-5917-5af4-8a7d-8e91a6ec85e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
