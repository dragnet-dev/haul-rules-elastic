// Dragnet [Ransomware]: dragnet-ransomware-2026-2729 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: f9516e16-9475-5e16-b51e-128ab7936047

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
