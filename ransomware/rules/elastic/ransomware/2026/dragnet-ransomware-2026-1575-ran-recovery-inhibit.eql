// Dragnet [Ransomware]: dragnet-ransomware-2026-1575 — Recovery Inhibition (embargo)
// Status: stable | Level: high | ID: 070d68df-5115-586f-acad-aed9fcfeecf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
