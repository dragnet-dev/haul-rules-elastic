// Dragnet [Ransomware]: dragnet-ransomware-2026-3346 — Recovery Inhibition (ALP-001)
// Status: stable | Level: high | ID: 236de0e4-3430-5bf3-9a66-3516dab6adb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
