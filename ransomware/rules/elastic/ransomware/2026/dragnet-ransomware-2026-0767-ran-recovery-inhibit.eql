// Dragnet [Ransomware]: dragnet-ransomware-2026-0767 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: f94b77ec-c0d0-595f-b371-2699429a003b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
