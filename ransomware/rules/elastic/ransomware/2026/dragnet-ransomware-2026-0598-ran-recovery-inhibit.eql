// Dragnet [Ransomware]: dragnet-ransomware-2026-0598 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 6df082d5-ba3e-53b4-9206-a77527982bd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
