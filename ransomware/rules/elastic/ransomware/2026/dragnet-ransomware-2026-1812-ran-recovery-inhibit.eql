// Dragnet [Ransomware]: dragnet-ransomware-2026-1812 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b01fdb21-f2e7-5ba5-9c4f-c5cbf0389652

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
