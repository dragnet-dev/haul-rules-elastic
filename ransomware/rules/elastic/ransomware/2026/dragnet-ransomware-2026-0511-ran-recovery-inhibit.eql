// Dragnet [Ransomware]: dragnet-ransomware-2026-0511 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 7211f420-5406-5e54-99fc-e89c242acf81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
