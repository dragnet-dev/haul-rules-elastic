// Dragnet [Ransomware]: dragnet-ransomware-2026-2466 — Recovery Inhibition (BrainCipher)
// Status: stable | Level: high | ID: e22307b1-5807-5017-a5e5-4b99499f6645

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
