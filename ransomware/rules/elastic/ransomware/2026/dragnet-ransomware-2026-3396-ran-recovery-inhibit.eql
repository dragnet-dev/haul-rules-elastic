// Dragnet [Ransomware]: dragnet-ransomware-2026-3396 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: b259502a-8acf-5445-aea7-a63af149d976

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
