// Dragnet [Ransomware]: dragnet-ransomware-2026-1541 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 545711c1-fe6d-5a81-9381-88cee31cef85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
