// Dragnet [Ransomware]: dragnet-ransomware-2026-2752 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 90370277-e91f-55e1-8813-c9c7df91a264

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
