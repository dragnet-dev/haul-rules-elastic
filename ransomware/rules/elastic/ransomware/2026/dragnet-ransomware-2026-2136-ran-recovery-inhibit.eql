// Dragnet [Ransomware]: dragnet-ransomware-2026-2136 — Recovery Inhibition (worldleaks)
// Status: test | Level: high | ID: 868917ef-c5d8-5eb4-918f-69b1c7d6b905

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
