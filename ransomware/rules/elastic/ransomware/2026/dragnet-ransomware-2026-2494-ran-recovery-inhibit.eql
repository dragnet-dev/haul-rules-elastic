// Dragnet [Ransomware]: dragnet-ransomware-2026-2494 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 26b7f287-7619-5124-a030-6231126ab605

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
