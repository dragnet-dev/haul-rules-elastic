// Dragnet [Ransomware]: dragnet-ransomware-2026-0091 — Recovery Inhibition (genesis)
// Status: stable | Level: high | ID: fa402a2b-e225-5223-a0a8-d777a7c9d36c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
