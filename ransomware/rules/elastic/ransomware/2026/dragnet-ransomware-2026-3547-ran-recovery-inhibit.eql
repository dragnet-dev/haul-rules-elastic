// Dragnet [Ransomware]: dragnet-ransomware-2026-3547 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: cb593a06-3bd6-5fb6-ac8f-28d2675005b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
