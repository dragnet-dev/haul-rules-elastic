// Dragnet [Ransomware]: dragnet-ransomware-2026-3217 — Recovery Inhibition (pear)
// Status: stable | Level: high | ID: 7c24471a-0525-5a3a-bd57-f859ff6688a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
