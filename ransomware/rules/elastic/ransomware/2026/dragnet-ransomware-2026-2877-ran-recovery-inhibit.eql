// Dragnet [Ransomware]: dragnet-ransomware-2026-2877 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: e66a48c0-578d-5b4b-a7c0-4de2cb3c0040

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
