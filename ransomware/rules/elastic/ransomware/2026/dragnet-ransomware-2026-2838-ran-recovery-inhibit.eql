// Dragnet [Ransomware]: dragnet-ransomware-2026-2838 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 15b4102b-bbc6-574f-b44a-a3675aa9483e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
