// Dragnet [Ransomware]: dragnet-ransomware-2026-0906 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 3203e5e3-ad3e-5dce-8517-3279ce5eef95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
