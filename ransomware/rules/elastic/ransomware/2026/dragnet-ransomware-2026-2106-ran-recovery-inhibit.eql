// Dragnet [Ransomware]: dragnet-ransomware-2026-2106 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 4fff454a-e57f-595a-bc59-80fbc1411721

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
