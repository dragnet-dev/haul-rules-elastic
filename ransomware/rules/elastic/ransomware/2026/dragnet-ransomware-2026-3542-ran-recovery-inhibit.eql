// Dragnet [Ransomware]: dragnet-ransomware-2026-3542 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 47497054-57e0-593e-a747-8b2950c1d327

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
