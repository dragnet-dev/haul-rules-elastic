// Dragnet [Ransomware]: dragnet-ransomware-2026-0131 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: a5be5d54-54c6-566f-adf7-87cf77fe337c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
