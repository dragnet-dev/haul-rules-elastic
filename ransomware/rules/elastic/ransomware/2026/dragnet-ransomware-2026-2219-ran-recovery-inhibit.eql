// Dragnet [Ransomware]: dragnet-ransomware-2026-2219 — Recovery Inhibition (lynx)
// Status: stable | Level: high | ID: 4dc1a329-9c9f-5b92-823c-24ea212953e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
