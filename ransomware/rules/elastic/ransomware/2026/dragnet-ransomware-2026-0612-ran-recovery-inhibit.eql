// Dragnet [Ransomware]: dragnet-ransomware-2026-0612 — Recovery Inhibition (payoutsking)
// Status: test | Level: high | ID: 42da1533-e14f-56dd-a21d-827e278b6c96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
