// Dragnet [Ransomware]: dragnet-ransomware-2026-2945 — Recovery Inhibition (genesis)
// Status: stable | Level: high | ID: d1df9b50-4c33-5a19-bbc4-1f1795a860d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
