// Dragnet [Ransomware]: dragnet-ransomware-2026-1388 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 29897333-f561-50a0-a5cd-83feacc081b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
