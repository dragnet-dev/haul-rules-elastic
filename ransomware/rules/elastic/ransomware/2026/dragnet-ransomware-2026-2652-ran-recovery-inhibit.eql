// Dragnet [Ransomware]: dragnet-ransomware-2026-2652 — Recovery Inhibition (m3rx)
// Status: stable | Level: high | ID: 8a6238f0-d821-52c2-80a5-6bcc1bc5c1e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
