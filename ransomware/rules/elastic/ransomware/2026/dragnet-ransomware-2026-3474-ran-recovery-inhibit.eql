// Dragnet [Ransomware]: dragnet-ransomware-2026-3474 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6697a011-1a23-509d-a552-2acce73092f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
