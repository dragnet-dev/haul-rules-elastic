// Dragnet [Ransomware]: dragnet-ransomware-2026-0489 — Recovery Inhibition (vect)
// Status: deprecated | Level: high | ID: 6ce415d5-e05a-5c1d-8353-855c12cb16de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
