// Dragnet [Ransomware]: dragnet-ransomware-2026-1922 — Recovery Inhibition (cipherforce)
// Status: stable | Level: high | ID: 81a60b63-686f-5bc3-a030-058851d98e51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
