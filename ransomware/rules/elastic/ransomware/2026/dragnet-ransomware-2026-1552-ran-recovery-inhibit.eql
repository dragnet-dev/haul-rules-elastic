// Dragnet [Ransomware]: dragnet-ransomware-2026-1552 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 8e25f8ca-ae57-5125-bb85-5d208807229d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
