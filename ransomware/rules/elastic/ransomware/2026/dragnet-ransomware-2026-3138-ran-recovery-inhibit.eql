// Dragnet [Ransomware]: dragnet-ransomware-2026-3138 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 6c03cb25-1304-5daf-a9e4-83ead45e182e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
