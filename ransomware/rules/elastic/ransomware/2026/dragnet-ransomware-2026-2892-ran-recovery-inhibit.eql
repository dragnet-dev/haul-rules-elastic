// Dragnet [Ransomware]: dragnet-ransomware-2026-2892 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 0c602b72-6fde-5da3-98c8-14d08c976029

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
