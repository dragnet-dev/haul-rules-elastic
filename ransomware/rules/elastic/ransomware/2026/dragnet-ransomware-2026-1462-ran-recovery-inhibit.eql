// Dragnet [Ransomware]: dragnet-ransomware-2026-1462 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 2b7d2908-2e41-5d35-b3d5-c1548dcf1c6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
