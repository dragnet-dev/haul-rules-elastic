// Dragnet [Ransomware]: dragnet-ransomware-2026-1543 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: cae4c28e-55dc-52fd-a507-8251b628a529

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
