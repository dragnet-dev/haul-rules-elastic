// Dragnet [Ransomware]: dragnet-ransomware-2026-0540 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 3360fc4b-0972-5447-b9e4-5e354f23bcae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
