// Dragnet [Ransomware]: dragnet-ransomware-2026-2221 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 373ff81b-2509-51e1-919f-06bcc4e09c54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
