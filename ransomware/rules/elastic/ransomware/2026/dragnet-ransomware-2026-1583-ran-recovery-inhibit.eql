// Dragnet [Ransomware]: dragnet-ransomware-2026-1583 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: c2c6a156-c959-5554-b9a6-278370737a7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
