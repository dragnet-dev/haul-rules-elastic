// Dragnet [Ransomware]: dragnet-ransomware-2026-0443 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 5ca122a8-ba43-5409-9bc9-6735ff4f9688

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
