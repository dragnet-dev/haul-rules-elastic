// Dragnet [Ransomware]: dragnet-ransomware-2026-0347 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 660d6d4e-064c-5c48-9ab5-53672ddfc2c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
