// Dragnet [Ransomware]: dragnet-ransomware-2026-3535 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: bae77049-c345-58c3-afcf-32ca6a523218

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
