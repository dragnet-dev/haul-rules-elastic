// Dragnet [Ransomware]: dragnet-ransomware-2026-3304 — Recovery Inhibition (vect)
// Status: deprecated | Level: high | ID: b6cc2ce2-0784-58f7-9713-85a9cfa8287a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
