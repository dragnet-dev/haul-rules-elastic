// Dragnet [Ransomware]: dragnet-ransomware-2026-1859 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: c032a0a3-4ef8-5ba7-ba6c-ccc9149415da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
