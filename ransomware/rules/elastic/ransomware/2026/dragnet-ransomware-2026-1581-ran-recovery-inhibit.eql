// Dragnet [Ransomware]: dragnet-ransomware-2026-1581 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 17c2112b-54ae-5447-bc03-978a743cfd8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
