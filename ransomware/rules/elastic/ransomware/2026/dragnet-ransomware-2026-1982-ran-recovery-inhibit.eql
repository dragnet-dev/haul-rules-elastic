// Dragnet [Ransomware]: dragnet-ransomware-2026-1982 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: f6b3f1b8-5e8f-56b3-9ad0-1d05d8494842

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
