// Dragnet [Ransomware]: dragnet-ransomware-2026-2907 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: b82d8542-d8b2-5473-8703-845edb36f952

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
