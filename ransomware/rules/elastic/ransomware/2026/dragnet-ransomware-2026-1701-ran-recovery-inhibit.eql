// Dragnet [Ransomware]: dragnet-ransomware-2026-1701 — Recovery Inhibition (orca)
// Status: stable | Level: high | ID: d39c6f3f-616f-5d49-bcf6-354d6d4cd8c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
