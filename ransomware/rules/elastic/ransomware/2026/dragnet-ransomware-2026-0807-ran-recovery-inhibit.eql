// Dragnet [Ransomware]: dragnet-ransomware-2026-0807 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d490ff32-c907-5f01-bd60-fdddcc9f340a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
