// Dragnet [Ransomware]: dragnet-ransomware-2026-2170 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 43656381-928b-5b50-9aa2-b7e2c7b6a438

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
