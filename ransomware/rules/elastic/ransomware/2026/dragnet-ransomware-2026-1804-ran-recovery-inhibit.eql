// Dragnet [Ransomware]: dragnet-ransomware-2026-1804 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 550a49d1-19b7-57ee-8b22-9866a0e7920b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
