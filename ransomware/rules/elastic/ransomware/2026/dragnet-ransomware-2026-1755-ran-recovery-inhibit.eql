// Dragnet [Ransomware]: dragnet-ransomware-2026-1755 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: ad006249-049e-581b-ac4c-d439a08fa29d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
