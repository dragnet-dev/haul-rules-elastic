// Dragnet [Ransomware]: dragnet-ransomware-2026-1793 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 70e50afe-1067-5a96-aa27-76734792395b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
