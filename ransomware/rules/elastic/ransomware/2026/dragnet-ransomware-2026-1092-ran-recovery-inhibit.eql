// Dragnet [Ransomware]: dragnet-ransomware-2026-1092 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 8563554e-f024-59fb-8894-5c8d68e478c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
