// Dragnet [Ransomware]: dragnet-ransomware-2026-1030 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 16a2d66e-35a4-5ae6-96f6-5eec2a0c3dee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
