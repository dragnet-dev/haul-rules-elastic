// Dragnet [Ransomware]: dragnet-ransomware-2026-2728 — Recovery Inhibition (sinobi)
// Status: stable | Level: high | ID: c421ffc1-d40e-5b26-a229-686ae1c5ccc9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
