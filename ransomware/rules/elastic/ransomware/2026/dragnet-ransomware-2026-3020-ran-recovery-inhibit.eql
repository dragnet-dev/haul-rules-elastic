// Dragnet [Ransomware]: dragnet-ransomware-2026-3020 — Recovery Inhibition (TiMc)
// Status: deprecated | Level: high | ID: 7fe601f3-7126-55e4-84e1-3a708ee3f637

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
