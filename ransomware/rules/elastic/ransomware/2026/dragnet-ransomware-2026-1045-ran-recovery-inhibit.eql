// Dragnet [Ransomware]: dragnet-ransomware-2026-1045 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 8480995e-0f35-55a8-b672-ac63e9aff55a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
