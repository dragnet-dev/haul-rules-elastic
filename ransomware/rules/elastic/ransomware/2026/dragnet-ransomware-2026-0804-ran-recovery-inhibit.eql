// Dragnet [Ransomware]: dragnet-ransomware-2026-0804 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 22061cd6-cd93-57ba-ac96-a96f2cc80ac4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
