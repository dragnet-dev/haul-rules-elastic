// Dragnet [Ransomware]: dragnet-ransomware-2026-2816 — Recovery Inhibition (secpo)
// Status: stable | Level: high | ID: 03926c32-2c41-5b89-b772-00c357c69cc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
