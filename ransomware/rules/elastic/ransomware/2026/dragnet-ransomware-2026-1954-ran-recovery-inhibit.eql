// Dragnet [Ransomware]: dragnet-ransomware-2026-1954 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: ab2fb1e7-04d5-5371-aeeb-18881cd90252

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
