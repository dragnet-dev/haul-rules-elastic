// Dragnet [Ransomware]: dragnet-ransomware-2026-0756 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2cb24a1a-21a9-5335-b9d3-8b5831cfa63e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
