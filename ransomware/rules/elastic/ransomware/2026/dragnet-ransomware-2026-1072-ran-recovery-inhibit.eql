// Dragnet [Ransomware]: dragnet-ransomware-2026-1072 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 48e46e62-ca5a-59d8-ada2-b0d5d4fe1601

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
