// Dragnet [Ransomware]: dragnet-ransomware-2026-3165 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 8a1387e6-03dd-5bdc-9cd9-e75dc27d20cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
