// Dragnet [Ransomware]: dragnet-ransomware-2026-0159 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 68cde400-41f3-5d90-afd6-0ecffd1dba9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
