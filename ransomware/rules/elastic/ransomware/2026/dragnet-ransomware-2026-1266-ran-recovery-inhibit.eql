// Dragnet [Ransomware]: dragnet-ransomware-2026-1266 — Recovery Inhibition (pear)
// Status: stable | Level: high | ID: 10258626-7ec0-5a29-939e-18feb1d31970

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
