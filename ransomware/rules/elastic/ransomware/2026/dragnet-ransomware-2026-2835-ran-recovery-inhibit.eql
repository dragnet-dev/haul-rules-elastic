// Dragnet [Ransomware]: dragnet-ransomware-2026-2835 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: fca5234e-e924-5e05-a2f8-35e247817218

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
