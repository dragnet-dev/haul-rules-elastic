// Dragnet [Ransomware]: dragnet-ransomware-2026-2236 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 8971c042-7559-5228-ba52-6700df79961e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
