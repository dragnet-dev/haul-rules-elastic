// Dragnet [Ransomware]: dragnet-ransomware-2026-1276 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: c65d028c-3f98-5483-b53e-048676a1dcd4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
