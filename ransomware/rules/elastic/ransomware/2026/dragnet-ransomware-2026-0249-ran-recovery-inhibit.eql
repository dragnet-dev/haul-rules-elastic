// Dragnet [Ransomware]: dragnet-ransomware-2026-0249 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: ed9aa0fd-b921-55c1-bab0-c8fb56166eca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
