// Dragnet [Ransomware]: dragnet-ransomware-2026-1373 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: f8f13e26-48cc-5b20-b37f-4a2f76369dae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
