// Dragnet [Ransomware]: dragnet-ransomware-2026-0993 — Recovery Inhibition (fulcrumsec)
// Status: stable | Level: high | ID: 1ad97f05-0bc3-5a5a-af9a-424eaf921c93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
