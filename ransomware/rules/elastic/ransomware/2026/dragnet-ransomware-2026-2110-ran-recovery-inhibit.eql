// Dragnet [Ransomware]: dragnet-ransomware-2026-2110 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 3f8af473-d5e3-554f-a0b4-224540decf9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
