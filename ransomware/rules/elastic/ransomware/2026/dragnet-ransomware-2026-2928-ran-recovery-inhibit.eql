// Dragnet [Ransomware]: dragnet-ransomware-2026-2928 — Recovery Inhibition (termite)
// Status: stable | Level: high | ID: e1be8814-b45c-5df0-b983-693434c1462a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
