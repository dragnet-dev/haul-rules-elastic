// Dragnet [Ransomware]: dragnet-ransomware-2026-3012 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 63b98d61-d66f-53c6-84a0-9469950eba30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
