// Dragnet [Ransomware]: dragnet-ransomware-2026-1734 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 05fb6ef3-911d-56f5-a4c0-a8c487e68359

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
