// Dragnet [Ransomware]: dragnet-ransomware-2026-2992 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d8d6362a-f922-57bc-bd65-d86144bcf068

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
