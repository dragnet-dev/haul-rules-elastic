// Dragnet [Ransomware]: dragnet-ransomware-2026-0435 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 6603b078-9649-5084-85e3-8d51fcec57e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
