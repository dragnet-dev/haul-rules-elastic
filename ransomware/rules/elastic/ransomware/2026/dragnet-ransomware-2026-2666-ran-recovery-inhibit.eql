// Dragnet [Ransomware]: dragnet-ransomware-2026-2666 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 080e4a24-8324-59b2-9bcf-6142dea77fce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
