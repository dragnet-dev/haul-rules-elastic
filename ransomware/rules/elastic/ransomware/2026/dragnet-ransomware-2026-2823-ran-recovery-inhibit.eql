// Dragnet [Ransomware]: dragnet-ransomware-2026-2823 — Recovery Inhibition (nitrogen)
// Status: stable | Level: high | ID: b33e910c-595d-501d-9e24-f6364c49091f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
