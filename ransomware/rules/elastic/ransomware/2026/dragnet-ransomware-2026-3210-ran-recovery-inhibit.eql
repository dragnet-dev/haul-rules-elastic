// Dragnet [Ransomware]: dragnet-ransomware-2026-3210 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: d1c9df72-f103-525c-a0cc-c0483235349b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
