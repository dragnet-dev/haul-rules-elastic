// Dragnet [Ransomware]: dragnet-ransomware-2026-3028 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 3f2d7985-bf14-5743-b8cb-87de497e4d12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
