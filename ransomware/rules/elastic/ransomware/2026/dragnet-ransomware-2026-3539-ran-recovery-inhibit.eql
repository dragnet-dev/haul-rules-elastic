// Dragnet [Ransomware]: dragnet-ransomware-2026-3539 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: ef440b33-f887-5f5d-8f70-ad24178bd828

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
