// Dragnet [Ransomware]: dragnet-ransomware-2026-1177 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 59ee3bd0-d781-5734-af3d-31abffef1f39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
