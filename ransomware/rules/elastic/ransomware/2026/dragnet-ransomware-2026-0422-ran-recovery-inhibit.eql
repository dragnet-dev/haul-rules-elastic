// Dragnet [Ransomware]: dragnet-ransomware-2026-0422 — Recovery Inhibition (beast)
// Status: stable | Level: high | ID: 96b5be1c-d6a7-5728-85ee-5386f15664a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
