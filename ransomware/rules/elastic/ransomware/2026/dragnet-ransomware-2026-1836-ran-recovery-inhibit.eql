// Dragnet [Ransomware]: dragnet-ransomware-2026-1836 — Recovery Inhibition (moneymessage)
// Status: test | Level: high | ID: 8a159ab5-8027-50f6-8e56-c74fa6358fc3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
