// Dragnet [Ransomware]: dragnet-ransomware-2026-2079 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: f215f4ec-16bf-59f3-81d4-cb4772129005

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
