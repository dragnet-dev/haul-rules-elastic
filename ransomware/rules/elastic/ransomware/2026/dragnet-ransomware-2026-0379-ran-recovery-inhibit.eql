// Dragnet [Ransomware]: dragnet-ransomware-2026-0379 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 0be445b7-4832-524f-be88-a3916b642eeb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
