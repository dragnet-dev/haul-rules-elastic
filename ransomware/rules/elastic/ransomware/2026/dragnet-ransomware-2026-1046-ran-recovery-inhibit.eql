// Dragnet [Ransomware]: dragnet-ransomware-2026-1046 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: df8cf6b2-ccb0-5f2e-8dfd-345106bbe938

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
