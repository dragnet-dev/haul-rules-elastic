// Dragnet [Ransomware]: dragnet-ransomware-2026-3196 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 19f0dc35-fd99-50a6-83c4-cc58b91938f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
