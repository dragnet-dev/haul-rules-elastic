// Dragnet [Ransomware]: dragnet-ransomware-2026-2084 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 41789426-d7e4-579f-889e-dd5dc5822a1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
