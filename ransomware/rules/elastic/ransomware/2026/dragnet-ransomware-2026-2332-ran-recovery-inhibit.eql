// Dragnet [Ransomware]: dragnet-ransomware-2026-2332 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 263ab11c-906a-5104-a8e2-00b45c2f42b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
