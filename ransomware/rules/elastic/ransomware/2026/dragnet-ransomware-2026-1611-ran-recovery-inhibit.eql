// Dragnet [Ransomware]: dragnet-ransomware-2026-1611 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: d3c71436-4e6b-558e-a07a-f2cceeb54b73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
