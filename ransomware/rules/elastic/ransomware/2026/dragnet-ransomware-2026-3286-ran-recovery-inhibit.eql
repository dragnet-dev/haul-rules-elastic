// Dragnet [Ransomware]: dragnet-ransomware-2026-3286 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 2929dfe8-4528-57dc-ac14-e136a0672cea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
