// Dragnet [Ransomware]: dragnet-ransomware-2026-2958 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 24321f3d-e471-5a90-8985-fc73d1feeb1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
