// Dragnet [Ransomware]: dragnet-ransomware-2026-2828 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 695f4980-2901-593a-80d7-340114211a5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
