// Dragnet [Ransomware]: dragnet-ransomware-2026-0185 — Recovery Inhibition (spacebears)
// Status: test | Level: high | ID: 0909fe24-d7d9-5c61-bd06-93adb1220e37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
