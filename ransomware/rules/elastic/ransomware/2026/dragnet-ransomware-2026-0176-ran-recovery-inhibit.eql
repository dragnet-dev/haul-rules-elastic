// Dragnet [Ransomware]: dragnet-ransomware-2026-0176 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 6e503314-3b5a-5688-91e5-39a42138b2a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
