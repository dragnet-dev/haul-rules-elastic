// Dragnet [Ransomware]: dragnet-ransomware-2026-3442 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 86caf30d-e561-5f7b-99f3-a781f41f93ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
