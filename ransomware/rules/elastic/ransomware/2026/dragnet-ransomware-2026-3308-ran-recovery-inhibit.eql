// Dragnet [Ransomware]: dragnet-ransomware-2026-3308 — Recovery Inhibition (anubis)
// Status: stable | Level: high | ID: 415afbda-7bb0-5b91-b8a9-8054c1939cdf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
