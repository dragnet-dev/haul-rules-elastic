// Dragnet [Ransomware]: dragnet-ransomware-2026-0093 — Recovery Inhibition (interlock)
// Status: test | Level: high | ID: 5fd098c8-a8af-5463-9061-693e5a61bfea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
