// Dragnet [Ransomware]: dragnet-ransomware-2026-2702 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: e62b6360-d54a-560b-a0da-99efc9d06e15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
