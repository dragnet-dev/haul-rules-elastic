// Dragnet [Ransomware]: dragnet-ransomware-2026-2591 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 298c088b-15da-581b-a50f-993b3c83958a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
