// Dragnet [Ransomware]: dragnet-ransomware-2026-2168 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: b84faf12-21c5-5994-a73c-3be89c23939d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
