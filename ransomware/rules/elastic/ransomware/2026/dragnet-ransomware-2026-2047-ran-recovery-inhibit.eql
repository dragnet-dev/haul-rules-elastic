// Dragnet [Ransomware]: dragnet-ransomware-2026-2047 — Recovery Inhibition (medusalocker)
// Status: stable | Level: high | ID: 37677d19-0836-5c21-8cd4-b7dffe907c2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
