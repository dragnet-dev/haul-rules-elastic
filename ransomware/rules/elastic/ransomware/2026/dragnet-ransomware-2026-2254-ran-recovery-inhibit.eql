// Dragnet [Ransomware]: dragnet-ransomware-2026-2254 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 97ab41b1-a369-5c61-b359-0aff6d580160

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
