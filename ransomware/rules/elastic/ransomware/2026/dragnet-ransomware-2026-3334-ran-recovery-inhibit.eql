// Dragnet [Ransomware]: dragnet-ransomware-2026-3334 — Recovery Inhibition (worldleaks)
// Status: stable | Level: high | ID: 33ffca75-8d8f-5328-81ad-582e29e74e13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
