// Dragnet [Ransomware]: dragnet-ransomware-2026-0228 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 73ddcdd9-59eb-5bac-840d-023354f65677

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
