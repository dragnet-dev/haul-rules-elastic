// Dragnet [Ransomware]: dragnet-ransomware-2026-3537 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 5a272dda-a738-59e0-854c-d1421302d9e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
