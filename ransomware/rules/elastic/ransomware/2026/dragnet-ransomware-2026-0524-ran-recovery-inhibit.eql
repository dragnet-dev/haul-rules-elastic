// Dragnet [Ransomware]: dragnet-ransomware-2026-0524 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: d005f290-210f-56e4-85b7-ba09d4f14f00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
