// Dragnet [Ransomware]: dragnet-ransomware-2026-1926 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 666fa97f-7109-505f-8e95-84611728ea5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
