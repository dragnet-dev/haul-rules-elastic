// Dragnet [Ransomware]: dragnet-ransomware-2026-3204 — Recovery Inhibition (insomnia)
// Status: test | Level: high | ID: 1001bcfe-de44-5955-9787-bbe21d0f7aa4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
