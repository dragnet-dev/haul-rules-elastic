// Dragnet [Ransomware]: dragnet-ransomware-2026-0351 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 122accf0-5e21-5098-a800-114af9896d10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
