// Dragnet [Ransomware]: dragnet-ransomware-2026-1275 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 4edd528a-ed3c-54ac-a091-3513c882994f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
