// Dragnet [Ransomware]: dragnet-ransomware-2026-1509 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1312598c-c12a-5ce1-80fa-f9b9709877dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
