// Dragnet [Ransomware]: dragnet-ransomware-2026-1576 — Recovery Inhibition (blacknevas)
// Status: stable | Level: high | ID: 70ca9a7a-57f4-5dff-865f-fa63a5a292c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
