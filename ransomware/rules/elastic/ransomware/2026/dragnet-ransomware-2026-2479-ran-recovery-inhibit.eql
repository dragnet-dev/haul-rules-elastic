// Dragnet [Ransomware]: dragnet-ransomware-2026-2479 — Recovery Inhibition (fulcrumsec)
// Status: stable | Level: high | ID: 8a97dace-bd66-504e-86ab-4821d254fe9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
