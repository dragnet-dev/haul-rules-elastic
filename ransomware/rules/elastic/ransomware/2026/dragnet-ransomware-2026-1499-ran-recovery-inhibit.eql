// Dragnet [Ransomware]: dragnet-ransomware-2026-1499 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 1e6976de-6904-5fef-bfde-38c50af56614

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
