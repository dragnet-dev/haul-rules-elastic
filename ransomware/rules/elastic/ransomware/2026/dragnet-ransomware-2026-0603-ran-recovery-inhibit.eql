// Dragnet [Ransomware]: dragnet-ransomware-2026-0603 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: fa62e509-522f-5c72-b71c-94278ac5990e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
