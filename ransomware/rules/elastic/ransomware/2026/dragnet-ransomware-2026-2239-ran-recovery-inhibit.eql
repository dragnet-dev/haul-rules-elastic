// Dragnet [Ransomware]: dragnet-ransomware-2026-2239 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 633cc39d-c6ce-5af3-bef2-a0c93f930d0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
