// Dragnet [Ransomware]: dragnet-ransomware-2026-0286 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 8e4c5a4a-e69f-51c3-90a0-e9c635bc60d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
