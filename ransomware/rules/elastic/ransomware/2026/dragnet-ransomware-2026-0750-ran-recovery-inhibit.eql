// Dragnet [Ransomware]: dragnet-ransomware-2026-0750 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 301c3095-ca76-575e-967a-d670e0c830cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
