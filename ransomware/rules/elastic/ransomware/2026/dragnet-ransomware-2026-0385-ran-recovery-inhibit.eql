// Dragnet [Ransomware]: dragnet-ransomware-2026-0385 — Recovery Inhibition (direwolf)
// Status: test | Level: high | ID: 11484210-961c-5f73-ade4-4bf773521fcb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
