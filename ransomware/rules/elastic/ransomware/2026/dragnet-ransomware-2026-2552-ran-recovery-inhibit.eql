// Dragnet [Ransomware]: dragnet-ransomware-2026-2552 — Recovery Inhibition (krybit)
// Status: stable | Level: high | ID: a593bd58-dda7-53c5-b0cb-2c4d255e8b4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
