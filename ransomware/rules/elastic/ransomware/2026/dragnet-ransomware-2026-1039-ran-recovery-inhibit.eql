// Dragnet [Ransomware]: dragnet-ransomware-2026-1039 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 75fedf73-3046-5a4d-8fae-78bc791da642

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
