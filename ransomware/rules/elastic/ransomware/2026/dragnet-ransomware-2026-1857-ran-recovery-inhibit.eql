// Dragnet [Ransomware]: dragnet-ransomware-2026-1857 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 097d35a6-0aa5-5757-8a48-4614c7abfbeb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
