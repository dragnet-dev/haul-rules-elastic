// Dragnet [Ransomware]: dragnet-ransomware-2026-1004 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: ab0bbdd5-6b63-59a3-b916-e7c615215191

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
