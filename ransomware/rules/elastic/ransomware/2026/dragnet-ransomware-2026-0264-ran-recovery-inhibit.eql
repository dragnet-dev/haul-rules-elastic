// Dragnet [Ransomware]: dragnet-ransomware-2026-0264 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 51055d64-2cb8-5cdf-b071-a610f73ce1f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
