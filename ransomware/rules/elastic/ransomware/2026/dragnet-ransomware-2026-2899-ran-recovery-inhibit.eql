// Dragnet [Ransomware]: dragnet-ransomware-2026-2899 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 2bb70a6a-1990-5a6f-b36c-193c9bf22cb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
