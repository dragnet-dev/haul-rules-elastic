// Dragnet [Ransomware]: dragnet-ransomware-2026-2719 — Recovery Inhibition (chaos)
// Status: stable | Level: high | ID: 1871192d-858e-5dc0-aa13-f37045443cff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
