// Dragnet [Ransomware]: dragnet-ransomware-2026-2121 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 4d5273ef-d896-5c15-b531-f1fe942552b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
