// Dragnet [Ransomware]: dragnet-ransomware-2026-2791 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0ee01609-34f6-554f-ac6a-f514ad056681

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
