// Dragnet [Ransomware]: dragnet-ransomware-2026-2016 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: d5a35405-9c6c-55b3-ad65-a7afc922d87b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
