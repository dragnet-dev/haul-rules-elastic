// Dragnet [Ransomware]: dragnet-ransomware-2026-0010 — Recovery Inhibition (blacknevas)
// Status: stable | Level: high | ID: 1bfa2b6a-78e2-5a1f-aa14-0d321a6446b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
