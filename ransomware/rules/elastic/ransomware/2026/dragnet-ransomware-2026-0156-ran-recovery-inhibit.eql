// Dragnet [Ransomware]: dragnet-ransomware-2026-0156 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 6ed541c0-1b7f-5789-ae04-e1bb6d8155f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
