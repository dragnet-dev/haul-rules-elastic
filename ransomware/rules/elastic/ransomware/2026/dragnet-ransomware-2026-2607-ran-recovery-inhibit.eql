// Dragnet [Ransomware]: dragnet-ransomware-2026-2607 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 2c11380f-4aef-57c8-8097-e95845ed3d62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
