// Dragnet [Ransomware]: dragnet-ransomware-2026-3134 — Recovery Inhibition (medusa)
// Status: test | Level: high | ID: 26c88ce2-4627-5ded-a824-fbb24cf25cbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
