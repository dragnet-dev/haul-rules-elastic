// Dragnet [Ransomware]: dragnet-ransomware-2026-3291 — Recovery Inhibition (beast)
// Status: stable | Level: high | ID: 723c5bbc-9052-59a9-8e4a-2abdc9b00a29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
