// Dragnet [Ransomware]: dragnet-ransomware-2026-0653 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: a5a85586-c63b-5a38-b454-c9fb361e5985

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
