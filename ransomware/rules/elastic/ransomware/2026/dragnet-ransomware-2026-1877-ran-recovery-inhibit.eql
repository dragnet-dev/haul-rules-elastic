// Dragnet [Ransomware]: dragnet-ransomware-2026-1877 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 8a8cfdc6-8065-5edd-8dea-292d4c24f85d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
