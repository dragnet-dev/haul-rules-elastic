// Dragnet [Ransomware]: dragnet-ransomware-2026-2171 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 56cd8b31-056f-5065-99bb-ee42bf66b68d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
