// Dragnet [Ransomware]: dragnet-ransomware-2026-1406 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: dc5bc933-1848-56d1-bf1b-884ae086beee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
