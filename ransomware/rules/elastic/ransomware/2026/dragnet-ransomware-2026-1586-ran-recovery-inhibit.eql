// Dragnet [Ransomware]: dragnet-ransomware-2026-1586 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: da08bcc3-4ed3-5bc6-af69-84881354c69e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
