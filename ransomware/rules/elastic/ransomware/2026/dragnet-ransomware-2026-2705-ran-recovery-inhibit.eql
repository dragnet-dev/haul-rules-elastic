// Dragnet [Ransomware]: dragnet-ransomware-2026-2705 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: b9467df8-c12c-5b81-af74-20ae1a4723ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
