// Dragnet [Ransomware]: dragnet-ransomware-2026-1394 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: df689ddf-e1d0-5ba8-b35a-d8ba3242d1ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
