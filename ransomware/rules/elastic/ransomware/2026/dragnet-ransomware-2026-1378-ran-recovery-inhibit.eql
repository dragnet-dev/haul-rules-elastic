// Dragnet [Ransomware]: dragnet-ransomware-2026-1378 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: fc4e5742-0c75-507f-92c8-8d4546ae6fa8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
