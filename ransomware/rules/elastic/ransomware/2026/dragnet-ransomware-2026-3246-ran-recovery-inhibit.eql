// Dragnet [Ransomware]: dragnet-ransomware-2026-3246 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: a53e7f8a-e84d-55f8-a6b3-262790f2fa73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
