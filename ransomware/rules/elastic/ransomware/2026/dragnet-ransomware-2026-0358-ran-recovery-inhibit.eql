// Dragnet [Ransomware]: dragnet-ransomware-2026-0358 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 3545b540-b71e-58bc-8b6d-e7cd3610a269

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
