// Dragnet [Ransomware]: dragnet-ransomware-2026-3361 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 8cb600a6-1d01-5e36-9d44-afa7285f7429

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
