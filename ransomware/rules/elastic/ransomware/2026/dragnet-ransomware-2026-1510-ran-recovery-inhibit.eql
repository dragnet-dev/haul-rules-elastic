// Dragnet [Ransomware]: dragnet-ransomware-2026-1510 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 118e492a-20f4-508b-a422-9883421b84cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
