// Dragnet [Ransomware]: dragnet-ransomware-2026-0769 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 98504412-e8f2-5e8c-a01f-e2bd5036b20d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
