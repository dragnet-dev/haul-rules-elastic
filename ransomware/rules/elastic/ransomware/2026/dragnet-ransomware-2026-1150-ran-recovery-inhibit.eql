// Dragnet [Ransomware]: dragnet-ransomware-2026-1150 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 367c419c-8f42-515b-83ee-845b7e08d46d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
