// Dragnet [Ransomware]: dragnet-ransomware-2026-2975 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: e4e40679-5656-53fd-b507-d65519a419d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
