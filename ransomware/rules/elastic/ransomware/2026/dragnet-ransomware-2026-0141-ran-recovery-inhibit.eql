// Dragnet [Ransomware]: dragnet-ransomware-2026-0141 — Recovery Inhibition (payoutsking)
// Status: test | Level: high | ID: 9fedaa09-0a98-5563-acef-343259c77ff1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
