// Dragnet [Ransomware]: dragnet-ransomware-2026-1094 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: d661f61a-763f-56ab-9ec3-80a472693b1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
