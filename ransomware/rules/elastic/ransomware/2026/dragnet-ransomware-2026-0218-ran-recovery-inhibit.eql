// Dragnet [Ransomware]: dragnet-ransomware-2026-0218 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: 17243a5c-9dee-5e1e-8a65-a4e010bbbe0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
