// Dragnet [Ransomware]: dragnet-ransomware-2026-3186 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: abfbce25-adc6-5b1e-97ed-6ab6f7878bc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
