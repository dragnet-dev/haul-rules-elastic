// Dragnet [Ransomware]: dragnet-ransomware-2026-1764 — Recovery Inhibition (embargo)
// Status: stable | Level: high | ID: 400557e1-ce7f-5828-b4a8-a4d4fdd04245

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
