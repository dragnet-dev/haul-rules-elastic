// Dragnet [Ransomware]: dragnet-ransomware-2026-1404 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 37dcc461-c199-5cc4-b645-4daa6e3e4e2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
