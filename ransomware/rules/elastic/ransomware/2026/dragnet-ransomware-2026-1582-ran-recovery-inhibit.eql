// Dragnet [Ransomware]: dragnet-ransomware-2026-1582 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: be35b527-7f70-58e2-9bc6-d776944332a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
