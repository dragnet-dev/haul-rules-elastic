// Dragnet [Ransomware]: dragnet-ransomware-2026-0564 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 11c5c9c3-8f18-5f79-b37e-d2c08204aa90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
