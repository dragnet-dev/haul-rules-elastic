// Dragnet [Ransomware]: dragnet-ransomware-2026-2794 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 12afdcd9-bc05-502f-8f20-3d6b29b33eaf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
