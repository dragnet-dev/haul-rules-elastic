// Dragnet [Ransomware]: dragnet-ransomware-2026-0144 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 7857054d-21f3-56e8-84f3-36a724a43978

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
