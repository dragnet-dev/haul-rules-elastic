// Dragnet [Ransomware]: dragnet-ransomware-2026-1449 — Recovery Inhibition (spacebears)
// Status: test | Level: high | ID: 283277c2-42c3-5413-bd08-ac8056acb10d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
