// Dragnet [Ransomware]: dragnet-ransomware-2026-1370 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 9c1d10d7-6735-5ef2-b7ca-6225a6fe4e86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
