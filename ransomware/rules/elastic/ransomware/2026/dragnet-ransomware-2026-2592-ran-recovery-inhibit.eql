// Dragnet [Ransomware]: dragnet-ransomware-2026-2592 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: a0fe833d-8f36-578a-bf9e-bd45bc0305f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
