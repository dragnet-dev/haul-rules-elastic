// Dragnet [Ransomware]: dragnet-ransomware-2026-1500 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: 98c562a4-bda8-56ca-9730-ede6c6780f1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
