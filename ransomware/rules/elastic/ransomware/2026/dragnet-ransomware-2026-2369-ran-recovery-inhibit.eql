// Dragnet [Ransomware]: dragnet-ransomware-2026-2369 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 567ab5e1-0899-531d-a664-778b7ee71a84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
