// Dragnet [Ransomware]: dragnet-ransomware-2026-2553 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 507be498-fde2-5834-b941-59233df8936e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
