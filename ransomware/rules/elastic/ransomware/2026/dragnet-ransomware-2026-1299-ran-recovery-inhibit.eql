// Dragnet [Ransomware]: dragnet-ransomware-2026-1299 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 87a85f24-cc0f-54ab-9aa2-9dc3d190424a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
