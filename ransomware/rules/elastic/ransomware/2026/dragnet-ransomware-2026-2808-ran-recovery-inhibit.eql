// Dragnet [Ransomware]: dragnet-ransomware-2026-2808 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 26a2fa9d-60db-56cd-8539-dab1009e123b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
