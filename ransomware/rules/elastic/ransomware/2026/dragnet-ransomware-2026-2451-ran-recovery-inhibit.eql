// Dragnet [Ransomware]: dragnet-ransomware-2026-2451 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 7dbb6ca3-64e0-5096-97c5-a889041ddbbd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
