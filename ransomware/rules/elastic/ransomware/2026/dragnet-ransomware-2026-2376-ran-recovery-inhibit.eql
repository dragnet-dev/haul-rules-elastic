// Dragnet [Ransomware]: dragnet-ransomware-2026-2376 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: aa9a32fe-0c17-5624-880c-756fff34baa7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
