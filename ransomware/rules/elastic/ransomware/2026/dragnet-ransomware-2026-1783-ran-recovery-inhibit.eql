// Dragnet [Ransomware]: dragnet-ransomware-2026-1783 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: b0702c7b-bf4c-5e5c-a89d-e02c65633081

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
