// Dragnet [Ransomware]: dragnet-ransomware-2026-0232 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: d5080fbd-fb9d-5774-b1ea-e806843d0850

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
