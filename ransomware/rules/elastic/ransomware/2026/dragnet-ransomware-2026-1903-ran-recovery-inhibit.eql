// Dragnet [Ransomware]: dragnet-ransomware-2026-1903 — Recovery Inhibition (worldleaks)
// Status: test | Level: high | ID: 191d3919-67d8-5cc8-aaaa-38c839c6b8d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
