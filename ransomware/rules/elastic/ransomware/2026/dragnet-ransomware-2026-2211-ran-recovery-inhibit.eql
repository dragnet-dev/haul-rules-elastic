// Dragnet [Ransomware]: dragnet-ransomware-2026-2211 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: a571ed1a-630b-5c95-a5d3-d67091c618bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
