// Dragnet [Ransomware]: dragnet-ransomware-2026-0431 — Recovery Inhibition (titan)
// Status: stable | Level: high | ID: f42c3d63-d0e7-5ed7-ba72-8fb8c3e12b91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
