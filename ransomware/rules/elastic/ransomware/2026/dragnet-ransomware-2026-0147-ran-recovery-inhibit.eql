// Dragnet [Ransomware]: dragnet-ransomware-2026-0147 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 2b9b42cb-c655-5ee5-bb44-681868f12a10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
