// Dragnet [Ransomware]: dragnet-ransomware-2026-2286 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 2c903ec2-9cb7-5b44-ab7d-49930657c940

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
