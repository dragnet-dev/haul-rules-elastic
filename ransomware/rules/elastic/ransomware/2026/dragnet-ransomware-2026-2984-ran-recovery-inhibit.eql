// Dragnet [Ransomware]: dragnet-ransomware-2026-2984 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 6acb8815-90e3-51a2-b449-8a8c68cd8d6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
