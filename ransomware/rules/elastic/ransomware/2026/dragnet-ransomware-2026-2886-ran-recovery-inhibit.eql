// Dragnet [Ransomware]: dragnet-ransomware-2026-2886 — Recovery Inhibition (anubis)
// Status: stable | Level: high | ID: 70f60466-d769-573d-a529-28ca54907bf3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
