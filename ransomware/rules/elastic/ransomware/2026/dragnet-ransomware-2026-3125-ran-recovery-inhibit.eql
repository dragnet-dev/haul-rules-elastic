// Dragnet [Ransomware]: dragnet-ransomware-2026-3125 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: bf7df137-9afc-5c8c-b0ec-c6f1da1f71b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
