// Dragnet [Ransomware]: dragnet-ransomware-2026-0287 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 03c248f0-fdf5-57b6-ac9c-ca3f5ac9315b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
