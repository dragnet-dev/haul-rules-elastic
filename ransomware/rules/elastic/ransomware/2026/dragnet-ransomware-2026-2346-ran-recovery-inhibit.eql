// Dragnet [Ransomware]: dragnet-ransomware-2026-2346 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: 79bb4c98-ae0b-53d0-afc2-20d39151f7cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
