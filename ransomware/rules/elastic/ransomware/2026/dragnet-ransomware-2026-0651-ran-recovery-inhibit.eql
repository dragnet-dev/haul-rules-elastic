// Dragnet [Ransomware]: dragnet-ransomware-2026-0651 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: aa162bcc-d40f-5370-aaee-f1981b5d9bbd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
