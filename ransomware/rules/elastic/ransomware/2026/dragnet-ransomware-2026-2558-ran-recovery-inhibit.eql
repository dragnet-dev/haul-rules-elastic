// Dragnet [Ransomware]: dragnet-ransomware-2026-2558 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: d0b0f240-531c-5ec6-bafa-2b80788958fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
