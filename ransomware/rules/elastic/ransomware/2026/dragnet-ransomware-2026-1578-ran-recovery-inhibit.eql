// Dragnet [Ransomware]: dragnet-ransomware-2026-1578 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 6cc05b8b-d93c-5f45-810a-5925832be906

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
