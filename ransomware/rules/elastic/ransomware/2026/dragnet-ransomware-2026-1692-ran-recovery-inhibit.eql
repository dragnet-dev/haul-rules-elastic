// Dragnet [Ransomware]: dragnet-ransomware-2026-1692 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 1cc50bed-2018-5d5c-97c2-39170592e987

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
