// Dragnet [Ransomware]: dragnet-ransomware-2026-2587 — Recovery Inhibition (interlock)
// Status: stable | Level: high | ID: 9b228914-dd53-59b3-b41f-20322e8aeff9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
