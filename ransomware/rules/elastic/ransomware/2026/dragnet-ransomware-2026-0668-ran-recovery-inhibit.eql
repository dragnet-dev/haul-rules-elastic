// Dragnet [Ransomware]: dragnet-ransomware-2026-0668 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: d526373a-be00-5939-90d4-a2f9b05133f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
