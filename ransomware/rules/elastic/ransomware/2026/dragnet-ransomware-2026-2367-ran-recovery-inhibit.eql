// Dragnet [Ransomware]: dragnet-ransomware-2026-2367 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 33c55586-3729-5ab2-bda1-1e348dab144c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
