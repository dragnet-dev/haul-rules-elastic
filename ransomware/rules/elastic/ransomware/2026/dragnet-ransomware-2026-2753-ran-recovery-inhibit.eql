// Dragnet [Ransomware]: dragnet-ransomware-2026-2753 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 38d6c6c6-0fc3-53ed-8423-9cce7524d31f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
