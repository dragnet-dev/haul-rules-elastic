// Dragnet [Ransomware]: dragnet-ransomware-2026-0961 — Recovery Inhibition (bravox)
// Status: stable | Level: high | ID: d6a0abf4-95a2-56d6-984b-411bd0f1ec55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
