// Dragnet [Ransomware]: dragnet-ransomware-2026-3128 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: d1f9a93b-b6d5-59e5-ba48-636cf4854f86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
