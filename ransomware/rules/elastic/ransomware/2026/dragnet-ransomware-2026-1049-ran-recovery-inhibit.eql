// Dragnet [Ransomware]: dragnet-ransomware-2026-1049 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: a9bbfba7-4914-55f6-948a-105b6585cedb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
