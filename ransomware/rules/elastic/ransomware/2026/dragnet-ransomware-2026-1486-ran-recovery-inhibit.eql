// Dragnet [Ransomware]: dragnet-ransomware-2026-1486 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: c674b9a1-b96d-5887-ac01-d526e8fe8ea8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
