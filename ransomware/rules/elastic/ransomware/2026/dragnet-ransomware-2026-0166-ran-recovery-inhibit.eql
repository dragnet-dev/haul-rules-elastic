// Dragnet [Ransomware]: dragnet-ransomware-2026-0166 — Recovery Inhibition (pear)
// Status: stable | Level: high | ID: b11441a8-4aaf-584a-9577-9e77e0408e31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
