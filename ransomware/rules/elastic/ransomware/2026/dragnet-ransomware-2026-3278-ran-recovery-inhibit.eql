// Dragnet [Ransomware]: dragnet-ransomware-2026-3278 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: a959ac06-05f6-5ebd-a3c2-ec809bf709a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
