// Dragnet [Ransomware]: dragnet-ransomware-2026-0816 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: b4ad2ce9-6826-5d44-b7ee-b5d51170f0b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
