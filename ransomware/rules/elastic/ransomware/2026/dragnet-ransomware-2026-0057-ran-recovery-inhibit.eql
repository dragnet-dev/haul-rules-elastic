// Dragnet [Ransomware]: dragnet-ransomware-2026-0057 — Recovery Inhibition (fulcrumsec)
// Status: stable | Level: high | ID: 309a729e-b97d-5aec-855c-649c0f28dd6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
