// Dragnet [Ransomware]: dragnet-ransomware-2026-1302 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: cf0beabd-21f6-54aa-a4fe-f328edd98789

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
