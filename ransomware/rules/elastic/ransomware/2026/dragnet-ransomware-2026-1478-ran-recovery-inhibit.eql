// Dragnet [Ransomware]: dragnet-ransomware-2026-1478 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 04a88a01-952a-5876-bd7d-6df271fd464c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
