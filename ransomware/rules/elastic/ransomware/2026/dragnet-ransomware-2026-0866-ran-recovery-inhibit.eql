// Dragnet [Ransomware]: dragnet-ransomware-2026-0866 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 1c80ce64-0f87-5264-a735-3c2db44f0151

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
