// Dragnet [Ransomware]: dragnet-ransomware-2026-0006 — Recovery Inhibition (anubis)
// Status: stable | Level: high | ID: 68c49f1e-e6b5-5dff-ba20-e2bd7672db11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
