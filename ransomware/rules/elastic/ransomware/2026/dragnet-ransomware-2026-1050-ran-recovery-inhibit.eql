// Dragnet [Ransomware]: dragnet-ransomware-2026-1050 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 167f9147-ce93-5a6d-9895-8eb9a80ad878

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
