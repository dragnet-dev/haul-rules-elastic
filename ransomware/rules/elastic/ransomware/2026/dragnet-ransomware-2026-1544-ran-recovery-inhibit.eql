// Dragnet [Ransomware]: dragnet-ransomware-2026-1544 — Recovery Inhibition (fulcrumsec)
// Status: stable | Level: high | ID: c67220d1-5349-5575-82b7-68d9838517d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
