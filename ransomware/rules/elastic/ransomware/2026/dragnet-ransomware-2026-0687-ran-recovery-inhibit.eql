// Dragnet [Ransomware]: dragnet-ransomware-2026-0687 — Recovery Inhibition (handala)
// Status: test | Level: high | ID: b794250f-87f4-5d59-9c32-c8b5da4c668b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
