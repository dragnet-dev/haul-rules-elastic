// Dragnet [Ransomware]: dragnet-ransomware-2026-3330 — Recovery Inhibition (interlock)
// Status: test | Level: high | ID: 287fbc88-859b-5858-b08f-a33cc02f95d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
