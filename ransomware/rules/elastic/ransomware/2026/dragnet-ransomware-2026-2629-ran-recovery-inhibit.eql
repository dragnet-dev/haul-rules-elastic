// Dragnet [Ransomware]: dragnet-ransomware-2026-2629 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: b19beb3b-c639-58f2-a72c-d6fcc6c767a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
