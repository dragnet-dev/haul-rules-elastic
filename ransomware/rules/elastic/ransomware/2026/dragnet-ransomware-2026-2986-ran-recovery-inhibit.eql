// Dragnet [Ransomware]: dragnet-ransomware-2026-2986 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 72520fdc-f4e1-5298-8e29-ec11335931ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
