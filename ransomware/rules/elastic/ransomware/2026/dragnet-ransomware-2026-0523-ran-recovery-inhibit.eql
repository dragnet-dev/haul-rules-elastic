// Dragnet [Ransomware]: dragnet-ransomware-2026-0523 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 3183fe04-32af-5714-9a69-39e3294988c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
