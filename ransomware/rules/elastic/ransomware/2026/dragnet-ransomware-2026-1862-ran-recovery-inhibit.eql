// Dragnet [Ransomware]: dragnet-ransomware-2026-1862 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: e4ff81e0-e240-5ed0-8e00-c5c2766db3d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
