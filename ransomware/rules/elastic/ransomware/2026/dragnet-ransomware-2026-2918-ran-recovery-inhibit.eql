// Dragnet [Ransomware]: dragnet-ransomware-2026-2918 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 36d41d41-c2d0-5257-91c6-5e07c36dbe5e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
