// Dragnet [Ransomware]: dragnet-ransomware-2026-2492 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: e86ea66e-0b81-5de9-8a1d-96b350077693

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
