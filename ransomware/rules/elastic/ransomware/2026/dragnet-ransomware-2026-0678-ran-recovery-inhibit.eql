// Dragnet [Ransomware]: dragnet-ransomware-2026-0678 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 24dec311-60fd-553f-99f2-1ec930e5840b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
