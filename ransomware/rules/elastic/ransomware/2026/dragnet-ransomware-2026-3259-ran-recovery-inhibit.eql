// Dragnet [Ransomware]: dragnet-ransomware-2026-3259 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 66cce999-adf8-5f23-80e8-7ccedfcc5c66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
