// Dragnet [Ransomware]: dragnet-ransomware-2026-2777 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: e6702db4-eb33-5ae5-8138-2ebeecdd6c75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
