// Dragnet [Ransomware]: dragnet-ransomware-2026-3180 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 4f04cd7f-5535-5b1d-904c-e4837f6cac65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
