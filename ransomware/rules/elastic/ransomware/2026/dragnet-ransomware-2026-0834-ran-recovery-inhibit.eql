// Dragnet [Ransomware]: dragnet-ransomware-2026-0834 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: 4fd437c0-fc68-5603-a398-3048ef9409c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
