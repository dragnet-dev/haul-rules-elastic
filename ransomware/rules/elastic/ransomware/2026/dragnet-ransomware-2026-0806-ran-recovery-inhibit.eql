// Dragnet [Ransomware]: dragnet-ransomware-2026-0806 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: a3748498-ca2b-5319-b897-cad1dbc16ef2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
