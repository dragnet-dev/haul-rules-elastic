// Dragnet [Ransomware]: dragnet-ransomware-2026-0623 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 809e9cd2-50a7-585a-85c0-f2a45988ed8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
