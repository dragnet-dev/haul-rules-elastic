// Dragnet [Ransomware]: dragnet-ransomware-2026-0881 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 34fd1c3c-4660-57ee-9855-dff3e3fce9ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
