// Dragnet [Ransomware]: dragnet-ransomware-2026-0221 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: 5ba4625c-5ab5-55c8-b1a8-0250067ca49f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
