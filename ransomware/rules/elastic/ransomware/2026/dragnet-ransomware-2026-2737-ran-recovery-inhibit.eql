// Dragnet [Ransomware]: dragnet-ransomware-2026-2737 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 524ee23a-103a-5eae-b0e4-b5e46e817560

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
