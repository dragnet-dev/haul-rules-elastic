// Dragnet [Ransomware]: dragnet-ransomware-2026-0440 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: b116cdd1-a8cf-5b01-b84c-6914a2ce764a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
