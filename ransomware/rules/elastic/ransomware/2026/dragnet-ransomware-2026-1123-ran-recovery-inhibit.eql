// Dragnet [Ransomware]: dragnet-ransomware-2026-1123 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: a9e5ddc6-9468-5cff-91e8-491fc58f8b97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
