// Dragnet [Ransomware]: dragnet-ransomware-2026-2799 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: fc6f47dc-53c8-5d2e-83fb-88147da9f7f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
