// Dragnet [Ransomware]: dragnet-ransomware-2026-3271 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 821d3028-57e9-5e88-b2ec-4c289dcd76ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
