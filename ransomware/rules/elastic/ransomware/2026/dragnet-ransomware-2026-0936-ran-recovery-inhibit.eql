// Dragnet [Ransomware]: dragnet-ransomware-2026-0936 — Recovery Inhibition (cmdorganization)
// Status: deprecated | Level: high | ID: a98c1916-93a4-562d-bdfd-91f1dd86d6e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
