// Dragnet [Ransomware]: dragnet-ransomware-2026-0136 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: f31bac88-d40d-5877-ba0a-7d036816ba4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
