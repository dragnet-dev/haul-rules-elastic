// Dragnet [Ransomware]: dragnet-ransomware-2026-0887 — Recovery Inhibition (ransomexx)
// Status: stable | Level: high | ID: 8f13b08c-3430-5719-8185-aec4c091eb02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
