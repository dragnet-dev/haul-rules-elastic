// Dragnet [Ransomware]: dragnet-ransomware-2026-1257 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 434c8fb1-ce62-560e-b971-9156f10f1822

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
