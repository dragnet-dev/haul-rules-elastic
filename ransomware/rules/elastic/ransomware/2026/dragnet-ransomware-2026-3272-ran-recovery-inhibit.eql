// Dragnet [Ransomware]: dragnet-ransomware-2026-3272 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 4b1fb67b-7044-5dfa-9d8d-268c1d9558cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
