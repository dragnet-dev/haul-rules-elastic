// Dragnet [Ransomware]: dragnet-ransomware-2026-2309 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: eb932a3b-961e-5836-9abd-7fb36af27777

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
