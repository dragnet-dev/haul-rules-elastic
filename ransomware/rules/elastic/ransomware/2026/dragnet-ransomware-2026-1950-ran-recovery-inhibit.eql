// Dragnet [Ransomware]: dragnet-ransomware-2026-1950 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 9eede1bc-18da-54ee-b0c9-15f5dc15f1e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
