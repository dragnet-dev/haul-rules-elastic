// Dragnet [Ransomware]: dragnet-ransomware-2026-1757 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 61b6150f-45f7-5941-ab0a-25dca1c34328

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
