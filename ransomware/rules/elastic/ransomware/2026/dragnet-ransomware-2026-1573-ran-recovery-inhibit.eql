// Dragnet [Ransomware]: dragnet-ransomware-2026-1573 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: d8a1f128-926a-5b11-9b0a-25ff579ccb24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
