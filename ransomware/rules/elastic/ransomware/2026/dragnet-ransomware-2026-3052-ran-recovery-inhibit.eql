// Dragnet [Ransomware]: dragnet-ransomware-2026-3052 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 349782cb-8ef3-5c0d-8b0e-ecf1fef72d34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
