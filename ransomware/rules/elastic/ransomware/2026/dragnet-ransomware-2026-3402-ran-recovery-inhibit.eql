// Dragnet [Ransomware]: dragnet-ransomware-2026-3402 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 793cf1f6-edfc-5f62-a297-7be7fcb6c7e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
