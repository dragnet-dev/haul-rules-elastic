// Dragnet [Ransomware]: dragnet-ransomware-2026-3527 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: 1da90b43-e23b-5fbc-a449-954e1cf26f84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
