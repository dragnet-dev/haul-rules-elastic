// Dragnet [Ransomware]: dragnet-ransomware-2026-3172 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5ddcb1d8-e305-5f13-9321-48b822e49974

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
