// Dragnet [Ransomware]: dragnet-ransomware-2026-0205 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 101095ba-3534-560d-84a0-c0a12264acb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
