// Dragnet [Ransomware]: dragnet-ransomware-2026-0117 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5a61a5b9-517b-57ba-b09d-80c695ba762d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
