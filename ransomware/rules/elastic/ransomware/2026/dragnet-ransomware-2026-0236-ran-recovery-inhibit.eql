// Dragnet [Ransomware]: dragnet-ransomware-2026-0236 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 0f485596-cda4-57e8-8921-a1351bb4a738

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
