// Dragnet [Ransomware]: dragnet-ransomware-2026-1184 — Recovery Inhibition (blacknevas)
// Status: stable | Level: high | ID: 5557a89a-df5d-5b81-acd3-576db42f8e34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
