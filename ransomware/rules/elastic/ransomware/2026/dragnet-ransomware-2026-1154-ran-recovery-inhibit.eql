// Dragnet [Ransomware]: dragnet-ransomware-2026-1154 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 41eac5fa-a8a0-5f8c-801f-a549dd6ec297

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
