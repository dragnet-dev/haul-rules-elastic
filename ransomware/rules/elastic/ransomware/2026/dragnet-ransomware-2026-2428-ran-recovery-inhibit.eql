// Dragnet [Ransomware]: dragnet-ransomware-2026-2428 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 7d4ae422-2659-5f80-88ae-f1a427ec84a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
