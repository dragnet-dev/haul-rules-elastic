// Dragnet [Ransomware]: dragnet-ransomware-2026-0768 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: a92d9060-35c0-53b6-b3f5-63e90aa2eab5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
