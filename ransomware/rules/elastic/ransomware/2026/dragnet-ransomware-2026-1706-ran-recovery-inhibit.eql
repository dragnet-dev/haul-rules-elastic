// Dragnet [Ransomware]: dragnet-ransomware-2026-1706 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 7357002f-23d7-5bd0-b361-378cb405e73b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
