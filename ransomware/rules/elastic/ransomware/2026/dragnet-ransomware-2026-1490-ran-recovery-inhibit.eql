// Dragnet [Ransomware]: dragnet-ransomware-2026-1490 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 6ec280b5-4e22-5e18-af8d-5fbc9235ed45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
