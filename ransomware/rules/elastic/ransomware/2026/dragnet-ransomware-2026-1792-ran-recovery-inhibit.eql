// Dragnet [Ransomware]: dragnet-ransomware-2026-1792 — Recovery Inhibition (vect)
// Status: deprecated | Level: high | ID: 4c5761d4-ce8e-57fe-a0fd-c2781dcb835e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
