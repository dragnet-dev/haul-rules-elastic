// Dragnet [Ransomware]: dragnet-ransomware-2026-2586 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ef20157a-97d2-554f-86f8-ac466c209396

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
