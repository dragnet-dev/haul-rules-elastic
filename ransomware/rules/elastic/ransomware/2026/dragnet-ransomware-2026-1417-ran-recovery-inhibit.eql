// Dragnet [Ransomware]: dragnet-ransomware-2026-1417 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 189c96ac-b399-5aae-a9ae-06230c30133d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
