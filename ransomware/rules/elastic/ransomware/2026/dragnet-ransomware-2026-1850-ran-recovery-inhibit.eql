// Dragnet [Ransomware]: dragnet-ransomware-2026-1850 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 9dad746a-960f-5834-bb51-9ab54c604c2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
