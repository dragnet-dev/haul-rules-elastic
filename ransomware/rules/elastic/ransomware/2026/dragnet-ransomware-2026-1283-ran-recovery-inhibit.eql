// Dragnet [Ransomware]: dragnet-ransomware-2026-1283 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: a20e587d-4917-5348-97b2-f204e0f0ff9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
