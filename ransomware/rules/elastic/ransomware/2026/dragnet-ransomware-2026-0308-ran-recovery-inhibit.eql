// Dragnet [Ransomware]: dragnet-ransomware-2026-0308 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: dfdc078b-8063-5d6a-b36d-762ce015aed0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
