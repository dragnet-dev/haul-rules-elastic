// Dragnet [Ransomware]: dragnet-ransomware-2026-1888 — Recovery Inhibition (payoutsking)
// Status: stable | Level: high | ID: 8e6ca7dc-ce5e-52e3-bdfd-f15ec9e66206

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
