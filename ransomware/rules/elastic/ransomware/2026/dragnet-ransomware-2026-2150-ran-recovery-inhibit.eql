// Dragnet [Ransomware]: dragnet-ransomware-2026-2150 — Recovery Inhibition (ALP-001)
// Status: stable | Level: high | ID: d2c3459f-1ad7-5cca-9218-23f05594e65b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
