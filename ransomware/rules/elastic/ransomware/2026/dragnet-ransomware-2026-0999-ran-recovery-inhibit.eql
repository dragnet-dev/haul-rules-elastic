// Dragnet [Ransomware]: dragnet-ransomware-2026-0999 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 06045c94-bac6-5f30-a452-fcb154b316e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
