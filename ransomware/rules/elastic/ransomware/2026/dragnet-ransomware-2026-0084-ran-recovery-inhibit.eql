// Dragnet [Ransomware]: dragnet-ransomware-2026-0084 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 1488fcc2-2a31-51c5-8f8d-b8fc45d016ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
