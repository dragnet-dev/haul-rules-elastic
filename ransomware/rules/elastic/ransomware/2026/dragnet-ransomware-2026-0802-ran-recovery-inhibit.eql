// Dragnet [Ransomware]: dragnet-ransomware-2026-0802 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 066374ee-104d-5ee8-9538-688f241f5479

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
