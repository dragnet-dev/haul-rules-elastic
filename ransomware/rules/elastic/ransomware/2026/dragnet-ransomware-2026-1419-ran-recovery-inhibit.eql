// Dragnet [Ransomware]: dragnet-ransomware-2026-1419 — Recovery Inhibition (LeakBazaar)
// Status: stable | Level: high | ID: 730d8af2-ddff-5b80-a26e-1b2b1789daa1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
