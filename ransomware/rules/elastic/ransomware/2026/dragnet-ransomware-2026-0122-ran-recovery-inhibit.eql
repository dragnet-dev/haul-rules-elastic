// Dragnet [Ransomware]: dragnet-ransomware-2026-0122 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: aba5ecdd-cb20-540d-8753-eddec38de3c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
