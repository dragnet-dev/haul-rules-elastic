// Dragnet [Ransomware]: dragnet-ransomware-2026-2014 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 9c02b648-9c63-5b73-a058-30d4f872c698

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
