// Dragnet [Ransomware]: dragnet-ransomware-2026-0491 — Recovery Inhibition (spacebears)
// Status: stable | Level: high | ID: cb7f3e52-4350-5f1e-a237-0e5627b3d414

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
