// Dragnet [Ransomware]: dragnet-ransomware-2026-1133 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 0c00d155-173b-5f62-8fa6-78750abd7266

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
