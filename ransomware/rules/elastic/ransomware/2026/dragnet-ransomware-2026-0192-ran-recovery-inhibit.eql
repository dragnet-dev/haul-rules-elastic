// Dragnet [Ransomware]: dragnet-ransomware-2026-0192 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 42bc8ad8-016e-5694-ba75-bceb407a26a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
