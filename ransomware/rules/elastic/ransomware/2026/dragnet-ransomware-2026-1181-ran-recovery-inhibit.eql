// Dragnet [Ransomware]: dragnet-ransomware-2026-1181 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 6ac6eba1-cb50-5a4f-b112-5a5ad6968a27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
