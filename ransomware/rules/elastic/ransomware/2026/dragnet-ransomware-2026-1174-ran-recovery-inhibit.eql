// Dragnet [Ransomware]: dragnet-ransomware-2026-1174 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 7534db53-1a10-549f-80ad-aeb33fa565be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
