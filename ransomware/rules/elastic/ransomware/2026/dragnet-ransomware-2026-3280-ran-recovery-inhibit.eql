// Dragnet [Ransomware]: dragnet-ransomware-2026-3280 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 1d37afca-053f-5c0d-8d1c-b13e8b26be60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
