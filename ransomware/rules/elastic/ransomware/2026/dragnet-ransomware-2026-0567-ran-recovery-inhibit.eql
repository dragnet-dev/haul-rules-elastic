// Dragnet [Ransomware]: dragnet-ransomware-2026-0567 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 6cc4cf99-3232-5795-9f16-dddc8a88b214

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
