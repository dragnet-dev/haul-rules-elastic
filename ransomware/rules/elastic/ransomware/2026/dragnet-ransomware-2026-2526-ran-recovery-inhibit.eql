// Dragnet [Ransomware]: dragnet-ransomware-2026-2526 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: fd5e46ee-e1c8-533f-a583-5903089ed21d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
