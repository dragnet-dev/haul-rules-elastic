// Dragnet [Ransomware]: dragnet-ransomware-2026-0426 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 1cc8203b-8137-57f4-8451-22e55c6dae29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
