// Dragnet [Ransomware]: dragnet-ransomware-2026-2663 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: 7c47f731-f7c5-513f-be01-d9c3f7cda9e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
