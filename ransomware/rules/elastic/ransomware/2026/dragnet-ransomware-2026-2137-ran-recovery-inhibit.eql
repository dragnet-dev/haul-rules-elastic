// Dragnet [Ransomware]: dragnet-ransomware-2026-2137 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 1ab48650-18f0-50b5-8636-41b49cc622ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
