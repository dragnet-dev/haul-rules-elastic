// Dragnet [Ransomware]: dragnet-ransomware-2026-2024 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: f988c68d-0e91-5bca-b960-16ec422b6a74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
