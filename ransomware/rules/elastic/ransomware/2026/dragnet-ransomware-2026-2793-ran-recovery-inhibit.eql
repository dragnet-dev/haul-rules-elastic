// Dragnet [Ransomware]: dragnet-ransomware-2026-2793 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: e1586bca-e1ee-5942-a143-c7d2e4106abf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
