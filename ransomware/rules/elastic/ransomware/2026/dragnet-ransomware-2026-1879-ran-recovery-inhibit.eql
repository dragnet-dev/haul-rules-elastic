// Dragnet [Ransomware]: dragnet-ransomware-2026-1879 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: cc15ad13-4795-59ca-a055-fb4578600468

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
