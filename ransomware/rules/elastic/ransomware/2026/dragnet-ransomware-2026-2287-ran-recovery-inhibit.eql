// Dragnet [Ransomware]: dragnet-ransomware-2026-2287 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 09c78d3f-0af2-5927-866d-7dddde907e90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
