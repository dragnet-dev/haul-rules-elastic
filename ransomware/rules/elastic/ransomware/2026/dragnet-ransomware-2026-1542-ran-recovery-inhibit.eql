// Dragnet [Ransomware]: dragnet-ransomware-2026-1542 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 3b6e249a-21ef-581e-bfe7-aebb32c43a7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
