// Dragnet [Ransomware]: dragnet-ransomware-2026-3327 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 29197fde-fd4a-53aa-a9d7-d51de5a1cdec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
