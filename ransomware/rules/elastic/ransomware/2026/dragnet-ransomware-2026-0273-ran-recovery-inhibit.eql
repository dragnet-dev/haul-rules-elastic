// Dragnet [Ransomware]: dragnet-ransomware-2026-0273 — Recovery Inhibition (morpheus)
// Status: deprecated | Level: high | ID: 98c77219-c1c6-53a7-9a49-6a59f98caa68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
