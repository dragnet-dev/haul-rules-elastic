// Dragnet [Ransomware]: dragnet-ransomware-2026-2212 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: da945c52-520b-5f4d-b67f-8c79c5393850

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
