// Dragnet [Ransomware]: dragnet-ransomware-2026-3164 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 8feb0688-330c-583c-9cec-fd804a53c1b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
