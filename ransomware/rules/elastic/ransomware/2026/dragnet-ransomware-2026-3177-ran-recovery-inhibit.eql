// Dragnet [Ransomware]: dragnet-ransomware-2026-3177 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 8bbc6b95-a180-58fd-be83-4dd7944f7dde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
