// Dragnet [Ransomware]: dragnet-ransomware-2026-0680 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 3a41d261-ccc9-5fba-af09-5e22be298f37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
