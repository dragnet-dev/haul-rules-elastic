// Dragnet [Ransomware]: dragnet-ransomware-2026-0545 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: cc99a67f-9d9b-527a-9e43-54544a72e5fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
