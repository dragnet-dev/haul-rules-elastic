// Dragnet [Ransomware]: dragnet-ransomware-2026-0450 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: ec7f9873-8e94-5b8f-9687-fc8d09e07503

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
