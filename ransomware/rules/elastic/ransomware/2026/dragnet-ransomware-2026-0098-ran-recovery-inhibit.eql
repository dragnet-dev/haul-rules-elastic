// Dragnet [Ransomware]: dragnet-ransomware-2026-0098 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: e5bef444-da33-5758-a30c-037a5ccfdf07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
