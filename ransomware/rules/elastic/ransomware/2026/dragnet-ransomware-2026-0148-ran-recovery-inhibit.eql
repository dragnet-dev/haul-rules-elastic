// Dragnet [Ransomware]: dragnet-ransomware-2026-0148 — Recovery Inhibition (ransomhouse)
// Status: stable | Level: high | ID: 1b661f16-8d87-52e3-83fa-d2dd750723bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
