// Dragnet [Ransomware]: dragnet-ransomware-2026-3500 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 4999242d-4a96-5ba4-bdd2-4b463ec0167d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
