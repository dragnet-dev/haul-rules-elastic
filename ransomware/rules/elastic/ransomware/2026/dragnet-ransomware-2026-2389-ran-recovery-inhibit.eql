// Dragnet [Ransomware]: dragnet-ransomware-2026-2389 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: fe41c4ad-7993-5c2c-be20-0f6108cfaa46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
