// Dragnet [Ransomware]: dragnet-ransomware-2026-0184 — Recovery Inhibition (anubis)
// Status: stable | Level: high | ID: a31dd27c-d301-559b-9769-cdb4a02e0bf2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
