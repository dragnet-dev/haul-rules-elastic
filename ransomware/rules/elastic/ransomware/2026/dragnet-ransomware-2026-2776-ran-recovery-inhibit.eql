// Dragnet [Ransomware]: dragnet-ransomware-2026-2776 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: 5670e6c5-9ab1-5972-a0e7-ce97e167024a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
