// Dragnet [Ransomware]: dragnet-ransomware-2026-0991 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 2f01d0dc-52fa-5ecc-888a-d5e1f619a523

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
