// Dragnet [Ransomware]: dragnet-ransomware-2026-3061 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 7bec5b91-d15b-5d35-9c68-28092822747d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
