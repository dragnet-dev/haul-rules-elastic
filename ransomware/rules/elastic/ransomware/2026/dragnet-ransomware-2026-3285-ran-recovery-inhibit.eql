// Dragnet [Ransomware]: dragnet-ransomware-2026-3285 — Recovery Inhibition (BrainCipher)
// Status: stable | Level: high | ID: 33e533a0-4d1e-5afb-a9bb-9536766aaaec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
