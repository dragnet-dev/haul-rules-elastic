// Dragnet [Ransomware]: dragnet-ransomware-2026-2635 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 5e4de77f-78ae-5424-a746-533f8a714868

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
