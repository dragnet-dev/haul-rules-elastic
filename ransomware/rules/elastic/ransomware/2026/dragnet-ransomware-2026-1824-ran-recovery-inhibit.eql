// Dragnet [Ransomware]: dragnet-ransomware-2026-1824 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 9e31603f-4af3-5e95-924b-e0e13948f505

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
