// Dragnet [Ransomware]: dragnet-ransomware-2026-3142 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: e3cdc7ee-3b82-536a-b04d-433854a7aec1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
