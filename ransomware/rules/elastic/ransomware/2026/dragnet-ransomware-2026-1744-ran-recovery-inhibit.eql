// Dragnet [Ransomware]: dragnet-ransomware-2026-1744 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 99c802e3-b2cc-5431-a09f-14476bf9d7c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
