// Dragnet [Ransomware]: dragnet-ransomware-2026-2218 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: f95ae931-00af-5743-b427-76063982d177

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
