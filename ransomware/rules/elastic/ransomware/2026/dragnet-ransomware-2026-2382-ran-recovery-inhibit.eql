// Dragnet [Ransomware]: dragnet-ransomware-2026-2382 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: c849b060-7206-5c20-a600-521f339c8a09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
