// Dragnet [Ransomware]: dragnet-ransomware-2026-2580 — Recovery Inhibition (fulcrumsec)
// Status: stable | Level: high | ID: b9497929-df9f-50e2-b8d4-e0394e3ec8ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
