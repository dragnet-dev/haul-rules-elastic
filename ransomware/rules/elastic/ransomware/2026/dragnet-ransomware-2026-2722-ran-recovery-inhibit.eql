// Dragnet [Ransomware]: dragnet-ransomware-2026-2722 — Recovery Inhibition (pear)
// Status: stable | Level: high | ID: 3bb676ab-2d30-5f1e-bd69-9028d39759bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
