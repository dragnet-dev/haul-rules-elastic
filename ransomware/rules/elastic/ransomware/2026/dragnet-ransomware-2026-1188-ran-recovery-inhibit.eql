// Dragnet [Ransomware]: dragnet-ransomware-2026-1188 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 199902ab-1776-55de-95eb-6168feea8f30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
