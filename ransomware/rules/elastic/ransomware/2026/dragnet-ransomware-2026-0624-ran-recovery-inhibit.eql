// Dragnet [Ransomware]: dragnet-ransomware-2026-0624 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: e966705e-5def-5026-94af-389318894d0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
