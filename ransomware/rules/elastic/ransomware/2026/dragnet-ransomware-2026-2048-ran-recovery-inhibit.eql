// Dragnet [Ransomware]: dragnet-ransomware-2026-2048 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 8700ac3a-df72-529a-8356-576f95aadde7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
