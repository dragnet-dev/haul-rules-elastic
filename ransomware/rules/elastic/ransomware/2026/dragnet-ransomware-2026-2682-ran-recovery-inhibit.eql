// Dragnet [Ransomware]: dragnet-ransomware-2026-2682 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: e945735b-8b3b-5451-bcf0-b2622762a301

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
