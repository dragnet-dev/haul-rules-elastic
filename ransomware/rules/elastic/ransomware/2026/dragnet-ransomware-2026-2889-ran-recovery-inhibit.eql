// Dragnet [Ransomware]: dragnet-ransomware-2026-2889 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 4f00e2f3-53de-58e8-bae8-41d1c60b873e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
