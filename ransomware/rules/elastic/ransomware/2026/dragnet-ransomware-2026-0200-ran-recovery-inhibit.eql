// Dragnet [Ransomware]: dragnet-ransomware-2026-0200 — Recovery Inhibition (vect)
// Status: deprecated | Level: high | ID: 30a15969-99e0-563b-b33b-ea3b0aec0e33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
