// Dragnet [Ransomware]: dragnet-ransomware-2026-3545 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 5c306f95-e1bd-5e3c-bb6f-c736f797970e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
