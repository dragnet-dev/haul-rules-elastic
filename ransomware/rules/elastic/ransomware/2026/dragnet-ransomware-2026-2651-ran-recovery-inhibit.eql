// Dragnet [Ransomware]: dragnet-ransomware-2026-2651 — Recovery Inhibition (m3rx)
// Status: stable | Level: high | ID: 02716009-2ad3-5569-b535-894915475ca0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
