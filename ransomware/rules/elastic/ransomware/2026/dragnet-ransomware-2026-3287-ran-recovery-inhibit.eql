// Dragnet [Ransomware]: dragnet-ransomware-2026-3287 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 351e8974-8849-5a50-b360-5dae4f2c3c0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
