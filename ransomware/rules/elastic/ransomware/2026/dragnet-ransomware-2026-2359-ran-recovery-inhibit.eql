// Dragnet [Ransomware]: dragnet-ransomware-2026-2359 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: fd9bb75a-9aca-5204-8187-fb1ec23f6606

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
