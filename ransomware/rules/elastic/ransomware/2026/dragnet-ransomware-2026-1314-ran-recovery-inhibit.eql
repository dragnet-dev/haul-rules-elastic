// Dragnet [Ransomware]: dragnet-ransomware-2026-1314 — Recovery Inhibition (worldleaks)
// Status: stable | Level: high | ID: d468da63-8f79-5cee-bb22-5952c735e864

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
