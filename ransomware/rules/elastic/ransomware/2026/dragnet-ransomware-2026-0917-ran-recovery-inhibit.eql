// Dragnet [Ransomware]: dragnet-ransomware-2026-0917 — Recovery Inhibition (lapsus$)
// Status: deprecated | Level: high | ID: 5df3199c-c845-5103-9690-81559a6f0828

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
