// Dragnet [Ransomware]: dragnet-ransomware-2026-0389 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: cd6ec99a-b8e6-5465-a45f-c743ffe5b1e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
