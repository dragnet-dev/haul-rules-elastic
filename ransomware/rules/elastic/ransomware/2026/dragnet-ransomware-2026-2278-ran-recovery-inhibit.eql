// Dragnet [Ransomware]: dragnet-ransomware-2026-2278 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ba23e8fe-b88b-5ca1-905f-8df497be3f3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
