// Dragnet [Ransomware]: dragnet-ransomware-2026-2706 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: a01b42a5-5887-55c3-abd6-3a2eb5e777d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
