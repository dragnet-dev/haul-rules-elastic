// Dragnet [Ransomware]: dragnet-ransomware-2026-0172 — Recovery Inhibition (ransomhouse)
// Status: stable | Level: high | ID: 2f0d5995-27ca-5b2a-8aa5-986cf9f1089f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
