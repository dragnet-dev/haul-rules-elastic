// Dragnet [Ransomware]: dragnet-ransomware-2026-1886 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 25ab3b5c-cd81-5762-b042-7598683591db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
