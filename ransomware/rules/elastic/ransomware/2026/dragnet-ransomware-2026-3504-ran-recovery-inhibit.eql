// Dragnet [Ransomware]: dragnet-ransomware-2026-3504 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: f70b2aa4-81e2-5ef2-98e6-54dddd2dc380

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
