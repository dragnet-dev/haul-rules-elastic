// Dragnet [Ransomware]: dragnet-ransomware-2026-1018 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: b72ae6a5-0df1-5efe-bd6f-a9ec350c02e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
