// Dragnet [Ransomware]: dragnet-ransomware-2026-0311 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 0984fe8b-b4f6-52f0-86b7-d6f177e7b70f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
