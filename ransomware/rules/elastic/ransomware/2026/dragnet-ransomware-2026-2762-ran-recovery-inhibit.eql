// Dragnet [Ransomware]: dragnet-ransomware-2026-2762 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 7c65f794-fc07-5139-9dc5-e88d9b609ce9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
