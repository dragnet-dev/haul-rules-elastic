// Dragnet [Ransomware]: dragnet-ransomware-2026-2413 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 7d8dd410-a12a-59c7-8cf9-1f00bdf7d302

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
