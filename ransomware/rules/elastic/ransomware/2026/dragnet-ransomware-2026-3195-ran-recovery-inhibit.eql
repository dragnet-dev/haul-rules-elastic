// Dragnet [Ransomware]: dragnet-ransomware-2026-3195 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 68ff95af-eea4-5a24-acdd-6c49798a9f62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
