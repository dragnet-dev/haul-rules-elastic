// Dragnet [Ransomware]: dragnet-ransomware-2026-3265 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: c2079b24-dc2b-5894-9907-c52b757399ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
