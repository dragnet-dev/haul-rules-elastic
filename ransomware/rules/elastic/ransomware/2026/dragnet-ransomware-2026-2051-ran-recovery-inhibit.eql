// Dragnet [Ransomware]: dragnet-ransomware-2026-2051 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a7155500-81b1-5707-ba10-cb8fbafa3c3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
