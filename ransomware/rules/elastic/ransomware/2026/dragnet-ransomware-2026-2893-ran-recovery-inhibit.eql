// Dragnet [Ransomware]: dragnet-ransomware-2026-2893 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: c33d3cd1-899b-5176-92eb-1e872d7cb114

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
