// Dragnet [Ransomware]: dragnet-ransomware-2026-0877 — Recovery Inhibition (insomnia)
// Status: test | Level: high | ID: 67113613-c555-5db3-b388-656dff1350b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
