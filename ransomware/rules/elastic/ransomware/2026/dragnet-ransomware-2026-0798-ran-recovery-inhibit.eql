// Dragnet [Ransomware]: dragnet-ransomware-2026-0798 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 7ee2c69f-a801-5ee9-93a2-7d976e0e906a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
