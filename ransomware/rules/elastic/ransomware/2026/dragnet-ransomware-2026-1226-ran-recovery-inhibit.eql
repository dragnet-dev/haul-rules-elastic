// Dragnet [Ransomware]: dragnet-ransomware-2026-1226 — Recovery Inhibition (worldleaks)
// Status: stable | Level: high | ID: 1d45cd26-5af5-5bf0-af2a-ee0c10f4e5ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
