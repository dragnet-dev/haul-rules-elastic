// Dragnet [Ransomware]: dragnet-ransomware-2026-0207 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c0c502cb-4b22-5e95-8993-349b82b147a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
