// Dragnet [Ransomware]: dragnet-ransomware-2026-1787 — Recovery Inhibition (beast)
// Status: test | Level: high | ID: a0a6fd0b-56f0-5f6c-9905-6bc23d26fa09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
