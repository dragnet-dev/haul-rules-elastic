// Dragnet [Ransomware]: dragnet-ransomware-2026-1775 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 351c05c4-7d76-5129-a689-9a8eb44c07ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
