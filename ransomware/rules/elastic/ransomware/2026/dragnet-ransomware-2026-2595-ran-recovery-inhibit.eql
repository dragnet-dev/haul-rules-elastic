// Dragnet [Ransomware]: dragnet-ransomware-2026-2595 — Recovery Inhibition (threeam)
// Status: stable | Level: high | ID: 0801bc83-1d1c-59c4-b8fb-148aba08497f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
