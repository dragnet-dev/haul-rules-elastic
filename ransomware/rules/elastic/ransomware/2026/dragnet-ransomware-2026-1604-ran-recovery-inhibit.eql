// Dragnet [Ransomware]: dragnet-ransomware-2026-1604 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 6622cc0a-f4c8-5546-bfd5-f6bbafc1fce6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
