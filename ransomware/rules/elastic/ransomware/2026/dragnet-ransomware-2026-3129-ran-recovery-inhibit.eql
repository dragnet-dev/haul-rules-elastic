// Dragnet [Ransomware]: dragnet-ransomware-2026-3129 — Recovery Inhibition (krybit)
// Status: stable | Level: high | ID: f6758c94-97c4-59ea-8f23-89fd59ef7db4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
