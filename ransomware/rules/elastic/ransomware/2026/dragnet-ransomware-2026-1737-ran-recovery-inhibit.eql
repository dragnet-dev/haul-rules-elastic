// Dragnet [Ransomware]: dragnet-ransomware-2026-1737 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: 3eeca2b6-49d3-5746-934a-76ecbb08381f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
