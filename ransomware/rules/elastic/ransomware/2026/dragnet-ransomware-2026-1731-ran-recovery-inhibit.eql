// Dragnet [Ransomware]: dragnet-ransomware-2026-1731 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: ba7f81a2-bcd1-53e6-9ab7-e4b2109bd857

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
