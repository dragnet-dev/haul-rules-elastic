// Dragnet [Ransomware]: dragnet-ransomware-2026-1337 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 6a616e61-75b3-5a17-a510-68d3ca56e6ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
