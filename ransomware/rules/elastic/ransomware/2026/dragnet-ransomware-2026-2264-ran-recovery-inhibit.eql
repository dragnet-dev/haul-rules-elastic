// Dragnet [Ransomware]: dragnet-ransomware-2026-2264 — Recovery Inhibition (gunra)
// Status: stable | Level: high | ID: ab85ea1d-ecff-51da-96bd-b1be08fe315e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
