// Dragnet [Ransomware]: dragnet-ransomware-2026-3248 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: b4a56627-0ffb-51cc-babc-e5f621852013

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
