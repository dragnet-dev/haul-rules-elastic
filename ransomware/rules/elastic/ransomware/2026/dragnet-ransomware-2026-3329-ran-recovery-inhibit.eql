// Dragnet [Ransomware]: dragnet-ransomware-2026-3329 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 9c8b01e3-f214-5fab-b385-45c0d7fa7a19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
