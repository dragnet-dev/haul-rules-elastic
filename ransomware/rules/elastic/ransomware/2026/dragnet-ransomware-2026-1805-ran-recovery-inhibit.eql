// Dragnet [Ransomware]: dragnet-ransomware-2026-1805 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 8acff2b8-7b26-53e3-8713-5645bc24dade

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
