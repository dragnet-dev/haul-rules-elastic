// Dragnet [Ransomware]: dragnet-ransomware-2026-0835 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 75c4e49a-01df-538a-8add-87bb04066efe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
