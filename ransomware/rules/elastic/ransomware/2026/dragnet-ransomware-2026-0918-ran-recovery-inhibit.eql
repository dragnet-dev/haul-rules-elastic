// Dragnet [Ransomware]: dragnet-ransomware-2026-0918 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 48dec302-6607-53c7-9d35-509e37b92011

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
