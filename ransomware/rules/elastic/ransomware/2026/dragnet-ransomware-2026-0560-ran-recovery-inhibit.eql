// Dragnet [Ransomware]: dragnet-ransomware-2026-0560 — Recovery Inhibition (fulcrumsec)
// Status: stable | Level: high | ID: 58a30839-9d35-5f38-8171-c43113a2167b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
