// Dragnet [Ransomware]: dragnet-ransomware-2026-1750 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: fb929127-1803-5131-b7ef-20b96632f6ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
