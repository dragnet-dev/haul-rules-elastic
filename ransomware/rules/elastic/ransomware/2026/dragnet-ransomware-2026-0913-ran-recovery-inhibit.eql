// Dragnet [Ransomware]: dragnet-ransomware-2026-0913 — Recovery Inhibition (krybit)
// Status: stable | Level: high | ID: 8552d51e-e398-5104-aafd-51849b2e475b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
