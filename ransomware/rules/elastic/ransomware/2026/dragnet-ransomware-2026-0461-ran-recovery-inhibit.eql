// Dragnet [Ransomware]: dragnet-ransomware-2026-0461 — Recovery Inhibition (nitrogen)
// Status: test | Level: high | ID: c1e5532a-d9f1-52c5-91d8-c1209faca2f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
