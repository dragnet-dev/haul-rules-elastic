// Dragnet [Ransomware]: dragnet-ransomware-2026-1680 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 4fe7d135-f738-51f0-aaba-0c068a5c1df5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
