// Dragnet [Ransomware]: dragnet-ransomware-2026-2180 — Recovery Inhibition (shadowbyt3$)
// Status: deprecated | Level: high | ID: 7515efb6-b0d0-5727-8617-a837a13c17e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
