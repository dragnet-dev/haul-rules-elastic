// Dragnet [Ransomware]: dragnet-ransomware-2026-2554 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: e4cf24ed-7dd0-5539-94a1-d6956c4b6b83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
