// Dragnet [Ransomware]: dragnet-ransomware-2026-0253 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 816e7190-9e61-5040-8c2e-0bd84bedfae9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
