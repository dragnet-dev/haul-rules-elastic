// Dragnet [Ransomware]: dragnet-ransomware-2026-3553 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 5dfdec2e-b84b-5769-8c8f-0c4e1247c701

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
