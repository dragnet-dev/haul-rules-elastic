// Dragnet [Ransomware]: dragnet-ransomware-2026-1974 — Recovery Inhibition (ms13089)
// Status: test | Level: high | ID: 0cc198c3-1d13-52c3-a5da-5cc31d113800

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
