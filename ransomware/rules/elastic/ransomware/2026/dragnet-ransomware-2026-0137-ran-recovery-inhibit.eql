// Dragnet [Ransomware]: dragnet-ransomware-2026-0137 — Recovery Inhibition (nitrogen)
// Status: test | Level: high | ID: 3ca0fd20-52d2-52e8-8908-568f97cae07c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
