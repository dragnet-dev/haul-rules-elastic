// Dragnet [Ransomware]: dragnet-ransomware-2026-0850 — Recovery Inhibition (LeakBazaar)
// Status: stable | Level: high | ID: 2f5781e4-571e-55dc-9276-361d6541063c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
