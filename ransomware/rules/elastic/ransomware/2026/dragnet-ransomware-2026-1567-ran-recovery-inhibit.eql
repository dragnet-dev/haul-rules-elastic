// Dragnet [Ransomware]: dragnet-ransomware-2026-1567 — Recovery Inhibition (chaos)
// Status: stable | Level: high | ID: 4521733e-c8d9-512b-999c-d64bca73791c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
