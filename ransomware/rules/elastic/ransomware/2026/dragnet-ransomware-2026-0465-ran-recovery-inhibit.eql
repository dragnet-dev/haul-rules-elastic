// Dragnet [Ransomware]: dragnet-ransomware-2026-0465 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 490e2870-37da-5a4e-9827-82417cfb920e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
