// Dragnet [Ransomware]: dragnet-ransomware-2026-2782 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: cb745c71-2bb7-5c58-a9f5-092b088f1f1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
