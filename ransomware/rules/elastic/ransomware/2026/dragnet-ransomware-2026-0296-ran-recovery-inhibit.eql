// Dragnet [Ransomware]: dragnet-ransomware-2026-0296 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: 199dfcf3-2fcf-57f9-9194-5a24fe2a2665

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
