// Dragnet [Ransomware]: dragnet-ransomware-2026-0650 — Recovery Inhibition (anubis)
// Status: stable | Level: high | ID: 0d881f3e-fec4-52fd-89d2-18d9faf78954

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
