// Dragnet [Ransomware]: dragnet-ransomware-2026-3123 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: cf851e9f-c755-5239-9464-33d855032fe5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
