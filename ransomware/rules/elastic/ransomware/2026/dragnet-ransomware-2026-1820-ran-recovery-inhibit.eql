// Dragnet [Ransomware]: dragnet-ransomware-2026-1820 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 99df45fa-d045-5c32-980c-959e7349d402

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
