// Dragnet [Ransomware]: dragnet-ransomware-2026-0105 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 37ccd276-2cdb-50b5-a637-2c05a8cee78f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
