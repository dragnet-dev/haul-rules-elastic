// Dragnet [Ransomware]: dragnet-ransomware-2026-0568 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: 7dfc77e3-8bcb-5c25-be56-3a0966987723

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
