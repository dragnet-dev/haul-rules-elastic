// Dragnet [Ransomware]: dragnet-ransomware-2026-2555 — Recovery Inhibition (aurora)
// Status: stable | Level: high | ID: 218c6bb1-b76e-5fdf-8193-9fe254e25fe1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
