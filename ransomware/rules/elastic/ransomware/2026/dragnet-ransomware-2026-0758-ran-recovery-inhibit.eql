// Dragnet [Ransomware]: dragnet-ransomware-2026-0758 — Recovery Inhibition (sinobi)
// Status: stable | Level: high | ID: bfbf6af3-f64f-57fc-963a-a44616c06828

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
