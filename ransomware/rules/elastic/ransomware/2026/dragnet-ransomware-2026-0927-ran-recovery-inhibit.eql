// Dragnet [Ransomware]: dragnet-ransomware-2026-0927 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: bd77821d-7e96-52ef-92fd-caec39ee769b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
