// Dragnet [Ransomware]: dragnet-ransomware-2026-2990 — Recovery Inhibition (vect)
// Status: deprecated | Level: high | ID: f75361b1-999b-56b4-a501-750360dc0f7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
