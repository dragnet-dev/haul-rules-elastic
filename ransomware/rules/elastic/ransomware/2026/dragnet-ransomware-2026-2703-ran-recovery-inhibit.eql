// Dragnet [Ransomware]: dragnet-ransomware-2026-2703 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: effe1729-97eb-5c14-833a-90c7fb15c1f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
