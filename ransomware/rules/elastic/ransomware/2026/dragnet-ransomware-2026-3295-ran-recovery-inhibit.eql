// Dragnet [Ransomware]: dragnet-ransomware-2026-3295 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a3b29a85-2021-5684-b24c-ba5385ac061e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
