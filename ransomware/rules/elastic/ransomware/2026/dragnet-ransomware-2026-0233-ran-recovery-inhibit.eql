// Dragnet [Ransomware]: dragnet-ransomware-2026-0233 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 22e8fb4f-7b43-5398-8e19-bfc0301e64bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
