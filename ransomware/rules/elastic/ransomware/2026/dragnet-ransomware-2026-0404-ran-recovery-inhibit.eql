// Dragnet [Ransomware]: dragnet-ransomware-2026-0404 — Recovery Inhibition (blackshrantac)
// Status: test | Level: high | ID: 0c7c51cd-f015-5cb1-8bcd-0aaa8247ac06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
