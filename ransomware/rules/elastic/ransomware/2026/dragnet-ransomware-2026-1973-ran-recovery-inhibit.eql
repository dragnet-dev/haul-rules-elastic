// Dragnet [Ransomware]: dragnet-ransomware-2026-1973 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 1f2eb0a5-7e58-5b65-b106-80bcea6007cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
