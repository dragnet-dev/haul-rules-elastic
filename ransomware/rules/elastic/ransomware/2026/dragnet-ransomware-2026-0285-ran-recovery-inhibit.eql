// Dragnet [Ransomware]: dragnet-ransomware-2026-0285 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f017bcb0-f7e8-5728-b8df-d5afdb332042

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
