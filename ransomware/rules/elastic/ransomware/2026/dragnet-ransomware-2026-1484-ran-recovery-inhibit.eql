// Dragnet [Ransomware]: dragnet-ransomware-2026-1484 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: ad2b054f-8a49-5c6a-87fc-02cda4861685

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
