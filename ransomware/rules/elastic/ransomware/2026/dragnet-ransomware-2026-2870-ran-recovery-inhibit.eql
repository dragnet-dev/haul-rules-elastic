// Dragnet [Ransomware]: dragnet-ransomware-2026-2870 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 073f6a3b-0c13-5910-b974-766816501da0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
