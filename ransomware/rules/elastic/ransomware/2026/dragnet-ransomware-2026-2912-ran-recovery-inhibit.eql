// Dragnet [Ransomware]: dragnet-ransomware-2026-2912 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 6f75599e-477d-5fab-875a-0b74715c15eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
