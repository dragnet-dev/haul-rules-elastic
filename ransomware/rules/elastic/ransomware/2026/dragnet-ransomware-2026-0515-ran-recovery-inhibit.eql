// Dragnet [Ransomware]: dragnet-ransomware-2026-0515 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: c84a6864-1154-5d54-9fa1-069c661a4b0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
