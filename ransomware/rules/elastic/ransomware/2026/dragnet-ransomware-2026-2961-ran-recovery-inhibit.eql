// Dragnet [Ransomware]: dragnet-ransomware-2026-2961 — Recovery Inhibition (direwolf)
// Status: test | Level: high | ID: ad62d550-5048-50ce-96a3-7b594359727a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
