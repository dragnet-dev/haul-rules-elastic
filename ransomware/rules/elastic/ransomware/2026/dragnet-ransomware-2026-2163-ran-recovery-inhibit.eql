// Dragnet [Ransomware]: dragnet-ransomware-2026-2163 — Recovery Inhibition (threeam)
// Status: stable | Level: high | ID: fb4b0e33-1297-5cd1-b8be-fe49d5c0582e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
