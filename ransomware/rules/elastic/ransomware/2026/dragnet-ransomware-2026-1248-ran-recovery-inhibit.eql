// Dragnet [Ransomware]: dragnet-ransomware-2026-1248 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 732c33b2-d6c6-5081-adf1-93203036de2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
