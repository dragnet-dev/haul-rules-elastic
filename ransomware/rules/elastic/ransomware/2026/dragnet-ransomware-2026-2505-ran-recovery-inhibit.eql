// Dragnet [Ransomware]: dragnet-ransomware-2026-2505 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 7b1f2888-2a3b-5ef8-bc00-b83fa5894695

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
