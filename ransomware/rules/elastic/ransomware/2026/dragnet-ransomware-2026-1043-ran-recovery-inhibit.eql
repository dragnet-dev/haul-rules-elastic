// Dragnet [Ransomware]: dragnet-ransomware-2026-1043 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: afb34ba5-d7fb-5100-9b30-a0f521290bf4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
