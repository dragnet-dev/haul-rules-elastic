// Dragnet [Ransomware]: dragnet-ransomware-2026-3030 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: f3579981-d433-5c67-a98e-c1878dfffefa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
