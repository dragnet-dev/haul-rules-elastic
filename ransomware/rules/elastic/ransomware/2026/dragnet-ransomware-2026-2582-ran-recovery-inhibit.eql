// Dragnet [Ransomware]: dragnet-ransomware-2026-2582 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c5fdae51-b3bc-5fc8-acb6-21aa51468cdc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
