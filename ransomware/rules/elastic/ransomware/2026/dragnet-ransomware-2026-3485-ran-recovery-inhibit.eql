// Dragnet [Ransomware]: dragnet-ransomware-2026-3485 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 4faf2656-87a2-5022-b2a8-1281449d3abe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
