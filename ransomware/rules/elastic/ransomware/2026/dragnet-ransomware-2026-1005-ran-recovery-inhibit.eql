// Dragnet [Ransomware]: dragnet-ransomware-2026-1005 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 2ef84e2c-c6db-52b7-9a4d-206154e83b28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
