// Dragnet [Ransomware]: dragnet-ransomware-2026-2527 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 08ce21f1-b8d9-5402-8814-fd57a4ae34fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
