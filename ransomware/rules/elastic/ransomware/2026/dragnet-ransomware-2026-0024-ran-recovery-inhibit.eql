// Dragnet [Ransomware]: dragnet-ransomware-2026-0024 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 71b4dd30-463e-5f8d-8fbf-7c7908907d2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
