// Dragnet [Ransomware]: dragnet-ransomware-2026-3452 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7f404364-d903-5ee8-b6a1-77aa105381e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
