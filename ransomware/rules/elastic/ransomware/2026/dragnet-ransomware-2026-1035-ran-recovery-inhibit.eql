// Dragnet [Ransomware]: dragnet-ransomware-2026-1035 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 0d6c5f1d-fe04-5d4d-81f0-43eb1a7c7f05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
