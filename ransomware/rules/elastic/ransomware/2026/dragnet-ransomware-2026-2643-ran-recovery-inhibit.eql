// Dragnet [Ransomware]: dragnet-ransomware-2026-2643 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 63ef34ca-8682-5fe3-9ab3-7427d8b4d769

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
