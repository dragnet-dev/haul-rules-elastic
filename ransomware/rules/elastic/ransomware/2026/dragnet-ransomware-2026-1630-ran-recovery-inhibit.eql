// Dragnet [Ransomware]: dragnet-ransomware-2026-1630 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: f75fba34-4b90-5ef0-8a98-f9622ed02db9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
