// Dragnet [Ransomware]: dragnet-ransomware-2026-1513 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 1023b613-7f74-5eec-996b-0263fc327719

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
