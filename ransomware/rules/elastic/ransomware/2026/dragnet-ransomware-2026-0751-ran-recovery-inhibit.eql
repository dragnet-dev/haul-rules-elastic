// Dragnet [Ransomware]: dragnet-ransomware-2026-0751 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 60a6c40b-5509-52b7-960a-9843b197718a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
