// Dragnet [Ransomware]: dragnet-ransomware-2026-3405 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: af5a6e2d-6285-5dee-a13a-085195fa499a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
