// Dragnet [Ransomware]: dragnet-ransomware-2026-1481 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 1c521d77-372a-52ea-8e10-a30f3f75051c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
