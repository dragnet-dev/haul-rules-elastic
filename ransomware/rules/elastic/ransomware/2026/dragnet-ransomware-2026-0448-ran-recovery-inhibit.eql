// Dragnet [Ransomware]: dragnet-ransomware-2026-0448 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 97f638f2-481e-5570-b944-d31000a94f9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
