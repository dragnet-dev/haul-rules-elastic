// Dragnet [Ransomware]: dragnet-ransomware-2026-0744 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: dded2164-e119-52ff-a368-236e43b145ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
