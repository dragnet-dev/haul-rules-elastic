// Dragnet [Ransomware]: dragnet-ransomware-2026-0967 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 49c9423d-cca9-5c0f-9959-f47e56aecd7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
