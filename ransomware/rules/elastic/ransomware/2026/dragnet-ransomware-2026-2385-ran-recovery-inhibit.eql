// Dragnet [Ransomware]: dragnet-ransomware-2026-2385 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 812e5099-1c23-5962-86e7-16a2bf4bca31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
