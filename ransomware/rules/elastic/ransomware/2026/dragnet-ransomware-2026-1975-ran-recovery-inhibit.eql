// Dragnet [Ransomware]: dragnet-ransomware-2026-1975 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 87058353-1ba6-5e4a-84bb-d6a2fbf5d886

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
