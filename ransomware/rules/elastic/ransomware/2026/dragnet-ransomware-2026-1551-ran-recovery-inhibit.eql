// Dragnet [Ransomware]: dragnet-ransomware-2026-1551 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: f647f3e4-0c12-59dd-ad08-2446fa058f80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
