// Dragnet [Ransomware]: dragnet-ransomware-2026-0853 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 8ee9ad75-22de-595e-9146-3140e542ebfc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
