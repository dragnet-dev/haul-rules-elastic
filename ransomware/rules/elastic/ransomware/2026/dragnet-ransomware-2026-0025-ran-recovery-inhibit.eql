// Dragnet [Ransomware]: dragnet-ransomware-2026-0025 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 914428e7-8a22-576c-8193-359baf0ba88c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
