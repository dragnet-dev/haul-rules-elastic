// Dragnet [Ransomware]: dragnet-ransomware-2026-1465 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 2e32ff15-9358-5139-9481-d1b0d97cb0a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
