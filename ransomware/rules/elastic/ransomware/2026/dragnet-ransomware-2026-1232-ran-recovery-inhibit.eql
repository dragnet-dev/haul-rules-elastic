// Dragnet [Ransomware]: dragnet-ransomware-2026-1232 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 03b83dd9-21f0-50b4-8f81-ddb664bd6845

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
