// Dragnet [Ransomware]: dragnet-ransomware-2026-2249 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 30abd218-f9c1-5005-856d-e46067893d36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
