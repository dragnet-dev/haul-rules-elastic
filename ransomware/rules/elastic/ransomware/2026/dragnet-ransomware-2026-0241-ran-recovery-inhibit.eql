// Dragnet [Ransomware]: dragnet-ransomware-2026-0241 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 98a41f87-101b-5e02-89ee-9284ceefcd5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
