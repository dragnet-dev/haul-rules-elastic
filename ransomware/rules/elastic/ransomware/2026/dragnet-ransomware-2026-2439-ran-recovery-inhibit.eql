// Dragnet [Ransomware]: dragnet-ransomware-2026-2439 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: a90b9fb3-ab1a-5e26-8747-dea9be72dfad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
