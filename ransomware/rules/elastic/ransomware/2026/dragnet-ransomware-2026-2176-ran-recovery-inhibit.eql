// Dragnet [Ransomware]: dragnet-ransomware-2026-2176 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 75d92cbc-0d05-5045-a27d-71cfa894f98b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
