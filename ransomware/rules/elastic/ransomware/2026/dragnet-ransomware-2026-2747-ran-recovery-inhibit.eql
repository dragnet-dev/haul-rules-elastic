// Dragnet [Ransomware]: dragnet-ransomware-2026-2747 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 83559317-46d3-5cf2-b665-9be546fd33d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
