// Dragnet [Ransomware]: dragnet-ransomware-2026-0724 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 80a91306-d434-55e0-8031-3254e2ee452a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
