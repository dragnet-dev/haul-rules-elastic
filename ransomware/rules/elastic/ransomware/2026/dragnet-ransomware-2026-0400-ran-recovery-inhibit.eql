// Dragnet [Ransomware]: dragnet-ransomware-2026-0400 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 9f991051-81bc-54a9-89a5-155b3662aa2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
