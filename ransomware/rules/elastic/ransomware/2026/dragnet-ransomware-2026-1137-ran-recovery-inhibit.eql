// Dragnet [Ransomware]: dragnet-ransomware-2026-1137 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 37fc0fca-8a1c-5a38-b968-5039a49de848

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
