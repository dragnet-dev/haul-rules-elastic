// Dragnet [Ransomware]: dragnet-ransomware-2026-0488 — Recovery Inhibition (fulcrumsec)
// Status: stable | Level: high | ID: f617cb36-9ad3-5f64-8b46-9459d46f9315

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
