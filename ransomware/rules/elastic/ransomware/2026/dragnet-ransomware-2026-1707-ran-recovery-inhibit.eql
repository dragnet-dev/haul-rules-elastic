// Dragnet [Ransomware]: dragnet-ransomware-2026-1707 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 8680e15c-c75f-5800-a1fb-22f1b1bf92fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
