// Dragnet [Ransomware]: dragnet-ransomware-2026-0904 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: a7d10271-7d51-5a10-81b1-f9398ad06660

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
