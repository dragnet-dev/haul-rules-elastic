// Dragnet [Ransomware]: dragnet-ransomware-2026-0376 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: 99ec790a-97cd-5355-a387-97f604cf4372

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
