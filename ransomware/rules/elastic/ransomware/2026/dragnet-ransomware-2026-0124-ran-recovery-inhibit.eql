// Dragnet [Ransomware]: dragnet-ransomware-2026-0124 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 1f0f1ff4-fe7b-56bc-aaf1-f47d1d5c1886

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
