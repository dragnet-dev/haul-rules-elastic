// Dragnet [Ransomware]: dragnet-ransomware-2026-0507 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: e8ad985c-dc14-5d6c-a5f2-d1695ee88f0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
