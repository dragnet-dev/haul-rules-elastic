// Dragnet [Ransomware]: dragnet-ransomware-2026-0090 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: 4921d36d-0bc9-5e48-91f7-2987097c1cf4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
