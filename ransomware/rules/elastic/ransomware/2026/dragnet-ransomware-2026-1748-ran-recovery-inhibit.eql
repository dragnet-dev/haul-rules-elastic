// Dragnet [Ransomware]: dragnet-ransomware-2026-1748 — Recovery Inhibition (chaos)
// Status: stable | Level: high | ID: d602a991-7d62-5850-b13c-2af3da0b4946

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
