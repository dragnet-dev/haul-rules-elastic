// Dragnet [Ransomware]: dragnet-ransomware-2026-0616 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 381d5c73-5266-5140-a116-6f41667cc8df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
