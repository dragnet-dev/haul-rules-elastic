// Dragnet [Ransomware]: dragnet-ransomware-2026-3168 — Recovery Inhibition (payoutsking)
// Status: test | Level: high | ID: eb322141-d91c-59fc-b147-dae130fe9ad6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
