// Dragnet [Ransomware]: dragnet-ransomware-2026-1070 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 8a6f12df-cb76-5c67-a32e-2fd479679416

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
