// Dragnet [Ransomware]: dragnet-ransomware-2026-1621 — Recovery Inhibition (embargo)
// Status: stable | Level: high | ID: 662b2581-e2fd-5ad1-a99d-1b63ce3cd410

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
