// Dragnet [Ransomware]: dragnet-ransomware-2026-2214 — Recovery Inhibition (medusalocker)
// Status: stable | Level: high | ID: 4472da21-84c2-54d7-b74d-e6b33a5789ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
