// Dragnet [Ransomware]: dragnet-ransomware-2026-1285 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: aa297f74-3233-5fd6-9703-57bb598d647d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
