// Dragnet [Ransomware]: dragnet-ransomware-2026-1191 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: c216b610-7897-5e2a-a259-631ded78a63c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
