// Dragnet [Ransomware]: dragnet-ransomware-2026-3313 — Recovery Inhibition (beast)
// Status: test | Level: high | ID: 4a5fb86f-71c1-5a98-90a8-e90cf0d35853

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
