// Dragnet [Ransomware]: dragnet-ransomware-2026-0611 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 612a4518-8998-5120-91b2-e251741840fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
