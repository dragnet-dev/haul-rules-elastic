// Dragnet [Ransomware]: dragnet-ransomware-2026-1114 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 47dd6e4e-b95d-58db-8e94-4e3e30202e97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
