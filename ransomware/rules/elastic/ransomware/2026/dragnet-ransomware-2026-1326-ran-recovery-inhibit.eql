// Dragnet [Ransomware]: dragnet-ransomware-2026-1326 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: db14a3b4-8300-5e16-b5ad-5f957ee1963b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
