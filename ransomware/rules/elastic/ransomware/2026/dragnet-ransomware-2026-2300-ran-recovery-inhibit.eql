// Dragnet [Ransomware]: dragnet-ransomware-2026-2300 — Recovery Inhibition (netrunner)
// Status: stable | Level: high | ID: f408225d-6ec4-5bd2-a808-7161ff93bc5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
