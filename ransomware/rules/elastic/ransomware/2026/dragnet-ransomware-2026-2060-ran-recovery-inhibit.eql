// Dragnet [Ransomware]: dragnet-ransomware-2026-2060 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: a28d2def-fcfc-584e-9cc7-3be058cf6713

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
