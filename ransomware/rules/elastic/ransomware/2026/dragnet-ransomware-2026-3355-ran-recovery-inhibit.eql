// Dragnet [Ransomware]: dragnet-ransomware-2026-3355 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 392c1798-f2d5-550e-9ca5-8f6c431df940

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
