// Dragnet [Ransomware]: dragnet-ransomware-2026-2204 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 318bd30e-326a-5e8a-ae09-681c374a769c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
