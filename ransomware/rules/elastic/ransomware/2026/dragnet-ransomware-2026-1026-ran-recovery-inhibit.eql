// Dragnet [Ransomware]: dragnet-ransomware-2026-1026 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: c454ebef-7eb3-556a-a372-806f34f98f1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
