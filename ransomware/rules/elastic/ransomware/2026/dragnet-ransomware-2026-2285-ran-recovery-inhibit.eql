// Dragnet [Ransomware]: dragnet-ransomware-2026-2285 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 98fecdee-a08d-54cd-9daa-30da09fed25e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
