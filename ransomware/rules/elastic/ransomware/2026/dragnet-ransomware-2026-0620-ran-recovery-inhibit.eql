// Dragnet [Ransomware]: dragnet-ransomware-2026-0620 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 9da998db-528b-5736-8421-c49e3757b4a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
