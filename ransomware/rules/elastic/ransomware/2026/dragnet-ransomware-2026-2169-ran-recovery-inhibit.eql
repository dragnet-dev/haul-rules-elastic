// Dragnet [Ransomware]: dragnet-ransomware-2026-2169 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 20178072-45ac-57a1-8217-2bca4047992a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
