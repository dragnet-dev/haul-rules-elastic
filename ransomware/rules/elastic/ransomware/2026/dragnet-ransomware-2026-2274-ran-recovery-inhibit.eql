// Dragnet [Ransomware]: dragnet-ransomware-2026-2274 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: b50c76de-8c06-53cc-bbdb-e92608190155

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
