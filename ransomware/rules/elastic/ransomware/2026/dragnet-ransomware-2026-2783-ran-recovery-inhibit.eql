// Dragnet [Ransomware]: dragnet-ransomware-2026-2783 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 7a10e6d5-de7f-507c-9c29-1434f791e731

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
