// Dragnet [Ransomware]: dragnet-ransomware-2026-3559 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: a9c1dc95-e9cc-550c-b676-db2d06e0e9ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
