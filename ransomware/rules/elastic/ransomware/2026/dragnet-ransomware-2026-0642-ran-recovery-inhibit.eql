// Dragnet [Ransomware]: dragnet-ransomware-2026-0642 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: de623abf-ccb7-5cd0-aa10-2331a9afc135

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
