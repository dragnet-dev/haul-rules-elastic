// Dragnet [Ransomware]: dragnet-ransomware-2026-3494 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: a783adb5-3a94-53b6-b43c-2580ea084d6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
