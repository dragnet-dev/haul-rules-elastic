// Dragnet [Ransomware]: dragnet-ransomware-2026-0235 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 9c9fac95-3240-5ba3-909e-97a0bbb8c7ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
