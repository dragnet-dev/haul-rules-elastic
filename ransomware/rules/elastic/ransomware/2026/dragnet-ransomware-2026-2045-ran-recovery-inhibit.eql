// Dragnet [Ransomware]: dragnet-ransomware-2026-2045 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: f0a35a09-914a-5f9e-bf7c-3b38fb83b208

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
