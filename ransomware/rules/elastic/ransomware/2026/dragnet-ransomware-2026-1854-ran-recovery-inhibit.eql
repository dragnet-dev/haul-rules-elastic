// Dragnet [Ransomware]: dragnet-ransomware-2026-1854 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: c353f318-a6e0-57e8-b333-a09693804610

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
