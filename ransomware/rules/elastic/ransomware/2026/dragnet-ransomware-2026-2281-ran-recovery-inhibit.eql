// Dragnet [Ransomware]: dragnet-ransomware-2026-2281 — Recovery Inhibition (payoutsking)
// Status: stable | Level: high | ID: b3ec9fe1-ff54-5120-88b0-7a2da5ae10ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
