// Dragnet [Ransomware]: dragnet-ransomware-2026-0606 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: fff14c79-5b82-53cb-8e46-77fe16210f88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
