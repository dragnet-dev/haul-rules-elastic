// Dragnet [Ransomware]: dragnet-ransomware-2026-0777 — Recovery Inhibition (netrunner)
// Status: stable | Level: high | ID: ee57a35f-628f-595d-9e27-cf02d9777415

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
