// Dragnet [Ransomware]: dragnet-ransomware-2026-0645 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: e20f4b6d-a541-561b-af35-9aee308c4fee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
