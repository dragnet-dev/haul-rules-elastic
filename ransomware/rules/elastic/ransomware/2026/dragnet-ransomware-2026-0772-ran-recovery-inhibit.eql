// Dragnet [Ransomware]: dragnet-ransomware-2026-0772 — Recovery Inhibition (LeakBazaar)
// Status: stable | Level: high | ID: 20abee5f-de8c-5410-b919-d2bad9e3ef42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
