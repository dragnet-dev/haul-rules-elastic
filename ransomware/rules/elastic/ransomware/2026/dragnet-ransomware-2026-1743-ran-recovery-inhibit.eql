// Dragnet [Ransomware]: dragnet-ransomware-2026-1743 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1748d08a-94ad-563f-bd62-586a65266790

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
