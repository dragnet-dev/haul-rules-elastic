// Dragnet [Ransomware]: dragnet-ransomware-2026-3244 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: 273c87cb-f393-5841-ac76-2cf914f67e07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
