// Dragnet [Ransomware]: dragnet-ransomware-2026-2375 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: 89a28354-b81a-5a35-886e-ed8ac50b6fa9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
