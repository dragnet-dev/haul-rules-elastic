// Dragnet [Ransomware]: dragnet-ransomware-2026-1843 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 942f9ea4-4335-53a1-95ae-424b34be66ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
