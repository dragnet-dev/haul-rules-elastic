// Dragnet [Ransomware]: dragnet-ransomware-2026-2317 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 9cd7f962-9f56-56f8-acba-974cb28839a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
