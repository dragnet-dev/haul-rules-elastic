// Dragnet [Ransomware]: dragnet-ransomware-2026-2321 — Recovery Inhibition (vect)
// Status: deprecated | Level: high | ID: c1abdb7a-cd08-56d9-8579-496ea6666348

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
