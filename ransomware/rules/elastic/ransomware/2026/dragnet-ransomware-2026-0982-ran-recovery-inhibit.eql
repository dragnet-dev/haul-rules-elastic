// Dragnet [Ransomware]: dragnet-ransomware-2026-0982 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 43576fce-a525-5b79-a891-8a70735df39c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
