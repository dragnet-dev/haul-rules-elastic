// Dragnet [Ransomware]: dragnet-ransomware-2026-0797 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: efa470d1-868c-507a-898b-140d5015a3aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
