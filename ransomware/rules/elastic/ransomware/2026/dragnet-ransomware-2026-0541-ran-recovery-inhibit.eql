// Dragnet [Ransomware]: dragnet-ransomware-2026-0541 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 678fecee-1937-5894-b9a1-24810c205171

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
