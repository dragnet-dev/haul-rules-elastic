// Dragnet [Ransomware]: dragnet-ransomware-2026-1477 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 3b378dbb-54c6-52d6-b157-13a617916e2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
