// Dragnet [Ransomware]: dragnet-ransomware-2026-3059 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: c752d5df-08bb-596a-8e6c-713146f3b42e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
