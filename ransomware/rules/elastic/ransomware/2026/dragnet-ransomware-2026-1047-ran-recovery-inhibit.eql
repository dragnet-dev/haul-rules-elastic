// Dragnet [Ransomware]: dragnet-ransomware-2026-1047 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 73eb778b-f287-5f4d-916e-d5732dbc33bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
