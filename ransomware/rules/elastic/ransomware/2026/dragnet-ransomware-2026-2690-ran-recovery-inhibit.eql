// Dragnet [Ransomware]: dragnet-ransomware-2026-2690 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 5532c019-6826-59aa-aa63-cc705bbf7be0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
