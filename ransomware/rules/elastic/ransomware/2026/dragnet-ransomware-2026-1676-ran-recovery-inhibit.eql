// Dragnet [Ransomware]: dragnet-ransomware-2026-1676 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 46248ff9-84d0-555f-8754-34b0a18851d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
