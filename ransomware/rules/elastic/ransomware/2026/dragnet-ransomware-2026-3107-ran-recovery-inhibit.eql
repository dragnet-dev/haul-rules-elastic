// Dragnet [Ransomware]: dragnet-ransomware-2026-3107 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 61861c39-3852-5513-9a32-d50847275bb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
