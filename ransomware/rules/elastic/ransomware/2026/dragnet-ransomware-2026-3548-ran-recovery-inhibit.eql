// Dragnet [Ransomware]: dragnet-ransomware-2026-3548 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: cc9eb5a6-4535-5be4-a8ee-f6b1a542a0f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
