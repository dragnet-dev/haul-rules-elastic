// Dragnet [Ransomware]: dragnet-ransomware-2026-2795 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: f1136cfe-a593-5fa5-8217-3ef41a24671e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
