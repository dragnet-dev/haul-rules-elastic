// Dragnet [Ransomware]: dragnet-ransomware-2026-0391 — Recovery Inhibition (interlock)
// Status: test | Level: high | ID: c2243791-d94e-5200-b60d-1edf839948be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
