// Dragnet [Ransomware]: dragnet-ransomware-2026-1897 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 765de3e4-0400-59c7-a22f-d2cd68308dca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
