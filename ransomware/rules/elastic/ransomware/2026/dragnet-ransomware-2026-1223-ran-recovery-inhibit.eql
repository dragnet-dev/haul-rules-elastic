// Dragnet [Ransomware]: dragnet-ransomware-2026-1223 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: fc33bf0d-dfaa-5988-bf31-e88c97e39829

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
