// Dragnet [Ransomware]: dragnet-ransomware-2026-0246 — Recovery Inhibition (chaos)
// Status: stable | Level: high | ID: 292c4f9f-2496-510e-99b2-701761463457

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
