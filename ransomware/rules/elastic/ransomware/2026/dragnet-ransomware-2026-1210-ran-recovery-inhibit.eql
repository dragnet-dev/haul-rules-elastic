// Dragnet [Ransomware]: dragnet-ransomware-2026-1210 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 22f47289-8da5-55f3-9382-edbbecee18ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
