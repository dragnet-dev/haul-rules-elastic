// Dragnet [Ransomware]: dragnet-ransomware-2026-0126 — Recovery Inhibition (cipherforce)
// Status: stable | Level: high | ID: 273b20af-947b-51c4-bf12-da0061047b99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
