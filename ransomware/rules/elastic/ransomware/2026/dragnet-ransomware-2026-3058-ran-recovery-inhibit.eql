// Dragnet [Ransomware]: dragnet-ransomware-2026-3058 — Recovery Inhibition (tengu)
// Status: stable | Level: high | ID: c9a1993e-6d2d-57b6-9cfa-74984e8098a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
