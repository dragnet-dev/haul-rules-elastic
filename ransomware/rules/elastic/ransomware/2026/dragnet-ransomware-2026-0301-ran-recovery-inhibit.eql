// Dragnet [Ransomware]: dragnet-ransomware-2026-0301 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 46e8af8f-c88f-5bb4-8469-d974c2a7c1f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
