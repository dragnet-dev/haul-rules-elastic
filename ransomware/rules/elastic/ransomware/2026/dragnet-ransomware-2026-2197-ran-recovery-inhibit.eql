// Dragnet [Ransomware]: dragnet-ransomware-2026-2197 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 29b0514a-d401-5480-8b12-255a2c55a792

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
