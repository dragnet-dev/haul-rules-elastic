// Dragnet [Ransomware]: dragnet-ransomware-2026-2689 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: c49e3db8-d4aa-5b96-ad64-fed45fc52c35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
