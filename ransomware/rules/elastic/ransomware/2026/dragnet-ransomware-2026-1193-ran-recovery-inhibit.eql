// Dragnet [Ransomware]: dragnet-ransomware-2026-1193 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: e276f721-299a-5663-9344-e67c7f4d3c38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
