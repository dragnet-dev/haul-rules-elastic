// Dragnet [Ransomware]: dragnet-ransomware-2026-1883 — Recovery Inhibition (genesis)
// Status: stable | Level: high | ID: 2d19a99a-846e-5210-a2a3-743dd072a7a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
