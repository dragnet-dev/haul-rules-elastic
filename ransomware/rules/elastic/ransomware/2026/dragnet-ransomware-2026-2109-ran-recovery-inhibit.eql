// Dragnet [Ransomware]: dragnet-ransomware-2026-2109 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: b9bc669b-c4c0-55c7-8604-1a60199681b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
