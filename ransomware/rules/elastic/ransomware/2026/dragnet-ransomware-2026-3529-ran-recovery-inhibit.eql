// Dragnet [Ransomware]: dragnet-ransomware-2026-3529 — Recovery Inhibition (krybit)
// Status: stable | Level: high | ID: 46542c44-4ddd-5148-8bf7-02e1c176b22e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
