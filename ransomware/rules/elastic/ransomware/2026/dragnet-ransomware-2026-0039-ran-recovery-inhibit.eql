// Dragnet [Ransomware]: dragnet-ransomware-2026-0039 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 70d39127-261b-5341-96d0-2c59c52e5161

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
