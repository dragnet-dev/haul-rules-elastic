// Dragnet [Ransomware]: dragnet-ransomware-2026-2373 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: 46d36654-ca1c-54ed-83d2-44dd9c5f86b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
