// Dragnet [Ransomware]: dragnet-ransomware-2026-2089 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 29645da4-90d8-55ab-bec0-00823cd81833

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
