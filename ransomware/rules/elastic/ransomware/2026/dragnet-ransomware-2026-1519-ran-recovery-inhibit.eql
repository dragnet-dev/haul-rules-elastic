// Dragnet [Ransomware]: dragnet-ransomware-2026-1519 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d0ae8ab6-154d-5b4a-ac80-45fd048f1826

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
