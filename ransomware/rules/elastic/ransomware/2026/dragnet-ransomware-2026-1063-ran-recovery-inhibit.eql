// Dragnet [Ransomware]: dragnet-ransomware-2026-1063 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 0a4abcb5-3758-59c6-8c2f-ab0fa189cbbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
