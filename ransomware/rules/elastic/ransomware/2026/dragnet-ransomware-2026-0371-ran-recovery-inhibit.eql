// Dragnet [Ransomware]: dragnet-ransomware-2026-0371 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: d487a128-0d38-5f38-98a0-c635cadbb820

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
