// Dragnet [Ransomware]: dragnet-ransomware-2026-1646 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: a5dfe0e3-85bf-5fc9-9969-acb9ef3cc231

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
