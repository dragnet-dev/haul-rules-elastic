// Dragnet [Ransomware]: dragnet-ransomware-2026-2000 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 46ab302c-e3d8-5402-b46e-8809df8aeab2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
