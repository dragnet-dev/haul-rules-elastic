// Dragnet [Ransomware]: dragnet-ransomware-2026-1570 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 89040d0d-3d4d-51ea-8423-43f71e286f8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
