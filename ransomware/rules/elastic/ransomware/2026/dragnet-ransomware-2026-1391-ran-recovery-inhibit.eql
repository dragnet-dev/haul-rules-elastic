// Dragnet [Ransomware]: dragnet-ransomware-2026-1391 — Recovery Inhibition (shadowbyt3$)
// Status: deprecated | Level: high | ID: 3c7818a4-cbb3-5ff6-bfac-5a3b2aaad8fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
