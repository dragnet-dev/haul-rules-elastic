// Dragnet [Ransomware]: dragnet-ransomware-2026-3364 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 7dbbde4a-af34-55f8-9a71-ad47ed748bba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
