// Dragnet [Ransomware]: dragnet-ransomware-2026-0244 — Recovery Inhibition (spacebears)
// Status: test | Level: high | ID: ae96fafc-8f98-5fcc-8cd3-3005c61701e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
