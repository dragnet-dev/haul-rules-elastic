// Dragnet [Ransomware]: dragnet-ransomware-2026-0008 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 35bf722e-4222-5f5d-9f1e-1fab9300dd9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
