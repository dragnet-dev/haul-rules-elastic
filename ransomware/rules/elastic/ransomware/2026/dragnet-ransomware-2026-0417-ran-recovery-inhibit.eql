// Dragnet [Ransomware]: dragnet-ransomware-2026-0417 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 5896f7ce-e512-59cc-9ae7-3562e0c7fd2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
