// Dragnet [Ransomware]: dragnet-ransomware-2026-1352 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 574dc27a-5fdf-5c9c-9a86-5d0b3ca892d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
