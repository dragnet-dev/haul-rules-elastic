// Dragnet [Ransomware]: dragnet-ransomware-2026-2272 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 8e2ef8c6-cdfd-5bd9-af61-66c82967f033

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
