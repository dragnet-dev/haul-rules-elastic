// Dragnet [Ransomware]: dragnet-ransomware-2026-2403 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 92446d77-fb4e-5801-a283-1cfd34c4295f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
