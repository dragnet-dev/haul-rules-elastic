// Dragnet [Ransomware]: dragnet-ransomware-2026-3224 — Recovery Inhibition (tengu)
// Status: stable | Level: high | ID: 91407764-38b6-55cc-8fd9-304576927991

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
