// Dragnet [Ransomware]: dragnet-ransomware-2026-2473 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 1b8f0499-ac5a-5818-a550-5161b59bcb05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
