// Dragnet [Ransomware]: dragnet-ransomware-2026-3407 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 1dd73c5a-810f-5e61-b737-793c596810f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
