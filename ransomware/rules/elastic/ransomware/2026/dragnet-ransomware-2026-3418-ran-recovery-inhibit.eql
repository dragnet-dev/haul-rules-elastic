// Dragnet [Ransomware]: dragnet-ransomware-2026-3418 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: ff0d66ee-1a97-5287-a30a-c7e0b556f00b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
