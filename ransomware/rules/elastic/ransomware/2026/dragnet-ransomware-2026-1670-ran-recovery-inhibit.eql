// Dragnet [Ransomware]: dragnet-ransomware-2026-1670 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: c705972f-7e5e-5ac2-98f9-d6b2aeb2e113

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
