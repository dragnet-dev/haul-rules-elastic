// Dragnet [Ransomware]: dragnet-ransomware-2026-0780 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 743e13dd-1f30-558b-a26b-6f70561b8371

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
