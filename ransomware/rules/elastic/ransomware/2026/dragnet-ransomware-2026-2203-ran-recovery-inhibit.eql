// Dragnet [Ransomware]: dragnet-ransomware-2026-2203 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 333d6ba3-21b5-53cf-91d9-784d5678c7de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
