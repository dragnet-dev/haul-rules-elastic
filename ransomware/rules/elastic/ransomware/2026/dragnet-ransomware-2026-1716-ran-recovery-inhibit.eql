// Dragnet [Ransomware]: dragnet-ransomware-2026-1716 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: b3dd0ca6-939a-5f1f-bee8-e99b097c6304

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
