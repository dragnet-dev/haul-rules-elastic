// Dragnet [Ransomware]: dragnet-ransomware-2026-2530 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 88bd703d-1394-5cc4-9674-30f07816fc30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
