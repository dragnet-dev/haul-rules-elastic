// Dragnet [Ransomware]: dragnet-ransomware-2026-0438 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: 97f28885-5636-54e8-b095-59c74b42d7e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
