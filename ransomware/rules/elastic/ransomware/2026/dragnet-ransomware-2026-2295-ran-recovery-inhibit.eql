// Dragnet [Ransomware]: dragnet-ransomware-2026-2295 — Recovery Inhibition (worldleaks)
// Status: stable | Level: high | ID: 720decb8-0377-5996-acb8-b7a0fbb6f4b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
