// Dragnet [Ransomware]: dragnet-ransomware-2026-2563 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: b017bec5-2ced-514b-8052-b70d91ebb984

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
