// Dragnet [Ransomware]: dragnet-ransomware-2026-3495 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 8c3a8692-6c8a-5313-977d-c69d00d0759f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
