// Dragnet [Ransomware]: dragnet-ransomware-2026-1293 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b0fabadd-8fcb-5c38-816f-614a3e1970d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
