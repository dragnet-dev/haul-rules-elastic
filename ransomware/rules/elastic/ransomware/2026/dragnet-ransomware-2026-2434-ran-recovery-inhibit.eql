// Dragnet [Ransomware]: dragnet-ransomware-2026-2434 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: a90f7fe6-2782-52ba-beec-195ef1bf2b2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
