// Dragnet [Ransomware]: dragnet-ransomware-2026-3328 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 393cdbff-513a-5b8b-94f4-fd5e73bb63e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
