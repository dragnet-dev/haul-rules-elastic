// Dragnet [Ransomware]: dragnet-ransomware-2026-0081 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 192f8e15-4532-574c-9406-9082ac05d1d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
