// Dragnet [Ransomware]: dragnet-ransomware-2026-2750 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: 2a03f29f-41d8-5f63-91da-b765a3fc0966

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
