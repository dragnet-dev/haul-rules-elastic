// Dragnet [Ransomware]: dragnet-ransomware-2026-0637 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: d14df825-b410-5dee-bac8-6c00e6ec062c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
