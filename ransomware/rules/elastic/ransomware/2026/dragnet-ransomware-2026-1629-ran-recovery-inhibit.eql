// Dragnet [Ransomware]: dragnet-ransomware-2026-1629 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: e920ee26-8818-5f7c-92ea-b3fd658ab93f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
