// Dragnet [Ransomware]: dragnet-ransomware-2026-0493 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: ff369e69-9adc-5c69-8706-613a677fa4b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
