// Dragnet [Ransomware]: dragnet-ransomware-2026-0349 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d59aae0f-c987-5a42-a115-a4381d45197f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
