// Dragnet [Ransomware]: dragnet-ransomware-2026-0919 — Recovery Inhibition (genesis)
// Status: stable | Level: high | ID: dc7cd6aa-2966-5f43-9c52-bd8da1d4ce84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
