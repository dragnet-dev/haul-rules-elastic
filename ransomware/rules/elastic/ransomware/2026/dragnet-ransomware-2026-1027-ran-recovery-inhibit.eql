// Dragnet [Ransomware]: dragnet-ransomware-2026-1027 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 41ae7915-892b-5f53-a637-eca63b814a68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
