// Dragnet [Ransomware]: dragnet-ransomware-2026-1187 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 88051785-f391-5b92-9df4-8dffa7ff2ad3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
