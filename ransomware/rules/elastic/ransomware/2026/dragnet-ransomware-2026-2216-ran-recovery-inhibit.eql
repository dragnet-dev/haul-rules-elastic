// Dragnet [Ransomware]: dragnet-ransomware-2026-2216 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: 199d82ab-5501-5c6c-94ee-bd63078d02ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
