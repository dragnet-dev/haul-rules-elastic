// Dragnet [Ransomware]: dragnet-ransomware-2026-0861 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ba597354-8d14-5305-a167-a4ca2d6a26b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
