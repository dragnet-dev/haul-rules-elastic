// Dragnet [Ransomware]: dragnet-ransomware-2026-0504 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c2866500-cd2e-55b0-a619-7cf03fd0ad5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
