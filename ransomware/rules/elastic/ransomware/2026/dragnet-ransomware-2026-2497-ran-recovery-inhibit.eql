// Dragnet [Ransomware]: dragnet-ransomware-2026-2497 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 9bea2198-7319-5fca-b9e6-58d13ed83689

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
