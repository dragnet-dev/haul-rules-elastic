// Dragnet [Ransomware]: dragnet-ransomware-2026-0168 — Recovery Inhibition (nova)
// Status: stable | Level: high | ID: 445a7ded-88df-52bf-92ef-50217a11eb18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
