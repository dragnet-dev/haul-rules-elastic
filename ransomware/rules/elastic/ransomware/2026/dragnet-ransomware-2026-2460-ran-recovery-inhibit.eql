// Dragnet [Ransomware]: dragnet-ransomware-2026-2460 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 00fd899f-a1b6-5721-bfdc-223738cb1f04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
