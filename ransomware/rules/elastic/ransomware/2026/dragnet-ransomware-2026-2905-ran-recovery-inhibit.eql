// Dragnet [Ransomware]: dragnet-ransomware-2026-2905 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 07824b6c-5b45-56d2-bf06-a34d7c014474

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
