// Dragnet [Ransomware]: dragnet-ransomware-2026-0048 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 4e7f4e93-ce35-56f5-a2be-470e42d56a6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
