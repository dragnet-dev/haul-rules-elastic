// Dragnet [Ransomware]: dragnet-ransomware-2026-2002 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 3ab0ca83-c48b-5b16-9f0e-a95a0a1c772c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
