// Dragnet [Ransomware]: dragnet-ransomware-2026-1088 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: e1752bff-d407-5f44-9474-955ae55e0d84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
