// Dragnet [Ransomware]: dragnet-ransomware-2026-3162 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: d5368f1f-952b-5f41-88a9-c0616347a82e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
