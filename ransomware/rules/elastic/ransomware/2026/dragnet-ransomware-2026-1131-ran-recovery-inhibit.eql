// Dragnet [Ransomware]: dragnet-ransomware-2026-1131 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 142dffd7-7194-5a9d-854f-4aadfdfcbe43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
