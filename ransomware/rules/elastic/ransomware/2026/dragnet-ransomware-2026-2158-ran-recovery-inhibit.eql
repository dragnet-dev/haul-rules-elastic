// Dragnet [Ransomware]: dragnet-ransomware-2026-2158 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: 7389f246-dd51-54d7-bf30-209099b65092

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
