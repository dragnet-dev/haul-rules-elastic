// Dragnet [Ransomware]: dragnet-ransomware-2026-3441 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5d55d54b-4a40-5c0d-a7d3-eaefa525e0cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
