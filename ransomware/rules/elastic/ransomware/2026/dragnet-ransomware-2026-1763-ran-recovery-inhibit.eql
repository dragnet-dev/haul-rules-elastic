// Dragnet [Ransomware]: dragnet-ransomware-2026-1763 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: c0edd415-b06a-56c5-9699-7ad88950c18a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
