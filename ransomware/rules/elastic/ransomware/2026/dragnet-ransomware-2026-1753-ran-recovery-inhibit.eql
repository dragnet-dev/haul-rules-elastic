// Dragnet [Ransomware]: dragnet-ransomware-2026-1753 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: addd32fb-5b36-5c01-b766-6a7706f404ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
