// Dragnet [Ransomware]: dragnet-ransomware-2026-3363 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 41bddcd8-8d78-54b5-b5b2-dfc46a72e46e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
