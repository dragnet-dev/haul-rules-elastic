// Dragnet [Ransomware]: dragnet-ransomware-2026-2034 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 17d171e7-db06-5fc2-bac7-6b9553a771db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
