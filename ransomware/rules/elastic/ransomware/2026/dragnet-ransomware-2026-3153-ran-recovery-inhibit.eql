// Dragnet [Ransomware]: dragnet-ransomware-2026-3153 — Recovery Inhibition (pear)
// Status: stable | Level: high | ID: 6639306e-16e1-59e2-a331-9b135d0e70d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
