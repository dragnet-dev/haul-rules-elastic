// Dragnet [Ransomware]: dragnet-ransomware-2026-2082 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: f1f3b911-c05c-5986-91b9-2ee48e412ed1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
