// Dragnet [Ransomware]: dragnet-ransomware-2026-3473 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: b3043a3c-b4e9-57cd-b202-8138fa017be9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
