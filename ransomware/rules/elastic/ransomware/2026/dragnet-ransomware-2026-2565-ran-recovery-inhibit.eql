// Dragnet [Ransomware]: dragnet-ransomware-2026-2565 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 62e56519-5c68-5c1b-945e-dca1b8876ff8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
