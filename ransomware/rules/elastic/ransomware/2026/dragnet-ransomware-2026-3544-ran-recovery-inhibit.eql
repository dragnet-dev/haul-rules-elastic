// Dragnet [Ransomware]: dragnet-ransomware-2026-3544 — Recovery Inhibition (nova)
// Status: stable | Level: high | ID: fd7fd6d8-9977-5e86-98db-07d97e2dd879

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
