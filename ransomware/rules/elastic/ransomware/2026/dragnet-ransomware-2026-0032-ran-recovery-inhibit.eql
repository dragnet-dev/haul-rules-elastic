// Dragnet [Ransomware]: dragnet-ransomware-2026-0032 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: a44b0ce6-047f-5677-ade6-9a5ce4dcf087

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
