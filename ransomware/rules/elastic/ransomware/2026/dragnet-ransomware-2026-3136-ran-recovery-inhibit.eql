// Dragnet [Ransomware]: dragnet-ransomware-2026-3136 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 94642926-de84-5577-a04c-a66c408125f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
