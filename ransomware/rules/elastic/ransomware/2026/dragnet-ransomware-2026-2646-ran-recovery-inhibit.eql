// Dragnet [Ransomware]: dragnet-ransomware-2026-2646 — Recovery Inhibition (m3rx)
// Status: stable | Level: high | ID: e7fca558-c769-5509-938a-e4d032b369d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
