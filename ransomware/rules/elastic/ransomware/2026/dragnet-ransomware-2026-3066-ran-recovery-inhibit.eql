// Dragnet [Ransomware]: dragnet-ransomware-2026-3066 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: d1c8d6aa-a139-5426-9b4f-eeba458eebeb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
