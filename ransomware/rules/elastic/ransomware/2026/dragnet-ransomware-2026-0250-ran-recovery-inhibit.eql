// Dragnet [Ransomware]: dragnet-ransomware-2026-0250 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 68903fec-8fd1-5523-a35a-08d64d527453

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
