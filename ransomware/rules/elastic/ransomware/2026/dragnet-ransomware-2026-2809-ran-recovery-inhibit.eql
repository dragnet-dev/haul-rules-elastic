// Dragnet [Ransomware]: dragnet-ransomware-2026-2809 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0d1c299d-5213-5bb0-aa0e-aa5fdafe71d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
