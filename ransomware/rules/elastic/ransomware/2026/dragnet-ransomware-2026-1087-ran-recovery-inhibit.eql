// Dragnet [Ransomware]: dragnet-ransomware-2026-1087 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 4f17bee0-1993-5e5c-85e7-bcc588717266

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
