// Dragnet [Ransomware]: dragnet-ransomware-2026-2544 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: ddbe1a89-7333-55db-b663-f33e0d250984

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
