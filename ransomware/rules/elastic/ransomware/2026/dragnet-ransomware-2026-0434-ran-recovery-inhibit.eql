// Dragnet [Ransomware]: dragnet-ransomware-2026-0434 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 1cc2b748-9460-556a-97a3-b3018f5f253f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
