// Dragnet [Ransomware]: dragnet-ransomware-2026-3074 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: cbf71bde-7ae5-594c-9be3-1a9b0093ac49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
