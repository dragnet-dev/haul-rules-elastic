// Dragnet [Ransomware]: dragnet-ransomware-2026-2826 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 29085961-c050-53c4-ae21-a8eba263c58a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
