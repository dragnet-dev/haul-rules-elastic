// Dragnet [Ransomware]: dragnet-ransomware-2026-2064 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: cb3b3a68-628d-5c68-ae75-3d131445bafa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
