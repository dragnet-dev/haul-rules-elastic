// Dragnet [Ransomware]: dragnet-ransomware-2026-1295 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 35d25e77-175a-5d9a-9448-21cf51c0adfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
