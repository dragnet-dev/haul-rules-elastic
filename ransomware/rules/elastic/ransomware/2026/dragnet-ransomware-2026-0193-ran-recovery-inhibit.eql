// Dragnet [Ransomware]: dragnet-ransomware-2026-0193 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 2fe5c8cf-60d7-5900-b577-893706b7fd29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
