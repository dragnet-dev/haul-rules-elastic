// Dragnet [Ransomware]: dragnet-ransomware-2026-1433 — Recovery Inhibition (atomsilo)
// Status: stable | Level: high | ID: 3cba80fc-87b4-5aaf-baef-482d3feec2b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
