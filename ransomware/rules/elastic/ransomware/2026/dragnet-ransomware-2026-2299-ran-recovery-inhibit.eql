// Dragnet [Ransomware]: dragnet-ransomware-2026-2299 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 0184adb3-f8b0-5d6c-9215-5e5506895729

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
