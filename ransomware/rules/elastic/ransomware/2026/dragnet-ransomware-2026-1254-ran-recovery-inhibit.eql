// Dragnet [Ransomware]: dragnet-ransomware-2026-1254 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 53fbebaa-066f-50f2-978c-fd7e7c3996e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
