// Dragnet [Ransomware]: dragnet-ransomware-2026-0387 — Recovery Inhibition (payoutsking)
// Status: test | Level: high | ID: 739aa1b9-3dc3-5fba-a911-1a852abf2a1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
