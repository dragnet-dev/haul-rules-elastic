// Dragnet [Ransomware]: dragnet-ransomware-2026-1864 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 2fb4cacd-f0ea-5fe2-ad29-835bbaadaed4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
