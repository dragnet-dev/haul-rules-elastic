// Dragnet [Ransomware]: dragnet-ransomware-2026-1125 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: b332c5da-652e-51d7-a98f-e01b444c162f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
