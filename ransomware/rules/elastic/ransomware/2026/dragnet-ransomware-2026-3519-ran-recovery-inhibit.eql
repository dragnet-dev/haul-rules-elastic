// Dragnet [Ransomware]: dragnet-ransomware-2026-3519 — Recovery Inhibition (interlock)
// Status: test | Level: high | ID: df3e84c9-2191-50b3-baa6-40277285c676

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
