// Dragnet [Ransomware]: dragnet-ransomware-2026-2895 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 5416c59b-46fe-580d-92f2-c28b66985718

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
