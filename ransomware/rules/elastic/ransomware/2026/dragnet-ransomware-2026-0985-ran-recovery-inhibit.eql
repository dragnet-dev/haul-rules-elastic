// Dragnet [Ransomware]: dragnet-ransomware-2026-0985 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 52d4962b-36ca-5b54-b97b-922d36c9e348

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
