// Dragnet [Ransomware]: dragnet-ransomware-2026-0527 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 98c66473-6b26-51c7-8b2c-f3fddd3ebd6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
