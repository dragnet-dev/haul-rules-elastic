// Dragnet [Ransomware]: dragnet-ransomware-2026-0408 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 34f4ed2e-ab3c-5fd5-9446-fd064de74edf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
