// Dragnet [Ransomware]: dragnet-ransomware-2026-1751 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 1cd71996-2022-5795-854d-5005981d0147

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
