// Dragnet [Ransomware]: dragnet-ransomware-2026-1645 — Recovery Inhibition (tridentlocker)
// Status: stable | Level: high | ID: e0023ebb-6832-5122-9fb4-56f7a40a56f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
