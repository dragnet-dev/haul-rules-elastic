// Dragnet [Ransomware]: dragnet-ransomware-2026-0248 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: c3f20297-0bb3-5acc-a8a0-910f07be63c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
