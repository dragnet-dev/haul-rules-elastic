// Dragnet [Ransomware]: dragnet-ransomware-2026-1377 — Recovery Inhibition (chaos)
// Status: stable | Level: high | ID: fefb611b-0205-5abd-8653-e38f72246182

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
