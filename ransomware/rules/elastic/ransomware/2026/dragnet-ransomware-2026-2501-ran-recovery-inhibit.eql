// Dragnet [Ransomware]: dragnet-ransomware-2026-2501 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: 0b906a44-e6c5-55d0-afea-24dd35236212

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
