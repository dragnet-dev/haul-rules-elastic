// Dragnet [Ransomware]: dragnet-ransomware-2026-0775 — Recovery Inhibition (ALP-001)
// Status: stable | Level: high | ID: c8497012-c919-5ccc-9ff1-e4ff2a005d1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
