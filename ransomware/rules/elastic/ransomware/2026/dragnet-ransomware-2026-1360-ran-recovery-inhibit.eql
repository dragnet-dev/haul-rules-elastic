// Dragnet [Ransomware]: dragnet-ransomware-2026-1360 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: a29ca699-30b7-522c-bd9e-bb78b23cb3ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
