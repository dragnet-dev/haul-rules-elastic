// Dragnet [Ransomware]: dragnet-ransomware-2026-1350 — Recovery Inhibition (lynx)
// Status: stable | Level: high | ID: 90051426-6531-5979-ac49-fc8732fbb868

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
