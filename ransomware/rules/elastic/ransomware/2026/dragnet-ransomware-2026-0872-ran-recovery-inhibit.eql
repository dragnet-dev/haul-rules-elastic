// Dragnet [Ransomware]: dragnet-ransomware-2026-0872 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 57e9be8c-9dde-5f2b-8e98-6ba7a62b70ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
