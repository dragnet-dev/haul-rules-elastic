// Dragnet [Ransomware]: dragnet-ransomware-2026-1380 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: c056d9cb-ed4d-59d4-9fc1-b444ec56ea81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
