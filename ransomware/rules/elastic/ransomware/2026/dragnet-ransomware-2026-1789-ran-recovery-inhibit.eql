// Dragnet [Ransomware]: dragnet-ransomware-2026-1789 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 4622e01c-443e-5ad4-bc92-276ba7013f8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
