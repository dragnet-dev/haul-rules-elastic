// Dragnet [Ransomware]: dragnet-ransomware-2026-1098 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 7cd84963-fa04-5ba7-b635-8af46b0299ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
