// Dragnet [Ransomware]: dragnet-ransomware-2026-1277 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: e3dc6090-c633-5c60-bb17-b6d96e292c96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
