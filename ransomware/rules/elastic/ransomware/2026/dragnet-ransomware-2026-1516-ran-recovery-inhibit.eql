// Dragnet [Ransomware]: dragnet-ransomware-2026-1516 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 4967b0e2-8023-54c0-b43a-7c264ac87982

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
