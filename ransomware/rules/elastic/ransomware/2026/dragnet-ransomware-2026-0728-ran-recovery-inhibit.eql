// Dragnet [Ransomware]: dragnet-ransomware-2026-0728 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 55e758a6-3f03-59a9-8dc5-fe7a7c4a6588

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
