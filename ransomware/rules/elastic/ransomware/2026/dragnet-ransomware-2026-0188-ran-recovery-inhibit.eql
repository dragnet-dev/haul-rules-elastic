// Dragnet [Ransomware]: dragnet-ransomware-2026-0188 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: e07d839b-cb36-54c2-8051-00a3414f25c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
