// Dragnet [Ransomware]: dragnet-ransomware-2026-0720 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 68b6be61-6836-5888-96af-8d8499e2fe18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
