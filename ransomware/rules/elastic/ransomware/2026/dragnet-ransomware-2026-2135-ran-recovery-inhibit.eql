// Dragnet [Ransomware]: dragnet-ransomware-2026-2135 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 282e27a6-df6a-5bbe-b422-5b0f8b8ed033

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
