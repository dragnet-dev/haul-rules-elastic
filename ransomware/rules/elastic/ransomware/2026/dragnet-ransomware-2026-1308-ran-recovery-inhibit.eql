// Dragnet [Ransomware]: dragnet-ransomware-2026-1308 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 40e4b0d9-d5d6-538f-aeb9-d4d3f4e54566

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
