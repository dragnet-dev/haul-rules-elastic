// Dragnet [Ransomware]: dragnet-ransomware-2026-2190 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: a200dfb1-417e-5263-9dc3-2ff41751f0ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
