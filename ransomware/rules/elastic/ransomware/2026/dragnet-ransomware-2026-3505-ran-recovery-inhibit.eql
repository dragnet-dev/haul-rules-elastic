// Dragnet [Ransomware]: dragnet-ransomware-2026-3505 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: fbac3251-3cb6-51b6-bfd9-9344b3928380

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
