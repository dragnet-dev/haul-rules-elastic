// Dragnet [Ransomware]: dragnet-ransomware-2026-3446 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 48cdfe13-335b-5c69-bd0d-3e5eb82add3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
