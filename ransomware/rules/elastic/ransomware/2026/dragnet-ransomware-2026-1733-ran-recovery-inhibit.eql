// Dragnet [Ransomware]: dragnet-ransomware-2026-1733 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 14b26e63-1514-5ce2-890d-e6e55c765af4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
