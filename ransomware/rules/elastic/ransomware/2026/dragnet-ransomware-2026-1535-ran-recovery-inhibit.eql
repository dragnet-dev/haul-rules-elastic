// Dragnet [Ransomware]: dragnet-ransomware-2026-1535 — Recovery Inhibition (payoutsking)
// Status: test | Level: high | ID: 989109cd-df52-51f1-a9a7-0df71f4cd119

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
