// Dragnet [Ransomware]: dragnet-ransomware-2026-2094 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: 5ef7d3fd-168c-5ff3-93a1-c876b3031ffe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
