// Dragnet [Ransomware]: dragnet-ransomware-2026-1109 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: c86a7be6-ca69-56f6-8093-f2e79e72f897

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
