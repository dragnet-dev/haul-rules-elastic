// Dragnet [Ransomware]: dragnet-ransomware-2026-2246 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: de13d090-13a1-5409-97c6-9e264566ab56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
