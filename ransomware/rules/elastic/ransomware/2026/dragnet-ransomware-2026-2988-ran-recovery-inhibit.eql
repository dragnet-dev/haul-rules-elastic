// Dragnet [Ransomware]: dragnet-ransomware-2026-2988 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 75b479a8-5c3c-5011-a6c0-d61dfeaef23e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
