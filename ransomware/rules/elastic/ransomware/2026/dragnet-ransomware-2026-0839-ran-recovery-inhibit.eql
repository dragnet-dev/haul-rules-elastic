// Dragnet [Ransomware]: dragnet-ransomware-2026-0839 — Recovery Inhibition (medusa)
// Status: test | Level: high | ID: ab87696b-9ad7-5727-9bcd-32616262a6e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
