// Dragnet [Ransomware]: dragnet-ransomware-2026-2691 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 3e41b7d2-6609-540b-9caf-cd0635e187cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
