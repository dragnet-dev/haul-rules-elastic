// Dragnet [Ransomware]: dragnet-ransomware-2026-1463 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: 27c70f06-aac4-5338-8dd6-46956e162180

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
