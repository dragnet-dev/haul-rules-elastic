// Dragnet [Ransomware]: dragnet-ransomware-2026-3456 — Recovery Inhibition (worldleaks)
// Status: stable | Level: high | ID: efbd3fe9-dfdf-5933-9f5d-e7015a756302

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
