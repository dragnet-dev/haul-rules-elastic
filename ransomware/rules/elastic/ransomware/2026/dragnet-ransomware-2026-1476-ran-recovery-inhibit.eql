// Dragnet [Ransomware]: dragnet-ransomware-2026-1476 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: b391eeea-b02a-524c-9593-c6005b213c95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
