// Dragnet [Ransomware]: dragnet-ransomware-2026-3419 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 15774f0b-3b94-5f81-bfeb-b2029ce05a86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
