// Dragnet [Ransomware]: dragnet-ransomware-2026-3424 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 3ed4b02e-fba4-5a65-b2f1-ce497406cf91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
