// Dragnet [Ransomware]: dragnet-ransomware-2026-3551 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: c4733543-3f8b-5af4-8d91-7965c828eb53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
