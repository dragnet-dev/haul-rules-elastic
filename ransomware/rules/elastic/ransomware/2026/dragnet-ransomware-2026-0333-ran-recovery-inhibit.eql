// Dragnet [Ransomware]: dragnet-ransomware-2026-0333 — Recovery Inhibition (vect)
// Status: deprecated | Level: high | ID: 2e136b7f-c0ef-5891-8ef5-c248dbc3e355

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
