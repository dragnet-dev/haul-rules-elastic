// Dragnet [Ransomware]: dragnet-ransomware-2026-0755 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: bc72a4ae-6348-5e46-aefb-31f68d2f682b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
