// Dragnet [Ransomware]: dragnet-ransomware-2026-2096 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: b02e6be2-7017-5b1f-b110-a93704adddf2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
