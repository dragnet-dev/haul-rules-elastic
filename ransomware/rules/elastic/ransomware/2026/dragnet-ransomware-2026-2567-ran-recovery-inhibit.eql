// Dragnet [Ransomware]: dragnet-ransomware-2026-2567 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: e2434114-991c-56e4-ad31-e1c87e50343e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
