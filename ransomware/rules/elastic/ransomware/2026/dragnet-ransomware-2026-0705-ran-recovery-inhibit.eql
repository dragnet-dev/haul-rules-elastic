// Dragnet [Ransomware]: dragnet-ransomware-2026-0705 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f6e6ae72-2b79-5330-afe4-ccc75a0e9e14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
