// Dragnet [Ransomware]: dragnet-ransomware-2026-1365 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 1e46aa4b-4247-5d6c-a6ea-1584e22aacf2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
