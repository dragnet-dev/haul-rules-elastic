// Dragnet [Ransomware]: dragnet-ransomware-2026-1403 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 681f9c83-9c7f-5436-8c2a-c07b76225912

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
