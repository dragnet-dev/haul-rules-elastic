// Dragnet [Ransomware]: dragnet-ransomware-2026-0836 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 8a00fa76-0ce6-5dcf-a052-7aa63f1baf38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
