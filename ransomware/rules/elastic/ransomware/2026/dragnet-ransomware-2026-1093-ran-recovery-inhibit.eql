// Dragnet [Ransomware]: dragnet-ransomware-2026-1093 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 8f406591-f535-5f5b-ba65-13fb0b969c36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
