// Dragnet [Ransomware]: dragnet-ransomware-2026-3432 — Recovery Inhibition (krybit)
// Status: stable | Level: high | ID: 4942f617-3f4e-5dd7-9b7b-aa40d76606a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
