// Dragnet [Ransomware]: dragnet-ransomware-2026-0575 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 01ad3306-f1d7-5b61-b83b-32203a139ee2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
