// Dragnet [Ransomware]: dragnet-ransomware-2026-1159 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 655ccb4e-a123-5cb4-ba38-2144db8c296c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
