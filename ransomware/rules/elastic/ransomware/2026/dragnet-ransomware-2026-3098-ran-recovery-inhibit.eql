// Dragnet [Ransomware]: dragnet-ransomware-2026-3098 — Recovery Inhibition (securotrop)
// Status: stable | Level: high | ID: 55eaea49-7e66-5f28-a57c-9517949bdeab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
