// Dragnet [Ransomware]: dragnet-ransomware-2026-2671 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 55da05c4-b92d-5924-b7b2-6d9357294380

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
