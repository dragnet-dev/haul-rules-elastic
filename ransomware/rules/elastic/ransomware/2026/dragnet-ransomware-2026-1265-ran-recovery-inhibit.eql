// Dragnet [Ransomware]: dragnet-ransomware-2026-1265 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 0caea64b-bd13-5784-a429-c2b318bd3e61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
