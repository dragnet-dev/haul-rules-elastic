// Dragnet [Ransomware]: dragnet-ransomware-2026-0667 — Recovery Inhibition (sicarii)
// Status: deprecated | Level: high | ID: dc507cf2-a52d-56f5-b04a-caf0151f459e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
