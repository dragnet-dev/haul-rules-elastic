// Dragnet [Ransomware]: dragnet-ransomware-2026-3032 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: 498d40c9-6a3e-54dd-af49-7cc5bdbdb1bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
