// Dragnet [Ransomware]: dragnet-ransomware-2026-1935 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 0d07482a-20f0-5264-b466-8bebdbcbfe06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
