// Dragnet [Ransomware]: dragnet-ransomware-2026-3173 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5dd6965d-e2c0-5b1f-b3d0-21944246934c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
