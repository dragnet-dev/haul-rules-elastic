// Dragnet [Ransomware]: dragnet-ransomware-2026-2612 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 9380a614-4157-5f55-b62b-63e6469c989e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
