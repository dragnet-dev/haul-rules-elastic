// Dragnet [Ransomware]: dragnet-ransomware-2026-0628 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 214029bb-52bd-5a34-a9ef-8c9140434bc0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
