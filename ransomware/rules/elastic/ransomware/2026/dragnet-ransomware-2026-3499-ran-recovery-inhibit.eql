// Dragnet [Ransomware]: dragnet-ransomware-2026-3499 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: c93ca354-34aa-5121-b20c-4fec41394b9c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
