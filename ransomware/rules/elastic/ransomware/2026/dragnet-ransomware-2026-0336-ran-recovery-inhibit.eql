// Dragnet [Ransomware]: dragnet-ransomware-2026-0336 — Recovery Inhibition (spacebears)
// Status: test | Level: high | ID: a0c79f31-220b-5ec6-890e-d8eb4dc4cae0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
