// Dragnet [Ransomware]: dragnet-ransomware-2026-3040 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 4da1c79b-d845-5831-9bce-a0751879c8a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
