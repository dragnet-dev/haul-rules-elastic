// Dragnet [Ransomware]: dragnet-ransomware-2026-1120 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: b96a45ee-4418-510a-ab82-fd3737f1cf30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
