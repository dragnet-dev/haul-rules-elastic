// Dragnet [Ransomware]: dragnet-ransomware-2026-3208 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 48cfe386-dcba-56c1-8f4e-2f81ff1b94b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
