// Dragnet [Ransomware]: dragnet-ransomware-2026-3214 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: def83b95-01f2-5996-8555-4531fc8154da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
