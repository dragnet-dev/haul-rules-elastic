// Dragnet [Ransomware]: dragnet-ransomware-2026-0178 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 848048a7-1316-5636-a984-1cc48f8dff0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
