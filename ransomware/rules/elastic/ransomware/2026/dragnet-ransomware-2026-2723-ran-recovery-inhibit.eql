// Dragnet [Ransomware]: dragnet-ransomware-2026-2723 — Recovery Inhibition (pear)
// Status: stable | Level: high | ID: 1fbd6956-19fe-5564-9008-77150af4626c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
