// Dragnet [Ransomware]: dragnet-ransomware-2026-0563 — Recovery Inhibition (spacebears)
// Status: test | Level: high | ID: 08dea89c-6b5b-5a9b-82b8-51a23bce6ea3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
