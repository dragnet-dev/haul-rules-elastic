// Dragnet [Ransomware]: dragnet-ransomware-2026-2468 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 608129fd-7f94-53d9-8d31-08555ae40c1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
