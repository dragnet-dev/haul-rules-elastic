// Dragnet [Ransomware]: dragnet-ransomware-2026-0103 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: c7854841-bb9a-57e2-a38b-ca4595a75a43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
