// Dragnet [Ransomware]: dragnet-ransomware-2026-0962 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: acd2a6f2-d30d-546d-b095-c02a281d7356

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
