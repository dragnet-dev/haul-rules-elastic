// Dragnet [Ransomware]: dragnet-ransomware-2026-1456 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 59536c83-93da-5cc1-91b7-87b76475b659

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
