// Dragnet [Ransomware]: dragnet-ransomware-2026-2289 — Recovery Inhibition (netrunner)
// Status: stable | Level: high | ID: f628032d-6e43-5c32-8a3f-15118a1f1ca3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
