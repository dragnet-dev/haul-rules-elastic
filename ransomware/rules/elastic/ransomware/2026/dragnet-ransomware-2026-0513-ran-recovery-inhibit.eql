// Dragnet [Ransomware]: dragnet-ransomware-2026-0513 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: eaec0326-ca30-5789-9c41-569a08731cb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
