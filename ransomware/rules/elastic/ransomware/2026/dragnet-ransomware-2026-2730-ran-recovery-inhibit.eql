// Dragnet [Ransomware]: dragnet-ransomware-2026-2730 — Recovery Inhibition (direwolf)
// Status: test | Level: high | ID: 39036b40-f832-530b-be1b-28be52a56de0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
