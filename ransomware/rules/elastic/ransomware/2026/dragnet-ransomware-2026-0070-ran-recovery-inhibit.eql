// Dragnet [Ransomware]: dragnet-ransomware-2026-0070 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: c7864f85-18c9-53b2-8199-f54126da4bd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
