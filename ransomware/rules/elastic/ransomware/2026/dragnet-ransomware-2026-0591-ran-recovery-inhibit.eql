// Dragnet [Ransomware]: dragnet-ransomware-2026-0591 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 4ebd1d74-5364-5461-bc80-92ad84dd8803

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
