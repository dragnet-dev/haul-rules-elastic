// Dragnet [Ransomware]: dragnet-ransomware-2026-2157 — Recovery Inhibition (TiMc)
// Status: deprecated | Level: high | ID: c85f5544-a311-5da4-a284-fd407d4421a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
