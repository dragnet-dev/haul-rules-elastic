// Dragnet [Ransomware]: dragnet-ransomware-2026-0665 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 92653ea0-0907-54b0-ac3c-46737b6b37ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
