// Dragnet [Ransomware]: dragnet-ransomware-2026-2138 — Recovery Inhibition (LeakBazaar)
// Status: stable | Level: high | ID: dcfccf8b-4ba2-580e-a933-a76be538b1a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
