// Dragnet [Ransomware]: dragnet-ransomware-2026-1342 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 57be3f2f-6908-5ab1-bd7d-d9e46675e34b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
