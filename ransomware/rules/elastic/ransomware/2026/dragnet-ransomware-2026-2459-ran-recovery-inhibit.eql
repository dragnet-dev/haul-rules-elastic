// Dragnet [Ransomware]: dragnet-ransomware-2026-2459 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 9e1db869-7342-5790-b70d-2577949acd09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
