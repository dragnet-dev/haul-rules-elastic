// Dragnet [Ransomware]: dragnet-ransomware-2026-1514 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: a752ba49-a8b9-5b65-97aa-6247e0f36d8f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
