// Dragnet [Ransomware]: dragnet-ransomware-2026-2078 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: d5e4f2d2-8e8a-5f9d-970b-99fb04a82d9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
