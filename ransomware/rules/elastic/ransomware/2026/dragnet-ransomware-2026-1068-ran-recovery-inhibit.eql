// Dragnet [Ransomware]: dragnet-ransomware-2026-1068 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 471a40a2-03b5-5fd6-aa09-b9263452cd5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
