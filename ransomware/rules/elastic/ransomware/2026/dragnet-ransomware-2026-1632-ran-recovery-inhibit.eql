// Dragnet [Ransomware]: dragnet-ransomware-2026-1632 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 4eefa771-1dea-5fe7-b1a8-10fc1015f8d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
