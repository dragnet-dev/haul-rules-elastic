// Dragnet [Ransomware]: dragnet-ransomware-2026-0690 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 277ae4cf-34ff-54e0-ba5c-1c6dea4c040f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
