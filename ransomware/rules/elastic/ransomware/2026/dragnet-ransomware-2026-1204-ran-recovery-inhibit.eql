// Dragnet [Ransomware]: dragnet-ransomware-2026-1204 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 1ed9819d-1dfd-51e6-900c-4fac60f8b153

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
