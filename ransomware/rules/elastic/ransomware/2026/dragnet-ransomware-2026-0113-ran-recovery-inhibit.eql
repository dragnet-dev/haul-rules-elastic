// Dragnet [Ransomware]: dragnet-ransomware-2026-0113 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 3c4d96bd-0ad5-5af7-a80f-dd593b09489c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
