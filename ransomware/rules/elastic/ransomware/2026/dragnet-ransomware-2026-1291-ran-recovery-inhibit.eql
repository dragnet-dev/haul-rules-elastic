// Dragnet [Ransomware]: dragnet-ransomware-2026-1291 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 69b8b98a-4858-5a08-86f4-4ff8b780260f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
