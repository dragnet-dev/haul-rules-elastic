// Dragnet [Ransomware]: dragnet-ransomware-2026-2644 — Recovery Inhibition (m3rx)
// Status: stable | Level: high | ID: 6aa8034e-6991-5b74-a028-3d255c4347ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
