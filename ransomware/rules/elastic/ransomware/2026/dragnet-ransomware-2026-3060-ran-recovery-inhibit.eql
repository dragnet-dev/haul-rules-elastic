// Dragnet [Ransomware]: dragnet-ransomware-2026-3060 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: e020f567-0e35-5608-833f-f558108391bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
