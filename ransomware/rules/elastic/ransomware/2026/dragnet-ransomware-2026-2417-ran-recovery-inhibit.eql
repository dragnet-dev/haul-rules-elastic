// Dragnet [Ransomware]: dragnet-ransomware-2026-2417 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 5a9d756d-ed9d-50b8-8bb4-873c73d1d555

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
