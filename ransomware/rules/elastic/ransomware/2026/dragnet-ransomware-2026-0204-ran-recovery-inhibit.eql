// Dragnet [Ransomware]: dragnet-ransomware-2026-0204 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 8e900298-c476-5081-bfd4-09265506bdbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
