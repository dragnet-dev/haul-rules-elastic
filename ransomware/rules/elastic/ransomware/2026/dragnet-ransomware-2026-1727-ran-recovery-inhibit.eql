// Dragnet [Ransomware]: dragnet-ransomware-2026-1727 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8aee9128-9656-58a1-8ec1-ac09495086a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
