// Dragnet [Ransomware]: dragnet-ransomware-2026-1279 — Recovery Inhibition (genesis)
// Status: stable | Level: high | ID: a9cc6299-0bda-5449-a070-33f8982b228b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
