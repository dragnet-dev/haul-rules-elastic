// Dragnet [Ransomware]: dragnet-ransomware-2026-0013 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 9796f0ec-df0e-5b20-bd76-3b163e328c38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
