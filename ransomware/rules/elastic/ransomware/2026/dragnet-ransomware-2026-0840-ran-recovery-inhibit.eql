// Dragnet [Ransomware]: dragnet-ransomware-2026-0840 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 1c28a508-efe6-50d4-8df8-330255f639da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
