// Dragnet [Ransomware]: dragnet-ransomware-2026-1468 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 4c3bdcba-12a6-54e7-8bf4-e0e8ca685aac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
