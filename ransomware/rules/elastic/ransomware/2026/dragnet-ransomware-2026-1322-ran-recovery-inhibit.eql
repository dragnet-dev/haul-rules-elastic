// Dragnet [Ransomware]: dragnet-ransomware-2026-1322 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: c4aefb4b-69f8-58d6-941e-8f2c888fff85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
