// Dragnet [Ransomware]: dragnet-ransomware-2026-1515 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: 1dad3c8d-2473-5158-ba3f-b1ccd3345536

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
