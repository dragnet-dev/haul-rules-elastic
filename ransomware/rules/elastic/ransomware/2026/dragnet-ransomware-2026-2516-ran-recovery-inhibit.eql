// Dragnet [Ransomware]: dragnet-ransomware-2026-2516 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: d6684daf-b429-5476-ba42-d6c2f3d07f33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
