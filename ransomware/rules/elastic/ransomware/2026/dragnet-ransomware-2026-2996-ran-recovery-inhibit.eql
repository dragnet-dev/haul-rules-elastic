// Dragnet [Ransomware]: dragnet-ransomware-2026-2996 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 1314f9d4-f9e0-5c3b-89f3-79cf4001d8a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
