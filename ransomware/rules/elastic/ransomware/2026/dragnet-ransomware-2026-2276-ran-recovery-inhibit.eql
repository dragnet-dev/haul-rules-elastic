// Dragnet [Ransomware]: dragnet-ransomware-2026-2276 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 85c7a7e2-468b-5006-b0ee-c17aa33cff98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
