// Dragnet [Ransomware]: dragnet-ransomware-2026-2405 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 1aa669cb-4961-567d-b27e-362b0569def2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
