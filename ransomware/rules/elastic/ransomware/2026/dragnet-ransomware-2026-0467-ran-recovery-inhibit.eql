// Dragnet [Ransomware]: dragnet-ransomware-2026-0467 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 587bbbc2-1166-57f5-8cba-d90b4bb6eed4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
