// Dragnet [Ransomware]: dragnet-ransomware-2026-0018 — Recovery Inhibition (lynx)
// Status: stable | Level: high | ID: ff6009f9-af23-5faf-8bda-b9cb2b0c24f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
