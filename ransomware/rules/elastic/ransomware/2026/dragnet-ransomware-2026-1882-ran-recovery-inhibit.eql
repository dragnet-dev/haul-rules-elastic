// Dragnet [Ransomware]: dragnet-ransomware-2026-1882 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 0f8e77b1-3dab-576f-8ef1-938388cc8fea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
