// Dragnet [Ransomware]: dragnet-ransomware-2026-1211 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 7cda1ee5-7a40-5218-9029-b1dc7ca5fc34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
