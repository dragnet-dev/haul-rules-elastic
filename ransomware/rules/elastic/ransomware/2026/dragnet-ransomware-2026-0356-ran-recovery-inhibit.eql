// Dragnet [Ransomware]: dragnet-ransomware-2026-0356 — Recovery Inhibition (beast)
// Status: stable | Level: high | ID: a16fa418-60b8-5955-930a-753d22c852cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
