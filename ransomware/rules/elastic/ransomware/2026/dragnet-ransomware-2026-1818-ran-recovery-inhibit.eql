// Dragnet [Ransomware]: dragnet-ransomware-2026-1818 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 79f44a3b-3fd5-55dc-b951-9025160d8658

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
