// Dragnet [Ransomware]: dragnet-ransomware-2026-3230 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: d1401e48-a6be-5077-9a58-67a42fb1f3aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
