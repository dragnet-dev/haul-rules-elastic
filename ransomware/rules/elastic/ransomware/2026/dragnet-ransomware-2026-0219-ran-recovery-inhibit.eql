// Dragnet [Ransomware]: dragnet-ransomware-2026-0219 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 24eb8933-e940-5dad-b32b-bd82ff20bb72

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
