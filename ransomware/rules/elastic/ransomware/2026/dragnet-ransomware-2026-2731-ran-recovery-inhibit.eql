// Dragnet [Ransomware]: dragnet-ransomware-2026-2731 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 5cfd7c4c-51c0-5254-a705-af375d1fae7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
