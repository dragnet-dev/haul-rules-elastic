// Dragnet [Ransomware]: dragnet-ransomware-2026-1773 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 562eb727-539a-53af-915f-1f6cbe46a6ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
