// Dragnet [Ransomware]: dragnet-ransomware-2026-2917 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 320ade41-de8f-5368-94be-2e593ba84de2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
