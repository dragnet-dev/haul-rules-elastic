// Dragnet [Ransomware]: dragnet-ransomware-2026-3249 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 88eed2b8-404b-5ac3-8e19-21ad50aaf872

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
