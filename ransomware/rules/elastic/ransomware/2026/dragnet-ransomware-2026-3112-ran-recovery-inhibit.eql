// Dragnet [Ransomware]: dragnet-ransomware-2026-3112 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 4131741b-c085-567b-aa4c-298cd2bb81f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
