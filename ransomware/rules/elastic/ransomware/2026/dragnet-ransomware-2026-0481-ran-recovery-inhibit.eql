// Dragnet [Ransomware]: dragnet-ransomware-2026-0481 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 7ddfbb9c-7d5d-5580-a640-48d5f77e3e6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
