// Dragnet [Ransomware]: dragnet-ransomware-2026-0283 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 96fd9ade-4eeb-505c-af25-c6bfc1551c60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
