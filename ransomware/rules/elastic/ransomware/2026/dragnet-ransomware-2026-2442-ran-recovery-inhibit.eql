// Dragnet [Ransomware]: dragnet-ransomware-2026-2442 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 316eebb0-13af-5e83-86ef-dabf5f87301c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
