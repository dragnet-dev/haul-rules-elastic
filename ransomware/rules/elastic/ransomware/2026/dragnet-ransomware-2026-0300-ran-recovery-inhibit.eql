// Dragnet [Ransomware]: dragnet-ransomware-2026-0300 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 7283a7a1-c9c9-5e3d-84a9-8ae350488a78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
