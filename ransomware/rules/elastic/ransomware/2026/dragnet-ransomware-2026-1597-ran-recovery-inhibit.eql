// Dragnet [Ransomware]: dragnet-ransomware-2026-1597 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: a60db9cd-5184-55ad-a33b-43d7878e015b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
