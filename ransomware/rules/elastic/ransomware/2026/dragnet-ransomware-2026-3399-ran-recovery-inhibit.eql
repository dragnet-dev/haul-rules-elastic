// Dragnet [Ransomware]: dragnet-ransomware-2026-3399 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 1137d9ed-b076-5af5-8a1d-c6b0b2426849

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
