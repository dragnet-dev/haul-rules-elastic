// Dragnet [Ransomware]: dragnet-ransomware-2026-3057 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 399f6b6e-c71d-5105-956b-13ef125f38a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
