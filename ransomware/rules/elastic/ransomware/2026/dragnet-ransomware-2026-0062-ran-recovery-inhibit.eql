// Dragnet [Ransomware]: dragnet-ransomware-2026-0062 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: b5602e68-1fba-57cf-b84a-92352e5d4efd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
