// Dragnet [Ransomware]: dragnet-ransomware-2026-1395 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: e096f460-2937-5087-82ba-149e8b02ee7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
