// Dragnet [Ransomware]: dragnet-ransomware-2026-0464 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 09db2868-c23e-5f67-8a16-93ab95170b67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
