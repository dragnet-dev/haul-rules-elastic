// Dragnet [Ransomware]: dragnet-ransomware-2026-2717 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: c5631651-4238-5673-a26a-e0d823d2edbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
