// Dragnet [Ransomware]: dragnet-ransomware-2026-2982 — Recovery Inhibition (direwolf)
// Status: test | Level: high | ID: a46521e1-e666-5e84-9a70-4dc9d25a3143

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
