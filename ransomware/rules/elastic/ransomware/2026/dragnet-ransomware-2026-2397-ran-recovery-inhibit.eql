// Dragnet [Ransomware]: dragnet-ransomware-2026-2397 — Recovery Inhibition (interlock)
// Status: stable | Level: high | ID: 561faab9-ce41-5f0a-8ea3-0097b59d6b4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
