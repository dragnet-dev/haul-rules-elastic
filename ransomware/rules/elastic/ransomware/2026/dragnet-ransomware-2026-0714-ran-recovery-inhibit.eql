// Dragnet [Ransomware]: dragnet-ransomware-2026-0714 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: cb47dcaa-fdd9-5112-817d-b21b7d2047cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
