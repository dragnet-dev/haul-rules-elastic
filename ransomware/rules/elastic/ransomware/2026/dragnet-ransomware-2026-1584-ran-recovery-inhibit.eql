// Dragnet [Ransomware]: dragnet-ransomware-2026-1584 — Recovery Inhibition (clop)
// Status: stable | Level: high | ID: 2c0b5a0c-5458-5e53-90a9-0e8b45c71a85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
