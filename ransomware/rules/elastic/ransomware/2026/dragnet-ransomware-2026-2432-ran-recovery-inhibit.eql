// Dragnet [Ransomware]: dragnet-ransomware-2026-2432 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: a7deaaa2-5bf9-545a-bee3-34762032b5c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
