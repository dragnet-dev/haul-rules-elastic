// Dragnet [Ransomware]: dragnet-ransomware-2026-2025 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 7a763563-a04c-5615-a24b-bafede12039e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
