// Dragnet [Ransomware]: dragnet-ransomware-2026-2474 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 33d65257-9c05-52d5-8ad7-4dc288fde10f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
