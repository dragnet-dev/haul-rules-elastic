// Dragnet [Ransomware]: dragnet-ransomware-2026-0915 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 7a48b0af-bd0f-5d7e-9717-cfebf459b4d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
