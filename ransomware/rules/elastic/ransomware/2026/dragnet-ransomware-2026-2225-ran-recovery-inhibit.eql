// Dragnet [Ransomware]: dragnet-ransomware-2026-2225 — Recovery Inhibition (payload)
// Status: test | Level: high | ID: 669a82e1-7fc6-570f-b053-9765c2825be0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
