// Dragnet [Ransomware]: dragnet-ransomware-2026-0486 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 9b06206b-9b5b-56fb-a514-9d8d1d686ec4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
