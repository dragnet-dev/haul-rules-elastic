// Dragnet [Ransomware]: dragnet-ransomware-2026-0031 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2cf7df3b-46cf-58cc-902f-cd3f8295b328

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
