// Dragnet [Ransomware]: dragnet-ransomware-2026-0230 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 60424a3e-ad54-513a-8604-effc32e0487d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
