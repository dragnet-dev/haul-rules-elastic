// Dragnet [Ransomware]: dragnet-ransomware-2026-3002 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: fd61c861-4731-5643-8d9f-467432accb42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
