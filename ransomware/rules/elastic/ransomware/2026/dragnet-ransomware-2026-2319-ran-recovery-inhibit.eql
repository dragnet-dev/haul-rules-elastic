// Dragnet [Ransomware]: dragnet-ransomware-2026-2319 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 46a33b7e-feac-5d1b-8ff9-f0693ceb0dde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
