// Dragnet [Ransomware]: dragnet-ransomware-2026-0709 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: c3d1050d-5a82-5764-85f4-033e80f03fa2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
