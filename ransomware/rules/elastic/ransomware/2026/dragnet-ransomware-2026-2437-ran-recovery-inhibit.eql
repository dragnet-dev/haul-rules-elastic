// Dragnet [Ransomware]: dragnet-ransomware-2026-2437 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 1f760b95-1e87-508c-9717-86ff96f7fd79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
