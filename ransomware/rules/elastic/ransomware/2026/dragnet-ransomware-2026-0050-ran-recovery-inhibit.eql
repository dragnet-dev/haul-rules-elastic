// Dragnet [Ransomware]: dragnet-ransomware-2026-0050 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: aee265b2-a7f3-582f-98c1-a928517697e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
