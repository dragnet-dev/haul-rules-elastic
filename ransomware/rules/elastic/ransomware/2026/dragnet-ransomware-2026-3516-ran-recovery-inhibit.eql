// Dragnet [Ransomware]: dragnet-ransomware-2026-3516 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 0b3a2f97-ae66-5c7d-8879-b9bfa87370e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
