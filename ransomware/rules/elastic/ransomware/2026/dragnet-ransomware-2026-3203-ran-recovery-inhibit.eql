// Dragnet [Ransomware]: dragnet-ransomware-2026-3203 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e5ef1087-70ca-5038-a007-713200fe538c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
