// Dragnet [Ransomware]: dragnet-ransomware-2026-0531 — Recovery Inhibition (payoutsking)
// Status: stable | Level: high | ID: 1f8916cc-20b0-5e3a-8a7f-cad4e90bcc4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
