// Dragnet [Ransomware]: dragnet-ransomware-2026-1756 — Recovery Inhibition (ALP-001)
// Status: stable | Level: high | ID: 39b3dd67-1c1c-5103-b1ab-39ae6fbd28f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
