// Dragnet [Ransomware]: dragnet-ransomware-2026-3508 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: e2dca2e9-821f-527e-a0fe-1b3632f64775

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
