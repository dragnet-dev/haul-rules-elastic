// Dragnet [Ransomware]: dragnet-ransomware-2026-0190 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: f14d334b-b428-5a58-a212-d13e8f2be877

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
