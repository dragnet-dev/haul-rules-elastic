// Dragnet [Ransomware]: dragnet-ransomware-2026-0367 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: f6999cdc-7776-576d-b8c5-e80848376dee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
