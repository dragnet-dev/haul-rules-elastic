// Dragnet [Ransomware]: dragnet-ransomware-2026-0699 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: a4cd08bd-6b03-53fc-a2f6-4d7459e55cae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
