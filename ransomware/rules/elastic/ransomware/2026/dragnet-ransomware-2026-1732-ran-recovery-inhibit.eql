// Dragnet [Ransomware]: dragnet-ransomware-2026-1732 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 034297aa-4ad7-5efa-b71a-926700908b61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
