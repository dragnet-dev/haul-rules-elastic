// Dragnet [Ransomware]: dragnet-ransomware-2026-3339 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 3081641f-db79-5eb9-a8a4-ce261e289f45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
