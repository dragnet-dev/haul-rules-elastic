// Dragnet [Ransomware]: dragnet-ransomware-2026-1048 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: fa8b9c0d-0567-5984-87f1-6a2dc729fa16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
