// Dragnet [Ransomware]: dragnet-ransomware-2026-0988 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 9e2c467c-7e2c-5fc9-8416-c95122878b71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
