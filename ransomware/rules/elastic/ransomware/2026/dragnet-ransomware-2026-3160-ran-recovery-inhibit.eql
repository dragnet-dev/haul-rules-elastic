// Dragnet [Ransomware]: dragnet-ransomware-2026-3160 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 35e3766c-8a23-5117-b269-237ec9b8863c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
