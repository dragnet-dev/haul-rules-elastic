// Dragnet [Ransomware]: dragnet-ransomware-2026-1710 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 11d3e893-86ea-5a96-8ac6-06da5020f383

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
