// Dragnet [Ransomware]: dragnet-ransomware-2026-2568 — Recovery Inhibition (krybit)
// Status: stable | Level: high | ID: b05befd3-00e3-5ca0-97fe-017f10b84129

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
