// Dragnet [Ransomware]: dragnet-ransomware-2026-1309 — Recovery Inhibition (ALP-001)
// Status: stable | Level: high | ID: 65006091-0c66-53bc-8aa4-84b5d028e348

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
