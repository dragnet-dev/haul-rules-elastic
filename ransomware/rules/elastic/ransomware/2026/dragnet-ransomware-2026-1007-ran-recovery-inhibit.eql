// Dragnet [Ransomware]: dragnet-ransomware-2026-1007 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: fd1272b3-f0e3-550a-8595-7208e9449b0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
