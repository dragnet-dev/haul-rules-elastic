// Dragnet [Ransomware]: dragnet-ransomware-2026-1696 — Recovery Inhibition (chaos)
// Status: stable | Level: high | ID: fd6fae96-1482-57cf-9806-d54c80c10a27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
