// Dragnet [Ransomware]: dragnet-ransomware-2026-1686 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: e0456469-f099-5378-afc8-91483e842f82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
