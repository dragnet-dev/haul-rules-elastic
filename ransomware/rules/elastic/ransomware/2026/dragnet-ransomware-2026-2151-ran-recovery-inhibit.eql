// Dragnet [Ransomware]: dragnet-ransomware-2026-2151 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 4a7563a8-d4ea-57a0-be0d-331224165cc3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
