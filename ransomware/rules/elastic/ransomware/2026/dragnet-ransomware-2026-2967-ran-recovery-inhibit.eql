// Dragnet [Ransomware]: dragnet-ransomware-2026-2967 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 6acec89d-7568-59a5-aeff-6cb48b6698d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
