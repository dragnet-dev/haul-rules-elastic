// Dragnet [Ransomware]: dragnet-ransomware-2026-1769 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: be110f9c-5f8d-5df7-b126-d70a413cc752

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
