// Dragnet [Ransomware]: dragnet-ransomware-2026-1415 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: da5b83c9-bd56-5aa7-b3e0-c4db6b253c1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
