// Dragnet [Ransomware]: dragnet-ransomware-2026-1148 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 58cc2d65-56c4-5202-93a8-9e84328fa0da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
