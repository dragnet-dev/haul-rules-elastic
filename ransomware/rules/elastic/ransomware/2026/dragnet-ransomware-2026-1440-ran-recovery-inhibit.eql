// Dragnet [Ransomware]: dragnet-ransomware-2026-1440 — Recovery Inhibition (payoutsking)
// Status: stable | Level: high | ID: 61924867-4e1a-5914-bcef-6ac9ce792147

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
