// Dragnet [Ransomware]: dragnet-ransomware-2026-2608 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 7e132d43-b5a3-5b1d-a3a8-0b85fa564b71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
