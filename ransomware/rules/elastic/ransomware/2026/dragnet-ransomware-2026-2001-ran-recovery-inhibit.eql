// Dragnet [Ransomware]: dragnet-ransomware-2026-2001 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 455b9ccf-2ebd-5ac2-9832-c9551e3a97fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
