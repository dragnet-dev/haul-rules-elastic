// Dragnet [Ransomware]: dragnet-ransomware-2026-0324 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 16dbb72d-a3c6-58bb-a70f-6d7f58e82a2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
