// Dragnet [Ransomware]: dragnet-ransomware-2026-2144 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 69a0031b-038b-5ab4-8493-94b7df9e2e76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
