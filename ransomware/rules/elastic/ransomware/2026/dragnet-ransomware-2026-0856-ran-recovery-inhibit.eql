// Dragnet [Ransomware]: dragnet-ransomware-2026-0856 — Recovery Inhibition (nitrogen)
// Status: test | Level: high | ID: 546d88b8-d2b9-57c4-baa8-cb0552dff4d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
