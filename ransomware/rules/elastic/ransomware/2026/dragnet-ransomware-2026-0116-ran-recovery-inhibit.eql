// Dragnet [Ransomware]: dragnet-ransomware-2026-0116 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: aabf8b69-6604-5b3f-b879-a4b6c524b83c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
