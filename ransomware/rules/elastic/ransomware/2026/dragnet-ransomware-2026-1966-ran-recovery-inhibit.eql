// Dragnet [Ransomware]: dragnet-ransomware-2026-1966 — Recovery Inhibition (worldleaks)
// Status: stable | Level: high | ID: 319b7e06-44af-59f6-aad8-9438de198494

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
