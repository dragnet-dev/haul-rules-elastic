// Dragnet [Ransomware]: dragnet-ransomware-2026-1893 — Recovery Inhibition (gunra)
// Status: stable | Level: high | ID: dc7d7ed6-a33b-5473-84b7-4d19b5da99e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
