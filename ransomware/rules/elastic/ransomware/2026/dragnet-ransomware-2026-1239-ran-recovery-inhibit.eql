// Dragnet [Ransomware]: dragnet-ransomware-2026-1239 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 850ecd4a-bfe4-500c-bc51-01a76d54f759

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
