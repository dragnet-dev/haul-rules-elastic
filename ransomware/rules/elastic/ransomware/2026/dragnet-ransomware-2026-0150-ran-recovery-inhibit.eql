// Dragnet [Ransomware]: dragnet-ransomware-2026-0150 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: f1acf407-f884-56ee-8816-1be93c6ea041

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
