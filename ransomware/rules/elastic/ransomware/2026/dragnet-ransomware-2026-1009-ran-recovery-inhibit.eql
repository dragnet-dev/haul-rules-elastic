// Dragnet [Ransomware]: dragnet-ransomware-2026-1009 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 2f161d72-cb5a-50b8-b59d-6cad7003a663

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
