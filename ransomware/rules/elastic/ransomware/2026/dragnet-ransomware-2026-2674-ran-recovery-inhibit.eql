// Dragnet [Ransomware]: dragnet-ransomware-2026-2674 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 76c934e8-931e-5082-9408-2a44c0dfa694

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
