// Dragnet [Ransomware]: dragnet-ransomware-2026-0727 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 383dff83-c8f7-5ec4-87df-2d7eb86204cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
