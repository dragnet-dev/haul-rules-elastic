// Dragnet [Ransomware]: dragnet-ransomware-2026-3411 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 9143dac9-b2e1-536e-be8e-092a0679a62d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
