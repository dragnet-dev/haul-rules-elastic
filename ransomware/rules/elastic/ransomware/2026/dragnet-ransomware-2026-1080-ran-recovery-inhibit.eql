// Dragnet [Ransomware]: dragnet-ransomware-2026-1080 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 89de37a0-df7a-5852-a578-7956df51757e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
