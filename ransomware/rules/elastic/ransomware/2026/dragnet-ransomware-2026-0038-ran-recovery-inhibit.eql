// Dragnet [Ransomware]: dragnet-ransomware-2026-0038 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 1d8d9524-4f76-524b-aa1b-87ecf80532c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
