// Dragnet [Ransomware]: dragnet-ransomware-2026-0530 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 7b1315e6-d298-5d67-b75e-68f81703c2a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
