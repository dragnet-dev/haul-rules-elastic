// Dragnet [Ransomware]: dragnet-ransomware-2026-1726 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: af465480-1872-557c-8ff7-d90ed16ff018

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
