// Dragnet [Ransomware]: dragnet-ransomware-2026-1313 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 957cea00-b179-5ae5-8225-5c0c36ffaf07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
