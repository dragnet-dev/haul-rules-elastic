// Dragnet [Ransomware]: dragnet-ransomware-2026-1028 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 3c4da37e-8cd1-52bf-ab75-2916ec0b68e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
