// Dragnet [Ransomware]: dragnet-ransomware-2026-0175 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 2fffd0f4-8805-5bdc-ae99-ab38fa9a5b6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
