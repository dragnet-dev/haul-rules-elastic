// Dragnet [Ransomware]: dragnet-ransomware-2026-2352 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 079c6dba-7edb-5a1f-83fd-eea850541ca6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
