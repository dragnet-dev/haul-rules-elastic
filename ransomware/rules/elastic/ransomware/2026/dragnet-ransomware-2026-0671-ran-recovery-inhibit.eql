// Dragnet [Ransomware]: dragnet-ransomware-2026-0671 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: c7159021-371c-5ff2-b3da-e0d2e51cc99d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
