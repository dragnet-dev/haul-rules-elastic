// Dragnet [Ransomware]: dragnet-ransomware-2026-2993 — Recovery Inhibition (lapsus$)
// Status: deprecated | Level: high | ID: 0dedefbd-048c-5afd-9804-099917913280

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
