// Dragnet [Ransomware]: dragnet-ransomware-2026-2387 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 4305648e-ea81-5c00-85c7-1dce48474324

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
