// Dragnet [Ransomware]: dragnet-ransomware-2026-0764 — Recovery Inhibition (TiMc)
// Status: deprecated | Level: high | ID: 60611bcf-517b-50d4-8fd7-0f1544b94865

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
