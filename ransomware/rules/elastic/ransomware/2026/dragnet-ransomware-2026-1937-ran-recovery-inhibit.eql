// Dragnet [Ransomware]: dragnet-ransomware-2026-1937 — Recovery Inhibition (spacebears)
// Status: stable | Level: high | ID: 8afb43be-fdaa-544c-b628-17f7bae0c97f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
