// Dragnet [Ransomware]: dragnet-ransomware-2026-0794 — Recovery Inhibition (chaos)
// Status: stable | Level: high | ID: c5eeea5c-1a42-5358-a1de-5ec8f5654599

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
