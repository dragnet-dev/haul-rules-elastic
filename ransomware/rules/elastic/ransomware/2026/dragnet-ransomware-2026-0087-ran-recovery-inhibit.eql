// Dragnet [Ransomware]: dragnet-ransomware-2026-0087 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 8a81004e-79f4-5a22-80da-318d02bf4b33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
