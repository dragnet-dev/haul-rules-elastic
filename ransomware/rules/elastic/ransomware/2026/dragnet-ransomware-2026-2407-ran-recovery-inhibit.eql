// Dragnet [Ransomware]: dragnet-ransomware-2026-2407 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 35aa5b1a-5f99-550c-baf5-576ec3666bc3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
