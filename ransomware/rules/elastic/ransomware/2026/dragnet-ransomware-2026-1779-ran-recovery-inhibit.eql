// Dragnet [Ransomware]: dragnet-ransomware-2026-1779 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: cae86773-0c31-53e4-a4b6-e4cab9514bd6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
