// Dragnet [Ransomware]: dragnet-ransomware-2026-3481 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 52001378-6879-507c-a48a-95b8f30fce6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
