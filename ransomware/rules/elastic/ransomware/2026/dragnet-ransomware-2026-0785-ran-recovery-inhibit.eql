// Dragnet [Ransomware]: dragnet-ransomware-2026-0785 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: a7ee4746-f7f1-553d-a209-dfafb17da170

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
