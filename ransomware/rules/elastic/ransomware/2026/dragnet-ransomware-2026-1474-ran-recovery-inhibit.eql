// Dragnet [Ransomware]: dragnet-ransomware-2026-1474 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: ebad91f4-9ac5-5fa9-9a4d-fe7dc68b6b11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
