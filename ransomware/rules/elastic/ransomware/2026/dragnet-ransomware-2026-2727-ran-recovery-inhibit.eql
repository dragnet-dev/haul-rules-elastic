// Dragnet [Ransomware]: dragnet-ransomware-2026-2727 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: f5decf7f-746f-592e-a461-2dc2d4c287ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
