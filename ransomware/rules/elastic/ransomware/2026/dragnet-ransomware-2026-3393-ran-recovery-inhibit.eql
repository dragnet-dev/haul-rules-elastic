// Dragnet [Ransomware]: dragnet-ransomware-2026-3393 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8612d324-67a2-545d-b526-ed16b074adab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
