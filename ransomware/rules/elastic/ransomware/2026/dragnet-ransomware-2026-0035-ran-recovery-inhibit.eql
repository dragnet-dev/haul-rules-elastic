// Dragnet [Ransomware]: dragnet-ransomware-2026-0035 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 9cac1ab0-365f-527a-8321-a2b305281421

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
