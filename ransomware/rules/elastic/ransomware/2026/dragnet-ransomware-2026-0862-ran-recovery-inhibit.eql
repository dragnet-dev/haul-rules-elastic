// Dragnet [Ransomware]: dragnet-ransomware-2026-0862 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 20c2033b-fbdd-50a7-bb7b-b032b7755dfa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
