// Dragnet [Ransomware]: dragnet-ransomware-2026-0971 — Recovery Inhibition (morpheus)
// Status: deprecated | Level: high | ID: 10ee5715-9b2a-5fb1-b3e2-3eaf6093d032

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
