// Dragnet [Ransomware]: dragnet-ransomware-2026-1458 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: 1973802d-bfaf-57ab-81d2-b8b12d8a8436

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
