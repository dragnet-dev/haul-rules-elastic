// Dragnet [Ransomware]: dragnet-ransomware-2026-3211 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: d85fd51e-638c-59da-a240-521f981b67eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
