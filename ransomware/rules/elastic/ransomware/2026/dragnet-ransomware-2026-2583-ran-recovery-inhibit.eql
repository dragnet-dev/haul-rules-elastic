// Dragnet [Ransomware]: dragnet-ransomware-2026-2583 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 0b57f144-0e9a-58d6-b3f8-82da2ead82b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
