// Dragnet [Ransomware]: dragnet-ransomware-2026-0855 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: a5a82e12-9696-519d-adbe-5fbc6c3c641a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
