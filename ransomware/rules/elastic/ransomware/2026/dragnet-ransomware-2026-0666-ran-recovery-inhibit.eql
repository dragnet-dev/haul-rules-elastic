// Dragnet [Ransomware]: dragnet-ransomware-2026-0666 — Recovery Inhibition (fulcrumsec)
// Status: stable | Level: high | ID: 017bc335-e8e3-57bc-a237-a3571f6cf8ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
