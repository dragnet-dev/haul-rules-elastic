// Dragnet [Ransomware]: dragnet-ransomware-2026-2700 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 289986ec-2259-5226-8e76-7e25d5fb673c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
