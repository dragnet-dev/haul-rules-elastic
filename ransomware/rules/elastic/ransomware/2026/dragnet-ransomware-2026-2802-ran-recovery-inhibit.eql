// Dragnet [Ransomware]: dragnet-ransomware-2026-2802 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 82ed4d23-a7d0-5080-b74e-71be862c6fce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
