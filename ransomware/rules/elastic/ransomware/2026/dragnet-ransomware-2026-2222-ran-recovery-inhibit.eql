// Dragnet [Ransomware]: dragnet-ransomware-2026-2222 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 5ea06b92-afea-52ac-a52d-bd1cb412e855

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
