// Dragnet [Ransomware]: dragnet-ransomware-2026-0544 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: 96fa8a26-b8a1-5ac0-a99c-29975c0279f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
