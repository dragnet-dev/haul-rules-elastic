// Dragnet [Ransomware]: dragnet-ransomware-2026-0281 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 99ebc6ab-0c3d-5b66-94d5-532d7f021ce7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
