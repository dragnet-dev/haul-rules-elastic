// Dragnet [Ransomware]: dragnet-ransomware-2026-1332 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: c863f80c-c1c2-52c0-83bd-42b12f8b7ddc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
