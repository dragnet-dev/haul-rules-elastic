// Dragnet [Ransomware]: dragnet-ransomware-2026-2120 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 024c745f-5418-5c72-a8ad-e72b7409adcb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
