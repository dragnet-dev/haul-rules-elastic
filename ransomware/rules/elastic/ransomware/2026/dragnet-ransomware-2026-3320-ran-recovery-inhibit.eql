// Dragnet [Ransomware]: dragnet-ransomware-2026-3320 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 34a8b819-96b0-558b-9a9f-455650f79741

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
