// Dragnet [Ransomware]: dragnet-ransomware-2026-0799 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 301bccfb-80d5-5a89-a6e1-daa9f4ab2f18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
