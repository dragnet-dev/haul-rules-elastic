// Dragnet [Ransomware]: dragnet-ransomware-2026-1250 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: d141438e-c1ec-58c9-ad20-86be2a8df124

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
