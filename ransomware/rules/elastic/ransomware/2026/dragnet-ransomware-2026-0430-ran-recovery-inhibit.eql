// Dragnet [Ransomware]: dragnet-ransomware-2026-0430 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 75515f44-e8af-5973-a85b-e71efc828d23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
