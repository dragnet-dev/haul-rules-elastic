// Dragnet [Ransomware]: dragnet-ransomware-2026-0776 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 7bb13aa2-7aa4-5cbb-ae9d-e2f04120d6b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
