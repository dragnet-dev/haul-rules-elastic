// Dragnet [Ransomware]: dragnet-ransomware-2026-3459 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 7b213aea-f2be-5d5b-b7c1-3ee1acec1737

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
