// Dragnet [Ransomware]: dragnet-ransomware-2026-3507 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0a27d926-24c0-5393-91eb-658b5734e9d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
