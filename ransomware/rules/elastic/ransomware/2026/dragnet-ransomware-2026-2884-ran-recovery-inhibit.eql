// Dragnet [Ransomware]: dragnet-ransomware-2026-2884 — Recovery Inhibition (genesis)
// Status: stable | Level: high | ID: 6c832282-da97-5bce-ab4e-9363342fb8a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
