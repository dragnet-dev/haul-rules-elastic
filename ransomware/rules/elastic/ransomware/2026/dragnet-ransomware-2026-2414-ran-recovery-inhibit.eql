// Dragnet [Ransomware]: dragnet-ransomware-2026-2414 — Recovery Inhibition (genesis)
// Status: stable | Level: high | ID: a684a2d0-1245-5871-9d07-0fc0cf54c2a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
