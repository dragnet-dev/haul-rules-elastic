// Dragnet [Ransomware]: dragnet-ransomware-2026-2223 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: ce0a4a80-0412-5ade-8bb9-37644f48ada1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
