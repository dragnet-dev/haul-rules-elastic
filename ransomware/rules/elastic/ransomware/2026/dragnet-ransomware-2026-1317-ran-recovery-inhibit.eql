// Dragnet [Ransomware]: dragnet-ransomware-2026-1317 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 5d154805-0b7b-56bb-acf7-8b1af32e3c14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
