// Dragnet [Ransomware]: dragnet-ransomware-2026-0538 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: 4730c6e5-d7cd-5aa7-8e3b-2a565607951a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
