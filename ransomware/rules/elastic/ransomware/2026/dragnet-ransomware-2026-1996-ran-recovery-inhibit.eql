// Dragnet [Ransomware]: dragnet-ransomware-2026-1996 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: ace1005f-22d1-5c9f-a03d-b8fa2d45d359

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
