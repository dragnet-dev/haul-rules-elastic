// Dragnet [Ransomware]: dragnet-ransomware-2026-3513 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 5f6772f2-a8a5-59f7-b3f4-23ed53b8271c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
