// Dragnet [Ransomware]: dragnet-ransomware-2026-0502 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: f5fc2d04-d406-565c-b3d7-c18d29dc7d26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
