// Dragnet [Ransomware]: dragnet-ransomware-2026-2569 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: e4119e30-7cfa-5e80-a055-d2606b056b5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
