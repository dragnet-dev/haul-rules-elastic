// Dragnet [Ransomware]: dragnet-ransomware-2026-0859 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 4eb30edf-d37b-522a-bc62-615ee0796ffe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
