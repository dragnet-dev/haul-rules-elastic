// Dragnet [Ransomware]: dragnet-ransomware-2026-0424 — Recovery Inhibition (genesis)
// Status: stable | Level: high | ID: 775280a8-0161-5001-82f7-12854a50ca07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
