// Dragnet [Ransomware]: dragnet-ransomware-2026-1156 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 180904c1-87d1-5053-b853-bac92d4fcca1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
