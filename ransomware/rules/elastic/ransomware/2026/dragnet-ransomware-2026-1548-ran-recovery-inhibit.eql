// Dragnet [Ransomware]: dragnet-ransomware-2026-1548 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: e82a3b2e-0beb-511a-898d-80180cd55a1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
