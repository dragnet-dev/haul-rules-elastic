// Dragnet [Ransomware]: dragnet-ransomware-2026-3371 — Recovery Inhibition (direwolf)
// Status: test | Level: high | ID: 0c3ea304-1fab-563f-8fd8-51642bcfe09e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
