// Dragnet [Ransomware]: dragnet-ransomware-2026-0331 — Recovery Inhibition (payoutsking)
// Status: stable | Level: high | ID: 7e3097d8-cded-57ca-b49b-67cbd498ffd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
