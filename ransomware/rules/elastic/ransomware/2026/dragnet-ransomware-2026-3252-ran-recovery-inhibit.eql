// Dragnet [Ransomware]: dragnet-ransomware-2026-3252 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 90807dd6-2cea-553c-a80f-2b3041d08333

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
