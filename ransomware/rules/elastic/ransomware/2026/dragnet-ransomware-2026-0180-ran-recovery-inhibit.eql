// Dragnet [Ransomware]: dragnet-ransomware-2026-0180 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 06d43200-9672-5ffa-b9ec-01cac9f42dd2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
