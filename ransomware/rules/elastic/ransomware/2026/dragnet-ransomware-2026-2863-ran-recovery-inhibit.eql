// Dragnet [Ransomware]: dragnet-ransomware-2026-2863 — Recovery Inhibition (payoutsking)
// Status: stable | Level: high | ID: c195601d-4a1f-553b-8f0e-d8be84c44f6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
