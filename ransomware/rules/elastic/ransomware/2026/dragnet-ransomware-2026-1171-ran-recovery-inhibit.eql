// Dragnet [Ransomware]: dragnet-ransomware-2026-1171 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: c3325b0f-dc9b-533f-ad85-e23d5d3a6b48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
