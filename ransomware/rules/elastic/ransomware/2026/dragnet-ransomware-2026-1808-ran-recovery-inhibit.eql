// Dragnet [Ransomware]: dragnet-ransomware-2026-1808 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 6365dd25-1f8f-5c8a-8388-c588f7d8abc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
