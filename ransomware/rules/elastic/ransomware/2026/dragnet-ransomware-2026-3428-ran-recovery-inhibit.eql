// Dragnet [Ransomware]: dragnet-ransomware-2026-3428 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 627eef3c-6e12-5a6e-af98-6b061136d61f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
