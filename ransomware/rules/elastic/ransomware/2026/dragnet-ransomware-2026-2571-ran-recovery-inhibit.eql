// Dragnet [Ransomware]: dragnet-ransomware-2026-2571 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 8fabc098-632d-53b9-904e-0e6bfcad7424

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
