// Dragnet [Ransomware]: dragnet-ransomware-2026-2093 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 9e34b9a4-e86c-5475-89cb-77ab89ebdb34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
