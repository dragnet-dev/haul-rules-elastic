// Dragnet [Ransomware]: dragnet-ransomware-2026-2392 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 499c6ece-3042-570a-8dc5-49460ae699c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
