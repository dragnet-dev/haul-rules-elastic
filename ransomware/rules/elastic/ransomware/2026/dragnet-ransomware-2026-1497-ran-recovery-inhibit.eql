// Dragnet [Ransomware]: dragnet-ransomware-2026-1497 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: 39d21560-1cea-55e5-b530-49059bc91217

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
