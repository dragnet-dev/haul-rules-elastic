// Dragnet [Ransomware]: dragnet-ransomware-2026-2146 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 48109730-8ac0-5dee-a980-6d3f7e3ae990

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
