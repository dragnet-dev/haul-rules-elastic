// Dragnet [Ransomware]: dragnet-ransomware-2026-2418 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 588738bc-6909-5250-b921-9dedc45c79a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
