// Dragnet [Ransomware]: dragnet-ransomware-2026-3453 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 29810958-5f76-58d2-9e8b-e660f9cec7e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
