// Dragnet [Ransomware]: dragnet-ransomware-2026-1993 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 9b851c24-18be-585d-9636-4a16744953bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
