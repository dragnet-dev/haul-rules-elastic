// Dragnet [Ransomware]: dragnet-ransomware-2026-2075 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: d20ae55a-6883-59e1-9300-6926b388f6cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
