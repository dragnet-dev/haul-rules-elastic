// Dragnet [Ransomware]: dragnet-ransomware-2026-2787 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 478342b0-e279-5028-b3a0-bd631bed4fce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
