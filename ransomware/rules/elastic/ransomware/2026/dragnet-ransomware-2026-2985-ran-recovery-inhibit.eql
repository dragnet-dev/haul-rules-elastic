// Dragnet [Ransomware]: dragnet-ransomware-2026-2985 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: ff716f80-49fa-5006-923c-2def43622259

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
