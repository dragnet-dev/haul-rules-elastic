// Dragnet [Ransomware]: dragnet-ransomware-2026-1079 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 57c0c225-a618-566d-bed7-177eddd20fee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
