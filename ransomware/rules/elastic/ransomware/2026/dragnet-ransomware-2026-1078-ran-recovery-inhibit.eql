// Dragnet [Ransomware]: dragnet-ransomware-2026-1078 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 07f3b98c-1bb2-53e0-b956-500bf8e69460

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
