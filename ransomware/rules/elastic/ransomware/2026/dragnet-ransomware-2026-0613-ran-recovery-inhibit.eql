// Dragnet [Ransomware]: dragnet-ransomware-2026-0613 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 0cb4a725-2540-531f-b0b6-ba1492b71c51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
