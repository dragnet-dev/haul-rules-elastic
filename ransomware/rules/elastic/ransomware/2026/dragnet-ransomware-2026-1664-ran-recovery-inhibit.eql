// Dragnet [Ransomware]: dragnet-ransomware-2026-1664 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 98bb9ac5-2cd2-5e7b-ad6a-2ea1ab05401a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
