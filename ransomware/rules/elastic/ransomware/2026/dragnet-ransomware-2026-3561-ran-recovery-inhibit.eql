// Dragnet [Ransomware]: dragnet-ransomware-2026-3561 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 099ef5ac-af17-56a4-97de-a73c6bf94ade

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
