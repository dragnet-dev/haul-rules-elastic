// Dragnet [Ransomware]: dragnet-ransomware-2026-2302 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 96d068fb-77cd-584d-949a-2d089ae0dc69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
