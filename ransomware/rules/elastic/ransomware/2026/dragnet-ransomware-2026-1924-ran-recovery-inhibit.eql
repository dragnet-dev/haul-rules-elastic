// Dragnet [Ransomware]: dragnet-ransomware-2026-1924 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 28c1d9a7-515e-5680-95a0-ea963befdbea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
