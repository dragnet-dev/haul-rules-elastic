// Dragnet [Ransomware]: dragnet-ransomware-2026-2080 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 9a09fc03-de75-5417-b2c7-9c1028b7cd82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
