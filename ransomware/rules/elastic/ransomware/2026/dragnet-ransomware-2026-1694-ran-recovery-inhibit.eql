// Dragnet [Ransomware]: dragnet-ransomware-2026-1694 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 70e96d3e-d975-567e-a441-718a2539c875

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
