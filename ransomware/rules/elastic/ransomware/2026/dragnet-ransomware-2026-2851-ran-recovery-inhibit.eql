// Dragnet [Ransomware]: dragnet-ransomware-2026-2851 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: e60e6ee9-a81f-587c-9ca2-611a726d9471

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
