// Dragnet [Ransomware]: dragnet-ransomware-2026-3187 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 65d5afae-1d5c-50d1-8bbc-acc208ab8fa8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
