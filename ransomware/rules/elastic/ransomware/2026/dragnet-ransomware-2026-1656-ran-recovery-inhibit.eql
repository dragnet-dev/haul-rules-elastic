// Dragnet [Ransomware]: dragnet-ransomware-2026-1656 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: d7499b0e-3ed4-5029-aead-872bb47d7323

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
