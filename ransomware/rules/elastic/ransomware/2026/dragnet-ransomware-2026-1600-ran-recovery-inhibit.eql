// Dragnet [Ransomware]: dragnet-ransomware-2026-1600 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 83ad5fc8-89cd-5046-b8e0-8be04eff489a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
