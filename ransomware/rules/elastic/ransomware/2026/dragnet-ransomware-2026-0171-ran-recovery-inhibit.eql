// Dragnet [Ransomware]: dragnet-ransomware-2026-0171 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 17475f3c-6792-5943-a4cd-debc130c686c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
