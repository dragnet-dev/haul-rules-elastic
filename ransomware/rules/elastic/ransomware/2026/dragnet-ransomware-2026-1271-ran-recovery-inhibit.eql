// Dragnet [Ransomware]: dragnet-ransomware-2026-1271 — Recovery Inhibition (gunra)
// Status: stable | Level: high | ID: be220aaa-e880-5b66-834b-50b5ce1f7999

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
