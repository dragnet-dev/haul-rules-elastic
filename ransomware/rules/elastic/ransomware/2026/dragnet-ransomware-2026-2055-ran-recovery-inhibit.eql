// Dragnet [Ransomware]: dragnet-ransomware-2026-2055 — Recovery Inhibition (aurora)
// Status: stable | Level: high | ID: acd7e8f6-6975-57b7-9d92-80e04c3c245a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
