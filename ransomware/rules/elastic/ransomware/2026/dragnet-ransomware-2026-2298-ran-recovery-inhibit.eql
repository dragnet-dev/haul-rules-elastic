// Dragnet [Ransomware]: dragnet-ransomware-2026-2298 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 1d365c97-e518-5d05-956a-6d3be24d91e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
