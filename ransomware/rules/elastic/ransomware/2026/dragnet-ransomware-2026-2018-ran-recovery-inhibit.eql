// Dragnet [Ransomware]: dragnet-ransomware-2026-2018 — Recovery Inhibition (LeakBazaar)
// Status: stable | Level: high | ID: 6b03935d-fb14-5cfb-ad3d-d62bddca3c38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
