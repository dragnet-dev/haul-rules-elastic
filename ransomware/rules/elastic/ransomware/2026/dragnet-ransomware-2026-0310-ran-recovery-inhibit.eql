// Dragnet [Ransomware]: dragnet-ransomware-2026-0310 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: e31815d8-b53a-50c3-af64-46ea93bbca15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
