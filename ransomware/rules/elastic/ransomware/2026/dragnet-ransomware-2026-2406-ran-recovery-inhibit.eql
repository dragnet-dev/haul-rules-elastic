// Dragnet [Ransomware]: dragnet-ransomware-2026-2406 — Recovery Inhibition (clop)
// Status: stable | Level: high | ID: 8d685e0b-3b22-5bd5-a598-400e413990f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
