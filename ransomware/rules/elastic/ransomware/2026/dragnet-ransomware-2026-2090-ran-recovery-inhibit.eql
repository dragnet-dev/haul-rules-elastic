// Dragnet [Ransomware]: dragnet-ransomware-2026-2090 — Recovery Inhibition (lapsus$)
// Status: deprecated | Level: high | ID: 7d16f2fa-60af-52c8-95cb-45c87d816ec8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
