// Dragnet [Ransomware]: dragnet-ransomware-2026-1768 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 43fa516d-55a1-572d-ac44-159a13096387

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
