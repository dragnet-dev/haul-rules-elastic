// Dragnet [Ransomware]: dragnet-ransomware-2026-2952 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: d5df9406-9707-514f-847f-15572fe3981e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
