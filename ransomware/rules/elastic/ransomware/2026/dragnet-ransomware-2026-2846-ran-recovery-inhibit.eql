// Dragnet [Ransomware]: dragnet-ransomware-2026-2846 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 19a765f6-ba3e-53a8-8c09-668d3a530f9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
