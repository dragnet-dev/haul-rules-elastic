// Dragnet [Ransomware]: dragnet-ransomware-2026-0924 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: e75e0d96-3166-5907-ac52-75df519c662a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
