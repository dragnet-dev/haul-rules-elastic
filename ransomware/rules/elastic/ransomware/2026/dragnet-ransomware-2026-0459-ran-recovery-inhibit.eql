// Dragnet [Ransomware]: dragnet-ransomware-2026-0459 — Recovery Inhibition (titan)
// Status: stable | Level: high | ID: 8450ccc3-bef8-5ce6-a7db-4a9e8a415f5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
