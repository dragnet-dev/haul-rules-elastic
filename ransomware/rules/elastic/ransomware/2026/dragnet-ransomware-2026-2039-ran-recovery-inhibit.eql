// Dragnet [Ransomware]: dragnet-ransomware-2026-2039 — Recovery Inhibition (medusa)
// Status: test | Level: high | ID: ac453909-442e-5f48-b6ab-ae9a155ca997

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
