// Dragnet [Ransomware]: dragnet-ransomware-2026-2937 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 27b42a31-8980-5f7a-acb4-80a902d9aa71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
