// Dragnet [Ransomware]: dragnet-ransomware-2026-0912 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: aea7b047-f54d-5b47-8cfd-ff938bf5709a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
