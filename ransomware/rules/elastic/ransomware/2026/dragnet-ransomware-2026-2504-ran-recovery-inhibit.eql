// Dragnet [Ransomware]: dragnet-ransomware-2026-2504 — Recovery Inhibition (Icarus)
// Status: deprecated | Level: high | ID: b302f35b-8442-52d0-a202-9eefb265449b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
