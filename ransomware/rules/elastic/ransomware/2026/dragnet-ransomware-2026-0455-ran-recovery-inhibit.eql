// Dragnet [Ransomware]: dragnet-ransomware-2026-0455 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: f4a03226-105f-5a6e-ba9c-a3f9b63467a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
