// Dragnet [Ransomware]: dragnet-ransomware-2026-3157 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 90304f2f-5b18-5622-afaa-d0f0587244e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
