// Dragnet [Ransomware]: dragnet-ransomware-2026-2639 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: d0425fc2-7767-5943-bc2d-95b06df7f55f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
