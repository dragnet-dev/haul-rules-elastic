// Dragnet [Ransomware]: dragnet-ransomware-2026-2472 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 5bf50198-44da-549a-b26c-a0f488e84202

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
