// Dragnet [Ransomware]: dragnet-ransomware-2026-1911 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 3591ec6f-3b41-52cc-8228-6e3854d43dc1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
