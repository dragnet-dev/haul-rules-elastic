// Dragnet [Ransomware]: dragnet-ransomware-2026-1980 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 77379673-99ac-592e-bdee-39e9ffe07027

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
