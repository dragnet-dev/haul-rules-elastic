// Dragnet [Ransomware]: dragnet-ransomware-2026-0621 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 8f32d523-eb79-5630-bb66-e82a7ff95c82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
