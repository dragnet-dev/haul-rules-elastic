// Dragnet [Ransomware]: dragnet-ransomware-2026-1675 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 7d8bbdc2-62db-52c8-996e-217b01c9b929

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
