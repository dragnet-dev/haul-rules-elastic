// Dragnet [Ransomware]: dragnet-ransomware-2026-1233 — Recovery Inhibition (m3rx)
// Status: stable | Level: high | ID: 920bfb0f-3615-5d81-a8ea-d936dad442cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
