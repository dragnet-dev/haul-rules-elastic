// Dragnet [Ransomware]: dragnet-ransomware-2026-2292 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: e607ab9e-db96-5cbf-bfe1-222b387bd241

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
