// Dragnet [Ransomware]: dragnet-ransomware-2026-2005 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 3c4fbf47-3c72-51f1-ac11-6100bcaebe17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
