// Dragnet [Ransomware]: dragnet-ransomware-2021-1076 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: 83099438-51e8-5884-80f1-cfbe5c6dbbc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
