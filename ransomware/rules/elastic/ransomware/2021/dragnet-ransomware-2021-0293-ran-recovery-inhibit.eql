// Dragnet [Ransomware]: dragnet-ransomware-2021-0293 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 40ce4444-b9f4-53e7-b7d0-6bbf0ce110a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
