// Dragnet [Ransomware]: dragnet-ransomware-2021-0877 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 13231399-2a3b-5378-a43a-8157ececf47c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
