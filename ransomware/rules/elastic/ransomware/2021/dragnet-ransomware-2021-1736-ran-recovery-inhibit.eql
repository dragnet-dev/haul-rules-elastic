// Dragnet [Ransomware]: dragnet-ransomware-2021-1736 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 804ea0d2-1e29-58d9-9958-31988c959b11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
