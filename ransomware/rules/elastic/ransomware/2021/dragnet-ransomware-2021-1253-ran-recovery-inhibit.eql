// Dragnet [Ransomware]: dragnet-ransomware-2021-1253 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 371fb209-829d-5131-acad-5d7de5212981

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
