// Dragnet [Ransomware]: dragnet-ransomware-2021-0184 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: 22d397d3-d030-5485-84cf-3f1c1b7bce68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
