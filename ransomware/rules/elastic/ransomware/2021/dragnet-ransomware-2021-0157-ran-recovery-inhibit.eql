// Dragnet [Ransomware]: dragnet-ransomware-2021-0157 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5e9206de-5665-56a3-83fe-7ad8a4c3fa1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
