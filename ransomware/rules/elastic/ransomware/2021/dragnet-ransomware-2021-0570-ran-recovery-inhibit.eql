// Dragnet [Ransomware]: dragnet-ransomware-2021-0570 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b7f52756-d51e-5195-8539-eede8358cd49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
