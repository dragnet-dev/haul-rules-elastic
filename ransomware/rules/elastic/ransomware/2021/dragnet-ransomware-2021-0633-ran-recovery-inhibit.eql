// Dragnet [Ransomware]: dragnet-ransomware-2021-0633 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 85f89639-7bef-5d91-85a2-59e19c525306

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
