// Dragnet [Ransomware]: dragnet-ransomware-2021-0755 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 58b327df-d149-5558-8a72-3e307365c720

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
