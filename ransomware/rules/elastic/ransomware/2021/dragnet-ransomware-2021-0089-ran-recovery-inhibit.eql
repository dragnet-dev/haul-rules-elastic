// Dragnet [Ransomware]: dragnet-ransomware-2021-0089 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: f18be689-bf97-5a2d-b525-12c70f3c6853

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
