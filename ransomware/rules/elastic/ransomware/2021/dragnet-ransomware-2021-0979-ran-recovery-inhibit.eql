// Dragnet [Ransomware]: dragnet-ransomware-2021-0979 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f45fb89a-fbf5-5044-8462-74534973f8e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
