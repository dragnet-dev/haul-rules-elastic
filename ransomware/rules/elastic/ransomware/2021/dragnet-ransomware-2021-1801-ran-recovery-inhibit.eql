// Dragnet [Ransomware]: dragnet-ransomware-2021-1801 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b7ca6bf1-1921-5e1f-abd5-a89b30cb4e0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
