// Dragnet [Ransomware]: dragnet-ransomware-2021-1159 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 974f6ce9-996d-5980-8558-005cbe0e87ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
