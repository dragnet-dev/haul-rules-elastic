// Dragnet [Ransomware]: dragnet-ransomware-2021-0663 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: ff967a53-d80a-5591-98d1-e95b77d658a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
