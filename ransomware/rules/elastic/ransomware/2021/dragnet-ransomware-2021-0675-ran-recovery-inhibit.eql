// Dragnet [Ransomware]: dragnet-ransomware-2021-0675 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 4e388bfd-65f5-5c90-9cef-17acdfa20d3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
