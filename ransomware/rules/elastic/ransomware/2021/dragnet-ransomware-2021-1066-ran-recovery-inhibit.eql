// Dragnet [Ransomware]: dragnet-ransomware-2021-1066 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 35dc297b-c83e-5100-a2ba-011347daa271

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
