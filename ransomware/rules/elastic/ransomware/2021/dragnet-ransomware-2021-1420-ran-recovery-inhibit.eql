// Dragnet [Ransomware]: dragnet-ransomware-2021-1420 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 998a714c-03b3-5620-925c-000ff854eb73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
