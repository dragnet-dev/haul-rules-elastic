// Dragnet [Ransomware]: dragnet-ransomware-2021-1638 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: b7247f11-3550-575e-b556-bd970e40394c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
