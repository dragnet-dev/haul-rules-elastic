// Dragnet [Ransomware]: dragnet-ransomware-2021-0583 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ba158436-b992-5018-b17f-9921aefa61f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
