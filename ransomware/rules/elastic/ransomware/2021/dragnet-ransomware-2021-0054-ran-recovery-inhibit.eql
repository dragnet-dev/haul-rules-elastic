// Dragnet [Ransomware]: dragnet-ransomware-2021-0054 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 0f8c9dd5-687e-5c49-8db5-e544837dde77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
