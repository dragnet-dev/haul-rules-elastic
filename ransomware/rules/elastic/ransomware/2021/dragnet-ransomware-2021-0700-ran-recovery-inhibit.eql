// Dragnet [Ransomware]: dragnet-ransomware-2021-0700 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: d01cfa07-ac84-5c17-8f64-06cdc10f6368

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
