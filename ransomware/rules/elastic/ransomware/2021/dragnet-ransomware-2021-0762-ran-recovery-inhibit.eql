// Dragnet [Ransomware]: dragnet-ransomware-2021-0762 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 331daf63-2412-5947-b18e-e74fc6c46908

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
