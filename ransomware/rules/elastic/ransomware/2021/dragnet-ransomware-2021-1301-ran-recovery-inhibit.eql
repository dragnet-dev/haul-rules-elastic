// Dragnet [Ransomware]: dragnet-ransomware-2021-1301 — Recovery Inhibition (mountlocker)
// Status: deprecated | Level: high | ID: cfbe7ea6-8963-5e09-b1e9-3a6b4ad43fdc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
