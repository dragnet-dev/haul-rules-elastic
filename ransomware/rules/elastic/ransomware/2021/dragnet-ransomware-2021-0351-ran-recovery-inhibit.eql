// Dragnet [Ransomware]: dragnet-ransomware-2021-0351 — Recovery Inhibition (azroteam)
// Status: deprecated | Level: high | ID: 22b9845d-dcdd-50f0-be2a-1682b47c89d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
