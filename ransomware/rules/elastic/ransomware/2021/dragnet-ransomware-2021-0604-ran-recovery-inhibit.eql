// Dragnet [Ransomware]: dragnet-ransomware-2021-0604 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 65d2da0e-0520-50c6-a7cb-b9d5888e1cfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
