// Dragnet [Ransomware]: dragnet-ransomware-2021-1027 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 8c6e7c21-704c-59d6-b849-f838caa0ae2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
