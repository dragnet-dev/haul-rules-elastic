// Dragnet [Ransomware]: dragnet-ransomware-2021-1225 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 5367e703-8f96-51a3-82a8-81d4f345fca8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
