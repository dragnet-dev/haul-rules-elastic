// Dragnet [Ransomware]: dragnet-ransomware-2021-1547 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 3ad9c464-d047-56ad-852d-68888a288796

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
