// Dragnet [Ransomware]: dragnet-ransomware-2021-0454 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 7b59123d-f939-5658-b34f-1416c21d1ad7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
