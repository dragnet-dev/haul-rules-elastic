// Dragnet [Ransomware]: dragnet-ransomware-2021-0192 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 94e43aac-5b18-56ec-9e33-53cbacaab80e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
