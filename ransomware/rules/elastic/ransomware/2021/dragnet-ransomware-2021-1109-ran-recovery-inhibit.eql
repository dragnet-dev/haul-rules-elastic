// Dragnet [Ransomware]: dragnet-ransomware-2021-1109 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b930bce3-4d99-5ffd-bfee-eb503319fc5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
