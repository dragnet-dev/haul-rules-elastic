// Dragnet [Ransomware]: dragnet-ransomware-2021-0370 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 657ec20b-dc59-59ed-b952-919fab825030

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
