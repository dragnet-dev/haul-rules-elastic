// Dragnet [Ransomware]: dragnet-ransomware-2021-1083 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: bf505805-c0e7-552e-aa6f-63929de7faed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
