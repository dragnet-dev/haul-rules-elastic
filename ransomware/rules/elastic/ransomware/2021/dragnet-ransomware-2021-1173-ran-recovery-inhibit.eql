// Dragnet [Ransomware]: dragnet-ransomware-2021-1173 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 043dd043-2d00-58df-8190-7d52bfa9d053

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
