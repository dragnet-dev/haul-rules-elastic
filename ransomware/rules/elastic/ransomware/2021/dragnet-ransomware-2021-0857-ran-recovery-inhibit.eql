// Dragnet [Ransomware]: dragnet-ransomware-2021-0857 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: c529538a-d392-5161-a573-072ec05a987d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
