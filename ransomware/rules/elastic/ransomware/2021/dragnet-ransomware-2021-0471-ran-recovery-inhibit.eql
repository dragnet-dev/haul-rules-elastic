// Dragnet [Ransomware]: dragnet-ransomware-2021-0471 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: c5161da9-c3f8-5900-972d-818277b433f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
