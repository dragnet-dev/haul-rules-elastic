// Dragnet [Ransomware]: dragnet-ransomware-2021-1475 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 80ada122-415e-53c1-a36b-18d768cf4178

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
