// Dragnet [Ransomware]: dragnet-ransomware-2021-1409 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: ae9ebf13-7385-5643-9708-f2d7e2979e64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
