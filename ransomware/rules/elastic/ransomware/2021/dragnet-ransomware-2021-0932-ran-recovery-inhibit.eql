// Dragnet [Ransomware]: dragnet-ransomware-2021-0932 — Recovery Inhibition (karma)
// Status: deprecated | Level: high | ID: 6862d9e8-bfab-5395-951a-a34b408e8748

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
