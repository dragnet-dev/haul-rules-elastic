// Dragnet [Ransomware]: dragnet-ransomware-2021-0405 — Recovery Inhibition (groove)
// Status: deprecated | Level: high | ID: 6112c084-1e90-5953-b8f4-fb8d5dc98022

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
