// Dragnet [Ransomware]: dragnet-ransomware-2021-1230 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: bc0a9d63-40e2-55a1-89a5-c01cad507c8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
