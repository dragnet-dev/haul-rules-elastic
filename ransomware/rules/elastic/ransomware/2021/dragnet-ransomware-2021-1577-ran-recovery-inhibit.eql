// Dragnet [Ransomware]: dragnet-ransomware-2021-1577 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 7c90c8f4-2112-5ad1-a4b9-abaef7bd4c2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
