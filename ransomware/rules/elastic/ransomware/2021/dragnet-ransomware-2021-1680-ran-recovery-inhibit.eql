// Dragnet [Ransomware]: dragnet-ransomware-2021-1680 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: fbfe3bf9-de7e-5315-9c18-44487e594062

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
