// Dragnet [Ransomware]: dragnet-ransomware-2021-0927 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 93e71740-bd7f-57b2-9822-25caabe502a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
