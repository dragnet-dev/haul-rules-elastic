// Dragnet [Ransomware]: dragnet-ransomware-2021-1011 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: a95d26b5-365f-511f-8404-27b6c6a2bdb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
