// Dragnet [Ransomware]: dragnet-ransomware-2021-0267 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 1a6c822f-fd33-57c9-ae54-13ad48601ad2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
