// Dragnet [Ransomware]: dragnet-ransomware-2021-1712 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 3c3a7c8c-a378-51c3-a738-c700eeaa26bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
