// Dragnet [Ransomware]: dragnet-ransomware-2021-1750 — Recovery Inhibition (mosesstaff)
// Status: deprecated | Level: high | ID: 8d503022-9590-5b80-97d2-50572ed785f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
