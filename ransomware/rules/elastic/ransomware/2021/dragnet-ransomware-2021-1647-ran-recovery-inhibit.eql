// Dragnet [Ransomware]: dragnet-ransomware-2021-1647 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5bbb7e8d-5cf3-5e90-9a0a-f8c1675eee8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
