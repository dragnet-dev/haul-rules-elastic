// Dragnet [Ransomware]: dragnet-ransomware-2021-0673 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 8cc765d4-9634-5db0-878c-808035cedce9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
