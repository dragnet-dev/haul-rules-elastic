// Dragnet [Ransomware]: dragnet-ransomware-2021-0214 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 59c125f8-9453-59c5-b0df-268679bf7873

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
