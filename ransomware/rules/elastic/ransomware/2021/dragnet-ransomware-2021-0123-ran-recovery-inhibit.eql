// Dragnet [Ransomware]: dragnet-ransomware-2021-0123 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 0eab5beb-1cf0-5186-bd95-e34f1ab0fc92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
