// Dragnet [Ransomware]: dragnet-ransomware-2021-1728 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: c606b66d-046b-56b7-8b9e-6775c4c462cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
