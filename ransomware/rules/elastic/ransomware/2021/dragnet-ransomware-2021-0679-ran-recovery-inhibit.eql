// Dragnet [Ransomware]: dragnet-ransomware-2021-0679 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 693d6de4-4b42-5b2e-9793-79c9ec2161ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
