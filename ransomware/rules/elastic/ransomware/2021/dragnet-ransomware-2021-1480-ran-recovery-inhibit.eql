// Dragnet [Ransomware]: dragnet-ransomware-2021-1480 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: 8453d20d-5ce7-5819-91b3-c0a08cb491f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
