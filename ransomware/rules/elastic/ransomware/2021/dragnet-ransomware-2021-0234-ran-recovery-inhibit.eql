// Dragnet [Ransomware]: dragnet-ransomware-2021-0234 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 2e348364-9e58-5ba5-9977-ba654c9b1334

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
