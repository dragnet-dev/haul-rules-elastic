// Dragnet [Ransomware]: dragnet-ransomware-2021-0548 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 351c2a43-8ee1-5a77-9dd1-1e4b714cb674

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
