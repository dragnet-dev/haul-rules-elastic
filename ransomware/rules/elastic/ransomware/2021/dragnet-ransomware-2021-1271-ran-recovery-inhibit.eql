// Dragnet [Ransomware]: dragnet-ransomware-2021-1271 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b94ad410-efe8-5a71-9ac7-1fd549003627

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
