// Dragnet [Ransomware]: dragnet-ransomware-2021-1125 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 55325a70-6a3a-5867-803e-f4774b3d6f9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
