// Dragnet [Ransomware]: dragnet-ransomware-2021-0333 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: a7bf0b52-7a0a-542b-a65c-643446e83e8f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
