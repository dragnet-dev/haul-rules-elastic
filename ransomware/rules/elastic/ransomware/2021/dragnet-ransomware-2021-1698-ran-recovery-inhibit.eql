// Dragnet [Ransomware]: dragnet-ransomware-2021-1698 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: c2da46d2-1e90-5103-b14c-b3db56570c65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
