// Dragnet [Ransomware]: dragnet-ransomware-2021-0568 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: b45c09e3-9b4f-52f6-944f-dc9d616fb888

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
