// Dragnet [Ransomware]: dragnet-ransomware-2021-0919 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 8ecb6725-0367-5da0-ac52-34f730f8ce28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
