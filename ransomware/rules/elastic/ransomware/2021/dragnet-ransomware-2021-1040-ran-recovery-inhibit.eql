// Dragnet [Ransomware]: dragnet-ransomware-2021-1040 — Recovery Inhibition (blacktor)
// Status: deprecated | Level: high | ID: a6eaf326-eee1-5dac-be28-5efb4ad66dcd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
