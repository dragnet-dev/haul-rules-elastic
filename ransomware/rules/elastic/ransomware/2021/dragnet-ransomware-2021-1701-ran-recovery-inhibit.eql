// Dragnet [Ransomware]: dragnet-ransomware-2021-1701 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 48800b16-5963-53fc-8c08-527c5b7fed49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
