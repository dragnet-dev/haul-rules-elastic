// Dragnet [Ransomware]: dragnet-ransomware-2021-0358 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: a737e77d-a6de-5168-996d-fc0a2c03b2bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
