// Dragnet [Ransomware]: dragnet-ransomware-2021-0770 — Recovery Inhibition (maui)
// Status: deprecated | Level: high | ID: cad9250e-ff2b-5356-9a90-cd63717a286d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
