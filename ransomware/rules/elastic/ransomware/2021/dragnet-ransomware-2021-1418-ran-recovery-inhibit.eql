// Dragnet [Ransomware]: dragnet-ransomware-2021-1418 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 090ba5bf-dfe5-5692-83e6-c85a744d0fd0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
