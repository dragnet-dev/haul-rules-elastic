// Dragnet [Ransomware]: dragnet-ransomware-2021-0588 — Recovery Inhibition (xinglocker)
// Status: deprecated | Level: high | ID: 1ff4da43-d127-5413-963c-4a5617e6a570

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
