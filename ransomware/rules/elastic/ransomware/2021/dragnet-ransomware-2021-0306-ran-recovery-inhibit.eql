// Dragnet [Ransomware]: dragnet-ransomware-2021-0306 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 6216fc3d-1ee5-5164-8e74-94f57e80f324

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
