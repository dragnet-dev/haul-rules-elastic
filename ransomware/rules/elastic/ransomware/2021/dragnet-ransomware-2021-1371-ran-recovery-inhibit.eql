// Dragnet [Ransomware]: dragnet-ransomware-2021-1371 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 6c35f981-b669-5c44-8d63-e61841af1130

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
