// Dragnet [Ransomware]: dragnet-ransomware-2021-0567 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 66f14a00-029d-51ca-bb16-7537ef898c17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
