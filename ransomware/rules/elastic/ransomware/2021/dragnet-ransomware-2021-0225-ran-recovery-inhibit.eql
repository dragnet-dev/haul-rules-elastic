// Dragnet [Ransomware]: dragnet-ransomware-2021-0225 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4f3be0ec-449f-5006-98a5-982446a89cd1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
