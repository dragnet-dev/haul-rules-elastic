// Dragnet [Ransomware]: dragnet-ransomware-2021-1432 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: 0ad4cc98-e217-5cf1-b354-d8cdbc539304

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
