// Dragnet [Ransomware]: dragnet-ransomware-2021-1165 — Recovery Inhibition (mosesstaff)
// Status: deprecated | Level: high | ID: dafb4b28-4e9f-5196-a0db-94faa816d44d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
