// Dragnet [Ransomware]: dragnet-ransomware-2021-1758 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: d52e5186-ce17-566b-96cd-418684be46f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
