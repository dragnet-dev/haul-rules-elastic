// Dragnet [Ransomware]: dragnet-ransomware-2021-0845 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 83ea1d6b-0220-5780-aec5-57063a0a548a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
