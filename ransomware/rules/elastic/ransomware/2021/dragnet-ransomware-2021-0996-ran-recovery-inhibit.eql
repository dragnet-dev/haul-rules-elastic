// Dragnet [Ransomware]: dragnet-ransomware-2021-0996 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: fd338031-0f58-5ae2-a82f-05d2fd348c16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
