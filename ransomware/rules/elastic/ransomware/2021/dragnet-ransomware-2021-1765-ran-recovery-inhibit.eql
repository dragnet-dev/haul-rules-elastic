// Dragnet [Ransomware]: dragnet-ransomware-2021-1765 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f69ce557-aa17-5159-afa6-8fbef8495aa8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
