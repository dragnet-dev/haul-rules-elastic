// Dragnet [Ransomware]: dragnet-ransomware-2021-0205 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: df8856e2-456c-5117-914d-9eabcb50f71d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
