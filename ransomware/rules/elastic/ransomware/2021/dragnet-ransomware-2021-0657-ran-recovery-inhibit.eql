// Dragnet [Ransomware]: dragnet-ransomware-2021-0657 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 9f86e31f-7ac2-5589-a37e-1832c03c5ba3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
