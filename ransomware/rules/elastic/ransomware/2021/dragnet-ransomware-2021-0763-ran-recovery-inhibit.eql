// Dragnet [Ransomware]: dragnet-ransomware-2021-0763 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: f194bed0-f029-5dc9-8fd4-f24c57c8ab25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
