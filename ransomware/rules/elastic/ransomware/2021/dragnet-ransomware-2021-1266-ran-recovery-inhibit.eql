// Dragnet [Ransomware]: dragnet-ransomware-2021-1266 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: a9d415cd-63ad-5aa1-8b84-c6b198362239

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
