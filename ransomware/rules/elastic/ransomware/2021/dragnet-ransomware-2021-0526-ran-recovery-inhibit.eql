// Dragnet [Ransomware]: dragnet-ransomware-2021-0526 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 89879bfd-2dfb-5db4-915a-7c6215523580

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
