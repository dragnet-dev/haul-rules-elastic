// Dragnet [Ransomware]: dragnet-ransomware-2021-1761 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c99fcdbc-6af7-5366-9955-8edde1bf0407

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
