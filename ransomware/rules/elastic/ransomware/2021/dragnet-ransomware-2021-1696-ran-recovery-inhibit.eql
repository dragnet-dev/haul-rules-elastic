// Dragnet [Ransomware]: dragnet-ransomware-2021-1696 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 850b0af7-2c38-535a-8b52-763f13d40dbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
