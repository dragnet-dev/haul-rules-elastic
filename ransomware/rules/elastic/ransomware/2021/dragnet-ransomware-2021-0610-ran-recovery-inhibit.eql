// Dragnet [Ransomware]: dragnet-ransomware-2021-0610 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 04ef0ade-e27c-59b2-986c-47f715d6fdb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
