// Dragnet [Ransomware]: dragnet-ransomware-2021-0784 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 648f57be-e78d-55c4-9e14-f96d55aeca36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
