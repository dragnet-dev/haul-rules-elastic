// Dragnet [Ransomware]: dragnet-ransomware-2021-1394 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: b615b64f-5fd2-570b-ab17-82de9d767b66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
