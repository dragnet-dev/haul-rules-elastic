// Dragnet [Ransomware]: dragnet-ransomware-2021-0150 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: cf664d92-3aeb-5969-881f-4afd53940e87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
