// Dragnet [Ransomware]: dragnet-ransomware-2021-0365 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 5a989510-c768-501b-959e-4f55979a2849

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
