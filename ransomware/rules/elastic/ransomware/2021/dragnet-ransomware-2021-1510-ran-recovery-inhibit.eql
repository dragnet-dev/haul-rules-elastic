// Dragnet [Ransomware]: dragnet-ransomware-2021-1510 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: baaf71d4-c0b6-5cfa-a9ba-f414ec539aea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
