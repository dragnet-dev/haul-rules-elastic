// Dragnet [Ransomware]: dragnet-ransomware-2021-1514 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 3ae710ae-3b3e-59f4-98ac-667842cbfebf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
