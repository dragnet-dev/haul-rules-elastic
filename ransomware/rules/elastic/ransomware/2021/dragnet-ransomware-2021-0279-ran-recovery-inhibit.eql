// Dragnet [Ransomware]: dragnet-ransomware-2021-0279 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: d3f445d5-3bfc-536f-8959-de88e2260ffd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
