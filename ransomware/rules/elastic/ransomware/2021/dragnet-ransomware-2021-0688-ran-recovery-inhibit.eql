// Dragnet [Ransomware]: dragnet-ransomware-2021-0688 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 3b186ad4-b79c-5591-9e9b-c8bfc499666e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
