// Dragnet [Ransomware]: dragnet-ransomware-2021-0380 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 358a4749-7886-5e79-9dbb-fadfd5bebb2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
