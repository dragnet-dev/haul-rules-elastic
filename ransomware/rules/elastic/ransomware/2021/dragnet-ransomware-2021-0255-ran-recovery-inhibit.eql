// Dragnet [Ransomware]: dragnet-ransomware-2021-0255 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: 367ac07b-6533-5f26-a198-917f1a365cb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
