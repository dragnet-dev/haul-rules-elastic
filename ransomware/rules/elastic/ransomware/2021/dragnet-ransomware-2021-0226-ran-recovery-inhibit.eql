// Dragnet [Ransomware]: dragnet-ransomware-2021-0226 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 81de9cdc-3617-5cd7-8efc-f55643268478

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
