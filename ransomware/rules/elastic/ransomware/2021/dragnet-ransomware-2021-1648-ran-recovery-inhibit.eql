// Dragnet [Ransomware]: dragnet-ransomware-2021-1648 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: 79f1a75d-e459-5bd5-ad75-11730f39707f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
