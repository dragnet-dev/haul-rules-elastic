// Dragnet [Ransomware]: dragnet-ransomware-2021-1417 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 1ab93c8a-ef26-5284-919d-e87c57b55261

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
