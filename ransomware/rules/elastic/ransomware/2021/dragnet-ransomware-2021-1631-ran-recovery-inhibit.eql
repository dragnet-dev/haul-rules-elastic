// Dragnet [Ransomware]: dragnet-ransomware-2021-1631 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: dcb754a9-8108-590b-a48e-dbe6fca2800c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
