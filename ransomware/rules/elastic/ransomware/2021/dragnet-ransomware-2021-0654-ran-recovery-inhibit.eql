// Dragnet [Ransomware]: dragnet-ransomware-2021-0654 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f4d46f84-e927-5fe0-9f0e-97ed079b9b6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
