// Dragnet [Ransomware]: dragnet-ransomware-2021-0107 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: c9309995-c1b2-50d4-b327-a302a48247b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
