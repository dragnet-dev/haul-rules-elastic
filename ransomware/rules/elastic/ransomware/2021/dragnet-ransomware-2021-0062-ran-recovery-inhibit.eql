// Dragnet [Ransomware]: dragnet-ransomware-2021-0062 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 97a902e2-cbd4-5873-bb3e-19e5feffebce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
