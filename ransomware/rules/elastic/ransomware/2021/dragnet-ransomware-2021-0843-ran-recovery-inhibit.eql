// Dragnet [Ransomware]: dragnet-ransomware-2021-0843 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 4f558b36-52a7-5f80-8e21-52092a6b9a8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
