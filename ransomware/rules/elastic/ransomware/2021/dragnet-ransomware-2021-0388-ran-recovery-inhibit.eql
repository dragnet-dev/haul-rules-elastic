// Dragnet [Ransomware]: dragnet-ransomware-2021-0388 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 8b9fe502-9fda-5bb3-bd41-b5f482d8bcbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
