// Dragnet [Ransomware]: dragnet-ransomware-2021-0776 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 113f4f08-3ad4-5317-a8fe-60cf7a6f585b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
