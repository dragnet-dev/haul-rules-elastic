// Dragnet [Ransomware]: dragnet-ransomware-2021-1237 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 407a6ad5-4f2d-548e-8440-0784c65d91b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
