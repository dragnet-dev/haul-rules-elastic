// Dragnet [Ransomware]: dragnet-ransomware-2021-0922 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 0efcc0b8-4328-5c3c-a571-09a64009f810

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
