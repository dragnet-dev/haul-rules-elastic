// Dragnet [Ransomware]: dragnet-ransomware-2021-1356 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e747634d-a20c-5809-ace5-68c96528bb9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
