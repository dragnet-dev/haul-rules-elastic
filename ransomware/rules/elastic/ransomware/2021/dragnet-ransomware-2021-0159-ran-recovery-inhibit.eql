// Dragnet [Ransomware]: dragnet-ransomware-2021-0159 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: d543d573-7658-50c0-a190-81f7b2cf8a78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
