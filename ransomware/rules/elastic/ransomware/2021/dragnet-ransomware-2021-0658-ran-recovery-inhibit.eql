// Dragnet [Ransomware]: dragnet-ransomware-2021-0658 — Recovery Inhibition (groove)
// Status: deprecated | Level: high | ID: 54aa5112-2384-519b-991a-19c9879e481a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
