// Dragnet [Ransomware]: dragnet-ransomware-2021-1257 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: c09b6cd9-a143-5c6c-ba98-798bf6ac247d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
