// Dragnet [Ransomware]: dragnet-ransomware-2021-0651 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 0c37e4e3-9bcb-55e6-9bb0-f7827e696142

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
