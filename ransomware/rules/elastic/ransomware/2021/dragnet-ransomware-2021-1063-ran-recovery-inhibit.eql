// Dragnet [Ransomware]: dragnet-ransomware-2021-1063 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 3d624945-3227-5d9e-bc58-5e74461c36ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
