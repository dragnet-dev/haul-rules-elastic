// Dragnet [Ransomware]: dragnet-ransomware-2021-0046 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 28d78561-3c7f-55ac-9235-4c7881065cad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
