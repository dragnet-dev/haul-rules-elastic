// Dragnet [Ransomware]: dragnet-ransomware-2021-1431 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: e60fe605-c84f-5620-b4f6-3a2d58f889e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
