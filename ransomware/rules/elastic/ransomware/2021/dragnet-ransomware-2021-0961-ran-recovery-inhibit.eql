// Dragnet [Ransomware]: dragnet-ransomware-2021-0961 — Recovery Inhibition (xinglocker)
// Status: deprecated | Level: high | ID: d079ddbe-fc63-584e-a026-3969e0eb7668

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
