// Dragnet [Ransomware]: dragnet-ransomware-2021-0211 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 703eb68a-3412-596f-b202-ae9f75a15e83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
