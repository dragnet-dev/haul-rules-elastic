// Dragnet [Ransomware]: dragnet-ransomware-2021-0298 — Recovery Inhibition (mosesstaff)
// Status: deprecated | Level: high | ID: 0ade7610-766a-5516-be02-5cc5fdc93ac4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
