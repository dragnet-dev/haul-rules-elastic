// Dragnet [Ransomware]: dragnet-ransomware-2021-1235 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 07920c30-26a8-52b3-bbe9-913b1fe5b154

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
