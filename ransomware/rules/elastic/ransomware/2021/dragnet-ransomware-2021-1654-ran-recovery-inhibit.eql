// Dragnet [Ransomware]: dragnet-ransomware-2021-1654 — Recovery Inhibition (sabbath)
// Status: deprecated | Level: high | ID: dc69d584-17d3-520b-a6ab-a40ce21d9ccd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
