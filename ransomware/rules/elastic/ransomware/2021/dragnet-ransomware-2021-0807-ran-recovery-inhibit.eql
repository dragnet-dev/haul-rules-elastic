// Dragnet [Ransomware]: dragnet-ransomware-2021-0807 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 47e50025-427d-5612-b69a-ffbc59c65334

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
