// Dragnet [Ransomware]: dragnet-ransomware-2021-0950 — Recovery Inhibition (sabbath)
// Status: deprecated | Level: high | ID: e278b557-5509-5ec4-a889-21fd54b84650

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
