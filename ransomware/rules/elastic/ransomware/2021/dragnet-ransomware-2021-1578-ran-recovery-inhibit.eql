// Dragnet [Ransomware]: dragnet-ransomware-2021-1578 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 2fbb69d7-6a02-50b9-86d6-9affb788a7a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
