// Dragnet [Ransomware]: dragnet-ransomware-2021-1789 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: d4b4fda1-c03a-5058-826b-286a49ac23ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
