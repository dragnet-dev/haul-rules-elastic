// Dragnet [Ransomware]: dragnet-ransomware-2021-1477 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 1e36f898-2027-5ed2-b66d-f47e8670989c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
