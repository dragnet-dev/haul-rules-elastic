// Dragnet [Ransomware]: dragnet-ransomware-2021-0266 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 2c855b76-0087-5460-a0e7-8850a5b0eccd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
