// Dragnet [Ransomware]: dragnet-ransomware-2021-1150 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 03da71fb-f4d0-59df-94a7-3de1cedd385c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
