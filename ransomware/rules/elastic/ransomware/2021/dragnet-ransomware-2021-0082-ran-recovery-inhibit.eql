// Dragnet [Ransomware]: dragnet-ransomware-2021-0082 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 4bdea789-6830-5870-b781-cf7b9728f0ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
