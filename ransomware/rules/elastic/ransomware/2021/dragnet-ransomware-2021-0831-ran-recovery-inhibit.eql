// Dragnet [Ransomware]: dragnet-ransomware-2021-0831 — Recovery Inhibition (lockdata)
// Status: deprecated | Level: high | ID: 2112cc2b-b875-5e56-bf52-4a83c03cb85b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
