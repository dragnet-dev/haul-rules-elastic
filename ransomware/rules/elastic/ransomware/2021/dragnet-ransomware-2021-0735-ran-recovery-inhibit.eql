// Dragnet [Ransomware]: dragnet-ransomware-2021-0735 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 10f7d21f-a9be-5bf4-8362-66a94dee9728

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
