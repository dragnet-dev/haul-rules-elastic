// Dragnet [Ransomware]: dragnet-ransomware-2021-0391 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 097665e0-9808-5b4d-8e2b-a30722fcc2fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
