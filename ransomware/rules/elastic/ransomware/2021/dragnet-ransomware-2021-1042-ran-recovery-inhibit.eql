// Dragnet [Ransomware]: dragnet-ransomware-2021-1042 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: fafbefe7-682a-5d65-9c55-83154954e902

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
