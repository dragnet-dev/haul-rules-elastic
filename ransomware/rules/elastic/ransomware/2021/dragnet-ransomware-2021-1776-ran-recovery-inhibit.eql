// Dragnet [Ransomware]: dragnet-ransomware-2021-1776 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 9f775ccd-57cb-526d-b2a9-d97463ce5000

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
