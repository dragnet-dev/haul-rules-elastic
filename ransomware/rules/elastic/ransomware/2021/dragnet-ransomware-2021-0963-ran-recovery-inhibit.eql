// Dragnet [Ransomware]: dragnet-ransomware-2021-0963 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a3188bde-a95f-5c2b-ba82-b14ac9db8799

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
