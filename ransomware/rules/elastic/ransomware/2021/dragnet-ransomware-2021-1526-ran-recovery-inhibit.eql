// Dragnet [Ransomware]: dragnet-ransomware-2021-1526 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 699b5618-9eff-5127-a34e-f52ed468de4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
