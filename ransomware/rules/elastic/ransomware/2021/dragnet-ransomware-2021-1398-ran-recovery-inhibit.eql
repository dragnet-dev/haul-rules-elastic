// Dragnet [Ransomware]: dragnet-ransomware-2021-1398 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 2ebe9b90-6375-5ba1-ba51-e1815021e4bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
