// Dragnet [Ransomware]: dragnet-ransomware-2021-0026 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 8ab320da-2bd8-5ad3-9f03-4f0bc31da872

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
