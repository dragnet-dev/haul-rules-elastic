// Dragnet [Ransomware]: dragnet-ransomware-2021-1218 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 979c0695-b120-543d-8687-59eda854c62d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
