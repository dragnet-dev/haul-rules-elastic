// Dragnet [Ransomware]: dragnet-ransomware-2021-0800 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 438106dd-2e7d-5040-b6dc-ea637a11dde2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
