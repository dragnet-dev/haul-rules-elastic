// Dragnet [Ransomware]: dragnet-ransomware-2021-0260 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 11d1529d-abb5-5fa9-96a6-098323e35d4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
