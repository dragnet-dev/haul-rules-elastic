// Dragnet [Ransomware]: dragnet-ransomware-2021-1799 — Recovery Inhibition (grief)
// Status: deprecated | Level: high | ID: 0a29299e-9f5a-55cb-8aa0-1b22a0efab35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
