// Dragnet [Ransomware]: dragnet-ransomware-2021-0975 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 2bc37080-86bc-5d63-8d63-9aa8039939c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
