// Dragnet [Ransomware]: dragnet-ransomware-2021-0689 — Recovery Inhibition (xinglocker)
// Status: deprecated | Level: high | ID: 79a7b6bc-fd60-5175-bec3-c93d1b8f7b8f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
