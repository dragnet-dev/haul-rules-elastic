// Dragnet [Ransomware]: dragnet-ransomware-2021-0600 — Recovery Inhibition (blackshadow)
// Status: deprecated | Level: high | ID: 0c8a0850-7b15-5a1c-9e77-a58f09d10a03

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
