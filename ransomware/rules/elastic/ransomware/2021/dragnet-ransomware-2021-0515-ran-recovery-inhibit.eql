// Dragnet [Ransomware]: dragnet-ransomware-2021-0515 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: b5b26a97-c74f-59a6-ad92-4d8c57485606

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
