// Dragnet [Ransomware]: dragnet-ransomware-2021-1280 — Recovery Inhibition (xinglocker)
// Status: deprecated | Level: high | ID: 48be7c01-2cca-541f-8439-20929cbf9371

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
