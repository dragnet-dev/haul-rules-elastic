// Dragnet [Ransomware]: dragnet-ransomware-2021-0556 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 797cf813-06c3-5d08-9a5d-aba06026530e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
