// Dragnet [Ransomware]: dragnet-ransomware-2021-0539 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: ab1e03c7-7e94-5909-84f5-8a25c6f06d13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
