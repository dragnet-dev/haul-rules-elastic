// Dragnet [Ransomware]: dragnet-ransomware-2021-0754 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 3d8c6f1c-31c1-5898-ae2d-be82ee3420fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
