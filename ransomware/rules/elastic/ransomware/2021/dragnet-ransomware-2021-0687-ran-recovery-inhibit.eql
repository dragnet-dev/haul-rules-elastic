// Dragnet [Ransomware]: dragnet-ransomware-2021-0687 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: e940d6a1-8a1c-5351-8459-0396c74dd451

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
