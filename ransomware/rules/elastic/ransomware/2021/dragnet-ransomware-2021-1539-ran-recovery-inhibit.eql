// Dragnet [Ransomware]: dragnet-ransomware-2021-1539 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 7516d5a3-f4b3-52eb-b65f-d4f308439959

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
