// Dragnet [Ransomware]: dragnet-ransomware-2021-0943 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 6272b879-553f-554b-838a-d715257286a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
