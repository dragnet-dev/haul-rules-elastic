// Dragnet [Ransomware]: dragnet-ransomware-2021-0905 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8bfadaaf-538c-5778-994c-9cf7617900a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
