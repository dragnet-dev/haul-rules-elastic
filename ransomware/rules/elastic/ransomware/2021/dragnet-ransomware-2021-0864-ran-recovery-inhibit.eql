// Dragnet [Ransomware]: dragnet-ransomware-2021-0864 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: e5d4b2dc-edfb-551e-8c50-33ac191240e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
