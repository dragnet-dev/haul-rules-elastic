// Dragnet [Ransomware]: dragnet-ransomware-2021-0178 — Recovery Inhibition (azroteam)
// Status: deprecated | Level: high | ID: 7675ad94-aa19-5fc3-bda1-2cbe6c1fdac9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
