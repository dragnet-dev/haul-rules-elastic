// Dragnet [Ransomware]: dragnet-ransomware-2021-1435 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: e34d1a80-b426-5627-ad22-1c1a80ae46fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
