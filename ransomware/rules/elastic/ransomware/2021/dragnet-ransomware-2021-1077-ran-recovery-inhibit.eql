// Dragnet [Ransomware]: dragnet-ransomware-2021-1077 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 494633dd-14d3-5869-8aa3-4c3281ef1e43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
