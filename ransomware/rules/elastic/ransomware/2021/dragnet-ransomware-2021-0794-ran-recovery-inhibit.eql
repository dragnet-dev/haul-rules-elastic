// Dragnet [Ransomware]: dragnet-ransomware-2021-0794 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 00389639-36c3-53a0-803e-eb67089e5b99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
