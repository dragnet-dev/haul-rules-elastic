// Dragnet [Ransomware]: dragnet-ransomware-2021-1219 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 13822860-1dd9-5814-ae0d-37cbf84ca555

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
