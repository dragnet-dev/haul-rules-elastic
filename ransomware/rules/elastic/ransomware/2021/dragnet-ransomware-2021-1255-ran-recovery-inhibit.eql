// Dragnet [Ransomware]: dragnet-ransomware-2021-1255 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5f37d404-0710-556a-9aab-3b730e8ed6e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
