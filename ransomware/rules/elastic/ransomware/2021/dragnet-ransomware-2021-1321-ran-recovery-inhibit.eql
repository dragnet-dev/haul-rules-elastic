// Dragnet [Ransomware]: dragnet-ransomware-2021-1321 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 0b96291a-f667-5e67-856f-2de117ff72c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
