// Dragnet [Ransomware]: dragnet-ransomware-2021-1123 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 4d1f66a2-1013-55f9-a9e0-c53ff7857e60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
