// Dragnet [Ransomware]: dragnet-ransomware-2021-1395 — Recovery Inhibition (darkside)
// Status: deprecated | Level: high | ID: 8ae0a612-cda7-50d0-b8f2-c575f7e73a38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
