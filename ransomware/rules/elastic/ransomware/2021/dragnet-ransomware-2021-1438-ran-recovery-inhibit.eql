// Dragnet [Ransomware]: dragnet-ransomware-2021-1438 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 3f05674f-a2d8-523f-8fd6-dbb13121275f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
