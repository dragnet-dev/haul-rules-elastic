// Dragnet [Ransomware]: dragnet-ransomware-2021-0933 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 0e6b258c-ff1a-5e10-8458-b2da3e4edbc3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
