// Dragnet [Ransomware]: dragnet-ransomware-2021-0569 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 75ec6509-5238-56a2-a695-7af6b1c50e1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
