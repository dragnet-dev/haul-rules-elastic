// Dragnet [Ransomware]: dragnet-ransomware-2021-1778 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: 1dd41cbb-bc66-5080-b2b6-4db6b099ec1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
