// Dragnet [Ransomware]: dragnet-ransomware-2021-1658 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 3d7569d2-9eb6-5818-b524-697736b7b764

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
