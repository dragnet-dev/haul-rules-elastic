// Dragnet [Ransomware]: dragnet-ransomware-2021-0477 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: a2b6efd7-92c8-535e-8cfd-b9d6420e147a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
