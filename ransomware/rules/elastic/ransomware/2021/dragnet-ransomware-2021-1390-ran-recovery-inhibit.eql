// Dragnet [Ransomware]: dragnet-ransomware-2021-1390 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: fb4acada-c584-5c4c-83b7-511b6fb34329

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
