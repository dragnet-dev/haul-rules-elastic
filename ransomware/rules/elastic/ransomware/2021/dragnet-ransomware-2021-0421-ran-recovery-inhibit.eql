// Dragnet [Ransomware]: dragnet-ransomware-2021-0421 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 89b888d7-76df-5370-a882-fe94a9dcceac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
