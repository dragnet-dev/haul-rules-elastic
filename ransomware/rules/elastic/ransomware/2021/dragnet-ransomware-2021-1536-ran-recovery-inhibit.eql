// Dragnet [Ransomware]: dragnet-ransomware-2021-1536 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 135f828b-3d99-505b-8022-29fa40916e73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
