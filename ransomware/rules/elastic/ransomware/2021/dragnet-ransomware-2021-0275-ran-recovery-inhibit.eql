// Dragnet [Ransomware]: dragnet-ransomware-2021-0275 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: f0aba965-3310-5115-b566-8ca37ada84f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
