// Dragnet [Ransomware]: dragnet-ransomware-2021-1349 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: dedb2b1e-7440-5c43-8a6f-99bcd141e566

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
