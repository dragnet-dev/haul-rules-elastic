// Dragnet [Ransomware]: dragnet-ransomware-2021-0064 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 03b37fc9-f349-50ef-87eb-8ac4a071206f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
