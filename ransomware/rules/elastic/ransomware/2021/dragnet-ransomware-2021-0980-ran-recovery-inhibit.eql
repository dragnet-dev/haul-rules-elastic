// Dragnet [Ransomware]: dragnet-ransomware-2021-0980 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 4a9a69c4-9e17-5a14-bb10-610ab4445053

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
