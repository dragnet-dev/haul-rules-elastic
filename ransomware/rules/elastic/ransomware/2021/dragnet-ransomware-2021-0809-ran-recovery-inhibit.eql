// Dragnet [Ransomware]: dragnet-ransomware-2021-0809 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: 61001976-5e6b-5f09-b382-bd675d475c82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
