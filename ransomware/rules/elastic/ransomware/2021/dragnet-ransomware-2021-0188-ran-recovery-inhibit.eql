// Dragnet [Ransomware]: dragnet-ransomware-2021-0188 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 5430b1cb-f14d-5606-af75-100b47019da4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
