// Dragnet [Ransomware]: dragnet-ransomware-2021-1567 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 21d04033-d3a6-56b0-bee3-e86e9cc2b497

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
