// Dragnet [Ransomware]: dragnet-ransomware-2021-0838 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: 5b19a702-8821-5045-8de0-4f2a8afcbf4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
