// Dragnet [Ransomware]: dragnet-ransomware-2021-0393 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: c40fd7cd-961d-55d7-869f-f2e088b090cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
