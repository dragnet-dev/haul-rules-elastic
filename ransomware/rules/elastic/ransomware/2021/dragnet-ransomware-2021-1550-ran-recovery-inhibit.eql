// Dragnet [Ransomware]: dragnet-ransomware-2021-1550 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: b60c8e92-8ed7-5c70-8b78-6bc153c6740a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
