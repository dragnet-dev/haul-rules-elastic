// Dragnet [Ransomware]: dragnet-ransomware-2021-0296 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a38ddec2-7ab8-5d0c-9de6-e09e4a6181d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
