// Dragnet [Ransomware]: dragnet-ransomware-2021-0690 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: deb419fe-58a0-5399-ac2d-38b0ff601962

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
