// Dragnet [Ransomware]: dragnet-ransomware-2021-0728 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 0fc44ec3-0238-5483-9e76-eea3cedfa4ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
