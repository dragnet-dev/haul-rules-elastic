// Dragnet [Ransomware]: dragnet-ransomware-2021-1351 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 212ffa9a-222d-591f-8f3d-014592e26ca6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
