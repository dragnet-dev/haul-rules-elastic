// Dragnet [Ransomware]: dragnet-ransomware-2021-0819 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 2c88e148-b16a-563d-80b8-d1fdabe86196

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
