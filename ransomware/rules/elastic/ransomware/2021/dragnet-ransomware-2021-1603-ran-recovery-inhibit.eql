// Dragnet [Ransomware]: dragnet-ransomware-2021-1603 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 1c495dde-eb87-5561-8873-ed4b58dce1a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
