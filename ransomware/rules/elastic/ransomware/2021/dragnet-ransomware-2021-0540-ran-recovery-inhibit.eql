// Dragnet [Ransomware]: dragnet-ransomware-2021-0540 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: db8cb96c-c88c-58ec-8a25-162f048a76f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
