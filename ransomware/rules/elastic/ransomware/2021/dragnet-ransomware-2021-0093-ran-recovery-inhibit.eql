// Dragnet [Ransomware]: dragnet-ransomware-2021-0093 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: d8dfeb05-14d2-53a1-8f6c-d398fe7956ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
