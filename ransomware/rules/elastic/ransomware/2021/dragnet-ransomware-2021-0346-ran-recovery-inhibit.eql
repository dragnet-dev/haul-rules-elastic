// Dragnet [Ransomware]: dragnet-ransomware-2021-0346 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 97a13d5f-72bb-524c-bd95-440d4a07b38c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
