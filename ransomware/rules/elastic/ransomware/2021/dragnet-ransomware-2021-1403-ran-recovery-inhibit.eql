// Dragnet [Ransomware]: dragnet-ransomware-2021-1403 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 4b2da309-e971-53ce-8076-7a62751ae0e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
