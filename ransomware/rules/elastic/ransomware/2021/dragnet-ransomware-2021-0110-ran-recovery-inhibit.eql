// Dragnet [Ransomware]: dragnet-ransomware-2021-0110 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: fd0582c1-1d36-549c-abe5-2968c06a7af5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
