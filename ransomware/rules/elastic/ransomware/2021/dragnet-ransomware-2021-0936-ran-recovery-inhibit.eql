// Dragnet [Ransomware]: dragnet-ransomware-2021-0936 — Recovery Inhibition (payloadbin)
// Status: deprecated | Level: high | ID: 59775c63-214f-5895-8e23-cc80bf0a5115

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
