// Dragnet [Ransomware]: dragnet-ransomware-2021-0937 — Recovery Inhibition (payloadbin)
// Status: deprecated | Level: high | ID: 2f93546f-8d55-563d-9614-4d71f72c9ad9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
