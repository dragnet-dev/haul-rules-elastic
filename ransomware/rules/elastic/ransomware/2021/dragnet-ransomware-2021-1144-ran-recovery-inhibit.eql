// Dragnet [Ransomware]: dragnet-ransomware-2021-1144 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 79312da5-6741-566a-995b-369ef368f897

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
