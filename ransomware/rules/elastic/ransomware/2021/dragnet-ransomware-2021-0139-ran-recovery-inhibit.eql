// Dragnet [Ransomware]: dragnet-ransomware-2021-0139 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: d55d8c13-af83-5ef7-915f-513f06c0ca70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
