// Dragnet [Ransomware]: dragnet-ransomware-2021-0375 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 6b658b0e-d082-565c-ab6a-d40b57770a3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
