// Dragnet [Ransomware]: dragnet-ransomware-2021-1350 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: a1e9d0ff-6f27-582b-b289-6df525358a53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
