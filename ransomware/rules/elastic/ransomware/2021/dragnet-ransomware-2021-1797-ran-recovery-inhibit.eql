// Dragnet [Ransomware]: dragnet-ransomware-2021-1797 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: f82a113c-225c-5cf0-a492-52ca88675fa4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
