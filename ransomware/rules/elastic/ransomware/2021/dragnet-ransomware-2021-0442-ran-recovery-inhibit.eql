// Dragnet [Ransomware]: dragnet-ransomware-2021-0442 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6b10c95a-288b-55df-affd-6473f5f8ec6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
