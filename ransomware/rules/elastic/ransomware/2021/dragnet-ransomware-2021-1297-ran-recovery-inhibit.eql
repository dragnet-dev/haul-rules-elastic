// Dragnet [Ransomware]: dragnet-ransomware-2021-1297 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 9f98c867-df24-53eb-9002-b905b13cab3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
