// Dragnet [Ransomware]: dragnet-ransomware-2021-0619 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 30c98951-8e95-5c04-83b8-a2f97e248ffb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
