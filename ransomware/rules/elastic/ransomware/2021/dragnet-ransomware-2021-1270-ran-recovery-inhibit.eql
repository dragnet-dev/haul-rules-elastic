// Dragnet [Ransomware]: dragnet-ransomware-2021-1270 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 16cf8db8-1b72-5a96-8d11-073d871d93d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
