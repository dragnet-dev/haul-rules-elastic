// Dragnet [Ransomware]: dragnet-ransomware-2021-0867 — Recovery Inhibition (cryp70n1c0d3)
// Status: deprecated | Level: high | ID: f6782bbb-c02d-5dc0-8660-0380e5e46c1f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
