// Dragnet [Ransomware]: dragnet-ransomware-2021-1156 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 85980934-2bb0-557a-a8e5-ef03a96d24a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
