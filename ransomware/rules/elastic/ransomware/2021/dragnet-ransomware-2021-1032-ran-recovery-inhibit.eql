// Dragnet [Ransomware]: dragnet-ransomware-2021-1032 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: bc19a76c-f872-5a0d-befe-afe1517741ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
