// Dragnet [Ransomware]: dragnet-ransomware-2021-0505 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 2aeda770-423b-5864-991c-31f86a0f11dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
