// Dragnet [Ransomware]: dragnet-ransomware-2021-0645 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: e13ba912-58b7-5606-8076-64f2f94bbf47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
