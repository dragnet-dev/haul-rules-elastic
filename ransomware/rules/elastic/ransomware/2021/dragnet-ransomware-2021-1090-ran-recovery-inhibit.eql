// Dragnet [Ransomware]: dragnet-ransomware-2021-1090 — Recovery Inhibition (xinglocker)
// Status: deprecated | Level: high | ID: cf78b72c-f1ea-5df7-bb2f-6e5e55198ffc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
