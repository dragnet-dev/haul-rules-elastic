// Dragnet [Ransomware]: dragnet-ransomware-2021-1054 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 501dd4ba-47c4-5b41-b71b-e9af758ee30e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
