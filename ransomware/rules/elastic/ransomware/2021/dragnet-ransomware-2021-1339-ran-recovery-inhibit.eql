// Dragnet [Ransomware]: dragnet-ransomware-2021-1339 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 2c06b4d2-5bd7-5bc1-8953-2a62b8e2243c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
