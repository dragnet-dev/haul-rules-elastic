// Dragnet [Ransomware]: dragnet-ransomware-2021-0562 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 54322313-aee9-5e2c-a341-7d375c514798

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
