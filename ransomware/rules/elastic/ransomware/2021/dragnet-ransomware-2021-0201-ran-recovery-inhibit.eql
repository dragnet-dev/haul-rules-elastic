// Dragnet [Ransomware]: dragnet-ransomware-2021-0201 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: 664d280b-35ed-5d2d-b473-b4a94453b131

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
