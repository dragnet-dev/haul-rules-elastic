// Dragnet [Ransomware]: dragnet-ransomware-2021-0227 — Recovery Inhibition (xinglocker)
// Status: deprecated | Level: high | ID: 8c2d98d9-81a1-50e3-b339-a5e240ec28d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
