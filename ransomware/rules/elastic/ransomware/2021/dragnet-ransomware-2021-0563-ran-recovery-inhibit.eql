// Dragnet [Ransomware]: dragnet-ransomware-2021-0563 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: e358c14f-0c55-57bf-8d7d-2e75cdcabaf2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
