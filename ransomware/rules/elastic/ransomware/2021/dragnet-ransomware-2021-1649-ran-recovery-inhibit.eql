// Dragnet [Ransomware]: dragnet-ransomware-2021-1649 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ae907266-4b11-56d8-9ffd-20bed48f9b6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
