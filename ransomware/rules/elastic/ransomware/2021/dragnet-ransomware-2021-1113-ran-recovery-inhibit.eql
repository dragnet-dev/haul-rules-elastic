// Dragnet [Ransomware]: dragnet-ransomware-2021-1113 — Recovery Inhibition (doppelpaymer)
// Status: deprecated | Level: high | ID: 965eae8a-8b79-50cc-b2f4-67fbbf284b53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
