// Dragnet [Ransomware]: dragnet-ransomware-2021-0263 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 2366e316-7d43-5363-b87b-bba348251c94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
