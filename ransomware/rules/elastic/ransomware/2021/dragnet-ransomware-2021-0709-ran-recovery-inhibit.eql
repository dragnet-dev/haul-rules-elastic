// Dragnet [Ransomware]: dragnet-ransomware-2021-0709 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: ac8ccd66-7857-53dd-82b5-f469fd4b72f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
