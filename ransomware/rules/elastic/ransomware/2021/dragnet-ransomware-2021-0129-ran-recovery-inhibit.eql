// Dragnet [Ransomware]: dragnet-ransomware-2021-0129 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: f81488b4-dad5-5943-9e9d-31171d26f88a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
