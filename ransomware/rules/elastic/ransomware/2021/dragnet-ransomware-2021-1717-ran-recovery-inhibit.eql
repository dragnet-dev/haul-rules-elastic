// Dragnet [Ransomware]: dragnet-ransomware-2021-1717 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 47d97435-0d00-583b-a30c-77f05e4a73be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
