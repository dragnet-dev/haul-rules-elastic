// Dragnet [Ransomware]: dragnet-ransomware-2021-1141 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: d288839c-886f-55b1-92b5-2ed44218dee6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
