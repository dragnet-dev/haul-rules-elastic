// Dragnet [Ransomware]: dragnet-ransomware-2021-0839 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 838e8641-a0c9-5b2b-97b2-b61a1428a5e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
