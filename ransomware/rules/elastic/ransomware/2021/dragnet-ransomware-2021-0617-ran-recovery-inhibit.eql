// Dragnet [Ransomware]: dragnet-ransomware-2021-0617 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: bc2a6842-03ac-5e0b-bb35-eb401e4e1214

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
