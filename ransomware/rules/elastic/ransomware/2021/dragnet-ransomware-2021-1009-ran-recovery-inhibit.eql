// Dragnet [Ransomware]: dragnet-ransomware-2021-1009 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: bbd14323-5007-5d60-b1bc-a838e159ce7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
