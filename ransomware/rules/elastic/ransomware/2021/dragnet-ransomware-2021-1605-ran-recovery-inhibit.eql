// Dragnet [Ransomware]: dragnet-ransomware-2021-1605 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: ed02ef07-da94-527d-ace0-b3a142b86d9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
