// Dragnet [Ransomware]: dragnet-ransomware-2021-1508 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 19063750-1bc6-54f2-bcad-c07e821c5615

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
