// Dragnet [Ransomware]: dragnet-ransomware-2021-1131 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 05e03a70-210b-5841-b768-5f2ab52eaf71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
