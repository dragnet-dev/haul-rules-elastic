// Dragnet [Ransomware]: dragnet-ransomware-2021-1675 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b32501b9-7a6e-5db8-9b06-1a44a3087e86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
