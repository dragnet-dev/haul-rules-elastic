// Dragnet [Ransomware]: dragnet-ransomware-2021-1807 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 464631c2-2fd0-5a85-b1b9-e4f5e8180936

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
