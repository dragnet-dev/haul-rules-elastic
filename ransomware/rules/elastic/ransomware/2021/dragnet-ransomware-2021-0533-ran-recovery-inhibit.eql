// Dragnet [Ransomware]: dragnet-ransomware-2021-0533 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: fac68943-de0c-5d55-bbf9-bcb4c957567a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
