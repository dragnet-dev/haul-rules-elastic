// Dragnet [Ransomware]: dragnet-ransomware-2021-1419 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: cc408409-9087-594a-9cdf-fab001630bf1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
