// Dragnet [Ransomware]: dragnet-ransomware-2021-0076 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 800293a2-407e-55d5-8bdc-755ef2631e50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
