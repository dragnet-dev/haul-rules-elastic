// Dragnet [Ransomware]: dragnet-ransomware-2021-1465 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: eb18717a-66ac-504e-afd1-451c65a9eaa8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
