// Dragnet [Ransomware]: dragnet-ransomware-2021-0901 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 54aececc-c7d6-55b5-a683-e0cdf95da5d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
