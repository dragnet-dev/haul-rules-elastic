// Dragnet [Ransomware]: dragnet-ransomware-2021-0017 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: f21b805c-c4e9-51a9-adf0-a9f0be5a49d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
