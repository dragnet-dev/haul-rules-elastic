// Dragnet [Ransomware]: dragnet-ransomware-2021-0934 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 0d570456-2c7c-5e94-8fce-4697e2089c47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
