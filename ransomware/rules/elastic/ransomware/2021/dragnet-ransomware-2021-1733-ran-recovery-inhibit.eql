// Dragnet [Ransomware]: dragnet-ransomware-2021-1733 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: 0e63020e-ea89-58f8-b66e-c553ef8421ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
