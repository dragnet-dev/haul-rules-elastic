// Dragnet [Ransomware]: dragnet-ransomware-2021-0131 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 88436920-65e5-5555-b82e-039bbe58e069

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
