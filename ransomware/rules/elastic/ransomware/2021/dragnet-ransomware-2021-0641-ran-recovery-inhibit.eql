// Dragnet [Ransomware]: dragnet-ransomware-2021-0641 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: c7e4d2b7-2c27-56f1-9c0a-1216762e4bdc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
