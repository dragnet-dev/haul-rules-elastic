// Dragnet [Ransomware]: dragnet-ransomware-2021-1244 — Recovery Inhibition (cryp70n1c0d3)
// Status: deprecated | Level: high | ID: 3b1ad8a4-e3a2-559b-b06f-5ae443353d5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
