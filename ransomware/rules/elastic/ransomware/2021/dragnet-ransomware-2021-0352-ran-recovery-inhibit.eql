// Dragnet [Ransomware]: dragnet-ransomware-2021-0352 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 54594f87-293f-5df6-9ac6-26a33df40567

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
