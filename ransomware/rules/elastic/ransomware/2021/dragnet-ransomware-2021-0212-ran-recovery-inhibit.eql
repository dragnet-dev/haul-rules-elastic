// Dragnet [Ransomware]: dragnet-ransomware-2021-0212 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: cb36b9fd-5afe-55d1-a287-c7ed704b4802

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
