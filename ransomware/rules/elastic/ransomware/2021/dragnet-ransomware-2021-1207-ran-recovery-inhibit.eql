// Dragnet [Ransomware]: dragnet-ransomware-2021-1207 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 1064868d-ad78-5725-ab94-590530a0a412

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
