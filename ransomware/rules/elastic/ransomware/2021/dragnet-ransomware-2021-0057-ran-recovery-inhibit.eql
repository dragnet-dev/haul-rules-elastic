// Dragnet [Ransomware]: dragnet-ransomware-2021-0057 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a01169c2-3034-5b8c-9918-c102a268aa1f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
