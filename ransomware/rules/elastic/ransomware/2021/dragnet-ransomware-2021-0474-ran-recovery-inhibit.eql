// Dragnet [Ransomware]: dragnet-ransomware-2021-0474 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 67c3f415-8c22-5752-9de5-60d35f76673a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
