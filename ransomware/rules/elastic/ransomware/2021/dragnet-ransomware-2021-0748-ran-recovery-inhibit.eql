// Dragnet [Ransomware]: dragnet-ransomware-2021-0748 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 1f3f2b6a-4d06-5005-85e1-7be9eb897a47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
