// Dragnet [Ransomware]: dragnet-ransomware-2021-0676 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 56a4c98f-5eec-526c-bbd3-d54206840b48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
