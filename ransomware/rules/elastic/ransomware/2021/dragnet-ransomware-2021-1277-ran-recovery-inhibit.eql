// Dragnet [Ransomware]: dragnet-ransomware-2021-1277 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: a700d7b1-92ec-5d62-969b-763e5adfbc61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
