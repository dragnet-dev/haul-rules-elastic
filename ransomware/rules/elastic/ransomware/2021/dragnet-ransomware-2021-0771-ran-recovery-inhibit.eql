// Dragnet [Ransomware]: dragnet-ransomware-2021-0771 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: aa562270-5fff-59cd-a28f-33dc4c554a23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
