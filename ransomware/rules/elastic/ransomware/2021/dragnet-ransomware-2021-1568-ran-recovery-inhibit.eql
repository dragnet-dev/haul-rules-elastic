// Dragnet [Ransomware]: dragnet-ransomware-2021-1568 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4d63c252-f48c-5bd2-bfcd-ccfcca6da695

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
