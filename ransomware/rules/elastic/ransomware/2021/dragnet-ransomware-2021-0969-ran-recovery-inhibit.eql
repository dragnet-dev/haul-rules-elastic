// Dragnet [Ransomware]: dragnet-ransomware-2021-0969 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 67eb417f-8b10-51c6-9a85-0879680cf3bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
