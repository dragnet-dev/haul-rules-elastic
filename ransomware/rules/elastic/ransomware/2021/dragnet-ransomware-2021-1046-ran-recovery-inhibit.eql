// Dragnet [Ransomware]: dragnet-ransomware-2021-1046 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: df213ec0-015f-5c98-acb3-e6a4af86dd14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
