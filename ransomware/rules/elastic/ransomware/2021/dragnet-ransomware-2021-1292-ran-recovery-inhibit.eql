// Dragnet [Ransomware]: dragnet-ransomware-2021-1292 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: aba954de-30b6-5e0e-b59d-d0897f5a6a7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
