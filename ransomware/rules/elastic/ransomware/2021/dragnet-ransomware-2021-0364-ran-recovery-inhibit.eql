// Dragnet [Ransomware]: dragnet-ransomware-2021-0364 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 1e8deb16-f975-53b7-9a6e-247d8b473290

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
