// Dragnet [Ransomware]: dragnet-ransomware-2021-0923 — Recovery Inhibition (nefilim)
// Status: deprecated | Level: high | ID: 1716b0f8-5505-53e3-abce-46a5ee3115b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
