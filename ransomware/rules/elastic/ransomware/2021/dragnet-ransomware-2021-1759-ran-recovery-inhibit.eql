// Dragnet [Ransomware]: dragnet-ransomware-2021-1759 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 4181494e-5c8e-5254-a223-cee853976ff1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
