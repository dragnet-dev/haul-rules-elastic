// Dragnet [Ransomware]: dragnet-ransomware-2021-1226 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6796c273-2818-5a45-a4ae-1ffd80ad9fc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
