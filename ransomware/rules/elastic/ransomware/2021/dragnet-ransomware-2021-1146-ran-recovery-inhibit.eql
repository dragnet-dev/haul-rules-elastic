// Dragnet [Ransomware]: dragnet-ransomware-2021-1146 — Recovery Inhibition (mountlocker)
// Status: deprecated | Level: high | ID: be44cc9d-c73b-554f-bcb2-fc554b31fce9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
