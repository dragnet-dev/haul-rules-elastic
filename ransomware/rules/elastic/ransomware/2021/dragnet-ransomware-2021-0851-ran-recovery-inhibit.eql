// Dragnet [Ransomware]: dragnet-ransomware-2021-0851 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: 02670224-9f64-5c75-9ce2-647713302c68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
