// Dragnet [Ransomware]: dragnet-ransomware-2021-0607 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 7a2bcfc1-3a29-5381-a269-78e280c5f2eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
