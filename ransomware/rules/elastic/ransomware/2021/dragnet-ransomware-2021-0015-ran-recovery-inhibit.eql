// Dragnet [Ransomware]: dragnet-ransomware-2021-0015 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 3c18a80f-8aa6-5886-9412-bf1b7b0b2e31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
