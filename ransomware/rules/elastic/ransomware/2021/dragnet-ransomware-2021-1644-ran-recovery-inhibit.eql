// Dragnet [Ransomware]: dragnet-ransomware-2021-1644 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: f89125df-ff22-5d4e-8cc8-e87feaf9984e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
