// Dragnet [Ransomware]: dragnet-ransomware-2021-0396 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: c1319af8-0b4e-56d0-a91a-9fe7041acb0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
