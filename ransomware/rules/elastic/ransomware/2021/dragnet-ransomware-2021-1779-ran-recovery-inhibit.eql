// Dragnet [Ransomware]: dragnet-ransomware-2021-1779 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 1bbd3c5d-e97a-57e8-b5dd-24ed757d7fe4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
