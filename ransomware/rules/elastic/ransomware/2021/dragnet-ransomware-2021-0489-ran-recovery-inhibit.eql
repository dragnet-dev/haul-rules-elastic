// Dragnet [Ransomware]: dragnet-ransomware-2021-0489 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: b3f73bf8-a05a-5413-bb8a-833d20749e89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
