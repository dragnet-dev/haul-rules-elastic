// Dragnet [Ransomware]: dragnet-ransomware-2021-0366 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 508c98ce-ec8d-5316-9a46-fa70cd368879

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
