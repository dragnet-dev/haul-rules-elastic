// Dragnet [Ransomware]: dragnet-ransomware-2021-0821 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 641b7104-7119-5c1b-92f9-61980c619431

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
