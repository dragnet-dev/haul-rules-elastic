// Dragnet [Ransomware]: dragnet-ransomware-2021-0777 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e4161ced-f4fc-5157-9b34-2ba98332e68e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
