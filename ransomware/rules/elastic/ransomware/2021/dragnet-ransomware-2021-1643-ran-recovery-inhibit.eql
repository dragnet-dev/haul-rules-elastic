// Dragnet [Ransomware]: dragnet-ransomware-2021-1643 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: e0a86221-59df-5859-8860-d10e6a2ee9e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
