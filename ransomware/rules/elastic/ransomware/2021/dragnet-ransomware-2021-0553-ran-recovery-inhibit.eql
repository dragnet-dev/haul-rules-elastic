// Dragnet [Ransomware]: dragnet-ransomware-2021-0553 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 877c17d3-12fb-5a89-8cf8-5094c84cd7ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
