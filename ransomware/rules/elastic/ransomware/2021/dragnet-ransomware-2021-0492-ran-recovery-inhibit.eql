// Dragnet [Ransomware]: dragnet-ransomware-2021-0492 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 324e45e4-e4db-5944-95a0-46cdf220fd2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
