// Dragnet [Ransomware]: dragnet-ransomware-2021-1543 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: d3b53299-eeb2-546c-bace-1ab28b26536d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
