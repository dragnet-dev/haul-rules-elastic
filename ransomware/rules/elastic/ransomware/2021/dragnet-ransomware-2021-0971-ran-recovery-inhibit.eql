// Dragnet [Ransomware]: dragnet-ransomware-2021-0971 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 8e4d2d62-30e7-5fc7-865f-6bc58d6110ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
