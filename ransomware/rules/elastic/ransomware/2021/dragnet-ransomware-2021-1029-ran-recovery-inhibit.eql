// Dragnet [Ransomware]: dragnet-ransomware-2021-1029 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: cb3a66ab-db24-546d-a0aa-86dd839de6d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
