// Dragnet [Ransomware]: dragnet-ransomware-2021-0892 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 11e88f44-8a8a-5f3a-9523-51fd121f60ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
