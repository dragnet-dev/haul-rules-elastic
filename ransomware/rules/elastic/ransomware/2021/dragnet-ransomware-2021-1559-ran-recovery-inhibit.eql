// Dragnet [Ransomware]: dragnet-ransomware-2021-1559 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 52e93d3e-b933-5ebc-8a9a-2ab9d5771bc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
