// Dragnet [Ransomware]: dragnet-ransomware-2021-0744 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: f4e8b9d1-ac80-5c2b-8b4b-6f41c7441229

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
