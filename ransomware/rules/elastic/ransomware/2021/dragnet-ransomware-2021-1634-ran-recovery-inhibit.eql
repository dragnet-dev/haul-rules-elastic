// Dragnet [Ransomware]: dragnet-ransomware-2021-1634 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: c2606fcf-7aa5-5d3d-9594-e2d58c5c3084

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
