// Dragnet [Ransomware]: dragnet-ransomware-2021-1229 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: b4a45199-eaae-5495-8012-4588c4a53b5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
