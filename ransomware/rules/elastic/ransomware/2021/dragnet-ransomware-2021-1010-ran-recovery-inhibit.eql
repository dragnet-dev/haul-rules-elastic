// Dragnet [Ransomware]: dragnet-ransomware-2021-1010 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 274ded31-b469-5555-8ab0-b4bf9471059b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
