// Dragnet [Ransomware]: dragnet-ransomware-2021-0048 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 32414202-3bee-5e57-995f-dbb3b2702e13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
