// Dragnet [Ransomware]: dragnet-ransomware-2021-1467 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 5eee8bd8-a84b-51bf-bc22-b0992999bad2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
