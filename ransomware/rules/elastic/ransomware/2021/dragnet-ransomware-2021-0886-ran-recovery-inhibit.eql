// Dragnet [Ransomware]: dragnet-ransomware-2021-0886 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: 94454e96-cbd4-562f-8310-d893c56b8c92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
