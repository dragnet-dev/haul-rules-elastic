// Dragnet [Ransomware]: dragnet-ransomware-2021-0252 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 60cc21a4-13ac-58ff-ac75-f7270abc767a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
