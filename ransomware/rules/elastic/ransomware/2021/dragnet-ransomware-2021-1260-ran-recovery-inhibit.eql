// Dragnet [Ransomware]: dragnet-ransomware-2021-1260 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b329d428-309b-5c5a-9644-d54a09365d79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
