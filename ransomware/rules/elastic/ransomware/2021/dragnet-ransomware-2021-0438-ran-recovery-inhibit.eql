// Dragnet [Ransomware]: dragnet-ransomware-2021-0438 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 359a22ea-e825-535e-a57d-c014306e2de1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
