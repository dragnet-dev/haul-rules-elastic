// Dragnet [Ransomware]: dragnet-ransomware-2021-1153 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: 3c0267f5-da42-5130-b56b-22d80f1d0fc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
