// Dragnet [Ransomware]: dragnet-ransomware-2021-0452 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: c43cfd99-da4f-5e5d-923e-9367d74ad457

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
