// Dragnet [Ransomware]: dragnet-ransomware-2021-1470 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: c24b82e3-5bb0-52ff-8537-58f4b89d99f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
