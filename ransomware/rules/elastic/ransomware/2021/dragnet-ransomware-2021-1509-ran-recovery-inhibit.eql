// Dragnet [Ransomware]: dragnet-ransomware-2021-1509 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 6ffcb480-98c8-5774-a7fe-b6a94d48d87b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
