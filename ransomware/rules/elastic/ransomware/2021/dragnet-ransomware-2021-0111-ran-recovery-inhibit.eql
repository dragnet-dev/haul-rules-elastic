// Dragnet [Ransomware]: dragnet-ransomware-2021-0111 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: fcc070c3-d6e5-5fa6-8e8b-ce88ea0143c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
