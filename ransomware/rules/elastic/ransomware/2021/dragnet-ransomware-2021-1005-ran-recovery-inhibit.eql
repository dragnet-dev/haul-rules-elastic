// Dragnet [Ransomware]: dragnet-ransomware-2021-1005 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 3bef0012-0b29-53da-8f16-aee2a5842a3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
