// Dragnet [Ransomware]: dragnet-ransomware-2021-1194 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5779b8ed-2705-5875-94de-2c8f272184ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
