// Dragnet [Ransomware]: dragnet-ransomware-2021-1468 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 4fac1132-717b-540a-996a-8bf80729eff0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
