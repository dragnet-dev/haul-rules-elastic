// Dragnet [Ransomware]: dragnet-ransomware-2021-0325 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 3999d141-2c75-5c9e-b75b-bdaefbc09067

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
