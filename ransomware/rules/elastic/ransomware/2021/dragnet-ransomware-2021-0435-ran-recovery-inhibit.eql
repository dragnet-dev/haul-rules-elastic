// Dragnet [Ransomware]: dragnet-ransomware-2021-0435 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 2453af3d-c4b3-52b7-aed7-457c5158b1fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
