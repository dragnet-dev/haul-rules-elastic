// Dragnet [Ransomware]: dragnet-ransomware-2021-0035 — Recovery Inhibition (bonacigroup)
// Status: deprecated | Level: high | ID: c03edc88-1a4f-56d6-8f86-eaeb95e03848

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
