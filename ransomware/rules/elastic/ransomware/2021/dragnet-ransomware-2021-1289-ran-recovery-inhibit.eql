// Dragnet [Ransomware]: dragnet-ransomware-2021-1289 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a74f6afd-0bd9-5c05-aafa-a38845ca86b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
