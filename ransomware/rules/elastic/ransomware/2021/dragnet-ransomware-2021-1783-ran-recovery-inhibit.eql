// Dragnet [Ransomware]: dragnet-ransomware-2021-1783 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: c3870d2c-fe58-555c-a545-819340732b00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
