// Dragnet [Ransomware]: dragnet-ransomware-2021-0693 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 436b80c1-f64a-52d4-ba69-ad7ce00e7d27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
