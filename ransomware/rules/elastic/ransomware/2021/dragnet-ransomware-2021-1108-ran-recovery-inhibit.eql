// Dragnet [Ransomware]: dragnet-ransomware-2021-1108 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: e11744b4-c899-57df-b8a2-09232e9048b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
