// Dragnet [Ransomware]: dragnet-ransomware-2021-0707 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: 9607e4f5-0b70-5f82-aedb-0e448e5d2545

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
