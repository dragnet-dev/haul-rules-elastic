// Dragnet [Ransomware]: dragnet-ransomware-2021-1397 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: c8608c5d-b62a-5b97-a5da-c3b122b18f8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
