// Dragnet [Ransomware]: dragnet-ransomware-2021-0020 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 54d2b346-5659-5884-b0eb-7e13e3e0044d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
