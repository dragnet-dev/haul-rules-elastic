// Dragnet [Ransomware]: dragnet-ransomware-2021-0566 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: f6ab393a-81c6-5574-9447-2388e9cd94ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
