// Dragnet [Ransomware]: dragnet-ransomware-2021-0283 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5e37955c-1fc3-5f59-a436-bea5aae68ff3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
