// Dragnet [Ransomware]: dragnet-ransomware-2021-1624 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 78288114-1874-5532-96fb-5d3731a56f88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
