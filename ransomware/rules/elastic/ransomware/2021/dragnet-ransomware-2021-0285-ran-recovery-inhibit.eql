// Dragnet [Ransomware]: dragnet-ransomware-2021-0285 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: ec422bed-e532-5e96-9231-d94563cc4dee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
