// Dragnet [Ransomware]: dragnet-ransomware-2021-0080 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c21fff3f-03df-5ecf-962b-dd7e8a06187a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
