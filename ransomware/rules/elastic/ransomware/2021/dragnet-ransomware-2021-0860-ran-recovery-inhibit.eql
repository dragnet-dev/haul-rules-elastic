// Dragnet [Ransomware]: dragnet-ransomware-2021-0860 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c5ed51a2-d7b3-52cd-8510-342400dd1da0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
