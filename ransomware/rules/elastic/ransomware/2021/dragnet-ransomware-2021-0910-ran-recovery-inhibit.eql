// Dragnet [Ransomware]: dragnet-ransomware-2021-0910 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 045a3543-a99d-524f-9034-12a8eac8ac1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
