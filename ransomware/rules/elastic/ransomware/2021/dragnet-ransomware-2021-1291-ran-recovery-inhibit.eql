// Dragnet [Ransomware]: dragnet-ransomware-2021-1291 — Recovery Inhibition (mountlocker)
// Status: deprecated | Level: high | ID: ed6df684-fd75-5417-ab63-54fc3593edbd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
