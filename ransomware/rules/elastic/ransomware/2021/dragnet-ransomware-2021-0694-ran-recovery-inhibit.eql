// Dragnet [Ransomware]: dragnet-ransomware-2021-0694 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 771e5de7-c2b1-545a-b369-1be548e62825

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
