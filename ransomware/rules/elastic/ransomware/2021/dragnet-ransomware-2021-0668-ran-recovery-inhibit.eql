// Dragnet [Ransomware]: dragnet-ransomware-2021-0668 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b1d30580-6daa-5c33-bb02-82d726c80d82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
