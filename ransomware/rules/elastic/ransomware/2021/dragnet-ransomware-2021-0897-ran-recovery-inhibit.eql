// Dragnet [Ransomware]: dragnet-ransomware-2021-0897 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 5e12ee47-8f22-5071-9315-48e48e0d62cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
