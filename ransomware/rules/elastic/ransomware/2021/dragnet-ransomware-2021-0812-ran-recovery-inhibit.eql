// Dragnet [Ransomware]: dragnet-ransomware-2021-0812 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 5bb36f88-df0d-5101-a966-f5cf38312491

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
