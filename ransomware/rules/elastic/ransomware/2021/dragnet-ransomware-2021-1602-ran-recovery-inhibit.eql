// Dragnet [Ransomware]: dragnet-ransomware-2021-1602 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: dec17525-a76f-5c53-98fd-6ee82164f11d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
