// Dragnet [Ransomware]: dragnet-ransomware-2021-0272 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 01929c71-f725-51e4-b548-e429ece67c85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
