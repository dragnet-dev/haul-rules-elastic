// Dragnet [Ransomware]: dragnet-ransomware-2021-0575 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: b4f59dfa-f883-579b-9f88-b6bcd65b9b83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
