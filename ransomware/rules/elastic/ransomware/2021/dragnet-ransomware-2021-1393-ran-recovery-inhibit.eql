// Dragnet [Ransomware]: dragnet-ransomware-2021-1393 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 49aba101-fbda-528b-bd2c-ecfae997d9a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
