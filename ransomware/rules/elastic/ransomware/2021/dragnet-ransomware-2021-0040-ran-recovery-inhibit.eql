// Dragnet [Ransomware]: dragnet-ransomware-2021-0040 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: d0c66e18-d536-5bef-9c01-931699a5dcf9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
