// Dragnet [Ransomware]: dragnet-ransomware-2021-0065 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 70f1a305-971e-571d-8694-2d39248741e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
