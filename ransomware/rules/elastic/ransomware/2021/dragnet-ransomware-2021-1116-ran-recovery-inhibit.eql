// Dragnet [Ransomware]: dragnet-ransomware-2021-1116 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: be64e329-ea22-5e08-ab52-5526e913531a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
