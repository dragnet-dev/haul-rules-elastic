// Dragnet [Ransomware]: dragnet-ransomware-2021-0001 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: efc1f543-7a81-5b95-95f9-df3c82989613

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
