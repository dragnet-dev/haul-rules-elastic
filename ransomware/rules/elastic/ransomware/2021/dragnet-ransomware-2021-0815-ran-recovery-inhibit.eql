// Dragnet [Ransomware]: dragnet-ransomware-2021-0815 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: 1b0ea4f1-1195-5806-b6dc-ba94cb30ca58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
