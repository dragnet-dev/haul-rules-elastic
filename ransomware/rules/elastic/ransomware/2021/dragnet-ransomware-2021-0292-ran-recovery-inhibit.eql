// Dragnet [Ransomware]: dragnet-ransomware-2021-0292 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: cafa039a-e9a6-52de-b0b2-596dcbf4c5c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
