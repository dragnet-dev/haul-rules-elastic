// Dragnet [Ransomware]: dragnet-ransomware-2021-0960 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: dc9d8d12-2ed0-52f6-8cdb-51bf337605a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
