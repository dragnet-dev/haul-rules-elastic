// Dragnet [Ransomware]: dragnet-ransomware-2021-1320 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 6ba82626-352d-56a2-9606-f791f899a10f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
