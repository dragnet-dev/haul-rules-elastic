// Dragnet [Ransomware]: dragnet-ransomware-2021-1506 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 7373ad5d-5176-5b20-957f-5551e03367ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
