// Dragnet [Ransomware]: dragnet-ransomware-2021-0498 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: ce5b560f-ef5f-5df8-b94b-86246cddd7f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
