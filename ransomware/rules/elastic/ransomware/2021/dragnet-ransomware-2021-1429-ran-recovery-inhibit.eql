// Dragnet [Ransomware]: dragnet-ransomware-2021-1429 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c09e6ceb-580f-5633-a691-42377446f45c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
