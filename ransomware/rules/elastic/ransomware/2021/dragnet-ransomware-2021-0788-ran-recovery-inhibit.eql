// Dragnet [Ransomware]: dragnet-ransomware-2021-0788 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: dd1b303b-8d2c-5f0a-a8cf-3772e42aacc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
