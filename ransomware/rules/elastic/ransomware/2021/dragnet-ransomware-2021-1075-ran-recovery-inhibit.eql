// Dragnet [Ransomware]: dragnet-ransomware-2021-1075 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c6d9bdeb-9f74-553c-990e-b904701b4564

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
