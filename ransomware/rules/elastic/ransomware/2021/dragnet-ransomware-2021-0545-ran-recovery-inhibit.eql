// Dragnet [Ransomware]: dragnet-ransomware-2021-0545 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 5c7d42ae-27ed-5dd2-ae3a-178df4da0306

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
