// Dragnet [Ransomware]: dragnet-ransomware-2021-0132 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: f0058784-2674-596f-b362-792267f3279d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
