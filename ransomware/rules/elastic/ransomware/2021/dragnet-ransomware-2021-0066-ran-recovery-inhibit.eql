// Dragnet [Ransomware]: dragnet-ransomware-2021-0066 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 16fa912c-37bd-57b0-9bdc-74b964025e52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
