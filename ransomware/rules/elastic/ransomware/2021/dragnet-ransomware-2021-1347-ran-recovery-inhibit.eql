// Dragnet [Ransomware]: dragnet-ransomware-2021-1347 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 85fbd80d-5a5a-54e5-8c6c-361734c3aaa9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
