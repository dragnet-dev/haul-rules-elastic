// Dragnet [Ransomware]: dragnet-ransomware-2021-0274 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 4588fcd5-847f-51d9-9d52-e3dbbacb73a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
