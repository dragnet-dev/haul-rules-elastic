// Dragnet [Ransomware]: dragnet-ransomware-2021-0006 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: b888d9f7-247d-5aa7-8580-c91e6c45a646

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
