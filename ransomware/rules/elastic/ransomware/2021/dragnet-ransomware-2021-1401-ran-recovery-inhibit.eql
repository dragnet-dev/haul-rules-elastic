// Dragnet [Ransomware]: dragnet-ransomware-2021-1401 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 3035daaf-c98e-5d9f-ac95-89c3bafbae45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
