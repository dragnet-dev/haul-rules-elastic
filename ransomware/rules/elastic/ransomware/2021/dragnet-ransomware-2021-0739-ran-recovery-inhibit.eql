// Dragnet [Ransomware]: dragnet-ransomware-2021-0739 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: bf99654c-da3f-54bb-800a-96c5e30b27be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
