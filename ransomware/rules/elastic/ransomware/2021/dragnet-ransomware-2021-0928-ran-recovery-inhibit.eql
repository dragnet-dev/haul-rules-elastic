// Dragnet [Ransomware]: dragnet-ransomware-2021-0928 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 3e077a08-66e1-531d-bf93-32ba7e6d9e22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
