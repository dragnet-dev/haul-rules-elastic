// Dragnet [Ransomware]: dragnet-ransomware-2021-0797 — Recovery Inhibition (sabbath)
// Status: deprecated | Level: high | ID: 2bc60cb9-bd3b-509f-adcf-61ff20c7ed14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
