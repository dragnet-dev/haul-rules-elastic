// Dragnet [Ransomware]: dragnet-ransomware-2021-0052 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 02a7cbb0-9fcb-591c-b271-578e853ece8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
