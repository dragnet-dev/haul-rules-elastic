// Dragnet [Ransomware]: dragnet-ransomware-2021-1746 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: d2fcbdaa-fabe-556d-addd-5cadfe816150

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
