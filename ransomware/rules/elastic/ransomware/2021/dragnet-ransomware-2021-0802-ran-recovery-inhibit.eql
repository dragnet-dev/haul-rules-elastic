// Dragnet [Ransomware]: dragnet-ransomware-2021-0802 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: c62af361-6522-58ee-85b8-27a946c098e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
