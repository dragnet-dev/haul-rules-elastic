// Dragnet [Ransomware]: dragnet-ransomware-2021-0230 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 76aed74f-cf03-58a8-9367-946267dccd73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
