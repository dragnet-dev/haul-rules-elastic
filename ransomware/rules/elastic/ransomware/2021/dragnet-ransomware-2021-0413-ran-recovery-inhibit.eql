// Dragnet [Ransomware]: dragnet-ransomware-2021-0413 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 36ab8d5d-9ddf-56e2-a9e3-3a877d98a8d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
