// Dragnet [Ransomware]: dragnet-ransomware-2021-1406 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 0866d2ce-d5e7-5067-a910-a36a9856cdd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
