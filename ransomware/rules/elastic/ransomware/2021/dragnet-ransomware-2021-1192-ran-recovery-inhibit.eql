// Dragnet [Ransomware]: dragnet-ransomware-2021-1192 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: c94fba97-aa41-5683-9c58-fca3fc82153d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
