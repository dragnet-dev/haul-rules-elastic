// Dragnet [Ransomware]: dragnet-ransomware-2021-1036 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 10ebe02b-d13d-5cc6-8fa4-2a38d8b86ed8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
