// Dragnet [Ransomware]: dragnet-ransomware-2021-0385 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: 430a8909-eff6-587d-bc13-69a2247ce342

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
