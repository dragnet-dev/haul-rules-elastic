// Dragnet [Ransomware]: dragnet-ransomware-2021-1805 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 8cbeca75-fcc5-59cf-a326-7b90698cf134

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
