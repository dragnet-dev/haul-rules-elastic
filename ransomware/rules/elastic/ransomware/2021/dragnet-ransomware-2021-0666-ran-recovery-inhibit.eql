// Dragnet [Ransomware]: dragnet-ransomware-2021-0666 — Recovery Inhibition (cryp70n1c0d3)
// Status: deprecated | Level: high | ID: 4d889736-1891-5136-8d63-1a43b65e6897

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
