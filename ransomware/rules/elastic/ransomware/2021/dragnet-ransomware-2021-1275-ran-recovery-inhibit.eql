// Dragnet [Ransomware]: dragnet-ransomware-2021-1275 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d51e30b7-82bd-5f13-b7d5-4f403cb3b4cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
