// Dragnet [Ransomware]: dragnet-ransomware-2021-0004 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ea0312e1-5a63-5db6-9809-851e86fde13b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
