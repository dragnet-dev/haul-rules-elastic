// Dragnet [Ransomware]: dragnet-ransomware-2021-0714 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 98f637bd-08a8-55e6-bc0d-8e98cd0a5074

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
