// Dragnet [Ransomware]: dragnet-ransomware-2021-0736 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 06db5cfe-7c7a-5fa0-b955-4737090755d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
