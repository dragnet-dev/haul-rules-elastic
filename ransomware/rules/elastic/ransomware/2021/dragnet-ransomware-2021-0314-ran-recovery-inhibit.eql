// Dragnet [Ransomware]: dragnet-ransomware-2021-0314 — Recovery Inhibition (mountlocker)
// Status: deprecated | Level: high | ID: 0746b605-9f02-5236-9f4d-1a443dc92a69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
