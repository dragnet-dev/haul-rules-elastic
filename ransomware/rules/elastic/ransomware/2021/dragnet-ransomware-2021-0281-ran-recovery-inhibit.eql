// Dragnet [Ransomware]: dragnet-ransomware-2021-0281 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: a790725e-0d2f-5e61-a466-82add366d41a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
