// Dragnet [Ransomware]: dragnet-ransomware-2021-0773 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 966c69d0-438a-57fb-b3df-afff23cc7bf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
