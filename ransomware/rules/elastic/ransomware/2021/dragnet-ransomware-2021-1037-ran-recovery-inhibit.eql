// Dragnet [Ransomware]: dragnet-ransomware-2021-1037 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: f0e2fee0-c2f8-5f71-bc94-828e43293d23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
