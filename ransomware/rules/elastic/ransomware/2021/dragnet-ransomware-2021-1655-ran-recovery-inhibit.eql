// Dragnet [Ransomware]: dragnet-ransomware-2021-1655 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: edcd0b9c-e061-5295-852d-43147e5efdf2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
