// Dragnet [Ransomware]: dragnet-ransomware-2021-1091 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: e0664115-6377-54d5-9592-b25004746609

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
