// Dragnet [Ransomware]: dragnet-ransomware-2021-0888 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e89eee8a-9497-5991-9ecd-16053173dc42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
