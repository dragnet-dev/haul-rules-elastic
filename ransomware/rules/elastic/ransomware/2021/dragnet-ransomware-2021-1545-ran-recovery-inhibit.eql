// Dragnet [Ransomware]: dragnet-ransomware-2021-1545 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 5f0a656d-7e44-51ff-8457-4d1931fe1c02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
