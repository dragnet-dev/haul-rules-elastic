// Dragnet [Ransomware]: dragnet-ransomware-2021-0407 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 9e11adea-a274-5501-894c-2ddb7f9b650f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
