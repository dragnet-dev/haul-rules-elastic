// Dragnet [Ransomware]: dragnet-ransomware-2021-0921 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f3fcdfc9-8529-54dd-bf36-475df561c030

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
