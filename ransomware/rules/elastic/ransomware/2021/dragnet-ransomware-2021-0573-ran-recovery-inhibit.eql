// Dragnet [Ransomware]: dragnet-ransomware-2021-0573 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 67a52563-143c-544f-844d-4b77777a99f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
