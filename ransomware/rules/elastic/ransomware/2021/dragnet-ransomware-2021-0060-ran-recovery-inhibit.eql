// Dragnet [Ransomware]: dragnet-ransomware-2021-0060 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 4dea543b-1093-595a-a855-cc3cc1efbf73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
