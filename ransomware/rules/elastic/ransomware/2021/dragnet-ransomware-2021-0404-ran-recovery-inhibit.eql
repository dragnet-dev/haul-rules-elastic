// Dragnet [Ransomware]: dragnet-ransomware-2021-0404 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b89157ec-ddd8-5e2b-8d96-97630d1307e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
