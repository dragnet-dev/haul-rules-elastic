// Dragnet [Ransomware]: dragnet-ransomware-2021-0295 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 18689172-e65d-57d8-a4a7-4a00e1fe5c8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
