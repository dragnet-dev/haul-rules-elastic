// Dragnet [Ransomware]: dragnet-ransomware-2021-0070 — Recovery Inhibition (payloadbin)
// Status: deprecated | Level: high | ID: 6f7722d5-fb48-5164-be16-a21ecf0405d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
