// Dragnet [Ransomware]: dragnet-ransomware-2021-0444 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 44cde4c7-2c45-5bb7-a61b-c52ebab84600

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
