// Dragnet [Ransomware]: dragnet-ransomware-2021-0379 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a3524693-8abd-5d12-aa7a-222a73286454

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
