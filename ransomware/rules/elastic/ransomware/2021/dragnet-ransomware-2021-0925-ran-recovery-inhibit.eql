// Dragnet [Ransomware]: dragnet-ransomware-2021-0925 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 023ad297-38e3-59df-b708-21795d2ba1ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
