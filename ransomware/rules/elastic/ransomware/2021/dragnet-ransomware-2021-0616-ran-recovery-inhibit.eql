// Dragnet [Ransomware]: dragnet-ransomware-2021-0616 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: fcaeec7d-2d39-52fc-aba4-42e29dac9ee6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
