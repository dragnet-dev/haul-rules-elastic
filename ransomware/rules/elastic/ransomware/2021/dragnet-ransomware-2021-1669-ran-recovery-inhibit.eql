// Dragnet [Ransomware]: dragnet-ransomware-2021-1669 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: f27f39ef-5164-5e9a-b311-ed3123a7df17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
