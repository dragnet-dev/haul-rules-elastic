// Dragnet [Ransomware]: dragnet-ransomware-2021-0280 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 0af587b5-099c-5c8c-a59b-ac5cc554d7fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
