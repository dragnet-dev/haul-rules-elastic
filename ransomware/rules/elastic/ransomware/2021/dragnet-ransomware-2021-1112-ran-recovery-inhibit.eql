// Dragnet [Ransomware]: dragnet-ransomware-2021-1112 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 4c6e1520-f4d9-5013-a19a-1c6c072c4fbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
