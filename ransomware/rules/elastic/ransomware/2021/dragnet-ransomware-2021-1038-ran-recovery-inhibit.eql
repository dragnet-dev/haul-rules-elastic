// Dragnet [Ransomware]: dragnet-ransomware-2021-1038 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 95af3af3-c136-5630-913a-2ad3158e062c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
