// Dragnet [Ransomware]: dragnet-ransomware-2021-0528 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: d7d1c364-c664-50aa-be9d-c367b93323b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
