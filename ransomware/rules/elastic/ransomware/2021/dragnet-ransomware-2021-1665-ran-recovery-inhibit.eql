// Dragnet [Ransomware]: dragnet-ransomware-2021-1665 — Recovery Inhibition (groove)
// Status: deprecated | Level: high | ID: 4b18561f-be79-57df-b195-c044d23d6070

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
