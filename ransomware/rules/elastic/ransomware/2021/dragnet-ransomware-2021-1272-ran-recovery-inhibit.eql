// Dragnet [Ransomware]: dragnet-ransomware-2021-1272 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 375b2dcb-5ca1-5814-9b09-3d3f7bc92707

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
