// Dragnet [Ransomware]: dragnet-ransomware-2021-0202 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 4afb6841-0a4b-5d3e-bf90-8326149e97d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
