// Dragnet [Ransomware]: dragnet-ransomware-2021-0987 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2f5b4f06-b853-50ae-a156-433aa571426d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
