// Dragnet [Ransomware]: dragnet-ransomware-2021-0732 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 01439051-4369-5a85-b2dc-a935cc59d5cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
