// Dragnet [Ransomware]: dragnet-ransomware-2021-0954 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 98d05b60-15ef-5ce1-88b4-6a1e17d09af7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
