// Dragnet [Ransomware]: dragnet-ransomware-2021-1574 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 139fa06b-6e90-5ef2-84f7-ff8f0473abb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
