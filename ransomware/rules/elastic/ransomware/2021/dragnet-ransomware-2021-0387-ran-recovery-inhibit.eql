// Dragnet [Ransomware]: dragnet-ransomware-2021-0387 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 3943d284-e8e2-5bb1-97e9-078dc9e8b235

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
