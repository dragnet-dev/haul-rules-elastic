// Dragnet [Ransomware]: dragnet-ransomware-2021-0543 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: c8e329f8-ea3f-51db-a7eb-37af811e2140

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
