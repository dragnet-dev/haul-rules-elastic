// Dragnet [Ransomware]: dragnet-ransomware-2021-0906 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 773485fe-f826-5adc-bea4-0090bb5e8cb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
