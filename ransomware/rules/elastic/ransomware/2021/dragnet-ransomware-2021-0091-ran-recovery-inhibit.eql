// Dragnet [Ransomware]: dragnet-ransomware-2021-0091 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 281051ac-57e3-53bd-9a6d-d6f66012503c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
