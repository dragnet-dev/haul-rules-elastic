// Dragnet [Ransomware]: dragnet-ransomware-2021-1664 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4a1179d1-02a7-5e34-aeb2-1264de053de6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
