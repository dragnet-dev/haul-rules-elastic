// Dragnet [Ransomware]: dragnet-ransomware-2021-0321 — Recovery Inhibition (pay2key)
// Status: deprecated | Level: high | ID: bea8b98e-117f-5032-ae4f-f40295a78797

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
