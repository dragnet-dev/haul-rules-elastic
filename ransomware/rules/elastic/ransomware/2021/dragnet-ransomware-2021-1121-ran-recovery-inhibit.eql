// Dragnet [Ransomware]: dragnet-ransomware-2021-1121 — Recovery Inhibition (astroteam)
// Status: deprecated | Level: high | ID: be26613d-20b5-5173-8971-700f31086b7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
