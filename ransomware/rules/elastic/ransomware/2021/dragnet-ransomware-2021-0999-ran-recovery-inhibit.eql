// Dragnet [Ransomware]: dragnet-ransomware-2021-0999 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: 43a750f6-ada4-5beb-86d9-9f2854923b52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
