// Dragnet [Ransomware]: dragnet-ransomware-2021-0335 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: c5ff8f42-6916-5c1b-89e0-0544c0a0c9aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
