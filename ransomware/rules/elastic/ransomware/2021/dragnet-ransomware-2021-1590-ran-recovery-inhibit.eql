// Dragnet [Ransomware]: dragnet-ransomware-2021-1590 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: fe9dccb4-423f-567f-91f3-07317efaafe7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
