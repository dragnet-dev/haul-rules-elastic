// Dragnet [Ransomware]: dragnet-ransomware-2021-1013 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: c3cf85d9-e1a7-554b-a588-e9c1c30cc228

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
