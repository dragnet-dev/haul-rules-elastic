// Dragnet [Ransomware]: dragnet-ransomware-2021-1596 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 2768dc4e-da1c-5c36-92d1-8fbbfb3205d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
