// Dragnet [Ransomware]: dragnet-ransomware-2021-0769 — Recovery Inhibition (payloadbin)
// Status: deprecated | Level: high | ID: 280ebd75-feef-5309-8536-c3312e2c7def

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
