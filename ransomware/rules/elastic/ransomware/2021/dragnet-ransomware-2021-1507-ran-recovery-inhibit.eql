// Dragnet [Ransomware]: dragnet-ransomware-2021-1507 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 083d19f3-d0b8-5132-ab24-ca6811fabd70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
