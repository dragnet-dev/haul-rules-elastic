// Dragnet [Ransomware]: dragnet-ransomware-2021-0466 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: 40dbe268-37bd-5b55-9646-a68917e2d841

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
