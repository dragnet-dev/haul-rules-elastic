// Dragnet [Ransomware]: dragnet-ransomware-2021-0824 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2e5a812d-41de-593a-94e9-0306de12fcbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
