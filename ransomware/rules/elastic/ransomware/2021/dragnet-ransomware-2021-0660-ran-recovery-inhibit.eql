// Dragnet [Ransomware]: dragnet-ransomware-2021-0660 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 1766ee87-4290-56a9-9bf9-15cca1503290

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
