// Dragnet [Ransomware]: dragnet-ransomware-2021-0095 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: e3e670a0-f5a5-57fa-b6a4-f880a3bfa4b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
