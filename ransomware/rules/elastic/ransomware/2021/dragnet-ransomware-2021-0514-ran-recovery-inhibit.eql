// Dragnet [Ransomware]: dragnet-ransomware-2021-0514 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d5909ff2-c22a-569d-ab19-3a44afbbf967

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
