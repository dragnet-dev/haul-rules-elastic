// Dragnet [Ransomware]: dragnet-ransomware-2021-0037 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b8f6958f-7bc2-5d5f-b858-59407d22e78b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
