// Dragnet [Ransomware]: dragnet-ransomware-2021-0559 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 4ba9bb64-8899-5de1-bb7a-fb74943bd594

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
