// Dragnet [Ransomware]: dragnet-ransomware-2021-0334 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: d5ffa2d8-db88-5fa1-88e7-89e0da5c10d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
