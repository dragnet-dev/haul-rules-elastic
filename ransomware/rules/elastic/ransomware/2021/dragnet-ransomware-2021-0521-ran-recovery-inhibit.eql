// Dragnet [Ransomware]: dragnet-ransomware-2021-0521 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 23934962-9f2c-5949-bab7-31a99e20575a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
