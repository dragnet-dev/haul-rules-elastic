// Dragnet [Ransomware]: dragnet-ransomware-2021-0517 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: aa1cf2ec-2ae8-51d3-8e0f-b58d1d12a1c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
