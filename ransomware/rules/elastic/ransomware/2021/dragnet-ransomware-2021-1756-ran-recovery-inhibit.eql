// Dragnet [Ransomware]: dragnet-ransomware-2021-1756 — Recovery Inhibition (karma)
// Status: deprecated | Level: high | ID: 2e004b6a-bb22-524f-8dcb-1d5250f57120

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
