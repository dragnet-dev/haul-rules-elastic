// Dragnet [Ransomware]: dragnet-ransomware-2021-1256 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 84a4639b-79d5-5545-bb0e-dba54eeee3f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
