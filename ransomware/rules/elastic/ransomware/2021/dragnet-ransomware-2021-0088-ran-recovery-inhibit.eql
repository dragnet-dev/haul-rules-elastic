// Dragnet [Ransomware]: dragnet-ransomware-2021-0088 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 0e9461fe-f69b-5865-9fdc-786c93f9d682

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
