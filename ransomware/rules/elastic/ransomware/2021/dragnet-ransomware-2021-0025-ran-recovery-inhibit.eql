// Dragnet [Ransomware]: dragnet-ransomware-2021-0025 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a05d4897-9ad3-5d63-8287-0592513d195e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
