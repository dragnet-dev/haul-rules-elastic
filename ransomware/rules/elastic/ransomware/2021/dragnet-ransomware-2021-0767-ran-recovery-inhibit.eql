// Dragnet [Ransomware]: dragnet-ransomware-2021-0767 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f593d629-5ccf-559c-8c05-ecfd58f1cfe5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
