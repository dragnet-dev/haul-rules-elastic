// Dragnet [Ransomware]: dragnet-ransomware-2021-0720 — Recovery Inhibition (sabbath)
// Status: deprecated | Level: high | ID: 91fde9ad-78b8-5205-98f1-c42d56bec1f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
