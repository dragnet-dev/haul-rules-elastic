// Dragnet [Ransomware]: dragnet-ransomware-2021-0108 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 0bd62142-ce56-565a-b4ea-6546869cd459

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
