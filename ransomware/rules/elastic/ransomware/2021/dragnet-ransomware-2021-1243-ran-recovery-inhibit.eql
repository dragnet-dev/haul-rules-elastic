// Dragnet [Ransomware]: dragnet-ransomware-2021-1243 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 49c282bf-2a15-5901-9177-f9b0568464ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
