// Dragnet [Ransomware]: dragnet-ransomware-2021-1424 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 05ae4ff1-c858-5897-aef5-f51da36ffd59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
