// Dragnet [Ransomware]: dragnet-ransomware-2021-1656 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 35ab2f90-d8e6-5b9e-a7b1-889d47a91ef0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
