// Dragnet [Ransomware]: dragnet-ransomware-2021-0699 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 3ccf7219-2ed0-5d63-bd74-402eb0f46dce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
