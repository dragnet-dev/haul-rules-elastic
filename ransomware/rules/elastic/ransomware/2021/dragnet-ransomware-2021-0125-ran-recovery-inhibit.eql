// Dragnet [Ransomware]: dragnet-ransomware-2021-0125 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c388721c-cf75-5f0e-aaae-a01cf9914497

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
