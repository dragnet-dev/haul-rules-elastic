// Dragnet [Ransomware]: dragnet-ransomware-2021-0578 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 6a51c045-66a0-56b3-bba0-b66c78ce8230

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
