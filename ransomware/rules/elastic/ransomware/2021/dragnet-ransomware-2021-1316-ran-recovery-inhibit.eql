// Dragnet [Ransomware]: dragnet-ransomware-2021-1316 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 14eac385-2093-5ff2-898b-142efb3a1dfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
