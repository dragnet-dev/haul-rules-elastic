// Dragnet [Ransomware]: dragnet-ransomware-2021-1493 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a60bde60-cc5d-5fef-a9fc-50d34780d15d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
