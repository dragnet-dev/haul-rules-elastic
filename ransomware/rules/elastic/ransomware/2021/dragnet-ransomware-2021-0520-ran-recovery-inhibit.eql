// Dragnet [Ransomware]: dragnet-ransomware-2021-0520 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 75e27fdd-2bca-5b94-bbc4-be74aee80bd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
