// Dragnet [Ransomware]: dragnet-ransomware-2021-0147 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f154a6eb-b23a-57e9-b954-ec774fd557b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
