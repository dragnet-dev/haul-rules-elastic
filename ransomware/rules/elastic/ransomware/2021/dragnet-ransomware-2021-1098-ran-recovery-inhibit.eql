// Dragnet [Ransomware]: dragnet-ransomware-2021-1098 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: e959373d-6cc3-5854-8173-6cb401eebf3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
