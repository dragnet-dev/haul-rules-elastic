// Dragnet [Ransomware]: dragnet-ransomware-2021-1208 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 76f22981-c17e-5f24-8b97-eef1c0dc5cfa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
