// Dragnet [Ransomware]: dragnet-ransomware-2021-0629 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e3524837-c682-5613-897f-21395e28d4c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
