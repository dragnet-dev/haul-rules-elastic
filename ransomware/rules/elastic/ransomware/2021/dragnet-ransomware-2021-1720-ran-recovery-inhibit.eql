// Dragnet [Ransomware]: dragnet-ransomware-2021-1720 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 4c022a56-9e8e-516c-a888-8d57875b4b61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
