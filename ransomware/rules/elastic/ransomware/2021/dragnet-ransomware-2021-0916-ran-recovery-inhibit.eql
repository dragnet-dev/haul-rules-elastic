// Dragnet [Ransomware]: dragnet-ransomware-2021-0916 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 043a884e-031f-5066-9878-037740bc3f1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
