// Dragnet [Ransomware]: dragnet-ransomware-2021-0791 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: 0fad6a58-c2fe-59f7-98a5-f82198754b2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
