// Dragnet [Ransomware]: dragnet-ransomware-2021-1594 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: f720a2d8-c7b8-572f-ad56-f2fefa1be7a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
