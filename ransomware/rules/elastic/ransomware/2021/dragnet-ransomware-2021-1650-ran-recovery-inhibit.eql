// Dragnet [Ransomware]: dragnet-ransomware-2021-1650 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8a52f959-125c-57c9-98d8-b06a380c5cc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
