// Dragnet [Ransomware]: dragnet-ransomware-2021-1363 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 918e0539-bef8-5e8c-8a07-505112ce6d1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
