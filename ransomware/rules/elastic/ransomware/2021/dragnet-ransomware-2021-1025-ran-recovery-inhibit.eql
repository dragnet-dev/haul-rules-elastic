// Dragnet [Ransomware]: dragnet-ransomware-2021-1025 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 0816581e-223e-5de5-b68a-1abbcc38d5f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
