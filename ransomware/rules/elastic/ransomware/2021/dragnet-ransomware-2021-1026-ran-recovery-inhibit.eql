// Dragnet [Ransomware]: dragnet-ransomware-2021-1026 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: 0f81e728-ada4-5a5b-ab01-fddbfbb78fc3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
