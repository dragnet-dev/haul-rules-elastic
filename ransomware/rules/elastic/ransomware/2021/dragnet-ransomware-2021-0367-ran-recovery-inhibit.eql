// Dragnet [Ransomware]: dragnet-ransomware-2021-0367 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 8aeb3605-5c2a-5095-992e-9e9e640c93d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
