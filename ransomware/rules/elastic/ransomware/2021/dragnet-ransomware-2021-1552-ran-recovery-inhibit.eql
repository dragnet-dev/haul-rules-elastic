// Dragnet [Ransomware]: dragnet-ransomware-2021-1552 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: ccff3609-4f8e-5f15-9dc3-f6a7cf238f06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
