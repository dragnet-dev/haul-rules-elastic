// Dragnet [Ransomware]: dragnet-ransomware-2021-0204 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: aa9dd30b-dc72-5834-9160-9dfaff594bfc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
