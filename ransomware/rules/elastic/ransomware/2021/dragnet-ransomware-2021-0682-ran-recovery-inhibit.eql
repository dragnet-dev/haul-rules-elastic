// Dragnet [Ransomware]: dragnet-ransomware-2021-0682 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 1fe6459b-3361-5d09-8429-67531cc50f80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
