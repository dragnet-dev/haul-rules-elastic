// Dragnet [Ransomware]: dragnet-ransomware-2021-1288 — Recovery Inhibition (blackshadow)
// Status: deprecated | Level: high | ID: 0af184f6-960a-5289-b610-986e5424af11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
