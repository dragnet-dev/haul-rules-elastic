// Dragnet [Ransomware]: dragnet-ransomware-2021-1474 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b241ccbb-cf26-5706-8b70-44195171b350

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
