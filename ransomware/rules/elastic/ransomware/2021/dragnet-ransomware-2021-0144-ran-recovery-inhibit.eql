// Dragnet [Ransomware]: dragnet-ransomware-2021-0144 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 40744d20-2df6-5a2a-80c7-f71d7e8d66cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
