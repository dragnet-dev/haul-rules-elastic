// Dragnet [Ransomware]: dragnet-ransomware-2021-0287 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: d0510f23-1b56-5952-9c00-3bff3c9fbe7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
