// Dragnet [Ransomware]: dragnet-ransomware-2021-0992 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e054d014-2a9c-5484-9947-09a85846c630

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
