// Dragnet [Ransomware]: dragnet-ransomware-2021-1030 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 4671ba95-4a75-5f0f-a9cf-997c3079404e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
