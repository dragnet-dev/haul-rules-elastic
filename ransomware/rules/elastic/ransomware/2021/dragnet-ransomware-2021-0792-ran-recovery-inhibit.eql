// Dragnet [Ransomware]: dragnet-ransomware-2021-0792 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 98d441a0-eb87-5a61-993e-51e43912b9dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
