// Dragnet [Ransomware]: dragnet-ransomware-2021-0339 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 3a308275-fb65-5fe2-bb77-f3dba9364a75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
