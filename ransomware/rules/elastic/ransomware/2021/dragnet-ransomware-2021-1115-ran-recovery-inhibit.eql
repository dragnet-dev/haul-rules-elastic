// Dragnet [Ransomware]: dragnet-ransomware-2021-1115 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 0221807f-c072-520a-8053-6cecb5f8b5f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
