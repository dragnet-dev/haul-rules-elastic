// Dragnet [Ransomware]: dragnet-ransomware-2021-1405 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: dacc6879-605b-5009-8a62-a756a088a6c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
