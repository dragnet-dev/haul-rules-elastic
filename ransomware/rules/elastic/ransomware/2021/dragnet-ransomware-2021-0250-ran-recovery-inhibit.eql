// Dragnet [Ransomware]: dragnet-ransomware-2021-0250 — Recovery Inhibition (cryp70n1c0d3)
// Status: deprecated | Level: high | ID: f82f077d-9a89-5087-92ca-6157db7de4ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
