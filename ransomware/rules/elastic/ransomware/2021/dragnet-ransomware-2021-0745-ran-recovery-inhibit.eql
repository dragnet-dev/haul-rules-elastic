// Dragnet [Ransomware]: dragnet-ransomware-2021-0745 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: fedcdaf3-904e-5d68-b6f1-ab9f51a02ae5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
