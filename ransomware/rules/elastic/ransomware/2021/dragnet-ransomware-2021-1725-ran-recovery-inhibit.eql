// Dragnet [Ransomware]: dragnet-ransomware-2021-1725 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 3e651c8d-f47d-5bbb-abde-02c889bf218f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
