// Dragnet [Ransomware]: dragnet-ransomware-2021-0506 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 5d0faaa6-eff9-509b-b443-5411402558f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
