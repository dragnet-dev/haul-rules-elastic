// Dragnet [Ransomware]: dragnet-ransomware-2021-1449 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 37fce253-1e48-5716-887d-b24a42d80593

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
