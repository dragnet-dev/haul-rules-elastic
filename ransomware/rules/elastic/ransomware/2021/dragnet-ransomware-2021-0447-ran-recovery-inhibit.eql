// Dragnet [Ransomware]: dragnet-ransomware-2021-0447 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: e781b6fc-d8dd-5b97-9002-247074f4c3c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
