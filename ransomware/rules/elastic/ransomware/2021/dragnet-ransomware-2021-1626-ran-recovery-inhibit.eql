// Dragnet [Ransomware]: dragnet-ransomware-2021-1626 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 489c8714-006f-5e6a-bfdd-078c2424bef9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
