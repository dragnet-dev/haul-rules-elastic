// Dragnet [Ransomware]: dragnet-ransomware-2021-1184 — Recovery Inhibition (mosesstaff)
// Status: deprecated | Level: high | ID: 8c9982aa-43d0-56f0-8d32-d9c51397569f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
