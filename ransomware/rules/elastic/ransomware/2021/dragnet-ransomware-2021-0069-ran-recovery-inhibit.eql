// Dragnet [Ransomware]: dragnet-ransomware-2021-0069 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: 8dcdc171-a436-5987-9a28-54165d949022

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
