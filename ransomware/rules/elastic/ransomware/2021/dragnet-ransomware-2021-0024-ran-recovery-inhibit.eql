// Dragnet [Ransomware]: dragnet-ransomware-2021-0024 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: c3597280-832a-58c0-a58e-d91f0009bedc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
