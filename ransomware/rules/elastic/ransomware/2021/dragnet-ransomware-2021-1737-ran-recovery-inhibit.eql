// Dragnet [Ransomware]: dragnet-ransomware-2021-1737 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 325a231c-8e4d-5eef-89c5-3bf514fff55b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
