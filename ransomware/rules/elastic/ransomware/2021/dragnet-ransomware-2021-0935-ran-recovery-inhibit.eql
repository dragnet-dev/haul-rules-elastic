// Dragnet [Ransomware]: dragnet-ransomware-2021-0935 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b03acde9-6eec-5d05-ad83-68d22227d1a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
