// Dragnet [Ransomware]: dragnet-ransomware-2021-1716 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: b81ed603-11e4-587a-bb45-e3f13193aeab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
