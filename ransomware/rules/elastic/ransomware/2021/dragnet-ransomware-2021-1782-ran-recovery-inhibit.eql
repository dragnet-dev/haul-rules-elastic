// Dragnet [Ransomware]: dragnet-ransomware-2021-1782 — Recovery Inhibition (payloadbin)
// Status: deprecated | Level: high | ID: 5b09e7d4-8dde-51c9-8161-fd178f28ca12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
