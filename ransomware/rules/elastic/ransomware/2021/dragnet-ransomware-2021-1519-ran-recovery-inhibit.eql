// Dragnet [Ransomware]: dragnet-ransomware-2021-1519 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 9efff759-e280-5779-8f21-5402fa213322

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
