// Dragnet [Ransomware]: dragnet-ransomware-2021-1512 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8710b35d-52be-5edb-a5a3-8316a0a1ee8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
