// Dragnet [Ransomware]: dragnet-ransomware-2021-1304 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 82d78a5b-7c30-580b-ab5d-a4424cb10aac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
