// Dragnet [Ransomware]: dragnet-ransomware-2021-0257 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ff3fd39a-53ce-5592-8249-35f20b7f6f82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
