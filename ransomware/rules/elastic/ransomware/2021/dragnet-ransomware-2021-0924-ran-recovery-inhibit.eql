// Dragnet [Ransomware]: dragnet-ransomware-2021-0924 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 3ccd1133-ec4d-5ad2-b995-88603bb4668d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
