// Dragnet [Ransomware]: dragnet-ransomware-2021-0137 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 45b25f90-f2c1-5424-994d-875d1dd312fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
