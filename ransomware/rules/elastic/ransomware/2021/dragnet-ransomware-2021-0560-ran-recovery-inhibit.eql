// Dragnet [Ransomware]: dragnet-ransomware-2021-0560 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 0998dbee-12e7-5d9b-b005-b746e0d2f717

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
