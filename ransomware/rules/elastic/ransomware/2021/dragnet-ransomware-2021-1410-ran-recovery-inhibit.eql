// Dragnet [Ransomware]: dragnet-ransomware-2021-1410 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ec20631a-6f40-59eb-b29a-30628f24280e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
