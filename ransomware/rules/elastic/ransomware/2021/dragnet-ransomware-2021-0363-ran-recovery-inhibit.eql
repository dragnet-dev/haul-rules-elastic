// Dragnet [Ransomware]: dragnet-ransomware-2021-0363 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: b5fa6c0c-0d26-5a5c-9d88-f100c378bd46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
