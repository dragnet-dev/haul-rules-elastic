// Dragnet [Ransomware]: dragnet-ransomware-2021-1201 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: d26cb887-189a-57f6-99a0-23e6b760b44b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
