// Dragnet [Ransomware]: dragnet-ransomware-2021-1551 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 96a71d16-63d0-58f9-afe4-630e1af3adc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
