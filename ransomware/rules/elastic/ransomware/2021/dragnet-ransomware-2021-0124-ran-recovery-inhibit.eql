// Dragnet [Ransomware]: dragnet-ransomware-2021-0124 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 3d9ecfc8-35f4-532b-a9b2-649e1b6fbcfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
