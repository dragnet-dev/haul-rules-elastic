// Dragnet [Ransomware]: dragnet-ransomware-2021-0646 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: eda6b5f6-dfe6-529c-930a-fc71ee9f607e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
