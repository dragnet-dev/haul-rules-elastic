// Dragnet [Ransomware]: dragnet-ransomware-2021-1162 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 4df46738-9547-5c11-a8e0-a46fd683d200

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
