// Dragnet [Ransomware]: dragnet-ransomware-2021-1443 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 30281fb5-c1db-5f4d-ad66-c0aa3fb60c87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
