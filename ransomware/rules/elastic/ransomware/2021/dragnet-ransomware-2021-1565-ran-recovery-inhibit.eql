// Dragnet [Ransomware]: dragnet-ransomware-2021-1565 — Recovery Inhibition (payloadbin)
// Status: deprecated | Level: high | ID: 0ff94ecc-cb0a-50c3-bf4d-3b4a46c4f411

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
