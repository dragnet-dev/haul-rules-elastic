// Dragnet [Ransomware]: dragnet-ransomware-2021-1178 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 091f5344-6511-5274-801e-44e425dcbbfd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
