// Dragnet [Ransomware]: dragnet-ransomware-2021-1126 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 102e5a39-9427-562b-b063-ed8181f833fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
