// Dragnet [Ransomware]: dragnet-ransomware-2020-0061 — Recovery Inhibition (egregor)
// Status: deprecated | Level: high | ID: c1b8b8d5-cce6-56a4-838d-ddefb12246d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
