// Dragnet [Ransomware]: dragnet-ransomware-2020-0218 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: bfd1d0fd-b6fa-5f89-a25e-e57f83a82ebf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
