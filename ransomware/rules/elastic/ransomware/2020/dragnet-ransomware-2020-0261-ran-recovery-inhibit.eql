// Dragnet [Ransomware]: dragnet-ransomware-2020-0261 — Recovery Inhibition (nefilim)
// Status: deprecated | Level: high | ID: 65199d28-86fc-5dcf-b337-3beca341d988

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
