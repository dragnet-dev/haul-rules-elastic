// Dragnet [Ransomware]: dragnet-ransomware-2020-0190 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: bffd74f8-1de1-5092-a247-752186b064e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
