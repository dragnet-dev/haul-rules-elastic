// Dragnet [Ransomware]: dragnet-ransomware-2020-0249 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: fe0032a6-ed6f-54d5-b3aa-4e1931d5fa19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
