// Dragnet [Ransomware]: dragnet-ransomware-2020-0091 — Recovery Inhibition (snake)
// Status: deprecated | Level: high | ID: 4fdf50e2-1604-5d04-8df1-0f6b2bcecac4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
