// Dragnet [Ransomware]: dragnet-ransomware-2020-0096 — Recovery Inhibition (doppelpaymer)
// Status: deprecated | Level: high | ID: 98b3c8bd-4ddb-52fd-8b27-48d279e82361

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
