// Dragnet [Ransomware]: dragnet-ransomware-2020-0152 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: d0ed461a-39e6-5b89-b553-314be043dc52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
