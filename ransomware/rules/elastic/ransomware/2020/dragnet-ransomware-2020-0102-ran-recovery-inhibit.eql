// Dragnet [Ransomware]: dragnet-ransomware-2020-0102 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 6ffc797f-1348-5756-8d65-be551391ba7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
