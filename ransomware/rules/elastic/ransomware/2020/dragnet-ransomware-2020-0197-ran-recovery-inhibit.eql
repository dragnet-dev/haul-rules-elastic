// Dragnet [Ransomware]: dragnet-ransomware-2020-0197 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: 97076180-4356-5a96-9afe-7e6783aa7dcc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
