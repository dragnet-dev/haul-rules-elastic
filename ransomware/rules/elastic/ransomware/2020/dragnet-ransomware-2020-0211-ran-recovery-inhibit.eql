// Dragnet [Ransomware]: dragnet-ransomware-2020-0211 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 7037dc97-218b-5cd4-9067-c37ea2c23688

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
