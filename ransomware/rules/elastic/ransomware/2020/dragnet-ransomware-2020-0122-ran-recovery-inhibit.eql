// Dragnet [Ransomware]: dragnet-ransomware-2020-0122 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: 297f2a59-90f2-52b7-b23f-9662a76a4faa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
