// Dragnet [Ransomware]: dragnet-ransomware-2020-0153 — Recovery Inhibition (doppelpaymer)
// Status: deprecated | Level: high | ID: 8b1bcf39-a0bd-5a96-a128-66f13020a03a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
