// Dragnet [Ransomware]: dragnet-ransomware-2020-0120 — Recovery Inhibition (netwalker)
// Status: deprecated | Level: high | ID: 5b2b813c-4af7-53a1-9540-af7550169d65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
