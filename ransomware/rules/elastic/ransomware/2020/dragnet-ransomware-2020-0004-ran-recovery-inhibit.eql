// Dragnet [Ransomware]: dragnet-ransomware-2020-0004 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 9b6ee433-83d7-55a0-aa74-484d3b598d15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
