// Dragnet [Ransomware]: dragnet-ransomware-2020-0267 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 0a9ebeac-e158-5bbe-aa12-7b6c9ad069b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
