// Dragnet [Ransomware]: dragnet-ransomware-2020-0069 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: af61f410-ff6e-5767-9fe1-db223774e283

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
