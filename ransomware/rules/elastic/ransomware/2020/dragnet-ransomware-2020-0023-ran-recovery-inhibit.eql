// Dragnet [Ransomware]: dragnet-ransomware-2020-0023 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 9e97bcaf-0da3-577d-9f11-e81fb560c759

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
