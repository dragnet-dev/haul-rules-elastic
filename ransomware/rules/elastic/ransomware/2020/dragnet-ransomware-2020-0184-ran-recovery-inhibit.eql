// Dragnet [Ransomware]: dragnet-ransomware-2020-0184 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: e0b7e08c-0bd3-5b9c-95da-ab0935416e9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
