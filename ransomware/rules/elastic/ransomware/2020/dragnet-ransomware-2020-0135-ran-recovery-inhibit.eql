// Dragnet [Ransomware]: dragnet-ransomware-2020-0135 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: 8a2563f9-ee86-59fa-9d5e-b14b097acc1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
