// Dragnet [Ransomware]: dragnet-ransomware-2020-0034 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: a2017a49-860a-5c1e-8bbe-98fb258cbce7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
