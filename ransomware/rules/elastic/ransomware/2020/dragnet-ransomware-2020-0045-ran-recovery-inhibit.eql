// Dragnet [Ransomware]: dragnet-ransomware-2020-0045 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: b1f22ce6-d7cb-559d-a4a8-655bce9bdd74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
