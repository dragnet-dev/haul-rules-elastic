// Dragnet [Ransomware]: dragnet-ransomware-2020-0258 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 36422343-9a0b-525f-98d5-1de8db4ebf80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
