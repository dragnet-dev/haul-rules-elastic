// Dragnet [Ransomware]: dragnet-ransomware-2020-0104 — Recovery Inhibition (netwalker)
// Status: deprecated | Level: high | ID: 32cdbc1f-0785-5f74-aa20-a69fd5948619

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
