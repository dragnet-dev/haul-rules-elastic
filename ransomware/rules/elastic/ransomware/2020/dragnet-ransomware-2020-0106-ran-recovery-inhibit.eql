// Dragnet [Ransomware]: dragnet-ransomware-2020-0106 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: d937ee9f-f49f-5e56-b44a-0e4434f04111

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
