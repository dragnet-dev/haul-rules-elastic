// Dragnet [Ransomware]: dragnet-ransomware-2020-0040 — Recovery Inhibition (egregor)
// Status: deprecated | Level: high | ID: 65060ea0-09a4-5333-b6d3-7f34ff050eca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
