// Dragnet [Ransomware]: dragnet-ransomware-2020-0028 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: b9d58ec0-ac48-55c0-8443-ff752d882570

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
