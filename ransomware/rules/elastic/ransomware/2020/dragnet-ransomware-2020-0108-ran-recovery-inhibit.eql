// Dragnet [Ransomware]: dragnet-ransomware-2020-0108 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: 2702264a-f25c-5f92-9818-613e46039c2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
