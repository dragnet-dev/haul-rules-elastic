// Dragnet [Ransomware]: dragnet-ransomware-2020-0236 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 696e0702-0224-5471-b1b2-e557cc2a9852

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
