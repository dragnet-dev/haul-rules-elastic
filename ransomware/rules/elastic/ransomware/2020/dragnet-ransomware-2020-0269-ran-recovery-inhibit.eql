// Dragnet [Ransomware]: dragnet-ransomware-2020-0269 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: a1d4ee6b-8de1-57b3-8ed2-b6fb3b215be7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
