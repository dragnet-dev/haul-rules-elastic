// Dragnet [Ransomware]: dragnet-ransomware-2020-0231 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 9a37b94b-bce7-59c5-9a4a-a432d52ad4f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
