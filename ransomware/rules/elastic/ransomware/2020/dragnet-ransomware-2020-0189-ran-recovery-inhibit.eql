// Dragnet [Ransomware]: dragnet-ransomware-2020-0189 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: 95cf5c03-2150-5f80-9461-d89340d5a584

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
