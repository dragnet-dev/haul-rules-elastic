// Dragnet [Ransomware]: dragnet-ransomware-2020-0010 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: 573d4b79-0767-5e9b-943a-4d25e3c23529

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
