// Dragnet [Ransomware]: dragnet-ransomware-2020-0115 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: aab38580-32d8-5cd6-b593-25f302efd13c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
