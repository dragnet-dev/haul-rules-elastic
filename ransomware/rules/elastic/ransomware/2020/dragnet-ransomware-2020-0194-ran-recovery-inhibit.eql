// Dragnet [Ransomware]: dragnet-ransomware-2020-0194 — Recovery Inhibition (doppelpaymer)
// Status: deprecated | Level: high | ID: 5ec7f700-2b7a-5c5e-b21f-46c8203d747c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
