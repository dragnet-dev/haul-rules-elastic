// Dragnet [Ransomware]: dragnet-ransomware-2020-0114 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 73d98a00-29e3-5c7a-ae40-6d1468bb9af8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
