// Dragnet [Ransomware]: dragnet-ransomware-2020-0177 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: eb1962b7-6d9a-511c-b66d-b67cec8902ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
