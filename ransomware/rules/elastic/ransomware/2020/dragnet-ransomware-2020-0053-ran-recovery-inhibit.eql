// Dragnet [Ransomware]: dragnet-ransomware-2020-0053 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 05486601-dc3a-520c-9db0-262e18c5a7b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
