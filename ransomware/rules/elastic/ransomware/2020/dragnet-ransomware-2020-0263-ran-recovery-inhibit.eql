// Dragnet [Ransomware]: dragnet-ransomware-2020-0263 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 76625554-9c9b-5670-ac25-16d5987eb8a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
