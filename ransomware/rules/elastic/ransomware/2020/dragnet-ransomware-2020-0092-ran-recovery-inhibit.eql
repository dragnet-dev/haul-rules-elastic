// Dragnet [Ransomware]: dragnet-ransomware-2020-0092 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: cf399a43-8169-5556-98da-e0d046969d62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
