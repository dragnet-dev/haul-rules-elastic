// Dragnet [Ransomware]: dragnet-ransomware-2020-0257 — Recovery Inhibition (netwalker)
// Status: deprecated | Level: high | ID: ed1c9bec-08ec-5727-aa6c-f30612c2cd75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
