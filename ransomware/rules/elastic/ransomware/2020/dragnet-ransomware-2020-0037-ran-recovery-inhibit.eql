// Dragnet [Ransomware]: dragnet-ransomware-2020-0037 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 4c88ace8-b50e-5dcb-b9a7-8bba5c1ba410

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
