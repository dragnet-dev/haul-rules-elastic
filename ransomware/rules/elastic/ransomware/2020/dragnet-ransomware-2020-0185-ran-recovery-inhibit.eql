// Dragnet [Ransomware]: dragnet-ransomware-2020-0185 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 015334ab-984f-5523-bb1f-c15f64c3d6eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
