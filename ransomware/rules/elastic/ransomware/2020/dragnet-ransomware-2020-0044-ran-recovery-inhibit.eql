// Dragnet [Ransomware]: dragnet-ransomware-2020-0044 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 68db2e31-687b-5444-a5a7-fac2f34ab191

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
