// Dragnet [Ransomware]: dragnet-ransomware-2020-0139 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 916e0955-53f5-569c-b2b6-6dc46ca19658

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
