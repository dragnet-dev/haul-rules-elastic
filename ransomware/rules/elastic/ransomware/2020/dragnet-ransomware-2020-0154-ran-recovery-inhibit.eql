// Dragnet [Ransomware]: dragnet-ransomware-2020-0154 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: e08d5ccd-78e6-5e62-8149-a25df7862272

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
