// Dragnet [Ransomware]: dragnet-ransomware-2020-0041 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: 95e322b1-eceb-5589-b301-7ef3fe3ea432

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
