// Dragnet [Ransomware]: dragnet-ransomware-2020-0049 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 0513c2d0-93cf-5233-a037-199126f5f51b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
