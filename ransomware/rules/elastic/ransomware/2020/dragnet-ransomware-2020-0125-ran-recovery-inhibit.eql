// Dragnet [Ransomware]: dragnet-ransomware-2020-0125 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 8ce7d053-7670-5f12-95dd-5e1e15863266

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
