// Dragnet [Ransomware]: dragnet-ransomware-2020-0003 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 43d343ca-9ba3-5941-984a-0980516f8643

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
