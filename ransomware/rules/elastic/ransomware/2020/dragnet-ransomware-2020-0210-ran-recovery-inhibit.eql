// Dragnet [Ransomware]: dragnet-ransomware-2020-0210 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: c8d59e1a-acf3-57b1-9443-6c93d0d7053f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
