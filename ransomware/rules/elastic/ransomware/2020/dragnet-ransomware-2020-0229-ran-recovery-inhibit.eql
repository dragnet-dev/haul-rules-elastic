// Dragnet [Ransomware]: dragnet-ransomware-2020-0229 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 0c014a75-d357-5239-8b03-20227f16adf5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
