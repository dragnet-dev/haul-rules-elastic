// Dragnet [Ransomware]: dragnet-ransomware-2020-0127 — Recovery Inhibition (netwalker)
// Status: deprecated | Level: high | ID: 5412b3d6-e1fc-510c-8a02-0c8736ab9ec0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
