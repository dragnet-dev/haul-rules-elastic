// Dragnet [Ransomware]: dragnet-ransomware-2020-0014 — Recovery Inhibition (doppelpaymer)
// Status: deprecated | Level: high | ID: 4aa56460-57cd-5375-9823-d87b0d794c19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
