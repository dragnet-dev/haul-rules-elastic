// Dragnet [Ransomware]: dragnet-ransomware-2020-0161 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 98dad983-cfe9-595b-8941-bb624d275b7c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
