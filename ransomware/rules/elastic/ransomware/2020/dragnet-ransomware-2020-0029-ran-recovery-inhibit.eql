// Dragnet [Ransomware]: dragnet-ransomware-2020-0029 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: f3600dab-b338-5100-9105-f87e113d7346

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
