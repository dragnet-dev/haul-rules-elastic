// Dragnet [Ransomware]: dragnet-ransomware-2020-0011 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 1bc36129-69cf-59a4-a18b-9ba6444ebe0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
