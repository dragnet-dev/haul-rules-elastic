// Dragnet [Ransomware]: dragnet-ransomware-2020-0133 — Recovery Inhibition (netwalker)
// Status: deprecated | Level: high | ID: ca25a36c-a09c-5ded-8cd5-c444b4be3b0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
