// Dragnet [Ransomware]: dragnet-ransomware-2020-0018 — Recovery Inhibition (lockbit)
// Status: deprecated | Level: high | ID: a7d5ab52-c8df-56ac-a01a-5d5f10baa0c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
