// Dragnet [Ransomware]: dragnet-ransomware-2020-0201 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: a39f6726-5d3f-597a-a673-fb17150392e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
