// Dragnet [Ransomware]: dragnet-ransomware-2020-0181 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 4037aa7c-1dfd-522a-80ca-dc2dabebb93d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
