// Dragnet [Ransomware]: dragnet-ransomware-2020-0131 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: da8ae1b9-aea4-5d9f-bbbd-38cc9bb486e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
