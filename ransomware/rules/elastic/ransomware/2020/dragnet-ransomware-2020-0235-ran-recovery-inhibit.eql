// Dragnet [Ransomware]: dragnet-ransomware-2020-0235 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: d12891e1-592c-51ca-821f-1fb0ff858bb9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
