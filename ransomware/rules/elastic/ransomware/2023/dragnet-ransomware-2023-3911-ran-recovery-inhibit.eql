// Dragnet [Ransomware]: dragnet-ransomware-2023-3911 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a3240cf6-6fde-57f9-96aa-3f32655f352b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
