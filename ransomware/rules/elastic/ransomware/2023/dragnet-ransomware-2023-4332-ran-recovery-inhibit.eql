// Dragnet [Ransomware]: dragnet-ransomware-2023-4332 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 08890332-aac3-5af1-9a30-ab7fc1c25544

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
