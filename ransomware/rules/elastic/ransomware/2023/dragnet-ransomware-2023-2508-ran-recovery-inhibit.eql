// Dragnet [Ransomware]: dragnet-ransomware-2023-2508 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: dfa506d8-3a84-5d14-a383-a73b7cfdb738

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
