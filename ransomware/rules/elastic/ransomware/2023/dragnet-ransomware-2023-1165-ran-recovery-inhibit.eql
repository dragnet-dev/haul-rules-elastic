// Dragnet [Ransomware]: dragnet-ransomware-2023-1165 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2f3b4bb2-631b-5fef-94e5-bd40f11e89c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
