// Dragnet [Ransomware]: dragnet-ransomware-2023-3573 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 354f5819-3631-550b-9b49-3c7cfaafbebb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
