// Dragnet [Ransomware]: dragnet-ransomware-2023-1511 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 37511e5a-a1d6-55f3-9720-76dbf0c1e45e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
