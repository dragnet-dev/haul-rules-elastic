// Dragnet [Ransomware]: dragnet-ransomware-2023-3401 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: cb600842-07de-5c0f-b873-0442f2c0ea1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
