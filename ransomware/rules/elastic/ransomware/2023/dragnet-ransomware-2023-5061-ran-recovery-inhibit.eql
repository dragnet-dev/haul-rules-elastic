// Dragnet [Ransomware]: dragnet-ransomware-2023-5061 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 28c22392-bf82-5176-a2ae-f57482929d21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
