// Dragnet [Ransomware]: dragnet-ransomware-2023-0110 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: cd3cfb5b-8980-524b-8856-09c9b1d23697

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
