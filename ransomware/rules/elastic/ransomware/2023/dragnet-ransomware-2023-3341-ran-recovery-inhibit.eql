// Dragnet [Ransomware]: dragnet-ransomware-2023-3341 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2fd152a3-3367-5c3a-a44d-76f2c47ba002

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
