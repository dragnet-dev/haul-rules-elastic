// Dragnet [Ransomware]: dragnet-ransomware-2023-3350 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: a46d9dbb-24fc-53cb-91cb-8db0bf3060b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
