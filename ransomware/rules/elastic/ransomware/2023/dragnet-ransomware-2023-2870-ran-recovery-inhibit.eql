// Dragnet [Ransomware]: dragnet-ransomware-2023-2870 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 23fc94ff-b263-5399-aa7e-f6d5beb043c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
