// Dragnet [Ransomware]: dragnet-ransomware-2023-1759 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 40dde1c4-a5f5-59bd-8ebe-e858ad4bda98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
