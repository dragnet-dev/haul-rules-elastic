// Dragnet [Ransomware]: dragnet-ransomware-2023-4756 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 11229060-2ece-57fc-b6cf-12b1e0ada45e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
