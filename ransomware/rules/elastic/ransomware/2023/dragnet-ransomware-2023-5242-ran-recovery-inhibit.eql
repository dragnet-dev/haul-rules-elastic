// Dragnet [Ransomware]: dragnet-ransomware-2023-5242 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5154732e-76fa-5bd5-aeb7-c4b115e1627f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
