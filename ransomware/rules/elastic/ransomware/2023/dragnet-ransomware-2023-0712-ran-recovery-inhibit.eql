// Dragnet [Ransomware]: dragnet-ransomware-2023-0712 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b0e6cd16-7271-512f-87aa-51b66e3455a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
