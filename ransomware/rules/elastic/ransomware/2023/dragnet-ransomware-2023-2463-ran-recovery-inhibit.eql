// Dragnet [Ransomware]: dragnet-ransomware-2023-2463 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 7fad8510-c305-5b0a-a69c-b95ea1812ea0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
