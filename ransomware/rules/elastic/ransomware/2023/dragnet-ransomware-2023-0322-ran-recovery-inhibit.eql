// Dragnet [Ransomware]: dragnet-ransomware-2023-0322 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3fe88fda-d49c-50c9-b278-71583fa4a047

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
