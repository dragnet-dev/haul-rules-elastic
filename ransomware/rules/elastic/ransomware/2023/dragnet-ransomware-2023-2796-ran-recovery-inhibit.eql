// Dragnet [Ransomware]: dragnet-ransomware-2023-2796 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 202f286e-24f9-5032-8643-44144bad96f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
