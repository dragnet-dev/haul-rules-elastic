// Dragnet [Ransomware]: dragnet-ransomware-2023-1122 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: b5805e1e-f397-5e06-956c-aabf344f0499

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
