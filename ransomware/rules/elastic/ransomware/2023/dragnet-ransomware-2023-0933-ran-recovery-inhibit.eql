// Dragnet [Ransomware]: dragnet-ransomware-2023-0933 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 077abb8b-a115-5170-9345-9eb9eb147361

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
