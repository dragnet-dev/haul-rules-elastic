// Dragnet [Ransomware]: dragnet-ransomware-2023-4335 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 65e80215-1f6c-5647-bd27-f1354bd9b54a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
