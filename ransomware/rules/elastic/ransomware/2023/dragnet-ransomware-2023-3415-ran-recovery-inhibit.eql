// Dragnet [Ransomware]: dragnet-ransomware-2023-3415 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: 4a6d1b6b-3421-552a-991b-139e88305f0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
