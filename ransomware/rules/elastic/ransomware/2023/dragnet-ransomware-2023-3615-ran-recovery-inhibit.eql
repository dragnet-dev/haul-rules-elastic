// Dragnet [Ransomware]: dragnet-ransomware-2023-3615 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 67f8c035-5124-5829-a1a6-a7dde4ea1b36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
