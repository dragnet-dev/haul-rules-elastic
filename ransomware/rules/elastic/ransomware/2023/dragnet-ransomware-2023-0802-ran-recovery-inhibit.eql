// Dragnet [Ransomware]: dragnet-ransomware-2023-0802 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: c1fee13b-f0f1-5f2d-9478-e33560727014

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
