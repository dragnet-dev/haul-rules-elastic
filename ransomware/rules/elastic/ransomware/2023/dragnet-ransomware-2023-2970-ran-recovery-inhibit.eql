// Dragnet [Ransomware]: dragnet-ransomware-2023-2970 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 2c6c22d3-7294-5214-a3f2-295fe62e198d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
