// Dragnet [Ransomware]: dragnet-ransomware-2023-3226 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 584a5f87-c2ce-50af-91c9-b3c741235a38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
