// Dragnet [Ransomware]: dragnet-ransomware-2023-2439 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f73b7388-c409-59d6-a479-148b8882cab3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
