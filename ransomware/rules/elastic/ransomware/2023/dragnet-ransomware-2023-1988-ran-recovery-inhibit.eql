// Dragnet [Ransomware]: dragnet-ransomware-2023-1988 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 2f9bc04a-b6bd-53ef-be29-9cf7643f8cec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
