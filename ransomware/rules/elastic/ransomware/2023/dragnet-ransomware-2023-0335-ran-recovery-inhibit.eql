// Dragnet [Ransomware]: dragnet-ransomware-2023-0335 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 650dd73b-c688-55a9-8363-1723f230420c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
