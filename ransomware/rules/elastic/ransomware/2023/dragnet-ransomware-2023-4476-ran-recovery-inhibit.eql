// Dragnet [Ransomware]: dragnet-ransomware-2023-4476 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: fd92cfb5-a91e-5e25-8708-3ad6e3925dce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
