// Dragnet [Ransomware]: dragnet-ransomware-2023-0583 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 62d88543-7fd6-5e45-9497-3a844e9a816f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
