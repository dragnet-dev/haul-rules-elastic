// Dragnet [Ransomware]: dragnet-ransomware-2023-0478 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5c53fe40-2ae3-5171-9914-75e504ce20a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
