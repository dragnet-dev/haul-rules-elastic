// Dragnet [Ransomware]: dragnet-ransomware-2023-0708 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 48ae12e2-e2a6-5214-9b5b-7b57a7793cc1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
