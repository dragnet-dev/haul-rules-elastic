// Dragnet [Ransomware]: dragnet-ransomware-2023-1048 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f096f22c-09a2-5589-828e-0489fadeb10a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
