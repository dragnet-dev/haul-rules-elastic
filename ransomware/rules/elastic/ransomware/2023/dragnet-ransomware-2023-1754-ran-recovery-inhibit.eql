// Dragnet [Ransomware]: dragnet-ransomware-2023-1754 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 18262377-18da-51f1-bffa-011656d33129

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
