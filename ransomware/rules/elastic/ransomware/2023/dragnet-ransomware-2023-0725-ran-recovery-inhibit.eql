// Dragnet [Ransomware]: dragnet-ransomware-2023-0725 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: cbd638cc-d37d-5e04-bb60-e488e76cf939

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
