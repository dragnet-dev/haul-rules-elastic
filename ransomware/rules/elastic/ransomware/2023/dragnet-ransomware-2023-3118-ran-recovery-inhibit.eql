// Dragnet [Ransomware]: dragnet-ransomware-2023-3118 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ff1235e5-c578-511d-a2ff-c8917ae728a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
