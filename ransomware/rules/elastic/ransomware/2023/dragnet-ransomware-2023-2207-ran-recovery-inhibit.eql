// Dragnet [Ransomware]: dragnet-ransomware-2023-2207 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d2e9fa6e-58e8-562a-a34d-4605b2b8fcf7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
