// Dragnet [Ransomware]: dragnet-ransomware-2023-1951 — Recovery Inhibition (unsafe)
// Status: deprecated | Level: high | ID: 5bba704c-925c-51cf-8461-7a346b51f57a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
