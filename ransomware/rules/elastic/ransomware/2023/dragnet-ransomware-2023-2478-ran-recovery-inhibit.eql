// Dragnet [Ransomware]: dragnet-ransomware-2023-2478 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e7d0768e-7041-5fca-bf80-b047ccb1ebd2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
