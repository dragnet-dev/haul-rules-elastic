// Dragnet [Ransomware]: dragnet-ransomware-2023-1129 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: da018f8d-eeea-5585-bada-65de61650752

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
