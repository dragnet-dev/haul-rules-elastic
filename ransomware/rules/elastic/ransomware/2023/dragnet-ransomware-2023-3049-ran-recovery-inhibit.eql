// Dragnet [Ransomware]: dragnet-ransomware-2023-3049 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4054e8e0-21b8-5e94-8cb5-7cad4c392d0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
