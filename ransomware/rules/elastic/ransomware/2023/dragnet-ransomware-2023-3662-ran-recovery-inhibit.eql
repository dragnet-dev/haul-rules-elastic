// Dragnet [Ransomware]: dragnet-ransomware-2023-3662 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 7606b207-213f-5940-96c2-b0a37e9f6766

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
