// Dragnet [Ransomware]: dragnet-ransomware-2023-2897 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: ceafce21-26c4-5059-ae39-621465da1a3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
