// Dragnet [Ransomware]: dragnet-ransomware-2023-0929 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5c5b70c3-7410-5de4-8fa4-c747be82f436

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
