// Dragnet [Ransomware]: dragnet-ransomware-2023-2560 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 96b0cb89-2f2d-5589-a5ca-5ee455398a3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
