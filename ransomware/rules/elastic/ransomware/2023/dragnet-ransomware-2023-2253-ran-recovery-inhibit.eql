// Dragnet [Ransomware]: dragnet-ransomware-2023-2253 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0e4b2f93-60d4-5c58-a69b-74883605ccb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
