// Dragnet [Ransomware]: dragnet-ransomware-2023-5341 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 08be4b4f-08ef-5367-806e-a23a945b44bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
