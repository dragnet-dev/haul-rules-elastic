// Dragnet [Ransomware]: dragnet-ransomware-2023-1263 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: eecd19d9-a16b-565b-a8ac-ad4eafa09a16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
