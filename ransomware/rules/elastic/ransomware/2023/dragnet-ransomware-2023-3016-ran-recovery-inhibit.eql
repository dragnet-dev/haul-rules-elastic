// Dragnet [Ransomware]: dragnet-ransomware-2023-3016 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 9df90ea9-733f-5fe2-a5a1-376b97d1f511

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
