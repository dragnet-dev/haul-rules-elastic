// Dragnet [Ransomware]: dragnet-ransomware-2023-1895 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6bada1bf-fa3a-5418-8835-fa3f921d5ae3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
