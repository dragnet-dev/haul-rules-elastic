// Dragnet [Ransomware]: dragnet-ransomware-2023-4390 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: b4396c58-1ecd-522f-8bee-068b30db0121

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
