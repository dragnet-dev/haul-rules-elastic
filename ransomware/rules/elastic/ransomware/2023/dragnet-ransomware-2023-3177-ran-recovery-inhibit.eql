// Dragnet [Ransomware]: dragnet-ransomware-2023-3177 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8966b633-d134-589f-9275-4696ba0a966a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
