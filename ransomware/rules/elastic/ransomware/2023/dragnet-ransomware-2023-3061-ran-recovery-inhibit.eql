// Dragnet [Ransomware]: dragnet-ransomware-2023-3061 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: ab187895-9756-5869-bc77-2b6326e17b9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
