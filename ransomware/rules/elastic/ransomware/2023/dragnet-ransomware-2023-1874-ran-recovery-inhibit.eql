// Dragnet [Ransomware]: dragnet-ransomware-2023-1874 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: a4544c76-f952-5044-a74a-097b926a216a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
