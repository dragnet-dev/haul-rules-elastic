// Dragnet [Ransomware]: dragnet-ransomware-2023-1693 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: b976a450-48fd-5838-a2f0-9b7ce63dd25a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
