// Dragnet [Ransomware]: dragnet-ransomware-2023-2056 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: d15b0c60-2378-5187-b199-09ad3f56a4bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
