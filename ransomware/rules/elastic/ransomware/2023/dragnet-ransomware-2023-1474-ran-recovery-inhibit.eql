// Dragnet [Ransomware]: dragnet-ransomware-2023-1474 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 73ebf23d-af5c-58ff-90f0-45ce038e790c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
