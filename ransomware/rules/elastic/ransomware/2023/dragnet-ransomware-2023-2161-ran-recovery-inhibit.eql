// Dragnet [Ransomware]: dragnet-ransomware-2023-2161 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: e061c3e6-76ed-5a67-b033-7047835ff00a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
