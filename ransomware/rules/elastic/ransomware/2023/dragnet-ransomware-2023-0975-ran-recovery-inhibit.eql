// Dragnet [Ransomware]: dragnet-ransomware-2023-0975 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: ee188921-317f-5523-9a4d-7722a03347f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
