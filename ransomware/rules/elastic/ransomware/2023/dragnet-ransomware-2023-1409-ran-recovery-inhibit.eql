// Dragnet [Ransomware]: dragnet-ransomware-2023-1409 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 7cf266f1-3815-5221-ad28-ae667837b00c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
