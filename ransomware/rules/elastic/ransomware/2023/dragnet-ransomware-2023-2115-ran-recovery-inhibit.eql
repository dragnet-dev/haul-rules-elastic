// Dragnet [Ransomware]: dragnet-ransomware-2023-2115 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 94818e9a-0a12-5cb3-8cbb-3d17b1f17c5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
