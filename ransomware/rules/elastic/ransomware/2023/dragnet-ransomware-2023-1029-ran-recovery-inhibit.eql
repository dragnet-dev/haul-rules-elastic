// Dragnet [Ransomware]: dragnet-ransomware-2023-1029 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: e3579911-f7c6-59ba-85c6-f501860a09aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
