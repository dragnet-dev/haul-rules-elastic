// Dragnet [Ransomware]: dragnet-ransomware-2023-1065 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 982c8515-b11f-5567-9a53-25d89e744d23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
