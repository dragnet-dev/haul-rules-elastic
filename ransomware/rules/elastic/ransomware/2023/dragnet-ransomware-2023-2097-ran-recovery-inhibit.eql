// Dragnet [Ransomware]: dragnet-ransomware-2023-2097 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5c971e3b-1bd5-50f7-824a-8108566bd4e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
