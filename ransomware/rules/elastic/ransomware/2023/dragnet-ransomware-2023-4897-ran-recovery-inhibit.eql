// Dragnet [Ransomware]: dragnet-ransomware-2023-4897 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 49b80471-a765-5066-a6c6-8dd78d09a13c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
