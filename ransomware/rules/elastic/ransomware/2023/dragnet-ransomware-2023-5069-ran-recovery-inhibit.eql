// Dragnet [Ransomware]: dragnet-ransomware-2023-5069 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 021c1aa3-5415-5cc0-9ae5-06cae00d40c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
