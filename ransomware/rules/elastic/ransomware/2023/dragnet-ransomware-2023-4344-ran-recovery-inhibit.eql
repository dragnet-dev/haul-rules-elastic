// Dragnet [Ransomware]: dragnet-ransomware-2023-4344 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 6c710af8-33c4-5845-9c45-c545e4a5e029

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
