// Dragnet [Ransomware]: dragnet-ransomware-2023-2891 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4ac84b78-b6d2-552d-ae43-15e94b14d0e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
