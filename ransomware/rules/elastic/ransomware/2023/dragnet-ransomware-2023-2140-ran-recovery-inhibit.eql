// Dragnet [Ransomware]: dragnet-ransomware-2023-2140 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f5bda034-a0ff-50ea-8c51-cb9248cf0ae3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
