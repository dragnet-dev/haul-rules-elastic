// Dragnet [Ransomware]: dragnet-ransomware-2023-1683 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5b684f72-ab77-55a1-9764-19a6dae9b327

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
