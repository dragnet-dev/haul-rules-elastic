// Dragnet [Ransomware]: dragnet-ransomware-2023-1223 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ee623756-9195-5002-807b-431c72595ce2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
