// Dragnet [Ransomware]: dragnet-ransomware-2023-1604 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 32164e6e-8a6e-56f3-92a1-5840d38a8f08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
