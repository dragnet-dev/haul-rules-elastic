// Dragnet [Ransomware]: dragnet-ransomware-2023-0302 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f2596b60-1954-54c7-855a-a1745b4af0c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
