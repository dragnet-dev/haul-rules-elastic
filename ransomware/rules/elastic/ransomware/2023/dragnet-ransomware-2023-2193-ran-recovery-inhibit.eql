// Dragnet [Ransomware]: dragnet-ransomware-2023-2193 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: c249e3e8-0321-532c-8d67-02498b69bec3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
