// Dragnet [Ransomware]: dragnet-ransomware-2023-4689 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 1a215fbd-b05d-5f93-a604-c08c7352feda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
