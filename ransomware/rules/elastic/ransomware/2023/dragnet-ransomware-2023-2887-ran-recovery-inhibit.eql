// Dragnet [Ransomware]: dragnet-ransomware-2023-2887 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 5e3ddf11-a652-5985-b1a5-efea3b2fa077

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
