// Dragnet [Ransomware]: dragnet-ransomware-2023-1442 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 7c4bc170-8f14-51e2-a42f-6cb71a59a2f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
