// Dragnet [Ransomware]: dragnet-ransomware-2023-1797 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: e0ced942-5fb9-5a13-8687-8488f46b9a64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
