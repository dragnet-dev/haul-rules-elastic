// Dragnet [Ransomware]: dragnet-ransomware-2023-3454 — Recovery Inhibition (cuba)
// Status: experimental | Level: high | ID: e262def1-06cd-5023-a2ef-aebb49faaac0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
