// Dragnet [Ransomware]: dragnet-ransomware-2023-1637 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e1db2aaf-ffad-5a40-9c79-a2d4e3bb056b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
