// Dragnet [Ransomware]: dragnet-ransomware-2023-2168 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 91cc9176-e303-5049-8e3b-92d6486ae2ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
