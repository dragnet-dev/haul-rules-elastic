// Dragnet [Ransomware]: dragnet-ransomware-2023-4963 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 346f34d1-9e71-5d58-9cb7-855ddf5fb5b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
