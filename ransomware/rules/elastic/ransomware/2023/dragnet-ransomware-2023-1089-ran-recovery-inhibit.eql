// Dragnet [Ransomware]: dragnet-ransomware-2023-1089 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 0100b2e4-f191-5859-b3c6-a796d4c93bd0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
