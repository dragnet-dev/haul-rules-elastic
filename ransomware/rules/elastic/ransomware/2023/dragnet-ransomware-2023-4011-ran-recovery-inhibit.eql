// Dragnet [Ransomware]: dragnet-ransomware-2023-4011 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 01e2428f-0907-5492-8283-4e31e905db7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
