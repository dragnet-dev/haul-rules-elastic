// Dragnet [Ransomware]: dragnet-ransomware-2023-3631 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d4ec461c-1c2e-5454-b36b-eebe631c24c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
