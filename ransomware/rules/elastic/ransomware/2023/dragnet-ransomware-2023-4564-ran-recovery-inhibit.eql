// Dragnet [Ransomware]: dragnet-ransomware-2023-4564 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: 68033462-bc93-5eb2-856d-20f14bd0d643

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
