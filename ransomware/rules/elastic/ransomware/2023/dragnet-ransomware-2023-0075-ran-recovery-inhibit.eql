// Dragnet [Ransomware]: dragnet-ransomware-2023-0075 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 53fb9a0f-c81d-5f2c-880b-0aca4e7e7b8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
