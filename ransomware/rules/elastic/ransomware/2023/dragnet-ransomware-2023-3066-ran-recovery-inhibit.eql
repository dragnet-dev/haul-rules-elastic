// Dragnet [Ransomware]: dragnet-ransomware-2023-3066 — Recovery Inhibition (rancoz)
// Status: experimental | Level: high | ID: 22e8d0ef-c0b4-5a4f-b7b8-84bc5f28f29f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
