// Dragnet [Ransomware]: dragnet-ransomware-2023-0158 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 9706dc68-7a6a-5992-912e-5c9ceabeb70a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
