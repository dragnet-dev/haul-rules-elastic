// Dragnet [Ransomware]: dragnet-ransomware-2023-0910 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: b1c8ae56-bbc2-5f44-9e83-b03803cde640

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
