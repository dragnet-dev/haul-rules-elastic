// Dragnet [Ransomware]: dragnet-ransomware-2023-2685 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: ebd4f552-c908-512e-972c-93da0907f435

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
