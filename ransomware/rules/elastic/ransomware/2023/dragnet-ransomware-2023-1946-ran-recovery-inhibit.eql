// Dragnet [Ransomware]: dragnet-ransomware-2023-1946 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 2e7b9371-fc5b-53b1-af74-975e83653223

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
