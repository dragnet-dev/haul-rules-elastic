// Dragnet [Ransomware]: dragnet-ransomware-2023-2265 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 908a7d3a-337d-511c-8ed7-dabaa2ef8715

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
