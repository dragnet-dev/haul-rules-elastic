// Dragnet [Ransomware]: dragnet-ransomware-2023-1581 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: d7992c5f-1345-5475-be30-a96780f7f07a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
