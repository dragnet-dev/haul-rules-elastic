// Dragnet [Ransomware]: dragnet-ransomware-2023-2581 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 87534eda-d109-513d-89a3-791897959c78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
