// Dragnet [Ransomware]: dragnet-ransomware-2023-2149 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0da3a573-cb3a-5c65-80c3-d4c8ea17a6a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
