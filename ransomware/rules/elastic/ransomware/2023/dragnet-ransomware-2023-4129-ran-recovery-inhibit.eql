// Dragnet [Ransomware]: dragnet-ransomware-2023-4129 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: c1ab2e99-74ca-51eb-a554-cd87dec94179

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
