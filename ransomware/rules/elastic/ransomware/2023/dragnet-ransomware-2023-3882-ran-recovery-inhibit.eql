// Dragnet [Ransomware]: dragnet-ransomware-2023-3882 — Recovery Inhibition (darkpower)
// Status: experimental | Level: high | ID: 96d3b978-5236-5af8-9ca6-61949bda264a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
