// Dragnet [Ransomware]: dragnet-ransomware-2023-0392 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: f5f23164-ae98-5ee8-be84-6cb8532946d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
