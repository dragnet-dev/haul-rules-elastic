// Dragnet [Ransomware]: dragnet-ransomware-2023-2464 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 2d27c35e-33c9-56a7-a862-3bdbfe2d0f2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
