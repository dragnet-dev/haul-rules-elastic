// Dragnet [Ransomware]: dragnet-ransomware-2023-4654 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: c11ff1b6-ef99-5344-9176-36a36c6a08fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
