// Dragnet [Ransomware]: dragnet-ransomware-2023-5328 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 40d81caa-b280-50b7-93aa-cba20dc27d9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
