// Dragnet [Ransomware]: dragnet-ransomware-2023-3046 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: b2337df1-9aaf-55da-9979-3492361106dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
