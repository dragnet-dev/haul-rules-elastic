// Dragnet [Ransomware]: dragnet-ransomware-2023-3915 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 9fe4bb6c-3128-5d9c-83ef-f45c8dd1fda8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
