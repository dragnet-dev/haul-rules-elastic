// Dragnet [Ransomware]: dragnet-ransomware-2023-4366 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: e41597cc-bd41-534e-85a2-a96a3228f103

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
