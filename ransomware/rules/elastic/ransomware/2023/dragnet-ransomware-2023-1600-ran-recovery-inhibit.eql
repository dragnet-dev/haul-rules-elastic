// Dragnet [Ransomware]: dragnet-ransomware-2023-1600 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7d15a337-8487-5274-b6e7-80f7da75831d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
