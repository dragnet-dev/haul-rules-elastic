// Dragnet [Ransomware]: dragnet-ransomware-2023-2738 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 91fa084e-fbd6-5203-a5d6-a6c377704c62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
