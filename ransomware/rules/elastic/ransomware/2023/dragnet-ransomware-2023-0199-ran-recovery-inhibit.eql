// Dragnet [Ransomware]: dragnet-ransomware-2023-0199 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: dbdf590a-1622-5723-b288-967fb4452502

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
