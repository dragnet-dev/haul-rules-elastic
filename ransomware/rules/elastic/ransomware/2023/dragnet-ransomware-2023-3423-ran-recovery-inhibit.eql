// Dragnet [Ransomware]: dragnet-ransomware-2023-3423 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: 860aee92-5ddf-5cbc-b6b0-a89e45e72abf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
