// Dragnet [Ransomware]: dragnet-ransomware-2023-5218 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5e4e41f8-24f4-5fa1-8476-8d4a6c700212

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
