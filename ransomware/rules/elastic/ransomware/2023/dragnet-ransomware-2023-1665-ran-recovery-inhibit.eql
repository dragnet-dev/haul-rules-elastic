// Dragnet [Ransomware]: dragnet-ransomware-2023-1665 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 7bfd1018-19dc-56c6-bae5-3b6fe1af3330

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
