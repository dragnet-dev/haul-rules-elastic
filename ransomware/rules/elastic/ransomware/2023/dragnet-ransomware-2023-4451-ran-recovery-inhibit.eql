// Dragnet [Ransomware]: dragnet-ransomware-2023-4451 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: bb8fb810-b439-5c1f-ad55-a43808c4a1e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
