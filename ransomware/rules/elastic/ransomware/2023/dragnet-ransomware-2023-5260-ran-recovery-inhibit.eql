// Dragnet [Ransomware]: dragnet-ransomware-2023-5260 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 57b2d75f-b28d-597a-a671-cd3050f07065

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
