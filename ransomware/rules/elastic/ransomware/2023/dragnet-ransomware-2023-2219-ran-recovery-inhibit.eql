// Dragnet [Ransomware]: dragnet-ransomware-2023-2219 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 96ca5229-c07e-5acb-91b5-4851bd3a2277

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
