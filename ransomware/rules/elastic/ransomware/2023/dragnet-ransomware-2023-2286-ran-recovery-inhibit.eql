// Dragnet [Ransomware]: dragnet-ransomware-2023-2286 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 7f799fd3-81f7-5f0c-b98d-45aad697ef32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
