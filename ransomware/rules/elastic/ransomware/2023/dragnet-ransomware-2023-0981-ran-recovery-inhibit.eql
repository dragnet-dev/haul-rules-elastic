// Dragnet [Ransomware]: dragnet-ransomware-2023-0981 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: f75ceeb0-cca2-5ce0-9322-db228c3ea249

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
