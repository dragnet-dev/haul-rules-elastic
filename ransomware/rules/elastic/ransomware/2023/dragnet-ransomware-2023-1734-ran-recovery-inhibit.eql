// Dragnet [Ransomware]: dragnet-ransomware-2023-1734 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a8fe9114-a5d0-5557-bba5-de9bfa63ee8f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
