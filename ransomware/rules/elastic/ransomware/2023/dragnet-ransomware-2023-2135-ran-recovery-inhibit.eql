// Dragnet [Ransomware]: dragnet-ransomware-2023-2135 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 82f8e4a4-dd28-5797-968b-41bac7924136

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
