// Dragnet [Ransomware]: dragnet-ransomware-2023-0063 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c2e52eac-985d-5e26-bebf-9b479454a054

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
