// Dragnet [Ransomware]: dragnet-ransomware-2023-4535 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 78d9ff44-21bd-5898-929c-593951f02bee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
