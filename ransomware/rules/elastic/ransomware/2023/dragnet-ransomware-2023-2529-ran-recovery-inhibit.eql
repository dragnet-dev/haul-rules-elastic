// Dragnet [Ransomware]: dragnet-ransomware-2023-2529 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 17f71bf8-b32c-54ed-83e2-1de2f4ae8634

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
