// Dragnet [Ransomware]: dragnet-ransomware-2023-3698 — Recovery Inhibition (darkrace)
// Status: experimental | Level: high | ID: a8164936-5005-5d7f-b932-481996e192d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
