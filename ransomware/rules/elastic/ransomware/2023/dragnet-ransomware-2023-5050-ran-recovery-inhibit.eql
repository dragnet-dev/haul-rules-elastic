// Dragnet [Ransomware]: dragnet-ransomware-2023-5050 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c141ff9a-b6dc-55c2-bbbd-8320205a5b0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
