// Dragnet [Ransomware]: dragnet-ransomware-2023-3709 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 2e3980f9-802e-5eb5-848f-2b9cc769e1bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
