// Dragnet [Ransomware]: dragnet-ransomware-2023-4571 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 4c400d2e-0f58-563c-b8e4-2b105cc3c9d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
