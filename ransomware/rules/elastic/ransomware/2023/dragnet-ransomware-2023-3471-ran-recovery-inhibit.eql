// Dragnet [Ransomware]: dragnet-ransomware-2023-3471 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: efb3d52f-7bba-58fb-94ad-c776c5f640fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
