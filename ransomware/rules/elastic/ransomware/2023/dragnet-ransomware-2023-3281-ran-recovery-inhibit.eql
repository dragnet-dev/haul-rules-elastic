// Dragnet [Ransomware]: dragnet-ransomware-2023-3281 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 08a35646-7092-5f58-8025-219fba70aea1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
