// Dragnet [Ransomware]: dragnet-ransomware-2023-4211 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cd644e6f-671c-5568-aa67-f7c5490436e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
