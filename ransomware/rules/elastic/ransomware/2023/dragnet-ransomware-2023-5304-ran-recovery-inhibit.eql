// Dragnet [Ransomware]: dragnet-ransomware-2023-5304 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5d7b46de-91e7-5981-a912-3b7fc462a88f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
