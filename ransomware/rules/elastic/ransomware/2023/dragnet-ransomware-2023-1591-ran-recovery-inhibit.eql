// Dragnet [Ransomware]: dragnet-ransomware-2023-1591 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 8bbcf26e-ccbf-5ff7-8b81-165b9b75a01b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
