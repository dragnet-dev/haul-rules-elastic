// Dragnet [Ransomware]: dragnet-ransomware-2023-1321 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 7d20aec9-1f90-5aa3-8710-44a293368a56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
