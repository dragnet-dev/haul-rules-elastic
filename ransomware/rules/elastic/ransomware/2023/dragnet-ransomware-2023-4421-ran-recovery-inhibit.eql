// Dragnet [Ransomware]: dragnet-ransomware-2023-4421 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 06d1d563-5f89-5b75-a9be-7b835fd62a3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
