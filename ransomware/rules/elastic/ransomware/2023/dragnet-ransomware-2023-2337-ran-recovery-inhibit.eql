// Dragnet [Ransomware]: dragnet-ransomware-2023-2337 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 1a21688f-037f-5c5b-a6b5-d6c1f5436b5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
