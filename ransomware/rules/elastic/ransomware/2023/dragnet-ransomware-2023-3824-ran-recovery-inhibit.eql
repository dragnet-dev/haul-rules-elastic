// Dragnet [Ransomware]: dragnet-ransomware-2023-3824 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: aebae295-1813-5e8c-9826-966714053999

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
