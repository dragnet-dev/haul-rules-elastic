// Dragnet [Ransomware]: dragnet-ransomware-2023-0523 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: cf004e33-339d-503e-bdb8-ff769d63fbba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
