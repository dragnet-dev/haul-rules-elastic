// Dragnet [Ransomware]: dragnet-ransomware-2023-2722 — Recovery Inhibition (moneymessage)
// Status: experimental | Level: high | ID: 5bd9552a-25a5-57bb-bacc-7f376e303230

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
