// Dragnet [Ransomware]: dragnet-ransomware-2023-4546 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: dccc4775-ffab-58e1-af65-6bdf9eb116a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
