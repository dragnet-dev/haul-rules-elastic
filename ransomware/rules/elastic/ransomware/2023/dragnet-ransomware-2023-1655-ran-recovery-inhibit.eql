// Dragnet [Ransomware]: dragnet-ransomware-2023-1655 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: b158e56a-23cf-54bc-b7be-50570017b205

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
