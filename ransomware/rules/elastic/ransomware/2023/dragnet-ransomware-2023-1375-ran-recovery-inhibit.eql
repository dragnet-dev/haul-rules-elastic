// Dragnet [Ransomware]: dragnet-ransomware-2023-1375 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: de7c7ad2-01bc-5c7f-9d42-08e98fb17a26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
