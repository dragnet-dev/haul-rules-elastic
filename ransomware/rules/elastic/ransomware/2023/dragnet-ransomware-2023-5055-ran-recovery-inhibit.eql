// Dragnet [Ransomware]: dragnet-ransomware-2023-5055 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 2da37534-a7eb-5448-98f3-43bd27ccb62e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
