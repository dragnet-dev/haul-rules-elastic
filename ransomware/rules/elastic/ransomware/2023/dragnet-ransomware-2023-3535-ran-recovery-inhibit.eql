// Dragnet [Ransomware]: dragnet-ransomware-2023-3535 — Recovery Inhibition (siegedsec)
// Status: experimental | Level: high | ID: d9f35f75-49b6-59d2-8cc7-b867a3863c70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
