// Dragnet [Ransomware]: dragnet-ransomware-2023-1651 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 89b4d872-0909-535d-8581-05c8bd732606

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
