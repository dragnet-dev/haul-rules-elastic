// Dragnet [Ransomware]: dragnet-ransomware-2023-0366 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 19f22c49-fee3-5b00-b1b7-60a6d7d69131

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
