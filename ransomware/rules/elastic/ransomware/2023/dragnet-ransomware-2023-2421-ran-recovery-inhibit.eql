// Dragnet [Ransomware]: dragnet-ransomware-2023-2421 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: f052e20b-c282-5260-9089-16393f71a760

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
