// Dragnet [Ransomware]: dragnet-ransomware-2023-4093 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 633882f5-484f-5ca4-a5a5-d1a9223226f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
