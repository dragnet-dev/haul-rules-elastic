// Dragnet [Ransomware]: dragnet-ransomware-2023-3217 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 6c93661b-f337-587d-a82b-fed0c310edcf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
