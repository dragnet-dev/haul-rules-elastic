// Dragnet [Ransomware]: dragnet-ransomware-2023-1970 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fbfdada6-fa19-5470-8022-1a0350ecc397

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
