// Dragnet [Ransomware]: dragnet-ransomware-2023-1526 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 4ec4f895-3161-5be2-9e92-da9efb7f20aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
