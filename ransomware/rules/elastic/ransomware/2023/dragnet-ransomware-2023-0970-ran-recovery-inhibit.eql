// Dragnet [Ransomware]: dragnet-ransomware-2023-0970 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 4a19fc62-ac56-5881-9723-8e3647337eae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
