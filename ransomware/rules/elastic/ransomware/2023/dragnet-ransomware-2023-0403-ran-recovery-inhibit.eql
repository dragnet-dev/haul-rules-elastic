// Dragnet [Ransomware]: dragnet-ransomware-2023-0403 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f3e5c15b-46ff-5a35-bcff-429dba8213f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
