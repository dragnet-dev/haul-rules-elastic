// Dragnet [Ransomware]: dragnet-ransomware-2023-3231 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: 4d425369-1bd0-5cb5-8df5-fbb160d43c51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
