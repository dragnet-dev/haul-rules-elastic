// Dragnet [Ransomware]: dragnet-ransomware-2023-0702 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 622abbd0-6c66-5ffa-9f92-563d3b726235

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
