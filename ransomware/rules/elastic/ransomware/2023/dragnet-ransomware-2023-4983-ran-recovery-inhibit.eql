// Dragnet [Ransomware]: dragnet-ransomware-2023-4983 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9182b92a-82dd-508b-8d65-c7977ddd0834

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
