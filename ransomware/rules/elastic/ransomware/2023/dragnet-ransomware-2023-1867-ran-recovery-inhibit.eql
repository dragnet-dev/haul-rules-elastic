// Dragnet [Ransomware]: dragnet-ransomware-2023-1867 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 515b7556-110f-5fd5-8817-c6eecaa072d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
