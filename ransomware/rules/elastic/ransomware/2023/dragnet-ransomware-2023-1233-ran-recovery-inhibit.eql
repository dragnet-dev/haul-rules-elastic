// Dragnet [Ransomware]: dragnet-ransomware-2023-1233 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 65bd0123-a2db-5056-9f42-59ad916dad5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
