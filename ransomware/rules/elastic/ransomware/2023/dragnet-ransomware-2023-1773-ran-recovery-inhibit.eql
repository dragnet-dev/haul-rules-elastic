// Dragnet [Ransomware]: dragnet-ransomware-2023-1773 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 9b4325e9-e240-57f0-aa43-7b710fc68eb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
