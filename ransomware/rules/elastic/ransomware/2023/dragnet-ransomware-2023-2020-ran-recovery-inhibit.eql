// Dragnet [Ransomware]: dragnet-ransomware-2023-2020 — Recovery Inhibition (werewolves)
// Status: experimental | Level: high | ID: 38e020fd-f6a8-5305-bf76-c620ceeeba4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
