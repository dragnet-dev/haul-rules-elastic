// Dragnet [Ransomware]: dragnet-ransomware-2023-4976 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8c047841-21bf-55ec-9597-2b645ce58333

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
