// Dragnet [Ransomware]: dragnet-ransomware-2023-0719 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 43e31207-b35b-5d74-b3a8-5216aa4aadc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
