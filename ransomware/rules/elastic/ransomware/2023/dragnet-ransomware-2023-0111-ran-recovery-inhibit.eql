// Dragnet [Ransomware]: dragnet-ransomware-2023-0111 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: dd529bf7-5cdb-5855-a31b-fd3a85d5c610

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
