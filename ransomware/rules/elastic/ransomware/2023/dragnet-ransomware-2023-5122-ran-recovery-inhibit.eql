// Dragnet [Ransomware]: dragnet-ransomware-2023-5122 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 21f16438-1a38-5564-af0b-11ababe026d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
