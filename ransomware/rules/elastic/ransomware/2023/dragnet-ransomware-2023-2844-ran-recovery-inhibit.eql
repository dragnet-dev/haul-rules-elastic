// Dragnet [Ransomware]: dragnet-ransomware-2023-2844 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 77f4eb16-5c2a-57fb-b871-1a48f8a3d0f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
