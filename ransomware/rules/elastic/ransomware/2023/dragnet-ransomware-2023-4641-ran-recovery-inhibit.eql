// Dragnet [Ransomware]: dragnet-ransomware-2023-4641 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 4ce5e089-d67d-5818-82af-beb94a184660

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
