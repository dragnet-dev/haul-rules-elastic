// Dragnet [Ransomware]: dragnet-ransomware-2023-3387 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 019f0edb-3ab1-5a05-b2fb-e4203f90dcd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
