// Dragnet [Ransomware]: dragnet-ransomware-2023-4547 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6d40840a-640f-59cc-bee6-494312e5b44a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
