// Dragnet [Ransomware]: dragnet-ransomware-2023-4927 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: ad1eb2c4-4871-585f-90da-4d7958b34854

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
