// Dragnet [Ransomware]: dragnet-ransomware-2023-2811 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: a78e233c-740d-5d4c-b8cd-53dc43dd7a32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
