// Dragnet [Ransomware]: dragnet-ransomware-2023-0587 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 80e9e655-eec1-5e03-8700-935406fdcda6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
