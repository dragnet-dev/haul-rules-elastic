// Dragnet [Ransomware]: dragnet-ransomware-2023-1381 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 7ae8fb52-af58-5661-99d8-13f261160f47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
