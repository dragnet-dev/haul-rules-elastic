// Dragnet [Ransomware]: dragnet-ransomware-2023-2909 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 3a0c9e96-ef84-56fb-93a7-e683553f8f5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
