// Dragnet [Ransomware]: dragnet-ransomware-2023-3018 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8f58b8b8-188e-5160-8fea-69ddf9363e77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
