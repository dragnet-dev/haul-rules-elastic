// Dragnet [Ransomware]: dragnet-ransomware-2023-0616 — Recovery Inhibition (raznatovic)
// Status: deprecated | Level: high | ID: fa73eedd-a6cc-582e-80fa-f947290259a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
