// Dragnet [Ransomware]: dragnet-ransomware-2023-2507 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b01201d9-ea9f-570f-a798-710bd4cc0f92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
