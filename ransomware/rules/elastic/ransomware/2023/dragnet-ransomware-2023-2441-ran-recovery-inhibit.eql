// Dragnet [Ransomware]: dragnet-ransomware-2023-2441 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 332a7a01-ae65-567e-8eed-4731c7302da8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
