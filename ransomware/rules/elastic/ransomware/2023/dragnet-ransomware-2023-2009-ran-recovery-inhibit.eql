// Dragnet [Ransomware]: dragnet-ransomware-2023-2009 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 57221a70-1341-5335-b894-a93c79dc1690

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
