// Dragnet [Ransomware]: dragnet-ransomware-2023-2808 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 5f266cb3-586f-5a5d-91c7-08fefc48f3a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
