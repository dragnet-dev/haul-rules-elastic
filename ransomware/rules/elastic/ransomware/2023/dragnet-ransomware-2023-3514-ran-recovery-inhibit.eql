// Dragnet [Ransomware]: dragnet-ransomware-2023-3514 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: d0981b8a-4aba-5078-9591-4acc8ebc7bf9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
