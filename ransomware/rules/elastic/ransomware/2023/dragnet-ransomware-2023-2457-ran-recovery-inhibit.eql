// Dragnet [Ransomware]: dragnet-ransomware-2023-2457 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 36cf4ec6-6e55-5f88-84e6-28020eef9bac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
