// Dragnet [Ransomware]: dragnet-ransomware-2023-1171 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: d6409dc6-e83c-5e51-890f-e1a027ef0175

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
