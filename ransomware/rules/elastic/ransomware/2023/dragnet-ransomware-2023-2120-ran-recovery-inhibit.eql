// Dragnet [Ransomware]: dragnet-ransomware-2023-2120 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: cec37221-6635-52c4-a634-6055d8bbe474

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
