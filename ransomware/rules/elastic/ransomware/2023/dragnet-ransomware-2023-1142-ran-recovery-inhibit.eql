// Dragnet [Ransomware]: dragnet-ransomware-2023-1142 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 0f97f699-0e53-5f2d-b61e-1ff89bcf2975

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
