// Dragnet [Ransomware]: dragnet-ransomware-2023-3506 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 482e96b4-38c0-5a0b-a51a-800ba7855064

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
