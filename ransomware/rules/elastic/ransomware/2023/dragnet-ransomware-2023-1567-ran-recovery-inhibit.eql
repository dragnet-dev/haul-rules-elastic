// Dragnet [Ransomware]: dragnet-ransomware-2023-1567 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 346e580a-c33a-5ce9-a907-6563b1426e09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
