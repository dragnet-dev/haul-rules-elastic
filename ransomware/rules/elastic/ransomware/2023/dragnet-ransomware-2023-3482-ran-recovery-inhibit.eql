// Dragnet [Ransomware]: dragnet-ransomware-2023-3482 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 3c9f9e98-efd2-5d3e-b8b4-057bd26ec287

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
