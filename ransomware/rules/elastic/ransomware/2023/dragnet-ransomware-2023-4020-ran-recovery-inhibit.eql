// Dragnet [Ransomware]: dragnet-ransomware-2023-4020 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 8cfcaa56-5605-5b6c-89d4-8e2cc23d5b62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
