// Dragnet [Ransomware]: dragnet-ransomware-2023-1530 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 830858aa-3a11-5f61-b20a-be2cea463f76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
