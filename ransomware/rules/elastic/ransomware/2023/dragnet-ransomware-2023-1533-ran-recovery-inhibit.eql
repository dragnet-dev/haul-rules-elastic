// Dragnet [Ransomware]: dragnet-ransomware-2023-1533 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: e16d3472-6f29-5634-b8ab-e34b0c895b2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
