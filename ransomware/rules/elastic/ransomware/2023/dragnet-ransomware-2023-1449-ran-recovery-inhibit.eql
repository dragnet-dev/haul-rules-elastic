// Dragnet [Ransomware]: dragnet-ransomware-2023-1449 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 1b91c73e-c32e-5ed3-8a94-02509ce2b4bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
