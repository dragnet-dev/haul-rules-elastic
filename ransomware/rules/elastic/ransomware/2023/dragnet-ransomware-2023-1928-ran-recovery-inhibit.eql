// Dragnet [Ransomware]: dragnet-ransomware-2023-1928 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 46ce6e87-70a2-5394-ba29-fdf3ab00da39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
