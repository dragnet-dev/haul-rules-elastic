// Dragnet [Ransomware]: dragnet-ransomware-2023-1071 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 59a710ba-6c14-5443-b9f2-b8cd38a8deab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
