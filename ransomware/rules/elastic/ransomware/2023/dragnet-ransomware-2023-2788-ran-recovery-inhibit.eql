// Dragnet [Ransomware]: dragnet-ransomware-2023-2788 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: fa615c54-fc92-5001-823c-bde51fc5415c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
