// Dragnet [Ransomware]: dragnet-ransomware-2023-4251 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 841fea63-2f89-54e9-9acb-53bb145946d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
