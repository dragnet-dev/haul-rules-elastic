// Dragnet [Ransomware]: dragnet-ransomware-2023-1240 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 2222f056-377e-57e5-8616-ca28edf240bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
