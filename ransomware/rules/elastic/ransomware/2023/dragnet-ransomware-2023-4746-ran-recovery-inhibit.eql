// Dragnet [Ransomware]: dragnet-ransomware-2023-4746 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2691ef4b-2df8-5493-836f-92c244c05f96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
