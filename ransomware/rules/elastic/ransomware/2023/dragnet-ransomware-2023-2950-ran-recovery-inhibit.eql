// Dragnet [Ransomware]: dragnet-ransomware-2023-2950 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 46190dab-d37b-540c-ac60-a602dbe34c65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
