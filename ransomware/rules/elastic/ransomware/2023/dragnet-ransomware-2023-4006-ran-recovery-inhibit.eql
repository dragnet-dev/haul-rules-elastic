// Dragnet [Ransomware]: dragnet-ransomware-2023-4006 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 39a4f90e-4eb1-547a-8949-2b946c6fae3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
