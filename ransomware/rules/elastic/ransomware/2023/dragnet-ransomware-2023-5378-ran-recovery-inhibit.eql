// Dragnet [Ransomware]: dragnet-ransomware-2023-5378 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 2fdcefc8-6442-5652-a610-1c3d3edc26a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
