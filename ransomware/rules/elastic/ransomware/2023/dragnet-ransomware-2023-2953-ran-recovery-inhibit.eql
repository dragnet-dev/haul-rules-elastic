// Dragnet [Ransomware]: dragnet-ransomware-2023-2953 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 9fa069ef-5bc9-5521-9793-d6e55e55f3b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
