// Dragnet [Ransomware]: dragnet-ransomware-2023-1362 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 1c8794ae-9d30-51a5-970e-a02782fb027d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
