// Dragnet [Ransomware]: dragnet-ransomware-2023-1162 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: ce7a7714-59f7-598b-aa66-191ee1f356c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
