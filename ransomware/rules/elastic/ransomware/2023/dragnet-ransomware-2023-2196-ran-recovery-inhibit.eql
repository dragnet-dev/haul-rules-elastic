// Dragnet [Ransomware]: dragnet-ransomware-2023-2196 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 65f7c57c-1980-57cb-962d-1039ce479a5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
