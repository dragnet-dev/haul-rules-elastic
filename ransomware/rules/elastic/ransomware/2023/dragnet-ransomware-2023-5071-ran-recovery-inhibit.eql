// Dragnet [Ransomware]: dragnet-ransomware-2023-5071 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4883ee95-053c-516f-85e7-f8309e8918ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
