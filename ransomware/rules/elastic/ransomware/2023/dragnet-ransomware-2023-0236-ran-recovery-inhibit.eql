// Dragnet [Ransomware]: dragnet-ransomware-2023-0236 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 6e5eee11-db95-5327-8efe-8c75ed3777af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
