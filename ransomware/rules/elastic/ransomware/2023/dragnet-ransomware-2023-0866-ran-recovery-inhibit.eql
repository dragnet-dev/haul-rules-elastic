// Dragnet [Ransomware]: dragnet-ransomware-2023-0866 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 69fc3a0b-07a0-581e-aeab-70f1463a7595

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
