// Dragnet [Ransomware]: dragnet-ransomware-2023-4914 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 34dbeed2-b32b-503e-93d5-5b20ddf9643d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
