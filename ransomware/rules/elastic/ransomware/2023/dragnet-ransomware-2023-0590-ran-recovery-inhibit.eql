// Dragnet [Ransomware]: dragnet-ransomware-2023-0590 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c7b84bb1-79ec-5a20-b12f-a4a0164749a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
