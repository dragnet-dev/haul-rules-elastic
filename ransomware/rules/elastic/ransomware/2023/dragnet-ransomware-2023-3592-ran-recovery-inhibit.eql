// Dragnet [Ransomware]: dragnet-ransomware-2023-3592 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: b1f0fd5c-6f33-58d5-bf4a-b672d964a79c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
