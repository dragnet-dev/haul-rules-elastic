// Dragnet [Ransomware]: dragnet-ransomware-2023-1927 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4995ff38-6833-5705-b5f2-9c2474a0ef6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
