// Dragnet [Ransomware]: dragnet-ransomware-2023-4033 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1eb57dfa-2614-5c3f-8f54-664df7e513ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
