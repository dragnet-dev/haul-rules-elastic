// Dragnet [Ransomware]: dragnet-ransomware-2023-2622 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 76da56b5-a4ae-5e3a-afb7-2feda0bbdb38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
