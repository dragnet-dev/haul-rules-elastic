// Dragnet [Ransomware]: dragnet-ransomware-2023-0107 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: d4e0dcf9-7744-5bc5-aaad-05ff2522ddf4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
