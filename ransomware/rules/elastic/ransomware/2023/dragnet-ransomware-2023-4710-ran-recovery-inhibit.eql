// Dragnet [Ransomware]: dragnet-ransomware-2023-4710 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 49ec9abf-c385-5c14-9557-2bfeaf6fe0c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
