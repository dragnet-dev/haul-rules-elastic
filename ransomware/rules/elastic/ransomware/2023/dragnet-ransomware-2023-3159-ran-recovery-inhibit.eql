// Dragnet [Ransomware]: dragnet-ransomware-2023-3159 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 6e1cef10-5756-5769-91dc-e13f360462d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
