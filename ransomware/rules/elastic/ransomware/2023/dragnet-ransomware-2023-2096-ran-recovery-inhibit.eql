// Dragnet [Ransomware]: dragnet-ransomware-2023-2096 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 17f29b4a-0be7-5009-b985-c545361649fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
