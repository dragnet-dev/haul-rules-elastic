// Dragnet [Ransomware]: dragnet-ransomware-2023-4219 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 00cb0300-38b3-5003-8523-ee04452d2101

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
