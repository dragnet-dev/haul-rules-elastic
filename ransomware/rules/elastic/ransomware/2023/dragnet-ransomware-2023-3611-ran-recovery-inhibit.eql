// Dragnet [Ransomware]: dragnet-ransomware-2023-3611 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: c44c169f-a177-5db6-8d9b-8ced8f2aa863

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
