// Dragnet [Ransomware]: dragnet-ransomware-2023-1278 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 9aabc513-18e7-5048-92ee-90adfba8c1c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
