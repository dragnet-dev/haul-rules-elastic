// Dragnet [Ransomware]: dragnet-ransomware-2023-4231 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ae7c8733-b88b-5e73-bf0f-59ea7e430831

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
