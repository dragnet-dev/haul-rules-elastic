// Dragnet [Ransomware]: dragnet-ransomware-2023-5168 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: adec54ac-4a28-587c-bc3b-8b446855f865

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
