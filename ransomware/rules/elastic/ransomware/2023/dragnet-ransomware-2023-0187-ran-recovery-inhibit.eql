// Dragnet [Ransomware]: dragnet-ransomware-2023-0187 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: e56603a9-e515-5df9-b1c9-12dda5faaa9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
