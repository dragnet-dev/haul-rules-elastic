// Dragnet [Ransomware]: dragnet-ransomware-2023-4052 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1133d920-4328-515d-bc10-f66aef074bd7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
