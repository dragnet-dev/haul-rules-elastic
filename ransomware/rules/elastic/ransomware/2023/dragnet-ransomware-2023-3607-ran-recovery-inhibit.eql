// Dragnet [Ransomware]: dragnet-ransomware-2023-3607 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f83f057c-9aaa-5ed8-b7b6-922d9154010a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
