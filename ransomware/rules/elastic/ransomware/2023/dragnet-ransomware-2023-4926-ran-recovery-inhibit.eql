// Dragnet [Ransomware]: dragnet-ransomware-2023-4926 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 9496308a-b0a6-5b1f-b033-9caed157a882

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
