// Dragnet [Ransomware]: dragnet-ransomware-2023-5255 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: fa941c7c-aece-53c0-9c5b-8a05f8f8256f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
