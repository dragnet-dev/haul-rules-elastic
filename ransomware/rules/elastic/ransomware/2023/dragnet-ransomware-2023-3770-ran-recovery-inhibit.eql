// Dragnet [Ransomware]: dragnet-ransomware-2023-3770 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: ad600b87-a0c7-5723-90cb-17e3bb628665

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
