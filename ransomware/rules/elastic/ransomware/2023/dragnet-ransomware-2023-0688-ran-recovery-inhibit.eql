// Dragnet [Ransomware]: dragnet-ransomware-2023-0688 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: a53ae63f-0cef-58af-84d1-2da001ef592c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
