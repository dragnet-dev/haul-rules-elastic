// Dragnet [Ransomware]: dragnet-ransomware-2023-3909 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 860e740d-9a14-50d0-bdee-9b7148bb0f41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
