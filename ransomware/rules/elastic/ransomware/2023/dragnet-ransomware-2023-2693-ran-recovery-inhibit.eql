// Dragnet [Ransomware]: dragnet-ransomware-2023-2693 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: 86662dae-4187-5015-8755-98cfe995169a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
