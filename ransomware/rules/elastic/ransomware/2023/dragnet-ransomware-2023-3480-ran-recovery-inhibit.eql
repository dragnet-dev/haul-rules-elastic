// Dragnet [Ransomware]: dragnet-ransomware-2023-3480 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ab1f2668-55ff-58fc-b895-b779ddc7838e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
