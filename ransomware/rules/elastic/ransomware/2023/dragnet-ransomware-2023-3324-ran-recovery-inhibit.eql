// Dragnet [Ransomware]: dragnet-ransomware-2023-3324 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: bb83b3ac-8cf7-5c6b-b08a-7908bab1d99d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
