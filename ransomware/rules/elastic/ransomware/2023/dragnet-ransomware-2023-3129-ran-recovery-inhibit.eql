// Dragnet [Ransomware]: dragnet-ransomware-2023-3129 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 2b49345c-67d9-5768-96e6-a445afd4cc93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
