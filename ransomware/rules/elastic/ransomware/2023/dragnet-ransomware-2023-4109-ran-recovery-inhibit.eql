// Dragnet [Ransomware]: dragnet-ransomware-2023-4109 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 97f25816-dbf6-5310-8e60-5282ae204d8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
