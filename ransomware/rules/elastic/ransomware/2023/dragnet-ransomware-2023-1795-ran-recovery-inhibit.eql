// Dragnet [Ransomware]: dragnet-ransomware-2023-1795 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5049aac7-aa99-50c0-ae78-99cfbeaa2293

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
