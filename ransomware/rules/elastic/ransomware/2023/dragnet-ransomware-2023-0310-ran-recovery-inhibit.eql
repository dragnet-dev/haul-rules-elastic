// Dragnet [Ransomware]: dragnet-ransomware-2023-0310 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8f2a4098-740d-5824-a621-7ec5033d294d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
