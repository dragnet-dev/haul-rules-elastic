// Dragnet [Ransomware]: dragnet-ransomware-2023-1823 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: f9dd8c09-bfda-5f68-8f1e-bafc8e79f58f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
