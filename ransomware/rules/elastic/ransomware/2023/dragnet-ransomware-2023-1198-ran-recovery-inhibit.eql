// Dragnet [Ransomware]: dragnet-ransomware-2023-1198 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 6ac3fcbd-da9d-59cb-9a20-ccb9b88aded3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
