// Dragnet [Ransomware]: dragnet-ransomware-2023-4505 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 9e090e4d-00b7-537a-880f-f1e59ac753f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
