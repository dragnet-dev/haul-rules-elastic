// Dragnet [Ransomware]: dragnet-ransomware-2023-1268 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8fb3888a-9012-5ccd-b568-22394f818ec8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
