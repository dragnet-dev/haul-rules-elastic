// Dragnet [Ransomware]: dragnet-ransomware-2023-0209 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: fa620260-5072-5683-89d4-6d516190bdca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
