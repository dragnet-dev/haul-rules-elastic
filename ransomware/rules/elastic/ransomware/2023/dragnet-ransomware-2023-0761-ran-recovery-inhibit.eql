// Dragnet [Ransomware]: dragnet-ransomware-2023-0761 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ced79231-17e9-5394-83bd-fb9f75b09092

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
