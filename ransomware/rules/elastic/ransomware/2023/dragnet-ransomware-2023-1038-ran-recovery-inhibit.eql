// Dragnet [Ransomware]: dragnet-ransomware-2023-1038 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 0e892fe8-afc6-555c-9456-801d9c2f736a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
