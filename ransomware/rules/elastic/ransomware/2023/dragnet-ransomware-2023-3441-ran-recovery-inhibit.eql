// Dragnet [Ransomware]: dragnet-ransomware-2023-3441 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 6a133fad-077e-5fbb-9b92-90c5c0751916

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
