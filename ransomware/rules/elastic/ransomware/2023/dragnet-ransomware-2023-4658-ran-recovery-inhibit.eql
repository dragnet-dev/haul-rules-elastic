// Dragnet [Ransomware]: dragnet-ransomware-2023-4658 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 85c04663-c278-5155-b82e-20df9eac9198

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
