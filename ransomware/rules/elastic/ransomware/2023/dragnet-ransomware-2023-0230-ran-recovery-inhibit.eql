// Dragnet [Ransomware]: dragnet-ransomware-2023-0230 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: e156d6fe-b22d-5d5b-8514-7880b2133a36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
