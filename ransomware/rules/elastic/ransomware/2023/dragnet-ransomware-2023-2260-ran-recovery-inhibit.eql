// Dragnet [Ransomware]: dragnet-ransomware-2023-2260 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a9d4a7b9-6a73-5a5d-bf50-28dead6bdc27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
