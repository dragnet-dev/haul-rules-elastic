// Dragnet [Ransomware]: dragnet-ransomware-2023-3331 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 3dacc790-fc25-50e5-903c-74885fd50d62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
