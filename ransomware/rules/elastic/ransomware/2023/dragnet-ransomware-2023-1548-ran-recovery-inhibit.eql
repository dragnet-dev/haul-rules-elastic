// Dragnet [Ransomware]: dragnet-ransomware-2023-1548 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 31fa98a7-c5db-59df-be56-3b30c8bcb01f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
