// Dragnet [Ransomware]: dragnet-ransomware-2023-1005 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 487d2a08-3e24-5b4a-af6e-3e7cee97bf8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
