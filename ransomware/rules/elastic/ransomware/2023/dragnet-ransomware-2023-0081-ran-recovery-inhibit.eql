// Dragnet [Ransomware]: dragnet-ransomware-2023-0081 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 81c99050-a0d3-511c-9a7d-e96ea0de9614

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
