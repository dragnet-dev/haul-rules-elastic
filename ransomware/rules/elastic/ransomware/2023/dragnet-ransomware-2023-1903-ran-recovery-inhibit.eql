// Dragnet [Ransomware]: dragnet-ransomware-2023-1903 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 9c625be4-1b92-5531-8773-77beef8f6375

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
