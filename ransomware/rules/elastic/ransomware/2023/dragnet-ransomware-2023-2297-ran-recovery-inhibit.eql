// Dragnet [Ransomware]: dragnet-ransomware-2023-2297 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: aba83022-ff35-53d8-900e-9b75571ab140

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
