// Dragnet [Ransomware]: dragnet-ransomware-2023-3561 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 2a7994f6-c2dc-5cb8-9217-7b07a842749f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
