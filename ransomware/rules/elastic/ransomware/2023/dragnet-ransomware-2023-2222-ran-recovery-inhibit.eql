// Dragnet [Ransomware]: dragnet-ransomware-2023-2222 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: eb6aee29-4df4-51c5-abbb-b11207506039

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
