// Dragnet [Ransomware]: dragnet-ransomware-2023-0881 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 83e1fe5c-9cef-5a46-a87d-10f81f9e1b24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
