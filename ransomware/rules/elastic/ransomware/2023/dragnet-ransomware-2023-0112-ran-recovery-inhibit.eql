// Dragnet [Ransomware]: dragnet-ransomware-2023-0112 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 2ef529fe-79c8-5b60-a724-4e1d8508e90c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
