// Dragnet [Ransomware]: dragnet-ransomware-2023-5316 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 7aafa65f-9e57-52d9-a25f-18e60f997774

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
