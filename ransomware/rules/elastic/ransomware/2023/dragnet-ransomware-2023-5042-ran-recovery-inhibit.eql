// Dragnet [Ransomware]: dragnet-ransomware-2023-5042 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 37564db4-9abc-57fc-8bf4-4d6bfa4c9296

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
