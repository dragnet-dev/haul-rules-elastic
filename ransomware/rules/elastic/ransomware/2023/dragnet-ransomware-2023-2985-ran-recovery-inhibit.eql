// Dragnet [Ransomware]: dragnet-ransomware-2023-2985 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7a8889cc-3b1e-55de-9de5-4bdeab978aba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
