// Dragnet [Ransomware]: dragnet-ransomware-2023-5097 — Recovery Inhibition (mallox)
// Status: experimental | Level: high | ID: 93889842-f118-5f22-af42-265f8103f218

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
