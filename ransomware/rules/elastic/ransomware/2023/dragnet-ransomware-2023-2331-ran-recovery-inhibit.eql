// Dragnet [Ransomware]: dragnet-ransomware-2023-2331 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d1026e21-b070-5d05-ae92-23eed8931d9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
