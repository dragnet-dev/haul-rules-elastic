// Dragnet [Ransomware]: dragnet-ransomware-2023-1288 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 7d2c5599-233c-5820-a9fe-6a7fb6c0a73c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
