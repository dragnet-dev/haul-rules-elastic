// Dragnet [Ransomware]: dragnet-ransomware-2023-2400 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f0964655-21b4-585e-a768-419a411a1b7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
