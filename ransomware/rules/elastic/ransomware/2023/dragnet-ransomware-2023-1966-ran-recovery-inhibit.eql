// Dragnet [Ransomware]: dragnet-ransomware-2023-1966 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: b2b917b1-6e95-5469-8a53-d4c7b384df8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
