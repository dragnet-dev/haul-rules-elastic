// Dragnet [Ransomware]: dragnet-ransomware-2023-3923 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 198aa8c8-a546-5fea-afba-918a43046413

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
