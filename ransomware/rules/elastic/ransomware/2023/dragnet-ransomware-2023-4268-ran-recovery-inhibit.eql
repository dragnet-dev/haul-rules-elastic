// Dragnet [Ransomware]: dragnet-ransomware-2023-4268 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: d4d6d6c0-ec8f-503d-92a8-e3ded4f7f3b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
