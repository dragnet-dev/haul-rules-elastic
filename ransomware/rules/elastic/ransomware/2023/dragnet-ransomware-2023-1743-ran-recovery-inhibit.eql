// Dragnet [Ransomware]: dragnet-ransomware-2023-1743 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 235c102f-1234-5952-b293-5342b7fdfe84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
