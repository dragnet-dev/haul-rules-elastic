// Dragnet [Ransomware]: dragnet-ransomware-2023-3944 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 963e60ef-35aa-54bf-9e28-0573044e41ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
