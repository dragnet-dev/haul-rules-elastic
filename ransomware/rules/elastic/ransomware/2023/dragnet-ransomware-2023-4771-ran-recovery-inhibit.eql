// Dragnet [Ransomware]: dragnet-ransomware-2023-4771 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: 55e3b2f0-5c5e-59a3-ab8d-36abba21df95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
