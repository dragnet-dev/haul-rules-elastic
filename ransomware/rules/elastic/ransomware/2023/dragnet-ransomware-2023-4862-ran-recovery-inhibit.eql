// Dragnet [Ransomware]: dragnet-ransomware-2023-4862 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 166bbc6c-b26f-5098-a3bb-663710c31f06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
