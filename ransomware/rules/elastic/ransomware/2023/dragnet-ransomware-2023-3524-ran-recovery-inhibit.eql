// Dragnet [Ransomware]: dragnet-ransomware-2023-3524 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f0a7d583-55f4-5713-a164-cc9bcfd5a626

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
