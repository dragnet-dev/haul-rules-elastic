// Dragnet [Ransomware]: dragnet-ransomware-2023-0579 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2ee7bbbf-adc5-5c48-82af-dc713f5108cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
