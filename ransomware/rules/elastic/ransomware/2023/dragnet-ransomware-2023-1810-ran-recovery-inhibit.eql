// Dragnet [Ransomware]: dragnet-ransomware-2023-1810 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: f36458fd-921a-5513-b8e4-900d001373f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
