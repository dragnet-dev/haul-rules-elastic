// Dragnet [Ransomware]: dragnet-ransomware-2023-2637 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 81a9a477-f461-5b6f-a782-da13b01297c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
