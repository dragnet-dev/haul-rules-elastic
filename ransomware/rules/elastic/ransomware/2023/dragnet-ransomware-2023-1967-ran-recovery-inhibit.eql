// Dragnet [Ransomware]: dragnet-ransomware-2023-1967 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2cfaf7d7-fe64-5d25-ae25-4515d28796d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
