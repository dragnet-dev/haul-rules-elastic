// Dragnet [Ransomware]: dragnet-ransomware-2023-2851 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 4ad113cb-0dbc-597b-909f-079bf9c49d0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
