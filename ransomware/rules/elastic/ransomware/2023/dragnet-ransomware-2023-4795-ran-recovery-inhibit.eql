// Dragnet [Ransomware]: dragnet-ransomware-2023-4795 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: ae254b2d-d460-5c7a-a831-2786aa4d231c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
