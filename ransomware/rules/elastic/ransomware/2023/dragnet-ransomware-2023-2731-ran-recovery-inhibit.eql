// Dragnet [Ransomware]: dragnet-ransomware-2023-2731 — Recovery Inhibition (cyclops)
// Status: deprecated | Level: high | ID: 241218d2-dd46-55a1-b806-b16df6b5c64b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
