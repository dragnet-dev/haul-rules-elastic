// Dragnet [Ransomware]: dragnet-ransomware-2023-2994 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: be78c95f-bb17-50ca-a522-d1c7e7b0e398

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
