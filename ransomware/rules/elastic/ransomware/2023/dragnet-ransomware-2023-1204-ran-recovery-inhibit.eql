// Dragnet [Ransomware]: dragnet-ransomware-2023-1204 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: f7c78801-0cd0-5d35-8754-4ca5bfd5e163

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
