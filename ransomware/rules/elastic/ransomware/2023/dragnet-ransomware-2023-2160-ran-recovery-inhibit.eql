// Dragnet [Ransomware]: dragnet-ransomware-2023-2160 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: 428518a4-229a-54b8-bb24-81bcf39677d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
