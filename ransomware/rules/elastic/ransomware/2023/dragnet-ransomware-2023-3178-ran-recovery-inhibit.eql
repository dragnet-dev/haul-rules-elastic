// Dragnet [Ransomware]: dragnet-ransomware-2023-3178 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1156d184-5950-57ed-84a9-08c6dffcd78b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
