// Dragnet [Ransomware]: dragnet-ransomware-2023-4494 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 21a7885c-600c-5029-aec0-0ff8acd05b3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
