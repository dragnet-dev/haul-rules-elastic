// Dragnet [Ransomware]: dragnet-ransomware-2023-3800 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 19b23289-3e30-55c7-86e7-4c23546a5e31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
