// Dragnet [Ransomware]: dragnet-ransomware-2023-2204 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: b005dc31-b853-5119-8b96-e02920d1eba8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
