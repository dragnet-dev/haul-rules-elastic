// Dragnet [Ransomware]: dragnet-ransomware-2023-1378 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: dd259272-6b5f-5815-ac29-b38ee595cf6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
