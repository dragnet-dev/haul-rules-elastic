// Dragnet [Ransomware]: dragnet-ransomware-2023-2777 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 5e6dccd6-10a6-5427-a760-64a51f97411f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
