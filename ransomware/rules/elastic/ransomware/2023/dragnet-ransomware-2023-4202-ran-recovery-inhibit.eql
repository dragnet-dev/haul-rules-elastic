// Dragnet [Ransomware]: dragnet-ransomware-2023-4202 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: d0e5bca6-ba98-5ece-b53d-6427d9ea64c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
