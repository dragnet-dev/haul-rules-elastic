// Dragnet [Ransomware]: dragnet-ransomware-2023-1785 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5cabf053-e0e5-5328-bd81-1625f8029b60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
