// Dragnet [Ransomware]: dragnet-ransomware-2023-5105 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 18ea7a14-b3cd-5b67-aeff-713710d49bc1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
