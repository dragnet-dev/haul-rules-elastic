// Dragnet [Ransomware]: dragnet-ransomware-2023-0163 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 44972a8f-fb8c-5ebb-8073-999b98ca58d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
