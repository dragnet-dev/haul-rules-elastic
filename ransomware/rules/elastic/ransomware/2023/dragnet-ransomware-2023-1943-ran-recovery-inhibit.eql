// Dragnet [Ransomware]: dragnet-ransomware-2023-1943 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: feaac9c6-9309-519e-98a6-38fe8ea9f6ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
