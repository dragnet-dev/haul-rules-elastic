// Dragnet [Ransomware]: dragnet-ransomware-2023-1148 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 28b02a30-4eb3-5016-842e-70e5079f6e4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
