// Dragnet [Ransomware]: dragnet-ransomware-2023-0533 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 100cb8cd-622a-554a-a742-6a5e2da8dce9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
