// Dragnet [Ransomware]: dragnet-ransomware-2023-3330 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 4ade9589-e4ca-5dce-850a-23c0a3f1fa8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
