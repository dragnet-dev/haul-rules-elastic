// Dragnet [Ransomware]: dragnet-ransomware-2023-1123 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 0fd50102-840c-5a21-9b95-94b0b3699f51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
