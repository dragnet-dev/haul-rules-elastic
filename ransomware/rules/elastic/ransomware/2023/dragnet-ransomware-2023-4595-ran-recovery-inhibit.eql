// Dragnet [Ransomware]: dragnet-ransomware-2023-4595 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 17cbdcfa-7c58-5bb5-9c29-33024b864173

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
