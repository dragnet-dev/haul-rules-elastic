// Dragnet [Ransomware]: dragnet-ransomware-2023-5065 — Recovery Inhibition (siegedsec)
// Status: experimental | Level: high | ID: a4e00a1b-5252-5c55-a6d9-9a27fc5bf414

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
