// Dragnet [Ransomware]: dragnet-ransomware-2023-4585 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: b48c0e06-2c80-52ae-9f0b-d95f4a6f27ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
