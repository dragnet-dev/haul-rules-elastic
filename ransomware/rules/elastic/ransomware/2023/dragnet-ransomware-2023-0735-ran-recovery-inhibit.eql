// Dragnet [Ransomware]: dragnet-ransomware-2023-0735 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: e468132c-06e1-5644-998d-13308a298a0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
