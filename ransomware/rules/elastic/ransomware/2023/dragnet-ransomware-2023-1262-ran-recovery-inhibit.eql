// Dragnet [Ransomware]: dragnet-ransomware-2023-1262 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: a577d11c-c492-5eb0-b635-00d55650486b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
