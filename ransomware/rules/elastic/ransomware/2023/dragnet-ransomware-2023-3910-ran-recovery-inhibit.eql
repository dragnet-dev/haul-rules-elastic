// Dragnet [Ransomware]: dragnet-ransomware-2023-3910 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: facbce0b-c490-5615-94c0-feef514d2039

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
