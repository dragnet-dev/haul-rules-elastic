// Dragnet [Ransomware]: dragnet-ransomware-2023-2470 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: cc2b08bb-ce53-53aa-bebe-7bceab3c46a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
