// Dragnet [Ransomware]: dragnet-ransomware-2023-2201 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c14d1e76-bce6-5166-bedc-50706db99b67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
