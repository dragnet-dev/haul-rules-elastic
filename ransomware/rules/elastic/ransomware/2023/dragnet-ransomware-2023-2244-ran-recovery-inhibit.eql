// Dragnet [Ransomware]: dragnet-ransomware-2023-2244 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 90ffb087-f2d3-57a3-8ae6-0852e9a1d8c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
