// Dragnet [Ransomware]: dragnet-ransomware-2023-0628 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5c19a468-cb54-5579-88a0-0c976c969f4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
