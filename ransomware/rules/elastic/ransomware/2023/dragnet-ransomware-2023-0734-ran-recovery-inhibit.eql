// Dragnet [Ransomware]: dragnet-ransomware-2023-0734 — Recovery Inhibition (ranstreet)
// Status: deprecated | Level: high | ID: e259156c-e3bc-5f53-b805-14994da7ec90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
