// Dragnet [Ransomware]: dragnet-ransomware-2023-3320 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: e1510cb7-e461-53c4-9d0e-6a576bb9cff2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
