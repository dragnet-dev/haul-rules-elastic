// Dragnet [Ransomware]: dragnet-ransomware-2023-0056 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: b49c00cc-b811-5bba-b192-712a0ff5b1d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
