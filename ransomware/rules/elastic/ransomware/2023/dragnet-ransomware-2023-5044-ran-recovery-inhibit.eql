// Dragnet [Ransomware]: dragnet-ransomware-2023-5044 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: a96a1901-f949-565f-933e-cb103f957030

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
