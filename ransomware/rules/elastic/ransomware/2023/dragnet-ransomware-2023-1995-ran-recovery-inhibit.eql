// Dragnet [Ransomware]: dragnet-ransomware-2023-1995 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 175421d1-0b58-5c6f-a468-a6218501dedb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
