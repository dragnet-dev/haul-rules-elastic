// Dragnet [Ransomware]: dragnet-ransomware-2023-5262 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f32e9cd6-c5dc-5d01-b331-5dccd59a0802

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
