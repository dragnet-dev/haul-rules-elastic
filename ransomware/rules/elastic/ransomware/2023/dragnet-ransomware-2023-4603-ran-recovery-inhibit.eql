// Dragnet [Ransomware]: dragnet-ransomware-2023-4603 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: fbdd06f7-4e2b-5c1d-8f05-94d16adccd94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
