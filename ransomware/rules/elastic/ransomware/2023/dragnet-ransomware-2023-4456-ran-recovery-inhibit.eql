// Dragnet [Ransomware]: dragnet-ransomware-2023-4456 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: f3111d7a-d116-5e79-9eb4-9fe8e87519f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
