// Dragnet [Ransomware]: dragnet-ransomware-2023-1314 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 0fcf3298-83fe-549e-b2cf-1765759644aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
