// Dragnet [Ransomware]: dragnet-ransomware-2023-0596 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 398e1582-294e-55e2-97e2-996f50c339d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
