// Dragnet [Ransomware]: dragnet-ransomware-2023-0456 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 69c001f8-fe3f-56e2-b8a3-f423c543c721

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
