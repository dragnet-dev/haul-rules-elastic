// Dragnet [Ransomware]: dragnet-ransomware-2023-3587 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ca2cd673-17cb-5a7e-9976-0e2ebf08a441

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
