// Dragnet [Ransomware]: dragnet-ransomware-2023-1061 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 2718cda4-90cb-53c5-b67c-e085959b8c48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
