// Dragnet [Ransomware]: dragnet-ransomware-2023-3500 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: abef8779-fa23-5287-9558-6cecd29eff12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
