// Dragnet [Ransomware]: dragnet-ransomware-2023-1964 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: e085928e-e1db-5d1e-ae30-7e0274ed30b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
