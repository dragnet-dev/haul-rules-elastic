// Dragnet [Ransomware]: dragnet-ransomware-2023-4088 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 13b8e3c1-4ba3-5ea3-90df-dd59d6126c74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
