// Dragnet [Ransomware]: dragnet-ransomware-2023-1446 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ac15f940-5d6b-561a-916d-15b5ac743d6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
