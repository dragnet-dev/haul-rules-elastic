// Dragnet [Ransomware]: dragnet-ransomware-2023-0739 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 22505a02-d33c-50c4-845d-f1ee039d5302

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
