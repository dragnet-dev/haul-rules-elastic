// Dragnet [Ransomware]: dragnet-ransomware-2023-1656 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 53acd7c6-6952-5a68-991c-732e1f6ce5fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
