// Dragnet [Ransomware]: dragnet-ransomware-2023-3439 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: ad7a8ab6-b407-5f2f-8900-abee49ad2895

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
