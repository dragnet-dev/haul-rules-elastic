// Dragnet [Ransomware]: dragnet-ransomware-2023-4745 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 11e9e33a-e2a2-5d1a-b83f-5709ae651b64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
