// Dragnet [Ransomware]: dragnet-ransomware-2023-4711 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8585ae08-6f78-5e70-ade9-64ebe4f06dd2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
