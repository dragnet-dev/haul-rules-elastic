// Dragnet [Ransomware]: dragnet-ransomware-2023-2835 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 905d080f-0bb0-5c13-ad7e-3457e063dc81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
