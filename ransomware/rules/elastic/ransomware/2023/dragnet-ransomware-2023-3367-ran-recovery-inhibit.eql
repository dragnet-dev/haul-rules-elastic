// Dragnet [Ransomware]: dragnet-ransomware-2023-3367 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: cab3781f-f853-5361-8aeb-cfb1e6fa805f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
