// Dragnet [Ransomware]: dragnet-ransomware-2023-0384 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 2ea4740c-3e7a-5ac2-9273-e3b0d12fa15e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
