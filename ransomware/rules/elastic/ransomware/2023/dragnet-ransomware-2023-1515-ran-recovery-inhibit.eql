// Dragnet [Ransomware]: dragnet-ransomware-2023-1515 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1f6f6e9d-a9ec-5b5a-843d-9111beff0e9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
