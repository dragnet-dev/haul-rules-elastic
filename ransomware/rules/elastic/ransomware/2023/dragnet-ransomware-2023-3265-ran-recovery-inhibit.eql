// Dragnet [Ransomware]: dragnet-ransomware-2023-3265 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: b1ba5255-5b6c-52f8-8085-c16a075ad1eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
