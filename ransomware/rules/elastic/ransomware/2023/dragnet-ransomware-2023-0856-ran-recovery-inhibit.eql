// Dragnet [Ransomware]: dragnet-ransomware-2023-0856 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: da2be031-40ae-5f15-b1de-61bc2252d28d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
