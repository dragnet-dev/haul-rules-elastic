// Dragnet [Ransomware]: dragnet-ransomware-2023-1304 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 35d90ef0-f036-5ae4-b918-5d70423c0548

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
