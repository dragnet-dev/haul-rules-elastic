// Dragnet [Ransomware]: dragnet-ransomware-2023-5289 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 677da95e-7436-593c-8a44-299e5a16ddc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
