// Dragnet [Ransomware]: dragnet-ransomware-2023-2263 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: f68ca280-163d-5b52-9377-17f766faf284

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
