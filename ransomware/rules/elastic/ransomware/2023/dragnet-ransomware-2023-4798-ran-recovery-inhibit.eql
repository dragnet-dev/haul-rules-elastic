// Dragnet [Ransomware]: dragnet-ransomware-2023-4798 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 02e1f037-6851-5746-9ff8-5eaf3e2f651a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
