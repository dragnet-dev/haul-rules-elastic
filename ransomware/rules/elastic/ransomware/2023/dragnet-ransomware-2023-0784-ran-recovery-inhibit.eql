// Dragnet [Ransomware]: dragnet-ransomware-2023-0784 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 420f073d-75e4-5371-9f57-0768cc1d961f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
