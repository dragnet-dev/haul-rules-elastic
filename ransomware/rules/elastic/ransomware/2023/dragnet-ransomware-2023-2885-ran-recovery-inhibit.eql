// Dragnet [Ransomware]: dragnet-ransomware-2023-2885 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 3fcb776e-4f76-5d48-907b-84e1621396bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
