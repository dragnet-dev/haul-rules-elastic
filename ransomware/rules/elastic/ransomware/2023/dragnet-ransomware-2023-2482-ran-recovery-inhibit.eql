// Dragnet [Ransomware]: dragnet-ransomware-2023-2482 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 71e06659-f4c1-5409-b6cb-585456175a2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
