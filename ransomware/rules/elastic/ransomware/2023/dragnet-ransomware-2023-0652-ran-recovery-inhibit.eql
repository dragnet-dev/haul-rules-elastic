// Dragnet [Ransomware]: dragnet-ransomware-2023-0652 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a5e1737b-e30d-563f-a29a-523de2162e30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
