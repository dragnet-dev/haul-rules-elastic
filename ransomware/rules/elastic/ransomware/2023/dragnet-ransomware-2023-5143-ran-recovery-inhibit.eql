// Dragnet [Ransomware]: dragnet-ransomware-2023-5143 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4b07945f-ab43-5da3-84f1-6bedf5d2762f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
