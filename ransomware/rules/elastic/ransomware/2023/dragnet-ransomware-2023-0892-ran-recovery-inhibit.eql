// Dragnet [Ransomware]: dragnet-ransomware-2023-0892 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 4b918a5b-3b77-591c-9822-b05fb8921098

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
