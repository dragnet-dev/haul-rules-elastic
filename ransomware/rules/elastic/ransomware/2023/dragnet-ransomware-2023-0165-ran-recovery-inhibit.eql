// Dragnet [Ransomware]: dragnet-ransomware-2023-0165 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: edd7ee18-6409-5a83-ae15-eda8642933f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
