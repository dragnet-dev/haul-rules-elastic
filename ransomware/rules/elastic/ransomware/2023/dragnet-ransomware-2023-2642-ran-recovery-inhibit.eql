// Dragnet [Ransomware]: dragnet-ransomware-2023-2642 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: e045653e-1f7c-5e5e-92c9-f7f8443f79f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
