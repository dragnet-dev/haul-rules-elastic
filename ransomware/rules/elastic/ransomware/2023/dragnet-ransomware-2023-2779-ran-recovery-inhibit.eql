// Dragnet [Ransomware]: dragnet-ransomware-2023-2779 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: e04a5be7-578e-5a83-b564-c14846897bc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
