// Dragnet [Ransomware]: dragnet-ransomware-2023-3051 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: d4375749-647c-592a-8b0b-777ca3db0d83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
