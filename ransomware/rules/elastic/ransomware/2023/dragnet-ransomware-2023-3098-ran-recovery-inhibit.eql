// Dragnet [Ransomware]: dragnet-ransomware-2023-3098 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 6c11a2da-a2ba-591a-b6ee-e6235b58b0fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
