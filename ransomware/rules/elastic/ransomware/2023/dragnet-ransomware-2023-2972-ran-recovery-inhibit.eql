// Dragnet [Ransomware]: dragnet-ransomware-2023-2972 — Recovery Inhibition (moneymessage)
// Status: experimental | Level: high | ID: 8e62b0f9-bfdd-57ed-9b08-1cd0042059d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
