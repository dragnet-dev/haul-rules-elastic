// Dragnet [Ransomware]: dragnet-ransomware-2023-2036 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 3e44ca1e-2ea0-55b9-9997-1a133d6fef04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
