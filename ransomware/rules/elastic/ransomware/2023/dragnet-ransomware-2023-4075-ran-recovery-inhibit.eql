// Dragnet [Ransomware]: dragnet-ransomware-2023-4075 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0dd490ef-0c0f-5349-a783-099be7a8402a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
