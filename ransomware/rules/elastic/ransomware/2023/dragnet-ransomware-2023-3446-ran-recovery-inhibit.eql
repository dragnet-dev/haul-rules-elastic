// Dragnet [Ransomware]: dragnet-ransomware-2023-3446 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: de8c9091-815a-5a6a-99f4-212451b092bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
