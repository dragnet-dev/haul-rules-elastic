// Dragnet [Ransomware]: dragnet-ransomware-2023-2518 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: ed2218bb-82d4-5546-80ad-e001c247c21f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
