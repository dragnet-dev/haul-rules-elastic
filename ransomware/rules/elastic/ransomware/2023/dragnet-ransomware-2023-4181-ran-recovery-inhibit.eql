// Dragnet [Ransomware]: dragnet-ransomware-2023-4181 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: f9bcaf5e-b9d6-5cc1-80ca-8573965f9cfa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
