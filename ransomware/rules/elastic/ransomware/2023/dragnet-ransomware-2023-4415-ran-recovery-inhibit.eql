// Dragnet [Ransomware]: dragnet-ransomware-2023-4415 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: f71bc05b-8c11-5f15-a455-1733cabed947

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
