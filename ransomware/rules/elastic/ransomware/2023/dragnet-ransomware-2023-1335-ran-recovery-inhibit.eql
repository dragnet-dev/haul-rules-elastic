// Dragnet [Ransomware]: dragnet-ransomware-2023-1335 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8da611b0-7a23-5728-9a5d-9cb59d0102e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
