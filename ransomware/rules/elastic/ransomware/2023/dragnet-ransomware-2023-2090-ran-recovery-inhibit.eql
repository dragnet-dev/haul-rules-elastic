// Dragnet [Ransomware]: dragnet-ransomware-2023-2090 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 03385514-15b8-50a0-8583-f63bb76fb8b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
