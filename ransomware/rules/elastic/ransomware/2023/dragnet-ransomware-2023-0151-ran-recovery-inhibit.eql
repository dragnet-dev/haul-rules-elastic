// Dragnet [Ransomware]: dragnet-ransomware-2023-0151 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 6c8de783-1ae7-587e-aad6-7d57764227b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
