// Dragnet [Ransomware]: dragnet-ransomware-2023-4561 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: 548b3c12-324e-5253-95b5-c0c269156f7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
