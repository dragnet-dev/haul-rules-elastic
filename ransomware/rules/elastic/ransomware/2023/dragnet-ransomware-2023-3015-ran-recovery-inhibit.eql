// Dragnet [Ransomware]: dragnet-ransomware-2023-3015 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 59f64e4f-7017-568e-a7bc-419faa8200c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
