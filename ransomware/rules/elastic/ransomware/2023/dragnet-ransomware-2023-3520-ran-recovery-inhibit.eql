// Dragnet [Ransomware]: dragnet-ransomware-2023-3520 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: f3b90130-e1dd-5f23-a027-8283c2e51c0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
