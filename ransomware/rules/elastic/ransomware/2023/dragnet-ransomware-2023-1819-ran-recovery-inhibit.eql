// Dragnet [Ransomware]: dragnet-ransomware-2023-1819 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: cde6f846-97a7-5fb1-946f-913d5056a45b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
