// Dragnet [Ransomware]: dragnet-ransomware-2023-0855 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 81a52b2a-0e2a-5f68-94c0-60ce125b4ff4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
