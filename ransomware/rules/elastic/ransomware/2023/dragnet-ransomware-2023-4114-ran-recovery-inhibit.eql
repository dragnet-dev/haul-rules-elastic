// Dragnet [Ransomware]: dragnet-ransomware-2023-4114 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 8439303b-2b8b-5898-b70f-75cd03fcb355

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
