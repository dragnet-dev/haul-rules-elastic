// Dragnet [Ransomware]: dragnet-ransomware-2023-3205 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ec80f1fe-a591-500f-9a1e-c746fbc23ca5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
