// Dragnet [Ransomware]: dragnet-ransomware-2023-3249 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 040a2505-f6d2-5b04-bf61-d2bc82020211

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
