// Dragnet [Ransomware]: dragnet-ransomware-2023-4531 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 799c78d7-a289-580a-9cc3-8bb8713df41e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
