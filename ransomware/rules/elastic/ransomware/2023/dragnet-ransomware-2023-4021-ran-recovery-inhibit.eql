// Dragnet [Ransomware]: dragnet-ransomware-2023-4021 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 82422940-d83e-5728-adba-932fc3779fb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
