// Dragnet [Ransomware]: dragnet-ransomware-2023-4765 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 64885fd5-cd39-55cf-9e9c-306e31e108f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
