// Dragnet [Ransomware]: dragnet-ransomware-2023-0391 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: bfdf0b23-081b-5089-a711-25f2c8d34800

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
