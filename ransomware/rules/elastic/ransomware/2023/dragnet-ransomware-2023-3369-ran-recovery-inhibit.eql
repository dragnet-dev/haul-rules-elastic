// Dragnet [Ransomware]: dragnet-ransomware-2023-3369 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a7a6b679-c51d-564a-b31a-aec5ea121012

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
