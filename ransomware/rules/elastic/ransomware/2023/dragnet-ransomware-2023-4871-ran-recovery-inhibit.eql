// Dragnet [Ransomware]: dragnet-ransomware-2023-4871 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 33e82d24-0ce0-5b91-bc63-a2bd3bf7d84e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
