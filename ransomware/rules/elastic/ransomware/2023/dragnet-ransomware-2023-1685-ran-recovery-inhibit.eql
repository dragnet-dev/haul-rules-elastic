// Dragnet [Ransomware]: dragnet-ransomware-2023-1685 — Recovery Inhibition (darkpower)
// Status: experimental | Level: high | ID: b4a85b3b-16c1-59b7-bca1-38d377f3f984

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
