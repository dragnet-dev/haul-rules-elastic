// Dragnet [Ransomware]: dragnet-ransomware-2023-0678 — Recovery Inhibition (cryptbb)
// Status: experimental | Level: high | ID: a21f13df-993a-567c-9161-00896da5955c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
