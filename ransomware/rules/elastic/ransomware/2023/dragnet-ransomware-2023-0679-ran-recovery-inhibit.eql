// Dragnet [Ransomware]: dragnet-ransomware-2023-0679 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: 87e5c8c6-ef95-59cd-b7b9-eb646b3e7f0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
