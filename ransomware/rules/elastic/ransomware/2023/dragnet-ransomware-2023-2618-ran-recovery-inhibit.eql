// Dragnet [Ransomware]: dragnet-ransomware-2023-2618 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 68e21150-514e-5e8d-8478-c636372f99e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
