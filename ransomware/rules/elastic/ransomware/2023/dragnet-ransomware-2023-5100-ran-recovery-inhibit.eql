// Dragnet [Ransomware]: dragnet-ransomware-2023-5100 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: c6e1afbb-9b2b-5216-b552-42aa25719da8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
