// Dragnet [Ransomware]: dragnet-ransomware-2023-3047 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 4c7e0ade-920f-5fc2-a837-bb5c4d272a22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
