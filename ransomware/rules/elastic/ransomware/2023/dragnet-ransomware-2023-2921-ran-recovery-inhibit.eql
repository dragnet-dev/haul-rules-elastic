// Dragnet [Ransomware]: dragnet-ransomware-2023-2921 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: fcc31d34-d0ca-51a5-8c08-93525e066758

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
