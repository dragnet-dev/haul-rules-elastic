// Dragnet [Ransomware]: dragnet-ransomware-2023-1542 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: da39fce9-e5dd-5996-99f0-42e260cc00af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
