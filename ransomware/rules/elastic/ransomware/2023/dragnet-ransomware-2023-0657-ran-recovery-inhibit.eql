// Dragnet [Ransomware]: dragnet-ransomware-2023-0657 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: f40d09c4-492d-5d59-bce9-24a3f0be3f6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
