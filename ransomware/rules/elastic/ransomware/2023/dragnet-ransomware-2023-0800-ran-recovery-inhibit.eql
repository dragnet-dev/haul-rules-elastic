// Dragnet [Ransomware]: dragnet-ransomware-2023-0800 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 91d32bb4-8f29-5634-b970-e6b46c52ed62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
