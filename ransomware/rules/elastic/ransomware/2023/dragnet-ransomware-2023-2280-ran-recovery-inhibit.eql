// Dragnet [Ransomware]: dragnet-ransomware-2023-2280 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: aee27dc8-390e-5bc1-9df7-b7331ab012c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
