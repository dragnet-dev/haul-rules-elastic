// Dragnet [Ransomware]: dragnet-ransomware-2023-3385 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 1e443937-4eb6-5e37-ae45-e71f99ec83b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
