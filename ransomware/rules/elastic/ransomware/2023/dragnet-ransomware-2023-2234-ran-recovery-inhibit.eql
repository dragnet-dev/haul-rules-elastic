// Dragnet [Ransomware]: dragnet-ransomware-2023-2234 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 0a29cdfa-e89c-5911-8d34-74fe96f4b7f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
