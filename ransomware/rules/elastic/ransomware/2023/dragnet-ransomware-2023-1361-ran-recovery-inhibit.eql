// Dragnet [Ransomware]: dragnet-ransomware-2023-1361 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 38f7c17b-c811-5c99-b305-4fffaf613ee0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
