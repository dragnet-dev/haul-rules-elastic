// Dragnet [Ransomware]: dragnet-ransomware-2023-3262 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 655d8daf-5970-51df-af1c-ea5464b8160d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
