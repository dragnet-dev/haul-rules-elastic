// Dragnet [Ransomware]: dragnet-ransomware-2023-3846 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 0d3de977-91af-5a77-9a9a-0d21d362feb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
