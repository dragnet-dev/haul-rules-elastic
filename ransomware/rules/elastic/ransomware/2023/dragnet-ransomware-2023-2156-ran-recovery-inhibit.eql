// Dragnet [Ransomware]: dragnet-ransomware-2023-2156 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: cac36cc4-a236-5aff-b6cc-60d6c7c53492

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
