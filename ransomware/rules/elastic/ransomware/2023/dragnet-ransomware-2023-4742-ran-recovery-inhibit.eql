// Dragnet [Ransomware]: dragnet-ransomware-2023-4742 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 96a30efe-e0a8-5891-ab24-34cf9cbdb931

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
