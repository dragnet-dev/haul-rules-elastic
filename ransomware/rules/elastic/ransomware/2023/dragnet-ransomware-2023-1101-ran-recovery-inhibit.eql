// Dragnet [Ransomware]: dragnet-ransomware-2023-1101 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 0e005ed1-47c2-56cb-9afb-f02322ffc0fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
