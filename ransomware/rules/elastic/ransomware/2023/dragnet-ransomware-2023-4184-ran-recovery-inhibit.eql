// Dragnet [Ransomware]: dragnet-ransomware-2023-4184 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 935f3622-6a80-59ef-94e8-4539c97a5acf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
