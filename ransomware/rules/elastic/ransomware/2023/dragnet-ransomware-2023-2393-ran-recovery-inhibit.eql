// Dragnet [Ransomware]: dragnet-ransomware-2023-2393 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f1f7425d-8a2c-5a37-84be-8e2a7001803c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
