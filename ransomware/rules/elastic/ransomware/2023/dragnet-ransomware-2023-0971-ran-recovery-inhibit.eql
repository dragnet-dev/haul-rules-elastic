// Dragnet [Ransomware]: dragnet-ransomware-2023-0971 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: ac144a20-409c-5c06-a323-c2103597fc6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
