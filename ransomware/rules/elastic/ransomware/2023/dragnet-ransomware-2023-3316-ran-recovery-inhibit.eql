// Dragnet [Ransomware]: dragnet-ransomware-2023-3316 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ad06178e-a72e-51f5-95d8-9fbf5ff67e65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
