// Dragnet [Ransomware]: dragnet-ransomware-2023-0307 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 62c8ff6f-e712-5f0f-b29d-871d938b53b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
