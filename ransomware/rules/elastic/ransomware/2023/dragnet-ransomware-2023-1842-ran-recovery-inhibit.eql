// Dragnet [Ransomware]: dragnet-ransomware-2023-1842 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5787dd55-c504-50bb-b093-352bbef66138

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
