// Dragnet [Ransomware]: dragnet-ransomware-2023-0071 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2941f4f3-4274-5f05-a7bb-312025f8092f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
