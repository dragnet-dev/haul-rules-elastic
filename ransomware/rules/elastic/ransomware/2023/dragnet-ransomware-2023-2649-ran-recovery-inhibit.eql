// Dragnet [Ransomware]: dragnet-ransomware-2023-2649 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: c0d2ec29-93da-5e9c-96c6-3b23b892880b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
