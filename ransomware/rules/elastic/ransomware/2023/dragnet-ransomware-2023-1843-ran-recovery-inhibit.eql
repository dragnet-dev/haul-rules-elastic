// Dragnet [Ransomware]: dragnet-ransomware-2023-1843 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 0acf4d16-0cfc-543d-9515-1571cdbc716d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
