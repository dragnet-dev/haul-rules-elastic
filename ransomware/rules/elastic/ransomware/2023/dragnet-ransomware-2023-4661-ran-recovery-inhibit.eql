// Dragnet [Ransomware]: dragnet-ransomware-2023-4661 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: 52ea258d-bdd1-5277-af29-481618847656

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
