// Dragnet [Ransomware]: dragnet-ransomware-2023-4303 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 96409894-b840-5160-8229-70200395b89c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
