// Dragnet [Ransomware]: dragnet-ransomware-2023-1805 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 71968337-75e8-5ec8-817f-d74abd89f1c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
