// Dragnet [Ransomware]: dragnet-ransomware-2023-1885 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: f9da1623-4fa8-50e7-ac6f-6ab6b04478d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
