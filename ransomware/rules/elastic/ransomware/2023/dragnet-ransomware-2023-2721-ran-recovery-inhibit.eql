// Dragnet [Ransomware]: dragnet-ransomware-2023-2721 — Recovery Inhibition (moneymessage)
// Status: experimental | Level: high | ID: a5635522-bc70-5c30-a49f-d6a7d171f2f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
