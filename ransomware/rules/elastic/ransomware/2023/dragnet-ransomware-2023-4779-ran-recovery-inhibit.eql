// Dragnet [Ransomware]: dragnet-ransomware-2023-4779 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 2faec40a-9351-5db1-a21c-4be232d730a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
