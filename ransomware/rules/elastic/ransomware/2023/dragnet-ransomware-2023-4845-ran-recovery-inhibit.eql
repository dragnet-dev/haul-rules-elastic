// Dragnet [Ransomware]: dragnet-ransomware-2023-4845 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f1e5b05f-9280-5fcd-9a9f-eb692c4282bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
