// Dragnet [Ransomware]: dragnet-ransomware-2023-1275 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 027df34d-aed2-5fb5-a2c9-22e741fa0a4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
