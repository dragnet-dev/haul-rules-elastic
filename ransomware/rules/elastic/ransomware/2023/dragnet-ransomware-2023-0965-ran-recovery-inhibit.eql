// Dragnet [Ransomware]: dragnet-ransomware-2023-0965 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: e289d5e4-59ae-5249-9be8-ad86c4fd61dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
