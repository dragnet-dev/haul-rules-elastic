// Dragnet [Ransomware]: dragnet-ransomware-2023-5184 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 1cb60219-29cd-57d8-8482-dfa23848ba0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
