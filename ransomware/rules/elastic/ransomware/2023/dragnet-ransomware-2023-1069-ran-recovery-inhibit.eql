// Dragnet [Ransomware]: dragnet-ransomware-2023-1069 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 2c3e8b82-1224-598f-8fe1-47a8bd556ec8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
