// Dragnet [Ransomware]: dragnet-ransomware-2023-0336 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: b8c038ab-ad55-5ef2-8241-daabd5ff2225

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
