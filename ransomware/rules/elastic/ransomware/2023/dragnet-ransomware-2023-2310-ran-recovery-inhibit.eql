// Dragnet [Ransomware]: dragnet-ransomware-2023-2310 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 73b60f5e-50da-5891-b01f-10ed5044d30f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
