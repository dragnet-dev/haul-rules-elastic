// Dragnet [Ransomware]: dragnet-ransomware-2023-4896 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f8a0dff9-4173-52ad-86f7-c07393333a7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
