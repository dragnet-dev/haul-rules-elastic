// Dragnet [Ransomware]: dragnet-ransomware-2023-2610 — Recovery Inhibition (malekteam)
// Status: experimental | Level: high | ID: d7406170-9361-5d21-9d7f-d7b98fa213d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
