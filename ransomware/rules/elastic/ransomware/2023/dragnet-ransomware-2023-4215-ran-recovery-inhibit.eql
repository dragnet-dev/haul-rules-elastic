// Dragnet [Ransomware]: dragnet-ransomware-2023-4215 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: d7bfe3da-7904-58d0-808b-b5068bca2cae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
