// Dragnet [Ransomware]: dragnet-ransomware-2023-3073 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 17ce9ef0-5c4c-5a43-8f87-6e410fe8335e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
