// Dragnet [Ransomware]: dragnet-ransomware-2023-3208 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1b1d6d19-0da0-5b8f-a8cf-32701e50bd00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
