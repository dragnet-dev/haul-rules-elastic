// Dragnet [Ransomware]: dragnet-ransomware-2023-3389 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 22e787d7-e79f-5576-a4bf-4e81b5abd3b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
