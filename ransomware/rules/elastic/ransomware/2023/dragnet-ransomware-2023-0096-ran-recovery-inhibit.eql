// Dragnet [Ransomware]: dragnet-ransomware-2023-0096 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 30709f41-f5cc-58b3-9220-9959ade76011

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
