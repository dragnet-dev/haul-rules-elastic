// Dragnet [Ransomware]: dragnet-ransomware-2023-2345 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: d9040f26-f898-51b9-ac3c-01603c1c54b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
