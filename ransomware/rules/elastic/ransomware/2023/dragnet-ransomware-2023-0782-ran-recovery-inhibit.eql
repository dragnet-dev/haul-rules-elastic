// Dragnet [Ransomware]: dragnet-ransomware-2023-0782 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1abea8eb-5670-5f54-a9ba-b6cbb07357e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
