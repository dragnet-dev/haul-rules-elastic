// Dragnet [Ransomware]: dragnet-ransomware-2023-3851 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 419527d2-0543-5390-ad10-279e375f2b05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
