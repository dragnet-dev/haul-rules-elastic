// Dragnet [Ransomware]: dragnet-ransomware-2023-1972 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 835c8f2b-3860-5159-b08a-6cfe2fc5ed60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
