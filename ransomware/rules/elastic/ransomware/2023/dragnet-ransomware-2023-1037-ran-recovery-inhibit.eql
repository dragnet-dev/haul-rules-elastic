// Dragnet [Ransomware]: dragnet-ransomware-2023-1037 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 810b291c-52a2-537b-9b0f-abe97dbb7a4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
