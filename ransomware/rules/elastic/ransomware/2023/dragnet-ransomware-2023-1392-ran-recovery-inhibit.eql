// Dragnet [Ransomware]: dragnet-ransomware-2023-1392 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: da718f6e-9e4b-52c9-8c2a-77f31c8ede1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
