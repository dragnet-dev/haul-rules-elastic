// Dragnet [Ransomware]: dragnet-ransomware-2023-0659 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8f9df539-bf62-5100-b1b3-9d880be9b2d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
