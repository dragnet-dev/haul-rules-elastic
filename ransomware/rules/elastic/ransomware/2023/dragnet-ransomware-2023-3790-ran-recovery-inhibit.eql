// Dragnet [Ransomware]: dragnet-ransomware-2023-3790 — Recovery Inhibition (siegedsec)
// Status: deprecated | Level: high | ID: b889a528-5382-5c0d-b6b2-cb82568eec5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
