// Dragnet [Ransomware]: dragnet-ransomware-2023-1443 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 7ab231f9-9f8a-53b9-beba-6950b82dd8ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
