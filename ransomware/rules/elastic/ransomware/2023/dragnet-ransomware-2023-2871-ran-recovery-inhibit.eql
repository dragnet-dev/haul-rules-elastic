// Dragnet [Ransomware]: dragnet-ransomware-2023-2871 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 31b2685c-3987-55f5-abc7-138a1a98dfbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
