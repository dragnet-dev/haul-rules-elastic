// Dragnet [Ransomware]: dragnet-ransomware-2023-5369 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 500cfbc2-428d-5429-9fc0-c6bb2e499b4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
