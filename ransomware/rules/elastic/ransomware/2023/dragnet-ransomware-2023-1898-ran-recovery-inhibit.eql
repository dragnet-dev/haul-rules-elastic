// Dragnet [Ransomware]: dragnet-ransomware-2023-1898 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 15572bc1-f792-57b2-8467-5eb6690e72fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
