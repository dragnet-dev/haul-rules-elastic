// Dragnet [Ransomware]: dragnet-ransomware-2023-1939 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 7b18f342-394c-5f2f-af63-041315542aab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
