// Dragnet [Ransomware]: dragnet-ransomware-2023-2258 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5bd76b9a-788b-5864-9b9c-684521436484

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
