// Dragnet [Ransomware]: dragnet-ransomware-2023-2369 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 020dd3c5-cdb3-5ed9-bc93-a5ef329cf548

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
