// Dragnet [Ransomware]: dragnet-ransomware-2023-3252 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 00570466-8373-5119-886b-67bcd2dce1db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
