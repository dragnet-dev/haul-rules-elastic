// Dragnet [Ransomware]: dragnet-ransomware-2023-4124 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: c016662f-1190-52d1-a736-9c9705974eb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
