// Dragnet [Ransomware]: dragnet-ransomware-2023-0012 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 6393a5d3-f8f9-52bf-8418-4d577e5db417

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
