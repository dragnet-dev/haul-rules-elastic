// Dragnet [Ransomware]: dragnet-ransomware-2023-5011 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4d48fd0f-0d2d-552d-b7a1-dfd4437544c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
