// Dragnet [Ransomware]: dragnet-ransomware-2023-5372 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 084521b2-8b2e-5365-89f8-1af0101063c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
