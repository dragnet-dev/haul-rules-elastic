// Dragnet [Ransomware]: dragnet-ransomware-2023-5346 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: dbd22851-4373-548f-a354-6d81c88af4eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
