// Dragnet [Ransomware]: dragnet-ransomware-2023-1949 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: 1aa919f4-385e-5c16-94f8-75154810dffc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
