// Dragnet [Ransomware]: dragnet-ransomware-2023-1618 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 9ba6d2f3-41ca-5e10-8cc7-591ea3c1bcb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
