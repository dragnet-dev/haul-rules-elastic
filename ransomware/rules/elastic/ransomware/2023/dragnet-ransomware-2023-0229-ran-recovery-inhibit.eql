// Dragnet [Ransomware]: dragnet-ransomware-2023-0229 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: f13e471f-f134-5593-b563-d02e357b2ca9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
