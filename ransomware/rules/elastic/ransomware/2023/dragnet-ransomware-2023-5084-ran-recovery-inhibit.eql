// Dragnet [Ransomware]: dragnet-ransomware-2023-5084 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8dd3bd31-ac3e-5376-8cce-17f11e8a0044

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
