// Dragnet [Ransomware]: dragnet-ransomware-2023-2682 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 3c44e746-641a-5277-8f9c-4a124a057eb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
