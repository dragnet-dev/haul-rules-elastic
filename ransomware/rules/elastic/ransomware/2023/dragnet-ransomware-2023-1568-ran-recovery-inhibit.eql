// Dragnet [Ransomware]: dragnet-ransomware-2023-1568 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3c42346a-f419-5430-9d17-ba16e5869738

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
