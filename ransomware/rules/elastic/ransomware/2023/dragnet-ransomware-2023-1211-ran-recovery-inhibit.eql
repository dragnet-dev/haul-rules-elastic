// Dragnet [Ransomware]: dragnet-ransomware-2023-1211 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 9adeda3d-d6ce-5d77-887d-822f7cb0f4eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
