// Dragnet [Ransomware]: dragnet-ransomware-2023-4122 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 4ce93660-46d7-55a6-a057-d0afdd670433

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
