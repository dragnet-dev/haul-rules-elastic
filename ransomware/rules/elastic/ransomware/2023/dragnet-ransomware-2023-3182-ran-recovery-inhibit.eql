// Dragnet [Ransomware]: dragnet-ransomware-2023-3182 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: bc87052a-bb64-5fb6-8452-551f05cf47cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
