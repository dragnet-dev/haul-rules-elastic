// Dragnet [Ransomware]: dragnet-ransomware-2023-0414 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 7963bf63-ee44-575e-9e51-77e0f245c544

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
