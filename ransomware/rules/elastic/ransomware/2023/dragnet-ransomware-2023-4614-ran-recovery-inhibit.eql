// Dragnet [Ransomware]: dragnet-ransomware-2023-4614 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: c089f6e1-0731-5a8d-a9ad-60d1c090685c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
