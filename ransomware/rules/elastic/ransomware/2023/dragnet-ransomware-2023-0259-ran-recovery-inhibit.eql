// Dragnet [Ransomware]: dragnet-ransomware-2023-0259 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 2659d5f3-2d41-584b-b501-1f8f1ac93ce6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
