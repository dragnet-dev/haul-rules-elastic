// Dragnet [Ransomware]: dragnet-ransomware-2023-2299 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: a11db356-cb21-5f60-89dd-d225e5c2d6cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
