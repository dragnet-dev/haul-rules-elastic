// Dragnet [Ransomware]: dragnet-ransomware-2023-0473 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 85ece201-44cb-5c1a-a84a-5ef7738f2600

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
