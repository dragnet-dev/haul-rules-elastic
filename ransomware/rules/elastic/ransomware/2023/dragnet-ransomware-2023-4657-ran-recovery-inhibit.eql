// Dragnet [Ransomware]: dragnet-ransomware-2023-4657 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: a1aa506e-0f84-549e-a46a-e6a46c695119

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
