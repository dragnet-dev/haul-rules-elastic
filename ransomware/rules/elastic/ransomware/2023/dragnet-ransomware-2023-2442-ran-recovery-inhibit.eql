// Dragnet [Ransomware]: dragnet-ransomware-2023-2442 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f0710eeb-93cf-50d6-96c3-9d44af24edfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
