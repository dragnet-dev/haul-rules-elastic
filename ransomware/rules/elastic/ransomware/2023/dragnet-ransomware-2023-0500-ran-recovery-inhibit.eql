// Dragnet [Ransomware]: dragnet-ransomware-2023-0500 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: 54e61ff1-9063-5689-b008-6d028c4434ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
