// Dragnet [Ransomware]: dragnet-ransomware-2023-3544 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 95a5c173-522f-5304-817f-71fcab5e6606

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
