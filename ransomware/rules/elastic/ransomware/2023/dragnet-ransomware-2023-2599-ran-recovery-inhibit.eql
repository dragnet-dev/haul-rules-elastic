// Dragnet [Ransomware]: dragnet-ransomware-2023-2599 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 1c4a7794-eeea-5014-99e9-553735022b46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
