// Dragnet [Ransomware]: dragnet-ransomware-2023-1723 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: ec8bdb69-75a0-518c-8564-81887c605630

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
