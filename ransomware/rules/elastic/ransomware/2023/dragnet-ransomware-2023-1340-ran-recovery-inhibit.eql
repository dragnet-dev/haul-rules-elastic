// Dragnet [Ransomware]: dragnet-ransomware-2023-1340 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: e07c8622-ef45-5927-a775-2c5ccbeb3f83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
