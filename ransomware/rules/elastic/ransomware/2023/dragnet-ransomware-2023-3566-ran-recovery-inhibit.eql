// Dragnet [Ransomware]: dragnet-ransomware-2023-3566 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d408a940-b540-5930-95d3-0ea39477c69d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
