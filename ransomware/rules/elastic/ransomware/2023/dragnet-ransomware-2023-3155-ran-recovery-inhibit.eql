// Dragnet [Ransomware]: dragnet-ransomware-2023-3155 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 6dd07a18-dd58-5c1e-b5a6-8761fe7be7b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
