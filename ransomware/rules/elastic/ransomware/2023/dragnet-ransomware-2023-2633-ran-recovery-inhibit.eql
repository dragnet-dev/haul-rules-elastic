// Dragnet [Ransomware]: dragnet-ransomware-2023-2633 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 2234f86e-2317-5df8-a361-7d00fb8266c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
