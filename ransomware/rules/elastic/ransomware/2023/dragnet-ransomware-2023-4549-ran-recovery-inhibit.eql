// Dragnet [Ransomware]: dragnet-ransomware-2023-4549 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0eaefefc-8b34-501a-ad5c-cbd3235477f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
