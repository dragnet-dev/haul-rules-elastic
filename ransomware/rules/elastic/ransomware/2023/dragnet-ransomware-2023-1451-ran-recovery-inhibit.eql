// Dragnet [Ransomware]: dragnet-ransomware-2023-1451 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: bdb8fc92-bfb0-5d7d-b8a6-1ac504c4ba7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
