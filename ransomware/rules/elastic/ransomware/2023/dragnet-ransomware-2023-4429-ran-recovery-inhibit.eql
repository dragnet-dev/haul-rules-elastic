// Dragnet [Ransomware]: dragnet-ransomware-2023-4429 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 87c21cd8-dbed-5afc-9ada-bd435a1d33f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
