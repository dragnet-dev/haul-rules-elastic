// Dragnet [Ransomware]: dragnet-ransomware-2023-1294 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: b4c2bb4e-9884-5881-85cf-9a9000e21ce7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
