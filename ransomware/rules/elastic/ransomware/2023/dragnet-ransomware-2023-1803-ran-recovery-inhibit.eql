// Dragnet [Ransomware]: dragnet-ransomware-2023-1803 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: cc85c4ca-c955-5da5-bc71-9b174a0b992b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
