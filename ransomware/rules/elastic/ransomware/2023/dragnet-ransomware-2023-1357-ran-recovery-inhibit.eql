// Dragnet [Ransomware]: dragnet-ransomware-2023-1357 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: d5890581-83cb-5892-9e71-8d8d40267cf2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
