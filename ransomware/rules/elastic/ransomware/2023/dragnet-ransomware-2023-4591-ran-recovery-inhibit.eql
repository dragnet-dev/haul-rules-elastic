// Dragnet [Ransomware]: dragnet-ransomware-2023-4591 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 479af836-7055-5a44-91fb-5d048dd8dd66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
