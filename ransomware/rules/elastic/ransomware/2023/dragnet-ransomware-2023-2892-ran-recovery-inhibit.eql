// Dragnet [Ransomware]: dragnet-ransomware-2023-2892 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 50438c4e-61c2-55ae-b5a0-8d63c51306a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
