// Dragnet [Ransomware]: dragnet-ransomware-2023-0003 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: dfacf3c8-ac76-56c7-8585-163243d34639

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
