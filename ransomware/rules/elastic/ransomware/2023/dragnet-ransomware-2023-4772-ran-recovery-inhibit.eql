// Dragnet [Ransomware]: dragnet-ransomware-2023-4772 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: b81f8c97-0151-57af-aba6-3f8d9eac02b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
