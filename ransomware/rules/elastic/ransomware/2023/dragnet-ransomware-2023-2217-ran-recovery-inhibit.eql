// Dragnet [Ransomware]: dragnet-ransomware-2023-2217 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2c1255e3-a1cc-550a-9eed-ff0f96305093

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
