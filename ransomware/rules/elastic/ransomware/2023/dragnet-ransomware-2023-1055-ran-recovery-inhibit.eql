// Dragnet [Ransomware]: dragnet-ransomware-2023-1055 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a7e06f0a-b1f9-5942-953c-1cc000a8bf8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
