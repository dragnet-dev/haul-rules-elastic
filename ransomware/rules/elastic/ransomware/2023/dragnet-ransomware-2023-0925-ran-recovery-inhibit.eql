// Dragnet [Ransomware]: dragnet-ransomware-2023-0925 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 81a9ef93-f1b5-5cf3-9724-2348720740a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
