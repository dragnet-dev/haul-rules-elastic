// Dragnet [Ransomware]: dragnet-ransomware-2023-4975 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: c608d57b-ab28-5fd0-b605-7212bd3d55d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
