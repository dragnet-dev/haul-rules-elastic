// Dragnet [Ransomware]: dragnet-ransomware-2023-4856 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 60c6b749-77f2-5c13-a6f9-b035839e6787

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
