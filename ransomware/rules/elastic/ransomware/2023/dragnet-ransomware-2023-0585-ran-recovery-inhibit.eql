// Dragnet [Ransomware]: dragnet-ransomware-2023-0585 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: b1333eb8-7852-5af5-8931-3444608dba68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
