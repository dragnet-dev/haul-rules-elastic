// Dragnet [Ransomware]: dragnet-ransomware-2023-0153 — Recovery Inhibition (noname)
// Status: experimental | Level: high | ID: 4497a6f1-6ceb-5090-a6bc-3318399244f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
