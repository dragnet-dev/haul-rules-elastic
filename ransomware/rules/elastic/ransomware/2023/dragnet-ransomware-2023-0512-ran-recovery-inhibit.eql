// Dragnet [Ransomware]: dragnet-ransomware-2023-0512 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: fbffc74d-ff4d-5f13-822b-9265657acd35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
