// Dragnet [Ransomware]: dragnet-ransomware-2023-4076 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 1b1300c1-340d-50a4-b988-227e54033b3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
