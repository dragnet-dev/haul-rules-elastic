// Dragnet [Ransomware]: dragnet-ransomware-2023-1152 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: ba11f7ae-6ffb-59e9-bb03-f0e3676b40db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
