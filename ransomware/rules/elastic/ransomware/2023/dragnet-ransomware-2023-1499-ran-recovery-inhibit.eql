// Dragnet [Ransomware]: dragnet-ransomware-2023-1499 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: 68c5bdfb-65ed-5e37-a75a-e9b0beb8648d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
