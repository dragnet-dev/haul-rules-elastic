// Dragnet [Ransomware]: dragnet-ransomware-2023-4617 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: cb9f1490-2328-5f5c-b008-1e95931327ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
