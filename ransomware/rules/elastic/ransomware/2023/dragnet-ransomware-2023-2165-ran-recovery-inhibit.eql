// Dragnet [Ransomware]: dragnet-ransomware-2023-2165 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 495be64a-7186-5415-ad90-8a56bb78199d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
