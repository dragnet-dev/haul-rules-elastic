// Dragnet [Ransomware]: dragnet-ransomware-2023-1772 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 85e02b29-db78-52ff-905a-f0d2c9abd537

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
