// Dragnet [Ransomware]: dragnet-ransomware-2023-5238 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ec9e5dbf-fb51-5dd8-a01f-f31a9f812057

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
