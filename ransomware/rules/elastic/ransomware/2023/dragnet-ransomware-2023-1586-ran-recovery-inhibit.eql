// Dragnet [Ransomware]: dragnet-ransomware-2023-1586 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 615e1760-c25e-5b39-b5aa-9f80d034383f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
