// Dragnet [Ransomware]: dragnet-ransomware-2023-1403 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 2e4fe25a-d7bc-5b91-885c-ce879f5b23bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
