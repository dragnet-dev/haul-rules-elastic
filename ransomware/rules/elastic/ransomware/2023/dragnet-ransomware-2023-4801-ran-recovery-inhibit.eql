// Dragnet [Ransomware]: dragnet-ransomware-2023-4801 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: efdff817-9fde-5bfb-bafa-34b7f94949d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
