// Dragnet [Ransomware]: dragnet-ransomware-2023-5190 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 0808399e-ee28-5290-8b47-030c1cc2e308

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
