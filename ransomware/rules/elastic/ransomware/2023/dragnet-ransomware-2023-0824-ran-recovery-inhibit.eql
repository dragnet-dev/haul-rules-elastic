// Dragnet [Ransomware]: dragnet-ransomware-2023-0824 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: 1586d4dc-959f-569c-b901-ba41e90289c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
