// Dragnet [Ransomware]: dragnet-ransomware-2023-3332 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: cd75d2da-57ab-59b5-83c3-95f8f6d8f4d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
