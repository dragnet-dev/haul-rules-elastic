// Dragnet [Ransomware]: dragnet-ransomware-2023-1298 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 505b19c9-6f3a-5c19-aefa-f6b97e82eb7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
