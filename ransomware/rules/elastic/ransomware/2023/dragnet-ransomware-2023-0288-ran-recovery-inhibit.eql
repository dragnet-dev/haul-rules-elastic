// Dragnet [Ransomware]: dragnet-ransomware-2023-0288 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 94282b89-6743-558e-90b2-de8417038d8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
