// Dragnet [Ransomware]: dragnet-ransomware-2023-2159 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: 81bf2e6a-51f5-54ae-a3ed-f37ec4ad3b7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
