// Dragnet [Ransomware]: dragnet-ransomware-2023-3772 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 63f59981-0802-56d8-b998-1dd147ff13c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
