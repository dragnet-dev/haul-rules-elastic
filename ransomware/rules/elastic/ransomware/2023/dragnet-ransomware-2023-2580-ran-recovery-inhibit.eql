// Dragnet [Ransomware]: dragnet-ransomware-2023-2580 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 3fd26ac8-c584-5991-8131-a322694f4ea5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
