// Dragnet [Ransomware]: dragnet-ransomware-2023-0882 — Recovery Inhibition (cuba)
// Status: experimental | Level: high | ID: aa217d2c-5c44-5ac6-a16d-f10cdc587a50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
