// Dragnet [Ransomware]: dragnet-ransomware-2023-4024 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 600fb2c6-5910-5724-8b9d-2623e3bbb736

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
