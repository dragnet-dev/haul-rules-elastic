// Dragnet [Ransomware]: dragnet-ransomware-2023-1114 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 6f1d7cbf-2d68-5a03-bb94-9bc9b7bd1b5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
