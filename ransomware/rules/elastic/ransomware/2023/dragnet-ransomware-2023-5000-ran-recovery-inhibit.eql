// Dragnet [Ransomware]: dragnet-ransomware-2023-5000 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: c373521c-9621-5796-9d74-9fed28ad6e95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
