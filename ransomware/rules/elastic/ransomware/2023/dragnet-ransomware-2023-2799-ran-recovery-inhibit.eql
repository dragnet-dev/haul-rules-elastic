// Dragnet [Ransomware]: dragnet-ransomware-2023-2799 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: a1392a1f-bd77-5971-9475-ee52ac5adee7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
