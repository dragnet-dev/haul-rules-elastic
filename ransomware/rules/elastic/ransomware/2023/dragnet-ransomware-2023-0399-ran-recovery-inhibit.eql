// Dragnet [Ransomware]: dragnet-ransomware-2023-0399 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 47af86a5-47c0-540a-8f18-0932d803672d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
