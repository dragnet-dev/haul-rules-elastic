// Dragnet [Ransomware]: dragnet-ransomware-2023-2215 — Recovery Inhibition (werewolves)
// Status: experimental | Level: high | ID: 2d0b23bc-d334-5590-8784-3d94697bdccd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
