// Dragnet [Ransomware]: dragnet-ransomware-2023-3153 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: aca785a6-0f16-502d-a054-004586443331

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
