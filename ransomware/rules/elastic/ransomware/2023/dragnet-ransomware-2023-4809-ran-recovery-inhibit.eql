// Dragnet [Ransomware]: dragnet-ransomware-2023-4809 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 49f9191a-91df-578f-b23a-f6c61aebdb09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
