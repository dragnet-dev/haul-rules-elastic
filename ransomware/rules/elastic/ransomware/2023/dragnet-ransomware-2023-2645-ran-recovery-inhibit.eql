// Dragnet [Ransomware]: dragnet-ransomware-2023-2645 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: ec115cc0-905b-5395-a582-4144afda121d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
