// Dragnet [Ransomware]: dragnet-ransomware-2023-1191 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 56ea5354-7ef7-5537-bd46-144ac928058d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
