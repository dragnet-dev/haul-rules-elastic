// Dragnet [Ransomware]: dragnet-ransomware-2023-1674 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: dd24243a-28e7-53e8-b6e8-8e06f00724b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
