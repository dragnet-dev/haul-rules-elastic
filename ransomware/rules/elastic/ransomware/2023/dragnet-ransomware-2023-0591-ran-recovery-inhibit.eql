// Dragnet [Ransomware]: dragnet-ransomware-2023-0591 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: da132a8a-076e-500c-9294-f0fb89012ceb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
