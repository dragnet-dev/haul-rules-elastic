// Dragnet [Ransomware]: dragnet-ransomware-2023-0421 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: c05878f0-664e-5bb2-8726-1337b86e036d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
