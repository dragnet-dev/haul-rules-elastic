// Dragnet [Ransomware]: dragnet-ransomware-2023-4410 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 048a4eec-51a2-5174-b7d4-f28930005f46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
