// Dragnet [Ransomware]: dragnet-ransomware-2023-2698 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 65a5213f-97d6-52a1-8b74-854a1a536424

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
