// Dragnet [Ransomware]: dragnet-ransomware-2023-3336 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 8ed476f9-82b2-5a78-9001-40457d56d047

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
