// Dragnet [Ransomware]: dragnet-ransomware-2023-1872 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 30e8d2ac-98a9-59fb-9ece-35ab79cf5910

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
