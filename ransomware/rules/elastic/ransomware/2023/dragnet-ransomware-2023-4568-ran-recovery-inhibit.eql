// Dragnet [Ransomware]: dragnet-ransomware-2023-4568 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f123d014-99b6-5ff5-ba51-79a51471801a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
