// Dragnet [Ransomware]: dragnet-ransomware-2023-0646 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8e16cd12-4696-57f4-aa51-0c7cdd42af1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
