// Dragnet [Ransomware]: dragnet-ransomware-2023-2230 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b6dc3d7c-51be-5a71-b149-6d1493966d20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
