// Dragnet [Ransomware]: dragnet-ransomware-2023-3244 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9f53e5cd-137c-5d43-911c-ce18b28fa1a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
