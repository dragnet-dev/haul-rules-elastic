// Dragnet [Ransomware]: dragnet-ransomware-2023-1873 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 0721fc0e-2f42-5e71-b8bc-6d6ab13452cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
