// Dragnet [Ransomware]: dragnet-ransomware-2023-2607 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 94594384-407d-5d96-aa96-030e195f82d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
