// Dragnet [Ransomware]: dragnet-ransomware-2023-5323 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: fbc37ffb-b98f-556f-bbb5-6b406fdec4ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
