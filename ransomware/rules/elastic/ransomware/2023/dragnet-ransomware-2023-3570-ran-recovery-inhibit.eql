// Dragnet [Ransomware]: dragnet-ransomware-2023-3570 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 66cc22c7-ef78-5fd4-b4da-61c1bc415591

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
