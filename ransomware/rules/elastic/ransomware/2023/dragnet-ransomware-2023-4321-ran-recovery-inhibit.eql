// Dragnet [Ransomware]: dragnet-ransomware-2023-4321 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 23de6459-4186-5823-9682-ee33e8798a07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
