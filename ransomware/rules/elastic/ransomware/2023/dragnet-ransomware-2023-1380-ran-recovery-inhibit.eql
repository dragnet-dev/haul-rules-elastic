// Dragnet [Ransomware]: dragnet-ransomware-2023-1380 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: a4a1a1ca-1cec-5850-be2c-d43479da664a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
