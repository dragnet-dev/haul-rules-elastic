// Dragnet [Ransomware]: dragnet-ransomware-2023-4819 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 0d34c333-1b15-5e9c-ac20-bdef6e8cd50f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
