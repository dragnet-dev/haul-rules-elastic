// Dragnet [Ransomware]: dragnet-ransomware-2023-1589 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: f456598e-5376-5957-927d-3cf9ba26ee6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
