// Dragnet [Ransomware]: dragnet-ransomware-2023-1562 — Recovery Inhibition (mallox)
// Status: experimental | Level: high | ID: 977b17f6-a178-5339-9218-06c62f34ab96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
