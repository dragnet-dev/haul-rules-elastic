// Dragnet [Ransomware]: dragnet-ransomware-2023-0061 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: a0b3accb-bc71-5b44-af0b-a29076a57e65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
