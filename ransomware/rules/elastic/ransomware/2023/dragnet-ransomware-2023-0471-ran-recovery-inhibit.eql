// Dragnet [Ransomware]: dragnet-ransomware-2023-0471 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 9f9c0b7b-6a29-5e9d-b8fc-a62b66a583a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
