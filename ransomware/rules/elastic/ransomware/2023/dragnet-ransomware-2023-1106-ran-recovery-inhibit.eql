// Dragnet [Ransomware]: dragnet-ransomware-2023-1106 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: a1b0b17f-c65f-5206-bdf7-9d31cd926f04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
