// Dragnet [Ransomware]: dragnet-ransomware-2023-0676 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 43ff4196-100d-50cf-a7e1-54189fbaccec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
