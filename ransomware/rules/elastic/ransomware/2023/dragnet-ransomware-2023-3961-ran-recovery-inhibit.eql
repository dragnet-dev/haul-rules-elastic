// Dragnet [Ransomware]: dragnet-ransomware-2023-3961 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: ddc84d4d-063a-5783-b9b5-41ff1a52e1b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
