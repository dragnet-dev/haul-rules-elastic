// Dragnet [Ransomware]: dragnet-ransomware-2023-0126 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0cec2da1-f2b9-50e2-8187-32312abaf746

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
