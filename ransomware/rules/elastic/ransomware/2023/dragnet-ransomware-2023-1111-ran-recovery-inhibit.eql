// Dragnet [Ransomware]: dragnet-ransomware-2023-1111 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1cc4539e-4b8e-5bae-aec7-ab6efef88123

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
