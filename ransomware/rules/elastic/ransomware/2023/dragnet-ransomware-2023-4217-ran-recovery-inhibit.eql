// Dragnet [Ransomware]: dragnet-ransomware-2023-4217 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 308f27b4-75e4-548e-b03d-0abf78f171b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
