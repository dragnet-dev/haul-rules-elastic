// Dragnet [Ransomware]: dragnet-ransomware-2023-3695 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 4cf8d311-645c-58f2-82a6-15d6d4bb1a73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
