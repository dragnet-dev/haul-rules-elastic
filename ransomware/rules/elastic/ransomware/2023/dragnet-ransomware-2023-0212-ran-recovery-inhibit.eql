// Dragnet [Ransomware]: dragnet-ransomware-2023-0212 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a1e39789-b790-5365-a281-042db3c6d4b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
