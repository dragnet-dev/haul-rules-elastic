// Dragnet [Ransomware]: dragnet-ransomware-2023-3090 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 5acf04ca-6658-58fa-bd28-abb6350cd85d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
