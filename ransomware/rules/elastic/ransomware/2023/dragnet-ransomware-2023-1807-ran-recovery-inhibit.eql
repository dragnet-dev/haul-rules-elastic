// Dragnet [Ransomware]: dragnet-ransomware-2023-1807 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: ae5a3e80-2869-5d26-b259-d1389606afba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
