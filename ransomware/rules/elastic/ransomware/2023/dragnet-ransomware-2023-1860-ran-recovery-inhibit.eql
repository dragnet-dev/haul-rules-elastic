// Dragnet [Ransomware]: dragnet-ransomware-2023-1860 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a40e71ab-d292-567d-abb4-badcf5d62674

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
