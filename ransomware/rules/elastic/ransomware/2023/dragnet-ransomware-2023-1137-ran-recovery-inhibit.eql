// Dragnet [Ransomware]: dragnet-ransomware-2023-1137 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 26aab650-9bc1-597d-be9f-99203ca2fd1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
