// Dragnet [Ransomware]: dragnet-ransomware-2023-3873 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7a8efd52-dc5f-5029-92d9-932a5f9f2e2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
