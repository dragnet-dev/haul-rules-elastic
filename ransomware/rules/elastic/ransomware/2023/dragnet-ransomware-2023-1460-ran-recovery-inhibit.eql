// Dragnet [Ransomware]: dragnet-ransomware-2023-1460 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f1222401-52a6-54f3-8acd-e601953d5a98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
