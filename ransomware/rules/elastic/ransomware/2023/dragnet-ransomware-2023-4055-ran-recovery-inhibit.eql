// Dragnet [Ransomware]: dragnet-ransomware-2023-4055 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ad4ce28d-34c7-57fb-a3e4-ce210a5b3075

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
