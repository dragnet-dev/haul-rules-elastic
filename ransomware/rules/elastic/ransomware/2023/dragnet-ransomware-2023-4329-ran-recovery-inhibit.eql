// Dragnet [Ransomware]: dragnet-ransomware-2023-4329 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: d4ce8b84-2061-5cfc-93c8-0f02e1459335

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
