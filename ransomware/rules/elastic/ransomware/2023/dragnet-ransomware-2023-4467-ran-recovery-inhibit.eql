// Dragnet [Ransomware]: dragnet-ransomware-2023-4467 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 20e52d99-9a9d-5733-a3fd-88dd626c7487

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
