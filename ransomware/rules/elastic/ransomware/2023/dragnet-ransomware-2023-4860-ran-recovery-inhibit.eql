// Dragnet [Ransomware]: dragnet-ransomware-2023-4860 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 53eaf9af-e319-5d28-8ef2-8b8224ce3908

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
