// Dragnet [Ransomware]: dragnet-ransomware-2023-0522 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: bbf9e1ec-888c-5465-94b7-7f9baf8c4497

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
