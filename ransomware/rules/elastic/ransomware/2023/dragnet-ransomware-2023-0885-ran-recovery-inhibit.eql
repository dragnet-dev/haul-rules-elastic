// Dragnet [Ransomware]: dragnet-ransomware-2023-0885 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1f4cb0a4-90aa-5087-8fc3-a901b9298dfc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
