// Dragnet [Ransomware]: dragnet-ransomware-2023-2241 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 53ffde55-b875-5090-8edb-dfbde2ec5990

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
