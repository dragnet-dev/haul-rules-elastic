// Dragnet [Ransomware]: dragnet-ransomware-2023-4579 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3af3dfd8-9221-5152-8d6d-c74a37267d61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
