// Dragnet [Ransomware]: dragnet-ransomware-2023-0295 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0882e038-0981-5e85-a16b-637c461a2713

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
