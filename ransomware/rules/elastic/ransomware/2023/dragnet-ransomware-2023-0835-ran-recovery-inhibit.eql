// Dragnet [Ransomware]: dragnet-ransomware-2023-0835 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e1e77c11-1eea-5126-b511-0bc951091b58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
