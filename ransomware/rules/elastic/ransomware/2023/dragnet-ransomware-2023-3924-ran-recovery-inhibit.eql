// Dragnet [Ransomware]: dragnet-ransomware-2023-3924 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 66497c56-488c-5651-b25d-1028c9e50c09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
