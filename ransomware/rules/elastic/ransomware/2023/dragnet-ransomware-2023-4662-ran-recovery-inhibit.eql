// Dragnet [Ransomware]: dragnet-ransomware-2023-4662 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: cedc8a33-c0de-5896-a622-5650b9992907

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
