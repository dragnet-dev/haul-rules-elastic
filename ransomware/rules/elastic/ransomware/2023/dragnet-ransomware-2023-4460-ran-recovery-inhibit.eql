// Dragnet [Ransomware]: dragnet-ransomware-2023-4460 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: ad21e517-0ca7-5865-a215-7d8f3acc0ac9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
