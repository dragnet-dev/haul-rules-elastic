// Dragnet [Ransomware]: dragnet-ransomware-2023-0155 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 1b78177a-dce3-5c08-b437-7aebd94e97ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
