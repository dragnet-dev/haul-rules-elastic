// Dragnet [Ransomware]: dragnet-ransomware-2023-4142 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3016fa0d-bd5e-5e01-a858-eb15bfb1c306

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
