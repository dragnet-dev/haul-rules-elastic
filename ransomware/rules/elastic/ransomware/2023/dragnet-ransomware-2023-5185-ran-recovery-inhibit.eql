// Dragnet [Ransomware]: dragnet-ransomware-2023-5185 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 86207440-9090-5008-b416-6160fa6f14c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
