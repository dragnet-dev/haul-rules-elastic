// Dragnet [Ransomware]: dragnet-ransomware-2023-3594 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 813935a9-6025-52f2-a19f-135d1ddecdff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
