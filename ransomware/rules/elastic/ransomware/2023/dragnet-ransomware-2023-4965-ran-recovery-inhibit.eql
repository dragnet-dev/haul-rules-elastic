// Dragnet [Ransomware]: dragnet-ransomware-2023-4965 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 84c513c6-ec60-565d-a963-c83de38bcc1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
