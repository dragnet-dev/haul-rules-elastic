// Dragnet [Ransomware]: dragnet-ransomware-2023-3687 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 3300b301-77a7-546b-9b4c-a96977b1f6dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
