// Dragnet [Ransomware]: dragnet-ransomware-2023-0257 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 9c77af1c-5fc4-5021-8280-0d657ac7b9f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
