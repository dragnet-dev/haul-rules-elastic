// Dragnet [Ransomware]: dragnet-ransomware-2023-3358 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 72410bf6-3174-51a3-9c62-9245e8437cd2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
