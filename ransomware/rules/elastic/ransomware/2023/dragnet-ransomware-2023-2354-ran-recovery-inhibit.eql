// Dragnet [Ransomware]: dragnet-ransomware-2023-2354 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: cbb961fa-e320-54d2-a84b-cb6f8fee01e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
