// Dragnet [Ransomware]: dragnet-ransomware-2023-3879 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 745e591e-19f0-5e50-af86-44a5581b2331

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
