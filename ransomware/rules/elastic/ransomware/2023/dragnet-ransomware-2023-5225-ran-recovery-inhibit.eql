// Dragnet [Ransomware]: dragnet-ransomware-2023-5225 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: a985bc76-7338-5b9c-a936-9ca6ceff13c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
