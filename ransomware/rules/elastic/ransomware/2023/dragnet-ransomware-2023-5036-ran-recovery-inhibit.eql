// Dragnet [Ransomware]: dragnet-ransomware-2023-5036 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: b98b1c91-98b3-5af0-b9c7-723419848665

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
