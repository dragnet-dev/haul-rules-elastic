// Dragnet [Ransomware]: dragnet-ransomware-2023-0171 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6662825a-99b4-514a-a1c7-28f96b1d6db7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
