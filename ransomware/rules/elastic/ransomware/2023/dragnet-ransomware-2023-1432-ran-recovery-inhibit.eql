// Dragnet [Ransomware]: dragnet-ransomware-2023-1432 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: 216c60b0-0c15-5375-a16c-401314015680

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
