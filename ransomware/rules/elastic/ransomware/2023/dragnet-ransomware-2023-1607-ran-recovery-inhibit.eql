// Dragnet [Ransomware]: dragnet-ransomware-2023-1607 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7cdbd773-6fb0-5812-95d8-3ec502d6fa11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
