// Dragnet [Ransomware]: dragnet-ransomware-2023-2213 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: eb69ddcd-352e-5f97-92ab-d3e1fa10d641

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
