// Dragnet [Ransomware]: dragnet-ransomware-2023-4003 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 97163e22-590b-578f-8b8f-662b43b7f8b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
