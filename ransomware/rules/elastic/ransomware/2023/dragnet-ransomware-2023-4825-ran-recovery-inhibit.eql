// Dragnet [Ransomware]: dragnet-ransomware-2023-4825 — Recovery Inhibition (vicesociety)
// Status: experimental | Level: high | ID: 75d3e8ff-b059-5dd3-8572-e06b92db2693

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
