// Dragnet [Ransomware]: dragnet-ransomware-2023-3184 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1b3dfea0-5fa5-55ae-97a7-f309c98e74f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
