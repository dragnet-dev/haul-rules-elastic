// Dragnet [Ransomware]: dragnet-ransomware-2023-4518 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 994a56b0-b5a6-5289-87e4-b8b4c261dbd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
