// Dragnet [Ransomware]: dragnet-ransomware-2023-4288 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: b448a091-aeb8-582c-ab3d-7acd15c7f0b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
