// Dragnet [Ransomware]: dragnet-ransomware-2023-0334 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9ec4eb14-708a-5bb1-a4c0-673326b2296c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
