// Dragnet [Ransomware]: dragnet-ransomware-2023-2809 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: c66c13d9-84e9-58d8-a41a-8df0f1bc84d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
