// Dragnet [Ransomware]: dragnet-ransomware-2023-3601 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: dd152ebe-012e-5ef8-9145-799a7fe3cc2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
