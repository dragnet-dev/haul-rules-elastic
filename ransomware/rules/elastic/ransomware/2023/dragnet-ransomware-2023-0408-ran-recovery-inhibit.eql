// Dragnet [Ransomware]: dragnet-ransomware-2023-0408 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 049d6f8c-dede-5203-b891-5848af75ab42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
