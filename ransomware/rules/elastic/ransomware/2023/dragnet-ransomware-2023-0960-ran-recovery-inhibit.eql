// Dragnet [Ransomware]: dragnet-ransomware-2023-0960 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5da78c83-7663-5dac-845d-fa2146f0749f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
