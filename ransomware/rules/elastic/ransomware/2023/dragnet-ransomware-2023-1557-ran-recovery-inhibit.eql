// Dragnet [Ransomware]: dragnet-ransomware-2023-1557 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0a354793-f6a5-548b-897f-652ecce50a24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
