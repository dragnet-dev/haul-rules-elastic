// Dragnet [Ransomware]: dragnet-ransomware-2023-5093 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 9a572b37-d970-53bd-bcae-026eebaf3ca3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
