// Dragnet [Ransomware]: dragnet-ransomware-2023-2841 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 28723d20-1b94-50e3-aef0-025e492a217a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
