// Dragnet [Ransomware]: dragnet-ransomware-2023-0963 — Recovery Inhibition (rancoz)
// Status: experimental | Level: high | ID: e5470642-8f85-56a1-9dc0-53f21388dbed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
