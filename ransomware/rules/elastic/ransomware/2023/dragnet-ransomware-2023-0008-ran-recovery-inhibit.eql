// Dragnet [Ransomware]: dragnet-ransomware-2023-0008 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 0afdd8cc-7c81-54b5-82c5-ae75e24d5430

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
