// Dragnet [Ransomware]: dragnet-ransomware-2023-0888 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7ac35ed5-16f3-5717-b509-bdea944a8d83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
