// Dragnet [Ransomware]: dragnet-ransomware-2023-0793 — Recovery Inhibition (werewolves)
// Status: experimental | Level: high | ID: 94130687-9e6a-54ef-a308-76db44af3334

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
