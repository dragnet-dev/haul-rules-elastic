// Dragnet [Ransomware]: dragnet-ransomware-2023-1183 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c1d834bf-3466-542d-b6eb-e1be88e16331

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
