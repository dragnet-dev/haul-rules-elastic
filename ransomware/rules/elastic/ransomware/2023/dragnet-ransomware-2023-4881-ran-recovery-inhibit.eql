// Dragnet [Ransomware]: dragnet-ransomware-2023-4881 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f5adf67a-39f8-5794-9078-2db8bd676984

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
