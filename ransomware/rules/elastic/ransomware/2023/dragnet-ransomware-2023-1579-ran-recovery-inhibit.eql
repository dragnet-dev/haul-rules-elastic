// Dragnet [Ransomware]: dragnet-ransomware-2023-1579 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 526aba04-bd8a-5a94-9f69-a1a29e83b1cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
