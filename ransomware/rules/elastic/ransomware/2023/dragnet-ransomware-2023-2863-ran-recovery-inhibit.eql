// Dragnet [Ransomware]: dragnet-ransomware-2023-2863 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: d716f7c2-afd4-5a47-a83f-03b679bcb0d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
