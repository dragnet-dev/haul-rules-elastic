// Dragnet [Ransomware]: dragnet-ransomware-2023-1749 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: d812741b-eb60-5f1b-8a1f-b2abe7c39f10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
