// Dragnet [Ransomware]: dragnet-ransomware-2023-1221 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: b47d8b6c-c0be-55c6-8562-8d5fe1d2e81b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
