// Dragnet [Ransomware]: dragnet-ransomware-2023-1957 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 93e7855f-3e54-5692-bf01-2031c0f07f4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
