// Dragnet [Ransomware]: dragnet-ransomware-2023-5090 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 2d5a9399-b194-5ba8-a21b-a8a83cf234ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
