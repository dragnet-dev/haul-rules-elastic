// Dragnet [Ransomware]: dragnet-ransomware-2023-0748 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: ac55d9e3-8a99-5408-8575-a49bd10a51d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
