// Dragnet [Ransomware]: dragnet-ransomware-2023-0144 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: 225b490f-c583-5859-8776-c7d3a6516782

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
