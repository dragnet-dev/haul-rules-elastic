// Dragnet [Ransomware]: dragnet-ransomware-2023-1877 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: 04e0ab8e-4f1f-5705-a223-f65439d8d6a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
