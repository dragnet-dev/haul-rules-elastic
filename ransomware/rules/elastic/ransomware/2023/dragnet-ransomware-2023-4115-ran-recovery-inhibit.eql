// Dragnet [Ransomware]: dragnet-ransomware-2023-4115 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0829e35e-58a5-53a9-b5fe-63780c20eeee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
