// Dragnet [Ransomware]: dragnet-ransomware-2023-5231 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 81b04fd4-63c6-5454-a058-e272efaad8bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
