// Dragnet [Ransomware]: dragnet-ransomware-2023-4008 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 44641919-28b1-54d8-98a1-2b340f347806

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
