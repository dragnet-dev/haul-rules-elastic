// Dragnet [Ransomware]: dragnet-ransomware-2023-1232 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 77d6bb74-86f6-5224-8bc6-fbef7a76979a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
