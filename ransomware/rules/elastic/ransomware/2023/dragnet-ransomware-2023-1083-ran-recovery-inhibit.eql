// Dragnet [Ransomware]: dragnet-ransomware-2023-1083 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e38d5c74-530f-5c9e-bb48-b429b4e9f897

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
