// Dragnet [Ransomware]: dragnet-ransomware-2023-2656 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: a9dacbc1-5586-5947-a14d-d044ffa6ec7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
