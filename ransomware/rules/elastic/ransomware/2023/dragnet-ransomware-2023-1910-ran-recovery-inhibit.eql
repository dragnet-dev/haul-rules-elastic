// Dragnet [Ransomware]: dragnet-ransomware-2023-1910 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 908e416e-7b25-5f65-9913-dca94f0172a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
