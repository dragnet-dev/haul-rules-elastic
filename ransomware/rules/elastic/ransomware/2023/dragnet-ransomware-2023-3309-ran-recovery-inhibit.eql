// Dragnet [Ransomware]: dragnet-ransomware-2023-3309 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 00fd1318-4a5a-5960-a0e4-930dc578821d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
