// Dragnet [Ransomware]: dragnet-ransomware-2023-4252 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 96728338-a9f1-5ac9-ba03-4b344eff43f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
