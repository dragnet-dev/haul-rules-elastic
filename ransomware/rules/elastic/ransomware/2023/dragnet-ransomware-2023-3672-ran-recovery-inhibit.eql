// Dragnet [Ransomware]: dragnet-ransomware-2023-3672 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: a0653d8a-c310-5eae-9058-4adbc03af1a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
