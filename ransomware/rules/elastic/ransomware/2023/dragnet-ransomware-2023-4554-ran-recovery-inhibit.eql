// Dragnet [Ransomware]: dragnet-ransomware-2023-4554 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: 23f0baa2-13fb-5404-a190-20714d60c064

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
