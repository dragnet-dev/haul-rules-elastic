// Dragnet [Ransomware]: dragnet-ransomware-2023-2110 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 7c0e0922-c558-5649-8d9b-ca4f88976c28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
