// Dragnet [Ransomware]: dragnet-ransomware-2023-1161 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e515fea3-ac64-53b4-af86-e7ffa34cefcc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
