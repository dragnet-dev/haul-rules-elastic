// Dragnet [Ransomware]: dragnet-ransomware-2023-2648 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 33fdb6a9-5b3b-55dd-9c20-fe241a277c19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
