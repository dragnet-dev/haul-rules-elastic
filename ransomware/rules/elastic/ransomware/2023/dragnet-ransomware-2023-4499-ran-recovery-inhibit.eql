// Dragnet [Ransomware]: dragnet-ransomware-2023-4499 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6715039f-af91-5053-897d-22ceccab43a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
