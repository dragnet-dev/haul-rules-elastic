// Dragnet [Ransomware]: dragnet-ransomware-2023-3104 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: c95e115c-9df4-5dfe-97a7-9b54033305e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
