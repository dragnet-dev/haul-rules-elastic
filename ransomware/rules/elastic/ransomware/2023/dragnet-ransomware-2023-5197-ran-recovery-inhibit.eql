// Dragnet [Ransomware]: dragnet-ransomware-2023-5197 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e2103bb8-429e-59b2-95c1-c82ea0fa761c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
