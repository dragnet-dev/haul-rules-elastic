// Dragnet [Ransomware]: dragnet-ransomware-2023-2882 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 3f9a3499-58e1-564f-a23c-bf5849fb7db5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
