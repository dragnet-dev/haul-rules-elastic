// Dragnet [Ransomware]: dragnet-ransomware-2023-3195 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: acb13f5d-d92d-58d0-8372-fd34b4da921a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
