// Dragnet [Ransomware]: dragnet-ransomware-2023-1453 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 70e72f30-b44d-5af5-9aa6-9bafd889de53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
