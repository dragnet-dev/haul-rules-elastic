// Dragnet [Ransomware]: dragnet-ransomware-2023-2250 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5af55708-0627-5b96-b631-bc5291c08a1f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
