// Dragnet [Ransomware]: dragnet-ransomware-2023-4232 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2a4a375b-c4fe-50f9-91b2-3794df37e8e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
