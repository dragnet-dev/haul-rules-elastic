// Dragnet [Ransomware]: dragnet-ransomware-2023-3806 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 9c74efb7-9f14-5faf-8012-b847c419f1bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
