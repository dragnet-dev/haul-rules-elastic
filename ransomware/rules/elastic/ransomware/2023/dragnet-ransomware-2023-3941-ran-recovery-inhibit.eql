// Dragnet [Ransomware]: dragnet-ransomware-2023-3941 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: fd8bd194-1f69-5f5f-8036-26400154439e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
