// Dragnet [Ransomware]: dragnet-ransomware-2023-1017 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: b6f2f704-5543-57cb-9100-b2b94f07668e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
