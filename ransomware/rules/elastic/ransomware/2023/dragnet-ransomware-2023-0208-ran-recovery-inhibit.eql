// Dragnet [Ransomware]: dragnet-ransomware-2023-0208 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 87e16f3e-d003-59b1-a63f-3593b39205a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
