// Dragnet [Ransomware]: dragnet-ransomware-2023-5331 — Recovery Inhibition (dunghill)
// Status: experimental | Level: high | ID: 4d4954ed-7aa7-5211-83cd-3dc891cfbc1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
