// Dragnet [Ransomware]: dragnet-ransomware-2023-4316 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 49d33301-b8f1-5b78-969c-6a7350be1970

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
