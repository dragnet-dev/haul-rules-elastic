// Dragnet [Ransomware]: dragnet-ransomware-2023-1178 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 4b52ca6d-3780-52eb-857a-d0e42c70b61d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
