// Dragnet [Ransomware]: dragnet-ransomware-2023-3577 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a533f1bd-1371-54ca-9f2a-7b4461e285c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
