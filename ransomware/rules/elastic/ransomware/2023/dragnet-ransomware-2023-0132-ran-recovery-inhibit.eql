// Dragnet [Ransomware]: dragnet-ransomware-2023-0132 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2b75ee3e-879e-515f-8ec9-ac98a26224e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
