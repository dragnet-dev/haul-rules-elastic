// Dragnet [Ransomware]: dragnet-ransomware-2023-4949 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: 6a0bcaf3-38f5-52ce-9df8-032ba951a1e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
