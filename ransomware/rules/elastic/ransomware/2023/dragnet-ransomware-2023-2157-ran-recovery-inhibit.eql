// Dragnet [Ransomware]: dragnet-ransomware-2023-2157 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: f65c9a57-19ac-5446-b2ec-fdbbb7dc7d82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
