// Dragnet [Ransomware]: dragnet-ransomware-2023-4832 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 1709e7a2-a694-5c64-b328-df60400860ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
