// Dragnet [Ransomware]: dragnet-ransomware-2023-3582 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: fd944ee6-e219-520c-af9a-8e7830c365c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
