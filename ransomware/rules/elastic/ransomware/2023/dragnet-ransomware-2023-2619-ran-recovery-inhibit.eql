// Dragnet [Ransomware]: dragnet-ransomware-2023-2619 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b18fcaf2-699f-587b-90eb-5a74c4fb69e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
