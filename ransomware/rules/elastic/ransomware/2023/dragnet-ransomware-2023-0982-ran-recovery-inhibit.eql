// Dragnet [Ransomware]: dragnet-ransomware-2023-0982 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 1c8dc29c-b170-52d6-b181-25439bbb0e16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
