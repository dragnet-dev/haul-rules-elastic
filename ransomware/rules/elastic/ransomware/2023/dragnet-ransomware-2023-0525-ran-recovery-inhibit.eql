// Dragnet [Ransomware]: dragnet-ransomware-2023-0525 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 820277d7-2778-50ae-97b3-3cf18dc82a10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
