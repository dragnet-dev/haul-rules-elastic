// Dragnet [Ransomware]: dragnet-ransomware-2023-0505 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: ff462c1c-3003-554b-8bc9-b3fe0ed9ca8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
