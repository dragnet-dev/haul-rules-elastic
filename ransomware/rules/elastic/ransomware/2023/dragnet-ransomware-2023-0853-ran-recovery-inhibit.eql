// Dragnet [Ransomware]: dragnet-ransomware-2023-0853 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: f9ecde15-7de8-53cc-a20a-f0a247ac9c58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
