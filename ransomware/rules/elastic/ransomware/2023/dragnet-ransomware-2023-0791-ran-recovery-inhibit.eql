// Dragnet [Ransomware]: dragnet-ransomware-2023-0791 — Recovery Inhibition (mallox)
// Status: experimental | Level: high | ID: 86b51c3e-87e3-52cb-94a6-1988e51c94bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
