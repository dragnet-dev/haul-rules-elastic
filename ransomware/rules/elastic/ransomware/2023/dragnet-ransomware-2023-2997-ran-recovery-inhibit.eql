// Dragnet [Ransomware]: dragnet-ransomware-2023-2997 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1f8100ce-a31c-541e-8a1c-7296caed44d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
