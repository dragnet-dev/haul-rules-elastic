// Dragnet [Ransomware]: dragnet-ransomware-2023-0426 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 78efd3f6-b56f-544b-9001-c1f634f4439a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
