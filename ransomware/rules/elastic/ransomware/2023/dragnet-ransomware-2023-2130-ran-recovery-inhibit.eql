// Dragnet [Ransomware]: dragnet-ransomware-2023-2130 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 7cacddf3-e73e-540a-85cc-096508499e76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
