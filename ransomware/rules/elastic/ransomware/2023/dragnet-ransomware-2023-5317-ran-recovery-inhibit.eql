// Dragnet [Ransomware]: dragnet-ransomware-2023-5317 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8500db6c-b67e-5ce1-a369-1fe7da52fc6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
