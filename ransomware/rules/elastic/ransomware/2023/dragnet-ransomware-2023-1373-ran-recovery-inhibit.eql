// Dragnet [Ransomware]: dragnet-ransomware-2023-1373 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: df3c30e5-b54a-5605-bab6-8d2a843bc739

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
