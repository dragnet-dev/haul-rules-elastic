// Dragnet [Ransomware]: dragnet-ransomware-2023-4950 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: f4b60d9b-5b48-588d-9bf4-b039830f4ac7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
