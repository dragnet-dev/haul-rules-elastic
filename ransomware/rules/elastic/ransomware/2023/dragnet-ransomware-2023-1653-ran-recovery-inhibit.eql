// Dragnet [Ransomware]: dragnet-ransomware-2023-1653 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 7c048c67-a805-5dc4-bbd8-6964c659f4bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
