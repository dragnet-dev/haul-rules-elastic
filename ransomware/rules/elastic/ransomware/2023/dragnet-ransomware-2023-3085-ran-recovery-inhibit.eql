// Dragnet [Ransomware]: dragnet-ransomware-2023-3085 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 25bdc422-3033-5829-a791-72aa3333bb5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
