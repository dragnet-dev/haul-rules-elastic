// Dragnet [Ransomware]: dragnet-ransomware-2023-1546 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: d7bb5dc0-a92a-57fe-83cf-031d89c6a5ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
