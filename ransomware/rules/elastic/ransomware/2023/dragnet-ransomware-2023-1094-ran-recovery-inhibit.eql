// Dragnet [Ransomware]: dragnet-ransomware-2023-1094 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: 9159a722-c12b-51da-80b2-1010c3f9f497

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
