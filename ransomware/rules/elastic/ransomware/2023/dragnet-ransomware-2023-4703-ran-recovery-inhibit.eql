// Dragnet [Ransomware]: dragnet-ransomware-2023-4703 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 59466159-531d-55db-87a1-6ebf52d29fc3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
