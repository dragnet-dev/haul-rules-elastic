// Dragnet [Ransomware]: dragnet-ransomware-2023-0432 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: 6a6e50e3-e28e-5763-8559-b094bdb65ee9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
