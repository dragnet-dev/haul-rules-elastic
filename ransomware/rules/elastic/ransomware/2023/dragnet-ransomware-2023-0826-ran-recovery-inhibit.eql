// Dragnet [Ransomware]: dragnet-ransomware-2023-0826 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 58bacf44-7145-509b-a55a-021462b3ccd6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
