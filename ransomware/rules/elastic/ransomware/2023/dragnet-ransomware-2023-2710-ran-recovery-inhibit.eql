// Dragnet [Ransomware]: dragnet-ransomware-2023-2710 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: c19aedd9-3c93-5fd4-b85b-db500335f19e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
