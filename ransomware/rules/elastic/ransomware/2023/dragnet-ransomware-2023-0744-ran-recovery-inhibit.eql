// Dragnet [Ransomware]: dragnet-ransomware-2023-0744 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 0715ac39-4b90-5223-9538-1eff9dd4d491

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
