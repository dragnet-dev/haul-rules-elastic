// Dragnet [Ransomware]: dragnet-ransomware-2023-2040 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3c75ec72-345e-5268-a7a1-ae28d000c1a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
