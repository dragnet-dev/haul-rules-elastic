// Dragnet [Ransomware]: dragnet-ransomware-2023-1628 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 6cef142a-27df-524e-a426-1f47be0967cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
