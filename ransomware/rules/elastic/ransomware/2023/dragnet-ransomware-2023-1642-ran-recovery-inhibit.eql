// Dragnet [Ransomware]: dragnet-ransomware-2023-1642 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: fc7256a9-4057-59e8-b051-77a155ab9e04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
