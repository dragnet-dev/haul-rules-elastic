// Dragnet [Ransomware]: dragnet-ransomware-2023-3156 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 61b26c27-f88a-53ab-98f3-f1c06b9aac27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
