// Dragnet [Ransomware]: dragnet-ransomware-2023-2729 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 1666cb47-4c0d-55d0-ab39-e55d0fce349b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
