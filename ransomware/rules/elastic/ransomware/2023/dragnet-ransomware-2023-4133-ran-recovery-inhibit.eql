// Dragnet [Ransomware]: dragnet-ransomware-2023-4133 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 9bd2ab5b-155d-5a69-9efa-1f65a01d1def

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
