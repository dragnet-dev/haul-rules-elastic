// Dragnet [Ransomware]: dragnet-ransomware-2023-1909 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: b12e5657-1ba9-5352-89a1-97eb8d773333

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
