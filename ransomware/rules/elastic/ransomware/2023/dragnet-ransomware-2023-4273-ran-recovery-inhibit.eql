// Dragnet [Ransomware]: dragnet-ransomware-2023-4273 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: b16cd7db-81fa-54c9-97bd-fbac829e88c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
