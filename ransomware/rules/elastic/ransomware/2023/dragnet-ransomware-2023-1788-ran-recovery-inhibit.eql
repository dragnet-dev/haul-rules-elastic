// Dragnet [Ransomware]: dragnet-ransomware-2023-1788 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: 2c90ef75-7ce9-569a-b7cc-1373fc628218

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
