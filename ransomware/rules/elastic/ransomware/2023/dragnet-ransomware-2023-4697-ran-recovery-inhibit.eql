// Dragnet [Ransomware]: dragnet-ransomware-2023-4697 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: e7088380-81d2-5869-adc8-879043638c15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
