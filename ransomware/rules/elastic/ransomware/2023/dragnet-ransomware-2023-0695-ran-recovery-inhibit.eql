// Dragnet [Ransomware]: dragnet-ransomware-2023-0695 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 904440b6-c10a-5b66-89c1-fb1ce6c75442

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
