// Dragnet [Ransomware]: dragnet-ransomware-2023-5167 — Recovery Inhibition (darkrace)
// Status: experimental | Level: high | ID: 5e35ea68-7b8d-5450-b5b5-f848922aa8aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
