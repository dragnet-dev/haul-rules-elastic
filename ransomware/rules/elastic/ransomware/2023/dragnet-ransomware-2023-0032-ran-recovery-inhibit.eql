// Dragnet [Ransomware]: dragnet-ransomware-2023-0032 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 66909eec-98ed-56ea-9af2-2c53c78fa714

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
