// Dragnet [Ransomware]: dragnet-ransomware-2023-5334 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: cc679a8e-f5b1-5207-ac9a-d81506994480

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
