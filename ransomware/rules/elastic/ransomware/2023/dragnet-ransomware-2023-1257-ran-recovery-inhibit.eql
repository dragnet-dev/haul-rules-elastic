// Dragnet [Ransomware]: dragnet-ransomware-2023-1257 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: d2c5b3d0-37da-574e-bcbd-4668736973ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
