// Dragnet [Ransomware]: dragnet-ransomware-2023-5296 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 68ea4295-63a5-5989-8284-72d5d6de030c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
