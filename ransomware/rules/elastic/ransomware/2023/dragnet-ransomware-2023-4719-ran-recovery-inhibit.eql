// Dragnet [Ransomware]: dragnet-ransomware-2023-4719 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3dfb19dd-1ce8-5f42-b033-09c7738fc462

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
