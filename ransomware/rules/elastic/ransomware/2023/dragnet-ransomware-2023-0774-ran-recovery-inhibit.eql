// Dragnet [Ransomware]: dragnet-ransomware-2023-0774 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: e6d0098e-c744-5e23-82da-5c4496ce8996

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
