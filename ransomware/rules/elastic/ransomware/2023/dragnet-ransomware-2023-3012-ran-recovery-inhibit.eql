// Dragnet [Ransomware]: dragnet-ransomware-2023-3012 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 796c393e-6d33-5dc4-bd60-cf1a79e97114

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
