// Dragnet [Ransomware]: dragnet-ransomware-2023-1024 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 8c2be4a7-8f47-54fc-8d19-109da044046f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
