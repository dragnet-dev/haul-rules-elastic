// Dragnet [Ransomware]: dragnet-ransomware-2023-2704 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a3d56ae7-592e-5428-b4de-23c872942bc0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
