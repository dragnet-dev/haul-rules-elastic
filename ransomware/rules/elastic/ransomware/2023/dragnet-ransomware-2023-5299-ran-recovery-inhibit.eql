// Dragnet [Ransomware]: dragnet-ransomware-2023-5299 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: a68b67eb-4617-52df-a1f5-ff71b182555b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
