// Dragnet [Ransomware]: dragnet-ransomware-2023-2276 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 4635b28f-136c-53f0-b89d-aed1efce2311

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
