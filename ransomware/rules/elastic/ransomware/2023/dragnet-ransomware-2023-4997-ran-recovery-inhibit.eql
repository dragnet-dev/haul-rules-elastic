// Dragnet [Ransomware]: dragnet-ransomware-2023-4997 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: bf0cc00c-0c6b-5740-8bff-cd26ff7b5c0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
