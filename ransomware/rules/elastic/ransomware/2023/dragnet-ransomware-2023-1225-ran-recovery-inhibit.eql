// Dragnet [Ransomware]: dragnet-ransomware-2023-1225 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: e2f9916f-f531-5e92-9d1f-783ab249a2d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
