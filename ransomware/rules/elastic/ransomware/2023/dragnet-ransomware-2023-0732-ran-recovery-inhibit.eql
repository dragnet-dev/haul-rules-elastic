// Dragnet [Ransomware]: dragnet-ransomware-2023-0732 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: dd4977c5-fca4-5a41-bbd8-57e5348ab041

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
