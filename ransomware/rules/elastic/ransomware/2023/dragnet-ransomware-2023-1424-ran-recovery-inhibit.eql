// Dragnet [Ransomware]: dragnet-ransomware-2023-1424 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1e2fac18-8ec5-517b-925f-f5bbb4e06111

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
