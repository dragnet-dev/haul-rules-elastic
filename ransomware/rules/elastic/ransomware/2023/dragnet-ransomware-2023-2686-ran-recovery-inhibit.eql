// Dragnet [Ransomware]: dragnet-ransomware-2023-2686 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c03281a6-9baf-53ad-acc8-d82126ab8b0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
