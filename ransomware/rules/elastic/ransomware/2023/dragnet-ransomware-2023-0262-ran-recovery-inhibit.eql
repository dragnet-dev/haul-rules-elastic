// Dragnet [Ransomware]: dragnet-ransomware-2023-0262 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: e7fd8ee5-608b-5bf2-bc78-b66425697878

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
