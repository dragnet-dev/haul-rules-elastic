// Dragnet [Ransomware]: dragnet-ransomware-2023-0936 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: bc567982-78bd-519d-a662-04d69b60351e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
