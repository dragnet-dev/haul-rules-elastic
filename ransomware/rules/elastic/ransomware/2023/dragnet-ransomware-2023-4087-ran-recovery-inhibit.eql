// Dragnet [Ransomware]: dragnet-ransomware-2023-4087 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 8747567b-3020-5927-8018-62e76abe9590

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
