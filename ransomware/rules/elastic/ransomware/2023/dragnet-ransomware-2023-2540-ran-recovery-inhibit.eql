// Dragnet [Ransomware]: dragnet-ransomware-2023-2540 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: b851561b-ec63-5427-99ea-a1af3dc0de00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
