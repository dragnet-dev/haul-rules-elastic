// Dragnet [Ransomware]: dragnet-ransomware-2023-2855 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: fac91387-5e3b-504b-9d18-14b1e5101a8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
