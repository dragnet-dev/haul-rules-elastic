// Dragnet [Ransomware]: dragnet-ransomware-2023-2816 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: a4f926ee-9b2d-5287-b0c9-cc087544c205

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
