// Dragnet [Ransomware]: dragnet-ransomware-2023-5028 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 0f9ecc64-c9fb-519c-aa2f-92d40eab0460

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
