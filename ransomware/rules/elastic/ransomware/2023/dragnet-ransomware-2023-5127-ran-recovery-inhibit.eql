// Dragnet [Ransomware]: dragnet-ransomware-2023-5127 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9efafcf7-5bc6-535c-9566-dbf8c94ddb39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
