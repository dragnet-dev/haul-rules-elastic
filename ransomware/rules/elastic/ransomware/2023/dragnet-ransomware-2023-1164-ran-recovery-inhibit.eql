// Dragnet [Ransomware]: dragnet-ransomware-2023-1164 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 14b39439-09e4-577f-a5b5-7cfeedc6f97b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
