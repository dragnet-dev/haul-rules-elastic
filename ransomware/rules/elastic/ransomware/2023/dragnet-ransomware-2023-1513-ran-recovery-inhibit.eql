// Dragnet [Ransomware]: dragnet-ransomware-2023-1513 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: cb9f96cc-190f-555a-ba87-d93db725cfc9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
