// Dragnet [Ransomware]: dragnet-ransomware-2023-0844 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 9d7b05ba-15be-50eb-b572-8e082c988d6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
