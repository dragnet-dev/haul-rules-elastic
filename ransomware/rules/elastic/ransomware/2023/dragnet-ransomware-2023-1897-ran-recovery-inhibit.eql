// Dragnet [Ransomware]: dragnet-ransomware-2023-1897 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 927e679a-1899-5e2c-947d-7fce291fc539

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
