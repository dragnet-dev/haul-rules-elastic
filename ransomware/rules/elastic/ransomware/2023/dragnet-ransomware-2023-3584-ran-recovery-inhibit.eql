// Dragnet [Ransomware]: dragnet-ransomware-2023-3584 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: bf12c754-b8df-5a31-b3cf-622d713b9fdd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
