// Dragnet [Ransomware]: dragnet-ransomware-2023-4923 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 406e3f98-52b2-5ddb-a3ac-4ec952e293f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
