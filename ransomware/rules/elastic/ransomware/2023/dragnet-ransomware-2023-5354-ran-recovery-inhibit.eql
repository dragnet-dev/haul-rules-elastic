// Dragnet [Ransomware]: dragnet-ransomware-2023-5354 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 39066f39-9b99-5cd2-8c92-b39e5334b877

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
