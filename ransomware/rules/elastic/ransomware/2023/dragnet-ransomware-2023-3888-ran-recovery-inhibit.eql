// Dragnet [Ransomware]: dragnet-ransomware-2023-3888 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8dc7f736-0168-5a42-8c51-8255fdfaace7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
