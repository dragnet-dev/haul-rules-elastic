// Dragnet [Ransomware]: dragnet-ransomware-2023-1334 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4e76d2f1-21fa-5459-8cc8-0f9c72f06619

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
