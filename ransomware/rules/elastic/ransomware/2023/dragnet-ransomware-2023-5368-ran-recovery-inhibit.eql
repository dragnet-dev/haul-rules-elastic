// Dragnet [Ransomware]: dragnet-ransomware-2023-5368 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: da43c970-58bc-5fad-b24b-150eb5213794

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
