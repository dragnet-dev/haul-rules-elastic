// Dragnet [Ransomware]: dragnet-ransomware-2023-2043 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 1b27b4d3-7e9a-54f8-9668-c7d2df5a99d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
