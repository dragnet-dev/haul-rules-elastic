// Dragnet [Ransomware]: dragnet-ransomware-2023-2376 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 9a309e97-8c5e-5664-a0e9-cdafd950341a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
