// Dragnet [Ransomware]: dragnet-ransomware-2023-0359 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: d5197dc4-88d9-52f2-9c16-ab59be80fa76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
