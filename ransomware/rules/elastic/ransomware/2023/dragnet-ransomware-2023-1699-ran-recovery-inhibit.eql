// Dragnet [Ransomware]: dragnet-ransomware-2023-1699 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 1dd924c2-243e-549e-a939-a855588f171e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
