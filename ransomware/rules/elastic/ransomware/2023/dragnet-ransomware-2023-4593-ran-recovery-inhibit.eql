// Dragnet [Ransomware]: dragnet-ransomware-2023-4593 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 4cf0deec-237a-50cb-ac53-30f5cf708916

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
