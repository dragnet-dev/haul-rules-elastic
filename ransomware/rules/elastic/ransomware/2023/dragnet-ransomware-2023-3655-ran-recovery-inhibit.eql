// Dragnet [Ransomware]: dragnet-ransomware-2023-3655 — Recovery Inhibition (moneymessage)
// Status: experimental | Level: high | ID: 671da738-5294-5cfa-99da-b84229ca1abf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
