// Dragnet [Ransomware]: dragnet-ransomware-2023-1593 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8b8b2d4f-9699-5b2c-bdeb-9d7b0902bc02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
