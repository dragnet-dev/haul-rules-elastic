// Dragnet [Ransomware]: dragnet-ransomware-2023-1547 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 624a0f94-df78-5a69-ac00-871ecdf4f16c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
