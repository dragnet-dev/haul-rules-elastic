// Dragnet [Ransomware]: dragnet-ransomware-2023-2938 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: b1d5cfd7-6d4b-50b9-a50b-9aaba0250a0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
