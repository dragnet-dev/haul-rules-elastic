// Dragnet [Ransomware]: dragnet-ransomware-2023-3344 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: 05eb6417-5777-5bf2-ba45-1095403f849a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
