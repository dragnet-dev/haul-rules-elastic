// Dragnet [Ransomware]: dragnet-ransomware-2023-4145 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 4b24a23f-c1cf-55ed-bbff-7e861ff6e008

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
