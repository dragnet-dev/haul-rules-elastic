// Dragnet [Ransomware]: dragnet-ransomware-2023-3225 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5fa77ff4-83d8-5984-a7ec-3458975e45ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
