// Dragnet [Ransomware]: dragnet-ransomware-2023-4409 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 7eeb74c6-562d-531d-8ac1-9839cc7645d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
