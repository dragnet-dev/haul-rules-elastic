// Dragnet [Ransomware]: dragnet-ransomware-2023-4234 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 6cd2e73e-8a35-5f19-8606-efb7fe64854d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
