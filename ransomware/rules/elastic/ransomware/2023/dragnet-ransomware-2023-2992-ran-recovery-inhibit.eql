// Dragnet [Ransomware]: dragnet-ransomware-2023-2992 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c0d7ac31-04cf-5f2a-b80e-6a0405e2990d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
