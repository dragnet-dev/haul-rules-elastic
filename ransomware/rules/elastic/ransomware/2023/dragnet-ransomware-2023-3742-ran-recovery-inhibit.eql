// Dragnet [Ransomware]: dragnet-ransomware-2023-3742 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 3dc9ee46-0b58-5df0-8d95-dfa85ffb0eae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
