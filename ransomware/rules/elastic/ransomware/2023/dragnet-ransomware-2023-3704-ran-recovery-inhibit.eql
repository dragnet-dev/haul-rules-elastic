// Dragnet [Ransomware]: dragnet-ransomware-2023-3704 — Recovery Inhibition (werewolves)
// Status: experimental | Level: high | ID: 7228bc65-e82b-541a-bd29-4f39acd9435b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
