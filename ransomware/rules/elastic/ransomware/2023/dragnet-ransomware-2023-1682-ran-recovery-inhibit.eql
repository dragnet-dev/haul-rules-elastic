// Dragnet [Ransomware]: dragnet-ransomware-2023-1682 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: 80ac6938-9bdd-5ba2-a6d9-da045db1dfd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
