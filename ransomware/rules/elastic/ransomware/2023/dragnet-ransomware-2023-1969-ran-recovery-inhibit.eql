// Dragnet [Ransomware]: dragnet-ransomware-2023-1969 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 73c7dbcf-fcd0-5916-b474-1887692d8987

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
