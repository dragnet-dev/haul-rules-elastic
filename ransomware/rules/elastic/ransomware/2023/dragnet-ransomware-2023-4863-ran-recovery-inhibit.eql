// Dragnet [Ransomware]: dragnet-ransomware-2023-4863 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ec9bb745-e0fd-5785-a436-6046efc0887b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
