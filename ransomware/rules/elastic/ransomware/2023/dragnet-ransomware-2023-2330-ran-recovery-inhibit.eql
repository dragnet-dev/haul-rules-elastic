// Dragnet [Ransomware]: dragnet-ransomware-2023-2330 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: b8887ceb-fe6c-5f14-9b7d-2af6dcba0e33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
