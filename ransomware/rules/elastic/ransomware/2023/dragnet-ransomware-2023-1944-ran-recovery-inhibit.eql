// Dragnet [Ransomware]: dragnet-ransomware-2023-1944 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: e5677d91-11b8-5757-bfed-81bc0214cf8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
