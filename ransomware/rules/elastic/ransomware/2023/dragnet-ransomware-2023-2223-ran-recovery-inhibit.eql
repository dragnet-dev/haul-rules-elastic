// Dragnet [Ransomware]: dragnet-ransomware-2023-2223 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 3718abcc-a947-5c66-b308-5036900cbf38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
