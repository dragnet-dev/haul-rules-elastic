// Dragnet [Ransomware]: dragnet-ransomware-2023-3929 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9b7f0608-e13f-57db-80bd-f03b93d55a5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
