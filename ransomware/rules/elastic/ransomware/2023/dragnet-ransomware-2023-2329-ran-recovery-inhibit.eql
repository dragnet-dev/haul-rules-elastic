// Dragnet [Ransomware]: dragnet-ransomware-2023-2329 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a8b055d3-bcd8-5988-a2b9-438d38ef27e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
