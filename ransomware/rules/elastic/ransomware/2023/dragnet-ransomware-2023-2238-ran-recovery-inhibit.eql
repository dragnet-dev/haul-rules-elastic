// Dragnet [Ransomware]: dragnet-ransomware-2023-2238 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f275f385-13a3-57c4-8493-7bacfcf465b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
