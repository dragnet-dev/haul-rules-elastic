// Dragnet [Ransomware]: dragnet-ransomware-2023-5106 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8067778a-b96c-53fb-ab3f-94063a1f8a4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
