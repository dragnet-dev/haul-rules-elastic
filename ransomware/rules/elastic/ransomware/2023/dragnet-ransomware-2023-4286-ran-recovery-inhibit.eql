// Dragnet [Ransomware]: dragnet-ransomware-2023-4286 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: d3699420-c0ad-59ce-a83b-40dc054d2883

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
