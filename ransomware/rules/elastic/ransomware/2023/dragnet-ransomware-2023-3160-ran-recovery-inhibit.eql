// Dragnet [Ransomware]: dragnet-ransomware-2023-3160 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 16fa0932-30dd-50a1-bf30-3afefe01e7c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
