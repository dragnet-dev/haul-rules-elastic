// Dragnet [Ransomware]: dragnet-ransomware-2023-2099 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 9dd6c5dd-4f56-5457-8a7d-8a1614b43d71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
