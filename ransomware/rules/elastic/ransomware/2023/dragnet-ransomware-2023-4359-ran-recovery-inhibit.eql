// Dragnet [Ransomware]: dragnet-ransomware-2023-4359 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 4d87c223-9f90-5bd4-aeff-e6a48ab58570

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
