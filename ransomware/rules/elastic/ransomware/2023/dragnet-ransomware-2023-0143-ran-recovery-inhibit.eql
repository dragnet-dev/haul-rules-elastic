// Dragnet [Ransomware]: dragnet-ransomware-2023-0143 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3e107b6c-3777-55cc-9468-4d41df22af4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
