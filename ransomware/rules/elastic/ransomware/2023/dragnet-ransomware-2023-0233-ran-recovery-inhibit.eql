// Dragnet [Ransomware]: dragnet-ransomware-2023-0233 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: 780aa979-82c5-552d-a0ad-1017c1c5240d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
