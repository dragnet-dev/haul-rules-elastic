// Dragnet [Ransomware]: dragnet-ransomware-2023-2741 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 5398c4bf-4a1a-5db7-b609-b9ade658b8cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
