// Dragnet [Ransomware]: dragnet-ransomware-2023-1192 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 716c537e-e544-5368-b08e-5ab6f2b27db0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
