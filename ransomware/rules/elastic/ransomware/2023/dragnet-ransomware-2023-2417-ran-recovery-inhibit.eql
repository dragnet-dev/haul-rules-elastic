// Dragnet [Ransomware]: dragnet-ransomware-2023-2417 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 6271958f-9f66-5e37-9e46-cabcab0b0796

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
