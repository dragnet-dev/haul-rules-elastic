// Dragnet [Ransomware]: dragnet-ransomware-2023-2420 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 089378a3-3803-5f06-ba21-b0e96d5e39ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
