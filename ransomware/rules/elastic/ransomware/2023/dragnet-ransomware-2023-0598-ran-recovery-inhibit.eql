// Dragnet [Ransomware]: dragnet-ransomware-2023-0598 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 3c342bc0-5311-503b-93b1-15cc41788aac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
