// Dragnet [Ransomware]: dragnet-ransomware-2023-1195 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 068e4f81-9058-565e-ad51-6283925edd21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
