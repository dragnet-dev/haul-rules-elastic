// Dragnet [Ransomware]: dragnet-ransomware-2023-4972 — Recovery Inhibition (dunghill)
// Status: experimental | Level: high | ID: 227d6932-95b2-5276-beb6-8f82628c2b09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
