// Dragnet [Ransomware]: dragnet-ransomware-2023-5366 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 5f480c9b-f83a-5f59-92d5-f95299e422ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
