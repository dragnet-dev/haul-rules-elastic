// Dragnet [Ransomware]: dragnet-ransomware-2023-1820 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2332f0d6-c019-5077-adfb-06b93914727b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
