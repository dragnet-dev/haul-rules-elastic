// Dragnet [Ransomware]: dragnet-ransomware-2023-2737 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 9f4823d0-52b9-5d78-ad26-4f6b2aced070

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
