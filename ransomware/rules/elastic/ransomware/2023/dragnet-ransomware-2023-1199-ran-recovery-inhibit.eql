// Dragnet [Ransomware]: dragnet-ransomware-2023-1199 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: b5afbff3-0097-5aad-8266-faa9b8a19984

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
