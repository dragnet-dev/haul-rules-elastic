// Dragnet [Ransomware]: dragnet-ransomware-2023-4401 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c3349703-a119-5aa2-bd7e-7535d0337a31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
