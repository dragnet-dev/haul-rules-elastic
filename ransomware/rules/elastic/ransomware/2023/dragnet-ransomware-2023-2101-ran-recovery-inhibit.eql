// Dragnet [Ransomware]: dragnet-ransomware-2023-2101 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: f9d3623d-82a0-5c6a-80af-44bf2db10edf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
