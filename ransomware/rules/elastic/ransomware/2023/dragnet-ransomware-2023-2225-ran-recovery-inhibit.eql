// Dragnet [Ransomware]: dragnet-ransomware-2023-2225 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 20d143a3-2403-5632-b507-8177a163c981

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
