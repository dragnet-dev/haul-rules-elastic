// Dragnet [Ransomware]: dragnet-ransomware-2023-4709 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9161c844-8648-5280-bcd5-9e309f32441c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
