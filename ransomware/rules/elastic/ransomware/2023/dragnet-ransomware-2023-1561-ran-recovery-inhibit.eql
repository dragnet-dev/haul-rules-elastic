// Dragnet [Ransomware]: dragnet-ransomware-2023-1561 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 2fbfdd59-92c6-51e2-90c8-103fbf701608

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
