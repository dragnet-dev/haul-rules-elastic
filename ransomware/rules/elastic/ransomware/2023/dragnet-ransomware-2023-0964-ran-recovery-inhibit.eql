// Dragnet [Ransomware]: dragnet-ransomware-2023-0964 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 56c95f09-3d20-5ed5-b5aa-d08d98a6b6a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
