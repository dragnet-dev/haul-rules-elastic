// Dragnet [Ransomware]: dragnet-ransomware-2023-3680 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4dcaceaa-598c-5c75-93d0-1c2e0f7998c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
