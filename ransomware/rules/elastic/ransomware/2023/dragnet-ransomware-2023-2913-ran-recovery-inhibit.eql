// Dragnet [Ransomware]: dragnet-ransomware-2023-2913 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: a98badf6-49c0-51d7-8ee1-96621f2450ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
