// Dragnet [Ransomware]: dragnet-ransomware-2023-0433 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: adba68bf-803d-546e-bb66-1085834a98c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
