// Dragnet [Ransomware]: dragnet-ransomware-2023-4295 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 34bfcf97-6f9c-57dd-83c7-eb1f8ac8736e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
