// Dragnet [Ransomware]: dragnet-ransomware-2023-0203 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c25a0bcf-9317-5c8e-a7df-bc20f28f38dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
