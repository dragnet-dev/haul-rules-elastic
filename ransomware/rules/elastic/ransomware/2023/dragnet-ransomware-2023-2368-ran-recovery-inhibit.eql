// Dragnet [Ransomware]: dragnet-ransomware-2023-2368 — Recovery Inhibition (medusa)
// Status: deprecated | Level: high | ID: cc049016-bf79-5dbd-abfb-107ea5e74c5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
