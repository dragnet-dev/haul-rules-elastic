// Dragnet [Ransomware]: dragnet-ransomware-2023-5134 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: ba91a9d6-c4dd-51c8-8842-1457dc305656

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
