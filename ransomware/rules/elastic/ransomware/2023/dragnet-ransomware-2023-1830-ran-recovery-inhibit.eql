// Dragnet [Ransomware]: dragnet-ransomware-2023-1830 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: d388cc6e-d078-55b4-8291-751bcc02f5e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
