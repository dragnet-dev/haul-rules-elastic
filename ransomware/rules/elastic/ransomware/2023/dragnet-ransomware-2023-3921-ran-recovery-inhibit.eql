// Dragnet [Ransomware]: dragnet-ransomware-2023-3921 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0d7d7d9f-26eb-5539-843a-543a087179c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
