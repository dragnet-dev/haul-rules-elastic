// Dragnet [Ransomware]: dragnet-ransomware-2023-1784 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3413bf8e-8da1-596c-bfbc-003267e89882

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
