// Dragnet [Ransomware]: dragnet-ransomware-2023-3706 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ff70922e-be56-50ac-aab3-d9c468e81697

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
