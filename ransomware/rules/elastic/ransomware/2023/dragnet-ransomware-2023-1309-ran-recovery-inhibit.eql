// Dragnet [Ransomware]: dragnet-ransomware-2023-1309 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 5a4d1f13-bc2a-51bf-9462-4740cb747855

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
