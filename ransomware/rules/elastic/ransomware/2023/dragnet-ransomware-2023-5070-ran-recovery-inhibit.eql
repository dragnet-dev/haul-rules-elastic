// Dragnet [Ransomware]: dragnet-ransomware-2023-5070 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 013609be-8898-5217-ab58-08c9063d57f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
