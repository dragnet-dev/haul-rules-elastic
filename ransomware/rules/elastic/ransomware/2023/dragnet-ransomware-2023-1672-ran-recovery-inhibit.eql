// Dragnet [Ransomware]: dragnet-ransomware-2023-1672 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 471a11da-ac3e-5792-b57a-26d994a72d29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
