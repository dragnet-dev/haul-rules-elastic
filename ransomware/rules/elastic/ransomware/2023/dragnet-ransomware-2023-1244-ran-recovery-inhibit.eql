// Dragnet [Ransomware]: dragnet-ransomware-2023-1244 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 43b096fd-ae1c-5757-ad70-2db2dcb4541a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
