// Dragnet [Ransomware]: dragnet-ransomware-2023-3781 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: e13223e7-d8fc-5638-8fe4-f89d1d643a54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
