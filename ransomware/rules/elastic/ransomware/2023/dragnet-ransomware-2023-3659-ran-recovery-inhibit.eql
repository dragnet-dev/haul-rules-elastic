// Dragnet [Ransomware]: dragnet-ransomware-2023-3659 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d63c565d-11e3-5eea-9206-49988872b96d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
