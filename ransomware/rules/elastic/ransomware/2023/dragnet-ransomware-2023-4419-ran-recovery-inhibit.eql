// Dragnet [Ransomware]: dragnet-ransomware-2023-4419 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: d6733d13-08ca-5fff-bfb5-b4dbadb7ff2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
