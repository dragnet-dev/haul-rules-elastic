// Dragnet [Ransomware]: dragnet-ransomware-2023-1858 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3cca56b0-2784-5211-a5cd-e068dddd52a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
