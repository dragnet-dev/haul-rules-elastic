// Dragnet [Ransomware]: dragnet-ransomware-2023-4330 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 1d7db02f-9d91-5109-bb36-c9b587f2d437

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
