// Dragnet [Ransomware]: dragnet-ransomware-2023-3994 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 84da095a-8dc1-5554-b86e-4743921dc216

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
