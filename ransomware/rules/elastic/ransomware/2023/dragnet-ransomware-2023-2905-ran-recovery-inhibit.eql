// Dragnet [Ransomware]: dragnet-ransomware-2023-2905 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 79946556-1e76-5a36-980f-6e3d004e172f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
