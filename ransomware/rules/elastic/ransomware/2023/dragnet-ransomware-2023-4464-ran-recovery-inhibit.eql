// Dragnet [Ransomware]: dragnet-ransomware-2023-4464 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 0911fe15-5a5a-5845-8486-6b27ee13e74f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
