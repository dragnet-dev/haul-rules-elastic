// Dragnet [Ransomware]: dragnet-ransomware-2023-0768 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 42000187-a349-5989-bb3d-b68435b6b952

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
