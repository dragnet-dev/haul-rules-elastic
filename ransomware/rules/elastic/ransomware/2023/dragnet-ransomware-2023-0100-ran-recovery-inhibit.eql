// Dragnet [Ransomware]: dragnet-ransomware-2023-0100 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 00779795-d1f5-5760-9507-de9c3c966a2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
