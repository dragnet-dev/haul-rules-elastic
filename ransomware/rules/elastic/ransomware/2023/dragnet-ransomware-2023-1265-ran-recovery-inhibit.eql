// Dragnet [Ransomware]: dragnet-ransomware-2023-1265 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: bd99575d-6c51-552d-9f03-b630626ba70b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
