// Dragnet [Ransomware]: dragnet-ransomware-2023-4698 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: ae059c73-a24c-5640-b825-da8200f12e45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
