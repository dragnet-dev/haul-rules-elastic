// Dragnet [Ransomware]: dragnet-ransomware-2023-4621 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 4898610c-1dd7-5ba8-849b-9e2c4b7d7a56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
