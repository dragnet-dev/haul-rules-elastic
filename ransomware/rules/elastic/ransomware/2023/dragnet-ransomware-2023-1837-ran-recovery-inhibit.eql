// Dragnet [Ransomware]: dragnet-ransomware-2023-1837 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 5b5a4433-7885-5e91-8320-96bb4fa04b6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
