// Dragnet [Ransomware]: dragnet-ransomware-2023-2059 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: a29e63d3-9e61-5af0-981d-241a3fbbf2f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
