// Dragnet [Ransomware]: dragnet-ransomware-2023-1760 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 24a243df-3058-53e4-9114-6607d437d3a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
