// Dragnet [Ransomware]: dragnet-ransomware-2023-2712 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: afb3b0c4-73a4-58b4-adad-a71f1afda4ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
