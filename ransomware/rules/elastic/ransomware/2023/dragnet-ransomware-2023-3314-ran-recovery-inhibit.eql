// Dragnet [Ransomware]: dragnet-ransomware-2023-3314 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 7e23a933-e3b6-5519-b779-d6d882e599a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
