// Dragnet [Ransomware]: dragnet-ransomware-2023-5298 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 902a8ea9-560d-5477-a5a1-429fc8c7b73d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
