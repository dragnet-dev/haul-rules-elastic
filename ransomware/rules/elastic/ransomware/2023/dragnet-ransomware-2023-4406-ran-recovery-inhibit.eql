// Dragnet [Ransomware]: dragnet-ransomware-2023-4406 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 93b3557c-b233-5ebf-a8c5-c111243859b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
