// Dragnet [Ransomware]: dragnet-ransomware-2023-3665 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 196afa66-fea6-587c-84c1-5069709d25d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
