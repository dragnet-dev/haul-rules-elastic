// Dragnet [Ransomware]: dragnet-ransomware-2023-3842 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 78d7c012-7c19-52fd-ad3b-ff8ddf67a22b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
