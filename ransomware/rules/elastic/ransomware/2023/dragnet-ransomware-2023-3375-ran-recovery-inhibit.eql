// Dragnet [Ransomware]: dragnet-ransomware-2023-3375 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a117424d-acc5-50fa-9a7b-2368bc4bbbb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
