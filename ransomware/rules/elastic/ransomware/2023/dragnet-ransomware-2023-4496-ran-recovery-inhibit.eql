// Dragnet [Ransomware]: dragnet-ransomware-2023-4496 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 28f89e14-5822-578b-bf17-794a1a086d88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
