// Dragnet [Ransomware]: dragnet-ransomware-2023-4159 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d8a61f7a-1c57-5374-a427-06db81803015

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
