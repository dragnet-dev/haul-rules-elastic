// Dragnet [Ransomware]: dragnet-ransomware-2023-2179 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: b8ae6c30-ebfb-5d6f-abc3-d58e68ecc628

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
