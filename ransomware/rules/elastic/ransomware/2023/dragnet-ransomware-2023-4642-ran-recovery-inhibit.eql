// Dragnet [Ransomware]: dragnet-ransomware-2023-4642 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: 4be73436-aa95-5301-9fb1-0752fd739d1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
