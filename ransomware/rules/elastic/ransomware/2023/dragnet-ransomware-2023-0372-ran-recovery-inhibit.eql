// Dragnet [Ransomware]: dragnet-ransomware-2023-0372 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 14e8e1fa-866d-5c66-ac69-c6113de08520

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
