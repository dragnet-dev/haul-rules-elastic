// Dragnet [Ransomware]: dragnet-ransomware-2023-3273 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 99eb43b5-25d0-5304-8f7b-dfa6c1993f23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
