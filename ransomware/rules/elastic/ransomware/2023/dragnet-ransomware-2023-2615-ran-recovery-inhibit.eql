// Dragnet [Ransomware]: dragnet-ransomware-2023-2615 — Recovery Inhibition (cloak)
// Status: experimental | Level: high | ID: 3502c468-ce82-5f09-9744-6a3f89e326c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
