// Dragnet [Ransomware]: dragnet-ransomware-2023-1127 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4d0082ab-2c81-5dd0-8add-da813f459704

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
