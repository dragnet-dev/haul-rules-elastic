// Dragnet [Ransomware]: dragnet-ransomware-2023-4425 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 71fb6d78-fd53-5b3d-bf57-f373c080aae2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
