// Dragnet [Ransomware]: dragnet-ransomware-2023-2940 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 0108aa59-cfea-5a19-9f27-5f9863ccaf9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
