// Dragnet [Ransomware]: dragnet-ransomware-2023-1590 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 6b44ad48-e7e8-5915-a41d-a864dd25a49a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
