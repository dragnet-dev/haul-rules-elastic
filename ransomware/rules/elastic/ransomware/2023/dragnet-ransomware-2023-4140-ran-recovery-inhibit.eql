// Dragnet [Ransomware]: dragnet-ransomware-2023-4140 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: cfe26d26-2376-57c8-a9f0-5312dedc89e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
