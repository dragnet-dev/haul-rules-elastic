// Dragnet [Ransomware]: dragnet-ransomware-2023-1043 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: dbe5bc5d-f489-54bc-b9ad-0769bbf6c21a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
