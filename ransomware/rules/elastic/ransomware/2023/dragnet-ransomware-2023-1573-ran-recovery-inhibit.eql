// Dragnet [Ransomware]: dragnet-ransomware-2023-1573 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c2ae4df1-0416-5a74-b02f-04d630dade70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
