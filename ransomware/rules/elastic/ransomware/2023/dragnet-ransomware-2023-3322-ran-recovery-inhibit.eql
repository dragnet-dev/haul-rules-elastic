// Dragnet [Ransomware]: dragnet-ransomware-2023-3322 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 741b041f-2db6-53c0-b820-c28115dff475

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
