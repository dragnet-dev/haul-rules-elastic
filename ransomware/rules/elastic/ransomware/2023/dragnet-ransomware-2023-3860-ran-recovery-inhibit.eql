// Dragnet [Ransomware]: dragnet-ransomware-2023-3860 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: af49cfcd-a280-5fbe-9c6d-6a795c0209ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
