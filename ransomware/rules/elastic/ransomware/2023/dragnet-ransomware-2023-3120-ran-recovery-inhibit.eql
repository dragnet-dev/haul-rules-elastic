// Dragnet [Ransomware]: dragnet-ransomware-2023-3120 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 33a1f920-b757-5ddb-9362-d4fa0a58cd46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
