// Dragnet [Ransomware]: dragnet-ransomware-2023-4040 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 33279935-3337-5089-8e82-de7442efcea8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
