// Dragnet [Ransomware]: dragnet-ransomware-2023-3163 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 2e76225d-749c-55f1-875b-e67d24fd40f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
