// Dragnet [Ransomware]: dragnet-ransomware-2023-4320 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 21e28e40-1d80-5014-955c-32c8fb786b00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
