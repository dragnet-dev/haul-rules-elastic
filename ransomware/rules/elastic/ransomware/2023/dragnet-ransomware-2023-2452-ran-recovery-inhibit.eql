// Dragnet [Ransomware]: dragnet-ransomware-2023-2452 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: e86a0cc1-7848-57ca-9d38-cc4b04880050

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
