// Dragnet [Ransomware]: dragnet-ransomware-2023-0182 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9d98ca75-f805-593f-b416-c01329a1a33d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
