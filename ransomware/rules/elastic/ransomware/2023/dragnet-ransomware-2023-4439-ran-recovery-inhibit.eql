// Dragnet [Ransomware]: dragnet-ransomware-2023-4439 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 9bb0fb29-cb69-522e-92cc-eb39403ed55e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
