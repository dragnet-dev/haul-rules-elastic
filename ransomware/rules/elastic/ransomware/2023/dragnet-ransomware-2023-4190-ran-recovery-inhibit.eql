// Dragnet [Ransomware]: dragnet-ransomware-2023-4190 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 15bfda09-8679-5974-9d19-5a587a167eea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
