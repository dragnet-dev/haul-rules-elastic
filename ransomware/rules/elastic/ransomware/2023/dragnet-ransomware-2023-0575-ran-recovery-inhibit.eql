// Dragnet [Ransomware]: dragnet-ransomware-2023-0575 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 3cf9b076-1126-5a78-ab5b-d6dc9ba1084f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
