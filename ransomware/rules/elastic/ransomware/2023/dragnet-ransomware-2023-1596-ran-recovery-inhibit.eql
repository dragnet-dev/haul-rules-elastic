// Dragnet [Ransomware]: dragnet-ransomware-2023-1596 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 1dd69b9b-3c31-5f5d-b910-071714e365a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
