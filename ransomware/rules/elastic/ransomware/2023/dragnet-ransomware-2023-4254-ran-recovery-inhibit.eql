// Dragnet [Ransomware]: dragnet-ransomware-2023-4254 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d7fd6096-2203-51d0-aa28-7fdfdb0ef7e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
