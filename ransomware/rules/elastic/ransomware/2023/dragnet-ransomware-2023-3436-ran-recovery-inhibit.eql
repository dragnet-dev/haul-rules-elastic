// Dragnet [Ransomware]: dragnet-ransomware-2023-3436 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d27c464a-715b-51ad-8eaa-8b3af118ecb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
