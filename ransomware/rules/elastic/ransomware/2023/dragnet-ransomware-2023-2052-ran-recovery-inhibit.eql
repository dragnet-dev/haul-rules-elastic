// Dragnet [Ransomware]: dragnet-ransomware-2023-2052 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: fd323cfb-90f6-5c3d-af8b-add1d79a3b7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
