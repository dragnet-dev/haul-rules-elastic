// Dragnet [Ransomware]: dragnet-ransomware-2023-2254 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f3f87f38-e26f-5f59-8161-9d39df3dfbe1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
