// Dragnet [Ransomware]: dragnet-ransomware-2023-1634 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: af7c0674-95c4-53db-a676-a71a26b414d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
