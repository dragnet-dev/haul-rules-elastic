// Dragnet [Ransomware]: dragnet-ransomware-2023-0119 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 4a39f354-1d9c-5484-9ccd-47704ae66e1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
