// Dragnet [Ransomware]: dragnet-ransomware-2023-4477 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: d8612886-90f8-5e0a-a36c-234f36ed0363

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
