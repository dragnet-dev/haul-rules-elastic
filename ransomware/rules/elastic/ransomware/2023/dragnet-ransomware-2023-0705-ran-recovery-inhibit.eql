// Dragnet [Ransomware]: dragnet-ransomware-2023-0705 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: be19bd20-0a30-5922-80fb-75d40b887b31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
