// Dragnet [Ransomware]: dragnet-ransomware-2023-2285 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5beee294-05bc-55e9-832f-8a2b55be1e17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
