// Dragnet [Ransomware]: dragnet-ransomware-2023-1323 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 18f7b4c3-6d8a-55ce-8c5a-6753eee4e102

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
