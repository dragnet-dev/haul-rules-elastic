// Dragnet [Ransomware]: dragnet-ransomware-2023-2962 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 8633ff98-2a28-5755-b1c4-97017405f8bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
