// Dragnet [Ransomware]: dragnet-ransomware-2023-2617 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 82540808-5407-5ea4-92f9-9191cd82024f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
