// Dragnet [Ransomware]: dragnet-ransomware-2023-1269 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: abe4bf3f-323a-5aaf-9280-efd6c851eeeb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
