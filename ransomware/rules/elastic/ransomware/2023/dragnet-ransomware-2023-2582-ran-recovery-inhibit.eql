// Dragnet [Ransomware]: dragnet-ransomware-2023-2582 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c0cbc715-7329-5af5-9f90-e3fa760f4158

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
