// Dragnet [Ransomware]: dragnet-ransomware-2023-2317 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 9e653be0-8902-51d0-b3b1-c8968ddafcd7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
