// Dragnet [Ransomware]: dragnet-ransomware-2023-4311 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 622b1df2-4c64-52e7-8fbf-680d4f65bd0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
