// Dragnet [Ransomware]: dragnet-ransomware-2023-0545 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a82e219c-4058-5d61-be94-5ad0698bf789

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
