// Dragnet [Ransomware]: dragnet-ransomware-2023-4769 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 96df8a27-d37d-56c4-80d8-31403cd65048

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
