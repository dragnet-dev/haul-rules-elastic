// Dragnet [Ransomware]: dragnet-ransomware-2023-1102 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 9b1e5ac7-1c8a-5202-80d8-30fcdc93dcb3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
