// Dragnet [Ransomware]: dragnet-ransomware-2023-1124 — Recovery Inhibition (vicesociety)
// Status: experimental | Level: high | ID: 207b1b45-56a7-50cd-932f-55453824832b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
