// Dragnet [Ransomware]: dragnet-ransomware-2023-2941 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 811a8a14-6dca-542c-b471-222831b0f001

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
