// Dragnet [Ransomware]: dragnet-ransomware-2023-4807 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0228fa29-7b1b-5475-9a1f-9f05305dd6ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
