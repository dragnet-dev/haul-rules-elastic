// Dragnet [Ransomware]: dragnet-ransomware-2023-1968 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 60609b6b-ce57-510d-867a-1de52e5fc1ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
