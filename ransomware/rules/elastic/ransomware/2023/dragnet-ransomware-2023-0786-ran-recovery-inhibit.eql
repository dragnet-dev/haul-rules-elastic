// Dragnet [Ransomware]: dragnet-ransomware-2023-0786 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e166c6a9-7533-5700-a184-28b61e78fcb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
