// Dragnet [Ransomware]: dragnet-ransomware-2023-2080 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 1c52b9e6-8795-5006-90f6-899ed96b0aa2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
