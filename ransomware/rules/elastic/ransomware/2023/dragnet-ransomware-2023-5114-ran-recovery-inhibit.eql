// Dragnet [Ransomware]: dragnet-ransomware-2023-5114 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 9045622d-c8a2-5884-8d3d-ada2f7708087

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
