// Dragnet [Ransomware]: dragnet-ransomware-2023-1438 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1b37bd75-0987-543f-84ef-9d324202a4d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
