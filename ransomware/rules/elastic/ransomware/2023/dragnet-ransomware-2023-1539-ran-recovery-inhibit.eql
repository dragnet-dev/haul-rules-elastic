// Dragnet [Ransomware]: dragnet-ransomware-2023-1539 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: c8fc05af-5dd6-5681-a3cc-66116766478a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
