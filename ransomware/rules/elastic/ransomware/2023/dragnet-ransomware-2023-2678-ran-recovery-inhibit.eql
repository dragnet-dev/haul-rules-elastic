// Dragnet [Ransomware]: dragnet-ransomware-2023-2678 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 73c3446d-e437-5766-bfad-84196109e4d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
