// Dragnet [Ransomware]: dragnet-ransomware-2023-1260 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: d5cfb781-0d26-50ca-805a-f95290f5205d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
