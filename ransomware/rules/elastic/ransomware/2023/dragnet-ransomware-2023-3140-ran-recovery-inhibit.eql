// Dragnet [Ransomware]: dragnet-ransomware-2023-3140 — Recovery Inhibition (underground)
// Status: experimental | Level: high | ID: f32bdead-dc08-5045-9766-3d5cbd2ec87b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
