// Dragnet [Ransomware]: dragnet-ransomware-2023-0355 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6124b861-01b7-5163-bb6e-803296d5d5eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
