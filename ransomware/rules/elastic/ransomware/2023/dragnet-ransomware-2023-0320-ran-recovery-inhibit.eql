// Dragnet [Ransomware]: dragnet-ransomware-2023-0320 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 69c7ab6c-3567-5bfc-a5da-cdf09ce28f80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
