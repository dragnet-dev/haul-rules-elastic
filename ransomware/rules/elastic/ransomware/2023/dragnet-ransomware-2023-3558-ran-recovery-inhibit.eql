// Dragnet [Ransomware]: dragnet-ransomware-2023-3558 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 002df38b-ad08-516e-a2f3-5b19182a8015

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
