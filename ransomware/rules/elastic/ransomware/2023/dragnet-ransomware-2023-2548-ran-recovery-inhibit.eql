// Dragnet [Ransomware]: dragnet-ransomware-2023-2548 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: bc5a7d46-8554-5a2a-9958-e8b2e46fe155

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
