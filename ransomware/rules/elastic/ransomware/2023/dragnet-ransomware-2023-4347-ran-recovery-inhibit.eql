// Dragnet [Ransomware]: dragnet-ransomware-2023-4347 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 8c33efb4-28ad-55a1-87cf-f629b5562b53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
