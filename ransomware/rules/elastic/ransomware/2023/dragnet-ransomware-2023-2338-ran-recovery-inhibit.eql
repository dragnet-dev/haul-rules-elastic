// Dragnet [Ransomware]: dragnet-ransomware-2023-2338 — Recovery Inhibition (darkrace)
// Status: experimental | Level: high | ID: 6278d793-e8f7-5eb4-8899-51fbd6a62693

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
