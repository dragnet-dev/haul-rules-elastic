// Dragnet [Ransomware]: dragnet-ransomware-2023-2382 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c41ec221-0735-5683-ba24-660992b166ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
