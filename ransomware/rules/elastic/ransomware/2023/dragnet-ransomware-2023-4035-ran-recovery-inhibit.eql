// Dragnet [Ransomware]: dragnet-ransomware-2023-4035 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: be3c58f5-1228-5e67-812d-d2f246473845

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
