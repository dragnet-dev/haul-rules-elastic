// Dragnet [Ransomware]: dragnet-ransomware-2023-3534 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c5086d2b-ba23-55f0-9fe1-8cc360f236a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
