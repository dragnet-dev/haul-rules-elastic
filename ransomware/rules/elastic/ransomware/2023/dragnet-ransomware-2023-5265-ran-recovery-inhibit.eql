// Dragnet [Ransomware]: dragnet-ransomware-2023-5265 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3afa74bd-536c-5856-acde-a84fde192b35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
