// Dragnet [Ransomware]: dragnet-ransomware-2023-4135 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: cb955833-b318-5d8d-8d18-a1465ad9a24d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
