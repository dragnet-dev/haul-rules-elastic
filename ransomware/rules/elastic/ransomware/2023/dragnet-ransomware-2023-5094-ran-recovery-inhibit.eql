// Dragnet [Ransomware]: dragnet-ransomware-2023-5094 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d62f67ff-33e5-5a15-b3a1-78669ffaa2a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
