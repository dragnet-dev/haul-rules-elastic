// Dragnet [Ransomware]: dragnet-ransomware-2023-1767 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 380c766b-eb03-5cac-9499-40bab11e78b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
