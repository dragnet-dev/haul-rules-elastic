// Dragnet [Ransomware]: dragnet-ransomware-2023-1625 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f467583d-a44e-5849-ac4c-a891264e1a3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
