// Dragnet [Ransomware]: dragnet-ransomware-2023-1476 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4b5705a9-b2b9-5994-9d9f-9324dc4ee4c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
