// Dragnet [Ransomware]: dragnet-ransomware-2023-4131 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 0a4c7a78-7c61-51c5-81e3-4788f5782019

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
