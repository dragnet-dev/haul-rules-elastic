// Dragnet [Ransomware]: dragnet-ransomware-2023-5301 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 61db0359-ed25-5825-8be4-272839fbf4c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
