// Dragnet [Ransomware]: dragnet-ransomware-2023-1779 — Recovery Inhibition (raznatovic)
// Status: experimental | Level: high | ID: 36348c40-eaa0-5ede-8197-65b035a9ae7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
