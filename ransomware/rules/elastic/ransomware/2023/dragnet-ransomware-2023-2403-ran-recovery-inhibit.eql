// Dragnet [Ransomware]: dragnet-ransomware-2023-2403 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 2f53270d-46d3-507d-91d1-a50dc8f35494

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
