// Dragnet [Ransomware]: dragnet-ransomware-2023-1159 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 68a18d89-c76a-5d68-bd8f-7759125ccf3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
