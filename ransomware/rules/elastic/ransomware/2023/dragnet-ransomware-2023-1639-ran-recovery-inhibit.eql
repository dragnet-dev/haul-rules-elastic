// Dragnet [Ransomware]: dragnet-ransomware-2023-1639 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: af27c266-ebe7-56c1-8d57-482467e21e8f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
