// Dragnet [Ransomware]: dragnet-ransomware-2023-5219 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e4ecdb50-448e-534d-9be2-59acdd8def4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
