// Dragnet [Ransomware]: dragnet-ransomware-2023-4151 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9f964325-1cd2-553f-beb0-cab9ac7c04de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
