// Dragnet [Ransomware]: dragnet-ransomware-2023-3088 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: fec30d5f-33e3-5e37-8172-5eff35376bb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
