// Dragnet [Ransomware]: dragnet-ransomware-2023-1965 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 013c51e2-89d4-55af-a034-f79e425c19cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
