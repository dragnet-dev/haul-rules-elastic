// Dragnet [Ransomware]: dragnet-ransomware-2023-5015 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 2c2437da-f59a-53d6-b7fe-cdfb4d11e813

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
