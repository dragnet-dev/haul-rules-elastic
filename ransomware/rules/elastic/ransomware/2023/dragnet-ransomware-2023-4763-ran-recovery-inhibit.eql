// Dragnet [Ransomware]: dragnet-ransomware-2023-4763 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 2fd36345-986e-5c6c-88c0-5aa13d30cab1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
