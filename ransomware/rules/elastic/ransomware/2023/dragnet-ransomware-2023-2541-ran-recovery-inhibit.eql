// Dragnet [Ransomware]: dragnet-ransomware-2023-2541 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 34537ce5-b6de-5117-92f8-860e9410faf3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
