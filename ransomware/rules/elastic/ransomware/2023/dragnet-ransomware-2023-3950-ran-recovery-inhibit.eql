// Dragnet [Ransomware]: dragnet-ransomware-2023-3950 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d814023f-4b19-5f97-bc9c-0fe756f6e450

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
