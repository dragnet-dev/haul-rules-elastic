// Dragnet [Ransomware]: dragnet-ransomware-2023-2957 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 545307cd-60c8-506d-a958-ab227a1192a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
