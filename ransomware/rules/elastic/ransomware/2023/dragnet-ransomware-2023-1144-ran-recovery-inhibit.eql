// Dragnet [Ransomware]: dragnet-ransomware-2023-1144 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f6c38447-ccb6-5d8d-890a-8a611907fe80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
