// Dragnet [Ransomware]: dragnet-ransomware-2023-2754 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 89e35db4-f162-5c98-9b7a-bf77a6a6623f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
