// Dragnet [Ransomware]: dragnet-ransomware-2023-4784 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 4f1bed09-8897-5363-8226-d29bd6b33b59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
