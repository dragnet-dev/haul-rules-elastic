// Dragnet [Ransomware]: dragnet-ransomware-2023-2358 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: cc959855-5bb8-5d61-a8ee-f75f697a5f30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
