// Dragnet [Ransomware]: dragnet-ransomware-2023-3119 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: a8d0904b-f2e8-5e39-acda-92c0a5d39672

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
