// Dragnet [Ransomware]: dragnet-ransomware-2023-2119 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: f30f7924-961b-58d2-9879-b38a59aeefa6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
