// Dragnet [Ransomware]: dragnet-ransomware-2023-2044 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 2520e9df-56d6-5efa-8dd8-88d695efbf26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
