// Dragnet [Ransomware]: dragnet-ransomware-2023-0308 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3134ff8c-5f54-5c81-a002-f2bf3dc40c31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
