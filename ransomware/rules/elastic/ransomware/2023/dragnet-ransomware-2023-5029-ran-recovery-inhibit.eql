// Dragnet [Ransomware]: dragnet-ransomware-2023-5029 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9db8e392-ce4e-5138-9cfc-679bd7c5b874

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
