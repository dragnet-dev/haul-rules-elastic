// Dragnet [Ransomware]: dragnet-ransomware-2023-1344 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 675d5e01-ecec-549b-b3ff-7378216c8280

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
