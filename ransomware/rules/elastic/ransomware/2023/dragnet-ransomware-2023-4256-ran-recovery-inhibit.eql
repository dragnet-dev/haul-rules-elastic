// Dragnet [Ransomware]: dragnet-ransomware-2023-4256 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 11565771-d1e2-5b4f-a8db-4e39f235e8b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
