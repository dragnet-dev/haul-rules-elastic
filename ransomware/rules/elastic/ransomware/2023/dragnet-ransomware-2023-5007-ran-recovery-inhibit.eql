// Dragnet [Ransomware]: dragnet-ransomware-2023-5007 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f915a974-ba50-5de5-9fec-09156b27ab25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
