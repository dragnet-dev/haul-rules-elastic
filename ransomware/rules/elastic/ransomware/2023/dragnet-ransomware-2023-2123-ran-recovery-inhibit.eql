// Dragnet [Ransomware]: dragnet-ransomware-2023-2123 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9c0e3b58-6e03-50c7-8967-2b09a154e775

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
