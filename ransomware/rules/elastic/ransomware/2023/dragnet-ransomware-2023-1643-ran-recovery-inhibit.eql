// Dragnet [Ransomware]: dragnet-ransomware-2023-1643 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: fa14fe32-1d17-5e49-b022-4c6d72cb0d6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
