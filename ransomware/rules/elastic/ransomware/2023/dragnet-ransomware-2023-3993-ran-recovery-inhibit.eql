// Dragnet [Ransomware]: dragnet-ransomware-2023-3993 — Recovery Inhibition (dunghill)
// Status: experimental | Level: high | ID: 9dba9a11-377a-511a-a365-bc732438eb56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
