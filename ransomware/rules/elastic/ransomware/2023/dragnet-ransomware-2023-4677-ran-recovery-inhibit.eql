// Dragnet [Ransomware]: dragnet-ransomware-2023-4677 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: 3514f7bb-7a96-5926-aa40-4b8bd04b6d47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
