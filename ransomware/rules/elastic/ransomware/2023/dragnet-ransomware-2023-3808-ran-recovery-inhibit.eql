// Dragnet [Ransomware]: dragnet-ransomware-2023-3808 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 3ce02fc9-60e1-536a-b3b0-c6b83cc3941f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
