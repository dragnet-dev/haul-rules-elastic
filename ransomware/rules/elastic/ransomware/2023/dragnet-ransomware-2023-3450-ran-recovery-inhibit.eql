// Dragnet [Ransomware]: dragnet-ransomware-2023-3450 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 33884562-f1d3-51ee-9165-e1dfa9672ded

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
