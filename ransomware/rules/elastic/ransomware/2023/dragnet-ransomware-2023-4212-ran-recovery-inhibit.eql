// Dragnet [Ransomware]: dragnet-ransomware-2023-4212 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5474ce50-d423-5190-9797-ea0b8f58ffad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
