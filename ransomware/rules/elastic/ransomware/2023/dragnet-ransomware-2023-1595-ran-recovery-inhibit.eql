// Dragnet [Ransomware]: dragnet-ransomware-2023-1595 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 4f8f8902-cac8-53af-97ce-26a075e0f3b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
