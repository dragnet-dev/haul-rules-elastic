// Dragnet [Ransomware]: dragnet-ransomware-2023-3603 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 5fded791-e9ba-5d64-88db-206e49057c4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
