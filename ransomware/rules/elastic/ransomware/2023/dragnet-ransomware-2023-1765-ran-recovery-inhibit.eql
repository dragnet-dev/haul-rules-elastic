// Dragnet [Ransomware]: dragnet-ransomware-2023-1765 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f3b1f331-e15d-5e47-b1b5-19626516d147

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
