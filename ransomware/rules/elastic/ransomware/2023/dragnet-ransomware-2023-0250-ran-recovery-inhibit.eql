// Dragnet [Ransomware]: dragnet-ransomware-2023-0250 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f5b02c2e-19be-5f92-af34-ac778f8a1c1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
