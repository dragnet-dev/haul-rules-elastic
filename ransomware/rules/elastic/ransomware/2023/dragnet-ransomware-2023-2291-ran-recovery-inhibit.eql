// Dragnet [Ransomware]: dragnet-ransomware-2023-2291 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: a76c5339-8b2d-5698-b489-d73784acf0a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
