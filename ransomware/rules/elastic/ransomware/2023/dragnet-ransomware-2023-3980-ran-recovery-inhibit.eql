// Dragnet [Ransomware]: dragnet-ransomware-2023-3980 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 77fa9bd0-2dbc-536c-b842-6be1f74bfa89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
