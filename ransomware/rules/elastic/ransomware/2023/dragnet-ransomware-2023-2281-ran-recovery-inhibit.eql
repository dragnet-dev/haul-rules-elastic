// Dragnet [Ransomware]: dragnet-ransomware-2023-2281 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 20f17935-f970-5d3e-a1b8-49a77a45f188

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
