// Dragnet [Ransomware]: dragnet-ransomware-2023-2579 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a8345907-d45e-5056-b16c-0482534a96d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
