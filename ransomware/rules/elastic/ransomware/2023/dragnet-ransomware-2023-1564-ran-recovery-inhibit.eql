// Dragnet [Ransomware]: dragnet-ransomware-2023-1564 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 4113646b-4ce1-5f22-a3d4-78d3b37e48cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
