// Dragnet [Ransomware]: dragnet-ransomware-2023-2195 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 7eb6addb-341d-5c95-996a-1f328296df99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
