// Dragnet [Ransomware]: dragnet-ransomware-2023-0109 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: bab5e582-0522-5161-8aaa-7191c881362b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
