// Dragnet [Ransomware]: dragnet-ransomware-2023-5355 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: ae263c9a-06d3-55ab-a50a-af272d9a02a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
