// Dragnet [Ransomware]: dragnet-ransomware-2023-0378 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 67e1e654-b6fe-565e-ae47-cb511819f76b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
