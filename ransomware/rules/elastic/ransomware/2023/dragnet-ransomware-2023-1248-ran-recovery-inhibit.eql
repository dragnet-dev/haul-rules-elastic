// Dragnet [Ransomware]: dragnet-ransomware-2023-1248 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 860500ea-c566-564a-95ad-be222d6e88a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
