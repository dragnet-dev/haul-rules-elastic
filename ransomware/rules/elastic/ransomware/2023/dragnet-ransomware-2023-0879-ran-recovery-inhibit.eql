// Dragnet [Ransomware]: dragnet-ransomware-2023-0879 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: bc026c21-f916-50b9-b49a-3339d914ba4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
