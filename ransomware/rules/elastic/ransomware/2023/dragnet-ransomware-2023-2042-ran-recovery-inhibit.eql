// Dragnet [Ransomware]: dragnet-ransomware-2023-2042 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: bb8685db-35c4-5900-87a0-8af5d0ca87ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
