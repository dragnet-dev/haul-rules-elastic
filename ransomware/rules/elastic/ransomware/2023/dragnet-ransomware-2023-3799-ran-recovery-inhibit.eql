// Dragnet [Ransomware]: dragnet-ransomware-2023-3799 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: c5d7a252-0260-5325-82b1-4d4ede1844ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
