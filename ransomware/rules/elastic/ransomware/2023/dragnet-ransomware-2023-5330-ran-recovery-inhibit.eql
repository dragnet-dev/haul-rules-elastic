// Dragnet [Ransomware]: dragnet-ransomware-2023-5330 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 278c950a-83cd-56e0-b2ad-4a033f94cf5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
