// Dragnet [Ransomware]: dragnet-ransomware-2023-1887 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1457c539-b606-5561-b242-e2dd385264df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
