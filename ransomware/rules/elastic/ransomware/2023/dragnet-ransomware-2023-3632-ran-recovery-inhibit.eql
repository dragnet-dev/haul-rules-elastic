// Dragnet [Ransomware]: dragnet-ransomware-2023-3632 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 799c780a-777f-5a87-a026-897d30d447e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
