// Dragnet [Ransomware]: dragnet-ransomware-2023-3039 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a5db88a3-f29c-5174-afea-36ab26b073af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
