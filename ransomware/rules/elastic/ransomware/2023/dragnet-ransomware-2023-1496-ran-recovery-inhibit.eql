// Dragnet [Ransomware]: dragnet-ransomware-2023-1496 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 21e4eea6-4049-536b-8916-46e7b28f9740

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
