// Dragnet [Ransomware]: dragnet-ransomware-2023-3988 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 20c5c5d8-e035-5896-bbf9-851354e509ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
