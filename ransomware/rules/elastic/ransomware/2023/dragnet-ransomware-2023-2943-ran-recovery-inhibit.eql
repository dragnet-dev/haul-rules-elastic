// Dragnet [Ransomware]: dragnet-ransomware-2023-2943 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: 98a7dcb0-f916-5784-a288-cab5ad0af103

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
