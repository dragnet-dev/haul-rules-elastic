// Dragnet [Ransomware]: dragnet-ransomware-2023-0192 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 4481be85-a347-5c14-8c91-de6e59de67ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
