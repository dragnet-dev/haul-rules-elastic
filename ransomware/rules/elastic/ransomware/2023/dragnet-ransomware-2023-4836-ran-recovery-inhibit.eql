// Dragnet [Ransomware]: dragnet-ransomware-2023-4836 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 26bb2a12-ba90-5f47-a55d-59369b3ab39c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
