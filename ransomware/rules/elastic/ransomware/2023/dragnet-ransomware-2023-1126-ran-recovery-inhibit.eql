// Dragnet [Ransomware]: dragnet-ransomware-2023-1126 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: a81c96b9-1ab1-5f3c-9216-bbde7e6bbf9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
