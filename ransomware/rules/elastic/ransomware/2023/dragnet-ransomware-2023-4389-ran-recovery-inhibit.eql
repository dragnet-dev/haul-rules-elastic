// Dragnet [Ransomware]: dragnet-ransomware-2023-4389 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: 44e69b91-6276-5b82-b263-df9e0d811264

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
