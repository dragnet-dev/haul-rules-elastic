// Dragnet [Ransomware]: dragnet-ransomware-2023-0911 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: eea1e9f3-315a-51e6-ac20-3b1c87bc08cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
