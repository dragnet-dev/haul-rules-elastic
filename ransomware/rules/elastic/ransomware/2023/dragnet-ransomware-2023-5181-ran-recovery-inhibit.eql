// Dragnet [Ransomware]: dragnet-ransomware-2023-5181 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 427943c0-e941-5c42-9f1d-646d33b9047d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
