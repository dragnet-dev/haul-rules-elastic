// Dragnet [Ransomware]: dragnet-ransomware-2023-0637 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d98728b3-7570-5605-9752-083e770824cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
