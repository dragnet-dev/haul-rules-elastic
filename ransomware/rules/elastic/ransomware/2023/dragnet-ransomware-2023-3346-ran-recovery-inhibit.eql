// Dragnet [Ransomware]: dragnet-ransomware-2023-3346 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: ca0ca19c-88a6-573f-bd81-8729647adc40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
