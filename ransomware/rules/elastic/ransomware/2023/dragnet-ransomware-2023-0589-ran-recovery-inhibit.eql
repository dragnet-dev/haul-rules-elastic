// Dragnet [Ransomware]: dragnet-ransomware-2023-0589 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e5473863-565b-5a7e-acd0-cd563250c88e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
