// Dragnet [Ransomware]: dragnet-ransomware-2023-2571 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: bfce6b6d-d0c2-56e7-846a-9eb9b797b775

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
