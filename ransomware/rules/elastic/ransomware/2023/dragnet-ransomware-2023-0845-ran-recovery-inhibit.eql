// Dragnet [Ransomware]: dragnet-ransomware-2023-0845 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 8d4f3968-18d6-5053-bd71-e59b3345e281

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
