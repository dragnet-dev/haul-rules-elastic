// Dragnet [Ransomware]: dragnet-ransomware-2023-0223 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 4c2a99ff-154e-513d-8a6d-fff0de52b852

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
