// Dragnet [Ransomware]: dragnet-ransomware-2023-4331 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: ab37f9f5-e706-5711-aa33-e9a997b436b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
