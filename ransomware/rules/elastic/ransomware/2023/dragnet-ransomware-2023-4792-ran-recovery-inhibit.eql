// Dragnet [Ransomware]: dragnet-ransomware-2023-4792 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 62d0eeff-8ef8-5f84-ae94-837e04b71094

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
