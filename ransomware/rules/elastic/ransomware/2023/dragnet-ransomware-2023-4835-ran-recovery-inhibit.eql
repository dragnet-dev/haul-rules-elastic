// Dragnet [Ransomware]: dragnet-ransomware-2023-4835 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ae418227-47d3-5360-822a-29bf508eb95c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
