// Dragnet [Ransomware]: dragnet-ransomware-2023-5081 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 4465a5bb-a2e1-5f87-8ebb-a1630c700f17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
