// Dragnet [Ransomware]: dragnet-ransomware-2023-2735 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: af56ed57-d70c-5e0f-a856-b0fd9f5931bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
