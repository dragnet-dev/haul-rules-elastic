// Dragnet [Ransomware]: dragnet-ransomware-2023-0206 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e5a7b0cf-e8d0-5256-8b93-64a9509f58c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
