// Dragnet [Ransomware]: dragnet-ransomware-2023-2078 — Recovery Inhibition (trigona)
// Status: deprecated | Level: high | ID: 13a94ec5-6761-5e72-ad82-7d3b546ba31b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
