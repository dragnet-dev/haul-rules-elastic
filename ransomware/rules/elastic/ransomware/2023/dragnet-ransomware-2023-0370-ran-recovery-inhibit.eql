// Dragnet [Ransomware]: dragnet-ransomware-2023-0370 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 6615e316-b74b-5e81-816c-cec849b9f53c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
