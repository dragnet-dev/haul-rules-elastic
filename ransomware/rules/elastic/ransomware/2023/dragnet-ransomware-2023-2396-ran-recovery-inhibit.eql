// Dragnet [Ransomware]: dragnet-ransomware-2023-2396 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 0b5f7967-6682-5344-ba5e-380dd20e95ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
