// Dragnet [Ransomware]: dragnet-ransomware-2023-1611 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: e220024c-09b2-55ec-9c35-3a39d511394f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
