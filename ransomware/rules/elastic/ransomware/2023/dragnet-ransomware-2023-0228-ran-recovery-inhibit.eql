// Dragnet [Ransomware]: dragnet-ransomware-2023-0228 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ca8ceb97-1068-583c-bfda-2da8737ff342

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
