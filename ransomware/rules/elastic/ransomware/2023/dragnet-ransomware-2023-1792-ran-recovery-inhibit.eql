// Dragnet [Ransomware]: dragnet-ransomware-2023-1792 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: d4784f2f-26e4-521d-bdf8-baa26fc735e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
