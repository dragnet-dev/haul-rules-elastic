// Dragnet [Ransomware]: dragnet-ransomware-2023-0383 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 94863355-d241-5577-a77e-80535a0cacda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
