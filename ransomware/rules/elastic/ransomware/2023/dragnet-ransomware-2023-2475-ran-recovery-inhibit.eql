// Dragnet [Ransomware]: dragnet-ransomware-2023-2475 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: dd612c8f-c93b-5bf1-a5a9-a50e4d1e82f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
