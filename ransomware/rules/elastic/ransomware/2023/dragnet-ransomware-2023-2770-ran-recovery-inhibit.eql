// Dragnet [Ransomware]: dragnet-ransomware-2023-2770 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 98faabfe-358e-5626-923c-ca179ea8a1d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
