// Dragnet [Ransomware]: dragnet-ransomware-2023-0390 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: d553967c-68fe-5866-aade-d3b95d865e49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
