// Dragnet [Ransomware]: dragnet-ransomware-2023-1520 — Recovery Inhibition (darkrace)
// Status: experimental | Level: high | ID: a2d3113d-1691-5196-b00f-bb3ee3813d31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
