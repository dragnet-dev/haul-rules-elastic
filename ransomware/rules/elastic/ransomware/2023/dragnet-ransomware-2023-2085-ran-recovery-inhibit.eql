// Dragnet [Ransomware]: dragnet-ransomware-2023-2085 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: c605452b-8300-5569-9efc-9ec8a16498c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
