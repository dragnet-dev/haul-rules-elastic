// Dragnet [Ransomware]: dragnet-ransomware-2023-5150 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: b8a5b8c6-1b3d-5667-874b-6994e81242e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
