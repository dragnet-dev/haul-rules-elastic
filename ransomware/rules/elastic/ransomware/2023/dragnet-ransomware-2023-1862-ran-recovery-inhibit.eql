// Dragnet [Ransomware]: dragnet-ransomware-2023-1862 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d6696dca-c3e7-57bd-a881-18edf0861d2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
