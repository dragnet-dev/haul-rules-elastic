// Dragnet [Ransomware]: dragnet-ransomware-2023-3998 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bd3818ea-cb82-5389-b54c-f69549a26fbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
