// Dragnet [Ransomware]: dragnet-ransomware-2023-1185 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 23185272-1af6-593f-9fd8-06baa85a272c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
