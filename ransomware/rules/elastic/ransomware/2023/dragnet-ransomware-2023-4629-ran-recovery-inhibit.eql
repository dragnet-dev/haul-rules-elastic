// Dragnet [Ransomware]: dragnet-ransomware-2023-4629 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: e464a4e2-6b7e-5535-8ecb-07c5d488d346

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
