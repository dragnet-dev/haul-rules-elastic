// Dragnet [Ransomware]: dragnet-ransomware-2023-2533 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 25992043-f4db-51ef-b17a-d90c8a598c63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
