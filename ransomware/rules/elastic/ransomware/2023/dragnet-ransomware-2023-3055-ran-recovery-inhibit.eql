// Dragnet [Ransomware]: dragnet-ransomware-2023-3055 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: 99d15687-4e13-5333-8fc1-c21eaf69f665

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
