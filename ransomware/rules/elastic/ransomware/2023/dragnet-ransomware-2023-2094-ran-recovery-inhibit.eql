// Dragnet [Ransomware]: dragnet-ransomware-2023-2094 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: ed18d72e-e6e3-59fe-b2a7-16267ca7f63e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
