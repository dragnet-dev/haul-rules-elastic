// Dragnet [Ransomware]: dragnet-ransomware-2023-0530 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5dfd8313-a0f8-5309-817a-a87e06b54061

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
