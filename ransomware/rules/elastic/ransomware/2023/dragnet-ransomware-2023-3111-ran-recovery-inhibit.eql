// Dragnet [Ransomware]: dragnet-ransomware-2023-3111 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 5394c4b5-2b37-57de-af41-5d0ede37814f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
