// Dragnet [Ransomware]: dragnet-ransomware-2023-4922 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 1785f68e-4f13-542d-aad0-6d6676920513

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
