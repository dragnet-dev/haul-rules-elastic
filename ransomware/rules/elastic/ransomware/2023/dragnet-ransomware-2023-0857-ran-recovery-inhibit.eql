// Dragnet [Ransomware]: dragnet-ransomware-2023-0857 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: 30c7dd4e-9bb6-5a74-b03f-df4402c7beda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
