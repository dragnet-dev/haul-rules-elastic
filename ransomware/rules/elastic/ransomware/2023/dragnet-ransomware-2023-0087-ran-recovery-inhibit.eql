// Dragnet [Ransomware]: dragnet-ransomware-2023-0087 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3864649c-d911-51bf-b393-095a4b7f56fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
