// Dragnet [Ransomware]: dragnet-ransomware-2023-1027 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 759fb330-909b-54b8-a586-91f1396344d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
