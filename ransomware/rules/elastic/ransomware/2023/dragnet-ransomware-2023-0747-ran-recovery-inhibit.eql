// Dragnet [Ransomware]: dragnet-ransomware-2023-0747 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 6ca01166-8fff-5ce6-a700-82d14659ba19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
