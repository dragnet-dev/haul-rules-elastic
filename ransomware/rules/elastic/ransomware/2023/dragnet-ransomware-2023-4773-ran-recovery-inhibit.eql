// Dragnet [Ransomware]: dragnet-ransomware-2023-4773 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: a4cb3516-f997-5ba5-87dd-af7f34260c20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
