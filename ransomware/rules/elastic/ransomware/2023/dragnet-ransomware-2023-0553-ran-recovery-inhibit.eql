// Dragnet [Ransomware]: dragnet-ransomware-2023-0553 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f0040526-5943-57a7-9320-0d8b0b2638d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
