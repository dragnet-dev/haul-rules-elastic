// Dragnet [Ransomware]: dragnet-ransomware-2023-0022 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 7cc2bd54-b429-5510-b8d1-07221b3969d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
