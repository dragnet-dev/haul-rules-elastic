// Dragnet [Ransomware]: dragnet-ransomware-2023-5286 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: 08354141-3097-5f3e-8d3d-24d7084d054b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
