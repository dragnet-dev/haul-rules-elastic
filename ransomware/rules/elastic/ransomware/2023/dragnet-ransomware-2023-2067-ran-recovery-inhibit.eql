// Dragnet [Ransomware]: dragnet-ransomware-2023-2067 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: d4f02c72-f20e-5da3-af21-1f6b5b784333

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
