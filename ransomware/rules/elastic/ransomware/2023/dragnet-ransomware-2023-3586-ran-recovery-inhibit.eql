// Dragnet [Ransomware]: dragnet-ransomware-2023-3586 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: c2b67367-e359-53e2-ab57-8e08403f61a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
