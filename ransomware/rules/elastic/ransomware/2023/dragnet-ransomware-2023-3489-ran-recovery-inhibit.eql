// Dragnet [Ransomware]: dragnet-ransomware-2023-3489 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 923dac4a-23da-5310-8e98-1df7d99ca5d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
