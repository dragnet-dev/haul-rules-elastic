// Dragnet [Ransomware]: dragnet-ransomware-2023-0890 — Recovery Inhibition (cuba)
// Status: experimental | Level: high | ID: a8746028-1aa9-5628-9a01-5c6333726014

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
