// Dragnet [Ransomware]: dragnet-ransomware-2023-4328 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: d084bb5f-aa90-5dcc-888f-3d5be86824ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
