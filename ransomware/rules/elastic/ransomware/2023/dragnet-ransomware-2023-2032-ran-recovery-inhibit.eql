// Dragnet [Ransomware]: dragnet-ransomware-2023-2032 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: be1952d7-40b4-54ba-8a8c-1491b0bbf647

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
