// Dragnet [Ransomware]: dragnet-ransomware-2023-0755 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 42bec784-79ea-592a-986d-c710b9135504

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
