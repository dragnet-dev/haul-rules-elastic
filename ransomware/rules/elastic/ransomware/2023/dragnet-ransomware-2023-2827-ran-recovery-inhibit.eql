// Dragnet [Ransomware]: dragnet-ransomware-2023-2827 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 99809e72-2b69-583a-96b4-5f06f7903caf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
