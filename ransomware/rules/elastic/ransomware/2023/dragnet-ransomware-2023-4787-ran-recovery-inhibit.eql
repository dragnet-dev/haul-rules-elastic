// Dragnet [Ransomware]: dragnet-ransomware-2023-4787 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 0b46c733-4b2e-5272-b981-310cdb8229c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
