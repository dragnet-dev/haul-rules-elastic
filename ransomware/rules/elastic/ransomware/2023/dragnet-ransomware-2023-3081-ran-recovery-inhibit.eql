// Dragnet [Ransomware]: dragnet-ransomware-2023-3081 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 646594f4-a3e7-581e-8797-22ee17abd38a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
