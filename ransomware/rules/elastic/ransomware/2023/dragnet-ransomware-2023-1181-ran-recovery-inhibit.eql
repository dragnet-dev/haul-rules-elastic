// Dragnet [Ransomware]: dragnet-ransomware-2023-1181 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 066abac4-a098-5605-859e-51430939a58a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
