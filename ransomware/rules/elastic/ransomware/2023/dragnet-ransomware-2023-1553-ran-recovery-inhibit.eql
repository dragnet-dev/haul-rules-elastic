// Dragnet [Ransomware]: dragnet-ransomware-2023-1553 — Recovery Inhibition (medusa)
// Status: deprecated | Level: high | ID: 88da2b0a-482c-5f80-b18f-d0df714c3d3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
