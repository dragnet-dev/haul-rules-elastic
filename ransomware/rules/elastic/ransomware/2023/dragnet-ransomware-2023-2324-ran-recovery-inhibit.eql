// Dragnet [Ransomware]: dragnet-ransomware-2023-2324 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e921dfa1-8f19-5f10-abe6-b7a86268ba65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
