// Dragnet [Ransomware]: dragnet-ransomware-2023-0467 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5f22a28c-03a7-5d3b-b8fc-983795e9334b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
