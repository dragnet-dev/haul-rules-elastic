// Dragnet [Ransomware]: dragnet-ransomware-2023-4750 — Recovery Inhibition (daixin)
// Status: deprecated | Level: high | ID: 553b5c94-4266-5031-a297-268be4422914

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
