// Dragnet [Ransomware]: dragnet-ransomware-2023-0513 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 63cbe282-186a-5e04-b6d2-9da9bb7d897e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
