// Dragnet [Ransomware]: dragnet-ransomware-2023-0622 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 5c2bfad8-7b93-5d14-8892-8e99f0f98d66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
