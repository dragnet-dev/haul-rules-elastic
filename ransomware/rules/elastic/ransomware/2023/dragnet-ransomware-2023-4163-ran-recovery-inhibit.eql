// Dragnet [Ransomware]: dragnet-ransomware-2023-4163 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: c6610805-a3b3-5a68-843a-f84e786043d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
