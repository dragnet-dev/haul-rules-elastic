// Dragnet [Ransomware]: dragnet-ransomware-2023-2053 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: dfac3325-d736-5d27-93d8-c3110f5fb146

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
