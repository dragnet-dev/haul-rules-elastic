// Dragnet [Ransomware]: dragnet-ransomware-2023-1039 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 9908e4b7-de8e-5a93-9970-b5319f2c8ff8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
