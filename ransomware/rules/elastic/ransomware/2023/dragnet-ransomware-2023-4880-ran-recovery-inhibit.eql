// Dragnet [Ransomware]: dragnet-ransomware-2023-4880 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a024afa4-2249-5ca9-894c-10b0a39b2a6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
