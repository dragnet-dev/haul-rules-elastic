// Dragnet [Ransomware]: dragnet-ransomware-2023-3686 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: 63ac5d0f-939c-5da9-b4b6-f94b3fcf9ab2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
