// Dragnet [Ransomware]: dragnet-ransomware-2023-3026 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5f8831ed-168f-5dee-959b-96ac919123bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
