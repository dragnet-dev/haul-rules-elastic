// Dragnet [Ransomware]: dragnet-ransomware-2023-2979 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3a6e044c-d470-585c-bc3a-f1d9cb7753d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
