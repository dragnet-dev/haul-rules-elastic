// Dragnet [Ransomware]: dragnet-ransomware-2023-0568 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 1135a132-8511-54e1-aefd-996b638f1702

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
