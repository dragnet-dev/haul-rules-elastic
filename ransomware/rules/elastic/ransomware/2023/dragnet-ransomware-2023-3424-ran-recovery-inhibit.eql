// Dragnet [Ransomware]: dragnet-ransomware-2023-3424 — Recovery Inhibition (daixin)
// Status: deprecated | Level: high | ID: 8743fd80-cfbc-5dae-a7e6-fecee56ccdbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
