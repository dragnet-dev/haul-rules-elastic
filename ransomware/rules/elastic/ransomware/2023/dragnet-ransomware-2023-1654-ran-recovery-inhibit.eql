// Dragnet [Ransomware]: dragnet-ransomware-2023-1654 — Recovery Inhibition (cryptnet)
// Status: experimental | Level: high | ID: 5bb3e4ee-f9ca-5d56-959d-42d43bcd10e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
