// Dragnet [Ransomware]: dragnet-ransomware-2023-3667 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 3aeda4e6-7245-5a68-a671-7364ee2f73f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
