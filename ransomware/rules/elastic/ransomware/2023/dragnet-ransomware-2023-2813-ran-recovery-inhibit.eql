// Dragnet [Ransomware]: dragnet-ransomware-2023-2813 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: bcaf2fcf-e963-53b7-98c2-8f88131def24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
