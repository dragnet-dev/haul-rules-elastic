// Dragnet [Ransomware]: dragnet-ransomware-2023-0179 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 01f8971c-f82e-5faf-b555-e1668e578640

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
