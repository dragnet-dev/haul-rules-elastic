// Dragnet [Ransomware]: dragnet-ransomware-2023-2537 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5e0044cc-a132-5744-a2d5-093acd24fd3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
