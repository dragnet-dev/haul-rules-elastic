// Dragnet [Ransomware]: dragnet-ransomware-2023-3651 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 16e56d86-08e7-5b30-b085-3c922c8994a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
