// Dragnet [Ransomware]: dragnet-ransomware-2023-4851 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: c9fbfcd0-cb1c-5a32-b6b3-7ba6e814f0e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
