// Dragnet [Ransomware]: dragnet-ransomware-2023-2139 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: cc403649-7f8c-5bcd-b75a-10178b9c8d8f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
