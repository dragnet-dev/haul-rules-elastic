// Dragnet [Ransomware]: dragnet-ransomware-2023-0004 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 42a34315-28dc-5ddc-9651-69bf2fd67f6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
