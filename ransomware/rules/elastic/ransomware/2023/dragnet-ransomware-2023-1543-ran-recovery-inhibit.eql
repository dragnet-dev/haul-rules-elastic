// Dragnet [Ransomware]: dragnet-ransomware-2023-1543 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9917b4cb-a7b6-5e13-a607-bbbab29719d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
