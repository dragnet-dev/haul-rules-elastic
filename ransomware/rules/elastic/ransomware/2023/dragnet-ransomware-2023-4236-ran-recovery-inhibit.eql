// Dragnet [Ransomware]: dragnet-ransomware-2023-4236 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 28e7245a-50d4-5f25-8c9c-95a120268ab6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
