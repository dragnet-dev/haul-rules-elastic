// Dragnet [Ransomware]: dragnet-ransomware-2023-3805 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: e543afa1-b4ec-50f8-8bd6-c971a073c214

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
