// Dragnet [Ransomware]: dragnet-ransomware-2023-2172 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 22665756-208f-59dc-9f41-4dfb5fec422b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
