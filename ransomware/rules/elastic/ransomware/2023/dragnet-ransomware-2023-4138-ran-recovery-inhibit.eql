// Dragnet [Ransomware]: dragnet-ransomware-2023-4138 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: bfee6453-2b15-566e-a0a5-203db2596031

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
