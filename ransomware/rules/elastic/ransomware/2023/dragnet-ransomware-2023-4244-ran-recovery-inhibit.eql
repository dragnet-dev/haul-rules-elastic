// Dragnet [Ransomware]: dragnet-ransomware-2023-4244 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 24ef0b9c-fe72-580e-a7fe-fc967e759f9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
