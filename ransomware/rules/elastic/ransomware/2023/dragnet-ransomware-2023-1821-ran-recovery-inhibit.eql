// Dragnet [Ransomware]: dragnet-ransomware-2023-1821 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 0096ac51-016c-594a-8b6a-2feb176e418f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
