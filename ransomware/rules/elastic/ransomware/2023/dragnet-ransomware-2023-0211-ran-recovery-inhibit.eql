// Dragnet [Ransomware]: dragnet-ransomware-2023-0211 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 13045a95-8885-5c4e-b335-beef5b795ffb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
