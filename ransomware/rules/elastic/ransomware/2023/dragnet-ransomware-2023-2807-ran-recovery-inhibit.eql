// Dragnet [Ransomware]: dragnet-ransomware-2023-2807 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: daaed616-4d1c-5db6-824e-fecf69d12570

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
