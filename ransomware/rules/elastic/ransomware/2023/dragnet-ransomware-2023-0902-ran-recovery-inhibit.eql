// Dragnet [Ransomware]: dragnet-ransomware-2023-0902 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 34cc3f1c-6117-5e1a-8a38-51cac2de4b82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
