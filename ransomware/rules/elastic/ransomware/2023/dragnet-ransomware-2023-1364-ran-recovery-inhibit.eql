// Dragnet [Ransomware]: dragnet-ransomware-2023-1364 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 57a3109f-36aa-5c66-90ba-6de18bf4cd21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
