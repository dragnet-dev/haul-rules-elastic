// Dragnet [Ransomware]: dragnet-ransomware-2023-1352 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 587daac4-38c3-5a43-88d9-ddbf01317a81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
