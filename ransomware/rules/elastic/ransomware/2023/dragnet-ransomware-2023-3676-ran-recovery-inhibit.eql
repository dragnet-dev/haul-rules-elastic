// Dragnet [Ransomware]: dragnet-ransomware-2023-3676 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: bf5c3de6-3677-5629-a5b6-5b80a2ba402a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
