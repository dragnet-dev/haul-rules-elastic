// Dragnet [Ransomware]: dragnet-ransomware-2023-4083 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 012b4dde-74cd-5955-b23f-17691d5901a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
