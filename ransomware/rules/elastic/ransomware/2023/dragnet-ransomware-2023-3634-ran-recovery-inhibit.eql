// Dragnet [Ransomware]: dragnet-ransomware-2023-3634 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: ecc22397-d54f-51a5-b389-20718e1fb29b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
