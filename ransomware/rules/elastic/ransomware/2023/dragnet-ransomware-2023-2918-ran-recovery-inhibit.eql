// Dragnet [Ransomware]: dragnet-ransomware-2023-2918 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 5db099a4-91ca-5d30-b36f-b67e2ac3d253

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
