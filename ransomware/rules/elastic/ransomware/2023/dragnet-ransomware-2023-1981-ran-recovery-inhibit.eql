// Dragnet [Ransomware]: dragnet-ransomware-2023-1981 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 81db76ba-174e-5d97-befd-d53824f99122

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
