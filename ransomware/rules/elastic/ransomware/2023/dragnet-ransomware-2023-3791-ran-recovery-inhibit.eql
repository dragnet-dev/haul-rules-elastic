// Dragnet [Ransomware]: dragnet-ransomware-2023-3791 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ca2ab71b-2005-549e-8a84-45d3449bf89c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
