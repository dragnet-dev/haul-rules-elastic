// Dragnet [Ransomware]: dragnet-ransomware-2023-2509 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 33bba6ad-b5a2-505b-a03a-86f343389c9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
