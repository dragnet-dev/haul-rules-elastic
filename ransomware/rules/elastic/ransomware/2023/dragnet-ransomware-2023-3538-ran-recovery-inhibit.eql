// Dragnet [Ransomware]: dragnet-ransomware-2023-3538 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 8eebf4ac-811e-5f37-a710-dca551e7aff0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
