// Dragnet [Ransomware]: dragnet-ransomware-2023-3780 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 3f274513-5fb1-57c5-b8ab-38622086ca2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
