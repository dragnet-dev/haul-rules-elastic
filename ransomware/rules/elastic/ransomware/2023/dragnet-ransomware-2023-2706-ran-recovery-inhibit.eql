// Dragnet [Ransomware]: dragnet-ransomware-2023-2706 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: aac27bfe-1c4c-5a3f-82ac-8de75758fce9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
