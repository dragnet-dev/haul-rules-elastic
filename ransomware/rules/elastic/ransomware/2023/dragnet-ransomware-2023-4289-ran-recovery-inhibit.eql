// Dragnet [Ransomware]: dragnet-ransomware-2023-4289 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 0003dfd5-9408-5a61-bf17-2648f420ccb2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
