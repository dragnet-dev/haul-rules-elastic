// Dragnet [Ransomware]: dragnet-ransomware-2023-2406 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: a61c30eb-2526-5efc-bcf4-7ee55d824bc0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
