// Dragnet [Ransomware]: dragnet-ransomware-2023-0044 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5026008e-f5c4-5ca2-ba80-5c48574f8c19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
