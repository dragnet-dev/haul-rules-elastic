// Dragnet [Ransomware]: dragnet-ransomware-2023-0801 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 156a4377-3d8b-5d92-b428-307240f62851

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
