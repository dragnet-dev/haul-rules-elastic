// Dragnet [Ransomware]: dragnet-ransomware-2023-1692 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: dc573301-b8f4-5fff-bad6-880bba061801

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
