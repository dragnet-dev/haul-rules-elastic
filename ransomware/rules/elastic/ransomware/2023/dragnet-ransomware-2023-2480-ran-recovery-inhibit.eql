// Dragnet [Ransomware]: dragnet-ransomware-2023-2480 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 139c4dcb-fdce-5f0e-8513-e31a0ad908f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
