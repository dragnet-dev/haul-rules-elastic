// Dragnet [Ransomware]: dragnet-ransomware-2023-2782 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 5720a8e9-5129-503f-bbc6-8a66fffc8179

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
