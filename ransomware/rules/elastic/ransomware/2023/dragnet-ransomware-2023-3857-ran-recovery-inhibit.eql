// Dragnet [Ransomware]: dragnet-ransomware-2023-3857 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2d93ae41-d7e3-5801-b841-3729091747a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
