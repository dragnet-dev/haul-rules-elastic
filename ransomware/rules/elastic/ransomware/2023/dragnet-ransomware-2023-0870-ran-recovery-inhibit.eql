// Dragnet [Ransomware]: dragnet-ransomware-2023-0870 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d2657ba5-8335-5ee5-9aec-3a51c3ee2f82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
