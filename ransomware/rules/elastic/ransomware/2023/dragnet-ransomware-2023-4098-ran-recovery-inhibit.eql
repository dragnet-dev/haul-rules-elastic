// Dragnet [Ransomware]: dragnet-ransomware-2023-4098 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 1c123df1-2b4f-57af-acfc-b7c91ec4e83c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
