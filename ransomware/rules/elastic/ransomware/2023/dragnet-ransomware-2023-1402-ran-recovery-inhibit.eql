// Dragnet [Ransomware]: dragnet-ransomware-2023-1402 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 45ed4048-508f-5cfb-9b21-48409ba0aa95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
