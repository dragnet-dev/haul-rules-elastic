// Dragnet [Ransomware]: dragnet-ransomware-2023-0730 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5f7a2e8f-5312-5412-863c-c785a272ca67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
