// Dragnet [Ransomware]: dragnet-ransomware-2023-3115 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2659b235-d3f8-5367-a1a6-2b2ed0adf072

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
