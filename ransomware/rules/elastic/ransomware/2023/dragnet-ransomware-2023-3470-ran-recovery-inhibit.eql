// Dragnet [Ransomware]: dragnet-ransomware-2023-3470 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 76b8453a-6f83-5ca7-a651-af8535392f21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
