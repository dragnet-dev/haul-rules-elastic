// Dragnet [Ransomware]: dragnet-ransomware-2023-0795 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: d54c37c9-2fc1-534b-9292-6b16d0bda7ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
