// Dragnet [Ransomware]: dragnet-ransomware-2023-4778 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 42133f94-f324-5682-b637-60bfc7f1f09b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
