// Dragnet [Ransomware]: dragnet-ransomware-2023-2409 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: fa4fa29f-4739-5479-8c3c-88622dc998d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
