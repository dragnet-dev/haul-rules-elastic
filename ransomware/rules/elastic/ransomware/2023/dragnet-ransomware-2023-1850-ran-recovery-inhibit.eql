// Dragnet [Ransomware]: dragnet-ransomware-2023-1850 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: c1c1eadd-db76-5df1-92ce-bf087bcbcb84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
