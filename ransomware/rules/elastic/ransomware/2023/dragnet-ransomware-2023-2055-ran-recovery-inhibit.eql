// Dragnet [Ransomware]: dragnet-ransomware-2023-2055 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 76594292-6bd9-5f90-bbe6-2e0cea77117d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
