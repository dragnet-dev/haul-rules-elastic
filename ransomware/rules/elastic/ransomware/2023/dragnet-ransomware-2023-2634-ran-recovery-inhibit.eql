// Dragnet [Ransomware]: dragnet-ransomware-2023-2634 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7d7903cf-4bb5-5157-aad1-046c457bf72e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
