// Dragnet [Ransomware]: dragnet-ransomware-2023-4175 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 13689af9-6248-50f5-857f-75a3c088266e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
