// Dragnet [Ransomware]: dragnet-ransomware-2023-3096 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ae031d00-2977-5cd7-a3f0-6073e6fccefb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
