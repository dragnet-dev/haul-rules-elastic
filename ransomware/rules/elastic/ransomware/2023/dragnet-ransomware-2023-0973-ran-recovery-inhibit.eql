// Dragnet [Ransomware]: dragnet-ransomware-2023-0973 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: b8968dd2-aa7a-5d9a-bb0a-01e281d3cd4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
