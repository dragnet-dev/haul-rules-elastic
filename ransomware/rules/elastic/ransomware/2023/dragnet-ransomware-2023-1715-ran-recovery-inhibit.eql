// Dragnet [Ransomware]: dragnet-ransomware-2023-1715 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e93e1946-a360-5514-bed5-b480df0a86ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
