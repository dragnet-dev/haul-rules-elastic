// Dragnet [Ransomware]: dragnet-ransomware-2023-3675 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 8a6de484-92ad-5332-b3ea-0b1cb4856b27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
