// Dragnet [Ransomware]: dragnet-ransomware-2023-3624 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f14a97f9-f8b2-5c30-b51e-4eb0688c50de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
