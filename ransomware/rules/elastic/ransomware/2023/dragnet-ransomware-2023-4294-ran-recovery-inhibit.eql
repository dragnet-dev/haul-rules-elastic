// Dragnet [Ransomware]: dragnet-ransomware-2023-4294 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: d646b184-a2de-5a3a-951e-74a73c8efbb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
