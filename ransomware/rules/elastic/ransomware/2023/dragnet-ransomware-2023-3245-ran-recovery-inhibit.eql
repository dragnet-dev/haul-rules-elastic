// Dragnet [Ransomware]: dragnet-ransomware-2023-3245 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: da195bb6-eb1b-5ac3-a774-1383948eaa11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
