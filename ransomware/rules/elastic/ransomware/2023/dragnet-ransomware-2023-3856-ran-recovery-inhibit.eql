// Dragnet [Ransomware]: dragnet-ransomware-2023-3856 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 1557bf51-a550-5158-bd33-b5d49dc27b6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
