// Dragnet [Ransomware]: dragnet-ransomware-2023-2002 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: eaf0f896-9a2e-54b6-ab25-fc166fce26b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
