// Dragnet [Ransomware]: dragnet-ransomware-2023-1052 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: ff62325a-a710-5b19-a891-4b8e751cefc6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
