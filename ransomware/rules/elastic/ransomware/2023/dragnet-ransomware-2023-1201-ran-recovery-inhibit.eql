// Dragnet [Ransomware]: dragnet-ransomware-2023-1201 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 78443716-2608-5faa-972c-4eb8b916dcd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
