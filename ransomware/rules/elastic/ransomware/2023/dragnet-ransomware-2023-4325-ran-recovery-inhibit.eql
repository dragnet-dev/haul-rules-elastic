// Dragnet [Ransomware]: dragnet-ransomware-2023-4325 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: d318edc7-52a3-51c6-b032-b780d5e4ece8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
