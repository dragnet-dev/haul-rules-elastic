// Dragnet [Ransomware]: dragnet-ransomware-2023-4014 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d5a3cd7d-4293-5117-9258-974b37ba5cb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
