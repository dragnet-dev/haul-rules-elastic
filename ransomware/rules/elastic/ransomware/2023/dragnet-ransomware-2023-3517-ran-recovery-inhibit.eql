// Dragnet [Ransomware]: dragnet-ransomware-2023-3517 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 5904db3a-847f-5bc0-aa5a-a9557a537d5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
