// Dragnet [Ransomware]: dragnet-ransomware-2023-2846 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: c0687bf9-0299-5a08-af9b-69525a1364fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
