// Dragnet [Ransomware]: dragnet-ransomware-2023-3074 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d030574a-90b9-5e53-a07b-634ba38687b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
