// Dragnet [Ransomware]: dragnet-ransomware-2023-0540 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d6cbe2ee-3bd0-5893-acf6-bd752c19a4d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
