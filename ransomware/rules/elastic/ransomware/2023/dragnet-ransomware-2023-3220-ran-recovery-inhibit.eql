// Dragnet [Ransomware]: dragnet-ransomware-2023-3220 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: bce4968c-831a-5e8b-9540-ff74bb1fae52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
