// Dragnet [Ransomware]: dragnet-ransomware-2023-3526 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: de2bcc7c-a690-5768-a8f4-d8ff3e09f21d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
