// Dragnet [Ransomware]: dragnet-ransomware-2023-0765 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 4e880a12-270b-5788-970a-18e71d1c79c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
