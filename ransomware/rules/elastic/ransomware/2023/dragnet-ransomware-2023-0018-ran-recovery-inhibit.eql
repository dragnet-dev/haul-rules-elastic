// Dragnet [Ransomware]: dragnet-ransomware-2023-0018 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 5bf05bfa-ae9a-5a11-822d-061495bcd9f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
