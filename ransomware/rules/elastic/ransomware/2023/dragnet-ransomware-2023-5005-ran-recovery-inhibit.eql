// Dragnet [Ransomware]: dragnet-ransomware-2023-5005 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: d2a5abb2-92a0-5046-980f-f0989fa2e2f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
