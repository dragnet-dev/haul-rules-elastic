// Dragnet [Ransomware]: dragnet-ransomware-2023-0051 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 65add1b9-aaa2-5ad5-9d24-6686addcf419

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
