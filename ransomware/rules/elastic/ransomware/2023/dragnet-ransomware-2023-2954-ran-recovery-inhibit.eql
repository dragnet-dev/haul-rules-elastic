// Dragnet [Ransomware]: dragnet-ransomware-2023-2954 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: 2da60501-19a5-5522-b008-05127e6f78af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
