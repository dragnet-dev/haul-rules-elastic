// Dragnet [Ransomware]: dragnet-ransomware-2023-4064 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 75acbd31-4845-57bb-bcfd-40630d359afc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
