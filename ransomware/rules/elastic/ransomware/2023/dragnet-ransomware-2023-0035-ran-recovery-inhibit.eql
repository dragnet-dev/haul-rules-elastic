// Dragnet [Ransomware]: dragnet-ransomware-2023-0035 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d77c7875-3e25-5b1c-af7a-41641010b378

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
