// Dragnet [Ransomware]: dragnet-ransomware-2023-2975 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7cfbb4ae-8859-507b-b04a-09ab0015ddff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
