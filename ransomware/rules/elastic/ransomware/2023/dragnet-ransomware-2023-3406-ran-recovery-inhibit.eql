// Dragnet [Ransomware]: dragnet-ransomware-2023-3406 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ecf739f1-02b2-5a98-8d0d-76cbdab388db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
