// Dragnet [Ransomware]: dragnet-ransomware-2023-2627 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 38630cde-a592-5eea-88d4-5251b7419d74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
