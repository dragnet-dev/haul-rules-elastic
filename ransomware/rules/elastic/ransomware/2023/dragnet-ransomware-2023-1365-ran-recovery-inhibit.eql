// Dragnet [Ransomware]: dragnet-ransomware-2023-1365 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 672193f0-68c8-5f91-b57e-fd04657ac683

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
