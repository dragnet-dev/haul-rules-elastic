// Dragnet [Ransomware]: dragnet-ransomware-2023-2859 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 17c86190-d2bb-5d5c-ba86-8336d3db4ae2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
