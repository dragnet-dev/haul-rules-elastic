// Dragnet [Ransomware]: dragnet-ransomware-2023-2348 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 43cf497a-95f2-5d4c-9e69-63fe4a8d105c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
