// Dragnet [Ransomware]: dragnet-ransomware-2023-1798 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 0711544c-753a-5338-b64d-2ce0c680e292

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
