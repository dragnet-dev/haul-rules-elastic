// Dragnet [Ransomware]: dragnet-ransomware-2023-4503 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 1f7141d4-5fa8-5eaa-b9b2-0c4447d02490

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
