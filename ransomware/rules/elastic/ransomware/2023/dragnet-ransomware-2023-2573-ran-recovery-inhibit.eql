// Dragnet [Ransomware]: dragnet-ransomware-2023-2573 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 9b4c5b97-c92d-58da-8c4e-b3b6c6fb4078

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
