// Dragnet [Ransomware]: dragnet-ransomware-2023-0363 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 2797a96d-5893-5b73-96ee-942ed0fa6310

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
