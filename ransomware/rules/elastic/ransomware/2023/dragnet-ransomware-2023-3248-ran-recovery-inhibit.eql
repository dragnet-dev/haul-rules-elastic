// Dragnet [Ransomware]: dragnet-ransomware-2023-3248 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: a9ddf493-1e66-5dfc-b03f-8457488a97f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
