// Dragnet [Ransomware]: dragnet-ransomware-2023-4624 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f52be908-2f3a-58f3-bd95-4b33b01a1f0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
