// Dragnet [Ransomware]: dragnet-ransomware-2023-2103 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 98b2c714-c3e8-5c9c-833a-cdfc34626b66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
