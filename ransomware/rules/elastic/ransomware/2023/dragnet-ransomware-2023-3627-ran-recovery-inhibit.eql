// Dragnet [Ransomware]: dragnet-ransomware-2023-3627 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 8fa7d1a9-1747-5207-b41e-f64ff35a57ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
