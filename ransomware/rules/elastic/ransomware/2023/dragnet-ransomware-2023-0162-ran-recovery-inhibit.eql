// Dragnet [Ransomware]: dragnet-ransomware-2023-0162 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: d56f2648-6389-563e-a63c-9682464de011

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
