// Dragnet [Ransomware]: dragnet-ransomware-2023-4620 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 354610dd-fa06-5851-9270-6056cef3f210

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
