// Dragnet [Ransomware]: dragnet-ransomware-2023-1603 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: b72114d2-cef6-5d55-9f9d-d3db592aa007

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
