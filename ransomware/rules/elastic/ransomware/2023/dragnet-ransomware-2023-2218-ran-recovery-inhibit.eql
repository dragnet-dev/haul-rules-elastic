// Dragnet [Ransomware]: dragnet-ransomware-2023-2218 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 86bb7df1-ce82-55b9-b08c-49e3b3656a55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
