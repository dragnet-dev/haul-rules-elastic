// Dragnet [Ransomware]: dragnet-ransomware-2023-5333 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: dc392f15-a633-557e-b3a1-a565f2dd8004

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
