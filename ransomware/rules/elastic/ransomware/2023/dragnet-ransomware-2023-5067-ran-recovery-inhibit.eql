// Dragnet [Ransomware]: dragnet-ransomware-2023-5067 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: f233169e-6a1d-51f5-b23b-e0e7fbd4477e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
