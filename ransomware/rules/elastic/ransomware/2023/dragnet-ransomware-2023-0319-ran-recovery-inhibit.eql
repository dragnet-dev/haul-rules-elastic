// Dragnet [Ransomware]: dragnet-ransomware-2023-0319 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 39982213-5331-577d-ac6d-71ecdad19dbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
