// Dragnet [Ransomware]: dragnet-ransomware-2023-1281 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 0cfcdc93-47b9-5019-a1f9-e32abb6ff926

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
