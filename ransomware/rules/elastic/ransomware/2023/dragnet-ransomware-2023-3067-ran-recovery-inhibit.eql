// Dragnet [Ransomware]: dragnet-ransomware-2023-3067 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 649ccbc0-d81a-5b8e-b120-a34271a16605

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
