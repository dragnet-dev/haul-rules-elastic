// Dragnet [Ransomware]: dragnet-ransomware-2023-1853 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 013c8b6b-3231-5bef-85fe-9f4b35937ade

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
