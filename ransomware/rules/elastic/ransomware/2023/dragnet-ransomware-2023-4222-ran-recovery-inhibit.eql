// Dragnet [Ransomware]: dragnet-ransomware-2023-4222 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 50b29cdf-f409-5851-84a9-34d97d7d4f2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
