// Dragnet [Ransomware]: dragnet-ransomware-2023-0072 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: a7237724-8c0a-5ab2-a68c-243db60eb4da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
