// Dragnet [Ransomware]: dragnet-ransomware-2023-5217 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: c5d5a1f5-2310-55dc-9249-7a84c69279f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
