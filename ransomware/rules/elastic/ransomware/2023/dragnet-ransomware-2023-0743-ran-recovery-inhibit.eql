// Dragnet [Ransomware]: dragnet-ransomware-2023-0743 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 14b5352b-ba6e-5d0b-8a86-ef142366930b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
