// Dragnet [Ransomware]: dragnet-ransomware-2023-1709 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 06041e5c-68c9-5e98-800f-1e519bacc60b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
