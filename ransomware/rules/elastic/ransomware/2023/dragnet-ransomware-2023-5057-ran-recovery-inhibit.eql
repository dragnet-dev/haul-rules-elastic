// Dragnet [Ransomware]: dragnet-ransomware-2023-5057 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: bf426e3f-c626-53ee-be78-36566c776c09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
