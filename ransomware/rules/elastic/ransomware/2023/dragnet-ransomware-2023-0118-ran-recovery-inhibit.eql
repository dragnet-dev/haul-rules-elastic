// Dragnet [Ransomware]: dragnet-ransomware-2023-0118 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: 1224ffd4-3ca4-5552-8871-e74359aa134a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
