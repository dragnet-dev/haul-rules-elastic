// Dragnet [Ransomware]: dragnet-ransomware-2023-0537 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9ed79602-a9c6-5871-9ecf-5652d6132d3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
