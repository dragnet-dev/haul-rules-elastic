// Dragnet [Ransomware]: dragnet-ransomware-2023-4921 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9847320a-0101-52f8-9dcf-4dd284942eca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
