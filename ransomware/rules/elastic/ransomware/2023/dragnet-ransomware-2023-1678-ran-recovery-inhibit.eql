// Dragnet [Ransomware]: dragnet-ransomware-2023-1678 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: b4410360-b362-500e-aff0-0b54ebb39498

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
