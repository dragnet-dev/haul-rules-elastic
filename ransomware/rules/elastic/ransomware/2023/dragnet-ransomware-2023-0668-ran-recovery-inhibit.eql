// Dragnet [Ransomware]: dragnet-ransomware-2023-0668 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: 6fdabb00-5e63-5b56-a212-a42dd7896821

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
