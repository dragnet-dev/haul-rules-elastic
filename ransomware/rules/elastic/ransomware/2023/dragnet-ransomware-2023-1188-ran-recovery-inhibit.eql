// Dragnet [Ransomware]: dragnet-ransomware-2023-1188 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f025b626-8bb3-5338-adfe-4b9018d19636

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
