// Dragnet [Ransomware]: dragnet-ransomware-2023-5248 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3ea6ccfc-5064-5949-be41-8edadcdb2404

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
