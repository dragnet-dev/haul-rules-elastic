// Dragnet [Ransomware]: dragnet-ransomware-2023-2707 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: b724ec6c-f17d-5f09-bde5-f3de89a1720e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
