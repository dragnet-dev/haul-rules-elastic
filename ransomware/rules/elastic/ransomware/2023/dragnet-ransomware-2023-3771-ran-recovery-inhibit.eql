// Dragnet [Ransomware]: dragnet-ransomware-2023-3771 — Recovery Inhibition (darkrace)
// Status: experimental | Level: high | ID: fd07df33-90e4-53ac-87c9-6d8bb9fb9be2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
