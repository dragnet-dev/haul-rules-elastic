// Dragnet [Ransomware]: dragnet-ransomware-2023-5252 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 0ea7fce4-664c-56a9-bbf1-f95fdf0f7007

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
