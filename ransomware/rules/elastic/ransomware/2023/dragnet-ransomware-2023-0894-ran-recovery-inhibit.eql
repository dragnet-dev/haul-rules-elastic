// Dragnet [Ransomware]: dragnet-ransomware-2023-0894 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 808ee407-f7c6-53b3-a055-5ec8994f849a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
