// Dragnet [Ransomware]: dragnet-ransomware-2023-4556 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: d72c9863-cb72-5cf7-a9aa-d25c917494c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
