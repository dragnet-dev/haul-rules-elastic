// Dragnet [Ransomware]: dragnet-ransomware-2023-2274 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: 6e942e1c-023e-5e12-a8a4-ac3a23ca5709

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
