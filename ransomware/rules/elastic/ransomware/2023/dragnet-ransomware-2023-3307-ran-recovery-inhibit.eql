// Dragnet [Ransomware]: dragnet-ransomware-2023-3307 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 38c2aafd-b15a-571a-8e07-59b401070c04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
