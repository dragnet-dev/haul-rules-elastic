// Dragnet [Ransomware]: dragnet-ransomware-2023-2349 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: ad185844-7d74-5e2e-9c34-adf92bba3a9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
