// Dragnet [Ransomware]: dragnet-ransomware-2023-3097 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 300371b2-4ac9-53ee-bf43-18c536654986

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
