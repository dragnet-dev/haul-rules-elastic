// Dragnet [Ransomware]: dragnet-ransomware-2023-1009 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4b677719-d7b2-5222-9aa1-4ba11402622d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
