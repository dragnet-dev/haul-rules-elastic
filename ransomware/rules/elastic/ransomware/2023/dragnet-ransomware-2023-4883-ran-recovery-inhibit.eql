// Dragnet [Ransomware]: dragnet-ransomware-2023-4883 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: db22b2e3-29c1-57cb-ae39-e057a33d4798

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
