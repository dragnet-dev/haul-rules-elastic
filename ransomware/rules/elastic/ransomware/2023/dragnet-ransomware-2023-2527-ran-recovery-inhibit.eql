// Dragnet [Ransomware]: dragnet-ransomware-2023-2527 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 4310b072-604f-5929-8446-dc0541af005e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
