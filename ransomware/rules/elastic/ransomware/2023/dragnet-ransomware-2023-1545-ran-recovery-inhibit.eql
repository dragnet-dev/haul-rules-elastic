// Dragnet [Ransomware]: dragnet-ransomware-2023-1545 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 142e89fe-d7fc-5a44-97da-042454199631

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
