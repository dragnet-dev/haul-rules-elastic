// Dragnet [Ransomware]: dragnet-ransomware-2023-5227 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 574a0a3d-4843-565e-adb0-a6054f9d338b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
