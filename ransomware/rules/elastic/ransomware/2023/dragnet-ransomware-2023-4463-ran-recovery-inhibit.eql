// Dragnet [Ransomware]: dragnet-ransomware-2023-4463 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 26659ecc-860b-586b-9ecb-793c042a0850

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
