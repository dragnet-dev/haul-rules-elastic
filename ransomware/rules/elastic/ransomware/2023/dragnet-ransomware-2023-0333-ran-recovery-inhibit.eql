// Dragnet [Ransomware]: dragnet-ransomware-2023-0333 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: c048868a-171b-5e90-930b-cadba544b85f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
