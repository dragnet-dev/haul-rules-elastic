// Dragnet [Ransomware]: dragnet-ransomware-2023-0544 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ea5a3157-01e2-5379-8163-078207dbb6d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
