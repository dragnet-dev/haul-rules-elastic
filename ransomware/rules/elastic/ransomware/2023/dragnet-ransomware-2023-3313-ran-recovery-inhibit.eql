// Dragnet [Ransomware]: dragnet-ransomware-2023-3313 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 273f92a1-f5ef-59f6-a99d-455d4803f3c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
