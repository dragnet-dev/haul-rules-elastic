// Dragnet [Ransomware]: dragnet-ransomware-2023-3202 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3300ace4-51e2-57f3-8027-3728b55f3027

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
