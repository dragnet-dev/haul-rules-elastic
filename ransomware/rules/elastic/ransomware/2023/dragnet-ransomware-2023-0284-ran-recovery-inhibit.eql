// Dragnet [Ransomware]: dragnet-ransomware-2023-0284 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: cc2e262a-b40d-5252-bbde-69fac6a64825

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
