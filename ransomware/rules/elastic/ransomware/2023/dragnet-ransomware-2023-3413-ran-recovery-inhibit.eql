// Dragnet [Ransomware]: dragnet-ransomware-2023-3413 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 7c3a689c-394b-5e88-ab89-b7baecd31756

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
