// Dragnet [Ransomware]: dragnet-ransomware-2023-5077 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 075778a8-eb41-5989-8c98-392e9156d484

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
