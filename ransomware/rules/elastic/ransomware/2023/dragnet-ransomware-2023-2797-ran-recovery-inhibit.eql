// Dragnet [Ransomware]: dragnet-ransomware-2023-2797 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: da0cf3d2-e7a2-5b1f-9db2-9e73720f075e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
