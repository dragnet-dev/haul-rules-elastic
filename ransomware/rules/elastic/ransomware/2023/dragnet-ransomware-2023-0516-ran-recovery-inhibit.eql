// Dragnet [Ransomware]: dragnet-ransomware-2023-0516 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 67e913f5-14df-5d5e-8a3e-69e3f1ef5524

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
