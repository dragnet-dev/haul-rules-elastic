// Dragnet [Ransomware]: dragnet-ransomware-2023-2900 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 93222993-902b-5ee5-a5ab-02c8cdeec460

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
