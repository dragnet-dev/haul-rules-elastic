// Dragnet [Ransomware]: dragnet-ransomware-2023-4671 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: cb4d28f6-a292-5feb-854a-3cbe807e9d0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
