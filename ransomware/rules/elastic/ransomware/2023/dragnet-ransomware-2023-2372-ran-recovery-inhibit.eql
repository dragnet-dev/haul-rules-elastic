// Dragnet [Ransomware]: dragnet-ransomware-2023-2372 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: ee37e4a5-a0fe-5dad-ab9a-f129e4e9cb6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
