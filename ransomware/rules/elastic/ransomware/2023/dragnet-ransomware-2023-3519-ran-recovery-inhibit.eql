// Dragnet [Ransomware]: dragnet-ransomware-2023-3519 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: d6d8df96-580f-5ae6-b769-23275b14a576

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
