// Dragnet [Ransomware]: dragnet-ransomware-2023-2500 — Recovery Inhibition (werewolves)
// Status: experimental | Level: high | ID: 97fc2d59-3ae6-5f16-a2fc-82f90ff48eca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
