// Dragnet [Ransomware]: dragnet-ransomware-2023-0849 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: b29392dc-204a-5eab-b0f9-d16ac027237e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
