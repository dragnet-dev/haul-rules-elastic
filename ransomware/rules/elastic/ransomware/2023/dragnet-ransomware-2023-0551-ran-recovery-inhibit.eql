// Dragnet [Ransomware]: dragnet-ransomware-2023-0551 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b4df51a2-3d51-57c9-9508-75a3842adceb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
