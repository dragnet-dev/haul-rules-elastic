// Dragnet [Ransomware]: dragnet-ransomware-2023-0574 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 058506cb-dcb4-5123-afb4-1cc1cba8dfd7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
