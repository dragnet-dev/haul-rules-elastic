// Dragnet [Ransomware]: dragnet-ransomware-2023-2990 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e3088779-3811-5502-a60b-1c1d81300fbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
