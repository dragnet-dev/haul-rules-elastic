// Dragnet [Ransomware]: dragnet-ransomware-2023-1254 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: bfe81ef4-9439-59b9-a243-70eb8668a8ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
