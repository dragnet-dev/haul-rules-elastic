// Dragnet [Ransomware]: dragnet-ransomware-2023-3393 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 43243187-24a8-5ab1-8996-39fb5c993fd7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
