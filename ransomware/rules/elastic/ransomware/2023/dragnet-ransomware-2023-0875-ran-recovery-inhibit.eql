// Dragnet [Ransomware]: dragnet-ransomware-2023-0875 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0ec3627a-eebd-5b35-9ea4-450941c9b85e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
