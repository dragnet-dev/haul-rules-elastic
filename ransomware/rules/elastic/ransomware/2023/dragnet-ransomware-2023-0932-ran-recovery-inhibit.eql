// Dragnet [Ransomware]: dragnet-ransomware-2023-0932 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 7e661996-e2bc-530c-be67-01a052846cd3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
