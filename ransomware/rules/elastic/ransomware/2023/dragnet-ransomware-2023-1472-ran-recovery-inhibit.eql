// Dragnet [Ransomware]: dragnet-ransomware-2023-1472 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: c4cb663c-c0e3-5f78-8624-e99b9d525970

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
