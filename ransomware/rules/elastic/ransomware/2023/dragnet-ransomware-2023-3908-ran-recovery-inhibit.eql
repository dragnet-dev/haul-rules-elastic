// Dragnet [Ransomware]: dragnet-ransomware-2023-3908 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: cbc656d4-c623-5dc0-9cb0-6383d16b9796

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
