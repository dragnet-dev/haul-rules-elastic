// Dragnet [Ransomware]: dragnet-ransomware-2023-0092 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5ed2cafc-4e79-503f-8638-ab1b2613419a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
