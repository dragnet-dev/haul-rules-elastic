// Dragnet [Ransomware]: dragnet-ransomware-2023-1974 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: cec5e8ff-93ca-5930-a90c-f70861c29676

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
