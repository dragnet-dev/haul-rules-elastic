// Dragnet [Ransomware]: dragnet-ransomware-2023-1247 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c75964d2-7e18-5eb8-ad92-62cf867d942a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
