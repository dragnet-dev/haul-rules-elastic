// Dragnet [Ransomware]: dragnet-ransomware-2023-1222 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 82e64d6e-ebc5-5808-8e88-eeef1c395cf3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
