// Dragnet [Ransomware]: dragnet-ransomware-2023-1441 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 910df15f-a349-5602-bacb-c2e7e36ad115

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
