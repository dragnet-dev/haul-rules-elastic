// Dragnet [Ransomware]: dragnet-ransomware-2023-3932 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 4003726f-c263-5fd2-80ea-aebdda78c1d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
