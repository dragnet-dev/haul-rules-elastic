// Dragnet [Ransomware]: dragnet-ransomware-2023-1847 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 261d2245-70f4-50ec-a2de-561f033bbf9c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
