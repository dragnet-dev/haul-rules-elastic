// Dragnet [Ransomware]: dragnet-ransomware-2023-5120 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b1c67da1-0257-551a-a10c-38dc4e363b51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
