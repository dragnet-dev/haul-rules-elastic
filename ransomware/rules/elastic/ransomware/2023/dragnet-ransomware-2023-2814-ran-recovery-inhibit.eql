// Dragnet [Ransomware]: dragnet-ransomware-2023-2814 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 91151240-1d23-56e8-afd3-379ac5c11d0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
