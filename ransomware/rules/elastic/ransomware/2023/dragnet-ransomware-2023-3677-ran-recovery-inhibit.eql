// Dragnet [Ransomware]: dragnet-ransomware-2023-3677 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 096c51ac-8995-5077-9eb0-c518151ce008

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
