// Dragnet [Ransomware]: dragnet-ransomware-2023-2189 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 77f1b88d-2174-53c7-b205-28a33e5c9748

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
