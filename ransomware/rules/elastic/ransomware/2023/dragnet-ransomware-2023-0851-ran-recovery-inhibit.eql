// Dragnet [Ransomware]: dragnet-ransomware-2023-0851 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 479fa445-62fb-5891-a9a6-d240eff4bfad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
