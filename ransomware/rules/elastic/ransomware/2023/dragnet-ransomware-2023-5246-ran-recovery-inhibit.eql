// Dragnet [Ransomware]: dragnet-ransomware-2023-5246 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a954b4c3-7cc7-52aa-8fb1-cda4b2a3ac2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
