// Dragnet [Ransomware]: dragnet-ransomware-2023-0244 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: e58ef30c-d7c8-5974-9d45-6543ca7ab7ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
