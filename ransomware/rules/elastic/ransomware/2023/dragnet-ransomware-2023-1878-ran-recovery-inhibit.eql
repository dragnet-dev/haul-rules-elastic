// Dragnet [Ransomware]: dragnet-ransomware-2023-1878 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: 9e73a10b-f319-5032-bec0-ad0f25d28e86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
