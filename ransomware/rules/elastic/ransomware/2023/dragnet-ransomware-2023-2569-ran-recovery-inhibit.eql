// Dragnet [Ransomware]: dragnet-ransomware-2023-2569 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 446b78c2-f04c-5d24-8548-b3fdf08abb40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
