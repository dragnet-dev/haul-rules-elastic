// Dragnet [Ransomware]: dragnet-ransomware-2023-2378 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5e5e3bc6-8e7d-5b64-9968-f1836e31ac99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
