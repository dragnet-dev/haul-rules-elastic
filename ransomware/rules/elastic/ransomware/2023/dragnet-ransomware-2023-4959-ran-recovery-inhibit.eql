// Dragnet [Ransomware]: dragnet-ransomware-2023-4959 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ff6bb77c-298a-58e4-8fdb-6ca616dd7e4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
