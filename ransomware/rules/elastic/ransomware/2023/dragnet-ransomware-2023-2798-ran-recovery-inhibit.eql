// Dragnet [Ransomware]: dragnet-ransomware-2023-2798 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 56f8f8d8-ceb5-5001-96e9-98b14140c072

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
