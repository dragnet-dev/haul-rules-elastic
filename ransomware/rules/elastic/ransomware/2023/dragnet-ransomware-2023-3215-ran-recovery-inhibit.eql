// Dragnet [Ransomware]: dragnet-ransomware-2023-3215 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: a0e5e6d3-9d2c-5705-bcbd-1b5118325539

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
