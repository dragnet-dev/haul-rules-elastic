// Dragnet [Ransomware]: dragnet-ransomware-2023-2117 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: c22e5973-0f14-5a25-acad-5ca11e9d2226

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
