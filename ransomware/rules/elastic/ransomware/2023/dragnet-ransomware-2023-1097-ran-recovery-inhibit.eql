// Dragnet [Ransomware]: dragnet-ransomware-2023-1097 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e2f0738c-0308-5264-bcf5-472852a7bf2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
