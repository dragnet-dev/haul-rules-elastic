// Dragnet [Ransomware]: dragnet-ransomware-2023-2630 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 177a2f10-15ed-5486-917e-275b38d1426c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
