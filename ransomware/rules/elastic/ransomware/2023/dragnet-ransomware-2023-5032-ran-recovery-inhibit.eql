// Dragnet [Ransomware]: dragnet-ransomware-2023-5032 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 9ae074df-5eb9-5901-b957-8e9ac69528d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
