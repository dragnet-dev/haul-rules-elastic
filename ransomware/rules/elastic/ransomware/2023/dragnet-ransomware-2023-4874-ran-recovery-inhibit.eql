// Dragnet [Ransomware]: dragnet-ransomware-2023-4874 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 2be16d27-c661-54c5-8ff9-dd32967fdb2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
