// Dragnet [Ransomware]: dragnet-ransomware-2023-3291 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: 918f79a7-f3aa-5466-82f6-d534d0911563

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
