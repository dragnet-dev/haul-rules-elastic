// Dragnet [Ransomware]: dragnet-ransomware-2023-5058 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4e78b8dd-93cf-552a-8841-d7c265086242

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
