// Dragnet [Ransomware]: dragnet-ransomware-2023-0447 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 9e9f1b06-77f0-55d9-9e20-4330308ea304

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
