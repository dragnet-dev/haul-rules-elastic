// Dragnet [Ransomware]: dragnet-ransomware-2023-2793 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 1a60e3b1-a449-5857-84d2-30124b2c166d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
