// Dragnet [Ransomware]: dragnet-ransomware-2023-4739 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5ed49937-093a-5313-baf7-ac9734a80169

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
