// Dragnet [Ransomware]: dragnet-ransomware-2023-2427 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 09e92df1-74b0-58ce-bd42-e7c31f324af9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
