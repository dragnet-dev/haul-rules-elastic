// Dragnet [Ransomware]: dragnet-ransomware-2023-1004 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 81eabef8-a30c-5724-9add-433afa254b94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
