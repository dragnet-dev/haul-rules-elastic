// Dragnet [Ransomware]: dragnet-ransomware-2023-4196 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: a8de0bb0-676e-5c50-9a6d-878fd5c2c414

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
