// Dragnet [Ransomware]: dragnet-ransomware-2023-1342 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 11c0609d-9092-522c-9b58-a21f6ae0f884

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
