// Dragnet [Ransomware]: dragnet-ransomware-2023-3681 — Recovery Inhibition (ALP-001)
// Status: experimental | Level: high | ID: 941d2529-ad21-50ae-8ac3-4b6abaadc4d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
