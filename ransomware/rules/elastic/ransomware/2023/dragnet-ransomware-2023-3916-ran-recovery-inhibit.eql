// Dragnet [Ransomware]: dragnet-ransomware-2023-3916 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1e388a6a-d4f5-5f25-b329-d78aa894719d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
