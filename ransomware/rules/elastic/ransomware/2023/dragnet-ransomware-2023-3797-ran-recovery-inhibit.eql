// Dragnet [Ransomware]: dragnet-ransomware-2023-3797 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 99dd5ab9-762c-50c4-acb1-ac47171782b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
