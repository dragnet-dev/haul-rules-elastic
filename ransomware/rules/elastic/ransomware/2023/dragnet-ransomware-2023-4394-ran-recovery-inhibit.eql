// Dragnet [Ransomware]: dragnet-ransomware-2023-4394 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f58cd86a-85b1-5ee3-803e-4386628aacae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
