// Dragnet [Ransomware]: dragnet-ransomware-2023-1305 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 4d677919-a6e9-5a3e-a894-c25a15d6300c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
