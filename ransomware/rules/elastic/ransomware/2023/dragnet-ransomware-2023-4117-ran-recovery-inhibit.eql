// Dragnet [Ransomware]: dragnet-ransomware-2023-4117 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e7a52919-2014-5c28-9423-d460c7829229

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
