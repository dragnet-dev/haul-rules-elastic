// Dragnet [Ransomware]: dragnet-ransomware-2023-0945 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 73424dd2-b88f-5eed-94d6-355fdd33681e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
