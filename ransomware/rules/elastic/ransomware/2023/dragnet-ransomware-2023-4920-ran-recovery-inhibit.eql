// Dragnet [Ransomware]: dragnet-ransomware-2023-4920 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: bdca216c-1ab7-5d1b-bbfe-f47cc80e226f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
