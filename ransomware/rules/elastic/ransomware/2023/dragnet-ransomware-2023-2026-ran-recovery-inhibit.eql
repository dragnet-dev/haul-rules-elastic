// Dragnet [Ransomware]: dragnet-ransomware-2023-2026 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 0c820f01-4555-5c55-beaa-6308e90524eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
