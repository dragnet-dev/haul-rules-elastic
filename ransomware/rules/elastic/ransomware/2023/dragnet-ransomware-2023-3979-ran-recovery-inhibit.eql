// Dragnet [Ransomware]: dragnet-ransomware-2023-3979 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: ffe608d4-afff-5e84-a8ee-e88d90d03dce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
