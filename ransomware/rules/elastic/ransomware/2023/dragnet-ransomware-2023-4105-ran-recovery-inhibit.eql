// Dragnet [Ransomware]: dragnet-ransomware-2023-4105 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ffcfc675-a4d1-59a3-806c-8310bdaf036c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
