// Dragnet [Ransomware]: dragnet-ransomware-2023-4377 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: 062da13a-bc14-5213-acab-852fd39ebff7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
