// Dragnet [Ransomware]: dragnet-ransomware-2023-2726 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: f8349f9f-f89b-58d4-a68b-93853900c41f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
