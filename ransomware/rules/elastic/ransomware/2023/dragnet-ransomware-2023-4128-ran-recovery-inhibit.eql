// Dragnet [Ransomware]: dragnet-ransomware-2023-4128 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 707c7226-88a2-503b-acc7-be3b1275245e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
