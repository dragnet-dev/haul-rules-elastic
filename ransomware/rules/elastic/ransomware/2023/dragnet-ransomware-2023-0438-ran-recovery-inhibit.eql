// Dragnet [Ransomware]: dragnet-ransomware-2023-0438 — Recovery Inhibition (cloak)
// Status: experimental | Level: high | ID: 3ac8d33f-3f14-5db1-8e1e-3e0e054756d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
