// Dragnet [Ransomware]: dragnet-ransomware-2023-3154 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f391eaf2-bf8a-5ecc-945c-5071feb791a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
