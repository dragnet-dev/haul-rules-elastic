// Dragnet [Ransomware]: dragnet-ransomware-2023-4502 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 712ffec6-5fab-51b3-b64b-15c8e4f702e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
