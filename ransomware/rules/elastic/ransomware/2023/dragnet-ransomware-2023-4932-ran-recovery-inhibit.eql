// Dragnet [Ransomware]: dragnet-ransomware-2023-4932 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: 3ec1b27e-209b-51ac-89a8-1dc1f100d6d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
