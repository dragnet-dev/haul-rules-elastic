// Dragnet [Ransomware]: dragnet-ransomware-2023-2293 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: d30b3119-7fb7-5d16-add5-4dc6074f7c4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
