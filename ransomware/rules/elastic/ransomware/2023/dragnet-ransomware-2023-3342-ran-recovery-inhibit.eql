// Dragnet [Ransomware]: dragnet-ransomware-2023-3342 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 4aed6728-6bde-5a73-87d0-a158ee401368

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
