// Dragnet [Ransomware]: dragnet-ransomware-2023-4589 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6cc183e4-c2ee-5f08-80fc-2ed5750fc01a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
