// Dragnet [Ransomware]: dragnet-ransomware-2023-4241 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 1b9f92a7-b9fa-5bbc-8311-8f6f1a59c948

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
