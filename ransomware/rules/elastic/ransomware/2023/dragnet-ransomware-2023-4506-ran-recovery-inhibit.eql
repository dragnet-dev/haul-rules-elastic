// Dragnet [Ransomware]: dragnet-ransomware-2023-4506 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a6b0868b-228a-5d05-9e9e-cc699cac5eac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
