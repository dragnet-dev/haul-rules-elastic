// Dragnet [Ransomware]: dragnet-ransomware-2023-5118 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b0daef4b-9c8f-51d8-91ed-5e25c97e521c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
