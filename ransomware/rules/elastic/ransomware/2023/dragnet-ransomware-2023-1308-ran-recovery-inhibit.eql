// Dragnet [Ransomware]: dragnet-ransomware-2023-1308 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3843961e-c476-576e-bf7f-cd6109c59bf6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
