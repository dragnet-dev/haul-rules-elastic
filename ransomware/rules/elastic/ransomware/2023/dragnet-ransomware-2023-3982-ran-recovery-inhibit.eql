// Dragnet [Ransomware]: dragnet-ransomware-2023-3982 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: d1a9d1e4-f993-5621-a5ab-0289b8e6efbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
