// Dragnet [Ransomware]: dragnet-ransomware-2023-2380 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 7f5450fa-bdb9-5545-8956-9dd91ecc738e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
