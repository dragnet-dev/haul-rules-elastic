// Dragnet [Ransomware]: dragnet-ransomware-2023-1771 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: dc039e2d-a71a-5664-acac-b6734c9dbf46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
