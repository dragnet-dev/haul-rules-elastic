// Dragnet [Ransomware]: dragnet-ransomware-2023-1636 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 96cae56c-67b5-51d6-a660-af26202fcfe8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
