// Dragnet [Ransomware]: dragnet-ransomware-2023-4964 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b483983f-65e2-5122-be18-f3f99cba2233

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
