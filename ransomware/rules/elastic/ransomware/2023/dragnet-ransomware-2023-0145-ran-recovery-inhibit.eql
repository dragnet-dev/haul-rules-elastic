// Dragnet [Ransomware]: dragnet-ransomware-2023-0145 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: b6a8f14a-0965-5020-8c4f-b0c1ce2b6eb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
