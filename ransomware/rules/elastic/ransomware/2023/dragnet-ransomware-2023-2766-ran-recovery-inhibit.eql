// Dragnet [Ransomware]: dragnet-ransomware-2023-2766 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: ad38e9bd-ef2e-5163-9807-985fd8cde995

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
