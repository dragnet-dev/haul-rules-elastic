// Dragnet [Ransomware]: dragnet-ransomware-2023-1915 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: 7d3a5e83-53e6-5883-8b31-4c0e96cf794b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
