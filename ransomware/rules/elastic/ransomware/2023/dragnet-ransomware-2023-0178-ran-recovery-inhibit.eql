// Dragnet [Ransomware]: dragnet-ransomware-2023-0178 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: ae8d14ce-1bdc-5b9b-8ea3-16c1c47e1a31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
