// Dragnet [Ransomware]: dragnet-ransomware-2023-4243 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a69ead4f-48d7-5b19-ba12-a873c6c823b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
