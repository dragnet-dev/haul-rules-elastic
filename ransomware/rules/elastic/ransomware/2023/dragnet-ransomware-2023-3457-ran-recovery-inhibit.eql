// Dragnet [Ransomware]: dragnet-ransomware-2023-3457 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4a3dc6b1-cb6a-5071-893b-b5cdfd81b1d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
