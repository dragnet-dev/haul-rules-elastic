// Dragnet [Ransomware]: dragnet-ransomware-2023-0443 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: b287235d-a189-596f-ab0c-f69c1bf96b99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
