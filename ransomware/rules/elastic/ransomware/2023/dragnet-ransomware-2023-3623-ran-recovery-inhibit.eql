// Dragnet [Ransomware]: dragnet-ransomware-2023-3623 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 025bf2ae-242c-5ab5-92b1-80b9dba510f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
