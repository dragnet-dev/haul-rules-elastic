// Dragnet [Ransomware]: dragnet-ransomware-2023-0547 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: d9d31365-d996-5663-9f32-f1448dcea00c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
