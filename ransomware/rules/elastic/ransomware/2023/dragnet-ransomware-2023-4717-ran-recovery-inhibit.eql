// Dragnet [Ransomware]: dragnet-ransomware-2023-4717 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f461327e-ad56-59f3-b318-f02195864c23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
