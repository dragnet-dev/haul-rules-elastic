// Dragnet [Ransomware]: dragnet-ransomware-2023-3362 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: ff96929b-ab35-5655-beb0-fdcf1a9f23dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
