// Dragnet [Ransomware]: dragnet-ransomware-2023-1019 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: a3180f71-a667-5515-aa04-bad32b812cbd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
