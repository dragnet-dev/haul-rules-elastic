// Dragnet [Ransomware]: dragnet-ransomware-2023-2460 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 8ec49631-6e45-57db-8279-3eab10bca0be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
