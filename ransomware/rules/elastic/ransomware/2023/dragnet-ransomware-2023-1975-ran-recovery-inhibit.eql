// Dragnet [Ransomware]: dragnet-ransomware-2023-1975 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 6e99d570-f6f3-58d6-82d6-fcc840b15d1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
