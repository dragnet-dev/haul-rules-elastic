// Dragnet [Ransomware]: dragnet-ransomware-2023-1983 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: d5c04300-24e8-5cc7-9fba-c0cf56133c46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
