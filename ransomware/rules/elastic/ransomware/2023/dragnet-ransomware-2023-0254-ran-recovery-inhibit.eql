// Dragnet [Ransomware]: dragnet-ransomware-2023-0254 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 8eab53d4-88ec-50bf-b819-360016057aef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
