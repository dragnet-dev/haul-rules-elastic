// Dragnet [Ransomware]: dragnet-ransomware-2023-0680 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: cf7cec30-d917-5745-844b-baed5404ed45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
