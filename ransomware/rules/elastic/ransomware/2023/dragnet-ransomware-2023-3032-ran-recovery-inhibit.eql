// Dragnet [Ransomware]: dragnet-ransomware-2023-3032 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 58aa2482-171e-5bb2-83bb-37cb0c7539ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
