// Dragnet [Ransomware]: dragnet-ransomware-2023-5020 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c4ae3914-2899-5948-86f9-ef026aa47309

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
