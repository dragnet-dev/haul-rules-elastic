// Dragnet [Ransomware]: dragnet-ransomware-2023-0141 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 9ebce454-4b19-5c3d-954e-2c68d495e75a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
