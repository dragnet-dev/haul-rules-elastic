// Dragnet [Ransomware]: dragnet-ransomware-2023-4685 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3521b9f6-8c67-5c6c-b30c-6e23b0f756a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
