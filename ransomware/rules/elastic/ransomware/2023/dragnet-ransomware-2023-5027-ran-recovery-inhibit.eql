// Dragnet [Ransomware]: dragnet-ransomware-2023-5027 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 43cd8cff-e983-5618-8115-7ab4fa7d17fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
