// Dragnet [Ransomware]: dragnet-ransomware-2023-4468 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: ec05a66b-fff5-564d-9a7b-d547549c86bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
