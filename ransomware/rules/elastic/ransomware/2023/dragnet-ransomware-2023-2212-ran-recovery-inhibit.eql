// Dragnet [Ransomware]: dragnet-ransomware-2023-2212 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: c36f23ac-6cfb-513a-9b67-84e9ca064680

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
