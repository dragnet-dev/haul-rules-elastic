// Dragnet [Ransomware]: dragnet-ransomware-2023-3673 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 78ccfd77-4dbd-5c48-8850-5de4d9747427

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
