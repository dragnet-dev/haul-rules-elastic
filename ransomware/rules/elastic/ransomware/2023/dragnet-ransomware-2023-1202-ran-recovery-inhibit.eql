// Dragnet [Ransomware]: dragnet-ransomware-2023-1202 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 61cfb4da-aacc-5932-ab1a-a41f6c2c174a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
