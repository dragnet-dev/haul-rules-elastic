// Dragnet [Ransomware]: dragnet-ransomware-2023-1697 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 650c464e-726f-51b1-bf48-264525446f57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
