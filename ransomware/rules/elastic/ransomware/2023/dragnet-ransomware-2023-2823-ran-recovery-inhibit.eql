// Dragnet [Ransomware]: dragnet-ransomware-2023-2823 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 37312f04-eeb8-5b20-be9d-dfab45a2ee89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
