// Dragnet [Ransomware]: dragnet-ransomware-2023-1051 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c3640878-3685-5458-bf49-c8cd48933673

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
