// Dragnet [Ransomware]: dragnet-ransomware-2023-0198 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9a84f582-d0c8-5131-9baa-70593bfbb2e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
