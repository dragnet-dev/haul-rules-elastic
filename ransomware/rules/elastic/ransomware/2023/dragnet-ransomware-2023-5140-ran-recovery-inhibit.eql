// Dragnet [Ransomware]: dragnet-ransomware-2023-5140 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 790d5a31-d771-519c-ab6e-6dab8c1844d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
