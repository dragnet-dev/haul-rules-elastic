// Dragnet [Ransomware]: dragnet-ransomware-2023-1368 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c35526a3-847b-5ce4-917f-282bac7dc172

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
