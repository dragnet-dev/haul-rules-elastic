// Dragnet [Ransomware]: dragnet-ransomware-2023-4427 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: 2aa6aa1a-1d9e-5a92-8a1e-18c262b37369

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
