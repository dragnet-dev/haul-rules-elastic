// Dragnet [Ransomware]: dragnet-ransomware-2023-3898 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: 4c304538-8924-5a61-ab5b-2bba65a50e7c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
