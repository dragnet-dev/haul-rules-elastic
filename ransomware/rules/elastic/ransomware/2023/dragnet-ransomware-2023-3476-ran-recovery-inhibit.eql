// Dragnet [Ransomware]: dragnet-ransomware-2023-3476 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 0e715ac1-300c-5b4e-aac7-b2f058933105

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
