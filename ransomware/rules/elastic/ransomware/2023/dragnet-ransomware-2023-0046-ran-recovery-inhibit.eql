// Dragnet [Ransomware]: dragnet-ransomware-2023-0046 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3b5f994f-de43-579a-a164-cf2faeca1a82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
