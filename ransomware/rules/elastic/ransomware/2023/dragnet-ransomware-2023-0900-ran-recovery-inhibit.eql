// Dragnet [Ransomware]: dragnet-ransomware-2023-0900 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 6fe43a30-b48a-53a6-ae15-98052cc442d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
