// Dragnet [Ransomware]: dragnet-ransomware-2023-3048 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: be2b15e9-0de5-5e21-b54d-6f3e42a3803a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
