// Dragnet [Ransomware]: dragnet-ransomware-2023-1135 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 4025d539-17f3-554e-94d7-f76f92eb2220

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
