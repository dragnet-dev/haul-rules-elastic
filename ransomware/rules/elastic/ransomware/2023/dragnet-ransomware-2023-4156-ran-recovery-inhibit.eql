// Dragnet [Ransomware]: dragnet-ransomware-2023-4156 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d828ff1a-3949-5e42-88a8-bd92aede53a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
