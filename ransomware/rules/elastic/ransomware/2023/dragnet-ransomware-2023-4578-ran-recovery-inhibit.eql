// Dragnet [Ransomware]: dragnet-ransomware-2023-4578 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: f5755c5e-3c6f-5b24-8700-2a5a771f1139

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
