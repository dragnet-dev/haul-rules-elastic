// Dragnet [Ransomware]: dragnet-ransomware-2023-3459 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0add66af-cbed-5216-a436-de7d9141cb59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
