// Dragnet [Ransomware]: dragnet-ransomware-2023-4665 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: b08715d5-55dc-5167-84c5-72533d37c3b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
