// Dragnet [Ransomware]: dragnet-ransomware-2023-1554 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: bdfa9b34-1a37-59f9-bd6f-416bf650ff3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
