// Dragnet [Ransomware]: dragnet-ransomware-2023-5113 — Recovery Inhibition (dunghill)
// Status: experimental | Level: high | ID: 72f9455d-594d-5a2b-bdb7-de79c0f8005c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
