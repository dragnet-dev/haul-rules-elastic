// Dragnet [Ransomware]: dragnet-ransomware-2023-3540 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 0f304bcf-6df6-5b33-b9a7-df85cde65e1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
