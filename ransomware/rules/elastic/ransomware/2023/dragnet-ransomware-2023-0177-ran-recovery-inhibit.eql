// Dragnet [Ransomware]: dragnet-ransomware-2023-0177 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a54b2306-6d3e-5da1-9989-cbd82e678d87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
