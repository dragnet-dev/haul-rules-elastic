// Dragnet [Ransomware]: dragnet-ransomware-2023-1084 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: ab0350ba-8158-50c6-bc9c-d80910ceb507

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
