// Dragnet [Ransomware]: dragnet-ransomware-2023-0720 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 243411f5-e430-538a-9bab-c45a37f49be0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
