// Dragnet [Ransomware]: dragnet-ransomware-2023-1315 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: 76f880c0-07cd-5090-aa0e-e10d48a77e33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
