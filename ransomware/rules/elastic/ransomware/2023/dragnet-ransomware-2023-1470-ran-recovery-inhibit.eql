// Dragnet [Ransomware]: dragnet-ransomware-2023-1470 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: bd4474a7-6bbd-5c2d-8454-45ea3e1a0ccf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
