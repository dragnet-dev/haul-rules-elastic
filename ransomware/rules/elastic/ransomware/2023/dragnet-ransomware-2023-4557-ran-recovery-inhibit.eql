// Dragnet [Ransomware]: dragnet-ransomware-2023-4557 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: faa83402-199e-5e1d-9f7c-f41b4bcbcd11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
