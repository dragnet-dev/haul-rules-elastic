// Dragnet [Ransomware]: dragnet-ransomware-2023-1923 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 2f7ccf02-8766-51e6-a04b-f5cc502bf7a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
