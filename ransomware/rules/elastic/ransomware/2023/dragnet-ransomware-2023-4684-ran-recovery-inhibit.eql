// Dragnet [Ransomware]: dragnet-ransomware-2023-4684 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 67256628-b994-5cb4-a91d-d1f3ba49e8ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
