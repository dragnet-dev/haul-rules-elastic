// Dragnet [Ransomware]: dragnet-ransomware-2023-1519 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 41564049-dc9b-5dcc-b1d4-a2e995c5c650

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
