// Dragnet [Ransomware]: dragnet-ransomware-2023-4101 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9e9cae1b-f1a2-547c-8006-104d3b84fbef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
