// Dragnet [Ransomware]: dragnet-ransomware-2023-2593 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7b286b39-0351-5be4-958c-bb2b73adb96d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
