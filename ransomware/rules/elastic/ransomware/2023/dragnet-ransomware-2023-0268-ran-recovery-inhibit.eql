// Dragnet [Ransomware]: dragnet-ransomware-2023-0268 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c8c10ee6-2049-5226-8c0c-45b15119ffc1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
