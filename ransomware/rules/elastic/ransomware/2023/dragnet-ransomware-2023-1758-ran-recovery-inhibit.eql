// Dragnet [Ransomware]: dragnet-ransomware-2023-1758 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 7092adb7-ceca-5e70-bb83-df32afc9764b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
