// Dragnet [Ransomware]: dragnet-ransomware-2023-1707 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 559e7672-fd5f-5068-a8a5-27fd076941a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
