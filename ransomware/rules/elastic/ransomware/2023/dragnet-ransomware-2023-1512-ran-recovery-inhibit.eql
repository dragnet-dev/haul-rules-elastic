// Dragnet [Ransomware]: dragnet-ransomware-2023-1512 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8d9fa24a-512c-5b81-b165-f1e268d33c1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
