// Dragnet [Ransomware]: dragnet-ransomware-2023-2164 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: bd129811-1314-550c-b862-86c1c18a7d25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
