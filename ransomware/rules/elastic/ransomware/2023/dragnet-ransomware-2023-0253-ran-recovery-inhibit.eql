// Dragnet [Ransomware]: dragnet-ransomware-2023-0253 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: bd8a78a1-2c9f-5027-9bcc-694fe2b3ac17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
