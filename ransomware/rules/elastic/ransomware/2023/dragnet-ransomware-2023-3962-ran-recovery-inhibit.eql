// Dragnet [Ransomware]: dragnet-ransomware-2023-3962 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: ae9a43d8-f945-58cf-a90e-eb9ad3aa36a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
