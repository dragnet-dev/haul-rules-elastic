// Dragnet [Ransomware]: dragnet-ransomware-2023-2700 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: daa013ea-c21c-50ce-9103-49cd984927e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
