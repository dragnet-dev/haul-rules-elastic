// Dragnet [Ransomware]: dragnet-ransomware-2023-2791 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 503420d5-ca6a-5563-b75f-a25702cf9ed2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
