// Dragnet [Ransomware]: dragnet-ransomware-2023-2498 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 8d141cfe-9d92-5ad1-83f0-85a17e8ca7a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
