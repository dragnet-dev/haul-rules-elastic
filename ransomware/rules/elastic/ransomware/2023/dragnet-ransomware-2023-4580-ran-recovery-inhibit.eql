// Dragnet [Ransomware]: dragnet-ransomware-2023-4580 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 2d56ff0a-4241-5c8c-8af8-cbd6fcc418d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
