// Dragnet [Ransomware]: dragnet-ransomware-2023-3516 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: acc1fa1d-5061-5088-84cb-7bd9ed233771

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
