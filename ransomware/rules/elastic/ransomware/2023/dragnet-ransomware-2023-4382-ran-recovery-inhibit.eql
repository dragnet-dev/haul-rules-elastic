// Dragnet [Ransomware]: dragnet-ransomware-2023-4382 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 7efdccd4-c1aa-5126-a3c0-763c91813a93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
