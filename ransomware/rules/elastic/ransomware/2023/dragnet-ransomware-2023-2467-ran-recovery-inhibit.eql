// Dragnet [Ransomware]: dragnet-ransomware-2023-2467 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 3551304c-e4f8-5f45-b938-a711920615dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
