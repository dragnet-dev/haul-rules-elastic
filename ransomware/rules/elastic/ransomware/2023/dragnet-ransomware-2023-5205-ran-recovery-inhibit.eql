// Dragnet [Ransomware]: dragnet-ransomware-2023-5205 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: de47ecb9-b837-5e26-8aab-6cfd4eb0bbbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
