// Dragnet [Ransomware]: dragnet-ransomware-2023-3398 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: abaee705-e9d6-58e8-b4fa-263856ab1c9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
