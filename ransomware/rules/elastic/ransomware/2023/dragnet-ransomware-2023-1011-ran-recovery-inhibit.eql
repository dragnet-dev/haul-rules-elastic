// Dragnet [Ransomware]: dragnet-ransomware-2023-1011 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 48e3c97b-72e5-5f15-ae1a-9983dc68d502

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
