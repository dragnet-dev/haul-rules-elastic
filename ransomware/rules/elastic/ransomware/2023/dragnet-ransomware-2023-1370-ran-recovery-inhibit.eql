// Dragnet [Ransomware]: dragnet-ransomware-2023-1370 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: 4a3528d7-fa4d-5aae-90fc-5f0cf8d54a33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
