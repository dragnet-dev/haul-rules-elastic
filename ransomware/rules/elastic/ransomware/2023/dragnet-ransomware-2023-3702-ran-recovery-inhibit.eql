// Dragnet [Ransomware]: dragnet-ransomware-2023-3702 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: d844571f-4c6f-577a-afd5-3dd4df870451

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
