// Dragnet [Ransomware]: dragnet-ransomware-2023-4010 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2c198207-fdda-504d-935d-15c573ff4d9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
