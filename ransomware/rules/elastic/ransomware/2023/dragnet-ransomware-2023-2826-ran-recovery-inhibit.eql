// Dragnet [Ransomware]: dragnet-ransomware-2023-2826 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 627ad40e-8fd5-5c05-a37f-20c81190380c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
