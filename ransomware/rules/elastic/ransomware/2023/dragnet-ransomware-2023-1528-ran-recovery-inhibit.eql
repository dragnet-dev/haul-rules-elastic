// Dragnet [Ransomware]: dragnet-ransomware-2023-1528 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 00621798-16a7-5051-a35d-d7da6088c05d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
