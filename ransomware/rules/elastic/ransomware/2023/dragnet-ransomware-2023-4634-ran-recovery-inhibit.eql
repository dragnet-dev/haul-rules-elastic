// Dragnet [Ransomware]: dragnet-ransomware-2023-4634 — Recovery Inhibition (siegedsec)
// Status: deprecated | Level: high | ID: e46cb25b-a07e-51d2-b012-a4a8f49ead24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
