// Dragnet [Ransomware]: dragnet-ransomware-2023-0946 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: d4311f96-4d83-5807-acc1-371a018699f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
