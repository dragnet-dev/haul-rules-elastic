// Dragnet [Ransomware]: dragnet-ransomware-2023-1105 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e9cbb358-a76c-589d-bd79-2fad270ee7d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
