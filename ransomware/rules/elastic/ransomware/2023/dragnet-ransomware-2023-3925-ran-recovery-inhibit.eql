// Dragnet [Ransomware]: dragnet-ransomware-2023-3925 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 796a9761-723c-5a29-829e-090549bcb5fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
