// Dragnet [Ransomware]: dragnet-ransomware-2023-3792 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: a27d713b-dd00-58a6-a796-fbc3499423ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
