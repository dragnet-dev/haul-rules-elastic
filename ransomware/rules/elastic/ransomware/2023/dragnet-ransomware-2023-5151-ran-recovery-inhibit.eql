// Dragnet [Ransomware]: dragnet-ransomware-2023-5151 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5be67c56-2b81-54e6-9c34-14effdb314f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
