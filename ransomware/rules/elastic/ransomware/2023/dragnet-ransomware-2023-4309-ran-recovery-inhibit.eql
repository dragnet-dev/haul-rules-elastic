// Dragnet [Ransomware]: dragnet-ransomware-2023-4309 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d7a470ef-1e2f-5779-8225-5d6736d3d6db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
