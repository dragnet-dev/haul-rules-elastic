// Dragnet [Ransomware]: dragnet-ransomware-2023-0577 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: d16a803d-d11c-5197-9f8b-1dde1690046d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
