// Dragnet [Ransomware]: dragnet-ransomware-2023-3210 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 278413aa-a42b-53ed-a569-9d281b67576b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
