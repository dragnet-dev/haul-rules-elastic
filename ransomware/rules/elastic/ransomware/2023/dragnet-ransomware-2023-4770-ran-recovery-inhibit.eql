// Dragnet [Ransomware]: dragnet-ransomware-2023-4770 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c952aae6-90eb-57e3-9c97-1dacf7cd6b96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
