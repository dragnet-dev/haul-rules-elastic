// Dragnet [Ransomware]: dragnet-ransomware-2023-2771 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: a4ae6217-9018-51f0-b711-d44dba6ede1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
