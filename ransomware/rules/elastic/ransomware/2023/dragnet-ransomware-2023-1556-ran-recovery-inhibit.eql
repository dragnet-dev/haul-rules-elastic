// Dragnet [Ransomware]: dragnet-ransomware-2023-1556 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a15bf044-c08c-56c4-b06e-a5e19d9cab6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
