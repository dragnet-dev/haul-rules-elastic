// Dragnet [Ransomware]: dragnet-ransomware-2023-2906 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6733b4a4-3663-5ee0-9094-93926869d636

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
