// Dragnet [Ransomware]: dragnet-ransomware-2023-0955 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 41c69e9a-e11d-5fd4-aaf7-b9d4861244a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
