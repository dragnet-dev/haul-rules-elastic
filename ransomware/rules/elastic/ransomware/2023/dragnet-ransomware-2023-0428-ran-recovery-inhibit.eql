// Dragnet [Ransomware]: dragnet-ransomware-2023-0428 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: cf3680ef-94cf-5af5-92b4-c50cb0ffbf83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
