// Dragnet [Ransomware]: dragnet-ransomware-2023-3640 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7a6abb1e-7869-512e-b36e-53b5934df036

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
