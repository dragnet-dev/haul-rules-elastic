// Dragnet [Ransomware]: dragnet-ransomware-2023-2552 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: bddb6c08-1cc3-5f85-bf77-04135edd175c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
