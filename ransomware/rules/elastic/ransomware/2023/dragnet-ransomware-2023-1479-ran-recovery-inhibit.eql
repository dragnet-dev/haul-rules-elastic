// Dragnet [Ransomware]: dragnet-ransomware-2023-1479 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: dc11a1a9-b56a-56b9-93b9-7f781275232b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
