// Dragnet [Ransomware]: dragnet-ransomware-2023-2321 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 83a1dfb4-591f-5d19-9f3c-4b3fca0df21c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
