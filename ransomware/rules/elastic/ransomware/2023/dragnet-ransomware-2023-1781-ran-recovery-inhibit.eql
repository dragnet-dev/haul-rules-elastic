// Dragnet [Ransomware]: dragnet-ransomware-2023-1781 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: a834806e-1298-5327-b1d5-ba1ffb388398

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
