// Dragnet [Ransomware]: dragnet-ransomware-2023-0561 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 212a14dc-f2c3-563e-a6f9-50b9afb63d2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
