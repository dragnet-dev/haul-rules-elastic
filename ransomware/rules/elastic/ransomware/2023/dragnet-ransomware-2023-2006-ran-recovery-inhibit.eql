// Dragnet [Ransomware]: dragnet-ransomware-2023-2006 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 6b39e0e9-e66f-5c6d-a14c-ab93b1ecc24b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
