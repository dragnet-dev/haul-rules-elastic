// Dragnet [Ransomware]: dragnet-ransomware-2023-0872 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 009b9f19-c37a-51f1-a0ba-1eb7263a37a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
