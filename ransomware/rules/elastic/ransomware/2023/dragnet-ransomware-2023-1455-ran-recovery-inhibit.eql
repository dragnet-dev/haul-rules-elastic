// Dragnet [Ransomware]: dragnet-ransomware-2023-1455 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8d408cf6-453a-5f06-b20c-e7c21800ad16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
