// Dragnet [Ransomware]: dragnet-ransomware-2023-2448 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 7f7072fa-7279-57d8-b95f-16e823658853

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
