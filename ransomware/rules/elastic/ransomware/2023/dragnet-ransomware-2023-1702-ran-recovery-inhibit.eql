// Dragnet [Ransomware]: dragnet-ransomware-2023-1702 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3f8d4ff9-e6d0-52d3-8629-486a0a121be0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
