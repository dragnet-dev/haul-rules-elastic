// Dragnet [Ransomware]: dragnet-ransomware-2023-2588 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 86c24d28-25d6-5cdd-9f46-13734cd89f0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
