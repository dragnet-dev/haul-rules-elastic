// Dragnet [Ransomware]: dragnet-ransomware-2023-4869 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 90990fd4-cf7d-5a44-a7bd-470c50a257e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
