// Dragnet [Ransomware]: dragnet-ransomware-2023-2084 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: cf520ccf-0ec6-55fc-92d4-7f0a08e77cb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
