// Dragnet [Ransomware]: dragnet-ransomware-2023-0738 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9a324c5d-f20f-58b1-9a0c-bd5d47e18ac0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
