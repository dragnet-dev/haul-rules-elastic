// Dragnet [Ransomware]: dragnet-ransomware-2023-3633 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 629d0b5a-6b46-5835-b552-253105d61d82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
