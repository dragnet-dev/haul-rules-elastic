// Dragnet [Ransomware]: dragnet-ransomware-2023-2394 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 586e2c74-e45a-5c6a-b4b2-b1a190a9b900

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
