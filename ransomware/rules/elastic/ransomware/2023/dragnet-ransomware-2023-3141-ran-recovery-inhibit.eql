// Dragnet [Ransomware]: dragnet-ransomware-2023-3141 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6e6624c5-e699-5a92-a4ce-28cbb5f736b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
