// Dragnet [Ransomware]: dragnet-ransomware-2023-2801 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 4f37da9f-8a22-5780-b1cc-4b5495f0a41e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
