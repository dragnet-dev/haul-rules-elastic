// Dragnet [Ransomware]: dragnet-ransomware-2023-4047 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a9bbb66d-4c02-5778-a97c-0a5eb01b8ef3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
