// Dragnet [Ransomware]: dragnet-ransomware-2023-2531 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: bb6abaa0-355d-5067-b510-13e42ef3e36b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
