// Dragnet [Ransomware]: dragnet-ransomware-2023-4758 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4235dce2-8bb0-5eb7-9429-e0075f1b233b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
