// Dragnet [Ransomware]: dragnet-ransomware-2023-3417 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c2525601-8c14-50d2-b8bf-acd96016b043

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
