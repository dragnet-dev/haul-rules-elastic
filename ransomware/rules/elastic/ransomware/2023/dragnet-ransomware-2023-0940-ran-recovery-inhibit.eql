// Dragnet [Ransomware]: dragnet-ransomware-2023-0940 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 99402b37-3e05-5020-b329-df241d87da3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
