// Dragnet [Ransomware]: dragnet-ransomware-2023-1889 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 493200f9-5381-50e1-9d8f-26c80a14405e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
