// Dragnet [Ransomware]: dragnet-ransomware-2023-0607 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 4ac33ff2-3b9c-5237-a00b-c9566faabe7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
