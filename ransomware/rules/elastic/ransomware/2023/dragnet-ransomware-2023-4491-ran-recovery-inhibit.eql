// Dragnet [Ransomware]: dragnet-ransomware-2023-4491 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: 77975fb3-3dc4-578a-a313-ddf565e01a5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
