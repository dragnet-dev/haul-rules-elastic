// Dragnet [Ransomware]: dragnet-ransomware-2023-2999 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 27790e48-96e8-5201-b320-203f8c89fd0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
