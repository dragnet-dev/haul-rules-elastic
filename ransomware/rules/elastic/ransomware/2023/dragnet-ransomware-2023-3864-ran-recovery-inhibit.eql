// Dragnet [Ransomware]: dragnet-ransomware-2023-3864 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: f80d66d0-ea1f-52d3-b9d3-90e4ff5938cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
