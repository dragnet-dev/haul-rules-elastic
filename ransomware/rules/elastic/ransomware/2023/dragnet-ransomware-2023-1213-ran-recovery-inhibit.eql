// Dragnet [Ransomware]: dragnet-ransomware-2023-1213 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ee9d0236-b65c-58e6-b0cb-3c46e593b2da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
