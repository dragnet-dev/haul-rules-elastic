// Dragnet [Ransomware]: dragnet-ransomware-2023-5112 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: c1a3f222-e0f2-5170-a4fb-a4a822993a88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
