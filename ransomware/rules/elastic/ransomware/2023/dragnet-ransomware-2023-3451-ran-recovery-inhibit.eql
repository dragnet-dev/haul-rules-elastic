// Dragnet [Ransomware]: dragnet-ransomware-2023-3451 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 02de1768-9e7f-55f3-94e5-632ffa172d48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
