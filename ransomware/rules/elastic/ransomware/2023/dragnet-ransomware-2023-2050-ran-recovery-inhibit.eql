// Dragnet [Ransomware]: dragnet-ransomware-2023-2050 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 15d3c899-3b4c-56e1-bc00-a4d5dc5de8d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
