// Dragnet [Ransomware]: dragnet-ransomware-2023-3440 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 4e6a6fb4-8f68-5656-ab7c-7944b573bb3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
