// Dragnet [Ransomware]: dragnet-ransomware-2023-4912 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 5171244b-aba2-5710-839c-ef8c21b95b6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
