// Dragnet [Ransomware]: dragnet-ransomware-2023-3597 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9a943fb6-f7b8-5139-b5ef-410fa4e26e72

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
