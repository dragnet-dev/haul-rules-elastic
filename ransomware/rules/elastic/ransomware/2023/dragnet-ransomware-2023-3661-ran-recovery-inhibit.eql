// Dragnet [Ransomware]: dragnet-ransomware-2023-3661 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 7b024667-365f-50ce-a575-8ee99f702a15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
