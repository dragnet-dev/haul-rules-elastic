// Dragnet [Ransomware]: dragnet-ransomware-2023-1793 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 8ae323e0-570f-517e-8586-d088538327ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
