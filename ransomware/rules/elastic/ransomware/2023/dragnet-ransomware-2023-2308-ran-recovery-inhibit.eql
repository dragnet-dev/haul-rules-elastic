// Dragnet [Ransomware]: dragnet-ransomware-2023-2308 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c39e045d-4843-5dbb-b6b4-32e4956678bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
