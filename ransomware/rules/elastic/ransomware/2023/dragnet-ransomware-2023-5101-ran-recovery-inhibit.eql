// Dragnet [Ransomware]: dragnet-ransomware-2023-5101 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 874639fc-fc11-5ccf-a651-9acb9afd0873

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
