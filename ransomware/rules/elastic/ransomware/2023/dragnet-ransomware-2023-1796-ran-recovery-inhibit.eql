// Dragnet [Ransomware]: dragnet-ransomware-2023-1796 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 7e5630a6-2d33-58b9-b200-0d92118acb6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
