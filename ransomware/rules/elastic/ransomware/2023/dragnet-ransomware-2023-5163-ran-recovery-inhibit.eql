// Dragnet [Ransomware]: dragnet-ransomware-2023-5163 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: bede3cad-d134-5338-881b-a509b82d41ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
