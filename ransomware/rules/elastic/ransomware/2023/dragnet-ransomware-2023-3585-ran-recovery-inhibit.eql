// Dragnet [Ransomware]: dragnet-ransomware-2023-3585 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d327b898-862e-5c63-8137-014d0611ef34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
