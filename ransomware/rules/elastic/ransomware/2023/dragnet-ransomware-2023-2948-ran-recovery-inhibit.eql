// Dragnet [Ransomware]: dragnet-ransomware-2023-2948 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: 8d341154-c750-5a6d-a1ee-459a3981f4b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
