// Dragnet [Ransomware]: dragnet-ransomware-2023-3605 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 7ece77ff-53cc-5b86-9387-fbf0ebb728a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
