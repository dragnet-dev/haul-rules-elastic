// Dragnet [Ransomware]: dragnet-ransomware-2023-1574 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 11703073-0026-5359-ba19-f97c559b05b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
