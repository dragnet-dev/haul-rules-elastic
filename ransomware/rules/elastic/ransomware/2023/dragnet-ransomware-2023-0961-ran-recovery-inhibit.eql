// Dragnet [Ransomware]: dragnet-ransomware-2023-0961 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 0814fd37-c691-5f36-8eec-0519935e2fe9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
