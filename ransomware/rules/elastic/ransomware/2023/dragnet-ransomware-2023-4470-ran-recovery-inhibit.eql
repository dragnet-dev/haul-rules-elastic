// Dragnet [Ransomware]: dragnet-ransomware-2023-4470 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: d228b352-135a-5449-aa4f-2fbf7fda4875

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
