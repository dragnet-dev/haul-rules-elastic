// Dragnet [Ransomware]: dragnet-ransomware-2023-0136 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: c5d03329-e21c-5ad3-9f8f-8edb8f430a19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
