// Dragnet [Ransomware]: dragnet-ransomware-2023-3006 — Recovery Inhibition (dunghill)
// Status: experimental | Level: high | ID: e0402814-364a-55af-a73a-22a4f15863d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
