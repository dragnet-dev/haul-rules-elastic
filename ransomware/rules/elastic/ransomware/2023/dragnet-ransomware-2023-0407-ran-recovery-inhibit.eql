// Dragnet [Ransomware]: dragnet-ransomware-2023-0407 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 38ec8eec-a560-5078-9dc7-6b3d83a1dda7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
