// Dragnet [Ransomware]: dragnet-ransomware-2023-3746 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a700c137-8541-5b65-9bd9-1e28564196db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
