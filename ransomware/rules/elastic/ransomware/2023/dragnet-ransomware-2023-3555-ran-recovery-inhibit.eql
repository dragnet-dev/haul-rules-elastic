// Dragnet [Ransomware]: dragnet-ransomware-2023-3555 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 6f4bf611-8fc3-5cda-a6f6-906f51bd240c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
