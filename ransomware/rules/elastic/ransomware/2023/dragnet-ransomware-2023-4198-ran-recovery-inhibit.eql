// Dragnet [Ransomware]: dragnet-ransomware-2023-4198 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a627feba-7916-54cd-a3b7-de4d51e6cf3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
