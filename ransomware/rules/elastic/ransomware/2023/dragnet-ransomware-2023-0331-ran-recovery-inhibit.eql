// Dragnet [Ransomware]: dragnet-ransomware-2023-0331 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 54754da5-850d-5589-8211-ccf6b3bdc4c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
