// Dragnet [Ransomware]: dragnet-ransomware-2023-4350 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 86790e1b-19ce-5f3f-a3b9-c7fa00a8e25d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
