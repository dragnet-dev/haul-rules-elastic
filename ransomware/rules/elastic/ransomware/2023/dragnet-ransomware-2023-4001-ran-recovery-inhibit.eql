// Dragnet [Ransomware]: dragnet-ransomware-2023-4001 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: d69f19a7-0fa9-5316-ab86-64f30acd9de5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
