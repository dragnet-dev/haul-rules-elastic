// Dragnet [Ransomware]: dragnet-ransomware-2023-0315 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: c09dc017-cfed-5f22-b8fa-b73e2b9c106b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
