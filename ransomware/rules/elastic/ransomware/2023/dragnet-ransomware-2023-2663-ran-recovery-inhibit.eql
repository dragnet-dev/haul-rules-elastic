// Dragnet [Ransomware]: dragnet-ransomware-2023-2663 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 335a80c2-22bb-536c-8fbf-b3df6c839441

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
