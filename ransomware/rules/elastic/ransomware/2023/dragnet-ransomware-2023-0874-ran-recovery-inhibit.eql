// Dragnet [Ransomware]: dragnet-ransomware-2023-0874 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: ddaf76a3-505f-5f27-8498-5e4ae1577de0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
