// Dragnet [Ransomware]: dragnet-ransomware-2023-0921 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 8ed2691d-dbde-512f-b01f-19daaa4ba4bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
