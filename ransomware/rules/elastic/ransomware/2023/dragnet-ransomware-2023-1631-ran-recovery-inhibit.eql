// Dragnet [Ransomware]: dragnet-ransomware-2023-1631 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: a6307465-4bd5-5393-a203-173434f57c5e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
