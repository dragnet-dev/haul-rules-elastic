// Dragnet [Ransomware]: dragnet-ransomware-2023-1286 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: b4cfc316-aeff-5865-8959-0e1bfb71fada

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
