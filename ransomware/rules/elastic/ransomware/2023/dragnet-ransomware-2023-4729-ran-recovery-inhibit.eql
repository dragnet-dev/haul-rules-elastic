// Dragnet [Ransomware]: dragnet-ransomware-2023-4729 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 54eef22f-fbf5-5a7b-916b-2b85bea9aa6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
