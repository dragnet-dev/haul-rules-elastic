// Dragnet [Ransomware]: dragnet-ransomware-2023-1615 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: c6203a9d-a5eb-53eb-98b2-9fade61d54d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
