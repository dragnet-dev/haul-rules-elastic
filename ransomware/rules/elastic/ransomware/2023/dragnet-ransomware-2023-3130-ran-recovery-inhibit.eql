// Dragnet [Ransomware]: dragnet-ransomware-2023-3130 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: d10de07a-2c4b-5fda-ae33-783a53e4aaa4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
