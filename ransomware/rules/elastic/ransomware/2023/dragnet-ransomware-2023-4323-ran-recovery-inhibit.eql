// Dragnet [Ransomware]: dragnet-ransomware-2023-4323 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: a7b3e813-e33c-5248-b16f-fd9a373a7579

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
