// Dragnet [Ransomware]: dragnet-ransomware-2023-5004 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 828eb02f-3489-5e18-bbcb-6fe63a68124d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
