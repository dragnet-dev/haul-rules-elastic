// Dragnet [Ransomware]: dragnet-ransomware-2023-0667 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 60ec23ac-c84c-512d-b5cc-f0cae344962d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
