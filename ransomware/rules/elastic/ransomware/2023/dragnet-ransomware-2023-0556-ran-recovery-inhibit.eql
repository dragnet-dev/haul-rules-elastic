// Dragnet [Ransomware]: dragnet-ransomware-2023-0556 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: b5047a3a-a817-5dd0-a553-a93db29aab61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
