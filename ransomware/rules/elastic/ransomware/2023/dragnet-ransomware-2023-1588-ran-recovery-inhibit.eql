// Dragnet [Ransomware]: dragnet-ransomware-2023-1588 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: ef5d930b-2fef-5718-b6ce-f1c4d22e9985

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
