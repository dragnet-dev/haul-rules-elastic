// Dragnet [Ransomware]: dragnet-ransomware-2023-3726 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 73c58c24-9575-5fca-9766-45298d62e617

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
