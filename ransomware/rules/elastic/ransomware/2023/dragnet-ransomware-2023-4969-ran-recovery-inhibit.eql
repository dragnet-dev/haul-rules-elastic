// Dragnet [Ransomware]: dragnet-ransomware-2023-4969 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 96153c56-d29c-5125-95d1-652c3dd33a83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
