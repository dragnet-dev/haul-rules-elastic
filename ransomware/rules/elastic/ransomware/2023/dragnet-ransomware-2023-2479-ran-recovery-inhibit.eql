// Dragnet [Ransomware]: dragnet-ransomware-2023-2479 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 89f14f94-9ad9-5c88-83cb-5900c1cc8025

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
