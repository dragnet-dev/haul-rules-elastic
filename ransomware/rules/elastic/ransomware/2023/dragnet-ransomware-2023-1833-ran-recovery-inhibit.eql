// Dragnet [Ransomware]: dragnet-ransomware-2023-1833 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a054e739-3079-5ed6-9314-6e17469a773c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
