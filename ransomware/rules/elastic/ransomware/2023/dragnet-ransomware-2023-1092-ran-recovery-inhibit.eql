// Dragnet [Ransomware]: dragnet-ransomware-2023-1092 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 1f5286b8-0826-58a8-b11f-0696dd32d093

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
