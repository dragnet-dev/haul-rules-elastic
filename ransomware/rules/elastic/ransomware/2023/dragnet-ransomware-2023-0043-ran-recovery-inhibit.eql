// Dragnet [Ransomware]: dragnet-ransomware-2023-0043 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: 66517e19-8ad7-53fd-b62c-5b5aa07c5539

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
