// Dragnet [Ransomware]: dragnet-ransomware-2023-2458 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a7a37665-f067-5567-830f-1a6a348f7731

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
