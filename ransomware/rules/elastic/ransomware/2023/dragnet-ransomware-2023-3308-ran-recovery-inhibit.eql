// Dragnet [Ransomware]: dragnet-ransomware-2023-3308 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 840ffffb-dd5b-5ca4-9a08-c277ec702a3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
