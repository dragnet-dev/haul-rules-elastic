// Dragnet [Ransomware]: dragnet-ransomware-2023-1176 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 025efb21-161c-5bfd-b697-199c11406f27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
