// Dragnet [Ransomware]: dragnet-ransomware-2023-5212 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 98a37572-f0b3-500b-bebd-e804a553d92b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
