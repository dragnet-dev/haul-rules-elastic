// Dragnet [Ransomware]: dragnet-ransomware-2023-0724 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a8878b39-5936-586d-9352-adccd19770c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
