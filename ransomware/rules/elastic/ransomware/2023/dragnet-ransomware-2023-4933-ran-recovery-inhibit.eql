// Dragnet [Ransomware]: dragnet-ransomware-2023-4933 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: d0eb7b47-e679-55a1-bc56-39a7aa082121

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
