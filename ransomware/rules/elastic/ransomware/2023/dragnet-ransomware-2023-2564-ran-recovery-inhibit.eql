// Dragnet [Ransomware]: dragnet-ransomware-2023-2564 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: b86d0933-8326-5cb8-8be0-5598584775ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
