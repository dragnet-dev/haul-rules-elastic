// Dragnet [Ransomware]: dragnet-ransomware-2023-3466 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: ed06d750-3aad-52aa-af57-535648770c17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
