// Dragnet [Ransomware]: dragnet-ransomware-2023-2963 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 83f19228-ffc6-5577-8810-66fd4011285b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
