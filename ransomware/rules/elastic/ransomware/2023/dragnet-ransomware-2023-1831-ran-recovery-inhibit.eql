// Dragnet [Ransomware]: dragnet-ransomware-2023-1831 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a4c483d5-49b7-57d9-a034-ffbb6763dd51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
