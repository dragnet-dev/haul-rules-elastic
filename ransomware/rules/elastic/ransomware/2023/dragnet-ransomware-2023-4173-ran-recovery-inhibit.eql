// Dragnet [Ransomware]: dragnet-ransomware-2023-4173 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 7becabd3-64b7-5026-8688-ddefd0b96941

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
