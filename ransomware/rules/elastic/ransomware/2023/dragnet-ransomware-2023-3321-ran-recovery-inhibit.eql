// Dragnet [Ransomware]: dragnet-ransomware-2023-3321 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e6e35173-e142-51fe-9de7-c049c6f43fd3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
