// Dragnet [Ransomware]: dragnet-ransomware-2023-1569 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e3a38dea-7c99-57ea-ae75-1fe2cff1cb1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
