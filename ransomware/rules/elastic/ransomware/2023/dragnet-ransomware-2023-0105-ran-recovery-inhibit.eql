// Dragnet [Ransomware]: dragnet-ransomware-2023-0105 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 339db465-5ed6-52ae-8497-87a7610c9aa6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
