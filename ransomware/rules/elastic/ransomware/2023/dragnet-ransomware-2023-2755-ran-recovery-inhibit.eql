// Dragnet [Ransomware]: dragnet-ransomware-2023-2755 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: db26a601-ca47-53c1-a362-a18ddd913ed0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
