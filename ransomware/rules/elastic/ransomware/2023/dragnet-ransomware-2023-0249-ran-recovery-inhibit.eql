// Dragnet [Ransomware]: dragnet-ransomware-2023-0249 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: ff057193-7f3e-55a5-b1c7-1909d2b6acb3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
