// Dragnet [Ransomware]: dragnet-ransomware-2023-0798 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: 734874fe-e049-535f-b502-638b175edfe1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
