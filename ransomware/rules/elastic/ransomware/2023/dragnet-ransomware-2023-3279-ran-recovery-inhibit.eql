// Dragnet [Ransomware]: dragnet-ransomware-2023-3279 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: 08b5e0ef-abe3-5fec-b037-d318094e16b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
