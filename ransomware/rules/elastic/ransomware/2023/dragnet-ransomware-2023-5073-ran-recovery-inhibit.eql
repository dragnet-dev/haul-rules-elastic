// Dragnet [Ransomware]: dragnet-ransomware-2023-5073 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 739e7f8e-4f4a-51b9-ad73-2c0b743ed92b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
