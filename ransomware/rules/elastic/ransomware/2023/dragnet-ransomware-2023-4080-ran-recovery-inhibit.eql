// Dragnet [Ransomware]: dragnet-ransomware-2023-4080 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e6e7ba56-1c5f-51de-8050-61849e3f4d5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
