// Dragnet [Ransomware]: dragnet-ransomware-2023-4017 — Recovery Inhibition (underground)
// Status: experimental | Level: high | ID: 7eeedf44-9a9d-5027-a630-d54ada5062ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
