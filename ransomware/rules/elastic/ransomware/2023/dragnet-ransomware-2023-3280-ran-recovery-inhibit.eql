// Dragnet [Ransomware]: dragnet-ransomware-2023-3280 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 9a78d26b-22f9-5d8f-baae-decd01cd721e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
