// Dragnet [Ransomware]: dragnet-ransomware-2023-4761 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 860ea74e-6467-5a63-807f-ba3d15ed4aca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
