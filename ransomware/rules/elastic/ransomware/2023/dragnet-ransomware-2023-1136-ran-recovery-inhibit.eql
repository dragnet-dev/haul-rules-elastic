// Dragnet [Ransomware]: dragnet-ransomware-2023-1136 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 00a7f5d0-d3cf-516a-83a4-93fc77a928a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
