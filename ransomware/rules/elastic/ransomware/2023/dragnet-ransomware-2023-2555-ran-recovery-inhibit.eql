// Dragnet [Ransomware]: dragnet-ransomware-2023-2555 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 6bc861eb-58d4-53f9-ac8d-d25cc14efce6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
