// Dragnet [Ransomware]: dragnet-ransomware-2023-3237 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: e61da2fc-ecbd-5cdd-b1e8-a20fb5799b3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
