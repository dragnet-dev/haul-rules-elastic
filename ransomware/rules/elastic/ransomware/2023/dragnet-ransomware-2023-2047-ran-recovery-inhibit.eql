// Dragnet [Ransomware]: dragnet-ransomware-2023-2047 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: a5a18c0d-8197-532b-9070-c6eadfef7c6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
