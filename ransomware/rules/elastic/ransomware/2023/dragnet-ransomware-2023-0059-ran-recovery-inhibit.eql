// Dragnet [Ransomware]: dragnet-ransomware-2023-0059 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 9cc31afc-065f-57bf-855f-09637fc9c1cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
