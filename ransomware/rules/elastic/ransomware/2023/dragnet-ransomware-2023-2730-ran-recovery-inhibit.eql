// Dragnet [Ransomware]: dragnet-ransomware-2023-2730 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f61fd7d2-bdda-5624-9e4a-e1712c240571

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
