// Dragnet [Ransomware]: dragnet-ransomware-2023-1901 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5adbd21f-6715-5f43-932d-217e20e95c51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
