// Dragnet [Ransomware]: dragnet-ransomware-2023-1291 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 94ee3d26-cd28-54cf-93f5-41660999a8c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
