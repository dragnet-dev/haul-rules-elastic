// Dragnet [Ransomware]: dragnet-ransomware-2023-2787 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 584385ce-53c5-5f68-bad1-eddf4b7f878a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
