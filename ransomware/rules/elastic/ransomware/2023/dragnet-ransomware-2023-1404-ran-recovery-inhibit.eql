// Dragnet [Ransomware]: dragnet-ransomware-2023-1404 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 35680988-534e-599c-ab2f-ed6315effe09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
