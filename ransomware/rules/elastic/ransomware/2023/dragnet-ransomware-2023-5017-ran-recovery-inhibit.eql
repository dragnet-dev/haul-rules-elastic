// Dragnet [Ransomware]: dragnet-ransomware-2023-5017 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 646f99d0-085f-5240-a66e-f7496228b29a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
