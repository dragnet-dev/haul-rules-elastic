// Dragnet [Ransomware]: dragnet-ransomware-2023-3875 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 686a4026-710c-593d-9461-5e389ce48c94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
