// Dragnet [Ransomware]: dragnet-ransomware-2023-3751 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 098f08e1-0307-56c5-8a7c-3b3c38faf610

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
