// Dragnet [Ransomware]: dragnet-ransomware-2023-2063 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b6b4637a-697c-5f79-9d7d-91fc3542bb8f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
