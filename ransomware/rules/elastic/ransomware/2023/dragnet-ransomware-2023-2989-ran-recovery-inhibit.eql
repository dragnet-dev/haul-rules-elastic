// Dragnet [Ransomware]: dragnet-ransomware-2023-2989 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 3ec6b3de-0e97-5d75-a96c-cae17b548f58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
