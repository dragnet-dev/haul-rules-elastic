// Dragnet [Ransomware]: dragnet-ransomware-2023-1021 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 9f39c6e5-b8e7-597b-a1ff-170d3f46fdf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
