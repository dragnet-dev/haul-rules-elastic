// Dragnet [Ransomware]: dragnet-ransomware-2023-0377 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c71558c7-139b-56cc-9cd0-b60736b16a32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
