// Dragnet [Ransomware]: dragnet-ransomware-2023-4046 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 413c5ae8-5e76-5a2a-bbb4-b4e2ab026ac7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
