// Dragnet [Ransomware]: dragnet-ransomware-2023-5257 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 941e477e-376c-5976-8c61-5def736b584c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
