// Dragnet [Ransomware]: dragnet-ransomware-2023-4592 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: e952769f-424c-5fc3-98a9-4181481258bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
