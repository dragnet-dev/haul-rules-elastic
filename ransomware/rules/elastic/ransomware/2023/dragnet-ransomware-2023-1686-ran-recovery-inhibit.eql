// Dragnet [Ransomware]: dragnet-ransomware-2023-1686 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: adb3579d-0a34-56c6-b245-159f6447472c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
