// Dragnet [Ransomware]: dragnet-ransomware-2023-3912 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: db33d983-0eed-59b2-8429-80538f3fd321

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
