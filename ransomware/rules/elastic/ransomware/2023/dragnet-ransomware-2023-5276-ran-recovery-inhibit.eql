// Dragnet [Ransomware]: dragnet-ransomware-2023-5276 — Recovery Inhibition (underground)
// Status: experimental | Level: high | ID: 53aba14f-adbc-5bec-a583-33b7240f1543

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
