// Dragnet [Ransomware]: dragnet-ransomware-2023-5307 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 3888ce92-c8d1-5c1f-bb9a-dbd96add6ddc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
