// Dragnet [Ransomware]: dragnet-ransomware-2023-3839 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: c548fa51-e2d9-5fd7-a6eb-ccfc28335bea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
