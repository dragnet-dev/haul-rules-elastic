// Dragnet [Ransomware]: dragnet-ransomware-2023-4817 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 8061443c-3f49-5966-8012-53e5d7d3b9bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
