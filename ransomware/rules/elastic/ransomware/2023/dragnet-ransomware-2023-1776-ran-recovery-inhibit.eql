// Dragnet [Ransomware]: dragnet-ransomware-2023-1776 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 1f33b24a-20fb-5434-80e9-618ab662b3af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
