// Dragnet [Ransomware]: dragnet-ransomware-2023-2895 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: de5f2d14-ff64-53a7-bdb8-122cddce7688

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
