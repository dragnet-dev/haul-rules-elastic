// Dragnet [Ransomware]: dragnet-ransomware-2023-0472 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 088d6741-5921-5e7a-a98e-735edd8f8a9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
