// Dragnet [Ransomware]: dragnet-ransomware-2023-4208 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 86f222ea-64f7-5001-8875-30db26cc7641

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
