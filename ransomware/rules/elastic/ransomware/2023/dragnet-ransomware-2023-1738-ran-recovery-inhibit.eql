// Dragnet [Ransomware]: dragnet-ransomware-2023-1738 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: 2836e7f9-a13c-54de-911f-f61120d507c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
