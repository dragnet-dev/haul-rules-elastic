// Dragnet [Ransomware]: dragnet-ransomware-2023-4760 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7ea2e588-679f-56e5-acab-0180956a4d34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
