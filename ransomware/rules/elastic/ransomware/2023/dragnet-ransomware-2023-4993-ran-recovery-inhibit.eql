// Dragnet [Ransomware]: dragnet-ransomware-2023-4993 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: e91c9608-3033-57c7-a35c-6780543119f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
