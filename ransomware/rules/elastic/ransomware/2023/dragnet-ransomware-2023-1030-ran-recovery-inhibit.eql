// Dragnet [Ransomware]: dragnet-ransomware-2023-1030 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 391e37ae-7658-58be-9569-7a81a61ed753

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
