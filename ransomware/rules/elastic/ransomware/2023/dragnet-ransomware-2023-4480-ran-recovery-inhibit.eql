// Dragnet [Ransomware]: dragnet-ransomware-2023-4480 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b0ea8c33-c7ea-55c3-b68e-c7ec37f3fb24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
