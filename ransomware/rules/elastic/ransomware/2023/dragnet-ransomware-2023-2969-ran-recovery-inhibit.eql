// Dragnet [Ransomware]: dragnet-ransomware-2023-2969 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d3e4e886-d85c-54a0-aa76-945124e43761

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
