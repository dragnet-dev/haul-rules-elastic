// Dragnet [Ransomware]: dragnet-ransomware-2023-1580 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3937e32e-e3db-56d0-a7aa-40a4281acbf1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
