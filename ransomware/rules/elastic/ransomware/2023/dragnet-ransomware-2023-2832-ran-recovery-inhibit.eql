// Dragnet [Ransomware]: dragnet-ransomware-2023-2832 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: abee4aff-1534-5710-a445-a762d72c77e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
