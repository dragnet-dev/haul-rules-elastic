// Dragnet [Ransomware]: dragnet-ransomware-2023-0597 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 312576e9-ee22-54ae-ad16-264529ca93bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
