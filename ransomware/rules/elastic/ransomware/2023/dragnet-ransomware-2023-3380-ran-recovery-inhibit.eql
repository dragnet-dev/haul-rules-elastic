// Dragnet [Ransomware]: dragnet-ransomware-2023-3380 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: cd764736-bf8e-5c0b-9252-2c43ce378b67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
