// Dragnet [Ransomware]: dragnet-ransomware-2023-0760 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 1ae1d8f2-ca59-5536-8a02-4f54cde8dab2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
