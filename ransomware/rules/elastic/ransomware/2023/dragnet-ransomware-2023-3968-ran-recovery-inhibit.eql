// Dragnet [Ransomware]: dragnet-ransomware-2023-3968 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 7fcd45b3-6a83-53a7-bd41-f2bc20a8a631

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
