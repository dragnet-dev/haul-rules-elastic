// Dragnet [Ransomware]: dragnet-ransomware-2023-3556 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 86b2d499-4f96-5092-bc6f-0256adaae24c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
