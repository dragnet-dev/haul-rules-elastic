// Dragnet [Ransomware]: dragnet-ransomware-2023-4885 — Recovery Inhibition (cyclops)
// Status: deprecated | Level: high | ID: 424a2b59-0493-5225-a16d-dc175ee93851

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
