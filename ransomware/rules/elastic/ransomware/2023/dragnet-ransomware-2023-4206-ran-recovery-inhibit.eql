// Dragnet [Ransomware]: dragnet-ransomware-2023-4206 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d0765b6f-e3fb-5e26-bcf0-af2eeebb5534

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
