// Dragnet [Ransomware]: dragnet-ransomware-2023-0534 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3337b461-697c-5371-bdd7-cab5f67bf9e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
