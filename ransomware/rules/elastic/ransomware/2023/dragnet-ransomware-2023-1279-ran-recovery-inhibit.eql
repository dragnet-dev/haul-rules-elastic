// Dragnet [Ransomware]: dragnet-ransomware-2023-1279 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f93af7dc-553e-5384-8e1e-ae76d6ccd82f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
