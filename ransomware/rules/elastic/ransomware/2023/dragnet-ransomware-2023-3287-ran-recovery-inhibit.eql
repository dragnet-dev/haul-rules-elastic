// Dragnet [Ransomware]: dragnet-ransomware-2023-3287 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 703fcf94-822b-5c28-9600-a6b22bc6b899

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
