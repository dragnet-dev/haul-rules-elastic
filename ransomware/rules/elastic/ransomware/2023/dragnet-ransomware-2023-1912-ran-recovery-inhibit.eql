// Dragnet [Ransomware]: dragnet-ransomware-2023-1912 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: c159b383-517c-5178-b305-afda4cc41d10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
