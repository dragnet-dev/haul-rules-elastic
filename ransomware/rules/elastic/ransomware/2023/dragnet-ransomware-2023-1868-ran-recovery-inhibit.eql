// Dragnet [Ransomware]: dragnet-ransomware-2023-1868 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 71294aea-5407-5956-b536-fcd3997cb0b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
