// Dragnet [Ransomware]: dragnet-ransomware-2023-3760 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 7191e9c8-fb8d-5d6c-949b-307e9412114c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
