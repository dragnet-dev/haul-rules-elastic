// Dragnet [Ransomware]: dragnet-ransomware-2023-3078 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a7b0c298-c932-566c-936a-c67c0680c182

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
