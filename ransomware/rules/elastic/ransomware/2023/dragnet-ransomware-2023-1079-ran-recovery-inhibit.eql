// Dragnet [Ransomware]: dragnet-ransomware-2023-1079 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8d807a79-1224-5109-bd1b-20a036bbd93b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
