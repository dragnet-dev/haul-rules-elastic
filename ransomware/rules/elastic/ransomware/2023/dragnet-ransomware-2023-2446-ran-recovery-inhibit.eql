// Dragnet [Ransomware]: dragnet-ransomware-2023-2446 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 083173b1-45ab-5cff-8425-34096c8f1f4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
