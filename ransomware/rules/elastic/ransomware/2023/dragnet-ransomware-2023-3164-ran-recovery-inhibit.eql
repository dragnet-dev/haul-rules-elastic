// Dragnet [Ransomware]: dragnet-ransomware-2023-3164 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3b3944ff-e702-5b86-9c27-2e07fe998bba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
