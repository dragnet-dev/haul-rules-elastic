// Dragnet [Ransomware]: dragnet-ransomware-2023-4515 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5250c479-5f82-54e0-bb4f-72cd4bbe8557

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
