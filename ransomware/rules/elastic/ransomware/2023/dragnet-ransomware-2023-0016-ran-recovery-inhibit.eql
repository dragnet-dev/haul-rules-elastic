// Dragnet [Ransomware]: dragnet-ransomware-2023-0016 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 67490613-4b45-52ae-827a-22b110594652

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
