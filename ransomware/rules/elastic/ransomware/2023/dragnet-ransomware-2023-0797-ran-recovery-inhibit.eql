// Dragnet [Ransomware]: dragnet-ransomware-2023-0797 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 839060d2-068a-520a-919a-749a873dd1aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
