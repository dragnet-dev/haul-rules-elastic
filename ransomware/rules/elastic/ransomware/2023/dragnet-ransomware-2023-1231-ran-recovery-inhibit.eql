// Dragnet [Ransomware]: dragnet-ransomware-2023-1231 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 6be3a776-ee3f-539b-8b27-544b7c07b3ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
