// Dragnet [Ransomware]: dragnet-ransomware-2023-3095 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 88f198a6-b772-5bf1-ae9a-388515b9fa1f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
