// Dragnet [Ransomware]: dragnet-ransomware-2023-2879 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 479813bd-e51e-508c-91a1-854572f61bf8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
