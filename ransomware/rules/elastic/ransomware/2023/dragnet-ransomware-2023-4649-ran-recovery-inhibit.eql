// Dragnet [Ransomware]: dragnet-ransomware-2023-4649 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a470803e-c82b-5647-9371-791218df5432

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
