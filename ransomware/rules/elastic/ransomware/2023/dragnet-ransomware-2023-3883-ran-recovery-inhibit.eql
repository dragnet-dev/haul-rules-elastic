// Dragnet [Ransomware]: dragnet-ransomware-2023-3883 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 67d5e126-beb1-5d85-8e42-123f3b304300

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
