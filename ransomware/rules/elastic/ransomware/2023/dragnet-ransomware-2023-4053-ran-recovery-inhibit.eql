// Dragnet [Ransomware]: dragnet-ransomware-2023-4053 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: bf55f6a3-a42e-5e9f-bf17-6a4f0065f488

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
