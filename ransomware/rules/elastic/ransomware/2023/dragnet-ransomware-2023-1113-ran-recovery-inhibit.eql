// Dragnet [Ransomware]: dragnet-ransomware-2023-1113 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 83888d96-4cf7-579b-80c2-fc1068ccdc25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
