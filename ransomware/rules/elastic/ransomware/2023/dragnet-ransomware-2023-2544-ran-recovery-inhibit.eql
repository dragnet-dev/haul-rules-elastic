// Dragnet [Ransomware]: dragnet-ransomware-2023-2544 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: ea92ada1-cad1-5676-9616-ac66b8dc235e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
