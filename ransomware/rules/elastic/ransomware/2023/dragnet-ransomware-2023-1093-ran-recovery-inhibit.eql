// Dragnet [Ransomware]: dragnet-ransomware-2023-1093 — Recovery Inhibition (mallox)
// Status: experimental | Level: high | ID: 83fea200-4703-5d55-8aeb-b33abd3c63b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
