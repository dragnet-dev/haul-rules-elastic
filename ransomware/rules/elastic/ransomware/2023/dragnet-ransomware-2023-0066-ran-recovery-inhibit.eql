// Dragnet [Ransomware]: dragnet-ransomware-2023-0066 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 3d8641a4-e73f-5d3d-978f-c665ed3f405f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
