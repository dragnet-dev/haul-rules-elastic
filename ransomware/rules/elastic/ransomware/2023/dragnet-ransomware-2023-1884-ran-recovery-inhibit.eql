// Dragnet [Ransomware]: dragnet-ransomware-2023-1884 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6d631bc0-ba48-5cac-b373-97587aeb663a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
