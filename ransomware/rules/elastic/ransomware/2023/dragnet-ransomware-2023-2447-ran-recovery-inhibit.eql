// Dragnet [Ransomware]: dragnet-ransomware-2023-2447 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: f7eb87e8-f586-5981-8856-d1ac5ade90e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
