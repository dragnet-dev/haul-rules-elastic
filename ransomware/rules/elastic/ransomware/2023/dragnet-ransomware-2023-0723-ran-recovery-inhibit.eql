// Dragnet [Ransomware]: dragnet-ransomware-2023-0723 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 0fe1d801-6ee5-5e88-a303-d856c58f55db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
