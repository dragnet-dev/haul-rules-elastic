// Dragnet [Ransomware]: dragnet-ransomware-2023-3419 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: 24c68529-6068-516f-934d-6a1dfb9c7166

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
