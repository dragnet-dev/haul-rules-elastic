// Dragnet [Ransomware]: dragnet-ransomware-2023-4628 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6323908e-b532-5a46-902b-d41b04162a82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
