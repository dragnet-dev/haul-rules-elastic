// Dragnet [Ransomware]: dragnet-ransomware-2023-3469 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 8f22fde5-fb8d-5ca8-b2c4-8c75a5190a83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
