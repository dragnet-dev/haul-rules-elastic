// Dragnet [Ransomware]: dragnet-ransomware-2023-4079 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 727f12ff-027b-5b55-986a-2728b853199d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
