// Dragnet [Ransomware]: dragnet-ransomware-2023-4767 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2c75eef9-d491-5947-9996-94bdfd86efba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
