// Dragnet [Ransomware]: dragnet-ransomware-2023-4690 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: c0ec4917-4c98-50ba-87fa-f69a3142bd63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
