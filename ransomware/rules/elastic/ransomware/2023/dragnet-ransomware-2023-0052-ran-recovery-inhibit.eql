// Dragnet [Ransomware]: dragnet-ransomware-2023-0052 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3c73f794-8412-5e40-9682-5f62db8eba72

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
