// Dragnet [Ransomware]: dragnet-ransomware-2023-1708 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 69e05466-3e0a-5e29-9f05-c80550a2049a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
