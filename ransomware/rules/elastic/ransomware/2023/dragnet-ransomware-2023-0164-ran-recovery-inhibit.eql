// Dragnet [Ransomware]: dragnet-ransomware-2023-0164 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: d1f24e98-b807-5cb1-b599-744c836682c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
