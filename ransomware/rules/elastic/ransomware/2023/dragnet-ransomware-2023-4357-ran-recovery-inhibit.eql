// Dragnet [Ransomware]: dragnet-ransomware-2023-4357 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: be93ed00-0963-5670-b461-62528057f816

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
