// Dragnet [Ransomware]: dragnet-ransomware-2023-1227 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 386b182b-a7e9-54fe-a068-d35d18e6f766

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
