// Dragnet [Ransomware]: dragnet-ransomware-2023-1871 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: b6a5960d-f4c2-511a-b1a8-f12e8784a944

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
