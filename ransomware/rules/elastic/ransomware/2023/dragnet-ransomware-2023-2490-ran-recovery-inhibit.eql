// Dragnet [Ransomware]: dragnet-ransomware-2023-2490 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0e64771c-da6b-5f0c-9b11-a834880e2ff4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
