// Dragnet [Ransomware]: dragnet-ransomware-2023-3027 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 9eb6ce92-1500-5ded-b7af-dee6d4006b3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
