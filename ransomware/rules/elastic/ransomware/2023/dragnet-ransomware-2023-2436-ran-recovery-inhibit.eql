// Dragnet [Ransomware]: dragnet-ransomware-2023-2436 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 36157ae9-1ad1-59ee-b3f7-4b7212e83a1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
