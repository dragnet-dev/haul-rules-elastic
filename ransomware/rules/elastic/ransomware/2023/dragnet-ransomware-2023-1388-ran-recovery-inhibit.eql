// Dragnet [Ransomware]: dragnet-ransomware-2023-1388 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: dd3de4a2-c78b-5c25-b816-bfd598082e95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
