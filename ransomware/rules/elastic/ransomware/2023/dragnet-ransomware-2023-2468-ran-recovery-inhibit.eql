// Dragnet [Ransomware]: dragnet-ransomware-2023-2468 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2a319094-3852-5aa6-abed-dffd52f8deb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
