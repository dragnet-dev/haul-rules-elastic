// Dragnet [Ransomware]: dragnet-ransomware-2023-4185 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 25362c69-fa9d-52d2-b75f-b75e590907bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
