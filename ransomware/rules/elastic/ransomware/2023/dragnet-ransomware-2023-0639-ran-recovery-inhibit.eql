// Dragnet [Ransomware]: dragnet-ransomware-2023-0639 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: 3e7393ac-4775-5354-8e71-23b0b4003742

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
