// Dragnet [Ransomware]: dragnet-ransomware-2023-5322 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d844b501-79bb-59ab-8881-a4f26b6d2270

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
