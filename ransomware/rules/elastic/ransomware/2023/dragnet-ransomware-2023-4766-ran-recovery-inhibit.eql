// Dragnet [Ransomware]: dragnet-ransomware-2023-4766 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a7105bf6-9359-51b7-880d-b9dd8c810b57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
