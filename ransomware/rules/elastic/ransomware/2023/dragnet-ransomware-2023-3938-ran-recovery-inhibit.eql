// Dragnet [Ransomware]: dragnet-ransomware-2023-3938 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 089c5bda-2e62-5140-8e8d-441fc526aaf5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
