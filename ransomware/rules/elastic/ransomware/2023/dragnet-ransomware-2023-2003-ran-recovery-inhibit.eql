// Dragnet [Ransomware]: dragnet-ransomware-2023-2003 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 7656aa2f-878d-5227-a5de-af60050d29dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
