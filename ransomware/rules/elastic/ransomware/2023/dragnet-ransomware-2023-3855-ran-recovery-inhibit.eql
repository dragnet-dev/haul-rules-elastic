// Dragnet [Ransomware]: dragnet-ransomware-2023-3855 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 6e4ef500-e248-5869-9dc5-ec559be904a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
