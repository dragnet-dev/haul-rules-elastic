// Dragnet [Ransomware]: dragnet-ransomware-2023-3188 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 841e1285-b676-5de8-9da0-f7f940d11fc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
