// Dragnet [Ransomware]: dragnet-ransomware-2023-3894 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: f997b1e7-1889-5054-8704-da84d0457280

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
