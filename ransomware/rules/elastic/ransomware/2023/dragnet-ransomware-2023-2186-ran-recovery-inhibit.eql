// Dragnet [Ransomware]: dragnet-ransomware-2023-2186 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 09c7b185-cdce-5a2d-9f79-960075ebb10b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
