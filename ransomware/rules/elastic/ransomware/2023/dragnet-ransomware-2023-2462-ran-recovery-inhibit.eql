// Dragnet [Ransomware]: dragnet-ransomware-2023-2462 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: cd925181-e7cf-5386-8d14-028581aeec2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
