// Dragnet [Ransomware]: dragnet-ransomware-2023-5266 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 375b0edb-d26a-5db6-9bc5-fb773cdf2b7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
