// Dragnet [Ransomware]: dragnet-ransomware-2023-3339 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: df8a26d3-73fb-5e3c-8e2e-fbc6aabcf5f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
