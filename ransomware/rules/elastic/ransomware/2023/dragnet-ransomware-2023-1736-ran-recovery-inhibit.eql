// Dragnet [Ransomware]: dragnet-ransomware-2023-1736 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: b8d19318-47f6-533a-a02b-ccb15eac1fc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
