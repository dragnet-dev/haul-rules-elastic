// Dragnet [Ransomware]: dragnet-ransomware-2023-4639 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: a7e8740d-0962-56ba-8c8b-ba18214a00da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
