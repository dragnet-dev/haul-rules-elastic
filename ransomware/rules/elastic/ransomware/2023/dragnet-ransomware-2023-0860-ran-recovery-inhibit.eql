// Dragnet [Ransomware]: dragnet-ransomware-2023-0860 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3207f359-0206-539c-8c8a-fbbf74fc3aef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
