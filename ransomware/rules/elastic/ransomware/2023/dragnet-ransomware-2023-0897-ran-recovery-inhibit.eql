// Dragnet [Ransomware]: dragnet-ransomware-2023-0897 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d0a5af60-9136-52c7-a5f2-89ac0bc6e5e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
