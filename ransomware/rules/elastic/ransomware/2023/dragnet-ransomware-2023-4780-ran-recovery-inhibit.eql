// Dragnet [Ransomware]: dragnet-ransomware-2023-4780 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6babcd99-a93f-5530-a29a-90c3a8e2b7f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
