// Dragnet [Ransomware]: dragnet-ransomware-2023-0474 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: d05f80f8-8fde-5042-a1d0-3347e413a32c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
