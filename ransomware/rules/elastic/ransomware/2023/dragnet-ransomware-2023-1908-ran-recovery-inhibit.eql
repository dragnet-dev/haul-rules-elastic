// Dragnet [Ransomware]: dragnet-ransomware-2023-1908 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 2be2405c-d832-59e4-8d27-0afa874898fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
