// Dragnet [Ransomware]: dragnet-ransomware-2023-3764 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c9e1100f-c320-58bd-8002-9aa291576648

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
