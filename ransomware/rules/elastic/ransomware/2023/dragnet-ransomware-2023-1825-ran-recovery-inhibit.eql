// Dragnet [Ransomware]: dragnet-ransomware-2023-1825 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 4d958441-7eec-508b-95bb-ca52d13e4a15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
