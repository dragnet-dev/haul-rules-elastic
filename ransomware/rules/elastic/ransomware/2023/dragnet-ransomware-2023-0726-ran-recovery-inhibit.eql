// Dragnet [Ransomware]: dragnet-ransomware-2023-0726 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: a9bd9dd3-fdef-5ea9-8cde-2bcb2da5e926

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
