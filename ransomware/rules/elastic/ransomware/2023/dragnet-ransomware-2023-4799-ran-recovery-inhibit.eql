// Dragnet [Ransomware]: dragnet-ransomware-2023-4799 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7c58a880-05cb-5676-a597-6dc735f325c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
