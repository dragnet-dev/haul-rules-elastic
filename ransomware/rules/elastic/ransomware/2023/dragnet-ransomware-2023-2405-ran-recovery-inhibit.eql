// Dragnet [Ransomware]: dragnet-ransomware-2023-2405 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: 9d27b097-2650-5811-b6cd-d7afa28fd7b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
