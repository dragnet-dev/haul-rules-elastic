// Dragnet [Ransomware]: dragnet-ransomware-2023-4828 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: fb646209-96ed-5b23-a89a-87775a4bf822

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
