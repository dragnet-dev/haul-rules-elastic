// Dragnet [Ransomware]: dragnet-ransomware-2023-2523 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7d8780f8-371b-5c8c-85db-88c07cb41921

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
