// Dragnet [Ransomware]: dragnet-ransomware-2023-1507 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: bc31fdbc-9d12-599f-8e5b-b21c03c934e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
