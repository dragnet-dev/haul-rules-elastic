// Dragnet [Ransomware]: dragnet-ransomware-2023-5018 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 9b916755-4ecb-59e5-a502-9de295ad2e82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
