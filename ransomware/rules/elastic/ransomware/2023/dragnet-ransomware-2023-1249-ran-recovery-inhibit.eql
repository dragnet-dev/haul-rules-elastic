// Dragnet [Ransomware]: dragnet-ransomware-2023-1249 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 9159740a-b853-55d4-921d-f4890005423a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
