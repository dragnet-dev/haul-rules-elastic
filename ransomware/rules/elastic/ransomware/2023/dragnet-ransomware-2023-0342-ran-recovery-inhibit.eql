// Dragnet [Ransomware]: dragnet-ransomware-2023-0342 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e28e080f-eb21-50dd-bcd9-9d63441613a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
