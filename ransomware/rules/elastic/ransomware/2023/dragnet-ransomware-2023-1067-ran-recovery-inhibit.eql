// Dragnet [Ransomware]: dragnet-ransomware-2023-1067 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: c2c9eea4-56f1-5400-b151-069048edf039

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
