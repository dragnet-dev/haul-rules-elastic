// Dragnet [Ransomware]: dragnet-ransomware-2023-0593 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3a2c791b-ce93-568f-95f0-1273612e4503

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
