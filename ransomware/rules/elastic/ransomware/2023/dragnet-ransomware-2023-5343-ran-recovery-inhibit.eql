// Dragnet [Ransomware]: dragnet-ransomware-2023-5343 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9f7d9042-c7fb-5662-8413-ea27bad9fd09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
