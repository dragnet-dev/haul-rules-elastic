// Dragnet [Ransomware]: dragnet-ransomware-2023-1155 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1cd431b6-f58e-594e-bb3a-2d9390217e83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
