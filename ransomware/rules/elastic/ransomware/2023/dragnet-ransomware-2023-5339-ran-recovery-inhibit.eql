// Dragnet [Ransomware]: dragnet-ransomware-2023-5339 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: c780b62f-c50f-5c60-af88-00355e7aea00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
