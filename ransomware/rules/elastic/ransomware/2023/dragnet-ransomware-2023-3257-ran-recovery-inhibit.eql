// Dragnet [Ransomware]: dragnet-ransomware-2023-3257 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d074795c-a2d8-5a11-baa6-9d55d0872d3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
