// Dragnet [Ransomware]: dragnet-ransomware-2023-4931 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 568f9b0d-8fbb-5052-9f44-627e27412ea7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
