// Dragnet [Ransomware]: dragnet-ransomware-2023-2647 — Recovery Inhibition (darkpower)
// Status: experimental | Level: high | ID: 16c42a7e-f9a5-575a-851e-9fd049c86578

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
