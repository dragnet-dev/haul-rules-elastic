// Dragnet [Ransomware]: dragnet-ransomware-2023-2289 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 28009dcd-8889-54b9-b12d-432e30d1fcc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
