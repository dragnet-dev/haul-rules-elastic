// Dragnet [Ransomware]: dragnet-ransomware-2023-3610 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 8468e005-04ee-5915-92e4-4892cd5e3b6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
