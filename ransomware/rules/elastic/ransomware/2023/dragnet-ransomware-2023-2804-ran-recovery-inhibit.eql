// Dragnet [Ransomware]: dragnet-ransomware-2023-2804 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 0c8feb57-d295-5c5d-b4d7-5eb6814a4d0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
