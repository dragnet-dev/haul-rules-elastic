// Dragnet [Ransomware]: dragnet-ransomware-2023-0047 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b6d3cb47-9eed-527e-aff8-96525ac944e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
