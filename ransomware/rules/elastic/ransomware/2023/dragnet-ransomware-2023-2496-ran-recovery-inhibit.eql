// Dragnet [Ransomware]: dragnet-ransomware-2023-2496 — Recovery Inhibition (werewolves)
// Status: experimental | Level: high | ID: 2d7b2e3b-0496-553f-b605-5a03865da2f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
