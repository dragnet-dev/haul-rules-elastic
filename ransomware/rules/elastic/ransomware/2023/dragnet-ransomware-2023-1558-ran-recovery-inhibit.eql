// Dragnet [Ransomware]: dragnet-ransomware-2023-1558 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3d611709-4228-5895-bb85-b69cf7d42c94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
