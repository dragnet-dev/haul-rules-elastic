// Dragnet [Ransomware]: dragnet-ransomware-2023-0999 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: b12ac4fe-340e-5db7-b898-d35dcbccd55a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
