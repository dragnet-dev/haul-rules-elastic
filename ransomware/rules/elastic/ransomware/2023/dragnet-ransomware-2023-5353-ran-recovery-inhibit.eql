// Dragnet [Ransomware]: dragnet-ransomware-2023-5353 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: 29ab0c6e-c866-5aab-ba9e-f35c86409870

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
