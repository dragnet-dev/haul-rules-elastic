// Dragnet [Ransomware]: dragnet-ransomware-2023-1994 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f1ec9a82-a647-5f31-afd6-83ff8c448d78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
