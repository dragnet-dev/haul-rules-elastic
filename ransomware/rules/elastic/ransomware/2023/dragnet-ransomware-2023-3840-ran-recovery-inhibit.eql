// Dragnet [Ransomware]: dragnet-ransomware-2023-3840 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: cb0b1488-c772-5bcc-bcfb-4b5f7d224679

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
