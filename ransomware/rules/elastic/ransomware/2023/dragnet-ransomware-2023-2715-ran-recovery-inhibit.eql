// Dragnet [Ransomware]: dragnet-ransomware-2023-2715 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 4431e3b4-2ffb-5364-99ec-038912e722b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
