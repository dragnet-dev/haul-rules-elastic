// Dragnet [Ransomware]: dragnet-ransomware-2023-1524 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c3681dfc-18d6-5c9c-8d60-4faaf1eec9d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
