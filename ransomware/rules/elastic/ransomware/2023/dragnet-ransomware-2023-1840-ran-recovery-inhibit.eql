// Dragnet [Ransomware]: dragnet-ransomware-2023-1840 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 80e8552e-0b7c-5abf-9f0e-0482d1f8581b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
