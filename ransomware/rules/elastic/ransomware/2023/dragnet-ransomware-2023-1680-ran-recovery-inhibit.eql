// Dragnet [Ransomware]: dragnet-ransomware-2023-1680 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 48fd231c-be54-52ff-92da-ab99d7fc5195

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
