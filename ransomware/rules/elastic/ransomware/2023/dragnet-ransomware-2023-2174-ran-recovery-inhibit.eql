// Dragnet [Ransomware]: dragnet-ransomware-2023-2174 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3e2e01f3-be71-5f8f-a932-71db1eab2c6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
