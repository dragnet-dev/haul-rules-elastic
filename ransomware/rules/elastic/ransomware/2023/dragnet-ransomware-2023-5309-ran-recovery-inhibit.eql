// Dragnet [Ransomware]: dragnet-ransomware-2023-5309 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 98d3c16a-b1d1-504c-b938-b229c26e29df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
