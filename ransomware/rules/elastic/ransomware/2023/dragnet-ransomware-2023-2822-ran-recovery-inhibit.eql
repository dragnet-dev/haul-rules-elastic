// Dragnet [Ransomware]: dragnet-ransomware-2023-2822 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 4c767797-df83-58f6-a0d5-3dbe6ace0242

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
