// Dragnet [Ransomware]: dragnet-ransomware-2023-2182 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: dab466eb-ab6c-5b19-a514-330ac7bcbd87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
