// Dragnet [Ransomware]: dragnet-ransomware-2023-5367 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 9740a7e4-f72c-58cf-a566-23119cb88555

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
