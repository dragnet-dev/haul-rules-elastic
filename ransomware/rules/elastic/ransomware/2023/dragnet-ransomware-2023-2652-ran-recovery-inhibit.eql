// Dragnet [Ransomware]: dragnet-ransomware-2023-2652 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: eafaac92-f5f5-55fb-9ed2-a11d9e99f850

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
