// Dragnet [Ransomware]: dragnet-ransomware-2023-1673 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: a1721607-eefc-54ac-8242-4abbd6c26fe1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
