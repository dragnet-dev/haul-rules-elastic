// Dragnet [Ransomware]: dragnet-ransomware-2023-1189 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 37cf3768-9e25-5904-882f-f717b8a058c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
