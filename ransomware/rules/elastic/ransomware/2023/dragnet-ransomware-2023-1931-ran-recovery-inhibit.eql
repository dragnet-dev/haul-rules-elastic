// Dragnet [Ransomware]: dragnet-ransomware-2023-1931 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: afd05003-43df-59ae-a0e2-c2069c7914f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
