// Dragnet [Ransomware]: dragnet-ransomware-2023-1074 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: b3ee1318-16e5-5fbb-9b5c-2099e341949e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
