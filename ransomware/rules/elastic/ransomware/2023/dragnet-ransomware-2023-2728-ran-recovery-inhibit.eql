// Dragnet [Ransomware]: dragnet-ransomware-2023-2728 — Recovery Inhibition (mallox)
// Status: experimental | Level: high | ID: 564c0612-530f-5cb0-90bf-a9787d605a61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
