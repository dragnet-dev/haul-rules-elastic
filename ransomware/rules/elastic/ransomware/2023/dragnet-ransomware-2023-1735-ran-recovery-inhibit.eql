// Dragnet [Ransomware]: dragnet-ransomware-2023-1735 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: c174bd16-e2bc-5c05-a9e9-6f725e201df5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
