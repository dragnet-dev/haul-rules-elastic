// Dragnet [Ransomware]: dragnet-ransomware-2023-1755 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 10b6547e-f361-58e0-aa1c-f32a0b126c2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
