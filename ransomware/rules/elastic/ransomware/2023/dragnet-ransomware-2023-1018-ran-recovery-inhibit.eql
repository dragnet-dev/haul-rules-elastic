// Dragnet [Ransomware]: dragnet-ransomware-2023-1018 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: bf0447e3-3a25-5047-94fd-03b268650f3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
