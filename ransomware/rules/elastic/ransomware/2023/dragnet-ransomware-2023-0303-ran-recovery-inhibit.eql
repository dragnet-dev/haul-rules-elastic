// Dragnet [Ransomware]: dragnet-ransomware-2023-0303 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 6eb9d4e3-a5a7-531a-bf65-342090683ba7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
