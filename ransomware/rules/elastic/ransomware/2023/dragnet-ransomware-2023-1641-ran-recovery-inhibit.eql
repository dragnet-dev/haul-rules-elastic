// Dragnet [Ransomware]: dragnet-ransomware-2023-1641 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: fdd00f2d-c1b7-5aed-8084-06f7f1eca1e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
