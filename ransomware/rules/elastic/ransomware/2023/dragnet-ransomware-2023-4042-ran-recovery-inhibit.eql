// Dragnet [Ransomware]: dragnet-ransomware-2023-4042 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5fe7a3ba-56fb-5c69-9738-b8254f7b461a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
