// Dragnet [Ransomware]: dragnet-ransomware-2023-3809 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 4a491b60-e898-5893-a297-8ca1d56e65fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
