// Dragnet [Ransomware]: dragnet-ransomware-2023-4420 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: dd0ebc7b-b10e-5839-a2fb-218046250530

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
