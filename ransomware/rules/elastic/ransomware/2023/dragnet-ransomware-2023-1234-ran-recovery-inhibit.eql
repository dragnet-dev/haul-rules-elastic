// Dragnet [Ransomware]: dragnet-ransomware-2023-1234 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6c063144-df64-5853-9b04-671fc376f614

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
