// Dragnet [Ransomware]: dragnet-ransomware-2023-3568 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: cf2de6e2-4612-5bce-a842-6e52238f4b67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
