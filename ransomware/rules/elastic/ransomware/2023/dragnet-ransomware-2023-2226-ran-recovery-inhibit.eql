// Dragnet [Ransomware]: dragnet-ransomware-2023-2226 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 0a1b34e1-ffb1-5ee0-9acf-7ad9ebd4e191

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
