// Dragnet [Ransomware]: dragnet-ransomware-2023-3347 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: aa9e411d-d5d3-57f9-8336-93230e3891c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
