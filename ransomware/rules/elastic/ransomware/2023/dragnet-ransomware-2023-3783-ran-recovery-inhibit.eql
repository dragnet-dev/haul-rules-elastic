// Dragnet [Ransomware]: dragnet-ransomware-2023-3783 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 560e7339-0c0f-5bdd-835a-2a41c9e53144

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
