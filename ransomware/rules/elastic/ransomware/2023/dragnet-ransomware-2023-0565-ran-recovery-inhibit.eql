// Dragnet [Ransomware]: dragnet-ransomware-2023-0565 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: a103bd39-c671-5af7-9f28-9fcbbfda5c4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
