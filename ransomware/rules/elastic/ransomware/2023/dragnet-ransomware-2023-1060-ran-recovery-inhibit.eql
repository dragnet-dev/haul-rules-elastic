// Dragnet [Ransomware]: dragnet-ransomware-2023-1060 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: 7be29a16-ad20-5233-8a9b-e9669d4d266f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
