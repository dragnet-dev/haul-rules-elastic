// Dragnet [Ransomware]: dragnet-ransomware-2023-1620 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4093742f-9e7b-56b6-9088-5d1fdb6f29bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
