// Dragnet [Ransomware]: dragnet-ransomware-2023-3069 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2250c40f-c6c8-546e-b854-849336307b8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
