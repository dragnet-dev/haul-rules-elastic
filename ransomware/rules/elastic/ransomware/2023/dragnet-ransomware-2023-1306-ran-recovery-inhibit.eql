// Dragnet [Ransomware]: dragnet-ransomware-2023-1306 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 9630e738-3b6d-505a-845e-538bb2f0a6eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
