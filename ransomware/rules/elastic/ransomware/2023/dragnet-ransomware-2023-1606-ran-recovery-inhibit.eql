// Dragnet [Ransomware]: dragnet-ransomware-2023-1606 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: 9ca674b6-62c9-5eae-9230-de4d0bbf1fb2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
