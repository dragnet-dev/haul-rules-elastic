// Dragnet [Ransomware]: dragnet-ransomware-2023-0431 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: a59582e6-8299-5eb4-b80a-bb3e9f6302ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
