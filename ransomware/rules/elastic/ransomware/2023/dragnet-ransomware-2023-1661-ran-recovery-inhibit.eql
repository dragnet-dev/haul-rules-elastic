// Dragnet [Ransomware]: dragnet-ransomware-2023-1661 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 86c2728f-4ac8-51d9-9216-689a1d5bbc4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
