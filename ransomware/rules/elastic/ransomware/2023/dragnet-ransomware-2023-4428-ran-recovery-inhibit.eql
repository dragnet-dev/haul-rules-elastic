// Dragnet [Ransomware]: dragnet-ransomware-2023-4428 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f65825af-1685-5a71-bcb7-4e89244e7fb9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
