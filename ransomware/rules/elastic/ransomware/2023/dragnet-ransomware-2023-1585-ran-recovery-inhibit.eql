// Dragnet [Ransomware]: dragnet-ransomware-2023-1585 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 51ed8ad7-680a-5208-8e36-73489e08dfd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
