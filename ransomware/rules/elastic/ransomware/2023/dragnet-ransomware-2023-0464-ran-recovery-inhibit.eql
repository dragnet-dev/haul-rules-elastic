// Dragnet [Ransomware]: dragnet-ransomware-2023-0464 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f26a02ef-374d-5571-9df1-3afdb61ee377

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
