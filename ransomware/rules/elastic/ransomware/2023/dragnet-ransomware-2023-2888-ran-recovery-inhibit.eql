// Dragnet [Ransomware]: dragnet-ransomware-2023-2888 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: bb5a1a1a-b77c-5793-90c3-8d6b7682db98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
