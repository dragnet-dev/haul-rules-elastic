// Dragnet [Ransomware]: dragnet-ransomware-2023-2197 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e4e7c72d-0272-5f49-8ef8-f3958beb17d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
