// Dragnet [Ransomware]: dragnet-ransomware-2023-0387 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f6b29a4c-e0ce-5c6f-a53d-2b0a3cce74d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
