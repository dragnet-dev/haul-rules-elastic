// Dragnet [Ransomware]: dragnet-ransomware-2023-1417 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: a10e1713-032c-56de-afca-030dd5a68a0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
