// Dragnet [Ransomware]: dragnet-ransomware-2023-0441 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: 99f8cc7f-3084-522d-8bd4-22895566a102

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
