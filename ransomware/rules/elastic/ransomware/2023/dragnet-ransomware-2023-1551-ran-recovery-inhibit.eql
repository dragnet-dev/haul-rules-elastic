// Dragnet [Ransomware]: dragnet-ransomware-2023-1551 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: aee168f8-10b1-5bac-87d3-33360bd853ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
