// Dragnet [Ransomware]: dragnet-ransomware-2023-4519 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 4227b12d-51a5-541a-9579-d7c11ced5a00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
