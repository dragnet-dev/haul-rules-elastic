// Dragnet [Ransomware]: dragnet-ransomware-2023-0491 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f308a970-1e25-59ba-bf13-abd6e6f88a91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
