// Dragnet [Ransomware]: dragnet-ransomware-2023-2683 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: fe2c4acc-bdfa-5ca8-a9dd-b5e9b2990615

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
