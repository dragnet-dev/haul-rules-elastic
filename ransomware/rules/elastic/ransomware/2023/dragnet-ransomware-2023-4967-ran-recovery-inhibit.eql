// Dragnet [Ransomware]: dragnet-ransomware-2023-4967 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 2f469c08-249d-5898-926d-b2c62d13286b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
