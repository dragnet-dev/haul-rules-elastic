// Dragnet [Ransomware]: dragnet-ransomware-2023-2758 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 5c4570de-111d-550d-ab3b-41a16bc8ce6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
