// Dragnet [Ransomware]: dragnet-ransomware-2023-3779 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 76b4c53d-0ca0-58b6-8e55-58eea321516b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
