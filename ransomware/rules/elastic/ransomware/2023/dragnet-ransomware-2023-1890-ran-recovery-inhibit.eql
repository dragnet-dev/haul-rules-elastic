// Dragnet [Ransomware]: dragnet-ransomware-2023-1890 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 65784a0d-96f6-5093-b849-6b9ac062676d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
