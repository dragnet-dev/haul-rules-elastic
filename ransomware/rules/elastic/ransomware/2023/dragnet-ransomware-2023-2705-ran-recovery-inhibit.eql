// Dragnet [Ransomware]: dragnet-ransomware-2023-2705 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: bb4c29cf-7ab5-54a3-8591-fdad3a4e0478

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
