// Dragnet [Ransomware]: dragnet-ransomware-2023-4166 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 04457fd4-a67f-591b-a83b-738cbac8f9e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
