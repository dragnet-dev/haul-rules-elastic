// Dragnet [Ransomware]: dragnet-ransomware-2023-0819 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5d7d4f2f-8caa-5931-a971-ae8faf665cc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
