// Dragnet [Ransomware]: dragnet-ransomware-2023-4176 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 29e8b0d0-f246-518c-9b34-ad76593ab554

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
