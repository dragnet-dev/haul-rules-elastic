// Dragnet [Ransomware]: dragnet-ransomware-2023-3545 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0ff1e812-67cb-56a2-828e-1f9c2bdee052

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
