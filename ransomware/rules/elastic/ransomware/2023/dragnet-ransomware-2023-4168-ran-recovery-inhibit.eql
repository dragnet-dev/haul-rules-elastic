// Dragnet [Ransomware]: dragnet-ransomware-2023-4168 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 4a2bcf31-3f07-50f7-a4fc-187e2f122d04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
