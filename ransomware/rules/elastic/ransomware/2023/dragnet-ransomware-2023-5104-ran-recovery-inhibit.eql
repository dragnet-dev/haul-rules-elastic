// Dragnet [Ransomware]: dragnet-ransomware-2023-5104 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 41e5ceec-1be3-5711-a2d2-d589fae38114

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
