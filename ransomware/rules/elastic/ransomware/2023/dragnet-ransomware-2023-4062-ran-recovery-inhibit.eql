// Dragnet [Ransomware]: dragnet-ransomware-2023-4062 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: ed19ab69-2d11-550d-ab0a-77f2137b5058

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
