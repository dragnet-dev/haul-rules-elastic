// Dragnet [Ransomware]: dragnet-ransomware-2023-4036 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 20cc1851-fd2b-5beb-929c-8cf992167851

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
