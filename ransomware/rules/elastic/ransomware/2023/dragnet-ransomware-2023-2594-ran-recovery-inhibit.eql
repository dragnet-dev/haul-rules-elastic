// Dragnet [Ransomware]: dragnet-ransomware-2023-2594 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 0da01165-ade1-524c-807d-6bcc1922bb0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
