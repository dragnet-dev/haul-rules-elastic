// Dragnet [Ransomware]: dragnet-ransomware-2023-1985 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 53193501-7efa-51b0-a99d-a5a23a4361dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
