// Dragnet [Ransomware]: dragnet-ransomware-2023-0294 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9d8977b0-7b18-5e7f-aec3-ac1071cc66cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
