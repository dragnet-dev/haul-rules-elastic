// Dragnet [Ransomware]: dragnet-ransomware-2023-0329 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 25aaae35-690a-5d50-a302-dfb98c597e57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
