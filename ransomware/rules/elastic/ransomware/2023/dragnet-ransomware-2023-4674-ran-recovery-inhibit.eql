// Dragnet [Ransomware]: dragnet-ransomware-2023-4674 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 650cc62f-59a5-548a-962f-0c086306e1f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
