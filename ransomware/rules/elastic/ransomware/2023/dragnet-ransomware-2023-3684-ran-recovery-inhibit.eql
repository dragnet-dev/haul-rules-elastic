// Dragnet [Ransomware]: dragnet-ransomware-2023-3684 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: eec8dcf1-7feb-5ad7-81c6-64560d225db7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
