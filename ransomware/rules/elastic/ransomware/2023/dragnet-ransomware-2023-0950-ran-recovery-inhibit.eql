// Dragnet [Ransomware]: dragnet-ransomware-2023-0950 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c0bd3c56-5856-50da-b1fc-be5b423228e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
