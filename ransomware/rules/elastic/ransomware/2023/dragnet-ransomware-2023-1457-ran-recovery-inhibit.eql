// Dragnet [Ransomware]: dragnet-ransomware-2023-1457 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a874eeb8-ce95-53cc-9637-6cd0989c220d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
