// Dragnet [Ransomware]: dragnet-ransomware-2023-2267 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 9216998e-496c-59d3-ad93-95c1e48d3743

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
