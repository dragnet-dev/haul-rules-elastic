// Dragnet [Ransomware]: dragnet-ransomware-2023-3682 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 082e6d7c-df6c-5a18-8281-4d5b2c479769

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
