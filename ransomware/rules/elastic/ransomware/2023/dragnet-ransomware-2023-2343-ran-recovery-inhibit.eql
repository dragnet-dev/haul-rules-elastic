// Dragnet [Ransomware]: dragnet-ransomware-2023-2343 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 624b7ae5-e808-5682-9a46-69af87973788

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
