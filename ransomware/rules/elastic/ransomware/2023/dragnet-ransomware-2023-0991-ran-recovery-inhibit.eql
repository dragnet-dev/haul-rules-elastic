// Dragnet [Ransomware]: dragnet-ransomware-2023-0991 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: a784297f-b045-571f-a193-47de38448356

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
