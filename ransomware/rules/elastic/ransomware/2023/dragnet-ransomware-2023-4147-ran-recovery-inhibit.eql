// Dragnet [Ransomware]: dragnet-ransomware-2023-4147 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: ac63a9c7-19b5-5ae8-b44f-2a55cea4bed4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
