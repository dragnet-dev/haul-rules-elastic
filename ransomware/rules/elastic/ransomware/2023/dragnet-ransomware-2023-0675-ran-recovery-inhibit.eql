// Dragnet [Ransomware]: dragnet-ransomware-2023-0675 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: ca04485f-4418-5364-9e8e-aef3bbd72edf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
