// Dragnet [Ransomware]: dragnet-ransomware-2023-3158 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: 58b42e44-2d81-5b94-91e1-55d4d88dc025

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
