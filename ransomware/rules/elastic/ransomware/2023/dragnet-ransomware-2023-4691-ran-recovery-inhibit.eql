// Dragnet [Ransomware]: dragnet-ransomware-2023-4691 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 384c9541-5727-5f5e-8380-d3d6783e45cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
