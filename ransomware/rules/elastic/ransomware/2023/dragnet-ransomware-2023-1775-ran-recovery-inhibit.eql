// Dragnet [Ransomware]: dragnet-ransomware-2023-1775 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c2fd78ef-d42d-582d-9e74-706cefee488a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
