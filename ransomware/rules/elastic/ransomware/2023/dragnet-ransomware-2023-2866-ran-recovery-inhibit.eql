// Dragnet [Ransomware]: dragnet-ransomware-2023-2866 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: b38e83fb-1960-5a9c-adef-df572011f559

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
