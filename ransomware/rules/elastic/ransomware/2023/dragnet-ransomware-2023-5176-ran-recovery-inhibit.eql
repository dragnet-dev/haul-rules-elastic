// Dragnet [Ransomware]: dragnet-ransomware-2023-5176 — Recovery Inhibition (mallox)
// Status: experimental | Level: high | ID: f3af7c84-e143-547d-8015-ebf83be31658

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
