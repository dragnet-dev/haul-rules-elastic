// Dragnet [Ransomware]: dragnet-ransomware-2023-5079 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: d6308229-9628-577f-8f08-26b06bec5330

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
