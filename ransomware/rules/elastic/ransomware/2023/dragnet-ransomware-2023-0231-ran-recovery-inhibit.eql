// Dragnet [Ransomware]: dragnet-ransomware-2023-0231 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 9d59d271-047e-539e-9156-28c813a49c59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
