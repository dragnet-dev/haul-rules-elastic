// Dragnet [Ransomware]: dragnet-ransomware-2023-1439 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c862d22e-9168-51e2-bbef-e7f0c1740345

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
