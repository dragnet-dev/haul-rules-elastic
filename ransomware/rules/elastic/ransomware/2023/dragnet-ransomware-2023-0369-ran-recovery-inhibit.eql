// Dragnet [Ransomware]: dragnet-ransomware-2023-0369 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: a3d5214a-cac9-5b43-a031-5e8a7fb92e2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
