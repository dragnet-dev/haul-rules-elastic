// Dragnet [Ransomware]: dragnet-ransomware-2023-4516 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 4304738c-26a6-5a2f-b5a1-3ff4b556b44a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
