// Dragnet [Ransomware]: dragnet-ransomware-2023-5062 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: dcecf547-2fe7-5e32-b740-d80a1f85c5df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
