// Dragnet [Ransomware]: dragnet-ransomware-2025-1832 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 611079ba-abe4-5848-b31a-e09bec8019b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
