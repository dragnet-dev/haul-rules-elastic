// Dragnet [Ransomware]: dragnet-ransomware-2025-0427 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 4f1f8ff2-5fc3-5245-b480-ad01f157d42f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
