// Dragnet [Ransomware]: dragnet-ransomware-2025-3163 — Recovery Inhibition (satanlockv2)
// Status: experimental | Level: high | ID: 8c69585c-c453-52c7-b31b-11291e7e4e08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
