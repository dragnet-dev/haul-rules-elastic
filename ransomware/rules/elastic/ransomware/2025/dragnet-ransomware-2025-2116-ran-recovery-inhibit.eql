// Dragnet [Ransomware]: dragnet-ransomware-2025-2116 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: d2d22d17-6e17-5f93-84b7-4005b8e4e233

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
