// Dragnet [Ransomware]: dragnet-ransomware-2025-3303 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 2768bcf2-b9a9-5aab-83f7-5a2518130326

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
