// Dragnet [Ransomware]: dragnet-ransomware-2025-1874 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 8195083a-1c3f-5ba7-b762-1be160a8f62f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
