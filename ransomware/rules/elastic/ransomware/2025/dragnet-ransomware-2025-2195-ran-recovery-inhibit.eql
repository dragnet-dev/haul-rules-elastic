// Dragnet [Ransomware]: dragnet-ransomware-2025-2195 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 5a4e3adb-c375-53f7-be73-50d4106cfc4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
