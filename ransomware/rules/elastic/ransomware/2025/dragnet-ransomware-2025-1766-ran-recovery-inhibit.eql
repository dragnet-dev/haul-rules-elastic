// Dragnet [Ransomware]: dragnet-ransomware-2025-1766 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: c0a4cee4-0705-572b-a9c5-2966c246f4fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
