// Dragnet [Ransomware]: dragnet-ransomware-2025-4259 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 6631e103-4064-58a2-94da-1d191bcd131b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
