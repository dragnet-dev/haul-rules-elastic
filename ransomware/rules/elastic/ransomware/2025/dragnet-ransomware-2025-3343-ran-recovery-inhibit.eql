// Dragnet [Ransomware]: dragnet-ransomware-2025-3343 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: b1227b46-f698-545b-b7f6-f6128ea3c873

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
