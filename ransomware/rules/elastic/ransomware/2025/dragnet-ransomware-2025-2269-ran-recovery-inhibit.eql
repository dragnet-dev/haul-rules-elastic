// Dragnet [Ransomware]: dragnet-ransomware-2025-2269 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 8e184e77-f502-52e0-a986-911eb973c482

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
