// Dragnet [Ransomware]: dragnet-ransomware-2025-0474 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8e7277b0-2060-5bc2-8315-a6e8c4700fc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
