// Dragnet [Ransomware]: dragnet-ransomware-2025-1293 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 2e206643-65d5-5573-b695-63ed7bff796c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
