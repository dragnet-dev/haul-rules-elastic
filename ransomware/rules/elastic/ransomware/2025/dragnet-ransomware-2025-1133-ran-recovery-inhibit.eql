// Dragnet [Ransomware]: dragnet-ransomware-2025-1133 — Recovery Inhibition (obscura)
// Status: experimental | Level: high | ID: 4f489e31-7838-5fdd-8cce-432b0e0c6653

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
