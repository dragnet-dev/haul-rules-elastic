// Dragnet [Ransomware]: dragnet-ransomware-2025-7425 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d0708145-e19d-501e-bb51-528013ac3b4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
