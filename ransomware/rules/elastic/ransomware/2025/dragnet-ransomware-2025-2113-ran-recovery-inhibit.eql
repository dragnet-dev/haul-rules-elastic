// Dragnet [Ransomware]: dragnet-ransomware-2025-2113 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 3e23c118-f654-56f1-ac64-9fc4886e0614

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
