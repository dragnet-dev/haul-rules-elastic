// Dragnet [Ransomware]: dragnet-ransomware-2025-6649 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1be0699a-2669-560d-bacb-70df34565177

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
