// Dragnet [Ransomware]: dragnet-ransomware-2025-2372 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: 990221e4-669a-5bb2-959e-ccce4deed29b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
