// Dragnet [Ransomware]: dragnet-ransomware-2025-4888 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: a1a09464-f1ac-5f79-8e4d-0cc55b4865f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
