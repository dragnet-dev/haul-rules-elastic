// Dragnet [Ransomware]: dragnet-ransomware-2025-2096 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 78106381-4fdd-5875-86ad-8229213675dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
