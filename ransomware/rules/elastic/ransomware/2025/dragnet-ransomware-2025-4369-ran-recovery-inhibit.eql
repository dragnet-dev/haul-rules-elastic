// Dragnet [Ransomware]: dragnet-ransomware-2025-4369 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ecba430e-1beb-5dca-8d24-5301aa535243

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
