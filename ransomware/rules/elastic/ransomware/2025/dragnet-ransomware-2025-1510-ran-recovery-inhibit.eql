// Dragnet [Ransomware]: dragnet-ransomware-2025-1510 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 572ddca8-4185-5bf0-9739-6a9300ed2724

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
