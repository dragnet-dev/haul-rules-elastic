// Dragnet [Ransomware]: dragnet-ransomware-2025-0786 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 82b47345-4bc2-5532-9b3b-412cdb998b84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
