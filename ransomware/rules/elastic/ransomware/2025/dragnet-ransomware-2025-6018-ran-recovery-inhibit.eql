// Dragnet [Ransomware]: dragnet-ransomware-2025-6018 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c94b6fce-b1d8-5665-b06c-35053723fce6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
