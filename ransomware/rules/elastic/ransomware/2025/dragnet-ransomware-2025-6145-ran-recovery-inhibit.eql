// Dragnet [Ransomware]: dragnet-ransomware-2025-6145 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3c01976f-8269-57e7-b046-35e98dae83ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
