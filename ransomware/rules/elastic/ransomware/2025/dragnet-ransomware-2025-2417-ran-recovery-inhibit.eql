// Dragnet [Ransomware]: dragnet-ransomware-2025-2417 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: b88548db-bdcf-55c7-8b0f-228b30cc6557

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
