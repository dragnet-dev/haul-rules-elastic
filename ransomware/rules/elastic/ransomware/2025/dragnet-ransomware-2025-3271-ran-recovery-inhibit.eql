// Dragnet [Ransomware]: dragnet-ransomware-2025-3271 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 53609259-e5cf-5d55-88ca-ef40addc724d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
