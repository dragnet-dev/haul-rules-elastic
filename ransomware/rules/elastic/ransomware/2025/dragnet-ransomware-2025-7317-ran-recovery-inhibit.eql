// Dragnet [Ransomware]: dragnet-ransomware-2025-7317 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4859a1d5-3486-5d56-aad9-bdbfd57fdc00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
