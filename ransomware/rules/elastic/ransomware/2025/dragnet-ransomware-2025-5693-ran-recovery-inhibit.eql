// Dragnet [Ransomware]: dragnet-ransomware-2025-5693 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3e88f559-c9a7-5767-af8a-d72aa1e39445

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
