// Dragnet [Ransomware]: dragnet-ransomware-2025-4422 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 27df8fbb-77ff-5acd-a5bf-379f05c2822a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
