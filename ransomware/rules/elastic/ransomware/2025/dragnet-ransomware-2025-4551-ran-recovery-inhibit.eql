// Dragnet [Ransomware]: dragnet-ransomware-2025-4551 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 02baafa5-557c-5db3-88b6-7303758382f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
