// Dragnet [Ransomware]: dragnet-ransomware-2025-2465 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 263db9cb-6679-59e4-8cd8-9a68e764d827

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
