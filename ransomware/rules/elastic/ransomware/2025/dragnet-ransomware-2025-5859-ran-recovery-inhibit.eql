// Dragnet [Ransomware]: dragnet-ransomware-2025-5859 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8c692852-e799-52d6-b6e6-1a3a5485a77c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
