// Dragnet [Ransomware]: dragnet-ransomware-2025-1077 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 53f83011-550e-5975-be88-c6a34207da8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
