// Dragnet [Ransomware]: dragnet-ransomware-2025-4263 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8d0d50eb-cbed-55a2-9869-41efe28beae2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
