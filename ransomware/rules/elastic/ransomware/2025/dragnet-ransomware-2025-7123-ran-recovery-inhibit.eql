// Dragnet [Ransomware]: dragnet-ransomware-2025-7123 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 67492644-c83e-5565-aad8-0e04ee9a0061

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
