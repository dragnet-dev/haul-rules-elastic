// Dragnet [Ransomware]: dragnet-ransomware-2025-6355 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e3a27aa7-8bd7-585e-9e6f-1bf6ea80687d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
