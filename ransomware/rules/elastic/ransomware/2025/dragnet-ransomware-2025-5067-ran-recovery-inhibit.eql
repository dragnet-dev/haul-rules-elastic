// Dragnet [Ransomware]: dragnet-ransomware-2025-5067 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 32860ead-4942-5f79-b2fa-db5b5e05d445

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
