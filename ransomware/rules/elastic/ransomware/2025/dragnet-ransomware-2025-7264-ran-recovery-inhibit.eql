// Dragnet [Ransomware]: dragnet-ransomware-2025-7264 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 347c1776-9874-59d7-a135-050d6545d355

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
