// Dragnet [Ransomware]: dragnet-ransomware-2025-5652 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 467b52d6-0eca-5fba-9d3c-565031e0d5ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
