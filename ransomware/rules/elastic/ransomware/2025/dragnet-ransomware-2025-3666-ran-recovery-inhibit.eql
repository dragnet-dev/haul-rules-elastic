// Dragnet [Ransomware]: dragnet-ransomware-2025-3666 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 65044031-0d09-508b-8d1d-f2541209d61c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
