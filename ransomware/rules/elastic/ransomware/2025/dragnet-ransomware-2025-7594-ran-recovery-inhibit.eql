// Dragnet [Ransomware]: dragnet-ransomware-2025-7594 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 50b1e87e-bd95-5ddc-b0be-64e98384cda4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
