// Dragnet [Ransomware]: dragnet-ransomware-2025-6573 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e65863ce-011d-5f57-8080-7fab71b03fb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
