// Dragnet [Ransomware]: dragnet-ransomware-2025-5604 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: c278d961-d8b6-59ab-9d55-2fc9ba17802d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
