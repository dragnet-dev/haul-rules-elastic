// Dragnet [Ransomware]: dragnet-ransomware-2025-7783 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 4ba072e5-921c-5792-a961-399ea6ab90dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
