// Dragnet [Ransomware]: dragnet-ransomware-2025-2174 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 9f8f6374-0040-5363-a8ce-4f79e17aa93b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
