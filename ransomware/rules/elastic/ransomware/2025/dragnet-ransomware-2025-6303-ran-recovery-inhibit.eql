// Dragnet [Ransomware]: dragnet-ransomware-2025-6303 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 15dea8b5-315d-511e-a6a2-36b160c0ade3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
