// Dragnet [Ransomware]: dragnet-ransomware-2025-3854 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5e51e609-7233-5512-8e87-ca787030e8a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
