// Dragnet [Ransomware]: dragnet-ransomware-2025-7230 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 4aefff38-9089-53a9-acd4-06dbed825796

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
