// Dragnet [Ransomware]: dragnet-ransomware-2025-6120 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 0d0db610-09f4-57d5-a9be-3a27d29ebeef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
