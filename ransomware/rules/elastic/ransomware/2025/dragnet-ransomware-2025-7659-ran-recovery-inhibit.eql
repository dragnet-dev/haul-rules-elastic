// Dragnet [Ransomware]: dragnet-ransomware-2025-7659 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: cd2e6d0a-5ba3-58d1-a3c3-b12245407fe7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
