// Dragnet [Ransomware]: dragnet-ransomware-2025-4883 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 82af83bf-4d29-54ac-9dc7-b6a8b1b67259

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
