// Dragnet [Ransomware]: dragnet-ransomware-2025-3232 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 30fdfba2-f5e4-5027-85aa-7cadfac48115

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
