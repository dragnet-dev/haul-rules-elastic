// Dragnet [Ransomware]: dragnet-ransomware-2025-4613 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 7e657c74-0abe-58a8-8522-811050126926

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
