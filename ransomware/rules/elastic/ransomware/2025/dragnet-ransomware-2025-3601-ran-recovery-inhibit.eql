// Dragnet [Ransomware]: dragnet-ransomware-2025-3601 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: c7379cee-7a2f-5833-b45e-08f8494d0240

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
