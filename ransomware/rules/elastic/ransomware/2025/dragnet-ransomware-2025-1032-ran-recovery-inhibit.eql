// Dragnet [Ransomware]: dragnet-ransomware-2025-1032 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 9151893f-97ca-5dfe-b4ec-0f788e9364fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
