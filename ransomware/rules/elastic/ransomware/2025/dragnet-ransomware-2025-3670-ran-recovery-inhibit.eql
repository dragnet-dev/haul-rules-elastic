// Dragnet [Ransomware]: dragnet-ransomware-2025-3670 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 4252605f-211f-5a6d-adaf-466fb0c0fc96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
