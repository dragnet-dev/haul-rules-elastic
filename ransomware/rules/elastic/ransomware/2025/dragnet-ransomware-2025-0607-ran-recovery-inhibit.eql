// Dragnet [Ransomware]: dragnet-ransomware-2025-0607 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 4e8157a8-b81d-544d-9d3c-a7c68d005113

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
