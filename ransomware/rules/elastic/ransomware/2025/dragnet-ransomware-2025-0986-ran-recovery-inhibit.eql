// Dragnet [Ransomware]: dragnet-ransomware-2025-0986 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 4241be92-a975-5b11-967b-534cfe6bad5e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
