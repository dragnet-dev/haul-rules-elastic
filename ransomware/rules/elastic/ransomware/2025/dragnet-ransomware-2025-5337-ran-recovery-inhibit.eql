// Dragnet [Ransomware]: dragnet-ransomware-2025-5337 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a371fa52-873c-5149-897a-5f83a0e32da0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
