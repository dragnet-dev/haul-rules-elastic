// Dragnet [Ransomware]: dragnet-ransomware-2025-2576 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 62bc3edc-af09-5e96-8d6f-3ca827927c42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
