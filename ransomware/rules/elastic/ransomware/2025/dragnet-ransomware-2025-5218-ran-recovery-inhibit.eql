// Dragnet [Ransomware]: dragnet-ransomware-2025-5218 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 0715bffd-7b91-5190-9686-081891119ac8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
