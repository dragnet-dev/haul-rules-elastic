// Dragnet [Ransomware]: dragnet-ransomware-2025-3200 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 44918c17-7bf7-5ec7-8780-e67b0be8ac63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
