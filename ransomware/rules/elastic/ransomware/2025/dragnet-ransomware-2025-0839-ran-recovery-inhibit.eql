// Dragnet [Ransomware]: dragnet-ransomware-2025-0839 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 5af7af3d-362b-5ce9-8f80-9176cd30e4ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
