// Dragnet [Ransomware]: dragnet-ransomware-2025-3144 — Recovery Inhibition (blackshrantac)
// Status: test | Level: high | ID: 03166ff6-e00e-5f76-9c48-1baac8e67ec1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
