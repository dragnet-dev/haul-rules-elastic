// Dragnet [Ransomware]: dragnet-ransomware-2025-5246 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 1e59765a-5d8e-57d0-a8d3-1a1b0e54fd77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
