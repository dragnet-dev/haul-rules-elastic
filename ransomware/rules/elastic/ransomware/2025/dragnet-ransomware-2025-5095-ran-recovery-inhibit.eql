// Dragnet [Ransomware]: dragnet-ransomware-2025-5095 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3d51b2f8-aa07-5f23-9c5c-3fe2f77d4b98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
