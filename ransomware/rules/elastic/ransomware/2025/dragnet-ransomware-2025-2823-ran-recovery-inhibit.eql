// Dragnet [Ransomware]: dragnet-ransomware-2025-2823 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 832d1508-99b1-5d7e-83f3-19cee994cbf9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
