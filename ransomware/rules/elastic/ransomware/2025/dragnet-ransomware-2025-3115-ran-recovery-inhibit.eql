// Dragnet [Ransomware]: dragnet-ransomware-2025-3115 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 7fa70647-1523-5886-8314-2adc7829d0a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
