// Dragnet [Ransomware]: dragnet-ransomware-2025-1880 — Recovery Inhibition (d4rk4rmy)
// Status: experimental | Level: high | ID: e0ba9017-03ce-529c-9354-705cfb3f2c9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
