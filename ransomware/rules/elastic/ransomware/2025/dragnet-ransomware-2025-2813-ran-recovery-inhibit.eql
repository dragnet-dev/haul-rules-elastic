// Dragnet [Ransomware]: dragnet-ransomware-2025-2813 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: b66928d2-5618-5e7f-be4f-befff0b31ee7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
