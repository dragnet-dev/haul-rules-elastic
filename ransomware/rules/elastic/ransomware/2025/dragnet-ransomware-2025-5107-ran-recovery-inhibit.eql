// Dragnet [Ransomware]: dragnet-ransomware-2025-5107 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: fd70fa8f-6bf3-580a-864f-5b3d43993bd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
