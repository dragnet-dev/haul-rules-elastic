// Dragnet [Ransomware]: dragnet-ransomware-2025-4293 — Recovery Inhibition (kawa4096)
// Status: experimental | Level: high | ID: 1dbb1e54-b2ee-5020-b678-91b49e9d2707

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
