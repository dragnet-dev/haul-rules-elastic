// Dragnet [Ransomware]: dragnet-ransomware-2025-4403 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2c35b7e6-d4dd-54fe-898a-f10337baeb0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
