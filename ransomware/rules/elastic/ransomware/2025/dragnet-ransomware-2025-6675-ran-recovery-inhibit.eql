// Dragnet [Ransomware]: dragnet-ransomware-2025-6675 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 668f0fa6-12eb-5c40-80e4-9cbdc2276679

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
