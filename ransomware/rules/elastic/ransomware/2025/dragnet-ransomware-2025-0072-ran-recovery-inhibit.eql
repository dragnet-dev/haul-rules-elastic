// Dragnet [Ransomware]: dragnet-ransomware-2025-0072 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 803e3178-05ef-5614-a60f-518ec718de0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
