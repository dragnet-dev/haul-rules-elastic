// Dragnet [Ransomware]: dragnet-ransomware-2025-5020 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 32515908-b2c3-5f79-93bc-c47d8dd38409

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
