// Dragnet [Ransomware]: dragnet-ransomware-2025-4255 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: e61ebde8-bb13-544d-bd44-276afbccd61e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
