// Dragnet [Ransomware]: dragnet-ransomware-2025-0354 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 572cf858-09ae-589b-b5c5-8c3f34165941

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
