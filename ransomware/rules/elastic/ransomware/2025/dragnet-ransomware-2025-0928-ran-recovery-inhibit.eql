// Dragnet [Ransomware]: dragnet-ransomware-2025-0928 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: dd3ac3a5-4bf7-5855-850c-c79e03c3f6f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
