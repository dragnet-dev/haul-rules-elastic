// Dragnet [Ransomware]: dragnet-ransomware-2025-1664 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: a220a3d6-8f72-5606-8381-157b9fad9a3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
