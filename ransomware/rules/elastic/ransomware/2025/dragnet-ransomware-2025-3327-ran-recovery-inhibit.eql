// Dragnet [Ransomware]: dragnet-ransomware-2025-3327 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: c3e86492-06eb-52d5-a298-4b0c4350ead4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
