// Dragnet [Ransomware]: dragnet-ransomware-2025-0579 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 3c4b6ab0-8d9e-50a1-b1d8-93a3f27259b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
