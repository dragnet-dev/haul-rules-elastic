// Dragnet [Ransomware]: dragnet-ransomware-2025-3315 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 2a4ec5be-40b3-5914-982e-f27fde8887c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
