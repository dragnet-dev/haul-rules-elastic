// Dragnet [Ransomware]: dragnet-ransomware-2025-4751 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 441ac6bc-060c-5da8-8a28-9c58fb315eb3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
