// Dragnet [Ransomware]: dragnet-ransomware-2025-1318 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: fa62c475-3ef3-54a7-8175-34bda3fb46af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
