// Dragnet [Ransomware]: dragnet-ransomware-2025-4060 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 0f6ef820-98b0-5554-8dcd-4d256485095b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
