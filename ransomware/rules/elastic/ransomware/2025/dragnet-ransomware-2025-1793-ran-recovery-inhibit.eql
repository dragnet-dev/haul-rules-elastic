// Dragnet [Ransomware]: dragnet-ransomware-2025-1793 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 655d8155-197b-50cd-b67b-e4faf707167f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
