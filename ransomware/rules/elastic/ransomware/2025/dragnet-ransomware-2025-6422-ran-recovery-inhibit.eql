// Dragnet [Ransomware]: dragnet-ransomware-2025-6422 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 274d1d28-722b-55ce-bbc2-71ca982b9295

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
