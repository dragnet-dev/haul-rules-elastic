// Dragnet [Ransomware]: dragnet-ransomware-2025-2682 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 4ce15d7c-45e0-5f7b-b371-75db6c54d28f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
