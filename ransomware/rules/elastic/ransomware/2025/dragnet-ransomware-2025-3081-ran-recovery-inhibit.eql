// Dragnet [Ransomware]: dragnet-ransomware-2025-3081 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: eb840930-440f-5ae0-9da8-d0194eef5b62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
