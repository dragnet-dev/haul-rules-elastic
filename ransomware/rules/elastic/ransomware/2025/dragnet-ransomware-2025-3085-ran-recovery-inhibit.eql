// Dragnet [Ransomware]: dragnet-ransomware-2025-3085 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: a8ad8813-cef1-53a5-aa12-c6c6e0ef362a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
