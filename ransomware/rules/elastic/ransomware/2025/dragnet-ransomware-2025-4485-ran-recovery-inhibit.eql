// Dragnet [Ransomware]: dragnet-ransomware-2025-4485 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 188850e6-1eef-5d2c-a06c-0007dbb05644

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
