// Dragnet [Ransomware]: dragnet-ransomware-2025-4474 — Recovery Inhibition (fog)
// Status: deprecated | Level: high | ID: 3c1ad287-db15-5bf9-b61a-789ab3f1a812

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
