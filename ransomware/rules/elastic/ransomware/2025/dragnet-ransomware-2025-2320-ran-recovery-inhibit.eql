// Dragnet [Ransomware]: dragnet-ransomware-2025-2320 — Recovery Inhibition (obscura)
// Status: experimental | Level: high | ID: 23d95240-11f9-5857-bf98-ed3c829ae3fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
