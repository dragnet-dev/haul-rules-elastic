// Dragnet [Ransomware]: dragnet-ransomware-2025-0410 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: a7b0850c-5f72-5e54-8d50-a72032a28b6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
