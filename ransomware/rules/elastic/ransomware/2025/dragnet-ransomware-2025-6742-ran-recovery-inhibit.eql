// Dragnet [Ransomware]: dragnet-ransomware-2025-6742 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: d1bd0af6-7a56-5da5-b4c6-451e2a10e8ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
