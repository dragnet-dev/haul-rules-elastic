// Dragnet [Ransomware]: dragnet-ransomware-2025-0616 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: cf35455c-cd46-53d2-8d30-66ef8b11a880

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
