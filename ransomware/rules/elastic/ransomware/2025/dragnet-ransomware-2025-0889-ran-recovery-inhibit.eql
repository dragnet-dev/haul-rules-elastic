// Dragnet [Ransomware]: dragnet-ransomware-2025-0889 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: a06f4180-f6f9-5bf9-a788-9cf639615870

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
