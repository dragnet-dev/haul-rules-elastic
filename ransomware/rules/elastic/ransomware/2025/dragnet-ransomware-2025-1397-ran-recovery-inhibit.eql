// Dragnet [Ransomware]: dragnet-ransomware-2025-1397 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 3c0fecdb-2dc1-50b0-838f-b666de69f212

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
