// Dragnet [Ransomware]: dragnet-ransomware-2025-4237 — Recovery Inhibition (VanHelsing)
// Status: experimental | Level: high | ID: 802237d5-d4af-5a8c-8daa-f984ecbeebe8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
