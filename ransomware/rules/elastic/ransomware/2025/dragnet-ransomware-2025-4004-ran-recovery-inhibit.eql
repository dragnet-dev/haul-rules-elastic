// Dragnet [Ransomware]: dragnet-ransomware-2025-4004 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d835ddf3-5051-58fa-915d-112b73fef276

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
