// Dragnet [Ransomware]: dragnet-ransomware-2025-7900 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 83113045-ac12-5514-8a8a-5d7528b56b26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
