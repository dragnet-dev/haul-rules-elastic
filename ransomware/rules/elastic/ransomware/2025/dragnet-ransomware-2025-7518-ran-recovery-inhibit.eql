// Dragnet [Ransomware]: dragnet-ransomware-2025-7518 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: a43c3dd3-7c9f-5cef-9a3a-06645db7de9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
