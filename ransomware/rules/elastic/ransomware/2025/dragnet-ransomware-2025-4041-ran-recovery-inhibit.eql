// Dragnet [Ransomware]: dragnet-ransomware-2025-4041 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 2ce21426-5650-5502-b898-898800b88fcc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
