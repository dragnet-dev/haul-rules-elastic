// Dragnet [Ransomware]: dragnet-ransomware-2025-4282 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 7f59178d-fe01-58c9-ad97-1f2db86b0162

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
