// Dragnet [Ransomware]: dragnet-ransomware-2025-1750 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 31efd27c-9b6e-5a43-a1aa-2fed4665766d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
