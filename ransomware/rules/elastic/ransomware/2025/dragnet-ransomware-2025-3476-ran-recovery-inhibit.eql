// Dragnet [Ransomware]: dragnet-ransomware-2025-3476 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0c177c02-3c33-5491-b57c-2222fbfe78d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
