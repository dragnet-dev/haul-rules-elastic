// Dragnet [Ransomware]: dragnet-ransomware-2025-0656 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: 9742bb66-e0eb-5902-b0d7-0ccb67706e58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
