// Dragnet [Ransomware]: dragnet-ransomware-2025-6327 — Recovery Inhibition (genesis)
// Status: experimental | Level: high | ID: 70fa0511-d246-59c4-8881-68f380140f71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
