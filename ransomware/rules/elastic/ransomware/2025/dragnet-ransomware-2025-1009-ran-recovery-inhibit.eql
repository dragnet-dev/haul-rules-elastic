// Dragnet [Ransomware]: dragnet-ransomware-2025-1009 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: d4c0e2b0-d735-562f-ace4-5754a591db21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
