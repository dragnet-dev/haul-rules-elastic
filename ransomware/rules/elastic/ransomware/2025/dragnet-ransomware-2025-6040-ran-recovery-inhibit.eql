// Dragnet [Ransomware]: dragnet-ransomware-2025-6040 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6a24c75d-4333-5383-81f2-aa4bbac058a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
