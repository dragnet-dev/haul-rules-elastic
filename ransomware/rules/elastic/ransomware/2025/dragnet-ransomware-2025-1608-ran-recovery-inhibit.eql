// Dragnet [Ransomware]: dragnet-ransomware-2025-1608 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: e5a4a470-f83e-5707-831f-d44c5d7431eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
