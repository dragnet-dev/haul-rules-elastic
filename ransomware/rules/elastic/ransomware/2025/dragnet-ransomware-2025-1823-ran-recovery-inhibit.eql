// Dragnet [Ransomware]: dragnet-ransomware-2025-1823 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: c4608216-c7d0-5ceb-a291-f96590ef22f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
