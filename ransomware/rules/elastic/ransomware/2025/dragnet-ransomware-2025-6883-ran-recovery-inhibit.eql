// Dragnet [Ransomware]: dragnet-ransomware-2025-6883 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: 36b586c7-fec4-51fc-bd22-117780e19276

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
