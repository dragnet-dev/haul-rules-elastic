// Dragnet [Ransomware]: dragnet-ransomware-2025-5598 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d79c67bc-afb3-502a-b462-5e9b1ccfaf92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
