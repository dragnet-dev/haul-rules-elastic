// Dragnet [Ransomware]: dragnet-ransomware-2025-4306 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8796b33c-18f7-5508-875c-6ed7572fbc3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
