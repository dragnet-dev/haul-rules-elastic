// Dragnet [Ransomware]: dragnet-ransomware-2025-5505 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: be585806-1795-5af8-a05a-356abee99871

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
