// Dragnet [Ransomware]: dragnet-ransomware-2025-0076 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 81612534-57e7-5b35-8570-badd48f8cd6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
