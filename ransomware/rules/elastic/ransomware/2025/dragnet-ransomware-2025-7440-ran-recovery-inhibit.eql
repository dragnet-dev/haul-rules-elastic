// Dragnet [Ransomware]: dragnet-ransomware-2025-7440 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 72e71c8f-d4e8-526c-b1ef-844b8f9b647c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
