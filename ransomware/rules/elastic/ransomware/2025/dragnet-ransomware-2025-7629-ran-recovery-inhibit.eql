// Dragnet [Ransomware]: dragnet-ransomware-2025-7629 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 41f6827f-5a96-5035-95fc-31a5558299b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
