// Dragnet [Ransomware]: dragnet-ransomware-2025-1818 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: e1e412e5-824c-5eff-af73-ee42e9bfb625

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
