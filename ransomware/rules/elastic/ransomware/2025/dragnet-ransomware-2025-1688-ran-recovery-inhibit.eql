// Dragnet [Ransomware]: dragnet-ransomware-2025-1688 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 550ee3a1-4297-5ad4-bfbd-388aa9cf8fa2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
