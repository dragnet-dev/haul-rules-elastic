// Dragnet [Ransomware]: dragnet-ransomware-2025-1542 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: b153463b-46ce-510b-903d-3e6cb6bfc34d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
