// Dragnet [Ransomware]: dragnet-ransomware-2025-5153 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: a746917a-36fe-54e5-9607-f6ed6ec79e08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
