// Dragnet [Ransomware]: dragnet-ransomware-2025-2219 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: d2efcb93-1fd8-5c4b-adab-b6b7d5b2c822

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
