// Dragnet [Ransomware]: dragnet-ransomware-2025-0851 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3965f4a1-42e1-5413-ae6f-c137ac270041

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
