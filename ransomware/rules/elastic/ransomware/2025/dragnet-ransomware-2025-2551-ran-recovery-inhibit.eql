// Dragnet [Ransomware]: dragnet-ransomware-2025-2551 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 914a1a85-e89c-584b-89d8-c937ef364e51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
