// Dragnet [Ransomware]: dragnet-ransomware-2025-3512 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 17777015-fa18-5bf7-b6ae-2a1a457e2eec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
