// Dragnet [Ransomware]: dragnet-ransomware-2025-6846 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 0c804e40-c4cc-5746-a951-2bd61dde0367

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
