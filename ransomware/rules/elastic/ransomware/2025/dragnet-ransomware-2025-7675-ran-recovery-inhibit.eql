// Dragnet [Ransomware]: dragnet-ransomware-2025-7675 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ffd6cbd8-6c82-53a0-9068-d248c5320b9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
