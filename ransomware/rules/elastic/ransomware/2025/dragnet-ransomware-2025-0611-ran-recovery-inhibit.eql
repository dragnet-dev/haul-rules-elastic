// Dragnet [Ransomware]: dragnet-ransomware-2025-0611 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: e5fd60d3-6cf1-59ca-b534-cb382449494f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
