// Dragnet [Ransomware]: dragnet-ransomware-2025-3230 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: c70c17fb-fea2-54b9-aa2c-b0b3e02ce60e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
