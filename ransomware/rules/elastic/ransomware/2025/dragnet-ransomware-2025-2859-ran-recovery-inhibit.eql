// Dragnet [Ransomware]: dragnet-ransomware-2025-2859 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: 4688832b-7443-5c24-b7a8-a17ad6be05d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
