// Dragnet [Ransomware]: dragnet-ransomware-2025-6915 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 7df863cb-9814-586e-8dbc-825452667627

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
