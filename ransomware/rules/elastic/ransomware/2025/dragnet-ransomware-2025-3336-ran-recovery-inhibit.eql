// Dragnet [Ransomware]: dragnet-ransomware-2025-3336 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4c364663-93e0-5e73-8bb0-6ff0cc4f0741

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
