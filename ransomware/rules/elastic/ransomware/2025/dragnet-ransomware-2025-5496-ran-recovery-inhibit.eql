// Dragnet [Ransomware]: dragnet-ransomware-2025-5496 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: bd5d0d1f-dc31-59a3-befd-8a9647c8afbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
