// Dragnet [Ransomware]: dragnet-ransomware-2025-0679 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d3c4d718-63c9-5729-8012-eb3745a7afde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
