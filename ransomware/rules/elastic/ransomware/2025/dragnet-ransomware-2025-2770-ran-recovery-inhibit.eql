// Dragnet [Ransomware]: dragnet-ransomware-2025-2770 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: c896894a-b41f-5bec-9e39-c0585177e573

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
