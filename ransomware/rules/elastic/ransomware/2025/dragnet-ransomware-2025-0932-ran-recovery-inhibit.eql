// Dragnet [Ransomware]: dragnet-ransomware-2025-0932 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5313a0f6-a407-51b5-b139-0c2162f9a6a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
