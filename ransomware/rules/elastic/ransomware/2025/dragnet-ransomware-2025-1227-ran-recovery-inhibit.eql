// Dragnet [Ransomware]: dragnet-ransomware-2025-1227 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: fcd22e98-92bb-5b2d-a2e2-1da4cb416f3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
