// Dragnet [Ransomware]: dragnet-ransomware-2025-1464 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: 7ed0cd87-5894-5a50-8767-c528ea38a7e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
