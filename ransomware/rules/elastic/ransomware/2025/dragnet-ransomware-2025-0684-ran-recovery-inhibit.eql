// Dragnet [Ransomware]: dragnet-ransomware-2025-0684 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: b40fb925-7091-5265-9dcd-556e677b7099

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
