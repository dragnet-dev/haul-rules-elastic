// Dragnet [Ransomware]: dragnet-ransomware-2025-4493 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: c088c80d-de43-52fd-a661-6c9976820d7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
