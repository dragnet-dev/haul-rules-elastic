// Dragnet [Ransomware]: dragnet-ransomware-2025-7719 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f9e6d09f-dd35-5e05-87d6-491eb263f799

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
