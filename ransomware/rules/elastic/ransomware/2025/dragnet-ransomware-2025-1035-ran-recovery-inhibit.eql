// Dragnet [Ransomware]: dragnet-ransomware-2025-1035 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ce156cfb-5041-5bb5-81f5-56c318ddacf5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
