// Dragnet [Ransomware]: dragnet-ransomware-2025-6716 — Recovery Inhibition (obscura)
// Status: experimental | Level: high | ID: 0123bb06-8bb0-5c6c-ad60-051e0e1f56aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
