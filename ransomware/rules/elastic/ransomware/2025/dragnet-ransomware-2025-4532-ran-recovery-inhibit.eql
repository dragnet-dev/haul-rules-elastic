// Dragnet [Ransomware]: dragnet-ransomware-2025-4532 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: ba2e814c-a598-56bb-a7d5-0255dc2d7694

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
