// Dragnet [Ransomware]: dragnet-ransomware-2025-0361 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 89a137a9-f6da-5a35-aa21-6e48840d7bc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
