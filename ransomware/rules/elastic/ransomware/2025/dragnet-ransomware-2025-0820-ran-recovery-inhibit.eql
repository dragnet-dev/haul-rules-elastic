// Dragnet [Ransomware]: dragnet-ransomware-2025-0820 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 922988d8-b46c-5b11-8bea-167edcec5b9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
