// Dragnet [Ransomware]: dragnet-ransomware-2025-5501 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: fc96694a-a3bd-527e-8c7a-fe46209c536e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
