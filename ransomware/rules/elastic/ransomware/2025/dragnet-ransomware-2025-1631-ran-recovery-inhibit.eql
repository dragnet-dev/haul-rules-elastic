// Dragnet [Ransomware]: dragnet-ransomware-2025-1631 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 0f8b4da8-5b65-56cd-ad06-8a5b79ff19bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
