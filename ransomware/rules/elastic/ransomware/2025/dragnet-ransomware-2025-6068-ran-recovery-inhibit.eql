// Dragnet [Ransomware]: dragnet-ransomware-2025-6068 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 291a0fa4-ceca-5226-ba99-75a71789a0f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
