// Dragnet [Ransomware]: dragnet-ransomware-2025-1233 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 6a9fbb66-72e6-54f5-87ec-4145258d1c50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
