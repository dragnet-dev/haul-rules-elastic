// Dragnet [Ransomware]: dragnet-ransomware-2025-4365 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: bdd87cc3-de8d-5ec2-b258-384b79c901c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
