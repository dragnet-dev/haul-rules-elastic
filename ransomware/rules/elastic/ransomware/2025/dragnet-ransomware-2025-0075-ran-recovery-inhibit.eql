// Dragnet [Ransomware]: dragnet-ransomware-2025-0075 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0a283869-6611-507a-ab75-34d5889bf82c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
