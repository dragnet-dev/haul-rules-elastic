// Dragnet [Ransomware]: dragnet-ransomware-2025-0777 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d723e8a0-a6dd-5966-9b4e-c46d30e09e7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
