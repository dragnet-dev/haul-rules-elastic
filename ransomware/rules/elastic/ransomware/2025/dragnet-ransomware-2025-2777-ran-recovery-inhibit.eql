// Dragnet [Ransomware]: dragnet-ransomware-2025-2777 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: c18d96bf-6d9f-5b68-b3ec-4c1fba49f675

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
