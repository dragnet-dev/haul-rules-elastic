// Dragnet [Ransomware]: dragnet-ransomware-2025-5991 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: 7553a47a-df18-5745-acab-8f92b66b1f11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
