// Dragnet [Ransomware]: dragnet-ransomware-2025-4672 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 76b76dff-1c35-5a09-bc3a-ba56a1333e77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
