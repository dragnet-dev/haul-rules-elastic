// Dragnet [Ransomware]: dragnet-ransomware-2025-4247 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: a67d7205-8187-5b77-a3e3-9af196203b7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
