// Dragnet [Ransomware]: dragnet-ransomware-2025-5670 — Recovery Inhibition (payoutsking)
// Status: test | Level: high | ID: fbb818d1-3e1f-559b-8413-a1389ab40a6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
