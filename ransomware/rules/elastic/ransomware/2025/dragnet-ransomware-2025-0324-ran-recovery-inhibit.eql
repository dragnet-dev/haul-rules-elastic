// Dragnet [Ransomware]: dragnet-ransomware-2025-0324 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7fa9a432-d346-5219-8662-b396be2bee1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
