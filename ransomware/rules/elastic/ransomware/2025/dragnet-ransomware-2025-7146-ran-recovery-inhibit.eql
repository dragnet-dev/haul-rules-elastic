// Dragnet [Ransomware]: dragnet-ransomware-2025-7146 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 4adf3c9b-0fd5-5768-97c7-6b1ebacbf03c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
