// Dragnet [Ransomware]: dragnet-ransomware-2025-5886 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: efd16225-d1b1-5b7a-bf9b-6ad50820231d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
