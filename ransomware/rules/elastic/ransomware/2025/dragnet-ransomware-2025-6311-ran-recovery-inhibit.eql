// Dragnet [Ransomware]: dragnet-ransomware-2025-6311 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: eb4795b9-83db-55e0-b834-3ae6503727b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
