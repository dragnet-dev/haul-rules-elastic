// Dragnet [Ransomware]: dragnet-ransomware-2025-6995 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: c9ab76d3-94f4-5260-a69a-3e21fc82e147

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
