// Dragnet [Ransomware]: dragnet-ransomware-2025-5546 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ca0423aa-a699-5d2b-8c0f-88343b14ca02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
