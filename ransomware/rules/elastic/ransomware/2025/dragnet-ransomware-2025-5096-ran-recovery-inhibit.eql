// Dragnet [Ransomware]: dragnet-ransomware-2025-5096 — Recovery Inhibition (interlock)
// Status: test | Level: high | ID: 48bdd4c0-b3e7-5e39-abe5-cf28f87e76b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
