// Dragnet [Ransomware]: dragnet-ransomware-2025-5493 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 459b01d1-665b-5850-ba00-b36e416faf4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
