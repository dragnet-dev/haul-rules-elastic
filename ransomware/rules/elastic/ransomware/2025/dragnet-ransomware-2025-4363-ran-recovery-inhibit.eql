// Dragnet [Ransomware]: dragnet-ransomware-2025-4363 — Recovery Inhibition (handala)
// Status: test | Level: high | ID: 4ae8f680-7f5b-5f29-b1d2-33068e2fc916

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
