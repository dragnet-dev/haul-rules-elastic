// Dragnet [Ransomware]: dragnet-ransomware-2025-1456 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: edebe252-e372-5cc5-920b-e9c0815ad0c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
