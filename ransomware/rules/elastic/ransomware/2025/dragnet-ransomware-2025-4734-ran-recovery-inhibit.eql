// Dragnet [Ransomware]: dragnet-ransomware-2025-4734 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: eb2a363b-43a9-55b3-b333-b6ba56691c05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
