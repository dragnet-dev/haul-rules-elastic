// Dragnet [Ransomware]: dragnet-ransomware-2025-7364 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 33072f88-f8bf-5d51-9a6c-f9b72bdd29d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
