// Dragnet [Ransomware]: dragnet-ransomware-2025-0574 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a853c32c-e103-542c-a2ae-b4ad0150994d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
