// Dragnet [Ransomware]: dragnet-ransomware-2025-2236 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0344155d-4e70-55ff-8b59-0ee1930136c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
