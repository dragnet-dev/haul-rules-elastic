// Dragnet [Ransomware]: dragnet-ransomware-2025-0041 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a8ccf3a3-a162-55cf-96a6-fd53290847d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
