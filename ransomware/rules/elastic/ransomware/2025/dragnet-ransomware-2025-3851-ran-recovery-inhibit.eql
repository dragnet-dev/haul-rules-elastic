// Dragnet [Ransomware]: dragnet-ransomware-2025-3851 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: a212a5af-dcca-5b46-b141-864d0f815f30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
