// Dragnet [Ransomware]: dragnet-ransomware-2025-4228 — Recovery Inhibition (genesis)
// Status: experimental | Level: high | ID: a276398f-2489-557c-897e-806079714960

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
