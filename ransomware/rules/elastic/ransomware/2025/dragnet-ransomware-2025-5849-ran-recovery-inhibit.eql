// Dragnet [Ransomware]: dragnet-ransomware-2025-5849 — Recovery Inhibition (gunra)
// Status: experimental | Level: high | ID: 4802c919-e9ee-50df-bfff-57ee01161449

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
