// Dragnet [Ransomware]: dragnet-ransomware-2025-4596 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 398a9a24-735e-5087-8e54-88c4260b4200

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
