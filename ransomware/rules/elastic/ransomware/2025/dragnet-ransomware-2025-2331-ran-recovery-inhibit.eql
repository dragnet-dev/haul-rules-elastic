// Dragnet [Ransomware]: dragnet-ransomware-2025-2331 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cbec6bd9-ca4d-5da2-bfde-58b8416376bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
