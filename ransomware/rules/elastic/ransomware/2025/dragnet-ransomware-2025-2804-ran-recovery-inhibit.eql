// Dragnet [Ransomware]: dragnet-ransomware-2025-2804 — Recovery Inhibition (frag)
// Status: deprecated | Level: high | ID: 8b3e83dd-1f42-5d9b-8ef9-061a21f975a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
