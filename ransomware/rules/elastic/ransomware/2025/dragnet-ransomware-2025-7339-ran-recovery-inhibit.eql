// Dragnet [Ransomware]: dragnet-ransomware-2025-7339 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 70ca36c4-3dd1-5b68-8e4f-b143ab90c491

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
