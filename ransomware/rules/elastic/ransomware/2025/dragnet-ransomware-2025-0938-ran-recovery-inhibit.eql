// Dragnet [Ransomware]: dragnet-ransomware-2025-0938 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ae6311c9-43b9-5c13-bd8c-20311aed5ee7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
