// Dragnet [Ransomware]: dragnet-ransomware-2025-0864 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: e7e7d562-8cf9-5259-a7c0-3ac0ae5fab9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
