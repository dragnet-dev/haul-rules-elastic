// Dragnet [Ransomware]: dragnet-ransomware-2025-0014 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 10f0e62f-e165-5f89-870e-a9b72d32aab4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
