// Dragnet [Ransomware]: dragnet-ransomware-2025-0311 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: bc67a72a-3882-5f63-9d21-0ac3884b6b82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
