// Dragnet [Ransomware]: dragnet-ransomware-2025-3535 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 6a01bade-9a6d-5820-943f-29c3b26b2778

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
