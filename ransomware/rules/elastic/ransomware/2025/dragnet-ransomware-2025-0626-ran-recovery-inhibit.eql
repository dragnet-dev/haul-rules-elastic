// Dragnet [Ransomware]: dragnet-ransomware-2025-0626 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: 8de5f0b9-73d9-5462-9fe7-92f8f3b1a0f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
