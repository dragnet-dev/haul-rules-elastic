// Dragnet [Ransomware]: dragnet-ransomware-2025-6244 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b4511a05-50ee-51fa-bb91-7f0dc1782698

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
