// Dragnet [Ransomware]: dragnet-ransomware-2025-6015 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: eb09cb89-c150-5051-bf39-10feaa96bf48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
