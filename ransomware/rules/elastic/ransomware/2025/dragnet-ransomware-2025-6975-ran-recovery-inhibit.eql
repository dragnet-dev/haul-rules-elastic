// Dragnet [Ransomware]: dragnet-ransomware-2025-6975 — Recovery Inhibition (securotrop)
// Status: experimental | Level: high | ID: 8755deaa-ad91-50d8-a4ad-df8babacfdfb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
