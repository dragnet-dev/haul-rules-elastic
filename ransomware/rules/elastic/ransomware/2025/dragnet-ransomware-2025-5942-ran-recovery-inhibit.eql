// Dragnet [Ransomware]: dragnet-ransomware-2025-5942 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: dee5b882-3523-5452-9810-be35647f531f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
