// Dragnet [Ransomware]: dragnet-ransomware-2025-5753 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 468a558c-3eb1-566e-a0f8-048b92314edb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
