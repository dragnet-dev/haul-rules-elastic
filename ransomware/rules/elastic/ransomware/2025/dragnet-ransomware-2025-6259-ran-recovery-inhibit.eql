// Dragnet [Ransomware]: dragnet-ransomware-2025-6259 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: de1c8914-de99-5705-ac7e-1f6d2890e398

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
