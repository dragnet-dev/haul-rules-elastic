// Dragnet [Ransomware]: dragnet-ransomware-2025-3206 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c35e9b4a-b5ad-5862-bf9b-11b1e0ec44cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
