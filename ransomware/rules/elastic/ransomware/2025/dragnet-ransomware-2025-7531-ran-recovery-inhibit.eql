// Dragnet [Ransomware]: dragnet-ransomware-2025-7531 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: c03914e7-8175-51bc-b6fa-4d1a698aa433

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
