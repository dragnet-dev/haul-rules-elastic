// Dragnet [Ransomware]: dragnet-ransomware-2025-5534 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 4225a497-a9e9-57dc-9888-7cd590e85b7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
