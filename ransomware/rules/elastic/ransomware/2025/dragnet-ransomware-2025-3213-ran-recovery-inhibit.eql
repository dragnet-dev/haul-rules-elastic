// Dragnet [Ransomware]: dragnet-ransomware-2025-3213 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: bdeedb72-1ce2-5a0d-b01b-abee9aee1da5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
