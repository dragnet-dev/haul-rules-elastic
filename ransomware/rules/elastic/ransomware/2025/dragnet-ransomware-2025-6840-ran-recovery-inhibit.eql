// Dragnet [Ransomware]: dragnet-ransomware-2025-6840 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: ead994a1-2435-59a6-b8ae-a1336e4fb8c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
