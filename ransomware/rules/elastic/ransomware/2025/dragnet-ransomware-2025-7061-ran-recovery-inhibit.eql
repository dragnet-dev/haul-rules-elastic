// Dragnet [Ransomware]: dragnet-ransomware-2025-7061 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b0159242-0bf8-57c9-b030-2b5308cf5a87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
