// Dragnet [Ransomware]: dragnet-ransomware-2025-0668 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 0d7781eb-4740-55a3-ba8d-d20e213ea023

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
