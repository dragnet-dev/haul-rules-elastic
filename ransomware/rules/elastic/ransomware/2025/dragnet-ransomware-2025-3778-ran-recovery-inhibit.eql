// Dragnet [Ransomware]: dragnet-ransomware-2025-3778 — Recovery Inhibition (d4rk4rmy)
// Status: experimental | Level: high | ID: e5b455d4-485c-5394-85b4-64169271d537

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
