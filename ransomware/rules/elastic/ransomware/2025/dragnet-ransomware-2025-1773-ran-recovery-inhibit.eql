// Dragnet [Ransomware]: dragnet-ransomware-2025-1773 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 256f2ffd-d2e0-55bc-9a8a-6e3d76c41076

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
