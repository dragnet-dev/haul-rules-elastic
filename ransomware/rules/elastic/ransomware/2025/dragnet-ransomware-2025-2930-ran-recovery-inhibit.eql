// Dragnet [Ransomware]: dragnet-ransomware-2025-2930 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: c2d677b0-4a64-54b5-9d0b-16833b0818a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
