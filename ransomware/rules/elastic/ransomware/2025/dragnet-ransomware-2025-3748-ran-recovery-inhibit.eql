// Dragnet [Ransomware]: dragnet-ransomware-2025-3748 — Recovery Inhibition (hellcat)
// Status: deprecated | Level: high | ID: 7b46c7c9-c343-551f-b9a5-75a65257afb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
