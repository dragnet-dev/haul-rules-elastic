// Dragnet [Ransomware]: dragnet-ransomware-2025-1030 — Recovery Inhibition (cephalus)
// Status: experimental | Level: high | ID: ffe1a1b8-db1c-5f51-82c6-536fb339d30a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
