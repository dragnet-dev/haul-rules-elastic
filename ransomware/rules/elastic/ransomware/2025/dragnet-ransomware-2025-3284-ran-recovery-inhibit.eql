// Dragnet [Ransomware]: dragnet-ransomware-2025-3284 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 51673ae5-3d53-526f-8894-7d636d857a73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
