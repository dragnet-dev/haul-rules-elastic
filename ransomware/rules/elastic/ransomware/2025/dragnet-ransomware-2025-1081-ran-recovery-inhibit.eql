// Dragnet [Ransomware]: dragnet-ransomware-2025-1081 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 42ac12d5-ee25-5a53-9824-b0c00467af2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
