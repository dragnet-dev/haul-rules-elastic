// Dragnet [Ransomware]: dragnet-ransomware-2025-3436 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: c7346965-84ab-558a-9824-47537810d843

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
