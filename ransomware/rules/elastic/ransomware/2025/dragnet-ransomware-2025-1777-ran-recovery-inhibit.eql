// Dragnet [Ransomware]: dragnet-ransomware-2025-1777 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 00f91e6a-f442-5fb7-a411-318e3dd1609c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
