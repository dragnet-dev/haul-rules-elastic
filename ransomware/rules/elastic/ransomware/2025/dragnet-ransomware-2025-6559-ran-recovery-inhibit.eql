// Dragnet [Ransomware]: dragnet-ransomware-2025-6559 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: ab356832-b361-5a54-94fe-006e013d713b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
