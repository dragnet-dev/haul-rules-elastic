// Dragnet [Ransomware]: dragnet-ransomware-2025-4245 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b8a42883-49d5-5c86-8217-c548aae625d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
