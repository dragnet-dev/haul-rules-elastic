// Dragnet [Ransomware]: dragnet-ransomware-2025-2834 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: b0a241b6-560e-582b-9c4f-c3b56a503925

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
