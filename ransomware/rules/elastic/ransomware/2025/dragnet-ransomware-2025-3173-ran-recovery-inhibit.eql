// Dragnet [Ransomware]: dragnet-ransomware-2025-3173 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: f7f4bee2-0900-5930-9e02-98377dbd85ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
