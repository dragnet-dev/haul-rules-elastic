// Dragnet [Ransomware]: dragnet-ransomware-2025-2427 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: c6679798-09e6-59b9-b9ec-c236033fe836

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
