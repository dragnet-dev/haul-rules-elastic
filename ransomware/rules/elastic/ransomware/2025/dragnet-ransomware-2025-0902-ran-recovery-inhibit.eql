// Dragnet [Ransomware]: dragnet-ransomware-2025-0902 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 8e41fc09-c95c-556b-88f0-edd8cdc5119d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
