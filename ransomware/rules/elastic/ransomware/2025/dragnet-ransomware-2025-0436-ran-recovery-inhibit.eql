// Dragnet [Ransomware]: dragnet-ransomware-2025-0436 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 410b00f2-66fa-5c23-9c27-aa39442fa2aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
