// Dragnet [Ransomware]: dragnet-ransomware-2025-6853 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 77df1c95-4446-5b10-8e7d-7519b53ad4c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
