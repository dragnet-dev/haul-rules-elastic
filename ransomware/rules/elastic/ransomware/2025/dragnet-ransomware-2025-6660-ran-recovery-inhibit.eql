// Dragnet [Ransomware]: dragnet-ransomware-2025-6660 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 168282aa-3eb8-508b-ad5f-18e08dffbbe0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
