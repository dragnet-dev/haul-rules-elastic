// Dragnet [Ransomware]: dragnet-ransomware-2025-1070 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 88c289f3-ab65-5e8e-bfe2-2f91564d93b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
