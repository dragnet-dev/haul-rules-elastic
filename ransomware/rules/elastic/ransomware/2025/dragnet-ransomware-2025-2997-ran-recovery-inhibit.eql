// Dragnet [Ransomware]: dragnet-ransomware-2025-2997 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f9f85b61-7441-50ad-a73c-b7ea6b99ea7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
