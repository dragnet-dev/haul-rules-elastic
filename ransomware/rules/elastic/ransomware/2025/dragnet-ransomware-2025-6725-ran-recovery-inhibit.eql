// Dragnet [Ransomware]: dragnet-ransomware-2025-6725 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: afeaa448-7cd3-5c69-a8e9-65f784fc20b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
