// Dragnet [Ransomware]: dragnet-ransomware-2025-7707 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: dd2f2b37-1a5d-5a0a-b46c-be5a185483d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
