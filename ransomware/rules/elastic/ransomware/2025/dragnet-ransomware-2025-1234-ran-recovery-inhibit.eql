// Dragnet [Ransomware]: dragnet-ransomware-2025-1234 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 247d6a82-86b9-57c8-940d-382227283228

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
