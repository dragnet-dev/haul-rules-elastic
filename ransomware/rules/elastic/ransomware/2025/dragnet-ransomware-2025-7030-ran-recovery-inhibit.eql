// Dragnet [Ransomware]: dragnet-ransomware-2025-7030 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 157bba20-9b45-57c3-af03-df051da2f3c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
