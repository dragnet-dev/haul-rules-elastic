// Dragnet [Ransomware]: dragnet-ransomware-2025-1483 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: bff80a7a-e5cc-5666-b0be-a6b46876785d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
