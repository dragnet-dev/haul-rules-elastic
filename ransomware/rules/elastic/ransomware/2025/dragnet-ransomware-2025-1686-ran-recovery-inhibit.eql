// Dragnet [Ransomware]: dragnet-ransomware-2025-1686 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2f9092df-e9ca-5352-8c28-94747588a11c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
