// Dragnet [Ransomware]: dragnet-ransomware-2025-1898 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 1e498206-d8a2-5ebf-9aac-8f809cbb9e31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
