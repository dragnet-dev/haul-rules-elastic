// Dragnet [Ransomware]: dragnet-ransomware-2025-1565 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 495529ac-265e-5933-afc1-3260b1ac57c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
