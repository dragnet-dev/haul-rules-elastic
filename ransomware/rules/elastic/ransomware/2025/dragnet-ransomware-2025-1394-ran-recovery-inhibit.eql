// Dragnet [Ransomware]: dragnet-ransomware-2025-1394 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 1ae14a3f-4897-5512-bec7-31df4a75bd53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
