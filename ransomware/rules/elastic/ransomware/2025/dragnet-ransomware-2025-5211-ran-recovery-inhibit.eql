// Dragnet [Ransomware]: dragnet-ransomware-2025-5211 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: adb0c759-6000-565a-becf-5bb59be83e0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
