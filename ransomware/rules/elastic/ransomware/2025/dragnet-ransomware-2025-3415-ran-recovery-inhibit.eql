// Dragnet [Ransomware]: dragnet-ransomware-2025-3415 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: e6a06577-9f72-56ed-b710-4afb5c37cd39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
