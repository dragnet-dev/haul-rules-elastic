// Dragnet [Ransomware]: dragnet-ransomware-2025-4543 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: f0a3e6a1-7be8-5573-b87b-dcc645041b25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
