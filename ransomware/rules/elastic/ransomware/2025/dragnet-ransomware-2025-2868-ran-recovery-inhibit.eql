// Dragnet [Ransomware]: dragnet-ransomware-2025-2868 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: 50000dea-1443-5c93-ab4f-7c830c6818bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
