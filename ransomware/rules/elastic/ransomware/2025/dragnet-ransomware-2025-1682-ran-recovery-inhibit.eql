// Dragnet [Ransomware]: dragnet-ransomware-2025-1682 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 2dc968d4-a3ce-5811-96fa-9a45d6e87865

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
