// Dragnet [Ransomware]: dragnet-ransomware-2025-6362 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 8d2015cf-2654-5ece-b231-06e75c9746e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
