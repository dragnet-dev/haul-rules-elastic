// Dragnet [Ransomware]: dragnet-ransomware-2025-3309 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: d55fa557-7fcc-5599-9888-4d48d9791cb3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
