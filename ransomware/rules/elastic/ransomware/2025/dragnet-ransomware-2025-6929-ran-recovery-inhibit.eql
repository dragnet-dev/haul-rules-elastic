// Dragnet [Ransomware]: dragnet-ransomware-2025-6929 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 7d0db071-5087-558d-b88c-b16379c9b79c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
