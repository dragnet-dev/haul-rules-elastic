// Dragnet [Ransomware]: dragnet-ransomware-2025-1956 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 3954144c-afc6-56be-8c9f-584bd254fac2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
