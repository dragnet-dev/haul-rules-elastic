// Dragnet [Ransomware]: dragnet-ransomware-2025-7203 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: b6fdfcd6-a0ed-56b5-8967-c3b6c7753998

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
