// Dragnet [Ransomware]: dragnet-ransomware-2025-5176 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 60c27c76-8412-5544-b9bb-38e178376d56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
