// Dragnet [Ransomware]: dragnet-ransomware-2025-0312 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 1f569b78-1edc-59cd-a75d-23c1621ee7d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
