// Dragnet [Ransomware]: dragnet-ransomware-2025-6001 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 5d696d7b-435a-5ff7-9ca4-37321565161b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
