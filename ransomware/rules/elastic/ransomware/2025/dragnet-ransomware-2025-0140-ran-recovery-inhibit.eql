// Dragnet [Ransomware]: dragnet-ransomware-2025-0140 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: bc71700c-7caf-53f3-8506-8e256c1a8559

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
