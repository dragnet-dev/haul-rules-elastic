// Dragnet [Ransomware]: dragnet-ransomware-2025-0279 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c0bbc008-d251-5b85-a4ee-aa48cce4d8c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
