// Dragnet [Ransomware]: dragnet-ransomware-2025-0390 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1d3bec89-8f16-5fbb-b4ea-667229e3bd97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
