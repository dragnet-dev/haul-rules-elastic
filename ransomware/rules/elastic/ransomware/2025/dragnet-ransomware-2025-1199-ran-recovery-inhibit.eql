// Dragnet [Ransomware]: dragnet-ransomware-2025-1199 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8e0ff0d4-e835-5fa0-967a-a3731d0d2087

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
