// Dragnet [Ransomware]: dragnet-ransomware-2025-7887 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 070fa5f5-f7d6-52f2-9fe6-5e7fd3bfc26b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
