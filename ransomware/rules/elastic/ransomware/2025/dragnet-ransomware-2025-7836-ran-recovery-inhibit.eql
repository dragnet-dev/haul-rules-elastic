// Dragnet [Ransomware]: dragnet-ransomware-2025-7836 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: ba955f5b-569b-5229-ae60-c2a2793de343

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
