// Dragnet [Ransomware]: dragnet-ransomware-2025-0907 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d4cbd3ae-da3e-5a94-879d-622eb9593c5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
