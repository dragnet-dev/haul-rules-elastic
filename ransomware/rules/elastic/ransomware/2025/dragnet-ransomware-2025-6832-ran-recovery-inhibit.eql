// Dragnet [Ransomware]: dragnet-ransomware-2025-6832 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 89aed55d-a0c0-5497-ade6-4fa914fb5111

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
