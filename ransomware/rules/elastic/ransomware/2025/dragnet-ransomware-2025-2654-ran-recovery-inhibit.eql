// Dragnet [Ransomware]: dragnet-ransomware-2025-2654 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 664507c2-964a-55d0-b1e3-d2eb490791b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
