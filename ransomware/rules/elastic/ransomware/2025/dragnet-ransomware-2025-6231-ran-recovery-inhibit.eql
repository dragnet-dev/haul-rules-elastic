// Dragnet [Ransomware]: dragnet-ransomware-2025-6231 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 74f992fc-2c39-57fb-a855-9a845c7f3c8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
