// Dragnet [Ransomware]: dragnet-ransomware-2025-0187 — Recovery Inhibition (crazyhunter)
// Status: experimental | Level: high | ID: 4f46561b-b307-5700-a8b9-a2a5e4669f2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
