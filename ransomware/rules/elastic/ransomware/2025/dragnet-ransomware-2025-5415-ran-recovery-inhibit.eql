// Dragnet [Ransomware]: dragnet-ransomware-2025-5415 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: ded014d0-ed9e-541f-8a8a-23cd03820a47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
