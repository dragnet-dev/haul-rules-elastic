// Dragnet [Ransomware]: dragnet-ransomware-2025-5203 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 48afb54c-0142-5914-a1a3-8f629029583d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
