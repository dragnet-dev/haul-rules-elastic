// Dragnet [Ransomware]: dragnet-ransomware-2025-1737 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: 87b75a91-4056-56c2-988d-305645cd86c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
