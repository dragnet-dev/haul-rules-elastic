// Dragnet [Ransomware]: dragnet-ransomware-2025-2057 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b9a384de-c45f-50a0-944a-85bdacb7b556

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
