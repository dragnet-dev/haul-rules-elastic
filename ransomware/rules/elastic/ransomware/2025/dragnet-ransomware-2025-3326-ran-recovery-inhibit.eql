// Dragnet [Ransomware]: dragnet-ransomware-2025-3326 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 576d4bc8-5884-5fb2-8cfd-e3a6cbec5262

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
