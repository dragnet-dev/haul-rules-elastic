// Dragnet [Ransomware]: dragnet-ransomware-2025-1931 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: 74a5aaf1-a8e4-5f80-9693-c60ae16c2ec3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
