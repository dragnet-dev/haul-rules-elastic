// Dragnet [Ransomware]: dragnet-ransomware-2025-7746 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c7f756b4-00ab-5868-8a99-b53a657ae8de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
