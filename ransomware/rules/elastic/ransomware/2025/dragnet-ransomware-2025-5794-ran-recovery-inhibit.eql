// Dragnet [Ransomware]: dragnet-ransomware-2025-5794 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 0bbcf744-7409-596f-87d6-f04cb1cd695e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
