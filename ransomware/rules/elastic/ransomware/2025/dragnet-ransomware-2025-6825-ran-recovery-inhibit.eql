// Dragnet [Ransomware]: dragnet-ransomware-2025-6825 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 324ceb65-8106-51e9-ae1f-ac4de7d6022b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
