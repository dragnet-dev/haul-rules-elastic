// Dragnet [Ransomware]: dragnet-ransomware-2025-7306 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: e76807ab-77fa-57ec-b641-ef00e4ecea61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
