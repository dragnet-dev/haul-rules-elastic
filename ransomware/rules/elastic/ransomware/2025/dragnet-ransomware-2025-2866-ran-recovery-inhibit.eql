// Dragnet [Ransomware]: dragnet-ransomware-2025-2866 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 30985142-1bf3-50e4-b625-4975d7b03fd3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
