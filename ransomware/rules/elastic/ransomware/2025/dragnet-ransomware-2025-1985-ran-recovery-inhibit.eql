// Dragnet [Ransomware]: dragnet-ransomware-2025-1985 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 12bc3e38-3a94-5629-96c1-c95fcb58e947

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
