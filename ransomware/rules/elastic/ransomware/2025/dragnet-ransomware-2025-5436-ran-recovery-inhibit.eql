// Dragnet [Ransomware]: dragnet-ransomware-2025-5436 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: c38ab2b6-6507-5fde-a4b8-8f1ebcd4c987

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
