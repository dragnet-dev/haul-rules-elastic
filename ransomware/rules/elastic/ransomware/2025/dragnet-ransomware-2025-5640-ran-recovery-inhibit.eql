// Dragnet [Ransomware]: dragnet-ransomware-2025-5640 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: f1510f18-c6a1-5c39-bbdd-c424ccf7e7eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
