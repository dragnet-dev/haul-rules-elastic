// Dragnet [Ransomware]: dragnet-ransomware-2025-3631 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1b9b2fca-9c50-5262-aa6c-2ed367d0e6ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
