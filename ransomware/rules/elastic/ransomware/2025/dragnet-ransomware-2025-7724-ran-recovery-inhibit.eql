// Dragnet [Ransomware]: dragnet-ransomware-2025-7724 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2a7f533b-40f0-5463-a9d0-df2f44b1aeaf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
