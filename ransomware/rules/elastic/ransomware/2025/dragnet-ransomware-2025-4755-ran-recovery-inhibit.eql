// Dragnet [Ransomware]: dragnet-ransomware-2025-4755 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f2bfdf70-54ef-5d5a-aae9-f8cc931d0f1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
