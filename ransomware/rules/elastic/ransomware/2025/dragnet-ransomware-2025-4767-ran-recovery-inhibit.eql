// Dragnet [Ransomware]: dragnet-ransomware-2025-4767 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 30425a97-7ae8-5284-9e29-7ab8434e32db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
