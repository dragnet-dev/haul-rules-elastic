// Dragnet [Ransomware]: dragnet-ransomware-2025-4928 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 8b681a4d-5c8f-554a-8796-b0821730ca70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
