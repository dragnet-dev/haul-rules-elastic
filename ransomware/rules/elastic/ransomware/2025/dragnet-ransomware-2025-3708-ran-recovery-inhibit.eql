// Dragnet [Ransomware]: dragnet-ransomware-2025-3708 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: fa72b119-08ff-55fe-8055-5fc8790d96d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
