// Dragnet [Ransomware]: dragnet-ransomware-2025-3540 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 5e0d6dc2-5f78-5769-968d-0bc74737e0f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
