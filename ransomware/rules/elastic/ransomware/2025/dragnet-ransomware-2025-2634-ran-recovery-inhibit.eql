// Dragnet [Ransomware]: dragnet-ransomware-2025-2634 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 08253af3-6a0a-507b-ab06-dacc3ec0e1d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
