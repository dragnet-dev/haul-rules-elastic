// Dragnet [Ransomware]: dragnet-ransomware-2025-2756 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 68acf269-ab6f-5518-94d6-787c3784b2ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
