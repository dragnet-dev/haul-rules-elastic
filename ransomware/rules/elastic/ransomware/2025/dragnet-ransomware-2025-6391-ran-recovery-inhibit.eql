// Dragnet [Ransomware]: dragnet-ransomware-2025-6391 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: e090d040-926a-525f-8614-e5b67bbce98b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
