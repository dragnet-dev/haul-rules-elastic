// Dragnet [Ransomware]: dragnet-ransomware-2025-5779 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: ec7a0f3d-9784-5f69-b608-0f6f5c02fe16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
