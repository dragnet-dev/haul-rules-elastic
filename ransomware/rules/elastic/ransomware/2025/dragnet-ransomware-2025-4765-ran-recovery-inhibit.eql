// Dragnet [Ransomware]: dragnet-ransomware-2025-4765 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 34c747d4-6362-5a98-848b-ad7757692fef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
