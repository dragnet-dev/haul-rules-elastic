// Dragnet [Ransomware]: dragnet-ransomware-2025-3214 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 019737b5-e8c1-51a2-93cc-d72958905531

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
