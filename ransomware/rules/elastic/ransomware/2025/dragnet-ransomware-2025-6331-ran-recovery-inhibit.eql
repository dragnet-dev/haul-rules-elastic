// Dragnet [Ransomware]: dragnet-ransomware-2025-6331 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 829e4f82-71e3-5c08-89af-66ed1f531deb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
