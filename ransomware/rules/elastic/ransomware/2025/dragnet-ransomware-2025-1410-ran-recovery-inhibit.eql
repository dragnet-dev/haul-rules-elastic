// Dragnet [Ransomware]: dragnet-ransomware-2025-1410 — Recovery Inhibition (weyhro)
// Status: experimental | Level: high | ID: f55bb8bf-b0d3-55ff-b85e-7a9812897b5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
