// Dragnet [Ransomware]: dragnet-ransomware-2025-2267 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6b0c302a-614b-5510-8b2a-6b90f7665761

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
