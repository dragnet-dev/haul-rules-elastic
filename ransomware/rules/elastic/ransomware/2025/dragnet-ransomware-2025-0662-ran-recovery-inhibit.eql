// Dragnet [Ransomware]: dragnet-ransomware-2025-0662 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 40d8cc31-be7b-5a6b-ac50-aa780cfb0d2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
