// Dragnet [Ransomware]: dragnet-ransomware-2025-1398 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: bcbbf965-6937-59c1-a5cc-868ee7a54ab7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
