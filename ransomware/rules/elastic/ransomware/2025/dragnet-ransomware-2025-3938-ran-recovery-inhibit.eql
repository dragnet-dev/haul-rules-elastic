// Dragnet [Ransomware]: dragnet-ransomware-2025-3938 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 36befe12-9348-54f7-8bb0-8f1315d323d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
