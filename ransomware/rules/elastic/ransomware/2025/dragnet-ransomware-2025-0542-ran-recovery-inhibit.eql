// Dragnet [Ransomware]: dragnet-ransomware-2025-0542 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: 516981b3-4ac6-568b-9d3c-70dea10f6f9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
