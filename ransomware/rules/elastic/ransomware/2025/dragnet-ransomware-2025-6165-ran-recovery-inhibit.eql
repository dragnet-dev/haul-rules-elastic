// Dragnet [Ransomware]: dragnet-ransomware-2025-6165 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 2e66362b-bd08-5f4f-a3a8-a7262c0cca56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
