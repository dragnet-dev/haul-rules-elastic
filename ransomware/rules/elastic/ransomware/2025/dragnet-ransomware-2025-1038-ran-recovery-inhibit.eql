// Dragnet [Ransomware]: dragnet-ransomware-2025-1038 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5a4fb231-0ba8-52d3-a65b-a1d13c3bb436

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
