// Dragnet [Ransomware]: dragnet-ransomware-2025-1445 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c3654f24-1369-5c4a-bff7-5b9bd40a2ccf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
