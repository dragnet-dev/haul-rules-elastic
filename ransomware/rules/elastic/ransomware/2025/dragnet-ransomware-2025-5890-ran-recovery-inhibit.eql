// Dragnet [Ransomware]: dragnet-ransomware-2025-5890 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 26357818-9235-5c49-b5e9-a0dacb87195f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
