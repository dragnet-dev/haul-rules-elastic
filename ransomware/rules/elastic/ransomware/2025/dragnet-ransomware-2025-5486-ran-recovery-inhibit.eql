// Dragnet [Ransomware]: dragnet-ransomware-2025-5486 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: accf1136-1461-5226-9d04-4d038d4f671e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
