// Dragnet [Ransomware]: dragnet-ransomware-2025-6571 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 3c1fcd76-c9f8-59d9-a6a3-a0b8d716590e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
