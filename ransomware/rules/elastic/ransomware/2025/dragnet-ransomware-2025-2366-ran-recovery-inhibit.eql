// Dragnet [Ransomware]: dragnet-ransomware-2025-2366 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: da965ca5-debb-511b-83d6-103ce768e020

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
