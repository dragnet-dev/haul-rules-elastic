// Dragnet [Ransomware]: dragnet-ransomware-2025-3198 — Recovery Inhibition (arkana)
// Status: experimental | Level: high | ID: f41e0761-558d-5dec-af87-c012f6c9f938

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
