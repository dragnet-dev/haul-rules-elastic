// Dragnet [Ransomware]: dragnet-ransomware-2025-0515 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 659f0347-3519-5845-b804-b9354db3bbe5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
