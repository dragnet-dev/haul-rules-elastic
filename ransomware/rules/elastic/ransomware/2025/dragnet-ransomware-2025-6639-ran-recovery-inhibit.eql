// Dragnet [Ransomware]: dragnet-ransomware-2025-6639 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7edbb27f-ee6a-503d-93fe-7cdba7359916

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
