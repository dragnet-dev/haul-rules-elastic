// Dragnet [Ransomware]: dragnet-ransomware-2025-2125 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 07886b8c-881e-5430-941c-b9ef6f13a39d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
