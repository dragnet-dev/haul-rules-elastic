// Dragnet [Ransomware]: dragnet-ransomware-2025-3098 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 086b33b5-472a-5b87-ad24-67dfc3452254

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
