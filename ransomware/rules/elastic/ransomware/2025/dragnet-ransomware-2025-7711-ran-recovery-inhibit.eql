// Dragnet [Ransomware]: dragnet-ransomware-2025-7711 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 52e9dd59-cb2c-5854-91d4-e7d898c38f37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
