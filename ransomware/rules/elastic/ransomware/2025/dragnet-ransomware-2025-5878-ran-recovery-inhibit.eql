// Dragnet [Ransomware]: dragnet-ransomware-2025-5878 — Recovery Inhibition (silent)
// Status: experimental | Level: high | ID: 8ebfde62-3e71-5d7f-8364-87c54e24bf25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
