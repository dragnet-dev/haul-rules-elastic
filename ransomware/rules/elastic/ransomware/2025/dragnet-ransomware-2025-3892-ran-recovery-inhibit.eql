// Dragnet [Ransomware]: dragnet-ransomware-2025-3892 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 1945b040-5e74-5788-b8f6-f263d13225ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
