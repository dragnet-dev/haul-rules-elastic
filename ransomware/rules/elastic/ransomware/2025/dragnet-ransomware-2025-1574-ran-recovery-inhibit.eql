// Dragnet [Ransomware]: dragnet-ransomware-2025-1574 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9c3c4bd5-14b7-5b03-acc5-8235e444e3a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
