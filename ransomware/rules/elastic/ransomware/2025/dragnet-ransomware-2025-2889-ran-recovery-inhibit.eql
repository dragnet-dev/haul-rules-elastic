// Dragnet [Ransomware]: dragnet-ransomware-2025-2889 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 587c10cd-e1d2-5030-bb54-fb7d26433dfd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
