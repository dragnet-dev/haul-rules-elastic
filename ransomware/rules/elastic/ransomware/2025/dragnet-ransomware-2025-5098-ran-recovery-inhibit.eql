// Dragnet [Ransomware]: dragnet-ransomware-2025-5098 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 1ac17014-1e2d-5c72-9cc1-5c58b002e266

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
