// Dragnet [Ransomware]: dragnet-ransomware-2025-0514 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: dd9e6beb-9ca2-5cbd-9a59-803d8ba6f483

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
