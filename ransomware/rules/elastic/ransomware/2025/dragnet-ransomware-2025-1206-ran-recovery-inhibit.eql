// Dragnet [Ransomware]: dragnet-ransomware-2025-1206 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ba1d7ae9-d4b8-5645-a71a-33c3e6d91968

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
