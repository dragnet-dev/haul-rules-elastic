// Dragnet [Ransomware]: dragnet-ransomware-2025-5729 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: cafc54a9-21d0-56f2-9311-598b1590475e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
