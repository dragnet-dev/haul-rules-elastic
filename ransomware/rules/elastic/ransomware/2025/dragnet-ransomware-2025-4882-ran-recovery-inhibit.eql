// Dragnet [Ransomware]: dragnet-ransomware-2025-4882 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 960c1602-2610-5c52-a011-58395e9d55f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
