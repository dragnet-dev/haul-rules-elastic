// Dragnet [Ransomware]: dragnet-ransomware-2025-6606 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4d965610-4ec1-59d8-9973-75f94a06d35e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
