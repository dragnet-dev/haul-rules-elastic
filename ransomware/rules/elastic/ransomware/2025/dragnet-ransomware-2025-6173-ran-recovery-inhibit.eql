// Dragnet [Ransomware]: dragnet-ransomware-2025-6173 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 63959ef8-fbb8-5ddb-be3c-5b4f6fe537ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
