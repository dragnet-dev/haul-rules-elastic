// Dragnet [Ransomware]: dragnet-ransomware-2025-6212 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 261021b5-43fc-5dc6-a8d1-77cd4206fbd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
