// Dragnet [Ransomware]: dragnet-ransomware-2025-0983 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: a7255002-5f09-51e9-ad0f-88512d45f46d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
