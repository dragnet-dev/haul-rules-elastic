// Dragnet [Ransomware]: dragnet-ransomware-2025-5164 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: db11fe78-b499-5fb7-8628-94fb06940ffd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
