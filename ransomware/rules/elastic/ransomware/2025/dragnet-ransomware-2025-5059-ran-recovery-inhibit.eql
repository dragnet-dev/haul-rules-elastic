// Dragnet [Ransomware]: dragnet-ransomware-2025-5059 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 3c29c319-40f6-53be-ae0d-328b57338e9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
