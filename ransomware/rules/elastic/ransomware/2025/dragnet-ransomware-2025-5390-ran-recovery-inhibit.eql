// Dragnet [Ransomware]: dragnet-ransomware-2025-5390 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 03ded8a4-7d65-503d-b5a1-ff4e3c88fe3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
