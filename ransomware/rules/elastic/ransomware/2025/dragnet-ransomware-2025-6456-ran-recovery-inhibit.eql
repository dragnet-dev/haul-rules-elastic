// Dragnet [Ransomware]: dragnet-ransomware-2025-6456 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 542d76c6-e8de-511b-a083-4bb060adf27f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
