// Dragnet [Ransomware]: dragnet-ransomware-2025-7381 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 23a07c06-c19a-54b4-8bc9-d9c65d16129a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
