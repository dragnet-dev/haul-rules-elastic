// Dragnet [Ransomware]: dragnet-ransomware-2025-4314 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: f62ac875-b142-5c50-b687-549f505d57cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
