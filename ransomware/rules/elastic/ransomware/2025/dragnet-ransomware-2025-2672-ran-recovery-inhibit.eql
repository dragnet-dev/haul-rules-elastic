// Dragnet [Ransomware]: dragnet-ransomware-2025-2672 — Recovery Inhibition (IMNCrew)
// Status: experimental | Level: high | ID: 899fc7d8-5727-579c-9173-d1d5c18704a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
