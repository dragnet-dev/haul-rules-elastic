// Dragnet [Ransomware]: dragnet-ransomware-2025-5622 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b2889689-6d63-5e3c-9ed8-fb850b594564

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
