// Dragnet [Ransomware]: dragnet-ransomware-2025-7731 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 11f8e024-e7d2-56e1-9319-3f237430bdab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
