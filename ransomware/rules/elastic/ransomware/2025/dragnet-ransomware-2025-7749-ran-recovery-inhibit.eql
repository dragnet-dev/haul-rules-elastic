// Dragnet [Ransomware]: dragnet-ransomware-2025-7749 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3922489e-e85a-5cde-a03f-e88994a40d54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
