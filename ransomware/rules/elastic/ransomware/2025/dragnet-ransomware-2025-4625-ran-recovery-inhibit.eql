// Dragnet [Ransomware]: dragnet-ransomware-2025-4625 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: dd95bafd-38f7-5ad6-9e87-5eb072ecdc29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
