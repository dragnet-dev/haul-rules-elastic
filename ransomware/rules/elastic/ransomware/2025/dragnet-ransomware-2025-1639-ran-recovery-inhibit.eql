// Dragnet [Ransomware]: dragnet-ransomware-2025-1639 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3674a87c-7db5-545b-ba65-86d8f4532c16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
