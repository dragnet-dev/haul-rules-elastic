// Dragnet [Ransomware]: dragnet-ransomware-2025-0537 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f239b71a-4aee-5e80-a49a-fa14f9825b4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
