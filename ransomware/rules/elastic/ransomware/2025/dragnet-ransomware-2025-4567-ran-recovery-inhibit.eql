// Dragnet [Ransomware]: dragnet-ransomware-2025-4567 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 56ba6fbe-9a04-5222-95cd-85c3226468d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
