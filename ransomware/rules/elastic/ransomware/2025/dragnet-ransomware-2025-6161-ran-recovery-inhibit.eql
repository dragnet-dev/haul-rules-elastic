// Dragnet [Ransomware]: dragnet-ransomware-2025-6161 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 8d4ccacd-1465-5fd8-8c95-fde9389fae0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
