// Dragnet [Ransomware]: dragnet-ransomware-2025-1928 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: c155587b-6e18-5065-a1ea-f834abe346b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
