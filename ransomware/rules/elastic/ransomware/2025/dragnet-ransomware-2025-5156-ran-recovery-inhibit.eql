// Dragnet [Ransomware]: dragnet-ransomware-2025-5156 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 59d38996-8f77-5c5d-b3f1-22a5e092f9f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
