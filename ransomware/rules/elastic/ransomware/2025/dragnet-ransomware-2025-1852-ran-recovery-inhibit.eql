// Dragnet [Ransomware]: dragnet-ransomware-2025-1852 — Recovery Inhibition (brotherhood)
// Status: experimental | Level: high | ID: a1820c24-393c-50b6-b502-1c96fa77bb9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
