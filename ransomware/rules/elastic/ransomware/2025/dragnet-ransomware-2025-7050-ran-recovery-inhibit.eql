// Dragnet [Ransomware]: dragnet-ransomware-2025-7050 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: fa81a5fb-9af5-5abf-84ad-466591cdcdff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
