// Dragnet [Ransomware]: dragnet-ransomware-2025-6475 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4d4473be-4934-525a-b26b-97e98ad2564c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
