// Dragnet [Ransomware]: dragnet-ransomware-2025-7868 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 7c4a7593-05dd-53dd-9a28-641c09ec7efe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
