// Dragnet [Ransomware]: dragnet-ransomware-2025-2441 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: c5ac756e-c645-53ae-ba1b-47903fcce94f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
