// Dragnet [Ransomware]: dragnet-ransomware-2025-7052 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8f3bfc8e-e1bb-5525-ba72-44fa742f6a1f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
