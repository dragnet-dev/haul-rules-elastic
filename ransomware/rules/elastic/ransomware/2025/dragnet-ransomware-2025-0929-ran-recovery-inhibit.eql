// Dragnet [Ransomware]: dragnet-ransomware-2025-0929 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: c13e3c96-59ab-589a-8f0b-73116fd3dd9c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
