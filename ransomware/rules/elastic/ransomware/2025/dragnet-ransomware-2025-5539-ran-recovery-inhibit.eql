// Dragnet [Ransomware]: dragnet-ransomware-2025-5539 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 6898a4b2-e28d-563e-b9b6-e481d1da61e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
