// Dragnet [Ransomware]: dragnet-ransomware-2025-3193 — Recovery Inhibition (kraken)
// Status: experimental | Level: high | ID: 82541283-0c94-5ad6-a277-5f3971e8c109

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
