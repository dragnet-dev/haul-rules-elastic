// Dragnet [Ransomware]: dragnet-ransomware-2025-2495 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 03535a9e-b300-53ea-ae64-007374e33463

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
