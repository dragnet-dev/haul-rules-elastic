// Dragnet [Ransomware]: dragnet-ransomware-2025-2912 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 4b3c27e0-1934-5df0-a603-5ebc47a288dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
