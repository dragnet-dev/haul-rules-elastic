// Dragnet [Ransomware]: dragnet-ransomware-2025-5064 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e5057390-1228-56b0-ad87-4d04b1eedb8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
