// Dragnet [Ransomware]: dragnet-ransomware-2025-5667 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 45e18f65-0727-5700-bee4-4393c45e50d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
