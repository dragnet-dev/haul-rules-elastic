// Dragnet [Ransomware]: dragnet-ransomware-2025-1541 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: cafa4646-910b-507c-b867-4c20f3410c0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
