// Dragnet [Ransomware]: dragnet-ransomware-2025-5519 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ce8c9616-3ccf-5543-84bd-f2bdf35405d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
