// Dragnet [Ransomware]: dragnet-ransomware-2025-6431 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: bed933fb-69e1-5555-a937-bc18e275ce54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
