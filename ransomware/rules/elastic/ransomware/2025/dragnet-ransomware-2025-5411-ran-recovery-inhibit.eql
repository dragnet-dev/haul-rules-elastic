// Dragnet [Ransomware]: dragnet-ransomware-2025-5411 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: f149ae24-7c9c-5933-8118-4bcd666d7d05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
