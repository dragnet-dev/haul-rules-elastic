// Dragnet [Ransomware]: dragnet-ransomware-2025-5357 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 93e5b8aa-97b8-5b73-8ae0-ae02ad0e4978

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
