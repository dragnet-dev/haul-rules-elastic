// Dragnet [Ransomware]: dragnet-ransomware-2025-4288 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 70eb1bc4-ac11-5e78-925d-da54a72efe32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
