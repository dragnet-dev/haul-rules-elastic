// Dragnet [Ransomware]: dragnet-ransomware-2025-5862 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: afcbcb27-401b-5194-aa65-b3ed4a8a3b9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
