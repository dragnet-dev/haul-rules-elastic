// Dragnet [Ransomware]: dragnet-ransomware-2025-5782 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: e3e83358-c43b-594c-a14b-28583b82022f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
