// Dragnet [Ransomware]: dragnet-ransomware-2025-2342 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 6746f795-2c53-5e5f-9fc1-8aafa17b5c4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
