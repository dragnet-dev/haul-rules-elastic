// Dragnet [Ransomware]: dragnet-ransomware-2025-6446 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: cf883db6-0399-51d2-9966-c99c65ce4129

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
