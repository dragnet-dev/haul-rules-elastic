// Dragnet [Ransomware]: dragnet-ransomware-2025-6784 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: d7213c36-9018-5491-b762-62030b2efdb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
