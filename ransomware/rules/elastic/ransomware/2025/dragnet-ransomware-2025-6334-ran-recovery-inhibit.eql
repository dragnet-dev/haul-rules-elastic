// Dragnet [Ransomware]: dragnet-ransomware-2025-6334 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5c063e88-ead4-5d24-a4d6-f1d26e8133d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
