// Dragnet [Ransomware]: dragnet-ransomware-2025-6728 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 42945224-57e8-5f2a-a235-27402fd7bbab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
