// Dragnet [Ransomware]: dragnet-ransomware-2025-4619 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8aeabfac-c7c5-5d14-b2ae-d5ca10147fcf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
