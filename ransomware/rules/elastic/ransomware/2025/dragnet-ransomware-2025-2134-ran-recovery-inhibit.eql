// Dragnet [Ransomware]: dragnet-ransomware-2025-2134 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 827886a5-196e-5707-ab69-2ce012080203

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
