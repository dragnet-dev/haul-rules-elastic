// Dragnet [Ransomware]: dragnet-ransomware-2025-3287 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: cbee992e-2ae4-5e14-88b7-61172a1e314c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
