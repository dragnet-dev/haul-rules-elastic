// Dragnet [Ransomware]: dragnet-ransomware-2025-4966 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: fcb8bb38-ed72-5292-91dd-670f8afe980a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
