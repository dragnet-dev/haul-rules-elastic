// Dragnet [Ransomware]: dragnet-ransomware-2025-5839 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 88ad5ce9-2218-51ac-b20c-6242175421bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
