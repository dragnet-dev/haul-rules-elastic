// Dragnet [Ransomware]: dragnet-ransomware-2025-1011 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 411f2d37-bd4f-5ac3-8ea0-9ca1ecbf9401

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
