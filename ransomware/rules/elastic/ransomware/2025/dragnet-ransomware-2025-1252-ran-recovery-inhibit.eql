// Dragnet [Ransomware]: dragnet-ransomware-2025-1252 — Recovery Inhibition (kawa4096)
// Status: deprecated | Level: high | ID: bb9360ec-9d56-5f32-8ed4-f37553dfe2f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
