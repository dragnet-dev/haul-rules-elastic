// Dragnet [Ransomware]: dragnet-ransomware-2025-5448 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f378bc6a-8a8b-5270-81ab-15614387303c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
