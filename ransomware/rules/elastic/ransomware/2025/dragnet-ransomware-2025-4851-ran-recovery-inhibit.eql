// Dragnet [Ransomware]: dragnet-ransomware-2025-4851 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: 17a5c7c4-66a5-5570-8716-4ae25afc36dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
