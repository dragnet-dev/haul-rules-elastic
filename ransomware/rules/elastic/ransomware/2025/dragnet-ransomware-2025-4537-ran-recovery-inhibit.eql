// Dragnet [Ransomware]: dragnet-ransomware-2025-4537 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 9860b412-f848-5a7c-b8f4-0ab5e8de0331

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
