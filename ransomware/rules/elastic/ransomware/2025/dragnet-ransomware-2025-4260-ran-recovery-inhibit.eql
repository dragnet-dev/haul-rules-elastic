// Dragnet [Ransomware]: dragnet-ransomware-2025-4260 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 47b97389-4e76-5e31-b07c-5b7823fd7853

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
