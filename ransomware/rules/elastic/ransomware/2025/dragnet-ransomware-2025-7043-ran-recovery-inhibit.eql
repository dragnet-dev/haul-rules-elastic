// Dragnet [Ransomware]: dragnet-ransomware-2025-7043 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 48ce6477-38a5-59f8-9f61-5dcc97ad1eb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
