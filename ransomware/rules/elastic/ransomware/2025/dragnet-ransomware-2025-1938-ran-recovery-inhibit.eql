// Dragnet [Ransomware]: dragnet-ransomware-2025-1938 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: d0bf2f89-dddc-506b-94c1-11080f3691ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
