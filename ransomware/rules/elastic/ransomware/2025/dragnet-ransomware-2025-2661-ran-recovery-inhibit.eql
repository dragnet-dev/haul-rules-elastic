// Dragnet [Ransomware]: dragnet-ransomware-2025-2661 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: defc7069-131a-5064-86e3-022533ecbd42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
