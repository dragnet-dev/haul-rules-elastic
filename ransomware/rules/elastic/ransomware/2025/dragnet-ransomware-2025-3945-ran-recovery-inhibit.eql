// Dragnet [Ransomware]: dragnet-ransomware-2025-3945 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 75cc503b-2490-5a58-87b0-fabcc6967e24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
