// Dragnet [Ransomware]: dragnet-ransomware-2025-2645 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 5cf3c907-2db4-5ed7-9aa6-1c58b81ac846

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
