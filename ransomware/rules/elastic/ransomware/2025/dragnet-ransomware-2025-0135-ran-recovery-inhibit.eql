// Dragnet [Ransomware]: dragnet-ransomware-2025-0135 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: b5e0a50d-995c-5d93-bd36-7cc4a27e7165

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
