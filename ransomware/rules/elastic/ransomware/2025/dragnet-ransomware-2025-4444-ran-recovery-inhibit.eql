// Dragnet [Ransomware]: dragnet-ransomware-2025-4444 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 3cb8e0e9-3bed-59dd-8275-25b81efb655a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
