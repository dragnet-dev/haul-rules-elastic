// Dragnet [Ransomware]: dragnet-ransomware-2025-1924 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: b68457fa-ea56-5647-83e6-bbe37b2bf0f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
