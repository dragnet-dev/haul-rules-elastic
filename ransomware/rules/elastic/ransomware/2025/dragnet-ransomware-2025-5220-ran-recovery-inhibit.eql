// Dragnet [Ransomware]: dragnet-ransomware-2025-5220 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: d1d1b4f9-63df-5e8e-bb7f-87251836cb7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
