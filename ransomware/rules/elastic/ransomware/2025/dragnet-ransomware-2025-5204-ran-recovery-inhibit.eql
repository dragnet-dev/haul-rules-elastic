// Dragnet [Ransomware]: dragnet-ransomware-2025-5204 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 30b444a1-c97f-5098-a522-e909a1a594c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
