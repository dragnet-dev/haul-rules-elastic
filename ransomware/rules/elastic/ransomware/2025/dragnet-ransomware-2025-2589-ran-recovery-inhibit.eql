// Dragnet [Ransomware]: dragnet-ransomware-2025-2589 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: c81fe6b4-b9a9-5533-b2c8-066547c02432

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
