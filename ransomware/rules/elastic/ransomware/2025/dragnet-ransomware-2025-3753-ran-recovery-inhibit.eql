// Dragnet [Ransomware]: dragnet-ransomware-2025-3753 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 907420b4-b8c7-5c92-9a5b-ac5e9ea23b90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
