// Dragnet [Ransomware]: dragnet-ransomware-2025-2400 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 0d6c2923-fa0a-5d74-9cfc-8c28a7f53693

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
