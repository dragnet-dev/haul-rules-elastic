// Dragnet [Ransomware]: dragnet-ransomware-2025-1229 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e779d31f-ea18-5f28-8ba1-05155d9909bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
