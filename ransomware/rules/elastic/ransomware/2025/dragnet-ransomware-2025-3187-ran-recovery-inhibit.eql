// Dragnet [Ransomware]: dragnet-ransomware-2025-3187 — Recovery Inhibition (handala)
// Status: test | Level: high | ID: 3d53472e-291a-5692-814c-31c3e09c2fcf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
