// Dragnet [Ransomware]: dragnet-ransomware-2025-6959 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 7164adc8-b06c-525b-b12a-f37fb05e7540

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
