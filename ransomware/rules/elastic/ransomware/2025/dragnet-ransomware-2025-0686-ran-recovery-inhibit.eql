// Dragnet [Ransomware]: dragnet-ransomware-2025-0686 — Recovery Inhibition (teamxxx)
// Status: experimental | Level: high | ID: 121ffae9-1795-50fd-8675-d82046adaa98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
