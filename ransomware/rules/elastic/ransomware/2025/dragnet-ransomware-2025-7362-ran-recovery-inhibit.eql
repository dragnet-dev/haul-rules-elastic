// Dragnet [Ransomware]: dragnet-ransomware-2025-7362 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 646197d9-dd14-5cf4-8cde-567c1c7601fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
