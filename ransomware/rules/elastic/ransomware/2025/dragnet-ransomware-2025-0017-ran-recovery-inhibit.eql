// Dragnet [Ransomware]: dragnet-ransomware-2025-0017 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 33348f5d-7ea5-52c6-8245-fdde526312b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
