// Dragnet [Ransomware]: dragnet-ransomware-2025-2261 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 9ea86e2c-c386-5951-975c-f73fae448b6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
