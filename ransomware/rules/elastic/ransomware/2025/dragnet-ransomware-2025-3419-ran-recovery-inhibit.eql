// Dragnet [Ransomware]: dragnet-ransomware-2025-3419 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8ecac7bd-27f1-5b45-9067-f862aa1f9ea1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
