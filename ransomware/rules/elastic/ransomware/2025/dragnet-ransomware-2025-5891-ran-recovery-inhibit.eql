// Dragnet [Ransomware]: dragnet-ransomware-2025-5891 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 197852f3-d228-5415-8172-d29749c662f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
