// Dragnet [Ransomware]: dragnet-ransomware-2025-6071 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 973d22cc-cff0-5e13-bdba-590279f866aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
