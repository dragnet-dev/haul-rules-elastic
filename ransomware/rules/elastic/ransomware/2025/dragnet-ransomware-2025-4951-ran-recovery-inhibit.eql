// Dragnet [Ransomware]: dragnet-ransomware-2025-4951 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: d125b1bf-ddb6-5b26-a9e9-980edcd164d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
