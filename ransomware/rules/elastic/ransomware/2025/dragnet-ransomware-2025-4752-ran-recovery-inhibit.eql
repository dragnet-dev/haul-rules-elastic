// Dragnet [Ransomware]: dragnet-ransomware-2025-4752 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 05d5fb51-f2eb-5120-b940-5dfab2fa954b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
