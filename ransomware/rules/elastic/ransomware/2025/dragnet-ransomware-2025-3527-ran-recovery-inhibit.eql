// Dragnet [Ransomware]: dragnet-ransomware-2025-3527 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: d353068d-b761-5f80-b77c-3d2ce4fca1f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
