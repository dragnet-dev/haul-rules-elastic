// Dragnet [Ransomware]: dragnet-ransomware-2025-0627 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 1b2c4c42-9af3-5d12-a2a6-fef3e054a09f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
