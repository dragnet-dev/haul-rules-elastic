// Dragnet [Ransomware]: dragnet-ransomware-2025-6171 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: 57baf5a5-39b8-52e5-b88b-24653a1e1888

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
