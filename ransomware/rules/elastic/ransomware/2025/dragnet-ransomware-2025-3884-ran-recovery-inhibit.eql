// Dragnet [Ransomware]: dragnet-ransomware-2025-3884 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 7c2c1981-c2ad-5754-9130-733dedf58164

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
