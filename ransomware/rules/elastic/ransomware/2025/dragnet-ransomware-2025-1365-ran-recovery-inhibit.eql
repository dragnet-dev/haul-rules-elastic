// Dragnet [Ransomware]: dragnet-ransomware-2025-1365 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 79f43eaa-03c8-56ed-b4cb-972ea6c5174a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
