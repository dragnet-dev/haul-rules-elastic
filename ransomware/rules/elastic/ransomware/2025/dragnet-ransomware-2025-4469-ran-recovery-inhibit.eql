// Dragnet [Ransomware]: dragnet-ransomware-2025-4469 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 327e4f53-5d22-5c6c-8429-3339183ed269

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
