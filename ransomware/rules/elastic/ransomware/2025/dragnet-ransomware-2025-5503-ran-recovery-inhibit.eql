// Dragnet [Ransomware]: dragnet-ransomware-2025-5503 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 1b68192f-908c-5b78-b37c-8fb7041f3dc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
