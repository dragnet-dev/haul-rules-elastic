// Dragnet [Ransomware]: dragnet-ransomware-2025-0665 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c1647ddd-147b-523e-826b-6b8ac044be27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
