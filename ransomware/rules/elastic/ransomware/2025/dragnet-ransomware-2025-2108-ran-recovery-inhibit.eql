// Dragnet [Ransomware]: dragnet-ransomware-2025-2108 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: eb50b649-6cbb-5177-b3b2-dd2772232776

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
