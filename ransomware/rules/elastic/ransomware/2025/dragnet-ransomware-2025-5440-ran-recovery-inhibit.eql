// Dragnet [Ransomware]: dragnet-ransomware-2025-5440 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2e7f889e-6296-5457-9d5a-646647ec3e67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
