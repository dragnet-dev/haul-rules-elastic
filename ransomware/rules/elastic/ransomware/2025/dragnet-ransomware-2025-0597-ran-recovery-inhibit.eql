// Dragnet [Ransomware]: dragnet-ransomware-2025-0597 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2b012bc0-4ab9-55a1-803e-1145e15dedea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
