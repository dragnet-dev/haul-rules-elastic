// Dragnet [Ransomware]: dragnet-ransomware-2025-3596 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: bf089891-2d54-5046-a26d-b691bc39e591

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
