// Dragnet [Ransomware]: dragnet-ransomware-2025-4716 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: b8dbd521-e72d-5a55-ad2d-e7c52fdb58b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
