// Dragnet [Ransomware]: dragnet-ransomware-2025-1104 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: cb7b69dd-2947-527c-ad67-042afa569df5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
