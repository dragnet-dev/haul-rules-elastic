// Dragnet [Ransomware]: dragnet-ransomware-2025-0972 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a6dbd8c8-3332-501b-ba46-ec0cc50c068e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
