// Dragnet [Ransomware]: dragnet-ransomware-2025-5398 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: f95e7e14-6fa8-5d43-9112-27dcecece03a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
