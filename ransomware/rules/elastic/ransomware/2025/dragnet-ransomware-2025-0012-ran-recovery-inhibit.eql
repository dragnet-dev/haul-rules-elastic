// Dragnet [Ransomware]: dragnet-ransomware-2025-0012 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8e2d7090-644a-5e8a-aea8-15cfb18a9a4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
