// Dragnet [Ransomware]: dragnet-ransomware-2025-7681 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: bb2791e4-870f-537b-8586-beb701cddf3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
