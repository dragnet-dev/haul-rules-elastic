// Dragnet [Ransomware]: dragnet-ransomware-2025-3703 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: a600fdf6-8da7-55dc-8ef4-5092b5c91d1f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
