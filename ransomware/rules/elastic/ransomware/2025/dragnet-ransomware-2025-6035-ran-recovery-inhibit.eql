// Dragnet [Ransomware]: dragnet-ransomware-2025-6035 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: 923c5406-6ba9-5643-953c-5a48c09ae9fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
