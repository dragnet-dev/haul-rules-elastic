// Dragnet [Ransomware]: dragnet-ransomware-2025-0826 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 67005ea5-0ad0-57b1-af97-a77582670346

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
