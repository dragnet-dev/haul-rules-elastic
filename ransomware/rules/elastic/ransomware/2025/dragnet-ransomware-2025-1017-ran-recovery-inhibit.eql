// Dragnet [Ransomware]: dragnet-ransomware-2025-1017 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6e50c3f9-37f6-5862-8b0c-0055cbe581b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
