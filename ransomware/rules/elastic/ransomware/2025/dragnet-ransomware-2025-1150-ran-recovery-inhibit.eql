// Dragnet [Ransomware]: dragnet-ransomware-2025-1150 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 511179c2-378d-5962-8b8e-a5568fe94b57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
