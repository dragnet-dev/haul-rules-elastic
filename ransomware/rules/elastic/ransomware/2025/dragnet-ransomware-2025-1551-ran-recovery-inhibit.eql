// Dragnet [Ransomware]: dragnet-ransomware-2025-1551 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 4e7987a0-96a3-5710-a988-672046aa1414

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
