// Dragnet [Ransomware]: dragnet-ransomware-2025-6980 — Recovery Inhibition (securotrop)
// Status: experimental | Level: high | ID: 9039052e-e293-504f-920b-e15f270a72b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
