// Dragnet [Ransomware]: dragnet-ransomware-2025-2380 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 7f7d904a-992e-5184-8df6-c13d758fae88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
