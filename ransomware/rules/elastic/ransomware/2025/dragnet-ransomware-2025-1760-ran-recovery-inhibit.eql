// Dragnet [Ransomware]: dragnet-ransomware-2025-1760 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 188b1c51-34e8-543f-9017-02f4157fd630

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
