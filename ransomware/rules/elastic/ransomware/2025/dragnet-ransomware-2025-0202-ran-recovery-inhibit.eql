// Dragnet [Ransomware]: dragnet-ransomware-2025-0202 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: dc0e9a04-1adb-568c-a37b-3180657c1785

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
