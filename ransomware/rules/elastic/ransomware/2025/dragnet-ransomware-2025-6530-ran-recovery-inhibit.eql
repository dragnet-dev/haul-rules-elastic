// Dragnet [Ransomware]: dragnet-ransomware-2025-6530 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 67bd456d-17ab-53f1-8294-6b52b0765023

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
