// Dragnet [Ransomware]: dragnet-ransomware-2025-1927 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2f89a84d-a4d9-525a-8c92-2a5b28412ba1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
