// Dragnet [Ransomware]: dragnet-ransomware-2025-7109 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 4c3874a0-daa6-5e8a-ad1b-488614b41e2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
