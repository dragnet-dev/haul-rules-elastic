// Dragnet [Ransomware]: dragnet-ransomware-2025-5209 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 2643017d-f7dc-5829-84bc-385df0f16252

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
