// Dragnet [Ransomware]: dragnet-ransomware-2025-6401 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: c1c06616-d165-536d-bcff-3b44365db44a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
