// Dragnet [Ransomware]: dragnet-ransomware-2025-4269 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: 2912db6a-81f4-5047-9bdc-4866e125213e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
