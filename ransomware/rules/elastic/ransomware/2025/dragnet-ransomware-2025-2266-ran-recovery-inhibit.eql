// Dragnet [Ransomware]: dragnet-ransomware-2025-2266 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: c929771b-977d-594b-a589-35d27e9f3c7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
