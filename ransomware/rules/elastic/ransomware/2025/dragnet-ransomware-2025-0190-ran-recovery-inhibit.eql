// Dragnet [Ransomware]: dragnet-ransomware-2025-0190 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ea7515b9-1e99-5855-a696-b2cfea9772e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
