// Dragnet [Ransomware]: dragnet-ransomware-2025-2931 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c134063d-289f-5fde-9340-e0f475f3577c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
