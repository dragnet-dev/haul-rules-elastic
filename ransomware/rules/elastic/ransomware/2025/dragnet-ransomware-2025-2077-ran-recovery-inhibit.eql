// Dragnet [Ransomware]: dragnet-ransomware-2025-2077 — Recovery Inhibition (blackshrantac)
// Status: experimental | Level: high | ID: cc68f2a2-4d33-564b-9378-c821c897c851

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
