// Dragnet [Ransomware]: dragnet-ransomware-2025-7620 — Recovery Inhibition (frag)
// Status: deprecated | Level: high | ID: 181ccc73-6069-5246-b0e6-c68373cc5368

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
