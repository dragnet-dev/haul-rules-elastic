// Dragnet [Ransomware]: dragnet-ransomware-2025-0023 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 96ab369f-c05b-54c0-bb75-6519a5966263

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
