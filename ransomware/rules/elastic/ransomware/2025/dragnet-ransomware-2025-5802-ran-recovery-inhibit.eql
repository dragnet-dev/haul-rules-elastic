// Dragnet [Ransomware]: dragnet-ransomware-2025-5802 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0ff21239-c8fa-5d2a-98b2-48bda9945084

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
