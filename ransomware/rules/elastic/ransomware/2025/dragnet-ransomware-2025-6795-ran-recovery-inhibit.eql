// Dragnet [Ransomware]: dragnet-ransomware-2025-6795 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 16d4a3d2-87d7-582e-822b-98a5ff9e80c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
