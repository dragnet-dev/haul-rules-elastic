// Dragnet [Ransomware]: dragnet-ransomware-2025-6810 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 96da5076-41e4-59f0-ac0c-264c72e995c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
