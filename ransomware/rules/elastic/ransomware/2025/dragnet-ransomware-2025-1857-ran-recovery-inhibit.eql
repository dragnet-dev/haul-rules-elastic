// Dragnet [Ransomware]: dragnet-ransomware-2025-1857 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 8e8139a6-bcb2-5fef-b6b9-8c8f3b821625

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
