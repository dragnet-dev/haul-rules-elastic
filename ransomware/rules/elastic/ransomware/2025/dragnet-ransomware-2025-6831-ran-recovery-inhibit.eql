// Dragnet [Ransomware]: dragnet-ransomware-2025-6831 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 62e0697a-17a0-5936-b8b8-385c9470c83c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
