// Dragnet [Ransomware]: dragnet-ransomware-2025-5117 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: a715d8af-42f5-51e0-9e94-cecc67687890

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
