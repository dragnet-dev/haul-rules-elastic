// Dragnet [Ransomware]: dragnet-ransomware-2025-1261 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: dc7fcb68-500c-5ea6-9150-3185bfe1498c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
