// Dragnet [Ransomware]: dragnet-ransomware-2025-1226 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 4e2f8f7b-dff3-5442-94e6-f0a743c65909

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
