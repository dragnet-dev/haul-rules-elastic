// Dragnet [Ransomware]: dragnet-ransomware-2025-7748 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4cd540df-1754-592d-8356-28c557e546ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
