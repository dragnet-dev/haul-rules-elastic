// Dragnet [Ransomware]: dragnet-ransomware-2025-0166 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 59d0791d-dd36-599f-899f-23add9719177

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
