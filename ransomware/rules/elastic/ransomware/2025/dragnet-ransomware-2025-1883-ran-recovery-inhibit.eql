// Dragnet [Ransomware]: dragnet-ransomware-2025-1883 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 484e2be5-7d48-551a-a1ed-099d6da20bbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
