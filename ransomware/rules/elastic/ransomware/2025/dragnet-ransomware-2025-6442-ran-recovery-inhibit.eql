// Dragnet [Ransomware]: dragnet-ransomware-2025-6442 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 8d7bf94c-4fba-542c-ae51-6fd7a841dc85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
