// Dragnet [Ransomware]: dragnet-ransomware-2025-4844 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ee65182a-4bf3-57fa-b9ec-cae98a411a02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
