// Dragnet [Ransomware]: dragnet-ransomware-2025-4481 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 58376eca-378f-5bf4-9b4b-508b1c9ffcf6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
