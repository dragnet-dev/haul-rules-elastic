// Dragnet [Ransomware]: dragnet-ransomware-2025-3802 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3883d0f3-6cd4-5db1-be89-bb101bcc5a97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
