// Dragnet [Ransomware]: dragnet-ransomware-2025-1770 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: a48577c2-0498-56c9-b002-84b93124e962

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
