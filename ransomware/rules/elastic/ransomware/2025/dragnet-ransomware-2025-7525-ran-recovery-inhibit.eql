// Dragnet [Ransomware]: dragnet-ransomware-2025-7525 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 64689a0c-7329-5d68-80a0-d13024c1eabd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
