// Dragnet [Ransomware]: dragnet-ransomware-2025-6332 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 037682c5-79d9-536d-932b-ac94afc273d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
