// Dragnet [Ransomware]: dragnet-ransomware-2025-6888 — Recovery Inhibition (minteye)
// Status: deprecated | Level: high | ID: cd3f9cf2-9d51-58c0-9e55-e54eb7506578

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
