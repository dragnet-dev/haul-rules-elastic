// Dragnet [Ransomware]: dragnet-ransomware-2025-1000 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 97f81541-52ac-551a-a118-21af38c51c8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
