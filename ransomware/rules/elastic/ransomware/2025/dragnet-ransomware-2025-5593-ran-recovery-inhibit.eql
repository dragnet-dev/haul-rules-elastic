// Dragnet [Ransomware]: dragnet-ransomware-2025-5593 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: f63e34f9-88a4-50c8-a889-5c1f835b165a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
