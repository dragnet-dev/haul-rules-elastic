// Dragnet [Ransomware]: dragnet-ransomware-2025-6610 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: 91bdd1b9-884e-5282-9d03-16cf68f502da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
