// Dragnet [Ransomware]: dragnet-ransomware-2025-0560 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 6feb4e65-b5f5-5ed1-a252-a74be4c36c9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
