// Dragnet [Ransomware]: dragnet-ransomware-2025-7074 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: dc8e00e0-d2e6-5453-8840-f98ccf836cd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
