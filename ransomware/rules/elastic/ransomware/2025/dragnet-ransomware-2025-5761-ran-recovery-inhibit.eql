// Dragnet [Ransomware]: dragnet-ransomware-2025-5761 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 30c721f9-cff2-55a3-b88f-b16342791746

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
