// Dragnet [Ransomware]: dragnet-ransomware-2025-4801 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 025fd5cc-b9e0-559f-ac64-844bcf175826

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
