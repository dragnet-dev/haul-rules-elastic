// Dragnet [Ransomware]: dragnet-ransomware-2025-7199 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 9ef03d63-952b-5a43-bc49-c7b31270f21a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
