// Dragnet [Ransomware]: dragnet-ransomware-2025-6467 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 619b0b3c-6477-5ae4-9fcc-61ea4195852e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
