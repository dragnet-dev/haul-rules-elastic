// Dragnet [Ransomware]: dragnet-ransomware-2025-4086 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 9dbfdd5e-4f62-5c8b-9184-df24828ab9ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
