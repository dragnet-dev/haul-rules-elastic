// Dragnet [Ransomware]: dragnet-ransomware-2025-1563 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: b705630f-9bbd-59a6-99b0-4203234d3983

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
