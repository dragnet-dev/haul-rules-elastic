// Dragnet [Ransomware]: dragnet-ransomware-2025-2583 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f98e203c-e373-5b29-8a56-5089dbb1bd89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
