// Dragnet [Ransomware]: dragnet-ransomware-2025-6044 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 9f483950-66ca-584f-b96f-462384556315

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
