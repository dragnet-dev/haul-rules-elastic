// Dragnet [Ransomware]: dragnet-ransomware-2025-5362 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3e896620-a0ca-5e39-8ed3-b1fab378f87e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
