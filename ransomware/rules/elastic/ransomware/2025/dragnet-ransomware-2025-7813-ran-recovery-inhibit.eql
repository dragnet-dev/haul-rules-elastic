// Dragnet [Ransomware]: dragnet-ransomware-2025-7813 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 274321a4-b33d-5123-8983-d7c354220e0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
