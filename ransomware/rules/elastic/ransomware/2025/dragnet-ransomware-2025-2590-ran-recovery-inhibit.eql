// Dragnet [Ransomware]: dragnet-ransomware-2025-2590 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: c717e123-9f2b-5140-b020-00bd38c236e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
