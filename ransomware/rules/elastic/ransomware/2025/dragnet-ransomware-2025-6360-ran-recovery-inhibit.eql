// Dragnet [Ransomware]: dragnet-ransomware-2025-6360 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: a970f431-4209-5ce6-a4c9-37cd31532c72

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
