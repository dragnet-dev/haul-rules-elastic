// Dragnet [Ransomware]: dragnet-ransomware-2025-5736 — Recovery Inhibition (radar)
// Status: deprecated | Level: high | ID: 53059b4f-bff1-5975-a356-676ac9d026b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
