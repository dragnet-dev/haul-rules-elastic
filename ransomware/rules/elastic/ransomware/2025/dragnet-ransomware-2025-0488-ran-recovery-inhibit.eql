// Dragnet [Ransomware]: dragnet-ransomware-2025-0488 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 2db5b058-bceb-5c22-a966-3e17f4cebc13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
