// Dragnet [Ransomware]: dragnet-ransomware-2025-7048 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ee6e3254-6638-57a4-8b31-a35961d571b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
