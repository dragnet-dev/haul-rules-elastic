// Dragnet [Ransomware]: dragnet-ransomware-2025-4479 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ccdbef70-1d43-5553-91fc-e3b543c23328

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
