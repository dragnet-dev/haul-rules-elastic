// Dragnet [Ransomware]: dragnet-ransomware-2025-1553 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 62590ba2-7274-5573-81ec-a53ae32a838b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
