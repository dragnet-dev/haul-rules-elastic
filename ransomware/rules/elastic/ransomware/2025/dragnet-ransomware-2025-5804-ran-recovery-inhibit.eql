// Dragnet [Ransomware]: dragnet-ransomware-2025-5804 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 81f67bd9-6a54-5de8-b5a7-6f969c60e894

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
