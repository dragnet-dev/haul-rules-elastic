// Dragnet [Ransomware]: dragnet-ransomware-2025-4902 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b4a5fc83-42a7-504a-acd2-f1b825ce8635

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
