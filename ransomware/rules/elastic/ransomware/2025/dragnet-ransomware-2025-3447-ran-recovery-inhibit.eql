// Dragnet [Ransomware]: dragnet-ransomware-2025-3447 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d4ad6ecd-26d6-5a41-a9e9-fe6944230d3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
