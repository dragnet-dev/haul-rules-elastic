// Dragnet [Ransomware]: dragnet-ransomware-2025-2737 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 5f3ec982-e648-5150-b453-ef157749599b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
