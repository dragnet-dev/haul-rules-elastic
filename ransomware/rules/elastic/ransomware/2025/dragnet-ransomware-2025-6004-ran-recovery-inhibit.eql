// Dragnet [Ransomware]: dragnet-ransomware-2025-6004 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: f5b8f485-b0d9-56bd-b90a-5112186df85a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
