// Dragnet [Ransomware]: dragnet-ransomware-2025-7912 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: e16f979e-2d12-5716-89ae-d87882fb9cb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
