// Dragnet [Ransomware]: dragnet-ransomware-2025-1512 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5567baf5-f78d-5c65-9797-efb295ef2a58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
