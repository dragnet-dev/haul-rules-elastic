// Dragnet [Ransomware]: dragnet-ransomware-2025-7240 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7b704e93-6405-55e0-959a-fe597e05bcad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
