// Dragnet [Ransomware]: dragnet-ransomware-2025-1957 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 81ee25fd-7d35-5180-9293-d97d933ccf4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
