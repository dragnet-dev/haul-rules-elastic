// Dragnet [Ransomware]: dragnet-ransomware-2025-3072 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f7474681-1b9b-59b0-98f3-b48c58039caa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
