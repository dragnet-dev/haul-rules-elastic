// Dragnet [Ransomware]: dragnet-ransomware-2025-7530 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: e9ba1f9a-5dcc-56ad-95ef-59817fd9ee35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
