// Dragnet [Ransomware]: dragnet-ransomware-2025-3216 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 61910a47-415e-5a30-8df7-8cf319dbcd2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
