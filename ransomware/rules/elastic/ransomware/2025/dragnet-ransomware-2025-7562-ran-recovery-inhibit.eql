// Dragnet [Ransomware]: dragnet-ransomware-2025-7562 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 9fb1b6c4-3e5e-5a6c-a848-82802010e4dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
