// Dragnet [Ransomware]: dragnet-ransomware-2025-1228 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f616b1b9-c397-552c-8b04-458dd59d7f08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
