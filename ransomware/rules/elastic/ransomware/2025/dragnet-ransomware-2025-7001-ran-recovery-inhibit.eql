// Dragnet [Ransomware]: dragnet-ransomware-2025-7001 — Recovery Inhibition (akira)
// Status: experimental | Level: high | ID: ab0dfe6e-3a74-5f42-abb7-b07cdac7446b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
