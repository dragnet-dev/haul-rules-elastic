// Dragnet [Ransomware]: dragnet-ransomware-2025-6086 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 9eb84c6f-5ad7-5e8c-8f02-964ca37193b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
