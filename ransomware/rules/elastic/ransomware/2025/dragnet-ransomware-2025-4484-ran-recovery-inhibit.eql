// Dragnet [Ransomware]: dragnet-ransomware-2025-4484 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 01971614-9ea8-571c-8aab-20d67ddc3b79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
