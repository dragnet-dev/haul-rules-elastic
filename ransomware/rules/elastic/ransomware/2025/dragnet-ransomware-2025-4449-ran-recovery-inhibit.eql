// Dragnet [Ransomware]: dragnet-ransomware-2025-4449 — Recovery Inhibition (kawa4096)
// Status: experimental | Level: high | ID: bb701438-71b6-5381-89bc-8170c137e73a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
