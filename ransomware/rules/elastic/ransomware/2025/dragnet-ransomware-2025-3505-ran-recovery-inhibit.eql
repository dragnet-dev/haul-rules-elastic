// Dragnet [Ransomware]: dragnet-ransomware-2025-3505 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 1c795e2e-cdb8-51bf-b381-b0745dc1e112

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
