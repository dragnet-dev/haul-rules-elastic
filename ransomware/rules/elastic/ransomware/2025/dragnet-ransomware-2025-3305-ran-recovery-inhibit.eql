// Dragnet [Ransomware]: dragnet-ransomware-2025-3305 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: e98b4ec8-861a-5995-b58e-7961ebb2606a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
