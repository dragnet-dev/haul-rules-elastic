// Dragnet [Ransomware]: dragnet-ransomware-2025-1257 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: c78771d4-dd47-592d-996b-c063e3e657a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
