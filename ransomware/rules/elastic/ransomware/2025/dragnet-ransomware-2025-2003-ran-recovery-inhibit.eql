// Dragnet [Ransomware]: dragnet-ransomware-2025-2003 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d26af3a2-dde7-506b-b137-f2328d6d26c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
