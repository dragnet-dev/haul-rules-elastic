// Dragnet [Ransomware]: dragnet-ransomware-2025-1337 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e418a9e2-8dc9-59f3-acd3-a5d0db8da7a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
