// Dragnet [Ransomware]: dragnet-ransomware-2025-4833 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 69d1e7a7-7ed4-5fb1-86de-f418842f4897

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
