// Dragnet [Ransomware]: dragnet-ransomware-2025-5646 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 81a1b2dd-4d02-50aa-8fb0-cedb2102da19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
