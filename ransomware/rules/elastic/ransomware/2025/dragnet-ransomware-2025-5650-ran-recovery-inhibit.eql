// Dragnet [Ransomware]: dragnet-ransomware-2025-5650 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: e6fe51b1-5c73-51ba-9b9a-fdba440988a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
