// Dragnet [Ransomware]: dragnet-ransomware-2025-7007 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: b375b2aa-8084-505d-a445-a82944d7c94b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
