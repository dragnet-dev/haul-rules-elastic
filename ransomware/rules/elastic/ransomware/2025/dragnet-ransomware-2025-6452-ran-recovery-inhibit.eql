// Dragnet [Ransomware]: dragnet-ransomware-2025-6452 — Recovery Inhibition (fog)
// Status: deprecated | Level: high | ID: 76cc37cb-b8bf-5455-a380-7a1938303bfa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
