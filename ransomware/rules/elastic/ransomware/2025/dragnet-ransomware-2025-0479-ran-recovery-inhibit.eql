// Dragnet [Ransomware]: dragnet-ransomware-2025-0479 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 2c41cea6-8bf9-5484-a53a-ee5346b9519d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
