// Dragnet [Ransomware]: dragnet-ransomware-2025-5873 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 2d8ae595-6fc6-5920-9502-f89f5560be45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
