// Dragnet [Ransomware]: dragnet-ransomware-2025-1245 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: bde786dd-2892-57f5-8a6a-a7227aaff947

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
