// Dragnet [Ransomware]: dragnet-ransomware-2025-4071 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7dc2608c-de42-5f80-973a-77aa29c79725

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
