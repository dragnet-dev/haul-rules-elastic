// Dragnet [Ransomware]: dragnet-ransomware-2025-0968 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bb191da9-71f9-5586-bee3-0d006f671cf6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
