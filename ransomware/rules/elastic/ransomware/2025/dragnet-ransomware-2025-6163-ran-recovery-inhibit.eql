// Dragnet [Ransomware]: dragnet-ransomware-2025-6163 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: df746363-5aba-5ce7-aa29-9db251318cc9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
