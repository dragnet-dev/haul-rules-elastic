// Dragnet [Ransomware]: dragnet-ransomware-2025-4631 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: bcc66f65-5b69-50d9-a17c-01fe559c2c2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
