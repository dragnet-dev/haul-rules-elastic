// Dragnet [Ransomware]: dragnet-ransomware-2025-1754 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4ab989dc-6cd0-5234-92c1-2e47cfa3827c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
