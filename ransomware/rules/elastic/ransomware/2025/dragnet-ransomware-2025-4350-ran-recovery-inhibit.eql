// Dragnet [Ransomware]: dragnet-ransomware-2025-4350 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0063d74c-6482-5bd9-a803-ae967ad969dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
