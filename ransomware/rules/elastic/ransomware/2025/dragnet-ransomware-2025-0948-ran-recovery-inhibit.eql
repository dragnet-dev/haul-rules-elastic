// Dragnet [Ransomware]: dragnet-ransomware-2025-0948 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 24b0c021-f1f3-565d-a6b9-5410df9bb01b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
