// Dragnet [Ransomware]: dragnet-ransomware-2025-7331 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: e5769bf5-cc34-57a0-a899-7f274132d5e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
