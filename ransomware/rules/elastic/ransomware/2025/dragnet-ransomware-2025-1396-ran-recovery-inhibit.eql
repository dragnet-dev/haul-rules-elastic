// Dragnet [Ransomware]: dragnet-ransomware-2025-1396 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 4bb12be9-e8ff-53cc-a84f-dafaca2e3f3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
