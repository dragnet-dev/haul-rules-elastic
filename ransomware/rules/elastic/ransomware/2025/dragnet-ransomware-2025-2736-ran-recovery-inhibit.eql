// Dragnet [Ransomware]: dragnet-ransomware-2025-2736 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: a808ade7-3df5-5568-88c6-9bc179af74ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
