// Dragnet [Ransomware]: dragnet-ransomware-2025-0640 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 6edb1816-06d3-5025-8ab8-47000aeb674f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
