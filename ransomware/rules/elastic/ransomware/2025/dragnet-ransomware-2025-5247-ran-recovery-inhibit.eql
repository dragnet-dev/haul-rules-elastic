// Dragnet [Ransomware]: dragnet-ransomware-2025-5247 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 40d4968f-fd49-5b7e-b73a-ef50dcd2cd80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
