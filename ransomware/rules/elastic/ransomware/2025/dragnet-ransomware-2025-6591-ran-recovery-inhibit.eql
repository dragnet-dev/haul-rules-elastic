// Dragnet [Ransomware]: dragnet-ransomware-2025-6591 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: cd801961-732b-5e24-832d-d2004b61f3c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
