// Dragnet [Ransomware]: dragnet-ransomware-2025-2630 — Recovery Inhibition (d4rk4rmy)
// Status: deprecated | Level: high | ID: 97efb071-55d6-5260-a64e-19a81b9218bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
