// Dragnet [Ransomware]: dragnet-ransomware-2025-2579 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 4294bb6d-8850-5a4b-9eb4-f77423b31754

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
