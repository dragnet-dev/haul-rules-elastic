// Dragnet [Ransomware]: dragnet-ransomware-2025-0689 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 58ad2e31-b79a-5927-9ce9-8567c23f5211

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
