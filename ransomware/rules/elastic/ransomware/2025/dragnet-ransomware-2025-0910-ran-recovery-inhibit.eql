// Dragnet [Ransomware]: dragnet-ransomware-2025-0910 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 926a95b2-9df4-565a-9cb4-7b29026318c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
