// Dragnet [Ransomware]: dragnet-ransomware-2025-7650 — Recovery Inhibition (tengu)
// Status: experimental | Level: high | ID: 60951e33-2ad9-530e-ad9a-6221f9b950c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
