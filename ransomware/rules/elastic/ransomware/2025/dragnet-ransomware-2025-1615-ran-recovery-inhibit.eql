// Dragnet [Ransomware]: dragnet-ransomware-2025-1615 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 3b44a712-d362-521e-838c-b5a93605b1ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
