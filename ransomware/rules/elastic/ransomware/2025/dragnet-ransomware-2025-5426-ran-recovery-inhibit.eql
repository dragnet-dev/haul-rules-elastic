// Dragnet [Ransomware]: dragnet-ransomware-2025-5426 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: fd3aecf8-6aca-53ae-a3ca-2c78fff66420

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
