// Dragnet [Ransomware]: dragnet-ransomware-2025-4689 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ea13ce87-7517-5735-8560-3965efedfe22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
