// Dragnet [Ransomware]: dragnet-ransomware-2025-6316 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e138adff-a92e-58ee-b2e0-d9750ec3285b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
