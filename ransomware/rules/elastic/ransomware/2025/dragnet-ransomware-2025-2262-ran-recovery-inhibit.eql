// Dragnet [Ransomware]: dragnet-ransomware-2025-2262 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 778f483d-3810-53f5-9dc1-9d200233eaee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
