// Dragnet [Ransomware]: dragnet-ransomware-2025-2275 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c66dc4a7-543e-5075-993e-9d73d9b129a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
