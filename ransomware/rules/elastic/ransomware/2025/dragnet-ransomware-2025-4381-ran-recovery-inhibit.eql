// Dragnet [Ransomware]: dragnet-ransomware-2025-4381 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8e4e8253-57bb-5b9a-9cb4-def0209ad337

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
