// Dragnet [Ransomware]: dragnet-ransomware-2025-0935 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: b2afc9b5-0ed8-5a64-b493-b8a39a2b5932

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
