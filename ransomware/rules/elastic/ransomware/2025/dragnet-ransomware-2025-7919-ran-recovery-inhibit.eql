// Dragnet [Ransomware]: dragnet-ransomware-2025-7919 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: d0e66817-0c0f-504d-aa7f-560351402f94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
