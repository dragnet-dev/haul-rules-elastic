// Dragnet [Ransomware]: dragnet-ransomware-2025-2307 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d8d73397-867a-59d8-8c65-58128aa336a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
