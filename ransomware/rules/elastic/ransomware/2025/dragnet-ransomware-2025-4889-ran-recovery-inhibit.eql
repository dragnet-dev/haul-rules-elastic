// Dragnet [Ransomware]: dragnet-ransomware-2025-4889 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9841e045-11f5-5865-902a-7affa4eeb78d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
