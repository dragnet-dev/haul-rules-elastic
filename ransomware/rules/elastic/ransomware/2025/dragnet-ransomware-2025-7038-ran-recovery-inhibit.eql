// Dragnet [Ransomware]: dragnet-ransomware-2025-7038 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: b4299432-df1c-58ee-a839-cff76723ce01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
