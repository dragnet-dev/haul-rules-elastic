// Dragnet [Ransomware]: dragnet-ransomware-2025-3736 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 38851911-ff9f-5f74-b0a5-ca5f392d2fb3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
