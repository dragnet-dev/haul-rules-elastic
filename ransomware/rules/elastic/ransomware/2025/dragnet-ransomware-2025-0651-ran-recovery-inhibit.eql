// Dragnet [Ransomware]: dragnet-ransomware-2025-0651 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 1e5618b2-e768-5c1c-8d41-3211d18b8bfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
