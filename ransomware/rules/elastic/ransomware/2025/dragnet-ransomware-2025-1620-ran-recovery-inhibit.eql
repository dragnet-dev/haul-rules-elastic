// Dragnet [Ransomware]: dragnet-ransomware-2025-1620 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 754fc899-c05f-5ab4-b675-27aee6253f24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
