// Dragnet [Ransomware]: dragnet-ransomware-2025-1892 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2b0f2621-bfab-5c0b-b921-d5711dd590a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
