// Dragnet [Ransomware]: dragnet-ransomware-2025-3762 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 68f5117f-959d-58ad-8a22-b726216672c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
