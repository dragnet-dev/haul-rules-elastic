// Dragnet [Ransomware]: dragnet-ransomware-2025-6477 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b20295ae-b1d2-54ce-a18d-93bfd655f998

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
