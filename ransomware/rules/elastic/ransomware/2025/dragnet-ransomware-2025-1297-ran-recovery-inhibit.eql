// Dragnet [Ransomware]: dragnet-ransomware-2025-1297 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 55c4e79d-d2e4-55d6-b15e-3bec182a9c92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
