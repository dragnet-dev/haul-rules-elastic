// Dragnet [Ransomware]: dragnet-ransomware-2025-7575 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 1579d61c-9815-52c1-b05a-68bc0f037e48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
