// Dragnet [Ransomware]: dragnet-ransomware-2025-7564 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 37d93257-3d55-5e47-b98e-9064de61abe3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
