// Dragnet [Ransomware]: dragnet-ransomware-2025-0734 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 6835bd70-f870-5c5e-a0cb-54e828adcc7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
