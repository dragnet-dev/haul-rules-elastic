// Dragnet [Ransomware]: dragnet-ransomware-2025-4708 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 87d8d159-4c4c-5a61-b8be-5d9d65b24556

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
