// Dragnet [Ransomware]: dragnet-ransomware-2025-4626 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 32c5e46f-5083-5f97-ab71-b5562945b3ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
