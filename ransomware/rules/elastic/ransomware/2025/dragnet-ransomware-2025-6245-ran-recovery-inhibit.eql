// Dragnet [Ransomware]: dragnet-ransomware-2025-6245 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 595cc92c-cd07-59f0-a4e6-a7c716608141

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
