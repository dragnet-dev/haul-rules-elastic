// Dragnet [Ransomware]: dragnet-ransomware-2025-5741 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 47ca8731-92ec-5cad-a66e-b21a273268c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
