// Dragnet [Ransomware]: dragnet-ransomware-2025-1769 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 16869a27-3753-51ce-98a5-52008e9ed74e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
