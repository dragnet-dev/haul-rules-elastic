// Dragnet [Ransomware]: dragnet-ransomware-2025-6978 — Recovery Inhibition (securotrop)
// Status: experimental | Level: high | ID: 120128af-fc9b-585d-b695-dfca4b33aef7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
