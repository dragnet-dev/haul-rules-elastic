// Dragnet [Ransomware]: dragnet-ransomware-2025-1171 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c4ed7a5c-a65b-5550-bc08-9bee63589841

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
