// Dragnet [Ransomware]: dragnet-ransomware-2025-5232 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: c9f462bd-40e3-5203-94d1-1bd1252882e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
