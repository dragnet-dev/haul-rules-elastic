// Dragnet [Ransomware]: dragnet-ransomware-2025-1218 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 7ed05562-5b57-5989-bacc-c26fabe1ad5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
