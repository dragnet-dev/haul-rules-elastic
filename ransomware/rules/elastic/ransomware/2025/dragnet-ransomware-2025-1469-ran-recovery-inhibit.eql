// Dragnet [Ransomware]: dragnet-ransomware-2025-1469 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f805c961-fad7-576e-a5c3-8cd2cc46759e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
