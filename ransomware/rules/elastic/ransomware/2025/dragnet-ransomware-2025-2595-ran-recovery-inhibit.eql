// Dragnet [Ransomware]: dragnet-ransomware-2025-2595 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 356fdd0c-5fd8-534f-bbf8-9701f8100558

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
