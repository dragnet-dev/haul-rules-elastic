// Dragnet [Ransomware]: dragnet-ransomware-2025-6440 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: ca7bf941-75e4-5612-b188-a3072524805f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
