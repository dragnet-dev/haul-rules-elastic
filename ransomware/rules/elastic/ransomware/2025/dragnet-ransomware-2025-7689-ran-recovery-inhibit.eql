// Dragnet [Ransomware]: dragnet-ransomware-2025-7689 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 00febb4e-44d8-5ec6-b268-fb8e906b0638

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
