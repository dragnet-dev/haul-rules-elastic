// Dragnet [Ransomware]: dragnet-ransomware-2025-6434 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: e575646b-7cc1-5f02-adf6-3ed7656ff92b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
