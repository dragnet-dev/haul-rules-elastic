// Dragnet [Ransomware]: dragnet-ransomware-2025-0044 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: d529be55-cce6-55b0-849a-e792bba91068

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
