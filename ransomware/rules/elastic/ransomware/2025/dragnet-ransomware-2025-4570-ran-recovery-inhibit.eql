// Dragnet [Ransomware]: dragnet-ransomware-2025-4570 — Recovery Inhibition (ransomhouse)
// Status: test | Level: high | ID: c6ad9d25-0b14-5d63-9a89-1a4d87f03bbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
