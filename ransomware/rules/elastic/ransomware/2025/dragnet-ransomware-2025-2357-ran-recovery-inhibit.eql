// Dragnet [Ransomware]: dragnet-ransomware-2025-2357 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9ee01ab8-0da2-54da-96b1-b821f43c39e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
