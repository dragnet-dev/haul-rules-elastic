// Dragnet [Ransomware]: dragnet-ransomware-2025-2837 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 0ce37490-744c-55ef-aa86-1249392b3658

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
