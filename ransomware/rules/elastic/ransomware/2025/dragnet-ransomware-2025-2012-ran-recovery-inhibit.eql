// Dragnet [Ransomware]: dragnet-ransomware-2025-2012 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: c7772873-393d-5ddb-9799-bf10e5141178

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
