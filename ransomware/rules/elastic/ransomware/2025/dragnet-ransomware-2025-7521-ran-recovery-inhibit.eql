// Dragnet [Ransomware]: dragnet-ransomware-2025-7521 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 38637d64-60b7-5cc3-bcaf-b3bbdf5607c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
