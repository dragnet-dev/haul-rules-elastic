// Dragnet [Ransomware]: dragnet-ransomware-2025-3159 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 0d62b5c0-58a2-58dd-a1eb-0af66b765c7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
