// Dragnet [Ransomware]: dragnet-ransomware-2025-0776 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1e4da4eb-d192-5473-9fda-74de48210234

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
