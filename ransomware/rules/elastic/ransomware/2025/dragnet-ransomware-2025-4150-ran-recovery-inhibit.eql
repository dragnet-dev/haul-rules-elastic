// Dragnet [Ransomware]: dragnet-ransomware-2025-4150 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 669cbb26-a6e1-5b2f-85f8-f73fd927fe94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
