// Dragnet [Ransomware]: dragnet-ransomware-2025-2899 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 09c6d029-eae9-51b0-9e92-c8323e19226f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
