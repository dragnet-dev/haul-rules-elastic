// Dragnet [Ransomware]: dragnet-ransomware-2025-5663 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 43fb48f6-5087-5f31-9dcf-3e33ece6616b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
