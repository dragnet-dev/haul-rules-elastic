// Dragnet [Ransomware]: dragnet-ransomware-2025-1989 — Recovery Inhibition (d4rk4rmy)
// Status: deprecated | Level: high | ID: e9fcc617-38f0-5ef6-a505-466845ad814b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
