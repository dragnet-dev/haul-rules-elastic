// Dragnet [Ransomware]: dragnet-ransomware-2025-5866 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: bc889c30-3645-55fb-85d4-90450b9409cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
