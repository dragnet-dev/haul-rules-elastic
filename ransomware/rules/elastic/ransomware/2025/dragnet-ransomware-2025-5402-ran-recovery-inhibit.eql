// Dragnet [Ransomware]: dragnet-ransomware-2025-5402 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 85f2ceb2-6d9d-53a0-b84e-4e48c493d8d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
