// Dragnet [Ransomware]: dragnet-ransomware-2025-7399 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 0c43ce67-02d2-520e-bcfd-e1ee9d6075d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
