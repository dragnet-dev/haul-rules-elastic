// Dragnet [Ransomware]: dragnet-ransomware-2025-2854 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e4cf6354-e3f6-5256-b8b3-321f2534765e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
