// Dragnet [Ransomware]: dragnet-ransomware-2025-0768 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: e840743f-9664-5524-95bd-707896e14b44

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
