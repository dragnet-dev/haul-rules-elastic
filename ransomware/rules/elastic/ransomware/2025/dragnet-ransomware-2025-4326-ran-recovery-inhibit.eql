// Dragnet [Ransomware]: dragnet-ransomware-2025-4326 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 9d9780cf-24d5-518b-882c-e7b79641ea6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
