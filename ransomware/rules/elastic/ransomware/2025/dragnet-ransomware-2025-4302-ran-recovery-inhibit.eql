// Dragnet [Ransomware]: dragnet-ransomware-2025-4302 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: 8f59ab4b-0bd2-522e-92d3-7cbe09aee122

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
