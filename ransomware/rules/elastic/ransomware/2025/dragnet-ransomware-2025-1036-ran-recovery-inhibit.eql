// Dragnet [Ransomware]: dragnet-ransomware-2025-1036 — Recovery Inhibition (ralord)
// Status: experimental | Level: high | ID: b0307084-f74e-5a37-b72a-2626acde9d87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
