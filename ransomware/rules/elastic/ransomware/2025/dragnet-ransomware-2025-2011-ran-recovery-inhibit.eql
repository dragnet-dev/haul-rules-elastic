// Dragnet [Ransomware]: dragnet-ransomware-2025-2011 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: d43d9ebc-fa5a-5eae-9cfb-17bb24a6b2fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
