// Dragnet [Ransomware]: dragnet-ransomware-2025-4498 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: e196fdec-e99b-59f9-bdf5-ceccb9b79f25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
