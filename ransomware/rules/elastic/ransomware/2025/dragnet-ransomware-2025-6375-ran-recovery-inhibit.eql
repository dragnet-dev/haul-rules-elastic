// Dragnet [Ransomware]: dragnet-ransomware-2025-6375 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: f9492ed1-3533-56f0-9460-370ce3792524

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
