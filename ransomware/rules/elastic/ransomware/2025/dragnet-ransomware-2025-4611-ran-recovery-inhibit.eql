// Dragnet [Ransomware]: dragnet-ransomware-2025-4611 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2c803683-0a81-505b-8134-480cf92dae76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
