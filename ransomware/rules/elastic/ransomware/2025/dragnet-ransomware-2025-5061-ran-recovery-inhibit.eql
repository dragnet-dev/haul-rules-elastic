// Dragnet [Ransomware]: dragnet-ransomware-2025-5061 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 9d006a87-76e9-51a4-a14b-bf1ac8550ce0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
