// Dragnet [Ransomware]: dragnet-ransomware-2025-6299 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d678f389-79f8-5749-b059-7d310ab0153a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
