// Dragnet [Ransomware]: dragnet-ransomware-2025-0978 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 347134a4-6fb0-5357-9394-e09e9e404b3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
