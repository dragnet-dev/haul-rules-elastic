// Dragnet [Ransomware]: dragnet-ransomware-2025-1309 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 0e4a0d4b-2225-5c66-9bfe-265c83acedde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
