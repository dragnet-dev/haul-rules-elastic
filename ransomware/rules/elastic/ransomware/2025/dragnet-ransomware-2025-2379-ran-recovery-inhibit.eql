// Dragnet [Ransomware]: dragnet-ransomware-2025-2379 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 82e22a11-799a-5817-9df9-4eb8b264899b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
