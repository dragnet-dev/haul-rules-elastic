// Dragnet [Ransomware]: dragnet-ransomware-2025-6106 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 794691dc-2a32-5897-a666-4639f83c27a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
