// Dragnet [Ransomware]: dragnet-ransomware-2025-2948 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: c1a32108-78f3-58e1-9f24-549e16c7e24c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
