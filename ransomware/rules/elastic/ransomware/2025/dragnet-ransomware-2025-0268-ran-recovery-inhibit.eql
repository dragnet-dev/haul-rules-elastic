// Dragnet [Ransomware]: dragnet-ransomware-2025-0268 — Recovery Inhibition (bert)
// Status: experimental | Level: high | ID: bd94e0d8-0ebc-591b-bf12-220105144cfd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
