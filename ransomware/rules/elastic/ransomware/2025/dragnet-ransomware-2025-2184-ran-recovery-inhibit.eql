// Dragnet [Ransomware]: dragnet-ransomware-2025-2184 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 071d6548-c54b-5894-baf2-4b3934cdbbf6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
