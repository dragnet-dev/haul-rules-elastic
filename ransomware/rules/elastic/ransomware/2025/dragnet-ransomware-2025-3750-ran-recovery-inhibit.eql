// Dragnet [Ransomware]: dragnet-ransomware-2025-3750 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 6d49d4cd-0e49-56ca-b9a3-f01a4af890ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
