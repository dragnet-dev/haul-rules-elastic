// Dragnet [Ransomware]: dragnet-ransomware-2025-3260 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1ee6f2ac-ccd9-58c3-9084-e787925aa390

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
