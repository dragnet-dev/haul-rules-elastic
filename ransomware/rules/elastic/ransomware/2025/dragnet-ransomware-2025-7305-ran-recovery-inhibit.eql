// Dragnet [Ransomware]: dragnet-ransomware-2025-7305 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3a7f3a14-61fd-5d34-a69d-cb3875e24edd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
