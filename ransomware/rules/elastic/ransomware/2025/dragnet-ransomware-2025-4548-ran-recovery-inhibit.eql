// Dragnet [Ransomware]: dragnet-ransomware-2025-4548 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 17ec2048-b40b-59f9-82cc-d120f38689f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
