// Dragnet [Ransomware]: dragnet-ransomware-2025-3846 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: b67104d9-8ac6-5691-aea5-398502e509b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
