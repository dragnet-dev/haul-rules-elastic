// Dragnet [Ransomware]: dragnet-ransomware-2025-6099 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: fb471f25-bf13-55de-9800-7dbabe3837bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
