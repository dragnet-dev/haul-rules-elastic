// Dragnet [Ransomware]: dragnet-ransomware-2025-5575 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: e3ef0d74-b492-531a-92f3-8dd68851dbcf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
