// Dragnet [Ransomware]: dragnet-ransomware-2025-0384 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: e377f495-5540-5719-9af4-93a74802cc48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
