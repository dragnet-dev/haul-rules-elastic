// Dragnet [Ransomware]: dragnet-ransomware-2025-0358 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f6121aca-7d99-52c9-aaf9-b53befd249af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
