// Dragnet [Ransomware]: dragnet-ransomware-2025-0091 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 67b2bf3b-dd47-5846-bf0c-e31b64491f15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
