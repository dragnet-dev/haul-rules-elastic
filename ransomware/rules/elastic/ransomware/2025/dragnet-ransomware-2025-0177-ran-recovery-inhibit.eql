// Dragnet [Ransomware]: dragnet-ransomware-2025-0177 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: c65e4585-55e9-5407-9261-9f13bb926658

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
