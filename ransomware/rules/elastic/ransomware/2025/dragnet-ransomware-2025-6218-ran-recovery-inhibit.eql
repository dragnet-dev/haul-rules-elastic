// Dragnet [Ransomware]: dragnet-ransomware-2025-6218 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 72715e9f-0e09-5ad4-a72a-8dadd88522a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
