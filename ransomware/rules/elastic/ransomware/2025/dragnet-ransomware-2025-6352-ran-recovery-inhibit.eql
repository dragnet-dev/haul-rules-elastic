// Dragnet [Ransomware]: dragnet-ransomware-2025-6352 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 229150a0-29d4-5293-9849-b2e91dda4b89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
