// Dragnet [Ransomware]: dragnet-ransomware-2025-7548 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: f3de80d9-4054-5f9a-aebe-991f801c079a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
