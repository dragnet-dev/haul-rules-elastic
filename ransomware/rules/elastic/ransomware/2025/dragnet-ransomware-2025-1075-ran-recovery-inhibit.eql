// Dragnet [Ransomware]: dragnet-ransomware-2025-1075 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: 877d0d09-a3ac-5244-8929-51caaa24f0d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
