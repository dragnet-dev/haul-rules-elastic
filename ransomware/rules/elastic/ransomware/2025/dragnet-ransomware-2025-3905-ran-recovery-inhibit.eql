// Dragnet [Ransomware]: dragnet-ransomware-2025-3905 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 89ad9a8c-79f5-5a53-acce-959c0e637ca2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
