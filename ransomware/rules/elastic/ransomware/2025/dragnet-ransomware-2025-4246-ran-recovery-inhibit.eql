// Dragnet [Ransomware]: dragnet-ransomware-2025-4246 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 8932a724-2e30-5bd0-83c0-2b0511162c4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
