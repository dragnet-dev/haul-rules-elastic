// Dragnet [Ransomware]: dragnet-ransomware-2025-2824 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: a466ca1b-d3d3-57f6-ae1e-dcf158380742

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
