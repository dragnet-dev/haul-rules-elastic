// Dragnet [Ransomware]: dragnet-ransomware-2025-3741 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0b115d12-6e1e-5cab-bd8a-74de5fb7c1fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
