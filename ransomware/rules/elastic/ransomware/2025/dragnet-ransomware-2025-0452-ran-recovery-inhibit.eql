// Dragnet [Ransomware]: dragnet-ransomware-2025-0452 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4db8e247-508e-5bd8-bf10-fe23bc447f64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
