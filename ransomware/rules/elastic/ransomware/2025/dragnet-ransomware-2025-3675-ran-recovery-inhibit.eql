// Dragnet [Ransomware]: dragnet-ransomware-2025-3675 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7c8c065e-46b8-5848-b3b2-46298d0e9c0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
