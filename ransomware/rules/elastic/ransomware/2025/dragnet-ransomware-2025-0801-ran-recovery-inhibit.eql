// Dragnet [Ransomware]: dragnet-ransomware-2025-0801 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: fdcab5a3-9b3f-57ff-82f4-8acbad92b9ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
