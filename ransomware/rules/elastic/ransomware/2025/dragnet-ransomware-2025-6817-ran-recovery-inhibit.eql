// Dragnet [Ransomware]: dragnet-ransomware-2025-6817 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: 4dfcd912-7a2c-5817-84d1-e16f27cf4841

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
