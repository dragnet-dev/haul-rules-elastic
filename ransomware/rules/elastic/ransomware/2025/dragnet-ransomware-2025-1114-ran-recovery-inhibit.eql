// Dragnet [Ransomware]: dragnet-ransomware-2025-1114 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: d436dc06-c71f-5523-b187-0f6f0a108ad4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
