// Dragnet [Ransomware]: dragnet-ransomware-2025-4482 — Recovery Inhibition (anubis)
// Status: experimental | Level: high | ID: 6d426b25-c268-5235-b887-2037706e981b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
