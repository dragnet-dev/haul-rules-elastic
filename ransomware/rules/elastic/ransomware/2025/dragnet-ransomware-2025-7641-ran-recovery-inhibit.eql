// Dragnet [Ransomware]: dragnet-ransomware-2025-7641 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: e879570e-4fd5-5a1d-b1eb-f3e819fdf6c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
