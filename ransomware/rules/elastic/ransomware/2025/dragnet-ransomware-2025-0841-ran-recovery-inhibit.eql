// Dragnet [Ransomware]: dragnet-ransomware-2025-0841 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: fdd66e6c-c030-5ae3-adbf-6556d2417141

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
