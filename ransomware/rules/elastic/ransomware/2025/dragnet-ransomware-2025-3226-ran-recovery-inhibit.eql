// Dragnet [Ransomware]: dragnet-ransomware-2025-3226 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a9650069-008f-5339-a9a5-844d37b444ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
