// Dragnet [Ransomware]: dragnet-ransomware-2025-2643 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: f5ac2121-a65f-57b2-93e8-7df18e410604

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
