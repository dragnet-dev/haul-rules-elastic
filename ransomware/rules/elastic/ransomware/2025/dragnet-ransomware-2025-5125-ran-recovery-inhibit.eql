// Dragnet [Ransomware]: dragnet-ransomware-2025-5125 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 757408b3-94c7-56fe-af0b-41c7808f5145

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
