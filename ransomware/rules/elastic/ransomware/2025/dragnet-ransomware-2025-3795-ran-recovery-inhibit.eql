// Dragnet [Ransomware]: dragnet-ransomware-2025-3795 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 2d55356a-30d4-5f17-aa1c-870f83f969ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
