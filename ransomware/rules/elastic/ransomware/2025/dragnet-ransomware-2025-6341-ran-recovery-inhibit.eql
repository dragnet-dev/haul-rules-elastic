// Dragnet [Ransomware]: dragnet-ransomware-2025-6341 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 65ccd558-211c-52c5-8286-fd60324947cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
