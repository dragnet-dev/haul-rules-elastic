// Dragnet [Ransomware]: dragnet-ransomware-2025-6528 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 2e566a0c-0bd2-5b09-ba11-330949865987

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
