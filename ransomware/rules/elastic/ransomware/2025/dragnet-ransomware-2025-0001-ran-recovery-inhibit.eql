// Dragnet [Ransomware]: dragnet-ransomware-2025-0001 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: c37a5228-adea-5da1-8047-54d14e22cb6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
