// Dragnet [Ransomware]: dragnet-ransomware-2025-1322 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4ad16995-cd6c-5df0-bdbd-4c8284460812

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
