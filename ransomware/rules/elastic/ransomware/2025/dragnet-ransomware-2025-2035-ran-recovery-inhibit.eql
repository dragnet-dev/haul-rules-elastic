// Dragnet [Ransomware]: dragnet-ransomware-2025-2035 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ecbf06db-df8d-51ba-ad3d-08a6c4f7451f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
