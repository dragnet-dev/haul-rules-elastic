// Dragnet [Ransomware]: dragnet-ransomware-2025-2419 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 6ca484cb-2667-507e-b978-983ba3174819

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
