// Dragnet [Ransomware]: dragnet-ransomware-2025-2218 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7445a68b-145f-540b-afca-e7361b5c0f22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
