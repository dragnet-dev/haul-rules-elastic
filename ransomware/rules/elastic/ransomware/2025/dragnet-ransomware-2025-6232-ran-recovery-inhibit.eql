// Dragnet [Ransomware]: dragnet-ransomware-2025-6232 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 496d2bc4-7842-5c12-9dde-2f4025056e51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
