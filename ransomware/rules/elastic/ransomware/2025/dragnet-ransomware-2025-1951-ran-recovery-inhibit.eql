// Dragnet [Ransomware]: dragnet-ransomware-2025-1951 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: fc6f54ab-eef7-54f9-8115-1670f5ca9a64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
