// Dragnet [Ransomware]: dragnet-ransomware-2025-2177 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9e47fd62-3ca6-57a9-8c87-b9f7b1646be3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
