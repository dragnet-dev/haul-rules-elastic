// Dragnet [Ransomware]: dragnet-ransomware-2025-4437 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 6d2d60db-d9fd-5cb5-bff1-595a0604cce1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
