// Dragnet [Ransomware]: dragnet-ransomware-2025-3120 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: 93b4e300-8013-5a8b-82a1-d0698db6ec09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
