// Dragnet [Ransomware]: dragnet-ransomware-2025-6220 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: e1459667-b24b-5d7a-af7c-8a2e07a334d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
