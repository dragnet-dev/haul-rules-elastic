// Dragnet [Ransomware]: dragnet-ransomware-2025-7872 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 24862f32-7c9a-54ab-a2c2-6e340a8de970

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
