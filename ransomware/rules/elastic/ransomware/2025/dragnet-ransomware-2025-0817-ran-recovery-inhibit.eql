// Dragnet [Ransomware]: dragnet-ransomware-2025-0817 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 802df0fd-0a81-5517-97dd-f2ef5720fe14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
