// Dragnet [Ransomware]: dragnet-ransomware-2025-3126 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9b96a9c7-7706-51d8-b382-f4495f6879d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
