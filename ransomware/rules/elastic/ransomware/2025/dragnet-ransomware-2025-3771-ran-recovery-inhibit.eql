// Dragnet [Ransomware]: dragnet-ransomware-2025-3771 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: 0ae92bc5-592e-56bc-9075-56b964171219

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
