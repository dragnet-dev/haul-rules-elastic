// Dragnet [Ransomware]: dragnet-ransomware-2025-1809 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 828eb5ec-cae6-58fe-941d-7aff6aa239a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
