// Dragnet [Ransomware]: dragnet-ransomware-2025-3528 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 39320243-1b0b-5bbb-bd84-294c75139a61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
