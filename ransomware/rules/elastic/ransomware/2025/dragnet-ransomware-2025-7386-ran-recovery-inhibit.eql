// Dragnet [Ransomware]: dragnet-ransomware-2025-7386 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 0955d6c5-f266-5f09-abdb-5eba56b6a98b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
