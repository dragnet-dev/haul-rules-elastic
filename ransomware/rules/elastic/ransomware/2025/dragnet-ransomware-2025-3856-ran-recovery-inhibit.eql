// Dragnet [Ransomware]: dragnet-ransomware-2025-3856 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7f1cdeba-b183-5052-aaa5-7b46e40eb53c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
