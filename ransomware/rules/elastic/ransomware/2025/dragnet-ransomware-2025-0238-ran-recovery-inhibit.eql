// Dragnet [Ransomware]: dragnet-ransomware-2025-0238 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: c9c0e578-bfbc-535f-bbb3-9a080761160a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
