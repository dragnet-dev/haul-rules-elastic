// Dragnet [Ransomware]: dragnet-ransomware-2025-0183 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 66f45c64-035f-559b-a10a-79cef894d9b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
