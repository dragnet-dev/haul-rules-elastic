// Dragnet [Ransomware]: dragnet-ransomware-2025-4564 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: e9eee909-4301-5d57-b993-cc4222f004c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
