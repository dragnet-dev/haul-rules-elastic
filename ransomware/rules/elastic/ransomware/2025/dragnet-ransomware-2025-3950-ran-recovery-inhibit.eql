// Dragnet [Ransomware]: dragnet-ransomware-2025-3950 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 3bcc9bdb-a41d-5719-843b-4f3bd8ab1f33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
