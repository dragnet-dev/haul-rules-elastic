// Dragnet [Ransomware]: dragnet-ransomware-2025-5842 — Recovery Inhibition (gunra)
// Status: experimental | Level: high | ID: 00aed36f-5d9d-5d9b-9c87-9d24dcbebe38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
