// Dragnet [Ransomware]: dragnet-ransomware-2025-7096 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: b14b4154-d366-5de2-9bba-20249d48090a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
