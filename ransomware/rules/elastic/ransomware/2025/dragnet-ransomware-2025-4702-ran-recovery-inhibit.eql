// Dragnet [Ransomware]: dragnet-ransomware-2025-4702 — Recovery Inhibition (obscura)
// Status: experimental | Level: high | ID: d5d5855a-68ab-557a-b25a-b910bb188645

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
