// Dragnet [Ransomware]: dragnet-ransomware-2025-3836 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0136f4c2-2865-5b0b-a1fc-8ea2fcae6fc9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
