// Dragnet [Ransomware]: dragnet-ransomware-2025-6000 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: f641817b-01c7-5920-94c2-108e5d241458

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
