// Dragnet [Ransomware]: dragnet-ransomware-2025-6668 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3fff8e46-f7dd-5f34-a5da-c0711a269640

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
