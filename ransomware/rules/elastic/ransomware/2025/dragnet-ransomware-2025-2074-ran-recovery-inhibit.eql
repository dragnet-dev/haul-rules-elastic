// Dragnet [Ransomware]: dragnet-ransomware-2025-2074 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b3b7eebd-79e2-541f-9a6d-85f0d873ec74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
