// Dragnet [Ransomware]: dragnet-ransomware-2025-2059 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 93053210-68b2-5514-b502-ffcf40b10a3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
