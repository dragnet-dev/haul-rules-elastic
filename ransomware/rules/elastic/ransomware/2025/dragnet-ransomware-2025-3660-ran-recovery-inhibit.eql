// Dragnet [Ransomware]: dragnet-ransomware-2025-3660 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 68f1e0fe-4f8a-5ded-8fc0-1a384003a9e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
