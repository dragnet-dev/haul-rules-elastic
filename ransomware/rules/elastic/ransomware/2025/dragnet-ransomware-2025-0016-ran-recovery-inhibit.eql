// Dragnet [Ransomware]: dragnet-ransomware-2025-0016 — Recovery Inhibition (obscura)
// Status: deprecated | Level: high | ID: 697a42f2-e01f-54a2-8fd2-f666ed5797f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
