// Dragnet [Ransomware]: dragnet-ransomware-2025-4970 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 60d547ca-97bd-5fda-8042-535498156841

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
