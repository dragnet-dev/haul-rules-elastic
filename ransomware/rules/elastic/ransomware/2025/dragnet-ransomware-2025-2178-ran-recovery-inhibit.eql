// Dragnet [Ransomware]: dragnet-ransomware-2025-2178 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: a84d270e-9692-539a-84aa-5954e584765b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
