// Dragnet [Ransomware]: dragnet-ransomware-2025-2775 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 85f45820-1185-58aa-8aeb-02f38e804063

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
