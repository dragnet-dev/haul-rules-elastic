// Dragnet [Ransomware]: dragnet-ransomware-2025-5468 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 48998cfa-53db-5912-b38a-d69ad1755964

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
