// Dragnet [Ransomware]: dragnet-ransomware-2025-7400 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 76a4afd6-d84b-529b-a6e0-f9e9cc001114

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
