// Dragnet [Ransomware]: dragnet-ransomware-2025-7000 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: f834cb9a-71b6-5853-b629-192825e741f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
