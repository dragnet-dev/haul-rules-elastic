// Dragnet [Ransomware]: dragnet-ransomware-2025-6349 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 24c8940a-46f4-5adb-9a77-c346d6f63526

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
