// Dragnet [Ransomware]: dragnet-ransomware-2025-3561 — Recovery Inhibition (interlock)
// Status: test | Level: high | ID: 3f9274bd-4d25-5118-b40b-ef9e9b8f4faa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
