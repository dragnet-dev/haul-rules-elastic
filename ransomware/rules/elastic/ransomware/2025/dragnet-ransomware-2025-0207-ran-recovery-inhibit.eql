// Dragnet [Ransomware]: dragnet-ransomware-2025-0207 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f7af4856-62a5-5406-b49a-92f7448fa45e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
