// Dragnet [Ransomware]: dragnet-ransomware-2025-5715 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: ccd9f25f-31dc-5475-9680-1c76a6ba13aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
