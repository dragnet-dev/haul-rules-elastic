// Dragnet [Ransomware]: dragnet-ransomware-2025-7477 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e7816769-47af-501b-a838-77f32549743e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
