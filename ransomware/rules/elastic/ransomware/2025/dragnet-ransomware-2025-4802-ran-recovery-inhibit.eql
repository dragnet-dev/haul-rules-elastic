// Dragnet [Ransomware]: dragnet-ransomware-2025-4802 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: f2301881-65cc-5a01-9561-f09589618de2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
