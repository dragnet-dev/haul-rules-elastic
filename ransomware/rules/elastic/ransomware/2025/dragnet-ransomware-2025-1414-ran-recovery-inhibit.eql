// Dragnet [Ransomware]: dragnet-ransomware-2025-1414 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: f10171d0-a56c-554c-be39-3725923d9e9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
