// Dragnet [Ransomware]: dragnet-ransomware-2025-7273 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: b9843694-8127-547f-afdb-0b210ae17a4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
