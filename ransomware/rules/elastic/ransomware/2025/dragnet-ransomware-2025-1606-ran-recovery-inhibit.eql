// Dragnet [Ransomware]: dragnet-ransomware-2025-1606 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 039f43bf-04c5-5195-9314-1de857799349

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
