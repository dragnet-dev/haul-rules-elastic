// Dragnet [Ransomware]: dragnet-ransomware-2025-7925 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 66342440-85bf-5684-9edb-392b5f8cc696

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
