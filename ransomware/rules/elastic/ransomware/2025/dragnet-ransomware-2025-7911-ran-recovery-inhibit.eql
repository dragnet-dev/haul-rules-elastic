// Dragnet [Ransomware]: dragnet-ransomware-2025-7911 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 3387f5e5-e95e-5123-8111-335c3304b5db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
