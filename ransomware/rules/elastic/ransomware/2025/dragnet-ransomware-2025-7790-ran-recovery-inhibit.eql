// Dragnet [Ransomware]: dragnet-ransomware-2025-7790 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: b681eda6-dbe1-5973-9b80-cf4419b6e576

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
