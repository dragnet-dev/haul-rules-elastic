// Dragnet [Ransomware]: dragnet-ransomware-2025-6290 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 838083b9-d564-5f97-a356-1fec8f86d3ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
