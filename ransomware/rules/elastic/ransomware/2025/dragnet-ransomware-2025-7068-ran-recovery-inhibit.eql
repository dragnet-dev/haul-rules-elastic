// Dragnet [Ransomware]: dragnet-ransomware-2025-7068 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 1d4aed09-5960-5e2c-b501-aded10532b13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
