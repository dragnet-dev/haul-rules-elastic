// Dragnet [Ransomware]: dragnet-ransomware-2025-6206 — Recovery Inhibition (anubis)
// Status: experimental | Level: high | ID: 9385ace2-b3a7-5bf6-b04b-a59d564f61d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
