// Dragnet [Ransomware]: dragnet-ransomware-2025-4378 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 285b5287-acb7-5130-9bec-34b93f0345a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
