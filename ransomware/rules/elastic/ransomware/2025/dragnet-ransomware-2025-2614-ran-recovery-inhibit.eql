// Dragnet [Ransomware]: dragnet-ransomware-2025-2614 — Recovery Inhibition (cephalus)
// Status: experimental | Level: high | ID: 4e8c23bb-9d8e-5799-93cd-75dbdc4fc330

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
