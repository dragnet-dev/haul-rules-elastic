// Dragnet [Ransomware]: dragnet-ransomware-2025-5603 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 7cbeee9d-0b39-57bf-b93f-531876fc8ab1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
