// Dragnet [Ransomware]: dragnet-ransomware-2025-0002 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 819fad84-874d-51cb-9ac1-257796ad2039

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
