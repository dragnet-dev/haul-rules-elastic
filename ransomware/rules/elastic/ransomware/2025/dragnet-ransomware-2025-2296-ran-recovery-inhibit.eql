// Dragnet [Ransomware]: dragnet-ransomware-2025-2296 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c4bcfd16-a84a-5315-9ec6-a5b68d06a297

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
