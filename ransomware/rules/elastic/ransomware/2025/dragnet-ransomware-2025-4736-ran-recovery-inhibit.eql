// Dragnet [Ransomware]: dragnet-ransomware-2025-4736 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 7fb71d13-7b1e-5d2e-8ec7-13e909734bfb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
