// Dragnet [Ransomware]: dragnet-ransomware-2025-3902 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c65fb202-11df-5cbb-a864-181f327456ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
