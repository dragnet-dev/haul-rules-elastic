// Dragnet [Ransomware]: dragnet-ransomware-2025-1420 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 67270995-baf4-5751-ba28-682b8de97598

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
