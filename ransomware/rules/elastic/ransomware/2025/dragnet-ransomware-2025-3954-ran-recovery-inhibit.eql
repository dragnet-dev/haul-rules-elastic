// Dragnet [Ransomware]: dragnet-ransomware-2025-3954 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: f869d213-a9fb-585c-9f9d-c0848246c12b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
