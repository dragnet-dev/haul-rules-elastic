// Dragnet [Ransomware]: dragnet-ransomware-2025-1937 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 6c4bead8-2dee-5b83-807c-09910e8dee0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
