// Dragnet [Ransomware]: dragnet-ransomware-2025-6468 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: ee18478b-290b-5b88-8703-1931194b0472

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
