// Dragnet [Ransomware]: dragnet-ransomware-2025-6116 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ef30e9d7-4edf-5e08-bd6b-11680fc1214f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
