// Dragnet [Ransomware]: dragnet-ransomware-2025-7489 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 1574e388-f9cf-5426-9338-7a3c77da1dbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
