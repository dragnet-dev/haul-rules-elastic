// Dragnet [Ransomware]: dragnet-ransomware-2025-7559 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 2734d0bd-a983-5793-916b-f65596ec5c64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
