// Dragnet [Ransomware]: dragnet-ransomware-2025-4601 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d3b6e6ed-ea37-5941-875d-f4c450fa8dc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
