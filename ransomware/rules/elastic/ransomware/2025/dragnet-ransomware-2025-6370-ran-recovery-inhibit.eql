// Dragnet [Ransomware]: dragnet-ransomware-2025-6370 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: f0af745f-c085-51b7-8726-0bfe1eb1a00b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
