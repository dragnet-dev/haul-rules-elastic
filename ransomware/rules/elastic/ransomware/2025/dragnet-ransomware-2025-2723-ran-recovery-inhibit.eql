// Dragnet [Ransomware]: dragnet-ransomware-2025-2723 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: c87289e5-c652-5d18-8680-42317e24cef3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
