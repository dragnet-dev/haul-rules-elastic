// Dragnet [Ransomware]: dragnet-ransomware-2025-1389 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 9e7b7e1f-1b17-5dd0-85ff-9143913081e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
