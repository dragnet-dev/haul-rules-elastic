// Dragnet [Ransomware]: dragnet-ransomware-2025-3427 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: a29f81ba-c683-5cc5-ba0a-9ba537f252dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
