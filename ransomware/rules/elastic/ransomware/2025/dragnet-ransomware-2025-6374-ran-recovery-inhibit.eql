// Dragnet [Ransomware]: dragnet-ransomware-2025-6374 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 9b4600ed-d70a-5651-a840-63bbc37371c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
