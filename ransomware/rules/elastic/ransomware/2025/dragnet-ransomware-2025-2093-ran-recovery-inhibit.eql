// Dragnet [Ransomware]: dragnet-ransomware-2025-2093 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 1ff4ce3b-ef16-5732-9d6e-3ddba2e2583b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
