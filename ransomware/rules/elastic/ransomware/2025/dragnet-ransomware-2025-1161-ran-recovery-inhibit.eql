// Dragnet [Ransomware]: dragnet-ransomware-2025-1161 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 22cf4e3f-54a0-5728-bab3-2e2785a787c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
