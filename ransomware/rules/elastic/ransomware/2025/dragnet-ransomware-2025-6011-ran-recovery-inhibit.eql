// Dragnet [Ransomware]: dragnet-ransomware-2025-6011 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 39249296-3c5d-58ee-8668-648b41fe9764

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
