// Dragnet [Ransomware]: dragnet-ransomware-2025-4958 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3bdd080c-4bdb-5966-b9f5-62a6f85eebbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
