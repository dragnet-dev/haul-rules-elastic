// Dragnet [Ransomware]: dragnet-ransomware-2025-3462 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 0b142ee1-f4f6-5fab-aeda-6e3c724f129f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
