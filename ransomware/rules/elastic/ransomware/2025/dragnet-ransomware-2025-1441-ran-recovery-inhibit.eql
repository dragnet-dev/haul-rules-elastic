// Dragnet [Ransomware]: dragnet-ransomware-2025-1441 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 8b22fc77-d07d-5085-8406-ee55323bd64b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
