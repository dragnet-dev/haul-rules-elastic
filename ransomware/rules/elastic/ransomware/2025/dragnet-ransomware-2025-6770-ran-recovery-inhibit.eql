// Dragnet [Ransomware]: dragnet-ransomware-2025-6770 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 62d9f181-5c5f-59cf-a6d7-a9c5cd0f5ec9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
