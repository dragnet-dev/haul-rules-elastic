// Dragnet [Ransomware]: dragnet-ransomware-2025-6998 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7c784ed0-b056-5833-a0c5-d114b7eac188

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
