// Dragnet [Ransomware]: dragnet-ransomware-2025-1719 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 295c03ba-6632-5f4f-842a-9eb756d9755a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
