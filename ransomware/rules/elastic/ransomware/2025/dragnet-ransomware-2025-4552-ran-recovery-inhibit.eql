// Dragnet [Ransomware]: dragnet-ransomware-2025-4552 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 64b36f66-035f-5f98-b946-92da19a28847

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
