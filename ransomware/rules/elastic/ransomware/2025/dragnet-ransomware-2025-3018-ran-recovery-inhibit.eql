// Dragnet [Ransomware]: dragnet-ransomware-2025-3018 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: bd7d047c-768a-5054-9de0-efef418bc243

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
