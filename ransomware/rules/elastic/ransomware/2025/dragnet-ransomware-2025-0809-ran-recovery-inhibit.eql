// Dragnet [Ransomware]: dragnet-ransomware-2025-0809 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 1c2105a6-1942-5de2-9a4d-68be8d30a373

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
