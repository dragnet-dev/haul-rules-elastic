// Dragnet [Ransomware]: dragnet-ransomware-2025-5120 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: cd0b15fe-21a8-520a-a436-8357974380a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
