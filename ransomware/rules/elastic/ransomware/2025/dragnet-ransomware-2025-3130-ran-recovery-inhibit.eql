// Dragnet [Ransomware]: dragnet-ransomware-2025-3130 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 170e4a23-d4b4-50c8-a706-f04189af230a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
