// Dragnet [Ransomware]: dragnet-ransomware-2025-6873 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 5412cb35-43b0-595d-b389-a8eef7f31b73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
