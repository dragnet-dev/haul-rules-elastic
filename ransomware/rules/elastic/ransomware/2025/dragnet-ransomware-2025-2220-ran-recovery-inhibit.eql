// Dragnet [Ransomware]: dragnet-ransomware-2025-2220 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 89781949-e92d-5f1a-8305-9fcd2a7d9ad2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
