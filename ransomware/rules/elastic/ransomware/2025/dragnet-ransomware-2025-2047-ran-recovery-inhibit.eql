// Dragnet [Ransomware]: dragnet-ransomware-2025-2047 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 845b002c-b810-53ff-bcf8-a03dcf632a24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
