// Dragnet [Ransomware]: dragnet-ransomware-2025-2811 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 00117d7c-6be2-5254-9242-e74a4d815cb9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
