// Dragnet [Ransomware]: dragnet-ransomware-2025-3558 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: de511063-f9bb-5896-848f-6bf0cbca11f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
