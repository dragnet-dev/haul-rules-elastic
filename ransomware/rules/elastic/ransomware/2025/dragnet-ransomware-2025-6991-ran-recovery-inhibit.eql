// Dragnet [Ransomware]: dragnet-ransomware-2025-6991 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: e4cc2416-c9b9-5b80-bcc9-f1d6824e94b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
