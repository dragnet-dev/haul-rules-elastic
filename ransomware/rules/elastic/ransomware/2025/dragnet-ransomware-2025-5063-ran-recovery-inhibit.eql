// Dragnet [Ransomware]: dragnet-ransomware-2025-5063 — Recovery Inhibition (blackshrantac)
// Status: experimental | Level: high | ID: e5f66f5c-028f-5e74-a168-fa5b6766c77c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
