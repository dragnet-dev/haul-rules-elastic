// Dragnet [Ransomware]: dragnet-ransomware-2025-7031 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: d1c949b0-16e2-5bdd-b0a9-049b568cc50d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
