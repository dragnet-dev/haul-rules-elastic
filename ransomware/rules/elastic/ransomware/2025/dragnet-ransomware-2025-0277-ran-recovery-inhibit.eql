// Dragnet [Ransomware]: dragnet-ransomware-2025-0277 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: ebf67427-2757-533e-b402-dc14ab8cd10d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
