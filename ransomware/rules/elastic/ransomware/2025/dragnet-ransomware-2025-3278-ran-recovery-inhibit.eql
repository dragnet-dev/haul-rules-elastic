// Dragnet [Ransomware]: dragnet-ransomware-2025-3278 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 046c9b32-265c-55d7-a3e3-be66aeb3a268

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
