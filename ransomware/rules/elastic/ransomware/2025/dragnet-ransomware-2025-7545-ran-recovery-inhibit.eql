// Dragnet [Ransomware]: dragnet-ransomware-2025-7545 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: df3c3675-a953-520c-ba42-af9c30f5174e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
