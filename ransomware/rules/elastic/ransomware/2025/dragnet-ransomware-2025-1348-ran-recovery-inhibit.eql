// Dragnet [Ransomware]: dragnet-ransomware-2025-1348 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 857540ee-abdd-5034-b404-54ac3ccdfb0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
