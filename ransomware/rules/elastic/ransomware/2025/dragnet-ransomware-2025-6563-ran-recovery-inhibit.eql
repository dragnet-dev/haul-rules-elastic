// Dragnet [Ransomware]: dragnet-ransomware-2025-6563 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f333feb2-8d2a-5845-8008-193471acf5fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
