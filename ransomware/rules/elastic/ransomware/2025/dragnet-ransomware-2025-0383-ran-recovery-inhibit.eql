// Dragnet [Ransomware]: dragnet-ransomware-2025-0383 — Recovery Inhibition (orca)
// Status: experimental | Level: high | ID: b9aca5bb-8cc5-576e-97cb-aa834c33563a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
