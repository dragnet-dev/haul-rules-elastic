// Dragnet [Ransomware]: dragnet-ransomware-2025-7800 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 449540f0-2fec-55cc-973a-dc773ff767f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
