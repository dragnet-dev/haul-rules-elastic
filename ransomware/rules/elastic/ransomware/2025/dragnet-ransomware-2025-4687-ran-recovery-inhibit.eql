// Dragnet [Ransomware]: dragnet-ransomware-2025-4687 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: b41228c7-85db-5b9c-9ebf-b631225ac942

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
