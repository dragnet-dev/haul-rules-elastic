// Dragnet [Ransomware]: dragnet-ransomware-2025-7051 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 2a09befc-01f8-5369-961f-f7f8a16854de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
