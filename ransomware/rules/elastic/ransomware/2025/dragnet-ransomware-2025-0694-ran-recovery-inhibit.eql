// Dragnet [Ransomware]: dragnet-ransomware-2025-0694 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8f07e973-b4c4-59c8-bf6a-65976f2438ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
