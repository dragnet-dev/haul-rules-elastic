// Dragnet [Ransomware]: dragnet-ransomware-2025-1828 — Recovery Inhibition (ralord)
// Status: experimental | Level: high | ID: f05cfcbf-31da-56c0-9802-e2e40a287e80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
