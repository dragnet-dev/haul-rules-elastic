// Dragnet [Ransomware]: dragnet-ransomware-2025-7549 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: dfd5b4ec-8c47-55cc-9158-085ad876c593

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
