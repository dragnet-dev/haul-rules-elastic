// Dragnet [Ransomware]: dragnet-ransomware-2025-3383 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 175bdd88-58ad-5b7f-9a56-8bc32f109e39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
