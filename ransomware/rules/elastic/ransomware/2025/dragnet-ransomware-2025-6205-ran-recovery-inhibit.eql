// Dragnet [Ransomware]: dragnet-ransomware-2025-6205 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: dd6f9d04-4971-5547-9aa1-453c85e80932

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
