// Dragnet [Ransomware]: dragnet-ransomware-2025-0531 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a0cb24d9-a038-5c40-bedf-86189eb4a617

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
