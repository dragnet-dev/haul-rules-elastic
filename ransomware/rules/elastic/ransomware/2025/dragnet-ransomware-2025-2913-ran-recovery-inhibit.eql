// Dragnet [Ransomware]: dragnet-ransomware-2025-2913 — Recovery Inhibition (d4rk4rmy)
// Status: deprecated | Level: high | ID: 5c5c4bc7-8560-5bcc-9b86-c8d76836fcae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
