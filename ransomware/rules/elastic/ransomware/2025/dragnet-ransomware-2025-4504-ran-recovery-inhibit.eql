// Dragnet [Ransomware]: dragnet-ransomware-2025-4504 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: 9f7e19cf-cbfb-5d8f-9b2e-831da087e087

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
