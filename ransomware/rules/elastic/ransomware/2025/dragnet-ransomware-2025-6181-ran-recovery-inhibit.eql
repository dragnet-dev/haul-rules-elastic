// Dragnet [Ransomware]: dragnet-ransomware-2025-6181 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 70d54e45-df53-53f1-b3c7-ea0fd1780b11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
