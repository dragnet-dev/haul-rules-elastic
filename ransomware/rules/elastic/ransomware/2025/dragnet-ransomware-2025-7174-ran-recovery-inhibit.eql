// Dragnet [Ransomware]: dragnet-ransomware-2025-7174 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: 852576b5-872f-5bbc-a10c-adb1ebc41c1f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
