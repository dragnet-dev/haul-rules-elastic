// Dragnet [Ransomware]: dragnet-ransomware-2025-7741 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2afc9780-3a5b-5aaa-ac95-1b6777d91fc6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
