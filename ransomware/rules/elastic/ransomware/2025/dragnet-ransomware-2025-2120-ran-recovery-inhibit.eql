// Dragnet [Ransomware]: dragnet-ransomware-2025-2120 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: e656b1a5-0518-5fd8-8027-a3da748e3902

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
