// Dragnet [Ransomware]: dragnet-ransomware-2025-0252 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: fc843d3c-5b83-5e27-a694-d1b8a3a17b50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
