// Dragnet [Ransomware]: dragnet-ransomware-2025-5797 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 74eea9a3-5779-5b90-8301-8938ea9dc839

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
