// Dragnet [Ransomware]: dragnet-ransomware-2025-5138 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: 6f2c0469-02d0-5af9-ad0d-637573ce1a34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
