// Dragnet [Ransomware]: dragnet-ransomware-2025-7502 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 02effe4f-9b03-51d3-a6e0-4df7ff62e7a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
