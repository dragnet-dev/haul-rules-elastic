// Dragnet [Ransomware]: dragnet-ransomware-2025-1725 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 67446039-e5e7-58a4-b05a-e5cc59e43025

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
