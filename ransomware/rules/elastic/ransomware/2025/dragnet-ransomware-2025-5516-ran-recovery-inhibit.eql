// Dragnet [Ransomware]: dragnet-ransomware-2025-5516 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2e1932d0-5e0c-5eb0-b255-2ead49a2615c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
