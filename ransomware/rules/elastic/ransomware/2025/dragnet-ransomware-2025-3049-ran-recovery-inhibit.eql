// Dragnet [Ransomware]: dragnet-ransomware-2025-3049 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 50353591-c14a-584d-b4f9-c4bff514579e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
