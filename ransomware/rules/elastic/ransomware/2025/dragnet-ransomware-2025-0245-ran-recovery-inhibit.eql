// Dragnet [Ransomware]: dragnet-ransomware-2025-0245 — Recovery Inhibition (nitrogen)
// Status: test | Level: high | ID: adc75198-0974-55d8-a5c7-c8b6c571518c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
