// Dragnet [Ransomware]: dragnet-ransomware-2025-1138 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: d47ee0f7-8a9e-5c94-9948-8516c088899b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
