// Dragnet [Ransomware]: dragnet-ransomware-2025-3170 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: c21a8dc9-e60b-5ae5-bf62-573215d7e39e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
