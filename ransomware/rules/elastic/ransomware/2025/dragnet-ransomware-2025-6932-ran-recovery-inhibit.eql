// Dragnet [Ransomware]: dragnet-ransomware-2025-6932 — Recovery Inhibition (radar)
// Status: experimental | Level: high | ID: cc8d6d11-d47b-58dd-8eef-f1af8598ee23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
