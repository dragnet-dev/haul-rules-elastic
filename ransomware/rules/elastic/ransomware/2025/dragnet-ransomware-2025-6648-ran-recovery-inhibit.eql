// Dragnet [Ransomware]: dragnet-ransomware-2025-6648 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d0cc0832-c851-5ea3-a7ca-1c5f12598321

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
