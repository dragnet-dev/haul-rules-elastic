// Dragnet [Ransomware]: dragnet-ransomware-2025-2759 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: 0910519b-6105-5eed-a029-2d26770f4e9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
