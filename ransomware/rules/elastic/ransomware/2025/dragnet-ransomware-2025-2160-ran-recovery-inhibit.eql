// Dragnet [Ransomware]: dragnet-ransomware-2025-2160 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: 04c4f5de-ebb2-5fc4-ba05-169a60bc87cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
