// Dragnet [Ransomware]: dragnet-ransomware-2025-6879 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: a51d10a7-ccfe-5eff-a865-870eee099094

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
