// Dragnet [Ransomware]: dragnet-ransomware-2025-1417 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: be731a7d-79dd-56bf-99b2-7001d56e9f28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
