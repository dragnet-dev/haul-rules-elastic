// Dragnet [Ransomware]: dragnet-ransomware-2025-4618 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: ad9ce1a7-27d0-55b4-aae6-3c72cbe6f58e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
