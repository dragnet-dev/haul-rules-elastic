// Dragnet [Ransomware]: dragnet-ransomware-2025-7018 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 536ae291-22f7-5e2c-97b3-cb812caab46f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
