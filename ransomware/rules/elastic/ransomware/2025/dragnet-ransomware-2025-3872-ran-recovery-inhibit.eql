// Dragnet [Ransomware]: dragnet-ransomware-2025-3872 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0d03c8fa-25ef-5647-8e4d-e1b4b5dde52b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
