// Dragnet [Ransomware]: dragnet-ransomware-2025-2888 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 6eea4372-7da0-5f88-ba92-e3f7b26861f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
