// Dragnet [Ransomware]: dragnet-ransomware-2025-6762 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: abfa8eb5-6e7d-55c7-9088-03cea401c9f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
