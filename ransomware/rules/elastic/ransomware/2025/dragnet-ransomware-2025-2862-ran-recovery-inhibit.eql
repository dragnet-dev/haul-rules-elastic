// Dragnet [Ransomware]: dragnet-ransomware-2025-2862 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: 7adbb7be-4e54-5b8a-8740-9ceff293a0cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
