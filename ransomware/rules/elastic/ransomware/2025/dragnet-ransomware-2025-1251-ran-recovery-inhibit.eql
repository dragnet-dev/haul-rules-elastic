// Dragnet [Ransomware]: dragnet-ransomware-2025-1251 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3e28dad4-55ca-5329-a9ff-a2fb5242696c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
