// Dragnet [Ransomware]: dragnet-ransomware-2025-5689 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a6fdfece-6631-5a1e-aa4e-3ffcbb370846

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
