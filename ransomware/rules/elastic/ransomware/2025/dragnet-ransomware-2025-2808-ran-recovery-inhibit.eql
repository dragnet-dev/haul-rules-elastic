// Dragnet [Ransomware]: dragnet-ransomware-2025-2808 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: f47debfc-90b5-5461-b082-0cbd645fc0cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
