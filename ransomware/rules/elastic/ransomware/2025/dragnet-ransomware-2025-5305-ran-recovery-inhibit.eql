// Dragnet [Ransomware]: dragnet-ransomware-2025-5305 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 73f93f0c-8ee8-5697-9c80-844dac3ebf85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
