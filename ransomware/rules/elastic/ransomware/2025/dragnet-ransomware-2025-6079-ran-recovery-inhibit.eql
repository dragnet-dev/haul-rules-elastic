// Dragnet [Ransomware]: dragnet-ransomware-2025-6079 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 42c15193-5303-508b-a2fe-a2bf0242c825

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
