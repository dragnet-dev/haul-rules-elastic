// Dragnet [Ransomware]: dragnet-ransomware-2025-7324 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 1e96e065-4b98-5b2e-99ce-8816956a6517

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
