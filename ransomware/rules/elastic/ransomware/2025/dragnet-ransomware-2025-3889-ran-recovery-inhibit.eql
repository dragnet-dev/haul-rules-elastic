// Dragnet [Ransomware]: dragnet-ransomware-2025-3889 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: f509a34c-54b0-504b-a06a-486f589d095f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
