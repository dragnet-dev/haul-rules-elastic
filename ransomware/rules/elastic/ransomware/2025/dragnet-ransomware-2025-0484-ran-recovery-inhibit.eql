// Dragnet [Ransomware]: dragnet-ransomware-2025-0484 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2da19ca5-c450-53eb-af56-77ee9554686b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
