// Dragnet [Ransomware]: dragnet-ransomware-2025-1912 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: e9d5decb-784a-553b-9d35-3495144700b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
