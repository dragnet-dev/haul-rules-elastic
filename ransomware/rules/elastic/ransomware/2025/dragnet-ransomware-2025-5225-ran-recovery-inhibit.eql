// Dragnet [Ransomware]: dragnet-ransomware-2025-5225 — Recovery Inhibition (reynolds)
// Status: experimental | Level: high | ID: 64c63137-66b4-5b05-92dc-faaed2b4a943

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
