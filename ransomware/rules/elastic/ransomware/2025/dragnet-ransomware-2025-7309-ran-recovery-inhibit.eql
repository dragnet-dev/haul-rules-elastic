// Dragnet [Ransomware]: dragnet-ransomware-2025-7309 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 88fb6f01-afa7-5040-ae5f-5c7a2887cc9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
