// Dragnet [Ransomware]: dragnet-ransomware-2025-6377 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 070cb4ad-b791-56b1-93c3-a2b59256ec2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
