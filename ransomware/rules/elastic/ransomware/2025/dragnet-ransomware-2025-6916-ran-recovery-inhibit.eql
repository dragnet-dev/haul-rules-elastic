// Dragnet [Ransomware]: dragnet-ransomware-2025-6916 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: a2ae1d7e-b0bb-5764-ae1a-1e45dedf8824

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
