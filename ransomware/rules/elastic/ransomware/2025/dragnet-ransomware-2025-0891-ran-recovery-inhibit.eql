// Dragnet [Ransomware]: dragnet-ransomware-2025-0891 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: d4ade6e4-3b92-5965-bf40-aeca3f5a4915

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
