// Dragnet [Ransomware]: dragnet-ransomware-2025-6733 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 8cc430f3-e50c-512b-8231-3715ace896da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
