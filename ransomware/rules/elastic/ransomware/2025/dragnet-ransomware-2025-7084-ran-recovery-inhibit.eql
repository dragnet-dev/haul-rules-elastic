// Dragnet [Ransomware]: dragnet-ransomware-2025-7084 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 478733b0-3e32-561b-8442-9ece11552c94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
