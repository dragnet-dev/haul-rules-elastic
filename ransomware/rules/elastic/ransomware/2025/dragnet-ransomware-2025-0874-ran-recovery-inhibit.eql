// Dragnet [Ransomware]: dragnet-ransomware-2025-0874 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: cacca874-6d8b-5644-9630-c72427cb3fe9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
