// Dragnet [Ransomware]: dragnet-ransomware-2025-7239 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 731d479d-6bb5-5be5-862d-89b8daa0850e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
