// Dragnet [Ransomware]: dragnet-ransomware-2025-5912 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 157bb204-2cdb-537f-bb7e-85966a3e869c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
