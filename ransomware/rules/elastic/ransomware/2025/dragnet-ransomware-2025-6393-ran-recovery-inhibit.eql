// Dragnet [Ransomware]: dragnet-ransomware-2025-6393 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: a3c2dd14-9a1e-53cb-9ffc-2a99fd29eca6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
