// Dragnet [Ransomware]: dragnet-ransomware-2025-6174 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 4211ee2e-0eb6-5965-b37e-c41479a5f35b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
