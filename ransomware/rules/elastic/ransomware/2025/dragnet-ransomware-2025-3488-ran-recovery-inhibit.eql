// Dragnet [Ransomware]: dragnet-ransomware-2025-3488 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 385bdcb5-0ce9-5d72-9f5f-b612296212c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
