// Dragnet [Ransomware]: dragnet-ransomware-2025-7189 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: c9cee5ec-5379-58b5-852e-1d5884c39d7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
