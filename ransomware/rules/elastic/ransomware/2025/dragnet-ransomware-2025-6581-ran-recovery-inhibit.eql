// Dragnet [Ransomware]: dragnet-ransomware-2025-6581 — Recovery Inhibition (morpheus)
// Status: deprecated | Level: high | ID: e6654be1-e097-5832-8e0a-7dbb3afb677b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
