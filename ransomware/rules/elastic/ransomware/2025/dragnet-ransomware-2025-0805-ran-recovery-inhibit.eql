// Dragnet [Ransomware]: dragnet-ransomware-2025-0805 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 96543f56-088a-53e0-ad08-84132a03cb49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
