// Dragnet [Ransomware]: dragnet-ransomware-2025-3823 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 05d25f45-e60e-51bd-be3f-d51634685466

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
