// Dragnet [Ransomware]: dragnet-ransomware-2025-2795 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: cc1c7774-7ca9-5d15-8ee6-dd072312cc5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
