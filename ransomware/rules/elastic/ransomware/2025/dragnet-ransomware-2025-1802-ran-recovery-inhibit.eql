// Dragnet [Ransomware]: dragnet-ransomware-2025-1802 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 9684a167-3b83-5c75-add2-d9894a997fee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
