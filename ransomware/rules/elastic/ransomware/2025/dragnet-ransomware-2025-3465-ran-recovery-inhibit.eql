// Dragnet [Ransomware]: dragnet-ransomware-2025-3465 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 837b241b-7149-5a78-b3be-cc440ac90c3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
