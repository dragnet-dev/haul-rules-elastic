// Dragnet [Ransomware]: dragnet-ransomware-2025-2347 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 7c38f054-a856-5837-aca7-481067775856

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
