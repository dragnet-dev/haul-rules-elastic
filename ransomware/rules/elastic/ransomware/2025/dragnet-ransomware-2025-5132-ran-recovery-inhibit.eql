// Dragnet [Ransomware]: dragnet-ransomware-2025-5132 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 53fb4544-791d-556d-bf21-41890541ad37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
