// Dragnet [Ransomware]: dragnet-ransomware-2025-4782 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: faee667a-0405-5f81-a0d6-c975a345bc79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
