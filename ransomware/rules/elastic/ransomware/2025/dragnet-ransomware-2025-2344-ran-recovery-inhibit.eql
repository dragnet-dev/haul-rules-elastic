// Dragnet [Ransomware]: dragnet-ransomware-2025-2344 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 0475dcb1-f29f-5dff-814a-dfb32f1b0bf7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
