// Dragnet [Ransomware]: dragnet-ransomware-2025-5968 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 00da9859-a408-52ba-8d40-3cc058146dda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
