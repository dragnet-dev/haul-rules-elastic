// Dragnet [Ransomware]: dragnet-ransomware-2025-2154 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0dc59efe-198b-5846-b0aa-2af2c0fb9861

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
