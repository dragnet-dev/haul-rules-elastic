// Dragnet [Ransomware]: dragnet-ransomware-2025-4917 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 99a77863-ef80-5ada-b632-c83067fda26a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
