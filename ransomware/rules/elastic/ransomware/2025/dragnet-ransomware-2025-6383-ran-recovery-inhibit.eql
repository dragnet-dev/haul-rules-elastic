// Dragnet [Ransomware]: dragnet-ransomware-2025-6383 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 9755ae87-1027-5ae7-b7e7-5c65b58869f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
