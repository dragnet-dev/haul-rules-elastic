// Dragnet [Ransomware]: dragnet-ransomware-2025-4703 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 070fe9db-3fa5-588a-bacd-75a73852026e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
