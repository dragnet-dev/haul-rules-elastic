// Dragnet [Ransomware]: dragnet-ransomware-2025-4037 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: c9460685-f4d2-58c1-9e34-4b9a4e76115a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
