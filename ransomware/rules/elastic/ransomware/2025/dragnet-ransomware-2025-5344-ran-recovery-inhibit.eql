// Dragnet [Ransomware]: dragnet-ransomware-2025-5344 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 95d49717-6556-52b5-bb47-d6aaf8d18e76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
