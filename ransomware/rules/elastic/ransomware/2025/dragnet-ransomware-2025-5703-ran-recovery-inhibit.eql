// Dragnet [Ransomware]: dragnet-ransomware-2025-5703 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 960d215e-73f8-580f-8cec-60c61f4ce3ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
