// Dragnet [Ransomware]: dragnet-ransomware-2025-7281 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: bb2d016b-b35c-513b-9bce-43486a11abab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
