// Dragnet [Ransomware]: dragnet-ransomware-2025-2006 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: d4206951-586e-52e7-b06b-1793c871c35a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
