// Dragnet [Ransomware]: dragnet-ransomware-2025-0538 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 5b18c321-0b43-5924-834d-7afe39e635c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
