// Dragnet [Ransomware]: dragnet-ransomware-2025-5018 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 62360c2b-677e-5c4e-8d3f-ebc2288e2973

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
