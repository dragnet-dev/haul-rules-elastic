// Dragnet [Ransomware]: dragnet-ransomware-2025-7669 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 4bfde1d7-e5b1-5b5b-afba-697ac93ad56b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
