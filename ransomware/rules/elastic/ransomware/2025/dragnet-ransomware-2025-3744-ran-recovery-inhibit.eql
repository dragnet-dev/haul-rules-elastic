// Dragnet [Ransomware]: dragnet-ransomware-2025-3744 — Recovery Inhibition (satanlockv2)
// Status: experimental | Level: high | ID: 94f3c07a-9a50-5650-8693-67757a64f31f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
