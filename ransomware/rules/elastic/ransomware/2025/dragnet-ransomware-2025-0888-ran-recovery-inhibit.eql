// Dragnet [Ransomware]: dragnet-ransomware-2025-0888 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 5219865d-3fff-58c7-a431-32238b8f64be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
