// Dragnet [Ransomware]: dragnet-ransomware-2025-2009 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c8c3f46d-9868-5d91-ab2d-88aab959fa06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
