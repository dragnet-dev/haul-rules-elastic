// Dragnet [Ransomware]: dragnet-ransomware-2025-7754 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1057c86e-888d-5cc2-a9d7-eff354aed24c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
