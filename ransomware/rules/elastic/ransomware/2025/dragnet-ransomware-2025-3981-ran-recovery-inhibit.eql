// Dragnet [Ransomware]: dragnet-ransomware-2025-3981 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 5819e06a-e6f6-5385-83a8-5a2a161317e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
