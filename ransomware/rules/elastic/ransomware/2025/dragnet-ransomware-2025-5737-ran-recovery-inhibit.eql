// Dragnet [Ransomware]: dragnet-ransomware-2025-5737 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a087f022-346d-517d-bd6d-fd2ee93902aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
