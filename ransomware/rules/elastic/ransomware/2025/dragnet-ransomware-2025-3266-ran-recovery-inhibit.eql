// Dragnet [Ransomware]: dragnet-ransomware-2025-3266 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5d0e0fcb-eb92-5315-9a85-ec075e3758a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
