// Dragnet [Ransomware]: dragnet-ransomware-2025-2049 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ba141548-ddd1-5b50-abe2-59a47968aac5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
