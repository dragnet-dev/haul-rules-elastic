// Dragnet [Ransomware]: dragnet-ransomware-2025-1196 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 656abb41-27e4-568f-85ca-3899e10497ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
