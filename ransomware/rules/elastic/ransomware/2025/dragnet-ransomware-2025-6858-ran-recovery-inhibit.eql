// Dragnet [Ransomware]: dragnet-ransomware-2025-6858 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 70646426-f513-58ba-b599-64ee44334948

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
