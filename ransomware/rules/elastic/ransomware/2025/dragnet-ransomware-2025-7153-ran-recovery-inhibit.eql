// Dragnet [Ransomware]: dragnet-ransomware-2025-7153 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: 5e046b76-2c40-5fbc-84a6-e41d15ccaa7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
