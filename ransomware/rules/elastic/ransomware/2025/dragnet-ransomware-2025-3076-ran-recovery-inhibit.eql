// Dragnet [Ransomware]: dragnet-ransomware-2025-3076 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 5ed34d24-3312-5577-805d-a0a9b067e173

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
