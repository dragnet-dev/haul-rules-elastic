// Dragnet [Ransomware]: dragnet-ransomware-2025-6502 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: b7c8c8dd-5839-5018-9329-1dda93dab559

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
