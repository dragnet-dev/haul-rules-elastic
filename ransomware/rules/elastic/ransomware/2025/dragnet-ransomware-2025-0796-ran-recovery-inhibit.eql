// Dragnet [Ransomware]: dragnet-ransomware-2025-0796 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a540fddc-b38c-5aca-b8b9-63f8ab13796c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
