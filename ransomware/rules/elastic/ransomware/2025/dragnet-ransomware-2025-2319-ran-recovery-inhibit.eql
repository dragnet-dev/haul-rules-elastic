// Dragnet [Ransomware]: dragnet-ransomware-2025-2319 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 9e60d971-8d70-5da3-80bd-b303452828fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
