// Dragnet [Ransomware]: dragnet-ransomware-2025-4682 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 91a3885a-8fa3-53a4-a582-7794d81d90c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
