// Dragnet [Ransomware]: dragnet-ransomware-2025-6529 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 490cea47-d8e0-5abb-9f1a-0a5ea3295b0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
