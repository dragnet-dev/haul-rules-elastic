// Dragnet [Ransomware]: dragnet-ransomware-2025-3537 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 130fd5ed-ee1e-594a-ab4d-087cb90b9c2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
