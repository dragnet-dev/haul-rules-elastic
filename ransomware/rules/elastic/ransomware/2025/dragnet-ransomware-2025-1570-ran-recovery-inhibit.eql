// Dragnet [Ransomware]: dragnet-ransomware-2025-1570 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d70695f3-f330-5286-b7d0-a059639b96e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
