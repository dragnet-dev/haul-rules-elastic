// Dragnet [Ransomware]: dragnet-ransomware-2025-4948 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a9740bda-3efa-5598-8860-02c0a5f11f89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
