// Dragnet [Ransomware]: dragnet-ransomware-2025-1351 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 559cd835-12e8-52c6-b6f5-f0c7db897090

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
