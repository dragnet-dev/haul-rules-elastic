// Dragnet [Ransomware]: dragnet-ransomware-2025-0165 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 8725db82-0871-5a51-9c60-d4366920ec6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
