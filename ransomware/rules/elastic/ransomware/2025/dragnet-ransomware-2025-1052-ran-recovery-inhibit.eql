// Dragnet [Ransomware]: dragnet-ransomware-2025-1052 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ddfc6d5a-3783-5741-b5fa-160a92c94429

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
