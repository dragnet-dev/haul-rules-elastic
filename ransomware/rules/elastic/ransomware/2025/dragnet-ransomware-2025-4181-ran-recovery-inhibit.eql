// Dragnet [Ransomware]: dragnet-ransomware-2025-4181 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 7f0e539d-1cfb-58e7-af72-60d0853cdfc9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
