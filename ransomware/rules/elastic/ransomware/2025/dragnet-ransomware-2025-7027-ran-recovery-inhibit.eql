// Dragnet [Ransomware]: dragnet-ransomware-2025-7027 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 5899f26d-1827-5897-8a92-df697563d35a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
