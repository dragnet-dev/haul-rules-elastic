// Dragnet [Ransomware]: dragnet-ransomware-2025-6418 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 396639d8-4c27-5c32-99f7-9d27ea7749a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
