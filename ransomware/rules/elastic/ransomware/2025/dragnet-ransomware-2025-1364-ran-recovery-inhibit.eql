// Dragnet [Ransomware]: dragnet-ransomware-2025-1364 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 76f6b6c7-4c7c-5320-82c1-6402d438e96d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
