// Dragnet [Ransomware]: dragnet-ransomware-2025-7006 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 4d08847b-3515-5a94-93f5-cc246c5cedc3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
