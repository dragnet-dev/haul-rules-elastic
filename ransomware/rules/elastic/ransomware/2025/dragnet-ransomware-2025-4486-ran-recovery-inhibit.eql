// Dragnet [Ransomware]: dragnet-ransomware-2025-4486 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 699e5350-6825-5219-bbb5-128727b5677b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
