// Dragnet [Ransomware]: dragnet-ransomware-2025-6470 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 9fcc0f38-0ae1-5916-8c0b-5180fdef02af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
