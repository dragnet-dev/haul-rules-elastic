// Dragnet [Ransomware]: dragnet-ransomware-2025-2712 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 4cab10d5-5ee8-5947-b1ee-38f322d2c57a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
