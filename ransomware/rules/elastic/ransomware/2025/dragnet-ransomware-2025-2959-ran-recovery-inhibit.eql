// Dragnet [Ransomware]: dragnet-ransomware-2025-2959 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 34731465-88ad-5fb8-8ed1-7412a6cdb541

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
