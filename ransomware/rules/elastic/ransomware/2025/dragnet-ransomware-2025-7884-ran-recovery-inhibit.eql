// Dragnet [Ransomware]: dragnet-ransomware-2025-7884 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: 47a3b7fd-3298-56e7-8f1c-9e5a51242b1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
