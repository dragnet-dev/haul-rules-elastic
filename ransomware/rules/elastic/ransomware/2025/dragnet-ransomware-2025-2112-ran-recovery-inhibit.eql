// Dragnet [Ransomware]: dragnet-ransomware-2025-2112 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2f10e426-68b1-5ecb-a28c-23ba616693fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
