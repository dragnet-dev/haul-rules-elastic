// Dragnet [Ransomware]: dragnet-ransomware-2025-0477 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: c80a8cd7-91e2-555c-bd80-f6001ba85e0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
