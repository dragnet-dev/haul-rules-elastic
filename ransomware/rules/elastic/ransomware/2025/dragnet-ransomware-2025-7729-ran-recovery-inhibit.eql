// Dragnet [Ransomware]: dragnet-ransomware-2025-7729 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 5c71a146-3700-50e5-9ff3-7dd7b60edd9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
