// Dragnet [Ransomware]: dragnet-ransomware-2025-6918 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 5a818315-a83d-570b-b6e1-abf38fa5c464

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
