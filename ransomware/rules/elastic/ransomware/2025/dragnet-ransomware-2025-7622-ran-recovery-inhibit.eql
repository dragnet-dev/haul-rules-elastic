// Dragnet [Ransomware]: dragnet-ransomware-2025-7622 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 47ff31ce-4bb4-583e-8d8a-79f4f2ed1192

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
