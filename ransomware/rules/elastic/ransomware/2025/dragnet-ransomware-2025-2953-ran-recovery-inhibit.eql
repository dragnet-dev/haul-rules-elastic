// Dragnet [Ransomware]: dragnet-ransomware-2025-2953 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 930872df-968f-572a-b192-518148a9b40f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
