// Dragnet [Ransomware]: dragnet-ransomware-2025-5036 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: a9a44055-1591-5696-8229-2aac0fc1dbfb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
