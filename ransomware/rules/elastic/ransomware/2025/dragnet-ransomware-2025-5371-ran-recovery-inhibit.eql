// Dragnet [Ransomware]: dragnet-ransomware-2025-5371 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: d3180daa-9e34-52dc-be57-4cd1acba8291

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
