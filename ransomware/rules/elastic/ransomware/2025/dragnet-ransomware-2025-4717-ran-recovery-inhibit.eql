// Dragnet [Ransomware]: dragnet-ransomware-2025-4717 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3fbf672f-482c-57a3-91d5-0236dc543483

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
