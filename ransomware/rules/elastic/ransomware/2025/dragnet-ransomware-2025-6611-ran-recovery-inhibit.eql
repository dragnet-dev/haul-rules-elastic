// Dragnet [Ransomware]: dragnet-ransomware-2025-6611 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a796b755-26bd-5c96-8afd-cb50c4d62565

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
