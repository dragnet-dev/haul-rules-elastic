// Dragnet [Ransomware]: dragnet-ransomware-2025-6183 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1e1208ec-a1b3-5b1f-aa58-6bc9692ff686

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
