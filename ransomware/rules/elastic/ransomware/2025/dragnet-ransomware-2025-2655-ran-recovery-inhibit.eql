// Dragnet [Ransomware]: dragnet-ransomware-2025-2655 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 5c60999b-844a-59d9-b129-52c0989ae797

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
