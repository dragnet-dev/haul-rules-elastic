// Dragnet [Ransomware]: dragnet-ransomware-2025-4794 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: a88d6060-fc78-5a51-ace8-690070cb9e7c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
