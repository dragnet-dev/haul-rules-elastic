// Dragnet [Ransomware]: dragnet-ransomware-2025-6384 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ba080550-e810-5a6e-8609-1284b6a209f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
