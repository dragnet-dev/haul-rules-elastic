// Dragnet [Ransomware]: dragnet-ransomware-2025-1963 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a99582af-4a34-5398-aae0-b75537593494

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
