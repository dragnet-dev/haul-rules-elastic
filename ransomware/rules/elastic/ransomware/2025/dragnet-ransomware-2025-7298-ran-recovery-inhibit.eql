// Dragnet [Ransomware]: dragnet-ransomware-2025-7298 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: e06c66cc-6c30-5184-806c-e1749a265747

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
