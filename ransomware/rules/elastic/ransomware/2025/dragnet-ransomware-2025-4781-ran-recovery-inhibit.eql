// Dragnet [Ransomware]: dragnet-ransomware-2025-4781 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 0d7ba7a9-4ca6-5ca1-b018-6d6e38e85488

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
