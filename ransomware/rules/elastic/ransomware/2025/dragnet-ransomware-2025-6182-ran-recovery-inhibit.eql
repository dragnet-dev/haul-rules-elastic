// Dragnet [Ransomware]: dragnet-ransomware-2025-6182 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 4c3e29d0-60c6-514f-9976-ca799c55230f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
