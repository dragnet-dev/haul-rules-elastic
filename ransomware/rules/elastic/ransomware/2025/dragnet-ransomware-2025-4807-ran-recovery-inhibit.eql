// Dragnet [Ransomware]: dragnet-ransomware-2025-4807 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: c4e4abbb-0bd1-5df7-a1a5-16700791c2cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
