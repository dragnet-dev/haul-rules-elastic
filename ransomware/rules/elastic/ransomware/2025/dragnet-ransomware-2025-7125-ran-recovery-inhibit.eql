// Dragnet [Ransomware]: dragnet-ransomware-2025-7125 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3ff04d22-be10-52a5-8417-741604787b95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
