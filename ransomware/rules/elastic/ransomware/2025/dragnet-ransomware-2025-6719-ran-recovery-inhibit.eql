// Dragnet [Ransomware]: dragnet-ransomware-2025-6719 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 4e6d2cc3-bdbc-5bcf-8fb1-15a76a962936

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
