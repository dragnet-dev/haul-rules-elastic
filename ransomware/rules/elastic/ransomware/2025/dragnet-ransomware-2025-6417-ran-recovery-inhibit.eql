// Dragnet [Ransomware]: dragnet-ransomware-2025-6417 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 1cc65c69-2395-53b6-a581-301311e7511e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
