// Dragnet [Ransomware]: dragnet-ransomware-2025-0281 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 536ffda3-b07e-5f14-9e64-26ee49a4daa6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
