// Dragnet [Ransomware]: dragnet-ransomware-2025-3354 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 54cd5cac-15d8-5f97-9396-2e88cdbd6ce4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
