// Dragnet [Ransomware]: dragnet-ransomware-2025-6702 — Recovery Inhibition (arkana)
// Status: experimental | Level: high | ID: e4007919-7f16-5468-b5d3-00f884d7ed23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
