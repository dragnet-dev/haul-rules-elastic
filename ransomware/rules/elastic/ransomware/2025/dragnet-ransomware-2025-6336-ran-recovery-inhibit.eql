// Dragnet [Ransomware]: dragnet-ransomware-2025-6336 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: 0f8f4ab4-c3d8-52eb-b7c9-48addc833876

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
