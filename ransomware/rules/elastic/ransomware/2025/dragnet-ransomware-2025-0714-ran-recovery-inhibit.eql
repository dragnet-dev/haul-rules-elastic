// Dragnet [Ransomware]: dragnet-ransomware-2025-0714 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2174b789-4886-5f15-aa97-0f1e83f31487

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
