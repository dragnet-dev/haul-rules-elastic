// Dragnet [Ransomware]: dragnet-ransomware-2025-1528 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: ccbafeae-1d62-5432-be90-066a24076215

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
