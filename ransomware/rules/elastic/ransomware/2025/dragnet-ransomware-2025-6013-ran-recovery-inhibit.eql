// Dragnet [Ransomware]: dragnet-ransomware-2025-6013 — Recovery Inhibition (d4rk4rmy)
// Status: experimental | Level: high | ID: 7e8f4577-af8f-5cea-b7ea-e1a9e5ba46e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
