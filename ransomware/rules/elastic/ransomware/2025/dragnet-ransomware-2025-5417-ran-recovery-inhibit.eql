// Dragnet [Ransomware]: dragnet-ransomware-2025-5417 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 8253c478-3a4a-5add-9a0c-fd0f162b433f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
