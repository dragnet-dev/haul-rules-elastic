// Dragnet [Ransomware]: dragnet-ransomware-2025-6734 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: f8646126-5cb4-5773-a4a2-a2d45399edf2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
