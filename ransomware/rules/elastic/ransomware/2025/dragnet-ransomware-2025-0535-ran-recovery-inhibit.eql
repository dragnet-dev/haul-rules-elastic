// Dragnet [Ransomware]: dragnet-ransomware-2025-0535 — Recovery Inhibition (interlock)
// Status: test | Level: high | ID: d5854652-d501-5ee9-a185-a0c5546fa8e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
