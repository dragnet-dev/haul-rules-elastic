// Dragnet [Ransomware]: dragnet-ransomware-2025-2731 — Recovery Inhibition (daixin)
// Status: deprecated | Level: high | ID: dbd360f7-91c7-5e55-81cb-cc553f082418

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
