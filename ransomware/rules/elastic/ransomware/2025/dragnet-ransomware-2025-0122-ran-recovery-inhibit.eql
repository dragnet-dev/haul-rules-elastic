// Dragnet [Ransomware]: dragnet-ransomware-2025-0122 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: f2593e44-e60f-595b-b215-8ceefe952b6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
