// Dragnet [Ransomware]: dragnet-ransomware-2025-5602 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 9f0a3f2b-5370-57c7-a3cc-2abed55d90f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
