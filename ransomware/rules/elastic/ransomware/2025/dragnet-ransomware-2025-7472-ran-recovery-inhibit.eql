// Dragnet [Ransomware]: dragnet-ransomware-2025-7472 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: bc1a1d45-2501-52cd-ac01-55c04ad35e21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
