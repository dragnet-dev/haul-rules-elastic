// Dragnet [Ransomware]: dragnet-ransomware-2025-0168 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 7560ddac-2317-5826-9923-608dffebba1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
