// Dragnet [Ransomware]: dragnet-ransomware-2025-4408 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: 3e66cff7-4819-5a5c-b013-67e721016b33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
