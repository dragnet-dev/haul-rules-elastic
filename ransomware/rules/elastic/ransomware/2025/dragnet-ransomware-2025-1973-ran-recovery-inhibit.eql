// Dragnet [Ransomware]: dragnet-ransomware-2025-1973 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: 0c26951f-ce03-520e-8f00-dbbaf626c8b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
