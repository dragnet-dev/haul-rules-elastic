// Dragnet [Ransomware]: dragnet-ransomware-2025-3299 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5284045c-7214-5090-9990-afb87eeea22b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
