// Dragnet [Ransomware]: dragnet-ransomware-2025-0316 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: f05fa9dc-e996-5c31-b6a8-7c01a2100342

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
