// Dragnet [Ransomware]: dragnet-ransomware-2025-2477 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 681127c4-7259-50fb-b0bc-7f43b3c6ff56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
