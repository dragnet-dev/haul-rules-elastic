// Dragnet [Ransomware]: dragnet-ransomware-2025-2700 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1bc4b327-2a00-551e-b78e-86cad5b47224

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
