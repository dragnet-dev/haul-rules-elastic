// Dragnet [Ransomware]: dragnet-ransomware-2025-1155 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2d5c09a6-7d09-550a-b34d-386879cb48dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
