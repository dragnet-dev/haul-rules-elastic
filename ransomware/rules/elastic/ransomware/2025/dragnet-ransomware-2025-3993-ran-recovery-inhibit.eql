// Dragnet [Ransomware]: dragnet-ransomware-2025-3993 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 943b3b68-9223-572c-be75-71d304ac9cdd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
