// Dragnet [Ransomware]: dragnet-ransomware-2025-1242 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: edabf956-f192-52af-bd00-633dc960d62f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
