// Dragnet [Ransomware]: dragnet-ransomware-2025-4766 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7a173e94-494f-5052-b959-ffe0d5f762ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
