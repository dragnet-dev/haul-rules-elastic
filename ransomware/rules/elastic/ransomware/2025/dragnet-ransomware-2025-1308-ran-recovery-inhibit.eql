// Dragnet [Ransomware]: dragnet-ransomware-2025-1308 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: 78cea282-a0d3-5a69-b203-5a4a92eb1718

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
