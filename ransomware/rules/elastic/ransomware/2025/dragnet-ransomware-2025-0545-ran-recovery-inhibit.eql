// Dragnet [Ransomware]: dragnet-ransomware-2025-0545 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f2bd06d1-2a95-58ca-8477-3962358201f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
