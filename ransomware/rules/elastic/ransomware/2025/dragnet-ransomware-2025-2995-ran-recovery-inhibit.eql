// Dragnet [Ransomware]: dragnet-ransomware-2025-2995 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 7f2be8fa-a4b4-5ca1-a3af-ea7ed8326183

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
