// Dragnet [Ransomware]: dragnet-ransomware-2025-4842 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: e47f663b-190f-59d5-8ff3-027d97a4eca5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
