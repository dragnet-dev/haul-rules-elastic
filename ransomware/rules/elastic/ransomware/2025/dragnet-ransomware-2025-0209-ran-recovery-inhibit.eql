// Dragnet [Ransomware]: dragnet-ransomware-2025-0209 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: aa497d79-a400-55f4-9661-998059589f41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
