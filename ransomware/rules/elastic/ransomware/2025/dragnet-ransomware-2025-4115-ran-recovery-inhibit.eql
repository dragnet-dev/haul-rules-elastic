// Dragnet [Ransomware]: dragnet-ransomware-2025-4115 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 25a7d79e-99fe-56b7-b073-9c960f7fc69e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
