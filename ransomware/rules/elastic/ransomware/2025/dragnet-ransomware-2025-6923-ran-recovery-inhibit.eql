// Dragnet [Ransomware]: dragnet-ransomware-2025-6923 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cd8f6a31-ce6c-506a-9e0e-9264d8defd41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
