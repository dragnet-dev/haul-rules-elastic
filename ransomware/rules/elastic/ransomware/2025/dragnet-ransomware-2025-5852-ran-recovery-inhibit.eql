// Dragnet [Ransomware]: dragnet-ransomware-2025-5852 — Recovery Inhibition (gunra)
// Status: experimental | Level: high | ID: 9a63580e-ce7b-5aa6-a1f1-df041c5d4da5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
