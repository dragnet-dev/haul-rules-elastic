// Dragnet [Ransomware]: dragnet-ransomware-2025-3960 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: 06907a4d-76d6-58b3-9198-19c744ca289d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
