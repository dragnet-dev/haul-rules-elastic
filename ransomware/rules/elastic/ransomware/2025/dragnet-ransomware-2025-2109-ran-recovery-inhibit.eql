// Dragnet [Ransomware]: dragnet-ransomware-2025-2109 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: f1ad6abd-05dd-5299-af59-cf9b99456e8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
