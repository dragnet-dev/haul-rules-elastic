// Dragnet [Ransomware]: dragnet-ransomware-2025-5725 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: b463076c-e203-5e60-be57-74c1e5afe32c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
