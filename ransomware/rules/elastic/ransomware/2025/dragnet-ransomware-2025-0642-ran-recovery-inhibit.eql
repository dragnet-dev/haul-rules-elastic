// Dragnet [Ransomware]: dragnet-ransomware-2025-0642 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 96b42178-e2a4-594e-a4a6-afb00c531f07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
