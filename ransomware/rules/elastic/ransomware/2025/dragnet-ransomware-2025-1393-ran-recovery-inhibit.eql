// Dragnet [Ransomware]: dragnet-ransomware-2025-1393 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a423790f-08fe-5a03-b2c3-55f93e113777

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
