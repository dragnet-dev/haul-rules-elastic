// Dragnet [Ransomware]: dragnet-ransomware-2025-2273 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 45b0a0ed-a059-5644-92df-6c208426680b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
