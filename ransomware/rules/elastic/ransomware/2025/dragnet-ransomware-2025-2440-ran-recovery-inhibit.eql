// Dragnet [Ransomware]: dragnet-ransomware-2025-2440 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 35ba6cdc-6dec-5848-aa17-69b37a3934c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
