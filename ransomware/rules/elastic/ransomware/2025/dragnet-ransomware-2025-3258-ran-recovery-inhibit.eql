// Dragnet [Ransomware]: dragnet-ransomware-2025-3258 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0a6b249c-1836-5b92-8028-6c59e16231fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
