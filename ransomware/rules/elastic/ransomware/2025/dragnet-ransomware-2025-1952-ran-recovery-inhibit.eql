// Dragnet [Ransomware]: dragnet-ransomware-2025-1952 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: c8baadba-2078-5e61-a1c5-50af450d5acb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
