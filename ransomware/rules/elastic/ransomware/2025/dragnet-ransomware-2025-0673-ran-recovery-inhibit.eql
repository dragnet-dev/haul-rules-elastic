// Dragnet [Ransomware]: dragnet-ransomware-2025-0673 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d2c15348-fd7a-560a-87cf-7711c3530e63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
