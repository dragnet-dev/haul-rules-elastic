// Dragnet [Ransomware]: dragnet-ransomware-2025-6129 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 7b9ec5c6-2b68-5d87-8b07-da9dfeb6b09e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
