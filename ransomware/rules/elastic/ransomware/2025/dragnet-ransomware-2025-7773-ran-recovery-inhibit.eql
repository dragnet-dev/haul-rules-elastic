// Dragnet [Ransomware]: dragnet-ransomware-2025-7773 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 53c05e5f-5049-53cf-b21b-7d6124f31a0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
