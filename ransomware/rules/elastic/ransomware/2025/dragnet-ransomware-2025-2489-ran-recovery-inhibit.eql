// Dragnet [Ransomware]: dragnet-ransomware-2025-2489 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 0f4e6777-420e-587d-bfe8-d6ee0a718fd4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
