// Dragnet [Ransomware]: dragnet-ransomware-2025-1785 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 5947a405-6f59-51a8-8be9-817df6a04cba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
