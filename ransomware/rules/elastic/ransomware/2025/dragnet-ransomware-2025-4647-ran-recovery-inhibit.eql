// Dragnet [Ransomware]: dragnet-ransomware-2025-4647 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 800280d8-0ca3-5cc8-82d4-64596f1376eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
