// Dragnet [Ransomware]: dragnet-ransomware-2025-1896 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 7380511c-1250-52cf-b756-c4cac226c6d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
