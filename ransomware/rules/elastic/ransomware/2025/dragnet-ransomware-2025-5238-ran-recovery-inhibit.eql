// Dragnet [Ransomware]: dragnet-ransomware-2025-5238 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: f891500d-27ad-5a93-a320-8cfcd47198eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
