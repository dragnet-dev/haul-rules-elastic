// Dragnet [Ransomware]: dragnet-ransomware-2025-4170 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 25cff542-7a13-5899-b7bc-7f5a941f13c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
