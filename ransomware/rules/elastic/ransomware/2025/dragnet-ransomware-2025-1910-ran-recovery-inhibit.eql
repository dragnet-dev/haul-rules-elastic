// Dragnet [Ransomware]: dragnet-ransomware-2025-1910 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3ff9e86f-f380-59bd-aaf5-efc9e69ccfd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
