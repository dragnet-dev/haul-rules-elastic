// Dragnet [Ransomware]: dragnet-ransomware-2025-4783 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: e9d6f2b8-4fed-5e42-a306-97f3ff2d8ae3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
