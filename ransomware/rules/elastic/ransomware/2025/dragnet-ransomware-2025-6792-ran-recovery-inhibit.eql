// Dragnet [Ransomware]: dragnet-ransomware-2025-6792 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d0fd4509-c1c3-529f-be8a-b109be49e929

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
