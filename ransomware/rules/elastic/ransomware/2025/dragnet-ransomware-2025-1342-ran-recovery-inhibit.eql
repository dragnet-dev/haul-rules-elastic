// Dragnet [Ransomware]: dragnet-ransomware-2025-1342 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 9f60b11d-0f65-5dbc-a1bd-0f1b84df1ee8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
