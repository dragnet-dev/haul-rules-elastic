// Dragnet [Ransomware]: dragnet-ransomware-2025-4118 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 782e1361-d07d-599a-9511-0d538bc3eb50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
