// Dragnet [Ransomware]: dragnet-ransomware-2025-4831 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 8cafb3c0-c81e-5359-b398-e1b353f3b2e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
