// Dragnet [Ransomware]: dragnet-ransomware-2025-0128 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: e3b5be75-ad4b-5f31-a04d-2eac088a26d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
