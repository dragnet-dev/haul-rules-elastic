// Dragnet [Ransomware]: dragnet-ransomware-2025-3931 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: d7ca0ad9-1bf3-53b5-a0ce-ca29edb53d62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
