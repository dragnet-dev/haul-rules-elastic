// Dragnet [Ransomware]: dragnet-ransomware-2025-3608 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 5f851ef8-eba1-5df1-878c-75b0925cfa64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
