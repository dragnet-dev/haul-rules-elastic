// Dragnet [Ransomware]: dragnet-ransomware-2025-7885 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: d2a8cef0-7f62-567c-aee6-51775166cdc9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
