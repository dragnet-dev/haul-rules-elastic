// Dragnet [Ransomware]: dragnet-ransomware-2025-6450 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: a1c2a966-49ba-5ed6-bb87-f8bbe601e128

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
