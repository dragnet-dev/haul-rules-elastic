// Dragnet [Ransomware]: dragnet-ransomware-2025-5011 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 64dd532e-4a98-5096-b621-2239a839abb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
