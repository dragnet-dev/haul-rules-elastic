// Dragnet [Ransomware]: dragnet-ransomware-2025-1729 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: d0e1a7ea-ca61-5ff3-b6c5-9a97733f59d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
