// Dragnet [Ransomware]: dragnet-ransomware-2025-0842 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: d005565b-c4ee-56b0-9e20-fd7ae87c6a6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
