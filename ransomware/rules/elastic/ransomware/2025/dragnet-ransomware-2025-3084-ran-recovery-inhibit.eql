// Dragnet [Ransomware]: dragnet-ransomware-2025-3084 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 18a5a4da-cb42-528f-9002-6280f7cda1f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
