// Dragnet [Ransomware]: dragnet-ransomware-2025-6646 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 4e0b5231-3573-5386-91e7-e054148a0964

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
