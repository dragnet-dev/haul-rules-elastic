// Dragnet [Ransomware]: dragnet-ransomware-2025-4177 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 09ef8f48-8c79-5366-8784-105c105693fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
