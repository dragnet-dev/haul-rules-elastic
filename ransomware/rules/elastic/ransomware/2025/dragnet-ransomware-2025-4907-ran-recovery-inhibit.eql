// Dragnet [Ransomware]: dragnet-ransomware-2025-4907 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b1137227-7d69-5dac-9304-58a1cb56f4cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
