// Dragnet [Ransomware]: dragnet-ransomware-2025-3390 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: b05c8216-9342-5c84-ad46-0373cc829932

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
