// Dragnet [Ransomware]: dragnet-ransomware-2025-7539 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 235bb505-8468-5b82-b666-fa6313f6e34b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
