// Dragnet [Ransomware]: dragnet-ransomware-2025-4436 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e3542e04-c4f0-5e53-9951-f152061d5ca7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
