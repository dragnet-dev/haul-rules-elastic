// Dragnet [Ransomware]: dragnet-ransomware-2025-3413 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 62a69b2f-6e58-562e-98d5-3ef83f2fad1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
