// Dragnet [Ransomware]: dragnet-ransomware-2025-2463 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: b075535b-83d7-53c6-be06-1b4cea554b26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
