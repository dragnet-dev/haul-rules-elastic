// Dragnet [Ransomware]: dragnet-ransomware-2025-4345 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: e55f8bd8-762a-54c4-aac8-3440f279ec6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
