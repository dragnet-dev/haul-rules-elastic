// Dragnet [Ransomware]: dragnet-ransomware-2025-2936 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: b0fc40d7-a525-5a1c-b2f8-6c591b289d19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
