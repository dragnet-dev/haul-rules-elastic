// Dragnet [Ransomware]: dragnet-ransomware-2025-6552 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 45efa0da-c08a-5cd1-9927-8c41e061bc83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
