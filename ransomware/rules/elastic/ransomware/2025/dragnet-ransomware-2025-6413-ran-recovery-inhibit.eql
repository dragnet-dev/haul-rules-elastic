// Dragnet [Ransomware]: dragnet-ransomware-2025-6413 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 494db266-644c-559f-a923-649defa04da1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
