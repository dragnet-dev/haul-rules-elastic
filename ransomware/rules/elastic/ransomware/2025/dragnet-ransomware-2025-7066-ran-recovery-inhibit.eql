// Dragnet [Ransomware]: dragnet-ransomware-2025-7066 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: 1a063d43-ebdd-5a45-9eac-6de9afe9f389

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
