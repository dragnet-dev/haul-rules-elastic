// Dragnet [Ransomware]: dragnet-ransomware-2025-0872 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: 48fa20b1-d4f5-564f-a814-89c9f2f01038

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
