// Dragnet [Ransomware]: dragnet-ransomware-2025-2371 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 984f1241-015b-5e1c-96c9-0fc128905ab8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
