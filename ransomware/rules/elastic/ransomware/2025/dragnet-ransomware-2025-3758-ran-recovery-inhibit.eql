// Dragnet [Ransomware]: dragnet-ransomware-2025-3758 — Recovery Inhibition (weyhro)
// Status: experimental | Level: high | ID: ad611e68-18d1-536b-87a6-e4d0539fee12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
