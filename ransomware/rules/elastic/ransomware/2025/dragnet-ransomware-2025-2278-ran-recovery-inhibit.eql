// Dragnet [Ransomware]: dragnet-ransomware-2025-2278 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 889ddbdc-d5d6-5ed9-8405-414c08e2e783

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
