// Dragnet [Ransomware]: dragnet-ransomware-2025-5549 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 840c4b4e-6b1f-5b6b-a1e7-50e5f6fffc3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
