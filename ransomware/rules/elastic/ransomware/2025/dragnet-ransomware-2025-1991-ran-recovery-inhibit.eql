// Dragnet [Ransomware]: dragnet-ransomware-2025-1991 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 43bd9447-f703-570a-832c-488221fb07dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
