// Dragnet [Ransomware]: dragnet-ransomware-2025-2544 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 02efa1cd-f445-5bab-89ba-76f1b7bafdc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
