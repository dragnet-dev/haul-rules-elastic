// Dragnet [Ransomware]: dragnet-ransomware-2025-0084 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 110c3441-81ca-5af7-bf86-8757ba644c6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
