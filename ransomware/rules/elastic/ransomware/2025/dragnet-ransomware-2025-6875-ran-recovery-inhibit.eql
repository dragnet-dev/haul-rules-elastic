// Dragnet [Ransomware]: dragnet-ransomware-2025-6875 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b6c4f140-ac2c-5d63-87c1-26874892c60d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
