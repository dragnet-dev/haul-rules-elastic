// Dragnet [Ransomware]: dragnet-ransomware-2025-3101 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 69e11653-9eb1-5747-bb09-cc69ba8b2888

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
