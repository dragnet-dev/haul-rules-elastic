// Dragnet [Ransomware]: dragnet-ransomware-2025-6791 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: e5bdcba9-a54d-5e5e-b36b-ff8059c29fe9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
