// Dragnet [Ransomware]: dragnet-ransomware-2025-3056 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 18b4355b-ccca-50e9-bc02-90108dcb14b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
