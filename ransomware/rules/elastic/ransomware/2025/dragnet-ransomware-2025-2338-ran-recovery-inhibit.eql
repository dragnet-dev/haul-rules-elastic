// Dragnet [Ransomware]: dragnet-ransomware-2025-2338 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 3c50ba9f-7271-5ef6-a135-172b28497b8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
