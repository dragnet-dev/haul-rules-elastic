// Dragnet [Ransomware]: dragnet-ransomware-2025-5167 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: bad11879-188a-54cc-a33a-5d7f70e5f826

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
