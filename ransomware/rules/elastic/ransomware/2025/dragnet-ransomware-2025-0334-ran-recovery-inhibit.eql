// Dragnet [Ransomware]: dragnet-ransomware-2025-0334 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 7569a79f-9c6f-51e4-9322-c47b48c64bea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
