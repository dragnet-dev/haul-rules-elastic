// Dragnet [Ransomware]: dragnet-ransomware-2025-0104 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: c1dd3591-2708-51c7-ae00-0c1df69adf83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
