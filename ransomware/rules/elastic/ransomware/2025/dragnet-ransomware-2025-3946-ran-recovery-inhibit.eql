// Dragnet [Ransomware]: dragnet-ransomware-2025-3946 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: fa55cf4c-7cbb-528c-8e9f-6eb5c6e0ef70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
