// Dragnet [Ransomware]: dragnet-ransomware-2025-0739 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: 616d8e7e-13fc-5e2a-ad31-358b488fad68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
