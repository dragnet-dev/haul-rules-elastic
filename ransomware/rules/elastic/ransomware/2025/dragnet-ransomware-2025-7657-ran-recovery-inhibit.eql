// Dragnet [Ransomware]: dragnet-ransomware-2025-7657 — Recovery Inhibition (genesis)
// Status: experimental | Level: high | ID: dbfdcc91-8b31-5e24-ac0d-16215f500d3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
