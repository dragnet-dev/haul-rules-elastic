// Dragnet [Ransomware]: dragnet-ransomware-2025-4519 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8cab911e-e3cf-51ff-af73-b32607a5d9ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
