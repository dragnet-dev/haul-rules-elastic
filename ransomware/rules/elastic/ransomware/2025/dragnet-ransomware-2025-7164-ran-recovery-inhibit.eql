// Dragnet [Ransomware]: dragnet-ransomware-2025-7164 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: bcc12fda-7f77-5903-9f86-5c8dfb8838f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
