// Dragnet [Ransomware]: dragnet-ransomware-2025-0859 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: af6e8530-c3ce-5944-849d-7fd9c66c2632

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
