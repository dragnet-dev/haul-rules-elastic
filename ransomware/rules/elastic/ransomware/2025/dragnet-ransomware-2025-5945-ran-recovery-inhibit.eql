// Dragnet [Ransomware]: dragnet-ransomware-2025-5945 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 75560125-2179-5559-9b0a-9508afc89dc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
