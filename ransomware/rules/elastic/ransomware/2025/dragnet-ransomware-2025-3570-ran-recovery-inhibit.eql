// Dragnet [Ransomware]: dragnet-ransomware-2025-3570 — Recovery Inhibition (blackshrantac)
// Status: experimental | Level: high | ID: 06da452d-bd03-5c5c-a392-f059ba829959

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
