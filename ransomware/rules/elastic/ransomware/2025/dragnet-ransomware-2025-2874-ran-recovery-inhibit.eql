// Dragnet [Ransomware]: dragnet-ransomware-2025-2874 — Recovery Inhibition (securotrop)
// Status: experimental | Level: high | ID: 306e5275-114e-5e6e-a9cf-6f02236d87c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
