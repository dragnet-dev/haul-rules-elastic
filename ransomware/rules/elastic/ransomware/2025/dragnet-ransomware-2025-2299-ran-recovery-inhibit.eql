// Dragnet [Ransomware]: dragnet-ransomware-2025-2299 — Recovery Inhibition (medusa)
// Status: test | Level: high | ID: 1ce73095-add0-5ff3-b879-83df35622d99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
