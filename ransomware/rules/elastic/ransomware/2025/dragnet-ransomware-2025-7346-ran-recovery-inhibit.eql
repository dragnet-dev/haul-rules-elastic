// Dragnet [Ransomware]: dragnet-ransomware-2025-7346 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 76b98787-e894-5447-a77d-5357cf336123

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
