// Dragnet [Ransomware]: dragnet-ransomware-2025-2846 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7defc80d-6474-5d62-aa1d-edc3313f7d9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
