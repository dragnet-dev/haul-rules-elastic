// Dragnet [Ransomware]: dragnet-ransomware-2025-5024 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 5013e719-6300-5834-8066-130c54cbc90c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
