// Dragnet [Ransomware]: dragnet-ransomware-2025-5150 — Recovery Inhibition (genesis)
// Status: experimental | Level: high | ID: 19feadb1-4f31-50b2-b9a2-d459f317ca7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
