// Dragnet [Ransomware]: dragnet-ransomware-2025-1239 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 2746edcb-9513-5fbd-98ff-664a26e078e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
