// Dragnet [Ransomware]: dragnet-ransomware-2025-5778 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fe2d3914-1fd2-54c4-9ada-867f47e34b53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
