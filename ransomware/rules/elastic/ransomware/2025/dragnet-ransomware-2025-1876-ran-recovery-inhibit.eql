// Dragnet [Ransomware]: dragnet-ransomware-2025-1876 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 828fb242-e516-5b59-baf7-32cf6bce0150

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
