// Dragnet [Ransomware]: dragnet-ransomware-2025-4670 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 05e70299-3b70-5778-a0f9-b41bc382fd6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
