// Dragnet [Ransomware]: dragnet-ransomware-2025-5645 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: 85074023-524e-549e-96a5-a84aeb68d17c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
