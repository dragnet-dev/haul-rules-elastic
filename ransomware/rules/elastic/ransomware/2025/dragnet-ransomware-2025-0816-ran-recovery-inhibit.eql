// Dragnet [Ransomware]: dragnet-ransomware-2025-0816 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 54e2fb46-3ea9-5d1e-aeb5-ed7272843449

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
