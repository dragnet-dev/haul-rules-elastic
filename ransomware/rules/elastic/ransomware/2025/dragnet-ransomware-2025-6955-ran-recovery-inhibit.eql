// Dragnet [Ransomware]: dragnet-ransomware-2025-6955 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: 7d5a4833-a22d-5761-8a38-b7cd9954cb63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
