// Dragnet [Ransomware]: dragnet-ransomware-2025-6715 — Recovery Inhibition (datacarry)
// Status: deprecated | Level: high | ID: aea7556b-adbc-51a0-b684-915b4b1be2ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
