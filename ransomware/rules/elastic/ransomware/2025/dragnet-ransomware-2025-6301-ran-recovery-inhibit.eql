// Dragnet [Ransomware]: dragnet-ransomware-2025-6301 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 69ed3c53-1174-5b80-a687-662c40b7d672

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
