// Dragnet [Ransomware]: dragnet-ransomware-2025-4318 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: b8d7130a-7b14-5397-bbaf-fda2e056da25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
