// Dragnet [Ransomware]: dragnet-ransomware-2025-5627 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 4a8984ed-596e-59b0-858b-5fdd2941eb61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
