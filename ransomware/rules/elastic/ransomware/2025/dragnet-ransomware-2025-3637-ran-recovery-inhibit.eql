// Dragnet [Ransomware]: dragnet-ransomware-2025-3637 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 7b8dc2fe-dc6f-5849-8045-b052c0db6f7c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
