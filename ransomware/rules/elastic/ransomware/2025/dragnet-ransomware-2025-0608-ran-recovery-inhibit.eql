// Dragnet [Ransomware]: dragnet-ransomware-2025-0608 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 3a79ba43-92b2-5581-aec8-82e56910a8b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
