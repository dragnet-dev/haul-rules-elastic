// Dragnet [Ransomware]: dragnet-ransomware-2025-4013 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 513bc63c-f51a-58a9-b9d6-3deb2012257f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
