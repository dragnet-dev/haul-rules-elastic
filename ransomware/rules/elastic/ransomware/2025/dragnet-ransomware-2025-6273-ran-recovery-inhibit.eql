// Dragnet [Ransomware]: dragnet-ransomware-2025-6273 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: 7d3bc858-6ddc-556b-a969-398f22ee22e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
