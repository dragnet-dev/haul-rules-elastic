// Dragnet [Ransomware]: dragnet-ransomware-2025-4383 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 67098226-d530-5434-aa26-1aa8dceef211

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
