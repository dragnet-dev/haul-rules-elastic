// Dragnet [Ransomware]: dragnet-ransomware-2025-7063 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 8cd01e76-dddb-53ca-bd18-f1468d8ea757

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
