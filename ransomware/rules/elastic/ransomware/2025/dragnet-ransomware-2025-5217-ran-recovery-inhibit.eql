// Dragnet [Ransomware]: dragnet-ransomware-2025-5217 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 586ced9d-c3d9-5921-8b97-d5f0bf370172

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
