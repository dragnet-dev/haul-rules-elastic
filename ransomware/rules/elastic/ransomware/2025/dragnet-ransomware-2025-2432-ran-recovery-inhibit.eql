// Dragnet [Ransomware]: dragnet-ransomware-2025-2432 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 4e496070-6cb9-5f25-b5ac-4e174ec4cc93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
