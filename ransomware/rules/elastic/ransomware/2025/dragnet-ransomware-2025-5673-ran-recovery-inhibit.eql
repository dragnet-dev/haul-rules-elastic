// Dragnet [Ransomware]: dragnet-ransomware-2025-5673 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 77e3489b-b164-5335-83c4-a2c3a72f976e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
