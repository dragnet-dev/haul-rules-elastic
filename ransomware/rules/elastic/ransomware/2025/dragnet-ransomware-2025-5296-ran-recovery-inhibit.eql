// Dragnet [Ransomware]: dragnet-ransomware-2025-5296 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 56363dd4-cebb-5406-89ae-e712db4fe1ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
