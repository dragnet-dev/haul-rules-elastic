// Dragnet [Ransomware]: dragnet-ransomware-2025-7682 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a80e3f13-8f50-55f3-806b-ccce692d0e56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
