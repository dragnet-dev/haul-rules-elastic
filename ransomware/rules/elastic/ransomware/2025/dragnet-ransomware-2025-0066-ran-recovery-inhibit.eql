// Dragnet [Ransomware]: dragnet-ransomware-2025-0066 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 56acb147-e796-5ede-b275-61ae9a8688f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
