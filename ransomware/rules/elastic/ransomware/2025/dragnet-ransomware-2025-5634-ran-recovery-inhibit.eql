// Dragnet [Ransomware]: dragnet-ransomware-2025-5634 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 06a4bee5-ec29-5146-b624-206b96e77507

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
