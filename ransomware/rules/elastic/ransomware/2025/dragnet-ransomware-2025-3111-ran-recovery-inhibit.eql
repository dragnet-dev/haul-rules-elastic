// Dragnet [Ransomware]: dragnet-ransomware-2025-3111 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2946c92e-8768-54c9-9efa-973f26bc2b6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
