// Dragnet [Ransomware]: dragnet-ransomware-2025-6186 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a7042f5c-c5c0-516f-9888-927f19f6a7dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
