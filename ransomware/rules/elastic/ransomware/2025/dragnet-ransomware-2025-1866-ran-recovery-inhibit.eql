// Dragnet [Ransomware]: dragnet-ransomware-2025-1866 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 313f2027-e86b-54bd-b1f9-bc5534b5e50b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
