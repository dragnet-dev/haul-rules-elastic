// Dragnet [Ransomware]: dragnet-ransomware-2025-0145 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cbaed6e3-c1d0-54b4-bafd-e50f9120f2e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
