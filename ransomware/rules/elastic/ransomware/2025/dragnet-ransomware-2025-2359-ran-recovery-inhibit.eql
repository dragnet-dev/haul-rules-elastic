// Dragnet [Ransomware]: dragnet-ransomware-2025-2359 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 92278b16-042b-51a9-a8e0-a445a58e7bb2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
