// Dragnet [Ransomware]: dragnet-ransomware-2025-2763 — Recovery Inhibition (VanHelsing)
// Status: experimental | Level: high | ID: 07af55c3-d195-5e3a-9233-336c333ce147

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
