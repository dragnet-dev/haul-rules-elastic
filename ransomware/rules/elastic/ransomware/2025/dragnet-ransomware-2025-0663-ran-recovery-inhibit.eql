// Dragnet [Ransomware]: dragnet-ransomware-2025-0663 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7bf00c1a-8ba6-55ae-94cd-f4fb88d92d53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
