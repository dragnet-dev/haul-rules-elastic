// Dragnet [Ransomware]: dragnet-ransomware-2025-5879 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: a61a7a6c-1226-5262-b64e-2afea9fcb5f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
