// Dragnet [Ransomware]: dragnet-ransomware-2025-0577 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 77b0af3a-7b66-565b-90c6-60b93eadff75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
