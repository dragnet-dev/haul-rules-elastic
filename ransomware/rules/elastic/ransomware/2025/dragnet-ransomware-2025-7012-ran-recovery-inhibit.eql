// Dragnet [Ransomware]: dragnet-ransomware-2025-7012 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 0aab12d9-6fce-501a-a3fb-4771abb58b17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
