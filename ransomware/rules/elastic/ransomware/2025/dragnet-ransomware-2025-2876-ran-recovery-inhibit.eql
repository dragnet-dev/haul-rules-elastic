// Dragnet [Ransomware]: dragnet-ransomware-2025-2876 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0c6ee7be-a3ca-542d-8682-b842e4f9fa6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
