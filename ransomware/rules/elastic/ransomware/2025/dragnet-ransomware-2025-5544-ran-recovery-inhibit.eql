// Dragnet [Ransomware]: dragnet-ransomware-2025-5544 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a5ea5a30-4537-5e59-9148-8e6916accdfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
