// Dragnet [Ransomware]: dragnet-ransomware-2025-2978 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: f4bcbb4e-f846-5acc-a68c-0b1f2b9362dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
