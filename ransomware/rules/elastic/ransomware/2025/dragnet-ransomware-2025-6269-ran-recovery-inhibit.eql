// Dragnet [Ransomware]: dragnet-ransomware-2025-6269 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 3da7d3b1-5356-5e2c-8cec-f21cd67122bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
