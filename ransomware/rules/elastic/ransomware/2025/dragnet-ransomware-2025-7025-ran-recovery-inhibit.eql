// Dragnet [Ransomware]: dragnet-ransomware-2025-7025 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 3bec8102-656f-52d3-b164-7e08651121f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
