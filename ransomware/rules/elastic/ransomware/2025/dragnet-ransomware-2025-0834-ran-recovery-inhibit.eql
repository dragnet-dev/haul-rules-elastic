// Dragnet [Ransomware]: dragnet-ransomware-2025-0834 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 5a4f3569-02fe-5d83-9f5a-e1fc24c76998

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
