// Dragnet [Ransomware]: dragnet-ransomware-2025-6957 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 866b874d-122c-5788-8606-d1873a094047

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
