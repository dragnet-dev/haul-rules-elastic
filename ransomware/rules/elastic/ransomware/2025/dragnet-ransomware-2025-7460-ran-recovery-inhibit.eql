// Dragnet [Ransomware]: dragnet-ransomware-2025-7460 — Recovery Inhibition (kraken)
// Status: experimental | Level: high | ID: a610a7e7-65b3-5e0f-89dd-c0b57ccaa1c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
