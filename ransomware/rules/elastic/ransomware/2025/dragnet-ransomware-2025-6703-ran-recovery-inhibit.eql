// Dragnet [Ransomware]: dragnet-ransomware-2025-6703 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: bee571a2-aabf-5908-9e9c-e4291a499e49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
