// Dragnet [Ransomware]: dragnet-ransomware-2025-6515 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 34f15429-ecaf-5c10-a251-a6ee33f22cdb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
