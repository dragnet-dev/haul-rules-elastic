// Dragnet [Ransomware]: dragnet-ransomware-2025-4910 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 21415210-ac98-5ed3-9104-84769906feb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
