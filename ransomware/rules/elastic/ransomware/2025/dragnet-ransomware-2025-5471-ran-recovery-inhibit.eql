// Dragnet [Ransomware]: dragnet-ransomware-2025-5471 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: cb11713d-efce-5b76-abcb-6c9255795f2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
