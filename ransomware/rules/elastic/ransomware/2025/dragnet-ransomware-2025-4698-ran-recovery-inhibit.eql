// Dragnet [Ransomware]: dragnet-ransomware-2025-4698 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: f3ec7e8e-3336-5319-a130-48afbfd8eccf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
