// Dragnet [Ransomware]: dragnet-ransomware-2025-2626 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8e548c0b-b029-5001-ae4b-6478aa3a698f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
