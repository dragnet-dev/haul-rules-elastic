// Dragnet [Ransomware]: dragnet-ransomware-2025-4544 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: e721cf8a-578b-5517-96bb-50391d79504e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
