// Dragnet [Ransomware]: dragnet-ransomware-2025-7857 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6df18efc-3189-54c8-bc40-60ec51998702

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
