// Dragnet [Ransomware]: dragnet-ransomware-2025-3907 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 7e10638c-d372-54e9-a010-f9f40f3efad0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
