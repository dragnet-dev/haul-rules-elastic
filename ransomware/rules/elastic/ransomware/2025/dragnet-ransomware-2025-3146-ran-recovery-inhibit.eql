// Dragnet [Ransomware]: dragnet-ransomware-2025-3146 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8f8fd240-1e52-5a53-a675-c2554e32c82c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
