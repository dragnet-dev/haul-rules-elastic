// Dragnet [Ransomware]: dragnet-ransomware-2025-0559 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 0e314a61-11e0-5301-b79f-ab642373719a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
