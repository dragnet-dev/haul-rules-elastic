// Dragnet [Ransomware]: dragnet-ransomware-2025-7536 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: cd1b0ba0-a152-5076-a155-24a539a17421

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
