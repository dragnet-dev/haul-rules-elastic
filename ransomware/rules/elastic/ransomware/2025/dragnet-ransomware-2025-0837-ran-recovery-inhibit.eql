// Dragnet [Ransomware]: dragnet-ransomware-2025-0837 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 2ecb4925-2641-536f-863a-5428ca4d702d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
