// Dragnet [Ransomware]: dragnet-ransomware-2025-1820 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 0f77b980-221b-5641-b006-4982b412264c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
