// Dragnet [Ransomware]: dragnet-ransomware-2025-3224 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 05505cc7-5035-58cf-b0fc-a9904a261045

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
