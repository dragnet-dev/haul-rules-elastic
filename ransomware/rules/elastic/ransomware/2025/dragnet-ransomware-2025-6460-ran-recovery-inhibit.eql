// Dragnet [Ransomware]: dragnet-ransomware-2025-6460 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: f38b3195-bbc6-580d-9d84-e7afd0346351

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
