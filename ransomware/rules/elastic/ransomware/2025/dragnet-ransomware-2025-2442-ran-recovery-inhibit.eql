// Dragnet [Ransomware]: dragnet-ransomware-2025-2442 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: cc57ce7a-ec97-5c5a-a09f-be92cbeda29c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
