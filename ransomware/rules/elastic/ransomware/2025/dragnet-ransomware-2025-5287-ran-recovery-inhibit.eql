// Dragnet [Ransomware]: dragnet-ransomware-2025-5287 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 5e1c4307-897a-5793-a2e0-230eb6071d53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
