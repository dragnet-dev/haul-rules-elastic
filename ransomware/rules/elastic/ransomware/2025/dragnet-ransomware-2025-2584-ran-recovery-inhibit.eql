// Dragnet [Ransomware]: dragnet-ransomware-2025-2584 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 4aa2baf7-a9ef-5b27-bb1d-7c1c5d99f079

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
