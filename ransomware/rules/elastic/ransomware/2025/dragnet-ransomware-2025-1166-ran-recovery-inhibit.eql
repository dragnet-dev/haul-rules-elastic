// Dragnet [Ransomware]: dragnet-ransomware-2025-1166 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 67ce236c-b48d-51c5-8826-ab8e7e67291b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
