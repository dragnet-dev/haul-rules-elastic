// Dragnet [Ransomware]: dragnet-ransomware-2025-0469 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 75170cfb-12db-5a54-9959-111fd1819ccf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
