// Dragnet [Ransomware]: dragnet-ransomware-2025-7401 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4f82e911-b702-51a6-847c-61a071ec23f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
