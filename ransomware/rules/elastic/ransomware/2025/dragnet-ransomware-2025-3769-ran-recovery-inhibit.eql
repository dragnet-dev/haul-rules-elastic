// Dragnet [Ransomware]: dragnet-ransomware-2025-3769 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: b937d218-6a38-5a55-b0ce-1a870fc8818c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
