// Dragnet [Ransomware]: dragnet-ransomware-2025-2691 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: c6c2f419-d798-544e-811c-bc41f96ddfba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
