// Dragnet [Ransomware]: dragnet-ransomware-2025-2794 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: e809865b-3e32-5c57-9689-d8265f2876b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
