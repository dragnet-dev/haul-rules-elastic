// Dragnet [Ransomware]: dragnet-ransomware-2025-0159 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 48a57e86-1a87-5245-b1bc-30570b93fba4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
