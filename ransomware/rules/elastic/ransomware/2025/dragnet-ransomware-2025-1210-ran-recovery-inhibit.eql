// Dragnet [Ransomware]: dragnet-ransomware-2025-1210 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 8b407d5d-4c16-5706-8dc2-9a48c957fca3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
