// Dragnet [Ransomware]: dragnet-ransomware-2025-3244 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 1543b8ba-0909-5aaa-9a6a-1d92acac1b94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
