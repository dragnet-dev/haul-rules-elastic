// Dragnet [Ransomware]: dragnet-ransomware-2025-2170 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: ab4d6d70-5665-5669-822e-2bb84b36e34b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
