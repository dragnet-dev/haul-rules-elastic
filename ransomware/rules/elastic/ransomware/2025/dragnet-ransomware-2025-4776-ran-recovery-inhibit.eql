// Dragnet [Ransomware]: dragnet-ransomware-2025-4776 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: ca6496d8-b21e-51a8-8f7d-4d5f07f1820c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
