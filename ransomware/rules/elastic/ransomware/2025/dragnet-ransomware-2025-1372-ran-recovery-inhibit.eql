// Dragnet [Ransomware]: dragnet-ransomware-2025-1372 — Recovery Inhibition (cephalus)
// Status: experimental | Level: high | ID: 083125b9-d844-5909-8059-37e2979e04f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
