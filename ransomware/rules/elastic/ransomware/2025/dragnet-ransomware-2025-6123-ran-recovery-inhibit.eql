// Dragnet [Ransomware]: dragnet-ransomware-2025-6123 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d9b02610-f3f3-5426-9572-7422678bd62b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
