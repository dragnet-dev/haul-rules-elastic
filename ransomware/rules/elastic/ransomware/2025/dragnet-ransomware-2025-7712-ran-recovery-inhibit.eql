// Dragnet [Ransomware]: dragnet-ransomware-2025-7712 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 63ca4374-3081-5d5b-93ff-365c7f7e64f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
