// Dragnet [Ransomware]: dragnet-ransomware-2025-4916 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: 3284a91c-cde8-5601-8736-4878765e780a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
