// Dragnet [Ransomware]: dragnet-ransomware-2025-3559 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 9963b7cd-ff03-591d-9815-9e608db1d368

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
