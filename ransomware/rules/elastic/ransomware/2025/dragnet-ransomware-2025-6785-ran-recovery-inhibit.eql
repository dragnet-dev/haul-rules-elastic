// Dragnet [Ransomware]: dragnet-ransomware-2025-6785 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: cb506926-b22c-5ff1-b9aa-da9a4f07a44c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
