// Dragnet [Ransomware]: dragnet-ransomware-2025-2438 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: a50828f3-c5dd-515f-b0f6-3348fd6b8321

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
