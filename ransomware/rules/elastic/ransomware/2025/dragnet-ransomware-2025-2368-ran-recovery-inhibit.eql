// Dragnet [Ransomware]: dragnet-ransomware-2025-2368 — Recovery Inhibition (satanlockv2)
// Status: experimental | Level: high | ID: 742733c5-c4fb-5b63-ae6e-3954f15894f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
