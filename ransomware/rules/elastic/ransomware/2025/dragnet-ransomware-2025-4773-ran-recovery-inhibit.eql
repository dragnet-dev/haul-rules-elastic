// Dragnet [Ransomware]: dragnet-ransomware-2025-4773 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: 351a711b-e770-5ed3-a58d-06024f733945

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
