// Dragnet [Ransomware]: dragnet-ransomware-2025-6356 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 459684db-9f1f-5e98-829b-b86d555862d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
