// Dragnet [Ransomware]: dragnet-ransomware-2025-2696 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: d7a0ba1a-e683-5aeb-8d40-18084f3e3c82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
