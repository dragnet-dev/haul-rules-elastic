// Dragnet [Ransomware]: dragnet-ransomware-2025-4797 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 53f8d211-5cf5-5f2b-b390-b84f81a62ddc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
