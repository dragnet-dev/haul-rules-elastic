// Dragnet [Ransomware]: dragnet-ransomware-2025-5143 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: b430d6cd-8e22-5dd7-898f-53f76556a014

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
