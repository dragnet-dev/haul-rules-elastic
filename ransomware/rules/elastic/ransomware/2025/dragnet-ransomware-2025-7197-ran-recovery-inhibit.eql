// Dragnet [Ransomware]: dragnet-ransomware-2025-7197 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 40264cdf-9ba3-509d-8573-b63959647acd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
