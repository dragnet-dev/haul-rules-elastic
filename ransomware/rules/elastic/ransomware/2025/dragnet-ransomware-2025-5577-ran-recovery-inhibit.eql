// Dragnet [Ransomware]: dragnet-ransomware-2025-5577 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 749c8ba7-d975-5561-bae9-660d132fffd2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
