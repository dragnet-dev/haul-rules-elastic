// Dragnet [Ransomware]: dragnet-ransomware-2025-2336 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 473df9b5-6b7f-55c7-bb0e-58cf1e15c799

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
