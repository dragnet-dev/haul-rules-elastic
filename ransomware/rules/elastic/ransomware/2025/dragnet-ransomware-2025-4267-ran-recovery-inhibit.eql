// Dragnet [Ransomware]: dragnet-ransomware-2025-4267 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 14f0c8d2-41b5-5620-af98-0442c57483fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
