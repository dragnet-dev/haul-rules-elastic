// Dragnet [Ransomware]: dragnet-ransomware-2025-3407 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: dc6b643c-d781-5fbb-80e8-4a21fd2b9624

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
