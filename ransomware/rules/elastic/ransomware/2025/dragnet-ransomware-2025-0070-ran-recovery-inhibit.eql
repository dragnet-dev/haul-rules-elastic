// Dragnet [Ransomware]: dragnet-ransomware-2025-0070 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 82acdadf-68d4-5640-86da-d06438025999

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
