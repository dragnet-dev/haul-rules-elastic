// Dragnet [Ransomware]: dragnet-ransomware-2025-4525 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: f1d4cfb3-1fd0-5f66-9fb5-73f9faa6e470

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
