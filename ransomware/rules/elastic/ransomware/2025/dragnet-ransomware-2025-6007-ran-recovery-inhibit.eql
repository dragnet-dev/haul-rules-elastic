// Dragnet [Ransomware]: dragnet-ransomware-2025-6007 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 506854d4-b2d2-518f-8399-f9530adf0b79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
