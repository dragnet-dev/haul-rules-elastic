// Dragnet [Ransomware]: dragnet-ransomware-2025-4180 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 82b08fe5-aff6-5078-b2ea-dce05ed69cae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
