// Dragnet [Ransomware]: dragnet-ransomware-2025-5713 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cdd06e6d-6e0a-5d29-b07f-ce29f19d1237

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
