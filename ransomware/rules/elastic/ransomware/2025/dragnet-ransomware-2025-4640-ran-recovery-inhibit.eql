// Dragnet [Ransomware]: dragnet-ransomware-2025-4640 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 90ad2bce-5eac-52e5-8ca9-46773981112f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
