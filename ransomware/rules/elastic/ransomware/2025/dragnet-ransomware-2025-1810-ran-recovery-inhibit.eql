// Dragnet [Ransomware]: dragnet-ransomware-2025-1810 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 9a1f74d4-9f4f-545b-9962-299ea66f73c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
