// Dragnet [Ransomware]: dragnet-ransomware-2025-7513 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9f0b12fd-1136-597c-86e2-ca537e5af947

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
