// Dragnet [Ransomware]: dragnet-ransomware-2025-0774 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 69c02bab-d00a-5a2f-b339-239773bbe33c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
