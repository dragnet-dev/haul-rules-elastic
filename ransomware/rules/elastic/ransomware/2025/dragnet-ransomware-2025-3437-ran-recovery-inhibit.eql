// Dragnet [Ransomware]: dragnet-ransomware-2025-3437 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3623a907-8806-58d8-bccf-c393cdb911fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
