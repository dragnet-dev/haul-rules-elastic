// Dragnet [Ransomware]: dragnet-ransomware-2025-4964 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1345fbd1-451c-5c87-8851-ed15b822f722

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
