// Dragnet [Ransomware]: dragnet-ransomware-2025-0355 — Recovery Inhibition (apos)
// Status: experimental | Level: high | ID: 348d394b-bbb8-528d-baae-56ca89f975e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
