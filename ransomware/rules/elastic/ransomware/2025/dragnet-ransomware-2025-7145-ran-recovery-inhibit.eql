// Dragnet [Ransomware]: dragnet-ransomware-2025-7145 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 51cd87ae-1b62-511f-bda2-663461c9dc16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
