// Dragnet [Ransomware]: dragnet-ransomware-2025-5053 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: eeda7b62-1b83-5094-8da5-ee5ec75535fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
