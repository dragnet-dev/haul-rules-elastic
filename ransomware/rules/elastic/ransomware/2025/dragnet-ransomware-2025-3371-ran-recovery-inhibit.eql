// Dragnet [Ransomware]: dragnet-ransomware-2025-3371 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 74d6ae13-6fde-55a5-994f-584945466575

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
