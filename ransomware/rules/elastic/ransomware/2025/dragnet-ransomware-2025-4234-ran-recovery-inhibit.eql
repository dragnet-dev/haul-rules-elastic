// Dragnet [Ransomware]: dragnet-ransomware-2025-4234 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: da7ed28c-19e1-547c-a0df-d4a4491d12b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
