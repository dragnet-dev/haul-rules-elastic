// Dragnet [Ransomware]: dragnet-ransomware-2025-7484 — Recovery Inhibition (direwolf)
// Status: test | Level: high | ID: c6e499ed-ef37-54ea-88a2-73ff26bac310

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
