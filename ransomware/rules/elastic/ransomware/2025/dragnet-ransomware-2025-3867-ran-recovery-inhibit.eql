// Dragnet [Ransomware]: dragnet-ransomware-2025-3867 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: f7b7442f-94f5-5af2-9aa5-766484d8fd10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
