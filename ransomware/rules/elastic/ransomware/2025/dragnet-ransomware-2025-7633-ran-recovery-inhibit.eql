// Dragnet [Ransomware]: dragnet-ransomware-2025-7633 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 686a58bd-3342-5e17-b811-c2254f500d15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
