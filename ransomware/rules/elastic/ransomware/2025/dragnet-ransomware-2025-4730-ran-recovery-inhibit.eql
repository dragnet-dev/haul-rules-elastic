// Dragnet [Ransomware]: dragnet-ransomware-2025-4730 — Recovery Inhibition (bravox)
// Status: test | Level: high | ID: cb485abd-afdf-56bb-bb64-c8f6db5fb13b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
