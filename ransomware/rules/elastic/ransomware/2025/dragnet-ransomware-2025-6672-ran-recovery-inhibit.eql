// Dragnet [Ransomware]: dragnet-ransomware-2025-6672 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 04fe9e37-75f9-53aa-83d3-c45d80fca093

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
