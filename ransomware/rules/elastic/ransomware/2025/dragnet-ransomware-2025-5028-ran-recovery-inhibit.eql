// Dragnet [Ransomware]: dragnet-ransomware-2025-5028 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 96252e4f-959d-5447-a0d9-9efa4ba39bd2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
