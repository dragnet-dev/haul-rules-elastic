// Dragnet [Ransomware]: dragnet-ransomware-2025-7404 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 6cd80d13-eabd-5ea5-86f6-00bc033b39d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
