// Dragnet [Ransomware]: dragnet-ransomware-2025-3009 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 0335b282-9edb-586a-830d-e78560fab3b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
