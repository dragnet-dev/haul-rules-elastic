// Dragnet [Ransomware]: dragnet-ransomware-2025-1061 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: e07b2886-fe53-5963-a108-4381fa985fef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
