// Dragnet [Ransomware]: dragnet-ransomware-2025-6136 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8a0b92c8-f0d0-5d3b-85cc-383746c4dd0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
