// Dragnet [Ransomware]: dragnet-ransomware-2025-2054 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: ea7ef80d-ba0c-5396-9fdc-39576fed286a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
