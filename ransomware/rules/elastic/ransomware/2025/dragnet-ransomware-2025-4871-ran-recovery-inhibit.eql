// Dragnet [Ransomware]: dragnet-ransomware-2025-4871 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 302eeac9-c7aa-53f6-ac72-30f514a88a3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
