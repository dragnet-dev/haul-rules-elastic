// Dragnet [Ransomware]: dragnet-ransomware-2025-4214 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 68709c76-33fe-5960-b1d1-6e6271b307ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
