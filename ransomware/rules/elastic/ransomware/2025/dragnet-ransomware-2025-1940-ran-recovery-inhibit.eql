// Dragnet [Ransomware]: dragnet-ransomware-2025-1940 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: bb70c992-a323-5c32-bc98-1585c7319b1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
