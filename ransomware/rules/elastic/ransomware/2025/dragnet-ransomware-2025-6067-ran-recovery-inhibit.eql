// Dragnet [Ransomware]: dragnet-ransomware-2025-6067 — Recovery Inhibition (blackshrantac)
// Status: test | Level: high | ID: 58b82401-0a5d-5ac2-bb5a-31cfc8264c82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
