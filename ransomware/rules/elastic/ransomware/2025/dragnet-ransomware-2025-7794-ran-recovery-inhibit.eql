// Dragnet [Ransomware]: dragnet-ransomware-2025-7794 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 96ffca79-5535-5e3c-8ded-0192bd8af8d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
