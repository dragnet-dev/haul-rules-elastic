// Dragnet [Ransomware]: dragnet-ransomware-2025-1704 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b5080cab-35a7-5227-b24f-feb4496841f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
