// Dragnet [Ransomware]: dragnet-ransomware-2025-1187 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: a7aea59e-1e5c-5848-861d-3f11f36db201

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
