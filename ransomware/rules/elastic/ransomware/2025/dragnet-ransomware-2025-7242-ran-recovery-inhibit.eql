// Dragnet [Ransomware]: dragnet-ransomware-2025-7242 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: eaa09f92-839e-56e1-94e2-4d94c729f8af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
