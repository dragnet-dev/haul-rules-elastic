// Dragnet [Ransomware]: dragnet-ransomware-2025-1222 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e0e64029-6ed4-5062-a152-925c74afeaa3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
