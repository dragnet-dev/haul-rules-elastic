// Dragnet [Ransomware]: dragnet-ransomware-2025-1679 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 20de2be4-2988-5015-a73b-6a4823632d40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
