// Dragnet [Ransomware]: dragnet-ransomware-2025-5548 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e50d2544-79a7-517d-ab39-041084f46b85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
