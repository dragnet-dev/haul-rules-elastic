// Dragnet [Ransomware]: dragnet-ransomware-2025-1436 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: c83701e5-b65f-5c3e-a997-d15c2eb7e62f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
