// Dragnet [Ransomware]: dragnet-ransomware-2025-3489 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: f9b416ca-05ee-586b-a698-4ce97fa5b5f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
