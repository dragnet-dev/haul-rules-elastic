// Dragnet [Ransomware]: dragnet-ransomware-2025-3468 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: aaadce5b-bd3b-50e9-bdbd-67325e75d311

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
