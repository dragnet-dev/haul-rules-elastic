// Dragnet [Ransomware]: dragnet-ransomware-2025-0148 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2f2b4d3e-690a-5467-bf41-511055a9f38e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
