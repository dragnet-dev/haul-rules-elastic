// Dragnet [Ransomware]: dragnet-ransomware-2025-0501 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e9f28821-c3b1-5d25-b945-e1c55632978b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
