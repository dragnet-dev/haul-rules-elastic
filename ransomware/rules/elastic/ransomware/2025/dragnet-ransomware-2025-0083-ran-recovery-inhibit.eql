// Dragnet [Ransomware]: dragnet-ransomware-2025-0083 — Recovery Inhibition (ransomhouse)
// Status: test | Level: high | ID: 9cb71206-1dd5-5c09-b682-7f08bd6af5ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
