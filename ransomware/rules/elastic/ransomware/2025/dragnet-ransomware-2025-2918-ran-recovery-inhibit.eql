// Dragnet [Ransomware]: dragnet-ransomware-2025-2918 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: c565f332-0752-5921-bdc6-c0eebc90b15d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
