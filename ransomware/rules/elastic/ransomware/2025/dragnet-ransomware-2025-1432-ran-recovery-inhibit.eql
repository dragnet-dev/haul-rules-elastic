// Dragnet [Ransomware]: dragnet-ransomware-2025-1432 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: de8e40fa-1c99-5425-ac44-e80e2ccd2dc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
