// Dragnet [Ransomware]: dragnet-ransomware-2025-1543 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 142e0a92-c75f-59db-8b9e-577c9562b131

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
