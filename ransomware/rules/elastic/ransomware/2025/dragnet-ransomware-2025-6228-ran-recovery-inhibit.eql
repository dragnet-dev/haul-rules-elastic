// Dragnet [Ransomware]: dragnet-ransomware-2025-6228 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ad667bca-6a38-5da3-8a22-d832a4f3d072

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
