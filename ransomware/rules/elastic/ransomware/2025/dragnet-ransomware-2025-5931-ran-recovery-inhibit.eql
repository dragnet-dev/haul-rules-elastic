// Dragnet [Ransomware]: dragnet-ransomware-2025-5931 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2df68034-2690-5d66-bc5d-0501c1b966b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
