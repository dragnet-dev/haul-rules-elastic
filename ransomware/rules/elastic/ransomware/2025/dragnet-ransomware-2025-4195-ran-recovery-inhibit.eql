// Dragnet [Ransomware]: dragnet-ransomware-2025-4195 — Recovery Inhibition (hellcat)
// Status: deprecated | Level: high | ID: 9e7678d0-9ba8-5897-9cbf-8398638b8599

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
