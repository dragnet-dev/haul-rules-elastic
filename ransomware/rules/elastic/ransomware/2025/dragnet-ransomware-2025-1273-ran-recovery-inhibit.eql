// Dragnet [Ransomware]: dragnet-ransomware-2025-1273 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: 789e69e8-2fea-5fc1-9986-4a37c80479e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
