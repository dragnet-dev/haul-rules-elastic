// Dragnet [Ransomware]: dragnet-ransomware-2025-2826 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ba0c71fa-0691-5f8e-9208-fc86b70b0ce7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
