// Dragnet [Ransomware]: dragnet-ransomware-2025-3097 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e0f91156-92c9-5466-be74-8abc497643aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
