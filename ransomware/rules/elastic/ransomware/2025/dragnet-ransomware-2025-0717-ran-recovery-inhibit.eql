// Dragnet [Ransomware]: dragnet-ransomware-2025-0717 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 14f22d86-bcec-55a7-a488-19727020ac68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
