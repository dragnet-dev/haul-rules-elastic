// Dragnet [Ransomware]: dragnet-ransomware-2025-1637 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: 409945fe-ac4a-592b-b1cf-3ecda6e11354

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
