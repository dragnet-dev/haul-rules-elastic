// Dragnet [Ransomware]: dragnet-ransomware-2025-4256 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: ed8aa587-4cc3-579a-b2aa-de197f540eac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
