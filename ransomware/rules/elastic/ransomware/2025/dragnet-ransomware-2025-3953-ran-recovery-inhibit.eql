// Dragnet [Ransomware]: dragnet-ransomware-2025-3953 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 57a2656c-f283-55be-b28a-5f75035e91e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
