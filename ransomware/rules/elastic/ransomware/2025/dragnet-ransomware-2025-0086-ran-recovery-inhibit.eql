// Dragnet [Ransomware]: dragnet-ransomware-2025-0086 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c85efedb-f46b-544c-9162-8e7ea913de00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
