// Dragnet [Ransomware]: dragnet-ransomware-2025-7423 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 57b6f40e-5e0f-52ad-b1d0-19f42bfa8914

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
