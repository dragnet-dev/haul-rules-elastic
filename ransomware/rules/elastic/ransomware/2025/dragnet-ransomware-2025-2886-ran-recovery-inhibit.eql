// Dragnet [Ransomware]: dragnet-ransomware-2025-2886 — Recovery Inhibition (medusa)
// Status: deprecated | Level: high | ID: a24da3ec-1f28-5c9d-9a24-69c6eeb2fba3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
