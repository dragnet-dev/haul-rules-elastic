// Dragnet [Ransomware]: dragnet-ransomware-2025-4885 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 839f8770-34cf-5f20-898d-134240f5f82e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
