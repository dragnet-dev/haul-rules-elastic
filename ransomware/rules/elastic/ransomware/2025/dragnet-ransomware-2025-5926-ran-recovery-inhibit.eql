// Dragnet [Ransomware]: dragnet-ransomware-2025-5926 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: ace980a0-39ea-5c95-9908-807f05db3bdb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
