// Dragnet [Ransomware]: dragnet-ransomware-2025-2882 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: e715d78b-bbfc-5fe3-b73c-58b42cf3c63d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
