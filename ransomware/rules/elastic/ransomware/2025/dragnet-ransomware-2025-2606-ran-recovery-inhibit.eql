// Dragnet [Ransomware]: dragnet-ransomware-2025-2606 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: 513e8d10-559a-52ee-8881-e7005c056a86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
