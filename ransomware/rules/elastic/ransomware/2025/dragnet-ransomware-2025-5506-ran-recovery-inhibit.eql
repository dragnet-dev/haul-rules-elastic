// Dragnet [Ransomware]: dragnet-ransomware-2025-5506 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: f8af7e5c-afa5-5cfa-9f5c-3b12f16128c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
