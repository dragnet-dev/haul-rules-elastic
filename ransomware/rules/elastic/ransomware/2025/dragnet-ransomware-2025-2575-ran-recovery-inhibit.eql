// Dragnet [Ransomware]: dragnet-ransomware-2025-2575 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: ffc6e4f5-b6fb-5b83-a0f8-f2a609e74eb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
