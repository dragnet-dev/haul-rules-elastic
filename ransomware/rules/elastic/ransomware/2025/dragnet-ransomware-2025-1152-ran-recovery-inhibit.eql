// Dragnet [Ransomware]: dragnet-ransomware-2025-1152 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 7bd6dfb7-8c9c-50b6-9b31-338d19f659dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
