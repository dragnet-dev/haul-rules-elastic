// Dragnet [Ransomware]: dragnet-ransomware-2025-3128 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2fca7154-4641-523a-b8a3-3dbe6218e9a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
