// Dragnet [Ransomware]: dragnet-ransomware-2025-7344 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 79a71254-7c67-5171-8e45-64edc4fd1bc3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
