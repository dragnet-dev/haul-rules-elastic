// Dragnet [Ransomware]: dragnet-ransomware-2025-4502 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: a99c2a61-f07c-52b6-b0d2-72de9415efbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
