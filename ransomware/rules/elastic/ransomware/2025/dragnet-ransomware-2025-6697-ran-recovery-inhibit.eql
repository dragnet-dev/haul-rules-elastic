// Dragnet [Ransomware]: dragnet-ransomware-2025-6697 — Recovery Inhibition (tridentlocker)
// Status: experimental | Level: high | ID: 0007e85f-23d3-53f9-b17e-9cd5a5cec5e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
