// Dragnet [Ransomware]: dragnet-ransomware-2025-6609 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: ab5ff235-14d7-522e-81d2-0f95fc4a96da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
