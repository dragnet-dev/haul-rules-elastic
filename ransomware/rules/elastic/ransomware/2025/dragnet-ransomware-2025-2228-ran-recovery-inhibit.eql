// Dragnet [Ransomware]: dragnet-ransomware-2025-2228 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a9232208-7ab4-54e2-961a-6b3bcdf71a78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
