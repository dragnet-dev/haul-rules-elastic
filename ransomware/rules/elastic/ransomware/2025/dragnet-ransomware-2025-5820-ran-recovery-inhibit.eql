// Dragnet [Ransomware]: dragnet-ransomware-2025-5820 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 870d395d-ea67-5980-9ad4-dc0ad16c51a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
