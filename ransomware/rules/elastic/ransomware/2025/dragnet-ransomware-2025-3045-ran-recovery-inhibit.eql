// Dragnet [Ransomware]: dragnet-ransomware-2025-3045 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 4b5aaebe-24c8-5d69-9ccf-183e225c27e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
