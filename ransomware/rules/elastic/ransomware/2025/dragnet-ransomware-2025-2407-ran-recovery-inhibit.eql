// Dragnet [Ransomware]: dragnet-ransomware-2025-2407 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 0dfc360f-4bbb-5253-a6ce-2fd290f2a7c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
