// Dragnet [Ransomware]: dragnet-ransomware-2025-6294 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 8550d659-87f6-5aeb-ac7d-a3856a04c34d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
