// Dragnet [Ransomware]: dragnet-ransomware-2025-5625 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: e606aa72-d586-53f2-b79d-336ce5f76289

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
