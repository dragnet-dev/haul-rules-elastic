// Dragnet [Ransomware]: dragnet-ransomware-2025-2213 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: fca021ef-5b26-5bff-8302-f6b0ea89f2ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
