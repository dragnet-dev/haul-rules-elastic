// Dragnet [Ransomware]: dragnet-ransomware-2025-2450 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: b04f547b-7964-5963-b4d1-a5ee7c3cb285

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
