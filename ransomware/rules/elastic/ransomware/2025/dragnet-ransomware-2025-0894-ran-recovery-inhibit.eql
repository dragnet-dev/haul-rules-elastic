// Dragnet [Ransomware]: dragnet-ransomware-2025-0894 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: c88c933d-a341-50b0-8f6b-ee972c18c731

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
