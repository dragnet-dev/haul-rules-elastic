// Dragnet [Ransomware]: dragnet-ransomware-2025-6917 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: ee9104e8-0369-5ad6-a76e-b186de753bc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
