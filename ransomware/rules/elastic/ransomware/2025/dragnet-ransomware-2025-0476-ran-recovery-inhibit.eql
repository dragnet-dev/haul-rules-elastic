// Dragnet [Ransomware]: dragnet-ransomware-2025-0476 — Recovery Inhibition (chaos)
// Status: test | Level: high | ID: 44aa6b70-893b-58ca-98ef-ba77f01db3c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
