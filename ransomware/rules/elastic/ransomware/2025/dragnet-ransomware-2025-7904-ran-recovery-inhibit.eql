// Dragnet [Ransomware]: dragnet-ransomware-2025-7904 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 98b0faa8-b29f-5c58-ad27-b2425e47bae6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
