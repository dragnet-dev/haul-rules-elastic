// Dragnet [Ransomware]: dragnet-ransomware-2025-7493 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: e61f81b6-3ac6-5892-93fc-5e5a681dbaf5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
