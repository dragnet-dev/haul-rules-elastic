// Dragnet [Ransomware]: dragnet-ransomware-2025-1073 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: de23469b-46c3-53fe-b8ec-fbce0bc411ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
