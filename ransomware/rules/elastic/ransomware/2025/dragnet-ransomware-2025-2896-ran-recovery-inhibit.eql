// Dragnet [Ransomware]: dragnet-ransomware-2025-2896 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: 891dd4e9-5e28-524c-bde7-054efc043629

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
