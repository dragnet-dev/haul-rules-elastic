// Dragnet [Ransomware]: dragnet-ransomware-2025-4566 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 53b807b3-c528-5da6-9bc7-f7cbf4cc73c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
