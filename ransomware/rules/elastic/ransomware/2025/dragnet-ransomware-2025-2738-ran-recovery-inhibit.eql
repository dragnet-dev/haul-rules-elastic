// Dragnet [Ransomware]: dragnet-ransomware-2025-2738 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 34f046b0-93b4-5831-936a-b1af0b2ec3ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
