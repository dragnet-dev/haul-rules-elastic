// Dragnet [Ransomware]: dragnet-ransomware-2025-2486 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 879c2afe-413e-5b27-9bee-66b07e58f680

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
