// Dragnet [Ransomware]: dragnet-ransomware-2025-1558 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: 5ca2021c-b095-5824-a561-df3b4d4553a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
