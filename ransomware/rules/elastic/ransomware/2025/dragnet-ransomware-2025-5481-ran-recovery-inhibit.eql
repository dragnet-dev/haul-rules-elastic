// Dragnet [Ransomware]: dragnet-ransomware-2025-5481 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: d6883000-fcb3-58ed-8334-b3cb8ccf6843

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
