// Dragnet [Ransomware]: dragnet-ransomware-2025-4886 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9a033f55-8460-5e62-8616-84928f5e9fac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
