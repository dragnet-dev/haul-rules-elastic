// Dragnet [Ransomware]: dragnet-ransomware-2025-6641 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: e2bc1c10-f27a-57b7-97e6-af3f7a32e652

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
