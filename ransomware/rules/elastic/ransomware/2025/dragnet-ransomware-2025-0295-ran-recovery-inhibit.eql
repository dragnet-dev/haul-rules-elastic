// Dragnet [Ransomware]: dragnet-ransomware-2025-0295 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 7576e105-4c7b-5385-a152-2c20134d8f28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
