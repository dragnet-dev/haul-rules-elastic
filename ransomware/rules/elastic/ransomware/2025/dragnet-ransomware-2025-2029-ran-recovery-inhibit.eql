// Dragnet [Ransomware]: dragnet-ransomware-2025-2029 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: f4cc4324-f9a5-5cab-b636-8431f974c099

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
