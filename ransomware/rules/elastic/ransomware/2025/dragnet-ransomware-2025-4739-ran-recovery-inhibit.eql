// Dragnet [Ransomware]: dragnet-ransomware-2025-4739 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e782254a-36e1-5fe6-a5f5-88f803cbe312

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
