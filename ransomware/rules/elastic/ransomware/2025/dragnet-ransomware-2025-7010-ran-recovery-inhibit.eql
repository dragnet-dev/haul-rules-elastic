// Dragnet [Ransomware]: dragnet-ransomware-2025-7010 — Recovery Inhibition (brotherhood)
// Status: deprecated | Level: high | ID: 1b67ce8f-c5eb-5c8a-9da2-be1c027f9e97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
