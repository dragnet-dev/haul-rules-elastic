// Dragnet [Ransomware]: dragnet-ransomware-2025-5254 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 9021b758-67fa-514b-b8c4-4ad616160c54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
