// Dragnet [Ransomware]: dragnet-ransomware-2025-6589 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 5453fa9c-7dff-5ad3-8c53-1abe2c430fd6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
