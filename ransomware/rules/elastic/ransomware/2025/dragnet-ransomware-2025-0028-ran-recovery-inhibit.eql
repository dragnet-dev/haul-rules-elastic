// Dragnet [Ransomware]: dragnet-ransomware-2025-0028 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 8fa83627-d03c-59a0-bf09-ec0bc2e9c11d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
