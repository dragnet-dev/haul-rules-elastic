// Dragnet [Ransomware]: dragnet-ransomware-2025-1134 — Recovery Inhibition (anubis)
// Status: experimental | Level: high | ID: 18e7994f-b42d-57a4-8527-aa2fa3384c6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
