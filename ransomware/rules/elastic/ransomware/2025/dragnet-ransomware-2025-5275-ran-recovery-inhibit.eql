// Dragnet [Ransomware]: dragnet-ransomware-2025-5275 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: b647cb00-95e6-50ca-8041-ece40cdab830

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
