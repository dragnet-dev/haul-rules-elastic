// Dragnet [Ransomware]: dragnet-ransomware-2025-2028 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9da7c74b-6b8c-55f6-9b0f-4d1c76397f4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
