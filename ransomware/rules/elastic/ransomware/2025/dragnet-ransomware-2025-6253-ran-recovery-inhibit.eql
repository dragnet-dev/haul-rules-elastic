// Dragnet [Ransomware]: dragnet-ransomware-2025-6253 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 254e2110-fdd3-573e-9017-d18e0c0ffcd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
