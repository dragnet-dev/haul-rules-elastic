// Dragnet [Ransomware]: dragnet-ransomware-2025-4533 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 3681bd91-fe03-5d67-a6d5-7b6a38ae151c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
