// Dragnet [Ransomware]: dragnet-ransomware-2025-3491 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: aa46d13f-4a18-504f-b144-d42560ec4018

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
