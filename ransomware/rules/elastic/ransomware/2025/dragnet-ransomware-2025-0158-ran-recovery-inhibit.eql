// Dragnet [Ransomware]: dragnet-ransomware-2025-0158 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 0f4b59d6-e476-5283-a59a-5ce9cecd13df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
