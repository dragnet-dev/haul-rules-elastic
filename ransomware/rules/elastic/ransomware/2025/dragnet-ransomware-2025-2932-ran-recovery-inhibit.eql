// Dragnet [Ransomware]: dragnet-ransomware-2025-2932 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: b9a4d411-ee3a-5e54-a034-1761c52b6274

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
