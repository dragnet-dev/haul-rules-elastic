// Dragnet [Ransomware]: dragnet-ransomware-2025-7886 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: 12780e72-c9d1-5502-8f0d-a48294fb0e8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
