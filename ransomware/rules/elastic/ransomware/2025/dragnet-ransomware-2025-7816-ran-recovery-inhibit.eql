// Dragnet [Ransomware]: dragnet-ransomware-2025-7816 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0c572203-bb48-587c-b5d7-9fea2861b714

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
