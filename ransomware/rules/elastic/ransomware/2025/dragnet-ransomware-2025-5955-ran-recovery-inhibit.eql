// Dragnet [Ransomware]: dragnet-ransomware-2025-5955 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: f60c0f0c-e8dc-5b1e-be63-9d5f4ca06be1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
