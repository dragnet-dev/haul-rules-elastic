// Dragnet [Ransomware]: dragnet-ransomware-2025-5896 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c493a170-67a0-5437-8a1a-0a9530780b03

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
