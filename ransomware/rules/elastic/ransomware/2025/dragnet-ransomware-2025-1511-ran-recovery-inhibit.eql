// Dragnet [Ransomware]: dragnet-ransomware-2025-1511 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 58112c32-a70c-5b1c-b4b3-733b18ce2a48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
