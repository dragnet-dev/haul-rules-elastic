// Dragnet [Ransomware]: dragnet-ransomware-2025-4276 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 103380af-6144-5baf-a20b-025a4ce8e860

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
