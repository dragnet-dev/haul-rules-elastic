// Dragnet [Ransomware]: dragnet-ransomware-2025-7565 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: cdfd3d85-2b65-5fd7-8a52-e6ad43eb220b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
