// Dragnet [Ransomware]: dragnet-ransomware-2025-7684 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 04113472-07a7-5328-9125-adbd412e9d0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
