// Dragnet [Ransomware]: dragnet-ransomware-2025-7625 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: d8556125-91dc-5874-b046-b6d76e57e8e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
