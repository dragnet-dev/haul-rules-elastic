// Dragnet [Ransomware]: dragnet-ransomware-2025-0678 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: a60cfcb1-9420-5568-805d-3f94da77c8b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
