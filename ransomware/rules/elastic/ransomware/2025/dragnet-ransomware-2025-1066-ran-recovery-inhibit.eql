// Dragnet [Ransomware]: dragnet-ransomware-2025-1066 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: baa0c775-f3b3-5842-a905-ec1a33773ecb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
