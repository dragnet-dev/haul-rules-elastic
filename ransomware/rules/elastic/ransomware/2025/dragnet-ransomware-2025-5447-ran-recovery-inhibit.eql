// Dragnet [Ransomware]: dragnet-ransomware-2025-5447 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: eedcf5c1-1fa9-5fe7-9b8d-e1fb91394e9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
