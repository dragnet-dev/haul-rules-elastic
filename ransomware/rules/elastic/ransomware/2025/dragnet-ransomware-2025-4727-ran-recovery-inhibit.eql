// Dragnet [Ransomware]: dragnet-ransomware-2025-4727 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 602d599b-ae4a-5b58-9148-0279ba9cf440

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
