// Dragnet [Ransomware]: dragnet-ransomware-2025-6813 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1981c5ce-150a-5fb2-9822-65d022c52929

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
