// Dragnet [Ransomware]: dragnet-ransomware-2025-1619 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: f46aac62-5d99-54a7-94f3-c0a8f6e5bc66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
