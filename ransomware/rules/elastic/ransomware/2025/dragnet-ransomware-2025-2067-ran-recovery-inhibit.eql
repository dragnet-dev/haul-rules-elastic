// Dragnet [Ransomware]: dragnet-ransomware-2025-2067 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 01bc694d-b65f-51c2-8615-1457bd318663

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
