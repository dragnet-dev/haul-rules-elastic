// Dragnet [Ransomware]: dragnet-ransomware-2025-0144 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cd1d0e61-9c73-53d9-a705-7ecfb8d0ef7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
