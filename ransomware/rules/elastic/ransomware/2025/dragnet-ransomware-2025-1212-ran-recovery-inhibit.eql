// Dragnet [Ransomware]: dragnet-ransomware-2025-1212 — Recovery Inhibition (radiant)
// Status: deprecated | Level: high | ID: 8c2e316b-532c-59bb-aa7b-2e2d9481e7d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
