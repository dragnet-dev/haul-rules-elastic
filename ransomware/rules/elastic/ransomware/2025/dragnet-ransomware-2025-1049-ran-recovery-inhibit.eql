// Dragnet [Ransomware]: dragnet-ransomware-2025-1049 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: b2be1588-5a58-5c53-824c-841bf0e10d3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
