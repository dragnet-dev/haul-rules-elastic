// Dragnet [Ransomware]: dragnet-ransomware-2025-0998 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 96698f4b-b577-5d1c-bd5f-5378cf18ac17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
