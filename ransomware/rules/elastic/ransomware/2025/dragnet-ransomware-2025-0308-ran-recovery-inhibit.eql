// Dragnet [Ransomware]: dragnet-ransomware-2025-0308 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 4d47b616-e6d2-56e1-a96d-5eb19f1c7bdf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
