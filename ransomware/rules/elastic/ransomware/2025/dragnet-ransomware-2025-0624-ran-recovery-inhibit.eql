// Dragnet [Ransomware]: dragnet-ransomware-2025-0624 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 030ba812-5536-5f95-8c4b-7ec1d59f7bbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
