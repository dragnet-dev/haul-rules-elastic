// Dragnet [Ransomware]: dragnet-ransomware-2025-6658 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: 62f66a93-b111-5625-9189-1da6a59f8433

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
