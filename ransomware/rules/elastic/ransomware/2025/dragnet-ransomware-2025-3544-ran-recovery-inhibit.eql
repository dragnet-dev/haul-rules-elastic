// Dragnet [Ransomware]: dragnet-ransomware-2025-3544 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 6cf5a0b9-c830-5f47-b682-964b582b4169

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
