// Dragnet [Ransomware]: dragnet-ransomware-2025-2001 — Recovery Inhibition (VanHelsing)
// Status: experimental | Level: high | ID: 105a286c-4d4f-5c24-840c-7b84c1cc4625

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
