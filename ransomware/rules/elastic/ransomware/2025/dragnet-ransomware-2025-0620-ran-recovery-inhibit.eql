// Dragnet [Ransomware]: dragnet-ransomware-2025-0620 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 6e21423c-aa6a-5e69-9c59-90fd6f09fc16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
