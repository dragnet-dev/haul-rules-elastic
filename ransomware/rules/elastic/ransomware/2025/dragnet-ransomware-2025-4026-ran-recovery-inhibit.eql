// Dragnet [Ransomware]: dragnet-ransomware-2025-4026 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 773be1f9-58ed-59cf-ace9-aec6880d53f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
