// Dragnet [Ransomware]: dragnet-ransomware-2025-6838 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 8a41493b-1dd2-52ea-884b-2fecacba92aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
