// Dragnet [Ransomware]: dragnet-ransomware-2025-6887 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 6a2529ef-020c-5cea-94dd-1d019c106b75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
