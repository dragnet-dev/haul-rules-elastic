// Dragnet [Ransomware]: dragnet-ransomware-2025-2481 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: f02797e5-9189-524d-ae37-def76ce06bf1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
