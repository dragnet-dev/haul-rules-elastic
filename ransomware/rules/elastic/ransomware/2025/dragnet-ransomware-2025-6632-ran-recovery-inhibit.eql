// Dragnet [Ransomware]: dragnet-ransomware-2025-6632 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 8d5913ee-de6d-56a7-9853-45aee90379ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
