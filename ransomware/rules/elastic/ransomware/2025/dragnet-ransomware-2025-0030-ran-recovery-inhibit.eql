// Dragnet [Ransomware]: dragnet-ransomware-2025-0030 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 25e9a57b-7764-5a06-831f-2bbcb08c6272

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
