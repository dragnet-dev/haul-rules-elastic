// Dragnet [Ransomware]: dragnet-ransomware-2025-3706 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 15da325d-81d8-55bf-92ac-fb13cf73ff77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
