// Dragnet [Ransomware]: dragnet-ransomware-2025-6036 — Recovery Inhibition (interlock)
// Status: test | Level: high | ID: 9b6f4b0c-af5f-581c-835e-276b7cfc8a4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
