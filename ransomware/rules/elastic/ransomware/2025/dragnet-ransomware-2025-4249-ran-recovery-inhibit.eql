// Dragnet [Ransomware]: dragnet-ransomware-2025-4249 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: e3583749-8bf4-5faf-af09-81414af53c4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
