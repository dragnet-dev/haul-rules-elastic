// Dragnet [Ransomware]: dragnet-ransomware-2025-1954 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: dc1dbdf5-a362-5659-a7e3-f5172e4c31f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
