// Dragnet [Ransomware]: dragnet-ransomware-2025-0500 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e623c806-9698-5728-a783-c0aee9d7651f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
