// Dragnet [Ransomware]: dragnet-ransomware-2025-1885 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: d797fc59-8e2f-5c07-a239-ceee177140c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
