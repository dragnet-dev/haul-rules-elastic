// Dragnet [Ransomware]: dragnet-ransomware-2025-0221 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: ab899ef4-6e8b-5861-9e55-56d2071845f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
