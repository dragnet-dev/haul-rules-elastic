// Dragnet [Ransomware]: dragnet-ransomware-2025-5374 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 75b8b132-0df0-5e6a-b1b8-b1ba08da04eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
