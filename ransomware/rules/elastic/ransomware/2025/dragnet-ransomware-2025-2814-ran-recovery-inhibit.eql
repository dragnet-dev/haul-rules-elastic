// Dragnet [Ransomware]: dragnet-ransomware-2025-2814 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: e71deef1-6811-54d1-a6a7-58de9c640f30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
