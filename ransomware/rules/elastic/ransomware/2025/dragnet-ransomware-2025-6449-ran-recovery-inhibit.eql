// Dragnet [Ransomware]: dragnet-ransomware-2025-6449 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: f46c7eae-dc06-5e1b-a444-add7fbdbad0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
