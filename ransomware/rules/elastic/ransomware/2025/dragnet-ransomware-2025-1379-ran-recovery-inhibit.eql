// Dragnet [Ransomware]: dragnet-ransomware-2025-1379 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 78d1115f-0032-5235-95ac-3a218c0150ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
