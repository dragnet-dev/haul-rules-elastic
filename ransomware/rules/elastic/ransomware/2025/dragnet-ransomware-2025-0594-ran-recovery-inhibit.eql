// Dragnet [Ransomware]: dragnet-ransomware-2025-0594 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: ee8fcc97-d584-5c99-8062-948bfaa1f959

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
