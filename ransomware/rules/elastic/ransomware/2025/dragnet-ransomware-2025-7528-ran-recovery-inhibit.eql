// Dragnet [Ransomware]: dragnet-ransomware-2025-7528 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: c0afcf98-7ed3-5437-a2a9-cc2b916a58cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
