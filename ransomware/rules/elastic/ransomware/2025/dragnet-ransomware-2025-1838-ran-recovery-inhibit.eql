// Dragnet [Ransomware]: dragnet-ransomware-2025-1838 — Recovery Inhibition (chaos)
// Status: test | Level: high | ID: 30f291e5-4c5f-5295-985a-71c057dea80a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
