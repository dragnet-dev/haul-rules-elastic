// Dragnet [Ransomware]: dragnet-ransomware-2025-1566 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 906a4947-cb1d-54c2-bdf7-fbd6a874c483

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
