// Dragnet [Ransomware]: dragnet-ransomware-2025-6258 — Recovery Inhibition (genesis)
// Status: experimental | Level: high | ID: 7f64062f-7957-5d05-ab3a-cfc5e98bfbc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
