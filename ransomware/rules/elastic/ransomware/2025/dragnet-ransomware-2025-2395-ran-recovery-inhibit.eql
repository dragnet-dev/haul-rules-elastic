// Dragnet [Ransomware]: dragnet-ransomware-2025-2395 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: f7cf8b77-f1fd-5bf6-8579-deca97e897f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
