// Dragnet [Ransomware]: dragnet-ransomware-2025-0795 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fd2efd73-d932-55ae-bb14-564ca2317a2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
