// Dragnet [Ransomware]: dragnet-ransomware-2025-4081 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 7076e7e3-36a1-59e1-80ae-8bcecb059971

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
