// Dragnet [Ransomware]: dragnet-ransomware-2025-2817 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f41bafa4-96c9-5efb-ab20-d8a4611900e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
