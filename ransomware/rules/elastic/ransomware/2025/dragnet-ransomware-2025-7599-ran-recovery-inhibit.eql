// Dragnet [Ransomware]: dragnet-ransomware-2025-7599 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: bd8d09df-634a-5c5a-96ad-5de376538cc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
