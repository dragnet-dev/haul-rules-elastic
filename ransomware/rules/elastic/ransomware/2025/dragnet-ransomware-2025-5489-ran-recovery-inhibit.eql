// Dragnet [Ransomware]: dragnet-ransomware-2025-5489 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 3c925607-97dc-5d5c-9a35-c901aa5eaae4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
