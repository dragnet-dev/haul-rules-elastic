// Dragnet [Ransomware]: dragnet-ransomware-2025-5213 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3c2eae45-b023-5a73-9fbc-4cdb5efa3783

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
