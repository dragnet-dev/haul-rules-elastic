// Dragnet [Ransomware]: dragnet-ransomware-2025-7029 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: cbbde531-9571-5c40-89a3-7185141bb176

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
