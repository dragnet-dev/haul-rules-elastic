// Dragnet [Ransomware]: dragnet-ransomware-2025-4183 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 27ff8d84-f66d-563e-bff6-dde10296af94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
