// Dragnet [Ransomware]: dragnet-ransomware-2025-2596 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: fdd3cfce-573e-5d07-b527-3c7f572460b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
