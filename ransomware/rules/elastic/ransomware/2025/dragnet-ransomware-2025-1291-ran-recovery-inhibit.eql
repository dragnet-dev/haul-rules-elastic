// Dragnet [Ransomware]: dragnet-ransomware-2025-1291 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c5c22db6-6ed4-5f51-a58a-cdef93659600

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
