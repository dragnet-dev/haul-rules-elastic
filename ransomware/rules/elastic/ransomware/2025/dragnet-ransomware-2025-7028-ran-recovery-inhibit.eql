// Dragnet [Ransomware]: dragnet-ransomware-2025-7028 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 0fe22ebd-4ba7-5693-b14b-5fe44a627cba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
