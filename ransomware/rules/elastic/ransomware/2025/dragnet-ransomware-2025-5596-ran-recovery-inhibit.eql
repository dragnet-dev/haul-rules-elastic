// Dragnet [Ransomware]: dragnet-ransomware-2025-5596 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ae90f9d7-3118-5816-af88-e6d5956ad3c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
