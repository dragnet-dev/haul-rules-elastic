// Dragnet [Ransomware]: dragnet-ransomware-2025-3414 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: de4aed0f-3186-5365-95bb-f4b7400fef28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
