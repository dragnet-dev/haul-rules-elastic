// Dragnet [Ransomware]: dragnet-ransomware-2025-1144 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3832a8d8-5c95-5717-813d-07e70441c682

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
