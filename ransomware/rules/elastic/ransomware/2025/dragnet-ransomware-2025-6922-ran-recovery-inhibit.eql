// Dragnet [Ransomware]: dragnet-ransomware-2025-6922 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: fa6b7da6-0392-5a85-b22b-437d3fddff46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
