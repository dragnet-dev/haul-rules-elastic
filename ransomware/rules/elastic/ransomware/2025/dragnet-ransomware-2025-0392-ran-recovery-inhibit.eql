// Dragnet [Ransomware]: dragnet-ransomware-2025-0392 — Recovery Inhibition (datacarry)
// Status: deprecated | Level: high | ID: f080b7c8-62cd-5086-970f-f58c11528aeb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
