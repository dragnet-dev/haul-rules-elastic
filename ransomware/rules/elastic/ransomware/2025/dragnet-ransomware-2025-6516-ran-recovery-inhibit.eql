// Dragnet [Ransomware]: dragnet-ransomware-2025-6516 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 27d3d6f1-073e-58ff-9158-13506c2eb6a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
