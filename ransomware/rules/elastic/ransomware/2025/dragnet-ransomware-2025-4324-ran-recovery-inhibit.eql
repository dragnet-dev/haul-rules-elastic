// Dragnet [Ransomware]: dragnet-ransomware-2025-4324 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: ad895ef1-91d0-5c05-9fa3-df8753cbadc0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
