// Dragnet [Ransomware]: dragnet-ransomware-2025-4319 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 28af19e4-e018-562d-99c2-14bbf2f60aa9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
