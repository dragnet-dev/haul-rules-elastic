// Dragnet [Ransomware]: dragnet-ransomware-2025-0105 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: c1b3f969-6219-56bb-b968-54d2407c9baa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
