// Dragnet [Ransomware]: dragnet-ransomware-2025-3059 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 5a2f5140-74d3-55a7-b460-b6b7471ff7fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
