// Dragnet [Ransomware]: dragnet-ransomware-2025-4636 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a84d6935-c998-57c6-8cab-e6ea8213a86a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
