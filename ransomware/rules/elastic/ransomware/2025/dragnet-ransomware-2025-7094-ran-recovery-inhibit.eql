// Dragnet [Ransomware]: dragnet-ransomware-2025-7094 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 9f93bddd-81d4-502e-b365-a842fb79c17a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
