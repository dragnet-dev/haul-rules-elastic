// Dragnet [Ransomware]: dragnet-ransomware-2025-2773 — Recovery Inhibition (cephalus)
// Status: experimental | Level: high | ID: 0c6fe81b-67cd-5943-a17c-aef78ef627b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
