// Dragnet [Ransomware]: dragnet-ransomware-2025-2193 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f570af51-cbcc-5ae8-a760-24b8f19b9f03

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
