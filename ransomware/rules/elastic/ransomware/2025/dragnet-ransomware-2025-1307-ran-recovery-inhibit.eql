// Dragnet [Ransomware]: dragnet-ransomware-2025-1307 — Recovery Inhibition (kraken)
// Status: experimental | Level: high | ID: 8f2cef6a-90be-558c-b9de-0d2939935df8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
