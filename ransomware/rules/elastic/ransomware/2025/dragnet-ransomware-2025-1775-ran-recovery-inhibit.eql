// Dragnet [Ransomware]: dragnet-ransomware-2025-1775 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: b8f4352c-315b-5c1f-9541-9e19628d208e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
