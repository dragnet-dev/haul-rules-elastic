// Dragnet [Ransomware]: dragnet-ransomware-2025-2852 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 6ee0ec4a-dd34-5709-bc80-6ad28bd5e19a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
