// Dragnet [Ransomware]: dragnet-ransomware-2025-4418 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: bfe8fd78-fbe2-56d2-a09c-2ac7d53603d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
