// Dragnet [Ransomware]: dragnet-ransomware-2025-6233 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 0fe59a24-58fb-599b-b39c-18411eee9cf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
