// Dragnet [Ransomware]: dragnet-ransomware-2025-6478 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 66e924c9-817a-5341-a1c2-ab1ea036ac71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
