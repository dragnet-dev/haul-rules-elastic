// Dragnet [Ransomware]: dragnet-ransomware-2025-4475 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 2f8c376d-2b07-5a08-92c0-39ec8ebb8bc9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
