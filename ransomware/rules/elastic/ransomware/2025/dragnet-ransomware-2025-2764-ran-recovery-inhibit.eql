// Dragnet [Ransomware]: dragnet-ransomware-2025-2764 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 08959a01-20c0-5c76-83a0-88aa42ce35a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
