// Dragnet [Ransomware]: dragnet-ransomware-2025-0955 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 01b72ff3-fecc-57d0-be41-6f8cecb28e25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
