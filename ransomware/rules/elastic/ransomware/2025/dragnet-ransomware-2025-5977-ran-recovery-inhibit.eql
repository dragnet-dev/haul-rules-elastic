// Dragnet [Ransomware]: dragnet-ransomware-2025-5977 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 34b492e5-caf5-5ab8-996b-013952a40b74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
