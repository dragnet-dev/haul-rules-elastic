// Dragnet [Ransomware]: dragnet-ransomware-2025-0737 — Recovery Inhibition (cephalus)
// Status: deprecated | Level: high | ID: c7d4dfa8-d6a1-5488-8935-6bb518cba9bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
