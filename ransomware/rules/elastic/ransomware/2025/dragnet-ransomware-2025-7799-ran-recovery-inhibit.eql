// Dragnet [Ransomware]: dragnet-ransomware-2025-7799 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 76b5731f-7116-503a-856e-6b2163af013e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
