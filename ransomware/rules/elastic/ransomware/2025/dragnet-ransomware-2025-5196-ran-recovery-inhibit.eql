// Dragnet [Ransomware]: dragnet-ransomware-2025-5196 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 21101dcc-1de8-5b2c-aa3f-018e0c89ac47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
