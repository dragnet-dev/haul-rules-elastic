// Dragnet [Ransomware]: dragnet-ransomware-2025-3726 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: de414b66-4e83-5bd1-b3ff-722ea74d512f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
