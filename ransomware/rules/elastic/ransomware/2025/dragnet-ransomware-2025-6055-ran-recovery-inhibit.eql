// Dragnet [Ransomware]: dragnet-ransomware-2025-6055 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 6be9f2a7-f4cc-55f3-9e67-a633014dd6b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
