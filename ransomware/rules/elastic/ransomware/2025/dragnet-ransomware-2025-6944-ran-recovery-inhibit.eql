// Dragnet [Ransomware]: dragnet-ransomware-2025-6944 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: fa6cf268-29d7-5789-a711-6285ead334a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
