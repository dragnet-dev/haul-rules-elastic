// Dragnet [Ransomware]: dragnet-ransomware-2025-0750 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 44d2c242-c884-5b08-b135-1573017d6d8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
