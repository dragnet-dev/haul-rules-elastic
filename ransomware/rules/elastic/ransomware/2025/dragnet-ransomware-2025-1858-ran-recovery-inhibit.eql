// Dragnet [Ransomware]: dragnet-ransomware-2025-1858 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 48f8f9bc-3824-5b9b-9635-bd87ae5dea33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
