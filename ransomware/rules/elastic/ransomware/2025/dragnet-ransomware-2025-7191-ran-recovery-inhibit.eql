// Dragnet [Ransomware]: dragnet-ransomware-2025-7191 — Recovery Inhibition (medusa)
// Status: test | Level: high | ID: 494f110b-5534-54ab-979d-549afaa8ff6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
