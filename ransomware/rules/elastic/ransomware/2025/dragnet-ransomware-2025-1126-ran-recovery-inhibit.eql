// Dragnet [Ransomware]: dragnet-ransomware-2025-1126 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 79327bf4-ce8f-512c-b503-6bd9287ca7a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
