// Dragnet [Ransomware]: dragnet-ransomware-2025-3166 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 06d40d66-a155-5082-af5f-af9347e2ca69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
