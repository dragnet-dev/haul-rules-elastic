// Dragnet [Ransomware]: dragnet-ransomware-2025-5975 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7be520cc-bbc7-56eb-955c-69730032fb9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
