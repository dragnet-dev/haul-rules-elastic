// Dragnet [Ransomware]: dragnet-ransomware-2025-1544 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a3537c4a-f7d9-5b36-88ef-7cce78e66fda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
