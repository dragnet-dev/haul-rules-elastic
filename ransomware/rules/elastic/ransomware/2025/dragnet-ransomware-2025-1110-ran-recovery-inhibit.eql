// Dragnet [Ransomware]: dragnet-ransomware-2025-1110 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 6e5040a8-1fa4-52ab-bbf8-31d64648cf57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
