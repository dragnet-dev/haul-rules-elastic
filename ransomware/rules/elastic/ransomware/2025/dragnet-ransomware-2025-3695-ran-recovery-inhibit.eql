// Dragnet [Ransomware]: dragnet-ransomware-2025-3695 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 11705129-3f0c-5881-b226-e788f18719dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
