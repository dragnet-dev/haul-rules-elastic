// Dragnet [Ransomware]: dragnet-ransomware-2025-3549 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5796e3eb-b238-53b1-842e-b455afbe0221

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
