// Dragnet [Ransomware]: dragnet-ransomware-2025-4784 — Recovery Inhibition (benzona)
// Status: deprecated | Level: high | ID: 4a7c9cd6-37a7-532a-b208-b15fc3aa3365

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
