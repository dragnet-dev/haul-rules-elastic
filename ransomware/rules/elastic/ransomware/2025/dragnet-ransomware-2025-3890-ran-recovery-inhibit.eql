// Dragnet [Ransomware]: dragnet-ransomware-2025-3890 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: a98e0c05-9208-5af9-a262-9f112eb9f772

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
