// Dragnet [Ransomware]: dragnet-ransomware-2025-1696 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5ffe4bf9-2b2d-5bc7-a96e-0eb180edf430

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
