// Dragnet [Ransomware]: dragnet-ransomware-2025-1216 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 5b7f1557-de93-584b-8376-b851a4619322

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
