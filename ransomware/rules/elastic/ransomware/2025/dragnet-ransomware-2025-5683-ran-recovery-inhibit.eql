// Dragnet [Ransomware]: dragnet-ransomware-2025-5683 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5cb12a3e-26c3-5282-8f6a-0db88fa2fbc6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
