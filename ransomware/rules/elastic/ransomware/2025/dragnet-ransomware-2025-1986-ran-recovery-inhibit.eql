// Dragnet [Ransomware]: dragnet-ransomware-2025-1986 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3a725491-85d4-5697-86a7-0694cf64a5e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
