// Dragnet [Ransomware]: dragnet-ransomware-2025-4701 — Recovery Inhibition (cephalus)
// Status: experimental | Level: high | ID: 399dff59-9d67-5aa5-ba74-3f9a9c8bfac3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
