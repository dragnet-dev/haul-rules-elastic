// Dragnet [Ransomware]: dragnet-ransomware-2025-7632 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: f76c4839-0f3c-54db-98cd-3b685633bdcf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
