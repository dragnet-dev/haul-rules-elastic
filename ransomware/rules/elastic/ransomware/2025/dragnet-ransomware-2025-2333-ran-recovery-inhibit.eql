// Dragnet [Ransomware]: dragnet-ransomware-2025-2333 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 6c8c6c6a-3902-5b32-9ad2-c3e68e5bc61f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
