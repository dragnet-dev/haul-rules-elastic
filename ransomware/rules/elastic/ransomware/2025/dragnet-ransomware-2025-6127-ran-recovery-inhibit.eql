// Dragnet [Ransomware]: dragnet-ransomware-2025-6127 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 37ad3925-8882-52ae-b438-3af2552a72f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
