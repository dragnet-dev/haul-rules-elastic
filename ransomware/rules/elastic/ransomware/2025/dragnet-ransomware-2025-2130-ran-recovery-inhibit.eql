// Dragnet [Ransomware]: dragnet-ransomware-2025-2130 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 078f1c73-a159-5b25-8bb5-93c720ce045b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
