// Dragnet [Ransomware]: dragnet-ransomware-2025-4503 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 0ecd8e49-f2c1-5467-b3ac-a8f0884351d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
