// Dragnet [Ransomware]: dragnet-ransomware-2025-0836 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: d2129496-f33e-546b-a5ed-2e808cddf328

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
