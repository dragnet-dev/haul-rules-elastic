// Dragnet [Ransomware]: dragnet-ransomware-2025-4257 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c152f1a8-dcbb-59cf-ba8f-23e15fa82901

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
