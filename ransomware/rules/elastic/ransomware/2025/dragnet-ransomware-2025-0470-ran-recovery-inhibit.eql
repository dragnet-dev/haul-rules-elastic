// Dragnet [Ransomware]: dragnet-ransomware-2025-0470 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 6affc09d-1f6f-5133-8ea4-124ad3ec5fdb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
