// Dragnet [Ransomware]: dragnet-ransomware-2025-4859 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 6652b98b-b37b-577e-bdcf-db782f1e062e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
