// Dragnet [Ransomware]: dragnet-ransomware-2025-6307 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 1050ecfe-be93-5189-a645-6ec9cc2e6bbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
