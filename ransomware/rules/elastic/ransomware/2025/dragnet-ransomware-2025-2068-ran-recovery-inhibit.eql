// Dragnet [Ransomware]: dragnet-ransomware-2025-2068 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 177f94b3-deba-5923-b535-81621096d280

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
