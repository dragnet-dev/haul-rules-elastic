// Dragnet [Ransomware]: dragnet-ransomware-2025-6841 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: e7ab081d-83a2-565e-a8d0-a4f7b783847c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
