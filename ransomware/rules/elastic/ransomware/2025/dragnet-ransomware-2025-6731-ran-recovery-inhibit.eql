// Dragnet [Ransomware]: dragnet-ransomware-2025-6731 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 18a56991-7a6c-59b3-9d8e-182c288a44c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
