// Dragnet [Ransomware]: dragnet-ransomware-2025-7395 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: 87785631-aa83-58a4-885b-c469180fcbc0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
