// Dragnet [Ransomware]: dragnet-ransomware-2025-5464 — Recovery Inhibition (handala)
// Status: test | Level: high | ID: 907bacf5-5650-5ca7-8fbe-b99752d9e2cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
