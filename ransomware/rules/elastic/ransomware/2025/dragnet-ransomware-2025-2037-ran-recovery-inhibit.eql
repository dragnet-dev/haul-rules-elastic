// Dragnet [Ransomware]: dragnet-ransomware-2025-2037 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3fe00dea-8bce-59ed-9178-e32fa7fa3021

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
