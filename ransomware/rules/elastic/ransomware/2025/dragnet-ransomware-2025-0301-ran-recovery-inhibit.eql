// Dragnet [Ransomware]: dragnet-ransomware-2025-0301 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 82c4916e-54a8-574b-a31a-c147470b1094

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
