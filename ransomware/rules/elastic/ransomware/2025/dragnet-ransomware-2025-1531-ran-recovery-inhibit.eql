// Dragnet [Ransomware]: dragnet-ransomware-2025-1531 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: be0f1c82-b6b5-5ab8-a060-6da6a12ca0b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
