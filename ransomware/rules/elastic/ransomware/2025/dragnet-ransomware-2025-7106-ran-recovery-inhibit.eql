// Dragnet [Ransomware]: dragnet-ransomware-2025-7106 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1ec3b6d0-ab63-55d3-b0cf-2c5bacf52bd3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
