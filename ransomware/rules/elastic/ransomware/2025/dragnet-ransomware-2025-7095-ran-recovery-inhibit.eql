// Dragnet [Ransomware]: dragnet-ransomware-2025-7095 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f95d9e22-7257-5233-ab46-c8b86383817e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
