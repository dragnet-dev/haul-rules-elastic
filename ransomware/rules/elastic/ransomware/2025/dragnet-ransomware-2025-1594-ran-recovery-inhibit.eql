// Dragnet [Ransomware]: dragnet-ransomware-2025-1594 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: fe68e736-f161-5f0f-8764-d81a86533765

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
