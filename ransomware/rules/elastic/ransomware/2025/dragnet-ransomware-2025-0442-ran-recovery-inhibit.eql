// Dragnet [Ransomware]: dragnet-ransomware-2025-0442 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 27896ca1-08f5-52be-8d32-a09d193d4529

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
