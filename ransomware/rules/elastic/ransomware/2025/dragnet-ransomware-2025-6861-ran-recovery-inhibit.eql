// Dragnet [Ransomware]: dragnet-ransomware-2025-6861 — Recovery Inhibition (blackshrantac)
// Status: experimental | Level: high | ID: be3c2f0a-f0bf-581c-8821-a7f2abd413cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
