// Dragnet [Ransomware]: dragnet-ransomware-2025-0051 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 858e308b-911c-570f-b770-5d874189b383

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
