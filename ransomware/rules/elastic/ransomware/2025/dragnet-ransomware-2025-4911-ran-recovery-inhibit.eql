// Dragnet [Ransomware]: dragnet-ransomware-2025-4911 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 60c209f9-6cf7-556b-a227-6173768dd49e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
