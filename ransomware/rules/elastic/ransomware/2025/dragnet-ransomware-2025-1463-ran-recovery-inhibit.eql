// Dragnet [Ransomware]: dragnet-ransomware-2025-1463 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: a55b08ee-fdf4-5c65-a4a4-a25583a9a3c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
