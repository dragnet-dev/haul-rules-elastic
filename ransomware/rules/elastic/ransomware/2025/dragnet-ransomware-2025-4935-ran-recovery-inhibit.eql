// Dragnet [Ransomware]: dragnet-ransomware-2025-4935 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 718f5c46-5391-5bbc-a976-ed4a9ac19871

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
