// Dragnet [Ransomware]: dragnet-ransomware-2025-0341 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f1153364-4722-5832-af7e-6d7d5e72cca0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
