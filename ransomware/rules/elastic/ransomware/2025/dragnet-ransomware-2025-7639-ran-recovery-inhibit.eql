// Dragnet [Ransomware]: dragnet-ransomware-2025-7639 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 81b7d79e-f5b0-5da5-8c05-50d4910b3b55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
