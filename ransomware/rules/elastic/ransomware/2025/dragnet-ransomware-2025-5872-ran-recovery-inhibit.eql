// Dragnet [Ransomware]: dragnet-ransomware-2025-5872 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 98ff9f5e-199a-5a92-93ae-117cb49a3949

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
