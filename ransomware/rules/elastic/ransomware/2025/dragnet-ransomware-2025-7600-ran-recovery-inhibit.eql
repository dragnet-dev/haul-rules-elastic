// Dragnet [Ransomware]: dragnet-ransomware-2025-7600 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: b08b5387-8a8c-585d-a0b7-473e159ba474

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
