// Dragnet [Ransomware]: dragnet-ransomware-2025-1076 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 54f58a6a-dd0b-589a-b108-6cde477a04d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
