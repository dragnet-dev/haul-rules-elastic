// Dragnet [Ransomware]: dragnet-ransomware-2025-3340 — Recovery Inhibition (termite)
// Status: experimental | Level: high | ID: 74f6f8c9-dfac-532e-b3f4-284d408e1db7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
