// Dragnet [Ransomware]: dragnet-ransomware-2025-1330 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2137a27d-b291-585b-9689-6a000f6e490e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
