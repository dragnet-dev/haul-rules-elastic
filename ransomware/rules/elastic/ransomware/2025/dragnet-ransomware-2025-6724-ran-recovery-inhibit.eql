// Dragnet [Ransomware]: dragnet-ransomware-2025-6724 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: cc323a5c-94c8-5f98-bc1a-670590b30fde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
