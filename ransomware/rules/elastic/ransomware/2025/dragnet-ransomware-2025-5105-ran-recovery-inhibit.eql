// Dragnet [Ransomware]: dragnet-ransomware-2025-5105 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b6490e36-69cc-56f1-a6bd-b1643ee6d4a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
