// Dragnet [Ransomware]: dragnet-ransomware-2025-6567 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 6f5eebc9-50ee-5298-8711-e351e9dbb8a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
