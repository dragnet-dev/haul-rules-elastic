// Dragnet [Ransomware]: dragnet-ransomware-2025-6636 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: a2ea5514-0ece-5826-9191-1f5503283757

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
