// Dragnet [Ransomware]: dragnet-ransomware-2025-3006 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: 4c49ce3a-f32a-543d-884b-3b3c28dc0f50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
