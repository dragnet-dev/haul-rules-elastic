// Dragnet [Ransomware]: dragnet-ransomware-2025-7402 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 8d4aceb5-d2f9-5ac7-a496-cfa4507b3e14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
