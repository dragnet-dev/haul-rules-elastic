// Dragnet [Ransomware]: dragnet-ransomware-2025-4098 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 98ee0474-b53e-5222-ab31-ab8762438021

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
