// Dragnet [Ransomware]: dragnet-ransomware-2025-0661 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 60b94007-bae7-5a2c-9e8e-a2f25f4cbdf1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
