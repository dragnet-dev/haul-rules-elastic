// Dragnet [Ransomware]: dragnet-ransomware-2025-1816 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 78fd99d4-cf71-5702-884f-b7ff46c831ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
