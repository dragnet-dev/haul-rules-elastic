// Dragnet [Ransomware]: dragnet-ransomware-2025-1139 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: fc30de25-c330-504e-ad2c-c2753d44b73c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
