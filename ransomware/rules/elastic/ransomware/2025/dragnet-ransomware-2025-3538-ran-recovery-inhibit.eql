// Dragnet [Ransomware]: dragnet-ransomware-2025-3538 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d6200b87-2a43-5e52-a03e-80101a507f0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
