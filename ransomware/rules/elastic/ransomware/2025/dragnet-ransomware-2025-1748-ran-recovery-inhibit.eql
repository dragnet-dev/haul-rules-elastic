// Dragnet [Ransomware]: dragnet-ransomware-2025-1748 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 094b98e1-9914-59a8-a3dc-b0b02339a2b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
