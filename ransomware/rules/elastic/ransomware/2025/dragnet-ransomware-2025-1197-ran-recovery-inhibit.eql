// Dragnet [Ransomware]: dragnet-ransomware-2025-1197 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 036c357e-575b-5ed1-8542-c184a3401145

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
