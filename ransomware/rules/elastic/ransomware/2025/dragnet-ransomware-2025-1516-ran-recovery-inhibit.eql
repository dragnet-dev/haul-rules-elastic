// Dragnet [Ransomware]: dragnet-ransomware-2025-1516 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b2c1aaa8-5242-521a-b72c-fc3f75da0361

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
