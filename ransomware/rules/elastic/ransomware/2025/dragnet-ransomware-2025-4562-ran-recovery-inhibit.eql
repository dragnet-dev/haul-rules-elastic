// Dragnet [Ransomware]: dragnet-ransomware-2025-4562 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: df08aabf-b70a-5191-b0d7-74036dc1a98b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
