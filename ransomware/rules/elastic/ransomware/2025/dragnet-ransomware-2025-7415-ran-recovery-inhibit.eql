// Dragnet [Ransomware]: dragnet-ransomware-2025-7415 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: dbbad840-1f84-5429-a743-2022f971111c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
