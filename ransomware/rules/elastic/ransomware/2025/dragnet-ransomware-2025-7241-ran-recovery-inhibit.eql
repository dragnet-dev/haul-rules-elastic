// Dragnet [Ransomware]: dragnet-ransomware-2025-7241 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 31f356e0-014c-5e33-83b0-faff7dec30d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
