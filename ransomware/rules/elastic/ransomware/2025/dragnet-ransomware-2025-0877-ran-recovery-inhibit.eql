// Dragnet [Ransomware]: dragnet-ransomware-2025-0877 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 206368da-2d30-5d55-a814-149485f98e82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
