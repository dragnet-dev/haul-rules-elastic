// Dragnet [Ransomware]: dragnet-ransomware-2025-1448 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 870a3d47-b4a6-5071-9bf9-32036f5163fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
