// Dragnet [Ransomware]: dragnet-ransomware-2025-2582 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0591eee1-0aae-5527-b331-bdc44593175f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
