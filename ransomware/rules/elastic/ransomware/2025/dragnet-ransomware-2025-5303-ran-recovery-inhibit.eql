// Dragnet [Ransomware]: dragnet-ransomware-2025-5303 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5212937b-a39b-5427-b301-0fb11657363a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
