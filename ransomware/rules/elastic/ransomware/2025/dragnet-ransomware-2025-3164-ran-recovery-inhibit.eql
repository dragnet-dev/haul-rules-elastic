// Dragnet [Ransomware]: dragnet-ransomware-2025-3164 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: df42a242-a219-51d8-bd11-8c9f3ba1c9c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
