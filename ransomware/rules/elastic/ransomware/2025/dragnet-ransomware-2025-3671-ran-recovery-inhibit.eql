// Dragnet [Ransomware]: dragnet-ransomware-2025-3671 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bae4f7d3-9da5-5b83-839f-3eb1a0ba5954

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
