// Dragnet [Ransomware]: dragnet-ransomware-2025-0706 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: caba8372-c780-57ad-a35e-6e43d172486a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
