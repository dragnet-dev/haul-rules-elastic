// Dragnet [Ransomware]: dragnet-ransomware-2025-5116 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: 0bf9a751-7b4e-5997-9208-4915bf915cbd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
