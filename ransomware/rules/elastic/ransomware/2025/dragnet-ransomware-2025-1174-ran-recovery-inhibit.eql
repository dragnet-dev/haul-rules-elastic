// Dragnet [Ransomware]: dragnet-ransomware-2025-1174 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: b9d134f7-1ce0-58ff-b625-cd31db8597a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
