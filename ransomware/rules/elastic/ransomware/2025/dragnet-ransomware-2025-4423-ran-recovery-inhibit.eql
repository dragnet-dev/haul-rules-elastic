// Dragnet [Ransomware]: dragnet-ransomware-2025-4423 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 0e3c8d31-cc78-5771-8315-ce30e262103f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
