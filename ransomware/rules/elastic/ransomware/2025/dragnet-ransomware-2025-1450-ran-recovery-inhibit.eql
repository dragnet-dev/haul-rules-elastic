// Dragnet [Ransomware]: dragnet-ransomware-2025-1450 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 86ee90b5-5d9e-5f3f-afd6-8d2be12f5fc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
