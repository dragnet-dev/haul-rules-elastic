// Dragnet [Ransomware]: dragnet-ransomware-2025-0077 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 968c23e8-f75e-53a7-acd1-91dc696710a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
