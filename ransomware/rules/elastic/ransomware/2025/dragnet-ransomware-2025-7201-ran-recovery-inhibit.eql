// Dragnet [Ransomware]: dragnet-ransomware-2025-7201 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ba0fc761-0feb-55ea-a285-95faf5ecf05f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
