// Dragnet [Ransomware]: dragnet-ransomware-2025-2346 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 295c9a76-782d-5877-abf2-b86fccf0fdfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
