// Dragnet [Ransomware]: dragnet-ransomware-2025-2636 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d670f645-519e-5963-8308-2ad9f78cc19f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
