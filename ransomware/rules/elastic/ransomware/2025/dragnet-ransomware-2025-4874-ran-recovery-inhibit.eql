// Dragnet [Ransomware]: dragnet-ransomware-2025-4874 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 3990c710-9da4-5b5b-b539-cf002134664c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
