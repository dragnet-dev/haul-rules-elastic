// Dragnet [Ransomware]: dragnet-ransomware-2025-6407 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: a61399e4-ca68-5187-913b-835b0699dda9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
