// Dragnet [Ransomware]: dragnet-ransomware-2025-7802 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 06bbb5df-608c-5da9-bb67-175577300b63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
