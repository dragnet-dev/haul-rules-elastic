// Dragnet [Ransomware]: dragnet-ransomware-2025-4835 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 91031671-c752-5f3b-9bc2-4c59b324577a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
