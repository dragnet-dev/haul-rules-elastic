// Dragnet [Ransomware]: dragnet-ransomware-2025-5795 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 95cc7d83-5134-5125-bf56-65a5cf8fc1d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
