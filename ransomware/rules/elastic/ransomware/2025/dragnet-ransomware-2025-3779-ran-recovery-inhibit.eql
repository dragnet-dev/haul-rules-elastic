// Dragnet [Ransomware]: dragnet-ransomware-2025-3779 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 984861f0-c6da-56a7-be38-7d8c103ce9be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
