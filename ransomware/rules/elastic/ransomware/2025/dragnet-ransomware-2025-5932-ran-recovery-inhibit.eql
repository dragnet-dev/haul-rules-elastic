// Dragnet [Ransomware]: dragnet-ransomware-2025-5932 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 55b6fa61-26d4-55a8-b251-40db87428896

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
