// Dragnet [Ransomware]: dragnet-ransomware-2025-3894 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 55ccb449-fd1b-5137-b584-0a1f29d0995b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
