// Dragnet [Ransomware]: dragnet-ransomware-2025-5573 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8eb98461-2594-5644-a273-9df9ee046a12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
