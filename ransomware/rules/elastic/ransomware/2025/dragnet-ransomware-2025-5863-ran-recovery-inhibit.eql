// Dragnet [Ransomware]: dragnet-ransomware-2025-5863 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: ed447079-eed0-53a2-a7a9-0c472bcd1b70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
