// Dragnet [Ransomware]: dragnet-ransomware-2025-5323 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 416ca82f-2095-55a8-8ab8-3d8d28d715c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
