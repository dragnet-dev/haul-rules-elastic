// Dragnet [Ransomware]: dragnet-ransomware-2025-2089 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 98b32668-5aa8-54bd-8f6c-62010e57f090

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
