// Dragnet [Ransomware]: dragnet-ransomware-2025-6583 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a805cf8e-ffc2-5f7b-bd0e-77f7cc77f5f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
