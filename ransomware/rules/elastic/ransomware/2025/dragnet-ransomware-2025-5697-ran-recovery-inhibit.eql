// Dragnet [Ransomware]: dragnet-ransomware-2025-5697 — Recovery Inhibition (tridentlocker)
// Status: test | Level: high | ID: b966fb1d-2dcd-56c3-b738-2e27c28b89c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
