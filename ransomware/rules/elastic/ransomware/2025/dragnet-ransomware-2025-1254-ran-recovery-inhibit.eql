// Dragnet [Ransomware]: dragnet-ransomware-2025-1254 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 29e60b35-9d5b-5cd8-b006-5eff7ad26101

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
