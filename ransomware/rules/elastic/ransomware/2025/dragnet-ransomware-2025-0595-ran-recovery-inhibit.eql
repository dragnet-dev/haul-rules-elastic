// Dragnet [Ransomware]: dragnet-ransomware-2025-0595 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7a73de0b-a00f-5ebb-a327-ab765fc01272

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
