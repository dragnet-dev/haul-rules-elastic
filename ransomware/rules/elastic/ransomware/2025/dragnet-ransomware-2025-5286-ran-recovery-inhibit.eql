// Dragnet [Ransomware]: dragnet-ransomware-2025-5286 — Recovery Inhibition (ralord)
// Status: experimental | Level: high | ID: 0cfd843f-351d-54b8-a550-b6c159611a57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
