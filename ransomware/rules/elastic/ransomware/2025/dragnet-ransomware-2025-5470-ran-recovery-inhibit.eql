// Dragnet [Ransomware]: dragnet-ransomware-2025-5470 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 1180e807-1aad-5909-949a-9f93555cc2d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
