// Dragnet [Ransomware]: dragnet-ransomware-2025-6435 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 7f5a4aa4-9b04-50b9-b699-1705f1191a62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
