// Dragnet [Ransomware]: dragnet-ransomware-2025-6655 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 11cfce03-7b83-5457-a2a2-3568cb5af137

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
