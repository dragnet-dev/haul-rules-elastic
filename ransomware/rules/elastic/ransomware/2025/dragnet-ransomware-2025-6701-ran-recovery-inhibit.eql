// Dragnet [Ransomware]: dragnet-ransomware-2025-6701 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: c5675608-a833-56f6-b824-a47475b9137d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
