// Dragnet [Ransomware]: dragnet-ransomware-2025-7410 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 28d826a8-5ded-519f-b106-5cdfbf9f4469

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
