// Dragnet [Ransomware]: dragnet-ransomware-2025-3970 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: e3499231-de7f-5b05-b0e7-f68917fc6b8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
