// Dragnet [Ransomware]: dragnet-ransomware-2025-2528 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: bf05ce10-2c38-5780-975a-e84077025ac7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
