// Dragnet [Ransomware]: dragnet-ransomware-2025-4743 — Recovery Inhibition (insomnia)
// Status: test | Level: high | ID: fbb1ac53-d4e6-5543-a2a4-230ec2aeba19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
