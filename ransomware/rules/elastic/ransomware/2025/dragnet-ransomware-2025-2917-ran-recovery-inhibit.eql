// Dragnet [Ransomware]: dragnet-ransomware-2025-2917 — Recovery Inhibition (nitrogen)
// Status: test | Level: high | ID: 69dc4328-d874-5102-942e-d730c44eba81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
