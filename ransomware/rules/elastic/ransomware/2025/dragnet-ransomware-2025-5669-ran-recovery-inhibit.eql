// Dragnet [Ransomware]: dragnet-ransomware-2025-5669 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 6311e6f0-95e2-5576-9e7a-52268c3282b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
