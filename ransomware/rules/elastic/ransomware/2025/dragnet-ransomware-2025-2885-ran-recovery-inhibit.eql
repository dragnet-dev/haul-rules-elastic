// Dragnet [Ransomware]: dragnet-ransomware-2025-2885 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: b86bf5a2-7116-543f-9abf-38856cd9f5f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
