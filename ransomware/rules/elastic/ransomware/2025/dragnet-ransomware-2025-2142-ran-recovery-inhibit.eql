// Dragnet [Ransomware]: dragnet-ransomware-2025-2142 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 74a79466-ad08-5c7c-8b89-6bc837c557b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
