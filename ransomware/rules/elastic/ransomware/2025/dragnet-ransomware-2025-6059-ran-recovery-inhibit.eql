// Dragnet [Ransomware]: dragnet-ransomware-2025-6059 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: f6832021-68e7-5ba5-9227-ffbe9dc49585

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
