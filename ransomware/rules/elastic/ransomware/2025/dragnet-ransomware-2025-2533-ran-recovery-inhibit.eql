// Dragnet [Ransomware]: dragnet-ransomware-2025-2533 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 5bcfe8ff-345f-5760-b06e-97377cd1a955

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
