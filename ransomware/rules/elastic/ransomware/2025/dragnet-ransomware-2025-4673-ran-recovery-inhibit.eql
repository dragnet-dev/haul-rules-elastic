// Dragnet [Ransomware]: dragnet-ransomware-2025-4673 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 4ed2d651-d5c1-508c-a951-3a5c9f258d8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
