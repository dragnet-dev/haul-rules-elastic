// Dragnet [Ransomware]: dragnet-ransomware-2025-2152 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: fca5a54a-2552-58ab-b047-a7e5da91813a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
