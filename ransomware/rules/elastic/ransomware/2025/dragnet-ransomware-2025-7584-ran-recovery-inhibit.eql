// Dragnet [Ransomware]: dragnet-ransomware-2025-7584 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5b8467b6-270c-5210-ab26-b76ccbba5843

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
