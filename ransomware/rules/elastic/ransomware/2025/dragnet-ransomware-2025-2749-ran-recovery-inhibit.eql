// Dragnet [Ransomware]: dragnet-ransomware-2025-2749 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0c92267d-c11c-5339-a0e4-7a812a408702

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
