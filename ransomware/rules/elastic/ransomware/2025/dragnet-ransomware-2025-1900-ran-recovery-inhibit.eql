// Dragnet [Ransomware]: dragnet-ransomware-2025-1900 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 90773111-c004-5672-b204-943eb55cc439

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
