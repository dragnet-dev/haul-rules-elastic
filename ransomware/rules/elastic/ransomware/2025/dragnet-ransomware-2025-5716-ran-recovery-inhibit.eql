// Dragnet [Ransomware]: dragnet-ransomware-2025-5716 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: be7fdc60-061e-5d9e-9d4b-c6b74ce11f42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
