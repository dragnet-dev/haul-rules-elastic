// Dragnet [Ransomware]: dragnet-ransomware-2025-1314 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 806a175b-c2cc-5d5c-b92b-3a0dcc6da160

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
