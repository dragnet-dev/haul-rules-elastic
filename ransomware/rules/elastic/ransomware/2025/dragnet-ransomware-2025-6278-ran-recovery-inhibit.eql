// Dragnet [Ransomware]: dragnet-ransomware-2025-6278 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 4cce2200-22cf-5c61-a4fb-7d6d1e555d2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
