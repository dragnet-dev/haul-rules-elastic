// Dragnet [Ransomware]: dragnet-ransomware-2025-2754 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d74aef79-1ae2-5463-a34e-f0d4d8170e48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
