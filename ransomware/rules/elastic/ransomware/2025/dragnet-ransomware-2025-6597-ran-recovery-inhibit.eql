// Dragnet [Ransomware]: dragnet-ransomware-2025-6597 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 2cc9fd10-fff3-50f4-a968-89d45afbfd66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
