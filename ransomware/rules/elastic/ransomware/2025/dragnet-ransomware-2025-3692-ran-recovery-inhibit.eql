// Dragnet [Ransomware]: dragnet-ransomware-2025-3692 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 96aa0b57-5085-591f-acc5-3d40c29bbbbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
