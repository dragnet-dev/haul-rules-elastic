// Dragnet [Ransomware]: dragnet-ransomware-2025-2406 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 8bad9105-2636-50bc-ae4e-a18f27601d31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
