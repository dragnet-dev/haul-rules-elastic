// Dragnet [Ransomware]: dragnet-ransomware-2025-1983 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f37a1678-9534-5c39-b6c1-d9a642a16fac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
