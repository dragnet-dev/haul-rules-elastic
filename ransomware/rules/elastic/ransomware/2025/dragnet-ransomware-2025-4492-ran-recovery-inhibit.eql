// Dragnet [Ransomware]: dragnet-ransomware-2025-4492 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: f7f792ed-b008-5097-9a24-889127d8967b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
