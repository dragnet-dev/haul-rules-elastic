// Dragnet [Ransomware]: dragnet-ransomware-2025-0129 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b59d0690-b7d6-524d-8bb6-92eb2901e9e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
