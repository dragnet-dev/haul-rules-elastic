// Dragnet [Ransomware]: dragnet-ransomware-2025-7726 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4fa23ebe-dc10-5f35-aedf-6cc40ca5da35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
