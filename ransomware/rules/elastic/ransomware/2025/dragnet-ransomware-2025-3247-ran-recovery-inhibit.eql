// Dragnet [Ransomware]: dragnet-ransomware-2025-3247 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: dbb54e64-dffd-5952-9556-4e9d935de242

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
