// Dragnet [Ransomware]: dragnet-ransomware-2025-5175 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 9c237176-2aef-5481-a4bb-ffb2e8c78902

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
