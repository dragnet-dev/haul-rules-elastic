// Dragnet [Ransomware]: dragnet-ransomware-2025-1408 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1e026f1e-a73e-52dc-aa43-ec4aedc3c37c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
