// Dragnet [Ransomware]: dragnet-ransomware-2025-4406 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: dc367179-124c-56e1-8c67-4b688db0201d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
