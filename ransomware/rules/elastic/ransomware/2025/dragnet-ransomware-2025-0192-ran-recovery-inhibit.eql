// Dragnet [Ransomware]: dragnet-ransomware-2025-0192 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 7732518d-dd7e-590b-813b-369185564d95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
