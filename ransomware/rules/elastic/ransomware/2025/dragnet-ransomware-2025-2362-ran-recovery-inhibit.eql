// Dragnet [Ransomware]: dragnet-ransomware-2025-2362 — Recovery Inhibition (securotrop)
// Status: experimental | Level: high | ID: f463754e-7206-5dbd-84b6-49eb21efe300

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
