// Dragnet [Ransomware]: dragnet-ransomware-2025-3818 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 3c39ff78-da81-542e-8b5d-2494623543bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
