// Dragnet [Ransomware]: dragnet-ransomware-2025-1455 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 2f214dfb-bcf3-5482-9d0f-711d97f91a4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
