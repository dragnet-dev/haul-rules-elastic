// Dragnet [Ransomware]: dragnet-ransomware-2025-5249 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c570a5a9-801e-5941-809e-21007441a5a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
