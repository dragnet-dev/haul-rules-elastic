// Dragnet [Ransomware]: dragnet-ransomware-2025-6538 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 7ea95056-0346-5b20-8003-350df54b6994

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
