// Dragnet [Ransomware]: dragnet-ransomware-2025-6626 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: c2ee5148-47d8-58fb-8d0a-88b64772ee7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
