// Dragnet [Ransomware]: dragnet-ransomware-2025-2473 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 9a06f5f4-e022-567d-9988-791103e9d3a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
