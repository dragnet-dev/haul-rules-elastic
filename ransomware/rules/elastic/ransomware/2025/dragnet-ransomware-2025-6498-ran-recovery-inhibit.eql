// Dragnet [Ransomware]: dragnet-ransomware-2025-6498 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 84fce6d5-2b84-5ee3-a37e-25cfdeeb3560

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
