// Dragnet [Ransomware]: dragnet-ransomware-2025-4810 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: b26f314f-c99c-5d03-8553-fd56dcedcd17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
