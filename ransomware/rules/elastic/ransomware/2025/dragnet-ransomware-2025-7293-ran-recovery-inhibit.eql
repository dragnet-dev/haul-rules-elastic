// Dragnet [Ransomware]: dragnet-ransomware-2025-7293 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 9b772b32-f969-557d-b91c-fa0f8d5bb5d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
