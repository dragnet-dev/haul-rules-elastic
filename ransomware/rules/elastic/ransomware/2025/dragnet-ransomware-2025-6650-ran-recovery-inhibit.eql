// Dragnet [Ransomware]: dragnet-ransomware-2025-6650 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: eab7d530-f492-5527-bf33-9a1c55cb0193

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
