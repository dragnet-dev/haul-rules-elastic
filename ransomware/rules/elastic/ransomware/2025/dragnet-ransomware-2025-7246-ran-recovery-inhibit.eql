// Dragnet [Ransomware]: dragnet-ransomware-2025-7246 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1debe72c-ad73-501a-91c2-f8c7bb80a73e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
