// Dragnet [Ransomware]: dragnet-ransomware-2025-3707 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 0f8be074-60a6-5234-a60e-457bc811655e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
