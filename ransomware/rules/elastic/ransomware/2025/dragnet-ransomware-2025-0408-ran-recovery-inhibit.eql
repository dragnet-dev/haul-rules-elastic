// Dragnet [Ransomware]: dragnet-ransomware-2025-0408 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 38fffa15-bd9d-5954-80d3-5ea543a4ff32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
