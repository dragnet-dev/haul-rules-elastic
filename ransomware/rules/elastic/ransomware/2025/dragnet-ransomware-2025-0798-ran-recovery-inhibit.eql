// Dragnet [Ransomware]: dragnet-ransomware-2025-0798 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 5ded692d-44d2-511a-92c3-f819becbc962

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
