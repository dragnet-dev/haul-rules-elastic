// Dragnet [Ransomware]: dragnet-ransomware-2025-1709 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 4199b435-2265-5f55-bb8c-0582a1dd6181

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
