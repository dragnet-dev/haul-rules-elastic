// Dragnet [Ransomware]: dragnet-ransomware-2025-3784 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 955a8c58-b5fd-55ff-b577-256aff29b82b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
