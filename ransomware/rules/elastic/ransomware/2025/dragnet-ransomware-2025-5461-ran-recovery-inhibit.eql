// Dragnet [Ransomware]: dragnet-ransomware-2025-5461 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4929ba5f-b6f9-577c-a1da-21d93ec203a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
