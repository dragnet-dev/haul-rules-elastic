// Dragnet [Ransomware]: dragnet-ransomware-2025-3887 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: bf880984-c6d8-55c9-80af-f082702f15d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
