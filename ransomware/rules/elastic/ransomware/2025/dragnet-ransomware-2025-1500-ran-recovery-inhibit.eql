// Dragnet [Ransomware]: dragnet-ransomware-2025-1500 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2900513f-f93e-5fad-8ade-d550943128be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
