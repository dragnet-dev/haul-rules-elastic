// Dragnet [Ransomware]: dragnet-ransomware-2025-6796 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: f2820885-bc8b-5251-a159-76ade1720704

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
