// Dragnet [Ransomware]: dragnet-ransomware-2025-4194 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 4c09274b-2f7e-557f-9dce-f7a48d88a412

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
