// Dragnet [Ransomware]: dragnet-ransomware-2025-3898 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: fec23627-9ce4-5499-9c5f-805f92bda0e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
