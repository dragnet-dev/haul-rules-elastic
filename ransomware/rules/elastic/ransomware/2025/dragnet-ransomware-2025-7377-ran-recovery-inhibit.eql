// Dragnet [Ransomware]: dragnet-ransomware-2025-7377 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: d87b01bc-c319-5cd6-a97e-12605a2d307a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
