// Dragnet [Ransomware]: dragnet-ransomware-2025-7892 — Recovery Inhibition (radar)
// Status: deprecated | Level: high | ID: ac05e4a4-e9d3-5645-ae9a-e7173882d26c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
