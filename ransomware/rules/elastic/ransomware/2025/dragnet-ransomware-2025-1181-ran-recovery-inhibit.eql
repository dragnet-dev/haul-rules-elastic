// Dragnet [Ransomware]: dragnet-ransomware-2025-1181 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: cd9dff5c-a4e3-5129-bab3-31aedbb13d95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
