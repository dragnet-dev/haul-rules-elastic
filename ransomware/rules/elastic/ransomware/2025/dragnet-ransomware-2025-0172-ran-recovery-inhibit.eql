// Dragnet [Ransomware]: dragnet-ransomware-2025-0172 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: e113730a-ecb8-5ed0-9a4b-337bb11bf6b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
