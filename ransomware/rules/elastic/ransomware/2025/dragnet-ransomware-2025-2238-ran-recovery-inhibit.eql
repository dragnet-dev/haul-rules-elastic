// Dragnet [Ransomware]: dragnet-ransomware-2025-2238 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: f8e3fbe7-a7ec-5cc9-ae2f-d3497309c6ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
