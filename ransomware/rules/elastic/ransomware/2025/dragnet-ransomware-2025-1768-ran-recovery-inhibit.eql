// Dragnet [Ransomware]: dragnet-ransomware-2025-1768 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: d893a700-c646-57cc-9f40-079e5fefedfc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
