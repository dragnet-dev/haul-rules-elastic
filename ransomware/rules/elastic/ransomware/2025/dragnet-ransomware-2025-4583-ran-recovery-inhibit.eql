// Dragnet [Ransomware]: dragnet-ransomware-2025-4583 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6a88ff96-33f2-56d2-af80-0be72482aea2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
