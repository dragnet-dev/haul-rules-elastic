// Dragnet [Ransomware]: dragnet-ransomware-2025-1771 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 251f05f1-7eac-535a-9187-9dd26445e857

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
