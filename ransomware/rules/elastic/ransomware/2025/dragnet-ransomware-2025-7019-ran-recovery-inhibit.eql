// Dragnet [Ransomware]: dragnet-ransomware-2025-7019 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: 35bc97bb-4044-5e02-a729-8cbba96376ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
