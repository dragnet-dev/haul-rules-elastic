// Dragnet [Ransomware]: dragnet-ransomware-2025-0180 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 11a73090-587c-5830-bf25-22ebc57ffef1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
