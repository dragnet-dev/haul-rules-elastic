// Dragnet [Ransomware]: dragnet-ransomware-2025-2378 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ca679134-81ea-5662-8d26-d1ae8ab5ac4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
