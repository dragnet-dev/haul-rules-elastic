// Dragnet [Ransomware]: dragnet-ransomware-2025-3153 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: e92cfe5f-808c-5672-b029-789605538fdb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
