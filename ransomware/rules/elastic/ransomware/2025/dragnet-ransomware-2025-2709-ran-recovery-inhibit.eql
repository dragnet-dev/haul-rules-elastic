// Dragnet [Ransomware]: dragnet-ransomware-2025-2709 — Recovery Inhibition (handala)
// Status: test | Level: high | ID: 29a08372-2e8c-5347-851b-d882ae42f6dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
