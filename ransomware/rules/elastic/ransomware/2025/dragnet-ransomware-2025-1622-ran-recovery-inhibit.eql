// Dragnet [Ransomware]: dragnet-ransomware-2025-1622 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: f80e028d-f83a-5da2-968d-a162039af1ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
