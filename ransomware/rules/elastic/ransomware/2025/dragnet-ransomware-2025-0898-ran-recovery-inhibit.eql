// Dragnet [Ransomware]: dragnet-ransomware-2025-0898 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4e673a31-70ac-50aa-9468-39d2968e222c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
