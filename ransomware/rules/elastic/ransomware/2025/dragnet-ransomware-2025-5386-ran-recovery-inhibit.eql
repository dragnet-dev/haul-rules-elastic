// Dragnet [Ransomware]: dragnet-ransomware-2025-5386 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c4d431e9-f6ad-5010-9720-fa9bf7479dfa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
