// Dragnet [Ransomware]: dragnet-ransomware-2025-1733 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: fa98a3ac-d696-5086-90e3-3b50d7a81b6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
