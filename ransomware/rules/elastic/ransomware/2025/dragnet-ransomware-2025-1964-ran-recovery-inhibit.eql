// Dragnet [Ransomware]: dragnet-ransomware-2025-1964 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: 4cd45d5f-aba9-5b4e-b0fb-a887384a2704

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
