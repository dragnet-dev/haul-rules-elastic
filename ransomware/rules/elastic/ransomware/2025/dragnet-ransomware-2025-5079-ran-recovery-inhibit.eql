// Dragnet [Ransomware]: dragnet-ransomware-2025-5079 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: e063159e-fdd3-5075-92c3-d450ca3675c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
