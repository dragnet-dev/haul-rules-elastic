// Dragnet [Ransomware]: dragnet-ransomware-2025-0060 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 1a5fcbfd-aeb0-561b-a304-419b4c8ce6f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
