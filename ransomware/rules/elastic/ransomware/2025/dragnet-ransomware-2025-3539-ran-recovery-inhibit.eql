// Dragnet [Ransomware]: dragnet-ransomware-2025-3539 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: b95e8456-db9b-5d69-8913-a929ded67d88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
