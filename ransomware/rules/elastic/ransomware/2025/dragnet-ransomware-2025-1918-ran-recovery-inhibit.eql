// Dragnet [Ransomware]: dragnet-ransomware-2025-1918 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1f91a7b4-ee90-5962-ad61-aed108278ca4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
