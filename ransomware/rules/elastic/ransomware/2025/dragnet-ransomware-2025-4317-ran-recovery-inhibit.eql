// Dragnet [Ransomware]: dragnet-ransomware-2025-4317 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: a462a13c-bb20-5bf4-9ea1-56d05261e63b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
