// Dragnet [Ransomware]: dragnet-ransomware-2025-3205 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4275c483-775f-587a-9917-6ba1daa3941b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
