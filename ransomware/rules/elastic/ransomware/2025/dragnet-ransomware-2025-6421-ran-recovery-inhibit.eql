// Dragnet [Ransomware]: dragnet-ransomware-2025-6421 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: a15dd977-4daf-5aee-8499-6103bd936d87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
