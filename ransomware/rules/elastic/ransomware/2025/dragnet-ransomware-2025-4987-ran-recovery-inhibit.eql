// Dragnet [Ransomware]: dragnet-ransomware-2025-4987 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d2d5c258-990d-57c2-9cc0-6ca9ab9c4863

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
