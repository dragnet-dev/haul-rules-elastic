// Dragnet [Ransomware]: dragnet-ransomware-2025-4953 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d3158073-335b-58ea-9edd-8a20dc97325f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
