// Dragnet [Ransomware]: dragnet-ransomware-2025-1587 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: adb4ffad-fa70-5c85-b1a4-a15dfb428eef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
