// Dragnet [Ransomware]: dragnet-ransomware-2025-3735 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 7271a12e-d209-58eb-bf01-e737159321b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
