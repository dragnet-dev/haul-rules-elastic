// Dragnet [Ransomware]: dragnet-ransomware-2025-2903 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 3d24701e-58c9-5015-9e5b-d8c4b3491b20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
