// Dragnet [Ransomware]: dragnet-ransomware-2025-0346 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 590a8b5d-6e59-5280-acb2-db7284f4ab42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
