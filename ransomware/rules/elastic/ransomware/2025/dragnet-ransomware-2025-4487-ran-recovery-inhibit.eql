// Dragnet [Ransomware]: dragnet-ransomware-2025-4487 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 32ea2c85-9985-5f17-874e-c81d54ed046f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
