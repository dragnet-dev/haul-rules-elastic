// Dragnet [Ransomware]: dragnet-ransomware-2025-4137 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: fd2a543e-de75-5f11-83ba-568fe73c3abb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
