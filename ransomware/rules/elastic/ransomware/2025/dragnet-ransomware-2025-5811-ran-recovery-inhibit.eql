// Dragnet [Ransomware]: dragnet-ransomware-2025-5811 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 85404a75-d043-501b-a808-0895f292b9c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
