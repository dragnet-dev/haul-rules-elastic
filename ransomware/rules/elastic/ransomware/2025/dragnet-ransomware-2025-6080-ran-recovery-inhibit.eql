// Dragnet [Ransomware]: dragnet-ransomware-2025-6080 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: fc278084-bc0a-5446-b04f-7e2e36e73645

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
