// Dragnet [Ransomware]: dragnet-ransomware-2025-0996 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: f0d39c66-c620-55a6-b41d-e3bf2511c816

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
