// Dragnet [Ransomware]: dragnet-ransomware-2025-0372 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c8ceb495-0730-592b-a6a6-d1c7aeb04e2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
