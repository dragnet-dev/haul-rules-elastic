// Dragnet [Ransomware]: dragnet-ransomware-2025-6247 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2299c43c-4439-5b97-ad90-ef16b3326863

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
