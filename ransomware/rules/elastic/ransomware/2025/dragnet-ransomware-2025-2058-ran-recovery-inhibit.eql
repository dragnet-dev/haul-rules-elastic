// Dragnet [Ransomware]: dragnet-ransomware-2025-2058 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: f2488f3f-4ccb-54b7-a3b2-359ec7eba721

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
