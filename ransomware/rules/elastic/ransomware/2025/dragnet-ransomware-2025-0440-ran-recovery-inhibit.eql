// Dragnet [Ransomware]: dragnet-ransomware-2025-0440 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 609c60e2-a778-5546-b4ea-77d744042645

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
