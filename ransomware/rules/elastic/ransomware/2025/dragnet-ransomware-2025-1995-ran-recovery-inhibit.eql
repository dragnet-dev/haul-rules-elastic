// Dragnet [Ransomware]: dragnet-ransomware-2025-1995 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 11179f57-169d-5737-84f0-ed4ceb5e8f83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
