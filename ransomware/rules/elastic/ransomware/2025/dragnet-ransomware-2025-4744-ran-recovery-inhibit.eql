// Dragnet [Ransomware]: dragnet-ransomware-2025-4744 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 2e89502a-e355-5b85-88b4-ab1215493a2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
