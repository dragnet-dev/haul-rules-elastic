// Dragnet [Ransomware]: dragnet-ransomware-2025-6557 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 426780e3-4329-5f8c-94a8-f7b867622bc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
