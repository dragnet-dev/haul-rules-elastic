// Dragnet [Ransomware]: dragnet-ransomware-2025-0374 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 9dea3549-abc1-5651-a0ce-e36a7726f075

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
