// Dragnet [Ransomware]: dragnet-ransomware-2025-1046 — Recovery Inhibition (anubis)
// Status: experimental | Level: high | ID: 4851aaaa-9c8a-5be8-ae42-8ed2a9a4ee6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
