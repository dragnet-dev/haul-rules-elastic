// Dragnet [Ransomware]: dragnet-ransomware-2025-0152 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b936b144-07ca-5d8b-8b6b-c75e34dded5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
