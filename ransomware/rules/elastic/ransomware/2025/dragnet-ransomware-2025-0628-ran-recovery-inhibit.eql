// Dragnet [Ransomware]: dragnet-ransomware-2025-0628 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 89966569-86a4-5478-bd88-00c706142144

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
