// Dragnet [Ransomware]: dragnet-ransomware-2025-2207 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: d44829e4-1ed8-5b52-80c0-6ac131252c39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
