// Dragnet [Ransomware]: dragnet-ransomware-2025-4692 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9fd54a36-eeff-54c7-b0a9-cc857f2356b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
