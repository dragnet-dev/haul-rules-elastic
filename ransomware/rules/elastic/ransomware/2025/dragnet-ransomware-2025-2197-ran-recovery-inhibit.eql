// Dragnet [Ransomware]: dragnet-ransomware-2025-2197 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: d6ff6db3-5533-58e5-a68a-a00039d9950b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
