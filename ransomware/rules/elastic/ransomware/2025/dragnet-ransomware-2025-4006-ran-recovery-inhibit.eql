// Dragnet [Ransomware]: dragnet-ransomware-2025-4006 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: feed45e7-f518-5174-9706-04901493b870

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
