// Dragnet [Ransomware]: dragnet-ransomware-2025-1495 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: a028d4ec-c22c-5af9-9e7b-584e66bf21d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
