// Dragnet [Ransomware]: dragnet-ransomware-2025-3737 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: f30c44a9-b428-5a5d-a0ca-97812b01a138

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
