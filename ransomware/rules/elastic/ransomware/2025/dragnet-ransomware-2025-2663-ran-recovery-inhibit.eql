// Dragnet [Ransomware]: dragnet-ransomware-2025-2663 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 31d959a5-3fd2-52ff-8b8f-361d4e427f0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
