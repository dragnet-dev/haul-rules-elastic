// Dragnet [Ransomware]: dragnet-ransomware-2025-4055 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 05efb252-9550-5cbf-a5bf-37c6f9cad5da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
