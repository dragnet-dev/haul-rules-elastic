// Dragnet [Ransomware]: dragnet-ransomware-2025-2970 — Recovery Inhibition (anubis)
// Status: experimental | Level: high | ID: 2f3749bb-88f5-5271-beb1-8ccebb585a94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
