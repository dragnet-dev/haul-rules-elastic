// Dragnet [Ransomware]: dragnet-ransomware-2025-6638 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 3175db69-d9a6-5ea0-b26d-7aec000111cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
