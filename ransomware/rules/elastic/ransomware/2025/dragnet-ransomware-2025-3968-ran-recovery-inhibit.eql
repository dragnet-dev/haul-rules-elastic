// Dragnet [Ransomware]: dragnet-ransomware-2025-3968 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: fd65ddbd-d81b-54f0-afdc-b969323a5397

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
