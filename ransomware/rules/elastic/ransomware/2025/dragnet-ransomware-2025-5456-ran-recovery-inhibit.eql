// Dragnet [Ransomware]: dragnet-ransomware-2025-5456 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 8b99bbdf-928f-5327-b4cd-e9d003a93e21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
