// Dragnet [Ransomware]: dragnet-ransomware-2025-7480 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1efc777a-9fb7-5eda-b0dc-6de5aa9615d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
