// Dragnet [Ransomware]: dragnet-ransomware-2025-1283 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: dda8081d-1cd4-5970-a214-dc72036fa6aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
