// Dragnet [Ransomware]: dragnet-ransomware-2025-5719 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: 4e319aa0-d1a7-526d-923c-21ae99b5144a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
