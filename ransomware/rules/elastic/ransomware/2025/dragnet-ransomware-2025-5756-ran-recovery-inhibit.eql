// Dragnet [Ransomware]: dragnet-ransomware-2025-5756 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 47e1878c-3cd0-5b12-8549-fc7157cebf62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
