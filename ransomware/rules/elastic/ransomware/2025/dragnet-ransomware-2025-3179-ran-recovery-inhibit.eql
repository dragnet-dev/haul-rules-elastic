// Dragnet [Ransomware]: dragnet-ransomware-2025-3179 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: beb3280c-88ae-5c19-8b6b-b34ba813ed6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
