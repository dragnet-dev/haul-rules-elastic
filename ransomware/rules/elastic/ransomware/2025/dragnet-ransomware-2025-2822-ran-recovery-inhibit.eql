// Dragnet [Ransomware]: dragnet-ransomware-2025-2822 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 07a42c26-99e3-566a-a398-c7854c81ee2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
