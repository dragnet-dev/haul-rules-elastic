// Dragnet [Ransomware]: dragnet-ransomware-2025-6392 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 8f2cff3f-ed30-5d77-870c-a03b61712336

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
