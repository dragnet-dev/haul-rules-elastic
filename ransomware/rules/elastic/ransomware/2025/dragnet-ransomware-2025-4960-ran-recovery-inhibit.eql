// Dragnet [Ransomware]: dragnet-ransomware-2025-4960 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7486d06b-db7a-5d76-a260-6b13d4309c43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
