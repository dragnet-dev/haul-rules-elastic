// Dragnet [Ransomware]: dragnet-ransomware-2025-4723 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 721a605a-7d6c-5aac-8c87-afd19d17e46b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
