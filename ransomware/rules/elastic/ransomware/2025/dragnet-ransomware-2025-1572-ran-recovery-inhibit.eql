// Dragnet [Ransomware]: dragnet-ransomware-2025-1572 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 99d095b3-a4ad-59f0-ae85-09ec819d7b1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
