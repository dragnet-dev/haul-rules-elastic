// Dragnet [Ransomware]: dragnet-ransomware-2025-0519 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 6607df38-c2c9-5428-a610-dbf5a1bc0fd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
