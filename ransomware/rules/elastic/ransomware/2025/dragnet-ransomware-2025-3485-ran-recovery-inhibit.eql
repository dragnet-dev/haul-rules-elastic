// Dragnet [Ransomware]: dragnet-ransomware-2025-3485 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 95c0c359-2b6d-570c-9e4e-490d11b44631

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
