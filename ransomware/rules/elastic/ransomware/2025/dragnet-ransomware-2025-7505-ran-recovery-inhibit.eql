// Dragnet [Ransomware]: dragnet-ransomware-2025-7505 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: af252230-a837-5551-831c-8b7ce93240ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
