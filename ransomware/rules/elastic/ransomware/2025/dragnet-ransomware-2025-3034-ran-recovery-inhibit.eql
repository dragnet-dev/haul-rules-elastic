// Dragnet [Ransomware]: dragnet-ransomware-2025-3034 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 4807d6f0-754e-5dc4-a344-663f826da9c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
