// Dragnet [Ransomware]: dragnet-ransomware-2025-3318 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: c86b4fd2-3082-5d26-88f5-345dc6819385

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
