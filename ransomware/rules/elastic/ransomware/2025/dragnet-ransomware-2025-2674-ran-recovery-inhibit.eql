// Dragnet [Ransomware]: dragnet-ransomware-2025-2674 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 2b373e6d-ed49-5cb6-8e97-68d44d5f3ee2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
