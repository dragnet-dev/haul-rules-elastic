// Dragnet [Ransomware]: dragnet-ransomware-2025-0415 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ede4d727-43e5-5fd5-86d8-11d56d6bec2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
