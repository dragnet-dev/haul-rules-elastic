// Dragnet [Ransomware]: dragnet-ransomware-2025-6866 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 5ccdbaab-dda6-5695-a96e-d402dcbe3a49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
