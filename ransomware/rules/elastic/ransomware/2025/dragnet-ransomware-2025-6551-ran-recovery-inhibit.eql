// Dragnet [Ransomware]: dragnet-ransomware-2025-6551 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 416bdfca-999d-5eac-81ee-6f00b7346970

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
