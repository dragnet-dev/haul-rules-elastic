// Dragnet [Ransomware]: dragnet-ransomware-2025-4077 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 71b4ca5d-5de1-5e9a-a0b8-163646afd45a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
