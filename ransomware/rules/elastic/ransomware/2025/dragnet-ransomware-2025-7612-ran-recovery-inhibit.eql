// Dragnet [Ransomware]: dragnet-ransomware-2025-7612 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 0721228e-a206-52cb-a982-e9cc0d7fc194

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
