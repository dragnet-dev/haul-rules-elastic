// Dragnet [Ransomware]: dragnet-ransomware-2025-3948 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 26fd776c-1d33-544c-8501-a514e42b3d71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
