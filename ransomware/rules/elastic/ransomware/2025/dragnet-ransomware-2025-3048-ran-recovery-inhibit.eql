// Dragnet [Ransomware]: dragnet-ransomware-2025-3048 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: eccf9df4-4d67-5135-b8be-eed467530d8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
