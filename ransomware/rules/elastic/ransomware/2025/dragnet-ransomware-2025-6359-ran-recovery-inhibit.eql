// Dragnet [Ransomware]: dragnet-ransomware-2025-6359 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 5cc682f4-aa1d-56fa-935c-350326a6a74c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
