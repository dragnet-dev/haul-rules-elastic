// Dragnet [Ransomware]: dragnet-ransomware-2025-1980 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 76c274c3-c1c7-5c85-bdc9-87958c938d6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
