// Dragnet [Ransomware]: dragnet-ransomware-2025-2702 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 61a0a2ce-7389-5c56-9a99-ba0270213ef2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
