// Dragnet [Ransomware]: dragnet-ransomware-2025-5348 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: e933c216-d7bc-596e-b799-505b2bd254df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
