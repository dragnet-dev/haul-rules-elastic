// Dragnet [Ransomware]: dragnet-ransomware-2025-5013 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: c0d98260-43b8-5429-a5ec-1fe908882284

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
