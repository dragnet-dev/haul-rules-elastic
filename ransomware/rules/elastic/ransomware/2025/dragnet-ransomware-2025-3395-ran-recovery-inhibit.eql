// Dragnet [Ransomware]: dragnet-ransomware-2025-3395 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c3d61ae6-380b-5a69-b459-d97973138878

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
