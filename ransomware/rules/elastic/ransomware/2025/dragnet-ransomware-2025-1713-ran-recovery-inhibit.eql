// Dragnet [Ransomware]: dragnet-ransomware-2025-1713 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 8b746975-70d6-5716-ade7-2e06011d60a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
