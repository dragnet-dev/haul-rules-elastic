// Dragnet [Ransomware]: dragnet-ransomware-2025-5930 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f2583586-5282-5bff-8771-d52738274b43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
