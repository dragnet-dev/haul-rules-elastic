// Dragnet [Ransomware]: dragnet-ransomware-2025-0407 — Recovery Inhibition (obscura)
// Status: experimental | Level: high | ID: ab49e251-2ed7-567c-9707-76f280760490

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
