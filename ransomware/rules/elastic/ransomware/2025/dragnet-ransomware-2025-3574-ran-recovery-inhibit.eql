// Dragnet [Ransomware]: dragnet-ransomware-2025-3574 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 18baa832-df7f-5d48-9246-4aad6a70be9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
