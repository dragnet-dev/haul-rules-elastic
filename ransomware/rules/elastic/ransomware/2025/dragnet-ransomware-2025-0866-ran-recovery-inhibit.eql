// Dragnet [Ransomware]: dragnet-ransomware-2025-0866 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: ba377785-d2da-586d-a714-94c8b5018e5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
