// Dragnet [Ransomware]: dragnet-ransomware-2025-2286 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 943e199f-ab10-5b59-b428-58cc51891b10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
