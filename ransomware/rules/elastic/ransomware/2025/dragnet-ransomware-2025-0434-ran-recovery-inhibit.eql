// Dragnet [Ransomware]: dragnet-ransomware-2025-0434 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b45ffe9d-bd50-5e57-a4e6-e20f7c041ac6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
