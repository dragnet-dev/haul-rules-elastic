// Dragnet [Ransomware]: dragnet-ransomware-2025-6115 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 01efc136-573e-53da-9b3e-673ef07d87c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
