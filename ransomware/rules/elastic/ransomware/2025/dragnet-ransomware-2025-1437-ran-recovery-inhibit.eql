// Dragnet [Ransomware]: dragnet-ransomware-2025-1437 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: c42e5485-e111-52e4-bfbd-df84d896b5a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
