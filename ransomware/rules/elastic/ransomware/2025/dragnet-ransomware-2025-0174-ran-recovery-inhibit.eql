// Dragnet [Ransomware]: dragnet-ransomware-2025-0174 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: ef334121-567f-535c-89c0-32f31da2029e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
