// Dragnet [Ransomware]: dragnet-ransomware-2025-5364 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c7fbf171-ce55-576a-93cd-6e54642976f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
