// Dragnet [Ransomware]: dragnet-ransomware-2025-2680 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: c4990dc0-d03d-506b-9ab5-f1f34c88a7ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
