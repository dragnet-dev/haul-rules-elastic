// Dragnet [Ransomware]: dragnet-ransomware-2025-3380 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: c86198fe-2e13-5221-8f22-7db6294adbfc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
