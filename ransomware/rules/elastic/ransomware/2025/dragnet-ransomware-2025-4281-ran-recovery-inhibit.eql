// Dragnet [Ransomware]: dragnet-ransomware-2025-4281 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: ba7a0d4c-1ae5-5c89-bc12-461b49f3bd16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
