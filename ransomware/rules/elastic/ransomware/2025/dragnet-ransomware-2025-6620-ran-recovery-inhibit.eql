// Dragnet [Ransomware]: dragnet-ransomware-2025-6620 — Recovery Inhibition (worldleaks)
// Status: test | Level: high | ID: b2eced68-76c9-5342-801f-c8b002f69b37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
