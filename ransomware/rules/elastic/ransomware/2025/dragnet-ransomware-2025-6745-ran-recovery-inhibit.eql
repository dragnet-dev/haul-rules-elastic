// Dragnet [Ransomware]: dragnet-ransomware-2025-6745 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 31e949db-9fec-5f59-8030-a2611aea64fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
