// Dragnet [Ransomware]: dragnet-ransomware-2025-5883 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 0be6790e-831d-5909-91d0-bb96ef64b228

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
