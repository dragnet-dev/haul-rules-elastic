// Dragnet [Ransomware]: dragnet-ransomware-2025-3518 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 811af245-5936-5e05-812f-c29fedc772bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
