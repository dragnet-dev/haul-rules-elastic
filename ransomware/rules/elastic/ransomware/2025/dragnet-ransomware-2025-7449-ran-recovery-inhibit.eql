// Dragnet [Ransomware]: dragnet-ransomware-2025-7449 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fb199694-365c-57fb-807e-8136c3e54140

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
