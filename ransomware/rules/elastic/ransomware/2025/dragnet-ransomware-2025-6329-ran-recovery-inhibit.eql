// Dragnet [Ransomware]: dragnet-ransomware-2025-6329 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: d5665cf2-705d-5733-90b6-00e360e6b109

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
