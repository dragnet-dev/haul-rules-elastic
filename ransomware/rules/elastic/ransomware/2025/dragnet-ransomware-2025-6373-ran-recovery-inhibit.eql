// Dragnet [Ransomware]: dragnet-ransomware-2025-6373 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 47aa9328-2478-5b6a-8913-c08b974f25f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
