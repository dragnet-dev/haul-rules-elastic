// Dragnet [Ransomware]: dragnet-ransomware-2025-0709 — Recovery Inhibition (hellcat)
// Status: deprecated | Level: high | ID: b13f0fa2-7462-5e54-a03f-31179d63e5eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
