// Dragnet [Ransomware]: dragnet-ransomware-2025-5045 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: cebf6bc7-24a9-5647-8cd3-7f440ed1c4d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
