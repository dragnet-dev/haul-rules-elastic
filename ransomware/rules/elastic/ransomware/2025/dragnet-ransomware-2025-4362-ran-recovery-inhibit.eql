// Dragnet [Ransomware]: dragnet-ransomware-2025-4362 — Recovery Inhibition (kawa4096)
// Status: deprecated | Level: high | ID: 52177477-caeb-51cc-9b1e-cd36ca009d62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
