// Dragnet [Ransomware]: dragnet-ransomware-2025-0549 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 61deefde-4647-550a-9421-9e0b357cfc31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
