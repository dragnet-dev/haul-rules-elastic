// Dragnet [Ransomware]: dragnet-ransomware-2025-2276 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fcd865ee-a848-593e-8d47-e6ec0a6b0feb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
