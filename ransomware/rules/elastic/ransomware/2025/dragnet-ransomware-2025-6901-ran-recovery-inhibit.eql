// Dragnet [Ransomware]: dragnet-ransomware-2025-6901 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d5ca2374-77e3-5d14-be77-c11d538348cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
