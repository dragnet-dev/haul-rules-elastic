// Dragnet [Ransomware]: dragnet-ransomware-2025-6555 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: dea421a3-3f41-54b1-8296-85f5ec8e569a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
