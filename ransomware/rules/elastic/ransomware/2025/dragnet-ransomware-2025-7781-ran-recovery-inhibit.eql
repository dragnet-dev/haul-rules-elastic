// Dragnet [Ransomware]: dragnet-ransomware-2025-7781 — Recovery Inhibition (worldleaks)
// Status: test | Level: high | ID: c156bdd9-f263-5971-b929-4e9b5a539b08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
