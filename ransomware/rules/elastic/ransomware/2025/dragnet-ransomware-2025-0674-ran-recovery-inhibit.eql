// Dragnet [Ransomware]: dragnet-ransomware-2025-0674 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 653ae0f9-e16e-5c6b-9706-421b9ba1b0d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
