// Dragnet [Ransomware]: dragnet-ransomware-2025-0982 — Recovery Inhibition (genesis)
// Status: experimental | Level: high | ID: bea7166d-ebc9-5af6-8a5d-c7f14562e8c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
