// Dragnet [Ransomware]: dragnet-ransomware-2025-2205 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f9dc147f-3b19-5710-bdd2-ffbd3e40b5d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
