// Dragnet [Ransomware]: dragnet-ransomware-2025-5988 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 8b65c3c9-3c7b-556e-b9a9-0f62a1319765

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
