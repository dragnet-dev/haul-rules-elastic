// Dragnet [Ransomware]: dragnet-ransomware-2025-0333 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 554cb889-9e4c-5cda-ab19-0b97e8fe2e6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
