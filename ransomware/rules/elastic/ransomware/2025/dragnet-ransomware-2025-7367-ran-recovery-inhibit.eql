// Dragnet [Ransomware]: dragnet-ransomware-2025-7367 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: 1d47dac5-a996-5dec-9807-14c062261d59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
