// Dragnet [Ransomware]: dragnet-ransomware-2025-4865 — Recovery Inhibition (insomnia)
// Status: experimental | Level: high | ID: 73cec4d3-0a86-5654-a239-f0c2077711fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
