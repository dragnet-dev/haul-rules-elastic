// Dragnet [Ransomware]: dragnet-ransomware-2025-6225 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: e8cc9ba0-e594-5fd9-a47d-3dcd88ac6f90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
