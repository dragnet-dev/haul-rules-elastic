// Dragnet [Ransomware]: dragnet-ransomware-2025-5609 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 169bbae8-fb8d-5fdc-9fc9-1710bd65eff3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
