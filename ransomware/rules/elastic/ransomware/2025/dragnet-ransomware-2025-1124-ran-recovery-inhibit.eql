// Dragnet [Ransomware]: dragnet-ransomware-2025-1124 — Recovery Inhibition (termite)
// Status: experimental | Level: high | ID: 31f5b05e-6462-5c02-b466-075091db57bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
