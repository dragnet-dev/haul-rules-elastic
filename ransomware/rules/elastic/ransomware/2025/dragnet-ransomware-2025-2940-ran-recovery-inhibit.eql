// Dragnet [Ransomware]: dragnet-ransomware-2025-2940 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 490ae633-bbc2-50d4-82c8-d8a414519237

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
