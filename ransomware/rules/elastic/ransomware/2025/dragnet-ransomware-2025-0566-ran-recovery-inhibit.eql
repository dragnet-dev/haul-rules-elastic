// Dragnet [Ransomware]: dragnet-ransomware-2025-0566 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 680a2c36-0235-5606-8a1c-ea98b7c2f2ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
