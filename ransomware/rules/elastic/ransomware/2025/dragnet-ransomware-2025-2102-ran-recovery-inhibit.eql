// Dragnet [Ransomware]: dragnet-ransomware-2025-2102 — Recovery Inhibition (handala)
// Status: test | Level: high | ID: a24f30b8-593f-534e-b109-2d8c2fd361f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
