// Dragnet [Ransomware]: dragnet-ransomware-2025-3935 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1a6451fb-3187-54f9-9b04-426bc6925e1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
