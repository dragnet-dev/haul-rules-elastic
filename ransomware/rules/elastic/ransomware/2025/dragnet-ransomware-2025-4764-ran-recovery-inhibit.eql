// Dragnet [Ransomware]: dragnet-ransomware-2025-4764 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 97868060-3217-5a2e-b416-018138c785f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
