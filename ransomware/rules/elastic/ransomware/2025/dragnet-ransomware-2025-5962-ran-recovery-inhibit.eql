// Dragnet [Ransomware]: dragnet-ransomware-2025-5962 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 4c4f3602-15d9-59f9-959f-148a2c21d540

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
