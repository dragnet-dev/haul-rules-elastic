// Dragnet [Ransomware]: dragnet-ransomware-2025-5492 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: f31b39b2-c6c4-5633-9d6d-402baab7e817

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
