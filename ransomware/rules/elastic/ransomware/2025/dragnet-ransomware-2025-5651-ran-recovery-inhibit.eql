// Dragnet [Ransomware]: dragnet-ransomware-2025-5651 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a3ad98f3-2878-5d7f-891d-32f830e7d976

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
