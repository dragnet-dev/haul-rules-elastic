// Dragnet [Ransomware]: dragnet-ransomware-2025-1875 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: ae2ef32f-c3b5-5a43-8337-0354332313e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
