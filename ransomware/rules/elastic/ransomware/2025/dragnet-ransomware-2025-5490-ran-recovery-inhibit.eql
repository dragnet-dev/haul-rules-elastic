// Dragnet [Ransomware]: dragnet-ransomware-2025-5490 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: a44c3bfb-1d68-533d-a242-715f21ca205b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
