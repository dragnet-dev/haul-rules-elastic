// Dragnet [Ransomware]: dragnet-ransomware-2025-6723 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1b2526c4-a007-5c79-9a1a-f5353ac28bb2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
