// Dragnet [Ransomware]: dragnet-ransomware-2025-3317 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 1fffd2c4-7a5a-5766-8059-c96487e993ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
