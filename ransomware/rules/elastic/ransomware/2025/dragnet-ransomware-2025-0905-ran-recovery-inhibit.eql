// Dragnet [Ransomware]: dragnet-ransomware-2025-0905 — Recovery Inhibition (spacebears)
// Status: test | Level: high | ID: 8d6eb08e-ccda-5c09-b0f9-6850eae7ddb2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
