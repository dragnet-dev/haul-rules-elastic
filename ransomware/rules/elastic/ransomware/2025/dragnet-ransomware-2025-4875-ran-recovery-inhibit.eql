// Dragnet [Ransomware]: dragnet-ransomware-2025-4875 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 5ee5b103-5683-528d-8db4-93a7eb4466c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
