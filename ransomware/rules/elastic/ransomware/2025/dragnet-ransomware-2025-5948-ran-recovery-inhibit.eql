// Dragnet [Ransomware]: dragnet-ransomware-2025-5948 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: 2e01aad8-7b4e-5d24-b4a8-d13baacc8db6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
