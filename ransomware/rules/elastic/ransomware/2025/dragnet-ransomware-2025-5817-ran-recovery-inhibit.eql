// Dragnet [Ransomware]: dragnet-ransomware-2025-5817 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fb2eeece-8abb-52c1-997b-40266002c7b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
