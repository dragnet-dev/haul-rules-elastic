// Dragnet [Ransomware]: dragnet-ransomware-2025-2411 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: f50b527d-bb1d-5efd-87df-4cf899ffe5fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
