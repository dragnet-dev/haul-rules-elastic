// Dragnet [Ransomware]: dragnet-ransomware-2025-1623 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 2bf50ade-ba9c-5e1e-ad3a-44cd0674ea29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
