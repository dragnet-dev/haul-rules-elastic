// Dragnet [Ransomware]: dragnet-ransomware-2025-7259 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 5aab9d75-5baf-590d-b6df-ef9d7ff379a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
