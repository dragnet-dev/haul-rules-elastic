// Dragnet [Ransomware]: dragnet-ransomware-2025-3793 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 7ea6f37d-0243-5d26-b0d5-ad804ccde7f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
