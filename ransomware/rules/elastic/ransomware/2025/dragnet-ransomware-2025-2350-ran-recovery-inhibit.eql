// Dragnet [Ransomware]: dragnet-ransomware-2025-2350 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 7d956701-4ed8-5af3-b284-66a8b346e26b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
