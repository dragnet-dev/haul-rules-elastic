// Dragnet [Ransomware]: dragnet-ransomware-2025-4158 — Recovery Inhibition (radar)
// Status: deprecated | Level: high | ID: a2c9760a-94ea-5d23-92b0-65b044918dfc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
