// Dragnet [Ransomware]: dragnet-ransomware-2025-6833 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: facd7eff-94c0-5510-9226-352997591cd4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
