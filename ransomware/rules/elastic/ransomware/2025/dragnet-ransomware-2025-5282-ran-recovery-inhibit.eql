// Dragnet [Ransomware]: dragnet-ransomware-2025-5282 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: cd68476e-3726-57a5-9aba-17928ba1459e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
