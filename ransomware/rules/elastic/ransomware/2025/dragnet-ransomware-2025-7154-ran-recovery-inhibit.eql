// Dragnet [Ransomware]: dragnet-ransomware-2025-7154 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: 81120e46-06ad-5bd4-b02b-adf0eb5c2791

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
