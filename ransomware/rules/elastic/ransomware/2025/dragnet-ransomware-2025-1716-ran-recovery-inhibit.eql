// Dragnet [Ransomware]: dragnet-ransomware-2025-1716 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8f06c9cb-eaea-5a9e-9f4e-37ef3e79a077

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
