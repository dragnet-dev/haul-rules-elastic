// Dragnet [Ransomware]: dragnet-ransomware-2025-2072 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f7d2c325-cb7a-506c-aa31-f85170f22b98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
