// Dragnet [Ransomware]: dragnet-ransomware-2025-4512 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 743f0090-e7f1-5783-93f9-a2f1273786f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
