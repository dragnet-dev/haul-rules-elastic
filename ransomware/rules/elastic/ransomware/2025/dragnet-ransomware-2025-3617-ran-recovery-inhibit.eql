// Dragnet [Ransomware]: dragnet-ransomware-2025-3617 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 99af8a63-9a81-59cd-8440-8944cd5042c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
