// Dragnet [Ransomware]: dragnet-ransomware-2025-7442 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: d1575ac9-e152-5522-ab2c-0a345c9cc403

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
