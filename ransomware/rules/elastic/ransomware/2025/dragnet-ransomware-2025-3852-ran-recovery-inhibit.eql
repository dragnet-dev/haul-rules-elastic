// Dragnet [Ransomware]: dragnet-ransomware-2025-3852 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 287bc8fd-e041-5b99-80ce-d9e4f5478426

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
