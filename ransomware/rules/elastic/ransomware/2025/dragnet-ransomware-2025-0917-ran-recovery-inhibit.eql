// Dragnet [Ransomware]: dragnet-ransomware-2025-0917 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 534ca764-a4cf-567b-a1b3-c5cfb0683c4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
