// Dragnet [Ransomware]: dragnet-ransomware-2025-7443 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 114faee1-a11d-5e47-abb0-058877d58a04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
