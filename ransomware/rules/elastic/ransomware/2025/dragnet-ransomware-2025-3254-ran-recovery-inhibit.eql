// Dragnet [Ransomware]: dragnet-ransomware-2025-3254 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: e50e96cc-6101-56df-858b-5bc4d75d5373

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
