// Dragnet [Ransomware]: dragnet-ransomware-2025-1505 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: ef24708c-e181-55e9-b00f-3c16f8416e26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
