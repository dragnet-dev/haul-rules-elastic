// Dragnet [Ransomware]: dragnet-ransomware-2025-0092 — Recovery Inhibition (kryptos)
// Status: deprecated | Level: high | ID: 03007345-cee7-5f01-a729-a296d95a1b84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
