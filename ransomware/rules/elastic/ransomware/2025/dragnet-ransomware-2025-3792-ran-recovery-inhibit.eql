// Dragnet [Ransomware]: dragnet-ransomware-2025-3792 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: a350c582-6828-5e52-a51f-955a1824db6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
