// Dragnet [Ransomware]: dragnet-ransomware-2025-6826 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: c59c321f-09ae-5da3-ade2-b10d5a3d184d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
