// Dragnet [Ransomware]: dragnet-ransomware-2025-1707 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: ec1bcaff-b974-5516-920c-a7ed0d406b5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
