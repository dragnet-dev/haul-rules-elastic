// Dragnet [Ransomware]: dragnet-ransomware-2025-2010 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ee222ccf-4191-5b87-9083-3ac146e970af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
