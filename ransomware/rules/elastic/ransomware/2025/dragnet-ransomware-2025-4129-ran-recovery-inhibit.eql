// Dragnet [Ransomware]: dragnet-ransomware-2025-4129 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ca2da284-02a1-5214-92bf-842f105441b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
