// Dragnet [Ransomware]: dragnet-ransomware-2025-3903 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 83efca4d-2779-5c67-91d6-186cd273ed93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
