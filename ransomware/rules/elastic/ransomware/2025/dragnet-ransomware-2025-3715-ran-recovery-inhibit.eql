// Dragnet [Ransomware]: dragnet-ransomware-2025-3715 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4ed2a518-e029-571c-8d6d-8dae42780127

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
