// Dragnet [Ransomware]: dragnet-ransomware-2025-4876 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 5d34079d-bf5c-534a-8fcd-51552f6da530

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
