// Dragnet [Ransomware]: dragnet-ransomware-2025-0564 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: 12f80f12-f10c-5812-933b-f327e59fd853

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
