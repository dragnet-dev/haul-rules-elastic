// Dragnet [Ransomware]: dragnet-ransomware-2025-0505 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6dfaa9f4-7de8-560b-9616-b6b965ad2b14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
