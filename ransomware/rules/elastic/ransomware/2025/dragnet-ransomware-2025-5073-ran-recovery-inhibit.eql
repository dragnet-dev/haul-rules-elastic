// Dragnet [Ransomware]: dragnet-ransomware-2025-5073 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 99f1e1f3-5098-5979-ae88-31983f9fb74f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
