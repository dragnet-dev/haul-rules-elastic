// Dragnet [Ransomware]: dragnet-ransomware-2025-4070 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 73bbe253-b2b2-5828-9e02-a6f35666b94c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
