// Dragnet [Ransomware]: dragnet-ransomware-2025-2689 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 46212119-95d5-5ccf-a2c6-df161c25d810

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
