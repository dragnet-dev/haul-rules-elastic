// Dragnet [Ransomware]: dragnet-ransomware-2025-5121 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 5586d050-c63d-5be4-85e5-73c6ec362b18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
