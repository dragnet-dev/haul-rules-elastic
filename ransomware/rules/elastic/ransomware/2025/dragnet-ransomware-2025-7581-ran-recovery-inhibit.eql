// Dragnet [Ransomware]: dragnet-ransomware-2025-7581 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: af2ea063-94bb-58b2-ae97-b80b5039c81f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
