// Dragnet [Ransomware]: dragnet-ransomware-2025-4903 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 0d67ab27-ff40-5293-83ad-877e3da35efa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
