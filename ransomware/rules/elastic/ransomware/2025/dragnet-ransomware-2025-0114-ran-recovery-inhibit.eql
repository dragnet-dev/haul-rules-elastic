// Dragnet [Ransomware]: dragnet-ransomware-2025-0114 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 388a7689-0c3e-54f9-9c68-d45d6c95429d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
