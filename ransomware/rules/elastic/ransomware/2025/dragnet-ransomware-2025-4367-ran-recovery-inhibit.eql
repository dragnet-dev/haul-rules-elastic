// Dragnet [Ransomware]: dragnet-ransomware-2025-4367 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 9f6f693f-134c-5f5d-a33f-9b0425dee7b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
