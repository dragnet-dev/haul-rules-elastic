// Dragnet [Ransomware]: dragnet-ransomware-2025-7356 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 760b2cb2-c81d-5bbb-9d19-424c8b315713

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
