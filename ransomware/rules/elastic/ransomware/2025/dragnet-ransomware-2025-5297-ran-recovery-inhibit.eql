// Dragnet [Ransomware]: dragnet-ransomware-2025-5297 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 3250ccc7-076f-5ab5-8b73-3e3e6c7a4aa1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
