// Dragnet [Ransomware]: dragnet-ransomware-2025-2423 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 0bf4938b-7df9-5f29-95f9-8f778e47561c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
