// Dragnet [Ransomware]: dragnet-ransomware-2025-4979 — Recovery Inhibition (kraken)
// Status: experimental | Level: high | ID: 1d1c3b5c-c22d-5093-93bd-22e655d14f95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
