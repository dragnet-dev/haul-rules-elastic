// Dragnet [Ransomware]: dragnet-ransomware-2025-5950 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 16a38197-10a7-5c91-879b-6fbe1aa4bc19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
