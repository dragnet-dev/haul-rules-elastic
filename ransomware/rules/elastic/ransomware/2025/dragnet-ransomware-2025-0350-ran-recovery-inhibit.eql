// Dragnet [Ransomware]: dragnet-ransomware-2025-0350 — Recovery Inhibition (skira)
// Status: experimental | Level: high | ID: 810cf36c-61c1-5ac4-813f-aa78ea9b72c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
