// Dragnet [Ransomware]: dragnet-ransomware-2025-7708 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f794d8b3-5f49-511c-b215-a242dcc0aa35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
