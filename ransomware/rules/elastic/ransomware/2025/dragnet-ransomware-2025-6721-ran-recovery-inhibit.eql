// Dragnet [Ransomware]: dragnet-ransomware-2025-6721 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5466e33e-5df8-5428-bca7-753c18c15c4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
