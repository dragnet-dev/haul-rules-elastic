// Dragnet [Ransomware]: dragnet-ransomware-2025-0035 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 0b9c373c-cb13-5413-ba63-337272d1a38f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
