// Dragnet [Ransomware]: dragnet-ransomware-2025-5484 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 287c036f-81b2-5c99-b46d-e5641d60d77c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
