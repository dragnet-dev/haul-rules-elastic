// Dragnet [Ransomware]: dragnet-ransomware-2025-1603 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 333ff2ae-468f-5efc-9454-2a567df58768

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
