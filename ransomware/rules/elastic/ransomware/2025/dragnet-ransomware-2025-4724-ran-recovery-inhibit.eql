// Dragnet [Ransomware]: dragnet-ransomware-2025-4724 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1f35cc27-8336-51f3-8ca4-c1a439c3af90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
