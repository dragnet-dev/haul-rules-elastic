// Dragnet [Ransomware]: dragnet-ransomware-2025-3132 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 13a2a67e-450a-51bf-909b-933edc79bd9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
