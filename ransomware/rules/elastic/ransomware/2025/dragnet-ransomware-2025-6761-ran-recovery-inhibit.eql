// Dragnet [Ransomware]: dragnet-ransomware-2025-6761 — Recovery Inhibition (ralord)
// Status: experimental | Level: high | ID: 95d4caed-611a-5495-bd3d-7c3e1d4837b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
