// Dragnet [Ransomware]: dragnet-ransomware-2025-1526 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7b48dd69-6390-52d6-ab29-4d248c4f2e10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
