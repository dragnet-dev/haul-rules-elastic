// Dragnet [Ransomware]: dragnet-ransomware-2025-5485 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 6e9a6823-ebc2-5357-b429-4660dbdeaa57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
