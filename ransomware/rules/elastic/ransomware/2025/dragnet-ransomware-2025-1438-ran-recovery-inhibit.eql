// Dragnet [Ransomware]: dragnet-ransomware-2025-1438 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a67516e9-3489-542e-90d9-352632582f4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
