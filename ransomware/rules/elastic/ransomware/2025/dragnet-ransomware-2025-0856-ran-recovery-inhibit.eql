// Dragnet [Ransomware]: dragnet-ransomware-2025-0856 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 7f81dc3d-297d-5a19-8a96-f47e999dbe29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
