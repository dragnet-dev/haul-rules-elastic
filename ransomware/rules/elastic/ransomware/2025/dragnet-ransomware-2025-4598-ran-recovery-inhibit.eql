// Dragnet [Ransomware]: dragnet-ransomware-2025-4598 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 966196f4-f2de-5316-ad72-49f48308a377

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
