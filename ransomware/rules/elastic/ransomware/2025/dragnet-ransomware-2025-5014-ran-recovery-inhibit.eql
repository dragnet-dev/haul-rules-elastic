// Dragnet [Ransomware]: dragnet-ransomware-2025-5014 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 92063af4-1ed0-55d4-bb66-010c31a2b132

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
