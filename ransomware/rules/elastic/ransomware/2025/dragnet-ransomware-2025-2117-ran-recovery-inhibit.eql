// Dragnet [Ransomware]: dragnet-ransomware-2025-2117 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 6a16e0dc-cfbc-5cd4-9c10-e85f1228929a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
