// Dragnet [Ransomware]: dragnet-ransomware-2025-1965 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 03cc3cd7-9551-5012-b363-2ee4d7a8639a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
