// Dragnet [Ransomware]: dragnet-ransomware-2025-1091 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7fb62c05-464a-50d2-9fae-5037cad7c791

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
