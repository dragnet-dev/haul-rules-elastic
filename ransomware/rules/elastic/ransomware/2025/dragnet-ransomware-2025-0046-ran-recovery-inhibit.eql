// Dragnet [Ransomware]: dragnet-ransomware-2025-0046 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: f0844f3a-eb36-5741-b8d2-fddd227e04c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
