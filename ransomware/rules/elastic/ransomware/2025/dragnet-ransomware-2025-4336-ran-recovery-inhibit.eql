// Dragnet [Ransomware]: dragnet-ransomware-2025-4336 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 62b9aed5-cc33-59ad-9c54-e24c512162e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
