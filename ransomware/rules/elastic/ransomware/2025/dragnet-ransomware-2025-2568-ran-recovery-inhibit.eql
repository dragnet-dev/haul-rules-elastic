// Dragnet [Ransomware]: dragnet-ransomware-2025-2568 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 769ab9c9-aaaf-5b1c-b546-7171a25df6c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
