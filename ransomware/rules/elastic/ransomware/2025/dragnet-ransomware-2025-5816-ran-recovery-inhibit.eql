// Dragnet [Ransomware]: dragnet-ransomware-2025-5816 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 5dee6067-428d-5d7a-a93e-fb07e2b72448

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
