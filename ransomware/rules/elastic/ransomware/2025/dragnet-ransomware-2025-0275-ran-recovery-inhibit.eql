// Dragnet [Ransomware]: dragnet-ransomware-2025-0275 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3c804044-2343-58e2-8676-0b984ee88a2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
