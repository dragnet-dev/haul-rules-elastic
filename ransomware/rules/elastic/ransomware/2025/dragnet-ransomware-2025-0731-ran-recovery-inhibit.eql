// Dragnet [Ransomware]: dragnet-ransomware-2025-0731 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 93b84fce-576b-5234-9e3e-337373eec0b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
