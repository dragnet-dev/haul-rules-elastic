// Dragnet [Ransomware]: dragnet-ransomware-2025-4795 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 951b7571-430b-5f38-b93c-5a24dbe71902

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
