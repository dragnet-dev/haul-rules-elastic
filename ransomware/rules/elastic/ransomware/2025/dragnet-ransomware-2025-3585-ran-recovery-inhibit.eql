// Dragnet [Ransomware]: dragnet-ransomware-2025-3585 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 80e59928-c681-5d59-811b-7f936dce33b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
