// Dragnet [Ransomware]: dragnet-ransomware-2025-0197 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 0e549a14-87c6-5239-8867-b57111a7ae2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
