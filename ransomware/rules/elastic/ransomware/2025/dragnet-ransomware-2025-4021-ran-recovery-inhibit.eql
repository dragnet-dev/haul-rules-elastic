// Dragnet [Ransomware]: dragnet-ransomware-2025-4021 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: f2bc7c9b-cb01-5d3b-be5b-1ede4794ed1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
