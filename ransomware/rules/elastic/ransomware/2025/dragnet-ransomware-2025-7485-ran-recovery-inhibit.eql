// Dragnet [Ransomware]: dragnet-ransomware-2025-7485 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 65ee672e-3fb9-5c7a-b399-2d471cfd75ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
