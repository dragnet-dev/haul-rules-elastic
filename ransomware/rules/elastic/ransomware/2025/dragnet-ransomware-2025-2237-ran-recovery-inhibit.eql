// Dragnet [Ransomware]: dragnet-ransomware-2025-2237 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d4a483aa-862d-5771-b0f0-81b3b61e21a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
