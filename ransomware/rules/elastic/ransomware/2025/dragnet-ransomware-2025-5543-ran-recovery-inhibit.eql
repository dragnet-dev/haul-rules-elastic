// Dragnet [Ransomware]: dragnet-ransomware-2025-5543 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: beeb05bc-96ac-5386-85a3-611f39e9e97f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
