// Dragnet [Ransomware]: dragnet-ransomware-2025-1839 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7c81a29f-6aed-5b1f-86a9-cc2915fab2ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
