// Dragnet [Ransomware]: dragnet-ransomware-2025-0289 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: c8d04300-d24c-5fb5-ab4f-d79da78d4d18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
