// Dragnet [Ransomware]: dragnet-ransomware-2025-3039 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 73160402-0dde-5986-bcad-1e64c2046c5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
