// Dragnet [Ransomware]: dragnet-ransomware-2025-0055 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 17e7ddc2-9bcc-517a-a07d-aa20fe6fa3ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
