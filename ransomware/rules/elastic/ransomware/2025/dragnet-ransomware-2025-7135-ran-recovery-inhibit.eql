// Dragnet [Ransomware]: dragnet-ransomware-2025-7135 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: ab2052e0-573e-5829-ac73-9ae1918cff53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
