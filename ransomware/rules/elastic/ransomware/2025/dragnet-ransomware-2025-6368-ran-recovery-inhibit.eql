// Dragnet [Ransomware]: dragnet-ransomware-2025-6368 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: 9d0bb2c3-8f50-55c5-9577-75f11c71bcf6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
