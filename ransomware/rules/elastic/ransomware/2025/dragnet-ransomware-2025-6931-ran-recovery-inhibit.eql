// Dragnet [Ransomware]: dragnet-ransomware-2025-6931 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: e62e2237-d17e-5910-bc45-d53f593bba0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
