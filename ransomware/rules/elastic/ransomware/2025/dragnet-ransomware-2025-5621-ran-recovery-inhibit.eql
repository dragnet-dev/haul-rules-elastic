// Dragnet [Ransomware]: dragnet-ransomware-2025-5621 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 27b55f97-6983-5f24-9fde-23766508ef9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
