// Dragnet [Ransomware]: dragnet-ransomware-2025-6280 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 02572b08-b315-5c1d-8ab5-b3e89eda6dfd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
