// Dragnet [Ransomware]: dragnet-ransomware-2025-3711 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a8d37731-285a-5c80-91cf-ac553ae1f30d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
