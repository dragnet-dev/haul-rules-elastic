// Dragnet [Ransomware]: dragnet-ransomware-2025-6743 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 5465ab0e-0beb-5323-825d-5315a54706ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
