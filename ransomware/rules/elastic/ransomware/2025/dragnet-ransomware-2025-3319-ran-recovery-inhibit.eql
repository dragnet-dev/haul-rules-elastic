// Dragnet [Ransomware]: dragnet-ransomware-2025-3319 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: e7caaf51-0b3f-550c-8bc1-7009c5bd5879

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
