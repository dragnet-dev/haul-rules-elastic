// Dragnet [Ransomware]: dragnet-ransomware-2025-4955 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 80da5b91-ae85-5730-9930-1efd65b76ea0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
