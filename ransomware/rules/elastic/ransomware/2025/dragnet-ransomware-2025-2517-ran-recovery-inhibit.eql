// Dragnet [Ransomware]: dragnet-ransomware-2025-2517 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a0fdd58c-2d4c-5268-a3ef-0f1b261116de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
