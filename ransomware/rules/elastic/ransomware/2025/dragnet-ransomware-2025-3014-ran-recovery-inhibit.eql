// Dragnet [Ransomware]: dragnet-ransomware-2025-3014 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 53b61a53-90c0-5fdc-a790-640c91f6fa4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
