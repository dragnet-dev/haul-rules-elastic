// Dragnet [Ransomware]: dragnet-ransomware-2025-0113 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 8933aaa2-c3b7-513a-9c75-7072a401cece

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
