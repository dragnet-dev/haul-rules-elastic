// Dragnet [Ransomware]: dragnet-ransomware-2025-5636 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 5b2a1133-57cc-5a81-8163-0454be48d98e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
