// Dragnet [Ransomware]: dragnet-ransomware-2025-3007 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 90612aa4-ef0e-5048-9108-36158969adfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
