// Dragnet [Ransomware]: dragnet-ransomware-2025-1409 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 196b2712-0808-5c53-aa56-0489450336f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
