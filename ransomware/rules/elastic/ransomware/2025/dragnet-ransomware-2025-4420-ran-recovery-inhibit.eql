// Dragnet [Ransomware]: dragnet-ransomware-2025-4420 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e930222f-b679-53cf-a78e-b4586878edeb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
