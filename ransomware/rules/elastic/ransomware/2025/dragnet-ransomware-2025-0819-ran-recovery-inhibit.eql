// Dragnet [Ransomware]: dragnet-ransomware-2025-0819 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 99fcc434-8732-576f-bf28-e1b426cfd15a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
