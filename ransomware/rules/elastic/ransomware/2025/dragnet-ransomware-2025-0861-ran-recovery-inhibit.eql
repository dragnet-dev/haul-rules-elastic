// Dragnet [Ransomware]: dragnet-ransomware-2025-0861 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 868dd2c1-0424-584e-8ce0-6fd68204381a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
