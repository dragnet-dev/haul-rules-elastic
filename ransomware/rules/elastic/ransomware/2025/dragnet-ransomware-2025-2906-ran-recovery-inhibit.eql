// Dragnet [Ransomware]: dragnet-ransomware-2025-2906 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 026a29e9-043e-531d-90bb-f48c8478cb21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
