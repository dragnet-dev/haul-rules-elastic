// Dragnet [Ransomware]: dragnet-ransomware-2025-5324 — Recovery Inhibition (brotherhood)
// Status: deprecated | Level: high | ID: 0ea56dd4-e79a-58b4-a5b0-af27e07ef5cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
