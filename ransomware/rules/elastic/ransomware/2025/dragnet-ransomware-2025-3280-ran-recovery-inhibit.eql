// Dragnet [Ransomware]: dragnet-ransomware-2025-3280 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: 2a19a636-53dc-5e6b-b439-1c9816afe349

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
