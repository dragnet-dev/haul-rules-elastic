// Dragnet [Ransomware]: dragnet-ransomware-2025-7516 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 3476cd83-8273-5c2a-8fec-b020a74e6c5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
