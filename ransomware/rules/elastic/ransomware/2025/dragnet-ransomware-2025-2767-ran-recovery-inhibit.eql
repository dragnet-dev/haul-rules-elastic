// Dragnet [Ransomware]: dragnet-ransomware-2025-2767 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: e82d99ad-e502-52a6-8ba4-5afb992afead

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
