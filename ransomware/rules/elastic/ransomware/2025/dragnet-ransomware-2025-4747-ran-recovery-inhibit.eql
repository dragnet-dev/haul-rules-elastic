// Dragnet [Ransomware]: dragnet-ransomware-2025-4747 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: d1bd74ba-62c9-52ba-a9ba-95a0733e44d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
