// Dragnet [Ransomware]: dragnet-ransomware-2025-1798 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 672d5af6-a05c-5248-a939-2b4adc57b3d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
