// Dragnet [Ransomware]: dragnet-ransomware-2025-0386 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 14b37e08-6d25-5af8-80d7-1547b3bfcd85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
