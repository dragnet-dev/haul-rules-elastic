// Dragnet [Ransomware]: dragnet-ransomware-2025-7220 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0428201e-060c-5f3d-9812-f1bf66c243ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
