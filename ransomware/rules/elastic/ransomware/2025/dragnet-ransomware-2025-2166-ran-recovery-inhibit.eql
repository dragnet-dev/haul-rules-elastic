// Dragnet [Ransomware]: dragnet-ransomware-2025-2166 — Recovery Inhibition (radar)
// Status: experimental | Level: high | ID: c6225ae7-52d7-5556-8ac1-31e4063e6ee0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
