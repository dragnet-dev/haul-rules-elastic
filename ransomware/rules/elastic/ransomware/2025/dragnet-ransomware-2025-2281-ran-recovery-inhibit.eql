// Dragnet [Ransomware]: dragnet-ransomware-2025-2281 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 06c658a7-6067-542a-affb-a89ac714db19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
