// Dragnet [Ransomware]: dragnet-ransomware-2025-4049 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 9273f23e-cb07-5974-8be6-df32e376d154

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
