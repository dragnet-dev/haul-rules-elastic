// Dragnet [Ransomware]: dragnet-ransomware-2025-0088 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 89d6a048-e3cb-5fc6-9dd5-76e01d0d74f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
