// Dragnet [Ransomware]: dragnet-ransomware-2025-2189 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 724846dd-6cb4-57be-ba23-79af65927e70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
