// Dragnet [Ransomware]: dragnet-ransomware-2025-1116 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: ae3fa17c-03d4-5df0-81ec-9c839668295e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
