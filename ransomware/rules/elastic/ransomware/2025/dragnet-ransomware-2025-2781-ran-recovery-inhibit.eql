// Dragnet [Ransomware]: dragnet-ransomware-2025-2781 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 79144cf1-c80b-5c10-820f-dcfb597877fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
