// Dragnet [Ransomware]: dragnet-ransomware-2025-1826 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 6eb08f92-69e7-59b2-8729-08962f4554cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
