// Dragnet [Ransomware]: dragnet-ransomware-2025-3600 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 313379cd-72d0-56d5-a27a-c9743918b050

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
