// Dragnet [Ransomware]: dragnet-ransomware-2025-6811 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 6a2f4352-139f-5f70-97a8-ae562c73d55a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
