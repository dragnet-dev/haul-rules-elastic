// Dragnet [Ransomware]: dragnet-ransomware-2025-1903 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 0b9eecfc-fb63-5d44-b6bc-f9e11139bdd2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
