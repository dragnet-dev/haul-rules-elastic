// Dragnet [Ransomware]: dragnet-ransomware-2025-0649 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 275ab476-8fb3-5412-9738-b10b66f4a435

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
