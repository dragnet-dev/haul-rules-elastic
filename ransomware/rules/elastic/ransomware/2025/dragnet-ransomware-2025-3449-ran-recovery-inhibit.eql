// Dragnet [Ransomware]: dragnet-ransomware-2025-3449 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f48ef570-ef7f-5995-a1de-196141628660

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
