// Dragnet [Ransomware]: dragnet-ransomware-2025-3933 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 39ab4541-bbd7-5e23-adad-4f516c9ed514

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
