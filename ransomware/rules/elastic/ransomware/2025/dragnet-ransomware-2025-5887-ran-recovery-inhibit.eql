// Dragnet [Ransomware]: dragnet-ransomware-2025-5887 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0122e786-a1f0-5bd1-bd8a-0202e18346a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
