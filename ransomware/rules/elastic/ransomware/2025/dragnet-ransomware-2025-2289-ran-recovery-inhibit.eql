// Dragnet [Ransomware]: dragnet-ransomware-2025-2289 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 84babadc-6d8b-5042-beb1-9ca4c1a546a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
