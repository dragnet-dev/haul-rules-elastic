// Dragnet [Ransomware]: dragnet-ransomware-2025-5923 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7a284739-8913-5f7b-aa6c-9a3b9fdbb162

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
