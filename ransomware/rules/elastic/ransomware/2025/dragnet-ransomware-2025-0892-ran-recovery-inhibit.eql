// Dragnet [Ransomware]: dragnet-ransomware-2025-0892 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4c2b08ab-8c77-55be-86a7-eaaa3106418e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
