// Dragnet [Ransomware]: dragnet-ransomware-2025-6295 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: f2cdd6a3-7e4d-54d9-b8c2-f8856d0200a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
