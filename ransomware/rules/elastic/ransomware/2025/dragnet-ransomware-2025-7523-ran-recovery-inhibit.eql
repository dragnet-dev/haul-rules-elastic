// Dragnet [Ransomware]: dragnet-ransomware-2025-7523 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 777f3970-e5c2-5b43-ba13-7e0edecf2f18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
