// Dragnet [Ransomware]: dragnet-ransomware-2025-4215 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: abd345a7-32a4-577f-a05a-bab745e4fa92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
