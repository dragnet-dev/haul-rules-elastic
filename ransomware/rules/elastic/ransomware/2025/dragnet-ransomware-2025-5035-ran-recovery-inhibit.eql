// Dragnet [Ransomware]: dragnet-ransomware-2025-5035 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: f8e41977-1b07-5352-b7af-3d5bdeba5a59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
