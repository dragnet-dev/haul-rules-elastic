// Dragnet [Ransomware]: dragnet-ransomware-2025-1299 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 7888d2b5-c188-57d8-af87-bccea719f170

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
