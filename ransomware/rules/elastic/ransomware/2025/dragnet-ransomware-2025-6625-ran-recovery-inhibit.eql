// Dragnet [Ransomware]: dragnet-ransomware-2025-6625 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 335c1c2a-13e1-541d-bbcd-2ba4ff642d90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
