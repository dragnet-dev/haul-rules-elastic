// Dragnet [Ransomware]: dragnet-ransomware-2025-5206 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 51fe7f6d-dfd3-585a-8fb3-42cd6c52e1be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
