// Dragnet [Ransomware]: dragnet-ransomware-2025-1643 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 97b586fe-9c95-5005-ab7b-bf827c289eb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
