// Dragnet [Ransomware]: dragnet-ransomware-2025-5151 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 3e595e77-3895-5097-9666-7e33896ed536

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
