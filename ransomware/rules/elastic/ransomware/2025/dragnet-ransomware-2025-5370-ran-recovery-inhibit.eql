// Dragnet [Ransomware]: dragnet-ransomware-2025-5370 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: c30b3c65-0391-51e6-8dbc-5c6c83438d71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
