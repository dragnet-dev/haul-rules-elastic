// Dragnet [Ransomware]: dragnet-ransomware-2025-3572 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cada5605-fa0c-533f-a1ec-63ff90b81a95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
