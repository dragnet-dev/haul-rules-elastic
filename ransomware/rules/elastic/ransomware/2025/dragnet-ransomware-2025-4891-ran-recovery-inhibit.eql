// Dragnet [Ransomware]: dragnet-ransomware-2025-4891 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 7e404bed-83ff-5e0e-9784-5ca4a94505a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
