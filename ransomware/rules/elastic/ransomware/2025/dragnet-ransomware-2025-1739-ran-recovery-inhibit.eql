// Dragnet [Ransomware]: dragnet-ransomware-2025-1739 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2d36a603-f48a-5fe4-8646-c90eb2f2b3e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
