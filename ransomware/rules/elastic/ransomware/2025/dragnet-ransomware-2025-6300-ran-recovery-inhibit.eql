// Dragnet [Ransomware]: dragnet-ransomware-2025-6300 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 6c533cca-0a57-585c-8144-423f3947c410

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
