// Dragnet [Ransomware]: dragnet-ransomware-2025-1749 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: f3d245d2-f97f-505b-9e0e-63d9747347ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
