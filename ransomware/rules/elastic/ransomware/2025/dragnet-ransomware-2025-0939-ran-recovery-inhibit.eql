// Dragnet [Ransomware]: dragnet-ransomware-2025-0939 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 332ec143-6b49-52e2-8266-fb3c161c4c8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
