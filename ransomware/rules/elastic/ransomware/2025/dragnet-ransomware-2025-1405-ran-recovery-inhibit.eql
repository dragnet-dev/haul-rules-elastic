// Dragnet [Ransomware]: dragnet-ransomware-2025-1405 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 4dfba50b-bd82-5c0a-bf9a-4d45185870bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
