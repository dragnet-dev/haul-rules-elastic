// Dragnet [Ransomware]: dragnet-ransomware-2025-4315 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a99e911e-5284-5c15-b536-95404d6eb3c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
