// Dragnet [Ransomware]: dragnet-ransomware-2025-4697 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 1af241df-cee7-585b-806b-606c8c4dd2e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
