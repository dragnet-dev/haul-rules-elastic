// Dragnet [Ransomware]: dragnet-ransomware-2025-4130 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: b6365c73-38c6-5297-986b-63b014695611

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
