// Dragnet [Ransomware]: dragnet-ransomware-2025-7042 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: e297673b-1643-5e5a-aa4a-958e1471ec1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
