// Dragnet [Ransomware]: dragnet-ransomware-2025-3556 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: dcfc21c6-2b55-5b84-88a2-d43ed887e1e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
