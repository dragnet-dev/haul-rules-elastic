// Dragnet [Ransomware]: dragnet-ransomware-2025-4830 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 95fe3ec5-b36e-5446-b2bd-093b8824cc1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
