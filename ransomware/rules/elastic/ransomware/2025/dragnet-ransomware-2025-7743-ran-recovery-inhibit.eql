// Dragnet [Ransomware]: dragnet-ransomware-2025-7743 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: a61a969f-c7eb-576d-8537-62f22314a2f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
