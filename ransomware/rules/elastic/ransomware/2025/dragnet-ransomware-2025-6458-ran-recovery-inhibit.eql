// Dragnet [Ransomware]: dragnet-ransomware-2025-6458 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 480bab47-355e-5419-803f-ec3dc9d7f0ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
