// Dragnet [Ransomware]: dragnet-ransomware-2025-4927 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 970c03e4-7309-5c58-b731-05d1240ec274

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
