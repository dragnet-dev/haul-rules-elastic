// Dragnet [Ransomware]: dragnet-ransomware-2025-2391 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 9b6da8b3-7857-528f-912f-636ff48e0271

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
