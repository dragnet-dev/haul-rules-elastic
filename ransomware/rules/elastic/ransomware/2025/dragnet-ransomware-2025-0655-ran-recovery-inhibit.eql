// Dragnet [Ransomware]: dragnet-ransomware-2025-0655 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: de64e1eb-f9b8-5ba5-8521-3a08d3111c33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
