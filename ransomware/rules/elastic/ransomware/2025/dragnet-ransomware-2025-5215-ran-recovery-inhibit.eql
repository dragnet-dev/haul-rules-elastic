// Dragnet [Ransomware]: dragnet-ransomware-2025-5215 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: ec2d704d-4c4f-5c7f-a794-3644db557613

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
