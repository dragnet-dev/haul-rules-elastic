// Dragnet [Ransomware]: dragnet-ransomware-2025-1648 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 2dc05f7a-9471-5b0d-9863-b306fd05e9d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
