// Dragnet [Ransomware]: dragnet-ransomware-2025-0335 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 65b4afe2-240d-5b82-b6ad-2ebdb7e56d10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
