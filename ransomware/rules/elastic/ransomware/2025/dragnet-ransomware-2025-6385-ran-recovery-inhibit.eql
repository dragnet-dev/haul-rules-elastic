// Dragnet [Ransomware]: dragnet-ransomware-2025-6385 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b5c0cb27-db8f-52dd-b342-b3a34b522866

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
