// Dragnet [Ransomware]: dragnet-ransomware-2025-6537 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 89756f8d-1775-5078-aa2e-4f81d7b439a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
