// Dragnet [Ransomware]: dragnet-ransomware-2025-2190 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 4b62a59e-7475-59d6-ac0b-49c66f2c64e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
