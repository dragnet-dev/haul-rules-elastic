// Dragnet [Ransomware]: dragnet-ransomware-2025-4151 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 08ba079a-55b1-51ad-86cc-a77bfc577a17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
