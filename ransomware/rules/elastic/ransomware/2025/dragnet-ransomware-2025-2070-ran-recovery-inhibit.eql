// Dragnet [Ransomware]: dragnet-ransomware-2025-2070 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 701b2e13-6ba6-5a42-a8ae-be2aeb5bd45a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
