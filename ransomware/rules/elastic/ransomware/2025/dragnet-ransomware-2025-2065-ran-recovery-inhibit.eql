// Dragnet [Ransomware]: dragnet-ransomware-2025-2065 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: a689b84f-caa2-5b89-8393-08e711450c2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
