// Dragnet [Ransomware]: dragnet-ransomware-2025-5359 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2a7bf52a-8706-51ec-9cee-294cfca23d00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
