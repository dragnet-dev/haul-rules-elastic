// Dragnet [Ransomware]: dragnet-ransomware-2025-6613 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: c83feba0-66c0-50e6-9ff9-3d59a73b1fdd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
