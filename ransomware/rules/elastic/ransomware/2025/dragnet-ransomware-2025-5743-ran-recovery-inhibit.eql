// Dragnet [Ransomware]: dragnet-ransomware-2025-5743 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ef9f936b-d5b7-5b65-a2b8-5de89f319fd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
