// Dragnet [Ransomware]: dragnet-ransomware-2025-0850 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 69b13e2f-4b98-5f7b-b3e3-65c9ec34728c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
