// Dragnet [Ransomware]: dragnet-ransomware-2025-4971 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 80f5be24-d149-5897-9eba-a1789a3dd410

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
