// Dragnet [Ransomware]: dragnet-ransomware-2025-0307 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 9125d3da-3999-5aeb-bd81-54252c19264b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
