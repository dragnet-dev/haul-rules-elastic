// Dragnet [Ransomware]: dragnet-ransomware-2025-6631 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 44248b14-fe8a-5366-9f85-018fefca2cab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
