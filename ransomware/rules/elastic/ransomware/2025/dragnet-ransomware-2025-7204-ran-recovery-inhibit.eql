// Dragnet [Ransomware]: dragnet-ransomware-2025-7204 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 8ada3754-8924-5997-bddc-8bdd1c72bc96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
