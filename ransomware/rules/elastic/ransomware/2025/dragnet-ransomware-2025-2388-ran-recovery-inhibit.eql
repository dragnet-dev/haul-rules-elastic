// Dragnet [Ransomware]: dragnet-ransomware-2025-2388 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: b7dc24d3-fcf4-5eee-82ab-b063a332e349

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
