// Dragnet [Ransomware]: dragnet-ransomware-2025-0490 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: c36d9099-f4ea-581f-8cb1-60ea83d4841f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
