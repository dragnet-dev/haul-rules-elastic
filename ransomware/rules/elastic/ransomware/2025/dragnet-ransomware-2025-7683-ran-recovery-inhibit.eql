// Dragnet [Ransomware]: dragnet-ransomware-2025-7683 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 4d49a6a7-f4ae-5aca-b9d2-6cba4629b141

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
