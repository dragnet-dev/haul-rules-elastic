// Dragnet [Ransomware]: dragnet-ransomware-2025-4933 — Recovery Inhibition (datacarry)
// Status: deprecated | Level: high | ID: 1f591824-a6c1-59eb-875a-3fe092dec553

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
