// Dragnet [Ransomware]: dragnet-ransomware-2025-2149 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 47d96bbf-a034-5bcc-90c7-b3b832a3f6bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
