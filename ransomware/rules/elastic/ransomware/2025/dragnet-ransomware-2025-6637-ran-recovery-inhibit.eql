// Dragnet [Ransomware]: dragnet-ransomware-2025-6637 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ea163d4c-546c-533d-9742-54abf93064e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
