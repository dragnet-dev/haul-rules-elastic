// Dragnet [Ransomware]: dragnet-ransomware-2025-6526 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: daf9e96a-4cb8-5e92-a439-f6993263700a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
