// Dragnet [Ransomware]: dragnet-ransomware-2025-3242 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2941ff2e-1d42-51b6-a65e-f4e2f55c259e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
