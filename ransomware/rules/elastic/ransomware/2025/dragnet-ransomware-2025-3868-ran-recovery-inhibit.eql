// Dragnet [Ransomware]: dragnet-ransomware-2025-3868 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 68586a48-f8fc-5967-9888-772921a19efc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
