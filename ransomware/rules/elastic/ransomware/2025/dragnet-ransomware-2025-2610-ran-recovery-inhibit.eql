// Dragnet [Ransomware]: dragnet-ransomware-2025-2610 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b0586880-7ab6-5326-a838-1325e68dcd40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
