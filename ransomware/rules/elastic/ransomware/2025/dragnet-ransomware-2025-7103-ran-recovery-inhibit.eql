// Dragnet [Ransomware]: dragnet-ransomware-2025-7103 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2aa2c3a6-1e99-5f10-befd-4cf3badaf4c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
