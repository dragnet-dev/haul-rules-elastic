// Dragnet [Ransomware]: dragnet-ransomware-2025-2571 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: b93413ad-4aef-54a9-a422-a531d2e6c48a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
