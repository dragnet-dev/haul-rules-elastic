// Dragnet [Ransomware]: dragnet-ransomware-2025-3399 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: f1997e4c-8ef1-5af6-b788-4880496306f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
