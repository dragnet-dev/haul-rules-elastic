// Dragnet [Ransomware]: dragnet-ransomware-2025-4816 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: f0f921ca-560e-5867-841f-de5ee6bc1666

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
