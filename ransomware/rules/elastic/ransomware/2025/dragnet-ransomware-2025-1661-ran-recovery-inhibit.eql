// Dragnet [Ransomware]: dragnet-ransomware-2025-1661 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 801e95fa-434a-5817-b2c7-d455e4051e94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
