// Dragnet [Ransomware]: dragnet-ransomware-2025-6686 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f8c27590-d377-5bb6-8f55-273333e4b783

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
