// Dragnet [Ransomware]: dragnet-ransomware-2025-0583 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f1922ef1-c7b7-57a3-a934-09b70a416c2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
