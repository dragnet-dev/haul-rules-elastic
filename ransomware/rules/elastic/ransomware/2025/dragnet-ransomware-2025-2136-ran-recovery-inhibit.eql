// Dragnet [Ransomware]: dragnet-ransomware-2025-2136 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: cb1f5212-c21a-5726-ba49-8d5d79243fa0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
