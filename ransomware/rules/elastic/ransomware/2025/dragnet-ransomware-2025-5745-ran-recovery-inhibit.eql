// Dragnet [Ransomware]: dragnet-ransomware-2025-5745 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 90717c3e-a10b-55b9-8310-fdd4ffc1f758

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
