// Dragnet [Ransomware]: dragnet-ransomware-2025-4448 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 2551d5ed-0e02-5d39-8fd3-1053c1047a2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
