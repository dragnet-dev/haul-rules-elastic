// Dragnet [Ransomware]: dragnet-ransomware-2025-7771 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: d604eff4-41fb-5e3d-8bd3-03880fc22abc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
