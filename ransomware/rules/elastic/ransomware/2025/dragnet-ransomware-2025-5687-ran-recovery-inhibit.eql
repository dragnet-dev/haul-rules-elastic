// Dragnet [Ransomware]: dragnet-ransomware-2025-5687 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: 6705966a-86a9-5fb0-b70a-f95972b45a1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
