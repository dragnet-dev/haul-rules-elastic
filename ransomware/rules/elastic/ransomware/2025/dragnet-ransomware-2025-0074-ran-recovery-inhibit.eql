// Dragnet [Ransomware]: dragnet-ransomware-2025-0074 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1d654158-f1d3-5341-af54-acfd1811885e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
