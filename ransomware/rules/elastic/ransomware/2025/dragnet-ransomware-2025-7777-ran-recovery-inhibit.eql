// Dragnet [Ransomware]: dragnet-ransomware-2025-7777 — Recovery Inhibition (d4rk4rmy)
// Status: experimental | Level: high | ID: 05e363aa-de71-5028-8a1b-620f8598eccd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
