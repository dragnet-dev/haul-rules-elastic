// Dragnet [Ransomware]: dragnet-ransomware-2025-7592 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: d92f2437-3df9-58b6-9029-83ee7f84a43d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
