// Dragnet [Ransomware]: dragnet-ransomware-2025-1194 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 0fc8cd5e-ef13-5cab-b369-14ebd5da99d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
