// Dragnet [Ransomware]: dragnet-ransomware-2025-0944 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: dc74761a-3e82-55c5-a3e6-5c639b30bfbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
