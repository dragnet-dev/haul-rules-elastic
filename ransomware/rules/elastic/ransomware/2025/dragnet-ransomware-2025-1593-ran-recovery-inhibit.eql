// Dragnet [Ransomware]: dragnet-ransomware-2025-1593 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 760869d3-4281-57a2-bf61-5427b3ce6bf7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
