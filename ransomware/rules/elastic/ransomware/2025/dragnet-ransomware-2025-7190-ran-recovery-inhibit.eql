// Dragnet [Ransomware]: dragnet-ransomware-2025-7190 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e0f911ed-5356-5dde-a684-1eef762748e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
