// Dragnet [Ransomware]: dragnet-ransomware-2025-4343 — Recovery Inhibition (nightspire)
// Status: experimental | Level: high | ID: 0fd04322-55d3-532c-a6e0-988b88698f59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
