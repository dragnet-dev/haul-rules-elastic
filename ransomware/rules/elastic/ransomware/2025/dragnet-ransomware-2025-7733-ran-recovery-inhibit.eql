// Dragnet [Ransomware]: dragnet-ransomware-2025-7733 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: e606a50a-5ba5-56f0-80d0-bc63e9e7dc4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
