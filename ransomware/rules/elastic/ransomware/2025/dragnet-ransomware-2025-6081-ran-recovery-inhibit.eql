// Dragnet [Ransomware]: dragnet-ransomware-2025-6081 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 2b694372-6a2c-5717-9dae-f523162326ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
