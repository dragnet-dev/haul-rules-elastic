// Dragnet [Ransomware]: dragnet-ransomware-2025-1373 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b0039194-29c9-5ec1-bb87-75a841920755

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
