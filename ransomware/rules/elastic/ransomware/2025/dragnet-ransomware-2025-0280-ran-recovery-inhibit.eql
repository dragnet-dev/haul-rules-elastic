// Dragnet [Ransomware]: dragnet-ransomware-2025-0280 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b5190fc6-b279-56d4-bd0c-b1df2c8f31bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
