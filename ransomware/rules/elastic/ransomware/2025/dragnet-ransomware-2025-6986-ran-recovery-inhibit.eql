// Dragnet [Ransomware]: dragnet-ransomware-2025-6986 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5382747c-d206-5d4a-8a1f-5a3d22169edd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
