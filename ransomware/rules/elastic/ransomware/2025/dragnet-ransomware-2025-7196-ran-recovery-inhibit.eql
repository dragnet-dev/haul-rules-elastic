// Dragnet [Ransomware]: dragnet-ransomware-2025-7196 — Recovery Inhibition (desolator)
// Status: experimental | Level: high | ID: 59285484-36d9-528c-b63e-91cd8caf8979

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
