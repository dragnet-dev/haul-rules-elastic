// Dragnet [Ransomware]: dragnet-ransomware-2025-7819 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: ebfe555b-97f1-5d61-b4e6-a3991e57d532

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
