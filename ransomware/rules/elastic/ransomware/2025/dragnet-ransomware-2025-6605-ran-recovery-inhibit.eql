// Dragnet [Ransomware]: dragnet-ransomware-2025-6605 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: aeba698b-c5b3-5e37-926c-2d96221c3a47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
