// Dragnet [Ransomware]: dragnet-ransomware-2025-1502 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: fe1043f8-0cf7-5df6-8d32-ee0ba39d22cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
