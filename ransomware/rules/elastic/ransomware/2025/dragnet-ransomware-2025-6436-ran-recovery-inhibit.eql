// Dragnet [Ransomware]: dragnet-ransomware-2025-6436 — Recovery Inhibition (kawa4096)
// Status: deprecated | Level: high | ID: ceba6d72-b4f3-59e0-8ebf-b5088eda6c31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
