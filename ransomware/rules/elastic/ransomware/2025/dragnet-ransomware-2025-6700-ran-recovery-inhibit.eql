// Dragnet [Ransomware]: dragnet-ransomware-2025-6700 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: a7a9033f-146b-50b1-ade0-6675d5f69fb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
