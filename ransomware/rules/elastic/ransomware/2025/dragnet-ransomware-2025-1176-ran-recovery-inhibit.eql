// Dragnet [Ransomware]: dragnet-ransomware-2025-1176 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 27ef8db1-0f50-53b4-b7fa-6b7994b6aac3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
