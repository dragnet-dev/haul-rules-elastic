// Dragnet [Ransomware]: dragnet-ransomware-2025-1369 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 05a1fbc5-c002-50d2-bc34-17251d2b7d57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
