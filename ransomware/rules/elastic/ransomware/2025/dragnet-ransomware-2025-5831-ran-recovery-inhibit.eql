// Dragnet [Ransomware]: dragnet-ransomware-2025-5831 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 35246c20-87d4-5c20-b95b-511deb57e01c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
