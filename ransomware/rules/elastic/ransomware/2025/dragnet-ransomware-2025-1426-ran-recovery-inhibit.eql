// Dragnet [Ransomware]: dragnet-ransomware-2025-1426 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 65608d42-7602-5d81-9095-d993ae4f49bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
