// Dragnet [Ransomware]: dragnet-ransomware-2025-7108 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: bf7bb1ef-462a-5d3e-aebd-ef5bd3d113ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
