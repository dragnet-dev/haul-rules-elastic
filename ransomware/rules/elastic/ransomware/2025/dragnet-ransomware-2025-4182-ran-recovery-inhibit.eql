// Dragnet [Ransomware]: dragnet-ransomware-2025-4182 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e554d671-7c37-5dde-b103-d5bfbccc9106

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
