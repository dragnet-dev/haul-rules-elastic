// Dragnet [Ransomware]: dragnet-ransomware-2025-7014 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: abbd9ea0-9ca5-54cd-992a-b921c56fcbe6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
