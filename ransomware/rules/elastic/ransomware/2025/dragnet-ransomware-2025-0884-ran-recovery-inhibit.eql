// Dragnet [Ransomware]: dragnet-ransomware-2025-0884 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 9634d38d-9ba3-587c-a86f-e9fd65092430

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
