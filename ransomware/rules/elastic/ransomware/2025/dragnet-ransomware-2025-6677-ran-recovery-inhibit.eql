// Dragnet [Ransomware]: dragnet-ransomware-2025-6677 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 5da4f275-fc4a-5f57-93de-36cf912cc1d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
