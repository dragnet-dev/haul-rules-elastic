// Dragnet [Ransomware]: dragnet-ransomware-2025-7152 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2488189e-519c-5a5b-bbc4-098c4df2d818

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
