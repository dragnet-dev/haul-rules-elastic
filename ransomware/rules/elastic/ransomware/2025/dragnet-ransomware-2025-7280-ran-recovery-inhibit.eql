// Dragnet [Ransomware]: dragnet-ransomware-2025-7280 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 9347ed1a-af02-5c96-9b88-bf91bf7d88af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
