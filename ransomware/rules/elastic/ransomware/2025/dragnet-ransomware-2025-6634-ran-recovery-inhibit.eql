// Dragnet [Ransomware]: dragnet-ransomware-2025-6634 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 349181d2-4f13-56de-8ca6-0288a55a4b28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
