// Dragnet [Ransomware]: dragnet-ransomware-2025-7291 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 24c3c4a3-ff2a-54eb-8ea5-3fb25ca99791

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
