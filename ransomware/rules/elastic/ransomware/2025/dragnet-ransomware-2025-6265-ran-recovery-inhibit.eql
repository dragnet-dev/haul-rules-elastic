// Dragnet [Ransomware]: dragnet-ransomware-2025-6265 — Recovery Inhibition (kazu)
// Status: experimental | Level: high | ID: 9d8c0cd7-805e-587d-89c4-46e8301ed84d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
