// Dragnet [Ransomware]: dragnet-ransomware-2025-4232 — Recovery Inhibition (cephalus)
// Status: deprecated | Level: high | ID: 0f25ed9e-af58-5ed6-9772-cd67d6f6ffdc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
