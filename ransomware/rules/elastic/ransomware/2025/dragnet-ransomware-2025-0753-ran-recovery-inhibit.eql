// Dragnet [Ransomware]: dragnet-ransomware-2025-0753 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 997d1a6c-10c0-5293-8657-6b6a9bf43b85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
