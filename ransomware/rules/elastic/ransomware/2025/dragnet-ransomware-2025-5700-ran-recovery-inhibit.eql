// Dragnet [Ransomware]: dragnet-ransomware-2025-5700 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 026385b7-f2dc-5b82-9206-90996561270a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
