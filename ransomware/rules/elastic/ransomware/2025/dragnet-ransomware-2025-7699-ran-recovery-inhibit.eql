// Dragnet [Ransomware]: dragnet-ransomware-2025-7699 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 1e3dd37d-180c-590d-a602-94f56814d244

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
