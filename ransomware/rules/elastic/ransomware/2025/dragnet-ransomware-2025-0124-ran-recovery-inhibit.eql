// Dragnet [Ransomware]: dragnet-ransomware-2025-0124 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 6c4e4143-261f-5216-bb8c-dfb3599f6a6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
