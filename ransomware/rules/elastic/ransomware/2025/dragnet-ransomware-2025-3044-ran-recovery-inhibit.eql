// Dragnet [Ransomware]: dragnet-ransomware-2025-3044 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: e58a8ad3-2902-5133-9f07-b1ed8992e001

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
