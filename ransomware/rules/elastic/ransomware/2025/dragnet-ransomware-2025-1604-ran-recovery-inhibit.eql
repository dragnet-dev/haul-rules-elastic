// Dragnet [Ransomware]: dragnet-ransomware-2025-1604 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 94ad796c-7985-56f0-9efe-f10757511458

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
