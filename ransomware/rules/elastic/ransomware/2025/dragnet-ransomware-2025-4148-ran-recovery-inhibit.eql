// Dragnet [Ransomware]: dragnet-ransomware-2025-4148 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 972bd46a-bd35-5c97-bb2a-94cdd86ff8d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
