// Dragnet [Ransomware]: dragnet-ransomware-2025-2259 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 1aec9f2c-57bd-57d0-a2ba-09265e998fe6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
