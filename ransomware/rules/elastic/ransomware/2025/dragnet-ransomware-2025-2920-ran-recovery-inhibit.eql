// Dragnet [Ransomware]: dragnet-ransomware-2025-2920 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: abe9a162-d00d-54e9-8e01-74e93ddabae7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
