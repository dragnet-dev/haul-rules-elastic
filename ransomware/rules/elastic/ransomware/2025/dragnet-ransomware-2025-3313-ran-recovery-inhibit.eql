// Dragnet [Ransomware]: dragnet-ransomware-2025-3313 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: abfff877-1784-516d-8ddf-8a73f38b76a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
