// Dragnet [Ransomware]: dragnet-ransomware-2025-3914 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a98712c1-cfc9-5664-a40e-c39fd83b1dae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
