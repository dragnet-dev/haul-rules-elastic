// Dragnet [Ransomware]: dragnet-ransomware-2025-5875 — Recovery Inhibition (silent)
// Status: experimental | Level: high | ID: a95cea51-1e10-5eee-a886-b496f3a8ab4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
