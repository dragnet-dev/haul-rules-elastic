// Dragnet [Ransomware]: dragnet-ransomware-2025-4700 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: bfd9b131-8854-5cd7-94da-51b2ab03798e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
