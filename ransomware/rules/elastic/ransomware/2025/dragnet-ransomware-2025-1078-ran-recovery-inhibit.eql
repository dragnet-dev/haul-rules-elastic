// Dragnet [Ransomware]: dragnet-ransomware-2025-1078 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: d594315e-c83a-5452-841d-2a2c38ff598d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
