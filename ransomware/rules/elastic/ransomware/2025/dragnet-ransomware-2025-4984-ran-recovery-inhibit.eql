// Dragnet [Ransomware]: dragnet-ransomware-2025-4984 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 0d02bd57-41ac-5a78-b5e6-c4b2778061ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
