// Dragnet [Ransomware]: dragnet-ransomware-2025-1064 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 134697a2-7b9a-55a9-80cd-400e5bfebb52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
