// Dragnet [Ransomware]: dragnet-ransomware-2025-7638 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 0d0dc993-d137-5469-87f7-09620229a4f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
