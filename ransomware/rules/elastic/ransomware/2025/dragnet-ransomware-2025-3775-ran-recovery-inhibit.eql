// Dragnet [Ransomware]: dragnet-ransomware-2025-3775 — Recovery Inhibition (radar)
// Status: deprecated | Level: high | ID: af4a8dd2-a142-5abe-ab22-8ca13e774fc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
