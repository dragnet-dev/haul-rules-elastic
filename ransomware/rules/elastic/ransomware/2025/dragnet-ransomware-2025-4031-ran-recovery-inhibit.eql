// Dragnet [Ransomware]: dragnet-ransomware-2025-4031 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: b5678322-971b-5e31-afa8-6181205f26ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
