// Dragnet [Ransomware]: dragnet-ransomware-2025-5595 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: e18b7fef-1920-5e47-bfe4-f9dc46872bf3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
