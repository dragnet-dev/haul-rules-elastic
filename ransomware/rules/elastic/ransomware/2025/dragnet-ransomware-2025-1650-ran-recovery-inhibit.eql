// Dragnet [Ransomware]: dragnet-ransomware-2025-1650 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: a9855dcf-df84-50fa-aa42-499ea78c8c5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
