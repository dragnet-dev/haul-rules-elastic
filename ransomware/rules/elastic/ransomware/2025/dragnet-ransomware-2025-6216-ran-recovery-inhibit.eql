// Dragnet [Ransomware]: dragnet-ransomware-2025-6216 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 77b4d7c0-8044-5035-b550-8c72c146cbdc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
