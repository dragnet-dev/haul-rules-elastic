// Dragnet [Ransomware]: dragnet-ransomware-2025-3364 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 55f38279-a38a-5d14-a883-b3af39503611

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
