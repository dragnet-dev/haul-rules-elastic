// Dragnet [Ransomware]: dragnet-ransomware-2025-6512 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 6ff906ef-fef1-50f3-905e-81feb9319866

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
