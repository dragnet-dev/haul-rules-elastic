// Dragnet [Ransomware]: dragnet-ransomware-2025-2954 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: e48f827d-48dc-5784-b5de-f4461993c609

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
