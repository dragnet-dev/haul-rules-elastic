// Dragnet [Ransomware]: dragnet-ransomware-2025-5665 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: be3e07af-0d28-5c76-a4b0-15d5ea22226b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
