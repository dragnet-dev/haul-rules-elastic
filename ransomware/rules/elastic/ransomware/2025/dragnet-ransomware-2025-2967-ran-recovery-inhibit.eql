// Dragnet [Ransomware]: dragnet-ransomware-2025-2967 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: c891ac72-aa5b-50ee-a70c-fd4e4980fe78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
