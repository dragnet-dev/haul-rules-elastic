// Dragnet [Ransomware]: dragnet-ransomware-2025-5681 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ec69f26a-2894-54b0-b5a2-2ae85c172156

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
