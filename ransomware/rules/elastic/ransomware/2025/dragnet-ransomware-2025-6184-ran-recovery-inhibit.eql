// Dragnet [Ransomware]: dragnet-ransomware-2025-6184 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 21faf443-8d63-55a8-8334-9722f9d4a67d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
