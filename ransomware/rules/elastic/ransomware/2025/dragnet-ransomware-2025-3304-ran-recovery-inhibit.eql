// Dragnet [Ransomware]: dragnet-ransomware-2025-3304 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 7d8f840f-fd4a-5eee-92e5-f4dfa97f4bc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
