// Dragnet [Ransomware]: dragnet-ransomware-2025-4295 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: c7287c94-a0c9-54ec-8a7b-32fda9fcf9a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
