// Dragnet [Ransomware]: dragnet-ransomware-2025-5587 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 34b43332-6c43-5fb2-83b7-1ae5d3bbbe64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
