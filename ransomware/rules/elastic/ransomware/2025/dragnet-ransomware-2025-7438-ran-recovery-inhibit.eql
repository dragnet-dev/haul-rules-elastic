// Dragnet [Ransomware]: dragnet-ransomware-2025-7438 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 391e1248-30fe-5334-b60d-14544a03a5d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
