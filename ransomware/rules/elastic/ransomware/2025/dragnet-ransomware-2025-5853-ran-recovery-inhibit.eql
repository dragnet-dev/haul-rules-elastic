// Dragnet [Ransomware]: dragnet-ransomware-2025-5853 — Recovery Inhibition (gunra)
// Status: experimental | Level: high | ID: b9605b79-b925-5916-a9d0-ccfa3ce768f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
