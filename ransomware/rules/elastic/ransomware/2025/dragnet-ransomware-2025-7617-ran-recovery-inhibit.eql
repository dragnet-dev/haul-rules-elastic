// Dragnet [Ransomware]: dragnet-ransomware-2025-7617 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 8dfdb63c-e53c-55f5-8e7c-ea424468af3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
