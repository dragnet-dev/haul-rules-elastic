// Dragnet [Ransomware]: dragnet-ransomware-2025-6032 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: c0e3230d-3a37-51c5-bbe1-f9ca09a06761

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
