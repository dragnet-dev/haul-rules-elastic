// Dragnet [Ransomware]: dragnet-ransomware-2025-2752 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 2b393b9e-f883-5fa5-ba3b-d9d24ad75aca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
