// Dragnet [Ransomware]: dragnet-ransomware-2025-6816 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: a63e56af-9ef4-57c6-8117-b49964a85256

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
