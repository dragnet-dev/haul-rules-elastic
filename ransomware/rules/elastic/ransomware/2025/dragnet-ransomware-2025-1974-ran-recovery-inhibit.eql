// Dragnet [Ransomware]: dragnet-ransomware-2025-1974 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 2efb2fda-ee4a-5971-aec2-1ac4aa5e9b01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
