// Dragnet [Ransomware]: dragnet-ransomware-2025-5918 — Recovery Inhibition (tridentlocker)
// Status: experimental | Level: high | ID: 9cbfe624-1e35-52f7-b9af-6782f0825598

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
