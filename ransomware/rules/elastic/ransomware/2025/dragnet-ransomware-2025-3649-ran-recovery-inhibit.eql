// Dragnet [Ransomware]: dragnet-ransomware-2025-3649 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: dadede99-fb85-5436-ab8d-b1332e271949

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
