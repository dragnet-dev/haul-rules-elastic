// Dragnet [Ransomware]: dragnet-ransomware-2025-1022 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: c5197855-3df6-557c-a825-8b9d781ff7cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
