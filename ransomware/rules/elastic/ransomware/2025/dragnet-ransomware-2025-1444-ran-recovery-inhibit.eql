// Dragnet [Ransomware]: dragnet-ransomware-2025-1444 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 45d09ac9-48a7-590d-80b4-e0db8618be20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
