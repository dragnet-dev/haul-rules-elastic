// Dragnet [Ransomware]: dragnet-ransomware-2025-0447 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 38c6867b-7751-593b-9ed8-b218d16ced1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
