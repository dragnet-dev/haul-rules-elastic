// Dragnet [Ransomware]: dragnet-ransomware-2025-0049 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 0374d22b-2d69-5dde-8d1e-169c8759c376

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
