// Dragnet [Ransomware]: dragnet-ransomware-2025-0732 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2b80a875-dea0-5158-b825-3802da3bd567

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
