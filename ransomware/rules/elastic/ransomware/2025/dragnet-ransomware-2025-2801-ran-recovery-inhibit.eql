// Dragnet [Ransomware]: dragnet-ransomware-2025-2801 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: ba72b4cb-ab10-5e97-9645-c6d88dc46d28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
