// Dragnet [Ransomware]: dragnet-ransomware-2025-7217 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 779e3df9-ccf7-58e6-81ce-360d26995b59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
