// Dragnet [Ransomware]: dragnet-ransomware-2025-7224 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: cc62b0b4-8a31-59ff-a598-59972fbdcefa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
