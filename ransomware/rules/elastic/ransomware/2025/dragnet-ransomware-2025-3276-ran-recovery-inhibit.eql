// Dragnet [Ransomware]: dragnet-ransomware-2025-3276 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b426756d-f247-5d1b-a14d-0424957ca523

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
