// Dragnet [Ransomware]: dragnet-ransomware-2025-3186 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: dcbca9c6-3ad4-5251-a714-74587d61aaf9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
