// Dragnet [Ransomware]: dragnet-ransomware-2025-0868 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 47df8c3c-1db3-5a51-b0e2-412a8c54f75e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
