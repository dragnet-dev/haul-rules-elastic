// Dragnet [Ransomware]: dragnet-ransomware-2025-6842 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: dad70b77-fb3c-51bc-bfae-a21125fdd1e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
