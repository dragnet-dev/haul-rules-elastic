// Dragnet [Ransomware]: dragnet-ransomware-2025-0265 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: d38bc7aa-1d30-598c-8a35-343b44692fb3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
