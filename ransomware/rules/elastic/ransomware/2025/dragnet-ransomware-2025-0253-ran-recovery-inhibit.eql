// Dragnet [Ransomware]: dragnet-ransomware-2025-0253 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: cddfe31c-01a7-5d53-83b2-887377f23ae2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
