// Dragnet [Ransomware]: dragnet-ransomware-2025-3858 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: bd7bc08f-e9d0-5cb0-9ff9-25b6e11414c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
