// Dragnet [Ransomware]: dragnet-ransomware-2025-1863 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: d596b024-1bc1-5ee2-b42e-48ba57f05adc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
