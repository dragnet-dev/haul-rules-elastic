// Dragnet [Ransomware]: dragnet-ransomware-2025-2873 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 6f2aabca-02d9-5a2a-899f-f8cad40576df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
