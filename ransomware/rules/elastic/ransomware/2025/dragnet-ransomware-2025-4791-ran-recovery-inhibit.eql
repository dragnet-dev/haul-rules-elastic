// Dragnet [Ransomware]: dragnet-ransomware-2025-4791 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 263d7baa-3ba5-5fee-a2ed-457ea6515c3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
