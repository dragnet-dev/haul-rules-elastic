// Dragnet [Ransomware]: dragnet-ransomware-2025-2722 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: ff3e91b2-cb57-58d5-9b37-211a18e35a03

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
