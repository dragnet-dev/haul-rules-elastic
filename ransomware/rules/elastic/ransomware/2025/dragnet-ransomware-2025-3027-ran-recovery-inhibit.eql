// Dragnet [Ransomware]: dragnet-ransomware-2025-3027 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: c77eb3a6-ea80-5800-aa65-fdd1c1a2ac7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
