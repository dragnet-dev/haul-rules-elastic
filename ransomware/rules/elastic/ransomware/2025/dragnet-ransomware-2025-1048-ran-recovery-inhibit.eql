// Dragnet [Ransomware]: dragnet-ransomware-2025-1048 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 4f199f4f-1278-5838-b10e-f084715969dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
