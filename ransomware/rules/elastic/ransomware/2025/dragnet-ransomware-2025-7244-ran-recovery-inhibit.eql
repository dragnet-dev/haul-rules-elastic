// Dragnet [Ransomware]: dragnet-ransomware-2025-7244 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 084a31e5-e7f9-54a4-9a41-e27ae6038146

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
