// Dragnet [Ransomware]: dragnet-ransomware-2025-5285 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 63bc9172-90c2-5bc7-b090-b031b43154ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
