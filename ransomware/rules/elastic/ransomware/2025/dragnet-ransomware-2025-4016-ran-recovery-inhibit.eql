// Dragnet [Ransomware]: dragnet-ransomware-2025-4016 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 46a09980-02ef-591c-9627-9a44b3345950

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
