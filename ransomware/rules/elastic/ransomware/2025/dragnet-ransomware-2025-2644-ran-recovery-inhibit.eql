// Dragnet [Ransomware]: dragnet-ransomware-2025-2644 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 03aec83a-288c-5ccc-a4ec-1cb29692abed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
