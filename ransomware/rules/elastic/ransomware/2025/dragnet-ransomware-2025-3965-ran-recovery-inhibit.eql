// Dragnet [Ransomware]: dragnet-ransomware-2025-3965 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: e9adaa1a-9ea0-55d2-b350-3a325da4972a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
