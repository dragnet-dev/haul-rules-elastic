// Dragnet [Ransomware]: dragnet-ransomware-2025-0799 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 60064ccc-ef7e-51ce-9103-a9810b21d662

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
