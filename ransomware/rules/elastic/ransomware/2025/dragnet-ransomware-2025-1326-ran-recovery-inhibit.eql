// Dragnet [Ransomware]: dragnet-ransomware-2025-1326 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f83c022a-f99c-5ef5-b1f8-d407ee0c523d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
