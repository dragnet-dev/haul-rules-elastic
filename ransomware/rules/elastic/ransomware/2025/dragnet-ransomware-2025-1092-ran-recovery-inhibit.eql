// Dragnet [Ransomware]: dragnet-ransomware-2025-1092 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 6e441291-3500-5dfb-b58b-2525c54056f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
