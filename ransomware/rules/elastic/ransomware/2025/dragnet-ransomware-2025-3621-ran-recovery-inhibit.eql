// Dragnet [Ransomware]: dragnet-ransomware-2025-3621 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e3fafd3d-ca68-537b-845f-90ad63d7aee3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
