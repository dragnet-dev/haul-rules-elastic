// Dragnet [Ransomware]: dragnet-ransomware-2025-4331 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 0cb54edf-820f-5dff-998e-b933107f1115

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
