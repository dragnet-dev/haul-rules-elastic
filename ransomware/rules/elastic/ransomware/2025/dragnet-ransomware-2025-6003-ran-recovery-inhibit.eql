// Dragnet [Ransomware]: dragnet-ransomware-2025-6003 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 91be42f2-c6d9-5dc7-82db-8381efdaa9d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
