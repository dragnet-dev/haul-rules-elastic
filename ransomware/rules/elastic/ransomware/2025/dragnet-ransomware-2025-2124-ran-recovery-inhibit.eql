// Dragnet [Ransomware]: dragnet-ransomware-2025-2124 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 8d0dccfe-a530-5ed0-92d6-987083d61823

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
