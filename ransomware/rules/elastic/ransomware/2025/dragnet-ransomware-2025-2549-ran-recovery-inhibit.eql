// Dragnet [Ransomware]: dragnet-ransomware-2025-2549 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: e68e8991-3f80-5f2d-a137-4e7c9fa99fb2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
