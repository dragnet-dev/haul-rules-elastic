// Dragnet [Ransomware]: dragnet-ransomware-2025-0276 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 044943a7-a7f8-58c0-9aa2-b8ef954a2f1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
