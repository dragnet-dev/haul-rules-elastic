// Dragnet [Ransomware]: dragnet-ransomware-2025-4939 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9caee03a-90ff-55f4-95e4-b31b65b38a6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
