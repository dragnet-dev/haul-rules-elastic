// Dragnet [Ransomware]: dragnet-ransomware-2025-6250 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: a38b480a-1921-577c-8961-a0ce77c26270

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
