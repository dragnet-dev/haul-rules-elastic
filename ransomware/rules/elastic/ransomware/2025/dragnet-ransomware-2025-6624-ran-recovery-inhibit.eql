// Dragnet [Ransomware]: dragnet-ransomware-2025-6624 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 1eb0420e-739a-50bc-b994-24330feb76d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
