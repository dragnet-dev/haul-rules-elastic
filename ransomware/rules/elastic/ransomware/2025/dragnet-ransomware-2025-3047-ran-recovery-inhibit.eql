// Dragnet [Ransomware]: dragnet-ransomware-2025-3047 — Recovery Inhibition (minteye)
// Status: deprecated | Level: high | ID: bb7ea24b-760d-5466-8535-d23bf5bc2134

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
