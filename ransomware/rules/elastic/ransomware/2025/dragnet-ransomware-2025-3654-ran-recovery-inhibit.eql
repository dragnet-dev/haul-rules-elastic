// Dragnet [Ransomware]: dragnet-ransomware-2025-3654 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8c094040-9fd2-5140-ab5e-b58e8aa30b47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
