// Dragnet [Ransomware]: dragnet-ransomware-2025-4425 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e446c0c9-b061-53ca-945c-3fa36b23e1b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
