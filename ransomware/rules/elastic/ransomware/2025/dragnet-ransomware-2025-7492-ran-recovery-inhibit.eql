// Dragnet [Ransomware]: dragnet-ransomware-2025-7492 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 598e8667-0edc-540e-8bf0-96bc5aa239ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
