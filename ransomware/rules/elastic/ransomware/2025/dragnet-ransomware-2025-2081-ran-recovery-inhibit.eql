// Dragnet [Ransomware]: dragnet-ransomware-2025-2081 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 485a779b-5b31-5aa7-8e5d-5abf15dd13ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
