// Dragnet [Ransomware]: dragnet-ransomware-2025-5499 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: a0d5a702-0fa6-51f3-83d5-c36fad454670

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
