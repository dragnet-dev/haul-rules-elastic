// Dragnet [Ransomware]: dragnet-ransomware-2025-3612 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 9e6aac37-82a0-524c-9c1f-9dcb6cf440db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
