// Dragnet [Ransomware]: dragnet-ransomware-2025-3717 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: eb7649d6-422d-5f1a-9d29-0c16f7ae9aaa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
