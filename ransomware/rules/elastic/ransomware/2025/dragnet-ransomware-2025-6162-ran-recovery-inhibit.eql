// Dragnet [Ransomware]: dragnet-ransomware-2025-6162 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: e77130c8-799e-5f1d-9669-95815163d90a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
