// Dragnet [Ransomware]: dragnet-ransomware-2025-1990 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 676b914c-677d-55dc-9f33-07fb129039bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
