// Dragnet [Ransomware]: dragnet-ransomware-2025-6670 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: 0055b9da-60a3-51fe-8501-cf3588e6921c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
