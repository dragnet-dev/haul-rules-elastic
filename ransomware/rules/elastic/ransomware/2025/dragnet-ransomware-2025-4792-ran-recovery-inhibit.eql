// Dragnet [Ransomware]: dragnet-ransomware-2025-4792 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 7eef2b22-7e76-5f38-bf9b-00df0c2eb0e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
