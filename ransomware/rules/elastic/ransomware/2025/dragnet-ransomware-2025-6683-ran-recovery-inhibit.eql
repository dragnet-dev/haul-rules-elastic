// Dragnet [Ransomware]: dragnet-ransomware-2025-6683 — Recovery Inhibition (obscura)
// Status: deprecated | Level: high | ID: baa63cdd-e0be-5cd5-b996-a5a278dec9fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
