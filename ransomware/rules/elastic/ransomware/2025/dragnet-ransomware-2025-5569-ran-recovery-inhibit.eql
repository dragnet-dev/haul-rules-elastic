// Dragnet [Ransomware]: dragnet-ransomware-2025-5569 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 135267c8-26c8-54b5-90fe-d95d80e4cb25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
