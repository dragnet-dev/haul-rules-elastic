// Dragnet [Ransomware]: dragnet-ransomware-2025-2863 — Recovery Inhibition (GDLockerSec)
// Status: experimental | Level: high | ID: a9d47f13-6193-55fc-87bd-51bbeec9b6e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
