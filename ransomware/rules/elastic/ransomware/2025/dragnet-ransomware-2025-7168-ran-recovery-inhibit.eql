// Dragnet [Ransomware]: dragnet-ransomware-2025-7168 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 8499fe9b-ec9b-5e3e-b028-2a5de8a4dce7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
