// Dragnet [Ransomware]: dragnet-ransomware-2025-0269 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f981f7c4-1c8a-54f4-86f0-4e8a8c5e97f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
