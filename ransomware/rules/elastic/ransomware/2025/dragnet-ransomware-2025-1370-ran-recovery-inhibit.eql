// Dragnet [Ransomware]: dragnet-ransomware-2025-1370 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: bce85951-faaa-5f21-9b4d-312062d5cacb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
