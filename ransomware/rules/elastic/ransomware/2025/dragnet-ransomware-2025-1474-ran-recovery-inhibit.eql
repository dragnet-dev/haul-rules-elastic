// Dragnet [Ransomware]: dragnet-ransomware-2025-1474 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6578291e-c2e4-5ac1-95a6-f36349beba6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
