// Dragnet [Ransomware]: dragnet-ransomware-2025-2729 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c6df17fd-4180-5096-bb28-2e5dbb403481

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
