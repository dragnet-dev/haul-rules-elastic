// Dragnet [Ransomware]: dragnet-ransomware-2025-7753 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: c89c7507-b743-5490-a1aa-52cb003eed41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
