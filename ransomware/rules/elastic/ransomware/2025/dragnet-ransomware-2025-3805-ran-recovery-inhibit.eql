// Dragnet [Ransomware]: dragnet-ransomware-2025-3805 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a6fbd00f-638d-509f-b418-160a6de84237

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
