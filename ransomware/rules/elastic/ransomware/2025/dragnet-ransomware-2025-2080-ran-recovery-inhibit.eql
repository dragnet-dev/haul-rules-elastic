// Dragnet [Ransomware]: dragnet-ransomware-2025-2080 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 8783a47d-e57d-5cc7-a5d4-3bfd4f37e3b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
