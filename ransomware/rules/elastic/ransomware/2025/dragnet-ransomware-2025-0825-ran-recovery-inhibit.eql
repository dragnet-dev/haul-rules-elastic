// Dragnet [Ransomware]: dragnet-ransomware-2025-0825 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: dd0323c4-6d6b-57d4-82ac-2dcb872412d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
