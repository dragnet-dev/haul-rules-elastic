// Dragnet [Ransomware]: dragnet-ransomware-2025-6966 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: b9dce1a6-bc34-55fd-9095-450b1d0929fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
