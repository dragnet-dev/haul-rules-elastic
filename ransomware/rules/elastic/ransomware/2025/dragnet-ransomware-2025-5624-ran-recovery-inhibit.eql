// Dragnet [Ransomware]: dragnet-ransomware-2025-5624 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 82f7216d-83b8-5417-a637-1af357e9fc9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
