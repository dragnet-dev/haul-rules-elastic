// Dragnet [Ransomware]: dragnet-ransomware-2025-5027 — Recovery Inhibition (gunra)
// Status: experimental | Level: high | ID: 67b6d29e-69a8-5d65-bdda-a0de086afe45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
