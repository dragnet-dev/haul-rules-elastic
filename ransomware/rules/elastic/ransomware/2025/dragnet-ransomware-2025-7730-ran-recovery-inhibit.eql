// Dragnet [Ransomware]: dragnet-ransomware-2025-7730 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: b351a56d-7064-5bf7-8d8c-e15940f09898

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
