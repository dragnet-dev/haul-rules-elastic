// Dragnet [Ransomware]: dragnet-ransomware-2025-6190 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: dc2fe0fd-20f8-5503-8b7b-3bddc173ca17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
