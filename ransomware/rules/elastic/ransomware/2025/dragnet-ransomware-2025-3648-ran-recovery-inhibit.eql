// Dragnet [Ransomware]: dragnet-ransomware-2025-3648 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: e7391966-49c9-5c31-b17b-643ab5d8e346

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
