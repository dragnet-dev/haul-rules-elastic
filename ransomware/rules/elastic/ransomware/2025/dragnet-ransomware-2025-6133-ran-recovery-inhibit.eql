// Dragnet [Ransomware]: dragnet-ransomware-2025-6133 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9a371aa1-2258-5b91-bbe0-0d60ff8cf83b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
