// Dragnet [Ransomware]: dragnet-ransomware-2025-5927 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 8557c612-5bd7-558a-8dde-4304d1479dc6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
