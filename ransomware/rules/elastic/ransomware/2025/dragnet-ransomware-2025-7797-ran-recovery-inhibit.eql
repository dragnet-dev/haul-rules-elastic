// Dragnet [Ransomware]: dragnet-ransomware-2025-7797 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 0a13c9e3-e427-5119-847b-d69e66b9c92f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
