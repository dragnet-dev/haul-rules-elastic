// Dragnet [Ransomware]: dragnet-ransomware-2025-1311 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: cc5c4152-1ded-5488-bba1-489460264041

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
