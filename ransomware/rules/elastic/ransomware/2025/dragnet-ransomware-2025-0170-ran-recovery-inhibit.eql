// Dragnet [Ransomware]: dragnet-ransomware-2025-0170 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 7770d508-e71c-54f5-89d3-7c682279d6f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
