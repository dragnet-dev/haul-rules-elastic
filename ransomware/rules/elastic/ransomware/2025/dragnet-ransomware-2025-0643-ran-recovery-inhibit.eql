// Dragnet [Ransomware]: dragnet-ransomware-2025-0643 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 543c3941-835c-5d58-a702-9c070664836f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
