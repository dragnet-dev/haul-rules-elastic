// Dragnet [Ransomware]: dragnet-ransomware-2025-7081 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 86841c72-47ad-5064-ae34-41458521ea18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
