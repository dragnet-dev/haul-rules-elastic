// Dragnet [Ransomware]: dragnet-ransomware-2025-6333 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cef0ee44-07ea-54c1-8144-7aa36571457e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
