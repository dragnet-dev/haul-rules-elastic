// Dragnet [Ransomware]: dragnet-ransomware-2025-2364 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e11749a6-25de-555f-8a7a-ee1ed862d802

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
