// Dragnet [Ransomware]: dragnet-ransomware-2025-5574 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 7a9bdc06-72e2-5549-a5e1-f9db948a7a78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
