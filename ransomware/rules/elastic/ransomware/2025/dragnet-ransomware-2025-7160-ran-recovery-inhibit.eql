// Dragnet [Ransomware]: dragnet-ransomware-2025-7160 — Recovery Inhibition (blackshrantac)
// Status: test | Level: high | ID: fa363698-b78c-5ff7-a553-c4d83856a9fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
