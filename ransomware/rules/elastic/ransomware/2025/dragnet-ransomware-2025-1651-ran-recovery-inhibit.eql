// Dragnet [Ransomware]: dragnet-ransomware-2025-1651 — Recovery Inhibition (IMNCrew)
// Status: experimental | Level: high | ID: 16846e7f-3dee-5f97-8a87-cb66129aa95b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
