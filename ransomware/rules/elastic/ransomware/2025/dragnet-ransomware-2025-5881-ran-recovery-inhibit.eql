// Dragnet [Ransomware]: dragnet-ransomware-2025-5881 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: c92ce550-138d-56d5-9778-870fdb6ea438

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
