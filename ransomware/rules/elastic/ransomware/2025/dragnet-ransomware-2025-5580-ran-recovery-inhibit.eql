// Dragnet [Ransomware]: dragnet-ransomware-2025-5580 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 8840fe57-d51f-592d-ab46-d1ea1ebb94aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
