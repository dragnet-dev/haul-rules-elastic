// Dragnet [Ransomware]: dragnet-ransomware-2025-3800 — Recovery Inhibition (blackshrantac)
// Status: experimental | Level: high | ID: fa58b5ef-75a7-5bf2-8ed3-3786b5e4ffb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
