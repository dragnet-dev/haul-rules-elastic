// Dragnet [Ransomware]: dragnet-ransomware-2025-7209 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 46ffd2f5-6067-58cb-bd55-4f6eac42a802

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
