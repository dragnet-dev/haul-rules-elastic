// Dragnet [Ransomware]: dragnet-ransomware-2025-0513 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 5a158ba4-d630-54c9-bed1-e374ca7405f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
