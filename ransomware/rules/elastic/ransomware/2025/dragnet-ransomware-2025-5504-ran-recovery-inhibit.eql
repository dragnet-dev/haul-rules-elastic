// Dragnet [Ransomware]: dragnet-ransomware-2025-5504 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: a7da6370-b038-51c0-8391-aa49c5e7b4f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
