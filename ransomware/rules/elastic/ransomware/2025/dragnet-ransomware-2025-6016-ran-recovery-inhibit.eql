// Dragnet [Ransomware]: dragnet-ransomware-2025-6016 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a569378f-2a24-569d-8e09-234ede7959db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
