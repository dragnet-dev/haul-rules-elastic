// Dragnet [Ransomware]: dragnet-ransomware-2025-4657 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 199cd104-dc63-558b-88eb-bfe09058e110

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
