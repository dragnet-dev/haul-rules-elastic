// Dragnet [Ransomware]: dragnet-ransomware-2025-5789 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 760d2aaa-43ec-51e8-a70b-1734b44cf1ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
