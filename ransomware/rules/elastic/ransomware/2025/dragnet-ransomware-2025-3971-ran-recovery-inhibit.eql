// Dragnet [Ransomware]: dragnet-ransomware-2025-3971 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 48132b10-e59c-5845-936e-c803e92802d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
