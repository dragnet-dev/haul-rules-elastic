// Dragnet [Ransomware]: dragnet-ransomware-2025-4643 — Recovery Inhibition (global)
// Status: experimental | Level: high | ID: 35ef5abd-2849-5aa4-9583-c88acd2a4d06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
