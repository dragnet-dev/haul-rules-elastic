// Dragnet [Ransomware]: dragnet-ransomware-2025-2101 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 6e0b4f10-fb19-51b9-afee-45ac3857a85a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
