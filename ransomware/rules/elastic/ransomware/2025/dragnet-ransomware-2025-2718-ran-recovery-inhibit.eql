// Dragnet [Ransomware]: dragnet-ransomware-2025-2718 — Recovery Inhibition (walocker)
// Status: experimental | Level: high | ID: 6916ed81-ec5f-52f2-b552-7eae4b6a8c01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
