// Dragnet [Ransomware]: dragnet-ransomware-2025-2815 — Recovery Inhibition (warlock)
// Status: experimental | Level: high | ID: 3c2ce7a3-121b-57d8-ba8f-6aa64c406960

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
