// Dragnet [Ransomware]: dragnet-ransomware-2025-5455 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8b32a513-9c9f-552d-88b7-06bd7220be71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
