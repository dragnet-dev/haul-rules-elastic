// Dragnet [Ransomware]: dragnet-ransomware-2025-4759 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ac86f2fc-fea3-5346-9a4f-2518a52484f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
