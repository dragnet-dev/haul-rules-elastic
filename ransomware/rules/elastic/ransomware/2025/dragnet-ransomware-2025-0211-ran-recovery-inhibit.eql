// Dragnet [Ransomware]: dragnet-ransomware-2025-0211 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c9da4535-829b-55cf-ba6a-0441cba67d7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
