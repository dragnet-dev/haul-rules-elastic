// Dragnet [Ransomware]: dragnet-ransomware-2025-0615 — Recovery Inhibition (frag)
// Status: deprecated | Level: high | ID: 988afa91-dc6a-5c63-9bef-ddb1c0988eb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
