// Dragnet [Ransomware]: dragnet-ransomware-2025-6430 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 257cc81d-12ff-5f32-898a-abf6cd381c3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
