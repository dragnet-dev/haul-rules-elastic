// Dragnet [Ransomware]: dragnet-ransomware-2025-5330 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 4f91999e-f431-5c55-bbfa-042924eb07b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
