// Dragnet [Ransomware]: dragnet-ransomware-2025-7044 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 43732441-045a-5899-9c49-e638ecdb6a8f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
