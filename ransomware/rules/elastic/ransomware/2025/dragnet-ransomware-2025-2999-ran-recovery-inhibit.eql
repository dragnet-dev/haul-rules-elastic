// Dragnet [Ransomware]: dragnet-ransomware-2025-2999 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c6caab43-a831-52f0-b235-e17628292b7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
