// Dragnet [Ransomware]: dragnet-ransomware-2025-4253 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8eff3d62-d762-5e98-b381-1baf7f3cdce2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
