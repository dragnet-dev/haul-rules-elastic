// Dragnet [Ransomware]: dragnet-ransomware-2025-1266 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 68c24df9-d9e9-5622-be82-81156b6263d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
