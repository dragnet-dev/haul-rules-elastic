// Dragnet [Ransomware]: dragnet-ransomware-2025-7553 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3a6c3477-e0e5-5349-88dd-8f546519e41d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
