// Dragnet [Ransomware]: dragnet-ransomware-2025-4542 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 407453a9-cd5d-594e-8343-9b0cc4d1d579

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
