// Dragnet [Ransomware]: dragnet-ransomware-2025-6698 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: e79c8a5a-e36a-52e4-990d-3c29c1c1393f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
