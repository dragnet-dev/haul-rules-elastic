// Dragnet [Ransomware]: dragnet-ransomware-2025-5451 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: a893896e-6bf2-5dd6-af8c-b4d937fc91f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
