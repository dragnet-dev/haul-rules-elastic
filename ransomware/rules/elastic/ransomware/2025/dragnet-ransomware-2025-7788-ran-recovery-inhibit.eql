// Dragnet [Ransomware]: dragnet-ransomware-2025-7788 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: f49c4e50-481f-553b-bc3e-1e7c9f1761b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
