// Dragnet [Ransomware]: dragnet-ransomware-2025-4582 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bdde3e22-cecd-567f-83ff-329f3ef873ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
