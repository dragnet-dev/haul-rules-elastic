// Dragnet [Ransomware]: dragnet-ransomware-2025-4669 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 62edfa4d-0d26-5f9e-b1aa-817bd861bcaf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
