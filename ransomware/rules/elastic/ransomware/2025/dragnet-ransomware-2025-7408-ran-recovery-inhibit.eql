// Dragnet [Ransomware]: dragnet-ransomware-2025-7408 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2f3e4a6c-05a3-5d95-ad1e-a4ca22c7719f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
