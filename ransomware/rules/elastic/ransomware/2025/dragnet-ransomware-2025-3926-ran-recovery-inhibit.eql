// Dragnet [Ransomware]: dragnet-ransomware-2025-3926 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e4aac1fa-fc5b-586a-9b85-111e0e3b26dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
