// Dragnet [Ransomware]: dragnet-ransomware-2025-0931 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 84583383-b6a4-56f4-9bb2-83dbb9fcdd84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
