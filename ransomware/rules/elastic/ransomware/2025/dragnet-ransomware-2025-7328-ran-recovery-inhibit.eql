// Dragnet [Ransomware]: dragnet-ransomware-2025-7328 — Recovery Inhibition (skira)
// Status: experimental | Level: high | ID: 6a6695e2-0fde-55bd-ad36-10c526b4958c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
