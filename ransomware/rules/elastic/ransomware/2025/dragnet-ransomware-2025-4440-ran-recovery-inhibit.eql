// Dragnet [Ransomware]: dragnet-ransomware-2025-4440 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a54e6ecd-495e-5ac2-b53d-f3140ca8fbd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
