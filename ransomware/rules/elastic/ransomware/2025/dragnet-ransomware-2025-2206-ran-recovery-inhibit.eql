// Dragnet [Ransomware]: dragnet-ransomware-2025-2206 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: 3ebca211-bff4-557e-8708-e80a7dc2759c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
