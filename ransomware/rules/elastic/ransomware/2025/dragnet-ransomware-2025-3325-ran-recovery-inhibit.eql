// Dragnet [Ransomware]: dragnet-ransomware-2025-3325 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 359ef816-4ff0-5668-ad18-2384bef379f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
