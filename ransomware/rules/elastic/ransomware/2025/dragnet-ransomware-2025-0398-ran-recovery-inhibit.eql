// Dragnet [Ransomware]: dragnet-ransomware-2025-0398 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 284efc08-cf44-5756-b341-2018869a437c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
