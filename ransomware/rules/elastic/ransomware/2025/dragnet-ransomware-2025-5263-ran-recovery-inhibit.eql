// Dragnet [Ransomware]: dragnet-ransomware-2025-5263 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 263680be-cf56-51ef-9029-dd409e808cf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
