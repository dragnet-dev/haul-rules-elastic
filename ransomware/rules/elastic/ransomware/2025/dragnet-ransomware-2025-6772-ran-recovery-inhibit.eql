// Dragnet [Ransomware]: dragnet-ransomware-2025-6772 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: ef36aa72-c6af-5270-ac89-046f119e1fc1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
