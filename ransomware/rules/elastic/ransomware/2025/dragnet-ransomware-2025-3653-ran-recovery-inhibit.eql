// Dragnet [Ransomware]: dragnet-ransomware-2025-3653 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 86cb728c-bb2a-5b46-adf3-7f87b3514744

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
