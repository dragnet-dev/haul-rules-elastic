// Dragnet [Ransomware]: dragnet-ransomware-2025-5044 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: a6cedbaa-26c5-50c8-8372-89a5857c6a99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
