// Dragnet [Ransomware]: dragnet-ransomware-2025-3768 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 18ae9221-62f4-56fb-8972-2ef23b1efd16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
