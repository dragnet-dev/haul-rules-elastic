// Dragnet [Ransomware]: dragnet-ransomware-2025-6804 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d4e6de06-3201-5098-9f09-dbabfa1ec3e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
