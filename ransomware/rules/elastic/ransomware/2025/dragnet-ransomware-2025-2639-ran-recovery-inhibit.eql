// Dragnet [Ransomware]: dragnet-ransomware-2025-2639 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 802e6ac4-ba60-5696-a6d2-db0729b2bdcb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
