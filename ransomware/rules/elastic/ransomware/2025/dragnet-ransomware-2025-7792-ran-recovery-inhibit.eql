// Dragnet [Ransomware]: dragnet-ransomware-2025-7792 — Recovery Inhibition (blackshrantac)
// Status: test | Level: high | ID: 3301bbf0-b0d3-5fa1-b125-ac4e2dfac102

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
