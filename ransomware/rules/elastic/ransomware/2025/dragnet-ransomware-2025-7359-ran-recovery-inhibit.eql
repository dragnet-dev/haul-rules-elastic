// Dragnet [Ransomware]: dragnet-ransomware-2025-7359 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3fb54da7-7c54-5092-9f04-92b727dcb3da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
