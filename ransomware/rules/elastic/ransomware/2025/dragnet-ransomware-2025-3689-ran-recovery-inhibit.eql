// Dragnet [Ransomware]: dragnet-ransomware-2025-3689 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 0f109d62-b148-5e35-9c82-839a4e56f68e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
