// Dragnet [Ransomware]: dragnet-ransomware-2025-1617 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3ff5d170-9bf2-55e4-a550-c5bd0b1c26fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
