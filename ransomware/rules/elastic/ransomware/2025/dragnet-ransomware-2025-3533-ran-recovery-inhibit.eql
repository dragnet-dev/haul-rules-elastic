// Dragnet [Ransomware]: dragnet-ransomware-2025-3533 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ec929e3f-40cd-5db0-bd4b-7ca813227b5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
