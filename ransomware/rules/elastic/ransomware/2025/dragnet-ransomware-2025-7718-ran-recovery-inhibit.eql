// Dragnet [Ransomware]: dragnet-ransomware-2025-7718 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 69664821-68e6-570f-b8f1-7775bd2359d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
