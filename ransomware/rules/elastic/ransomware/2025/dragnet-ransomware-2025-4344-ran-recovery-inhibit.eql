// Dragnet [Ransomware]: dragnet-ransomware-2025-4344 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 35af4469-4187-511d-ac7a-d884d44c3a68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
