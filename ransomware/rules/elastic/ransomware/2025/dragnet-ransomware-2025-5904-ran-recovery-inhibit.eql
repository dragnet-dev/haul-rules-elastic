// Dragnet [Ransomware]: dragnet-ransomware-2025-5904 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: e69381b0-4a04-5994-b675-53d3e374df95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
