// Dragnet [Ransomware]: dragnet-ransomware-2025-7839 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 4bb67d19-455a-5345-9e22-f8f23dda6667

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
