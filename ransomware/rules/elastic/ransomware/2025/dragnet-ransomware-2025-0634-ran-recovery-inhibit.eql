// Dragnet [Ransomware]: dragnet-ransomware-2025-0634 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9d97873c-6e1b-5d0d-9eca-2f73c0467196

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
