// Dragnet [Ransomware]: dragnet-ransomware-2025-7542 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e5e118ba-a17a-5c02-95b6-89cf6d7f6faf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
