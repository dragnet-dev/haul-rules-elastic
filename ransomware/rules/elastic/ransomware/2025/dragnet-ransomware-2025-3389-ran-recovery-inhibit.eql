// Dragnet [Ransomware]: dragnet-ransomware-2025-3389 — Recovery Inhibition (payoutsking)
// Status: test | Level: high | ID: 5f6df171-4ca7-57b7-a972-f2136b45d4c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
