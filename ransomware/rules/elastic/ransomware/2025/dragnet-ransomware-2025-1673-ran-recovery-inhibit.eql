// Dragnet [Ransomware]: dragnet-ransomware-2025-1673 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: 6e8eca0e-6249-58c7-8dc5-7ee94c455104

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
