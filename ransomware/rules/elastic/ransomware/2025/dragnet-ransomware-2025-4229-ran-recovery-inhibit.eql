// Dragnet [Ransomware]: dragnet-ransomware-2025-4229 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: bb6020ad-bedf-55ad-9f6c-8c920ee52047

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
