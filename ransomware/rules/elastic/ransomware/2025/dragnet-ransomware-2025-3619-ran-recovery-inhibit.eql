// Dragnet [Ransomware]: dragnet-ransomware-2025-3619 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 3c93f429-d1d3-5fe6-8d63-ec6248b8593e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
