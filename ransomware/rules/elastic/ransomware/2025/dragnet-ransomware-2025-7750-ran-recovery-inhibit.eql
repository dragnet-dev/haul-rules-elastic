// Dragnet [Ransomware]: dragnet-ransomware-2025-7750 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 4fa337f2-440f-5fca-909e-351a78b66684

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
