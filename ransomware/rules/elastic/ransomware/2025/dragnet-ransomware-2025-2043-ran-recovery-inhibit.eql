// Dragnet [Ransomware]: dragnet-ransomware-2025-2043 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4fd50cf2-5c59-5b30-a593-b1b3c77bf636

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
