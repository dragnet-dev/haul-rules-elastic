// Dragnet [Ransomware]: dragnet-ransomware-2025-6319 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a725c97a-cfa9-5856-bcd6-9cfd5997e662

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
