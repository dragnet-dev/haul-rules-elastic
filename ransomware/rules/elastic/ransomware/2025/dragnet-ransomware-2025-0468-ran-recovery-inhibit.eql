// Dragnet [Ransomware]: dragnet-ransomware-2025-0468 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 563cc68a-4e3c-5ad9-a92a-2c1cb62f2fe2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
