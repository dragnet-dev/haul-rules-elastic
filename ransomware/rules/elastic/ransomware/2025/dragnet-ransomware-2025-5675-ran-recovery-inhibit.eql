// Dragnet [Ransomware]: dragnet-ransomware-2025-5675 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 98d9c2ed-aa47-59e7-994c-fbfb48f059bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
