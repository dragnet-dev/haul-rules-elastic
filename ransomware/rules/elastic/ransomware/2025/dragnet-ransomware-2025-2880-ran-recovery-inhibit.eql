// Dragnet [Ransomware]: dragnet-ransomware-2025-2880 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: f14043ac-0174-5019-8618-be21ae744ead

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
