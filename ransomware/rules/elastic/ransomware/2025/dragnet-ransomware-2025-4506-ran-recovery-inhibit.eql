// Dragnet [Ransomware]: dragnet-ransomware-2025-4506 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 971a2962-a358-5a93-9570-881f4d2d68db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
