// Dragnet [Ransomware]: dragnet-ransomware-2025-1634 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2feb0e92-b349-5cfd-ae48-3919a7919696

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
