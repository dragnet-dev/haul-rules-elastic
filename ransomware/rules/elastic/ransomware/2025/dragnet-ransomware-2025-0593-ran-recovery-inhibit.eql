// Dragnet [Ransomware]: dragnet-ransomware-2025-0593 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: c576c6a4-a2ab-5c0c-abde-5361c66c8de2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
