// Dragnet [Ransomware]: dragnet-ransomware-2025-7466 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 230a446d-ce11-55d3-9c42-d859cadf69fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
