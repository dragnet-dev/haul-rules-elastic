// Dragnet [Ransomware]: dragnet-ransomware-2025-3883 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: e42e49ef-3cee-5795-b978-aa111a7c5fbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
