// Dragnet [Ransomware]: dragnet-ransomware-2025-3526 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: b109c3ea-ff32-5986-9834-9e14b93044a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
