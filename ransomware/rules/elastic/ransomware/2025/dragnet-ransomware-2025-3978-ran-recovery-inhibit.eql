// Dragnet [Ransomware]: dragnet-ransomware-2025-3978 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 35b3f1c0-0333-5f76-99f4-f07913167a07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
