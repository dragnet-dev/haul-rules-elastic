// Dragnet [Ransomware]: dragnet-ransomware-2025-3880 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: dae23f6b-6df6-5c3e-bda9-4767f969dc85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
