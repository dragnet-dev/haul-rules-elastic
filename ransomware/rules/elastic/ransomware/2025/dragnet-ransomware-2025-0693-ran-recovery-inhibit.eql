// Dragnet [Ransomware]: dragnet-ransomware-2025-0693 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: bb3f9e5e-c221-5205-854e-02277444c807

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
