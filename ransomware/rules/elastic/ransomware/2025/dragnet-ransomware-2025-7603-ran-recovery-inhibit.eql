// Dragnet [Ransomware]: dragnet-ransomware-2025-7603 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: c7f5a088-08ce-5421-ba61-5d926362e94b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
