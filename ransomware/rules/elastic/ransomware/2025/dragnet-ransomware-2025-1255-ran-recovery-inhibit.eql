// Dragnet [Ransomware]: dragnet-ransomware-2025-1255 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 246327a2-2543-5dff-a441-9641c6147282

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
