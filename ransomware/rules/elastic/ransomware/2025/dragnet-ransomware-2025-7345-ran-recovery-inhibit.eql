// Dragnet [Ransomware]: dragnet-ransomware-2025-7345 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 58fa2056-a981-5c0a-bc91-34631f15e513

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
