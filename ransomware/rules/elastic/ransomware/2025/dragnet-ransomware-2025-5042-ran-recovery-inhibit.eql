// Dragnet [Ransomware]: dragnet-ransomware-2025-5042 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: bdf5c370-9795-55f2-981c-480909c4c101

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
