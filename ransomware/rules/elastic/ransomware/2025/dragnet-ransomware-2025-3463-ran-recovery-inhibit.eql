// Dragnet [Ransomware]: dragnet-ransomware-2025-3463 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 635058d8-db15-5a9d-afe0-f082be0c4209

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
