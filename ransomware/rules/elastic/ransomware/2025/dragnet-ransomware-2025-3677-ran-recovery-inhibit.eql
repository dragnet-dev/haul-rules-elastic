// Dragnet [Ransomware]: dragnet-ransomware-2025-3677 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 4e0c3163-63be-5784-956a-e8f0b6b760d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
