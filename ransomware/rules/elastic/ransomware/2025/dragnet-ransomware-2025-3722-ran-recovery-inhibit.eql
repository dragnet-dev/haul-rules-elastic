// Dragnet [Ransomware]: dragnet-ransomware-2025-3722 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: ac505381-cbe4-582a-aeac-4899498fb864

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
