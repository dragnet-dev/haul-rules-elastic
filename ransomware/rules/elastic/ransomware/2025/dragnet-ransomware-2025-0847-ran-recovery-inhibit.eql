// Dragnet [Ransomware]: dragnet-ransomware-2025-0847 — Recovery Inhibition (underground)
// Status: experimental | Level: high | ID: 1fa4d9c7-ba55-5832-910a-c0e9e443f9a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
