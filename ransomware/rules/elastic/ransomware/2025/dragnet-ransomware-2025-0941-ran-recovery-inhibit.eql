// Dragnet [Ransomware]: dragnet-ransomware-2025-0941 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: c28c1726-d293-595c-9452-0075918172ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
