// Dragnet [Ransomware]: dragnet-ransomware-2025-0219 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 05190c5b-115a-52a2-a52f-de1cbb2ee0f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
