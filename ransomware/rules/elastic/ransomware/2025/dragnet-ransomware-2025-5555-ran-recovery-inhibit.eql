// Dragnet [Ransomware]: dragnet-ransomware-2025-5555 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d98a92fa-b933-5119-8666-61e030393aa7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
