// Dragnet [Ransomware]: dragnet-ransomware-2025-5352 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a02930d9-ad21-5010-9820-89ad349c2f95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
