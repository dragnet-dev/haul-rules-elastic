// Dragnet [Ransomware]: dragnet-ransomware-2025-6314 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 5daef6f2-660d-5130-9c40-b4299e164383

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
