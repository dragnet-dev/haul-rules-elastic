// Dragnet [Ransomware]: dragnet-ransomware-2025-3221 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: b8c6fb49-949d-5ede-b829-9775de0f4e3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
