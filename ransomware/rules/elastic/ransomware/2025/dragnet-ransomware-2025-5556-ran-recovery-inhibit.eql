// Dragnet [Ransomware]: dragnet-ransomware-2025-5556 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: 9a165058-c75b-573b-9fb6-ad3920c79e43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
