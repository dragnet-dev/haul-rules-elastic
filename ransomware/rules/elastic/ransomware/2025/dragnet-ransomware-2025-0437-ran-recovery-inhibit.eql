// Dragnet [Ransomware]: dragnet-ransomware-2025-0437 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 60d0ff44-6cd0-5f26-9852-9526371463fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
