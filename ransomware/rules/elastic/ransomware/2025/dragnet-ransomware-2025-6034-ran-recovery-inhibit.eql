// Dragnet [Ransomware]: dragnet-ransomware-2025-6034 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 170945c0-960f-519f-8a19-2170adde87ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
