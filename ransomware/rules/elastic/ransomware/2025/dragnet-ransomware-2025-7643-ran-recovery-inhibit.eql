// Dragnet [Ransomware]: dragnet-ransomware-2025-7643 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1d18bfee-b02a-5474-8938-daebbc79273f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
