// Dragnet [Ransomware]: dragnet-ransomware-2025-3791 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: dab9ae3b-49fc-510b-8184-d23748b24099

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
