// Dragnet [Ransomware]: dragnet-ransomware-2025-3174 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: edff77e6-0cfb-591a-8b6e-f14a6b8ea92f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
