// Dragnet [Ransomware]: dragnet-ransomware-2025-2966 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 735fd23b-8d7c-5e89-9e18-f77321f245e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
