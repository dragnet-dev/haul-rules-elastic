// Dragnet [Ransomware]: dragnet-ransomware-2025-0771 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 95826748-8f33-5ab2-a3e5-33b08ee9d088

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
