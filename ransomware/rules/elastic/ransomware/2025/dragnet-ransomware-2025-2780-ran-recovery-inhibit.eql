// Dragnet [Ransomware]: dragnet-ransomware-2025-2780 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: e980c606-fa87-5d6f-a6bf-5883da269595

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
