// Dragnet [Ransomware]: dragnet-ransomware-2025-5658 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: ce258baa-64a5-57b3-9450-9f359aa4646b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
