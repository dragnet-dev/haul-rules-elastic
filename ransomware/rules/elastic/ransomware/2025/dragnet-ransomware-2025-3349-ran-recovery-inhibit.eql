// Dragnet [Ransomware]: dragnet-ransomware-2025-3349 — Recovery Inhibition (rebornvc)
// Status: deprecated | Level: high | ID: b7a95ef6-66f7-5ef7-9b5d-c849152be550

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
