// Dragnet [Ransomware]: dragnet-ransomware-2025-3613 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 5a746d70-7d80-599b-8177-52b1660b4733

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
