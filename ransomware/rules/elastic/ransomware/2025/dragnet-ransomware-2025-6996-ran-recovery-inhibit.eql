// Dragnet [Ransomware]: dragnet-ransomware-2025-6996 — Recovery Inhibition (fog)
// Status: deprecated | Level: high | ID: 042b7a89-c746-56e0-b653-273d95d0edfb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
