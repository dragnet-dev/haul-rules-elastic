// Dragnet [Ransomware]: dragnet-ransomware-2025-6753 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: babe8caa-4243-52ad-9501-a1ac40869b7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
