// Dragnet [Ransomware]: dragnet-ransomware-2025-3425 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 68ecc94e-4dc8-5a08-84b3-8b47c829847c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
