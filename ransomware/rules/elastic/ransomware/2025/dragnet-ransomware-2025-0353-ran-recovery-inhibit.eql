// Dragnet [Ransomware]: dragnet-ransomware-2025-0353 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 9687e778-de60-5a7d-aec2-ad710dcd955e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
