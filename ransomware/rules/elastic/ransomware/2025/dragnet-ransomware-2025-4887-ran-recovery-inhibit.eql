// Dragnet [Ransomware]: dragnet-ransomware-2025-4887 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 53868d54-3048-517c-9fa3-6d4ae154fc7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
