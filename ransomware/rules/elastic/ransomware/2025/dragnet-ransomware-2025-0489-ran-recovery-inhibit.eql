// Dragnet [Ransomware]: dragnet-ransomware-2025-0489 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 27844e29-0841-5bd4-b5df-f0ceb017277c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
