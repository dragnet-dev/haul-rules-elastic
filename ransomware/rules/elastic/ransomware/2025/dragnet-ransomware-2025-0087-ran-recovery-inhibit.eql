// Dragnet [Ransomware]: dragnet-ransomware-2025-0087 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: a2da298c-5d89-5859-8e20-ce1d80ea738d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
