// Dragnet [Ransomware]: dragnet-ransomware-2025-7869 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 1781e7d0-33fd-53d6-b247-4d4ad8c0d6b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
