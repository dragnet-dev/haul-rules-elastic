// Dragnet [Ransomware]: dragnet-ransomware-2025-4355 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: a36cb7b2-4d6a-5b42-b948-f510c4d54514

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
