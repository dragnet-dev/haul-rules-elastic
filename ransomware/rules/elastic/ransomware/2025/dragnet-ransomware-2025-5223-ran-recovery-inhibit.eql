// Dragnet [Ransomware]: dragnet-ransomware-2025-5223 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8f5ede1b-964a-52c3-a810-7eb9d11bbcef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
