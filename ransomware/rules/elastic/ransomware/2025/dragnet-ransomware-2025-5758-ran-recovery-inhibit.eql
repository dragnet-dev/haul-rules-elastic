// Dragnet [Ransomware]: dragnet-ransomware-2025-5758 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 3889bb82-5fb0-5819-9eda-da38629d5fb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
