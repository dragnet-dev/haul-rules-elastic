// Dragnet [Ransomware]: dragnet-ransomware-2025-3478 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: cdbe206e-5a82-5c04-8895-114ce5b61184

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
