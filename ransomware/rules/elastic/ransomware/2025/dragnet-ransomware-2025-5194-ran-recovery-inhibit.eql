// Dragnet [Ransomware]: dragnet-ransomware-2025-5194 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9fdd0f96-dcbf-57d9-aeea-d3d5cf6d46b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
