// Dragnet [Ransomware]: dragnet-ransomware-2025-6499 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: dd98452b-63e6-5745-b940-24f18e95387a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
