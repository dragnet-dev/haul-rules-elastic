// Dragnet [Ransomware]: dragnet-ransomware-2025-3269 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 3ff71fb3-8af8-5d6e-bb67-853e79e4c772

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
