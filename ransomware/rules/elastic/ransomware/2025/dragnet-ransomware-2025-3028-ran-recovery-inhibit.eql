// Dragnet [Ransomware]: dragnet-ransomware-2025-3028 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c3be27a1-2283-59dd-b7a8-3d363584b00d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
