// Dragnet [Ransomware]: dragnet-ransomware-2025-7725 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: dd6539a0-4203-5464-b744-354a05ee4e67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
