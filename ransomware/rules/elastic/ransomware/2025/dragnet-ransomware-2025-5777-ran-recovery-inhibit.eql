// Dragnet [Ransomware]: dragnet-ransomware-2025-5777 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 7633e96f-a510-5ad0-b8f5-8092394f98a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
