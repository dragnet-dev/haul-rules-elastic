// Dragnet [Ransomware]: dragnet-ransomware-2025-5576 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 52e9a833-3213-5f03-bbad-8ad3d8443457

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
