// Dragnet [Ransomware]: dragnet-ransomware-2025-2529 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 104bca72-94f3-55f8-845c-266c00132c3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
