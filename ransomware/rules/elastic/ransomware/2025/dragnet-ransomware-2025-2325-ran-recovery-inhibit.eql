// Dragnet [Ransomware]: dragnet-ransomware-2025-2325 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 780f2acc-58f5-5fdb-b950-98a80a7a0bec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
