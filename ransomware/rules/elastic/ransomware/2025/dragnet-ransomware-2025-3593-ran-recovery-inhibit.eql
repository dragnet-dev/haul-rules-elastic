// Dragnet [Ransomware]: dragnet-ransomware-2025-3593 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: c49cf1a6-5727-59b4-a6ff-07c0f3d0cfdc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
