// Dragnet [Ransomware]: dragnet-ransomware-2025-0926 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 74aa3b7c-f9dc-534e-8d88-968a09290d02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
