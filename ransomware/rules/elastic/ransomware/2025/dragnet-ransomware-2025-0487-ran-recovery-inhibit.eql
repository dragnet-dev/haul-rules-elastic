// Dragnet [Ransomware]: dragnet-ransomware-2025-0487 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a9f1a112-0029-5e53-9358-ec01fb8f0c46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
