// Dragnet [Ransomware]: dragnet-ransomware-2025-5647 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: ad6f2c39-b1d5-587c-85e4-1506e961b0a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
