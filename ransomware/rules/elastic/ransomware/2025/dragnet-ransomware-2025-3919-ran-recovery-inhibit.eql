// Dragnet [Ransomware]: dragnet-ransomware-2025-3919 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: cc377d8e-ead3-5982-b87d-38733a1465b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
