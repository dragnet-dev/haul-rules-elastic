// Dragnet [Ransomware]: dragnet-ransomware-2025-3688 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 5dd46ad0-cddd-5241-8ac1-7df4df01a69f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
