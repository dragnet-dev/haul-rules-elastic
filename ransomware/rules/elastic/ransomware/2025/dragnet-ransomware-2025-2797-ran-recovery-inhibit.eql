// Dragnet [Ransomware]: dragnet-ransomware-2025-2797 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a8f8ea3d-e602-53b6-8dcb-354072eafd4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
