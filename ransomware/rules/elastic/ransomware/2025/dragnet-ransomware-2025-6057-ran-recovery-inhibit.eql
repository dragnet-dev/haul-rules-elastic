// Dragnet [Ransomware]: dragnet-ransomware-2025-6057 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 44918fb3-a901-5c05-90f0-9ee00b88b486

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
