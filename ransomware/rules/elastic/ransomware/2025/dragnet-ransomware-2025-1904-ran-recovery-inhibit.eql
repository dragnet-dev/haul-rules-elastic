// Dragnet [Ransomware]: dragnet-ransomware-2025-1904 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 319a82aa-7a1b-5d16-85c1-50f5b85ff58d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
