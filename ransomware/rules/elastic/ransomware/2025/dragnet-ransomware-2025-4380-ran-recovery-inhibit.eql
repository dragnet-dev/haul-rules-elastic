// Dragnet [Ransomware]: dragnet-ransomware-2025-4380 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a7fbb91c-019a-54a2-9ac5-4bd0b25091f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
