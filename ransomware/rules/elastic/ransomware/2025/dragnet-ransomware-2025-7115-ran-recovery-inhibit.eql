// Dragnet [Ransomware]: dragnet-ransomware-2025-7115 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 1d5643fd-80ad-5f16-afde-358ae5cad913

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
