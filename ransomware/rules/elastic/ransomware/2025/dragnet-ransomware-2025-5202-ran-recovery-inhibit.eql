// Dragnet [Ransomware]: dragnet-ransomware-2025-5202 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: f3325016-8ee6-5d8e-9ce3-8fc27ee4a7bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
