// Dragnet [Ransomware]: dragnet-ransomware-2025-3089 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: d265ace6-109d-5604-866a-8c2b0be96076

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
