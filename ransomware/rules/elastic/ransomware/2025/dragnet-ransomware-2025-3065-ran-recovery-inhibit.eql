// Dragnet [Ransomware]: dragnet-ransomware-2025-3065 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 63c48125-24a6-589b-b4e0-c972668f20e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
