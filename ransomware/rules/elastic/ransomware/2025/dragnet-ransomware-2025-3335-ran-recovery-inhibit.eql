// Dragnet [Ransomware]: dragnet-ransomware-2025-3335 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 82c1a13d-c4ac-5cf5-ace1-375e71c4cfe1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
