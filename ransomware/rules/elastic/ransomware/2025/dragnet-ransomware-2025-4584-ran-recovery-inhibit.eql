// Dragnet [Ransomware]: dragnet-ransomware-2025-4584 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 316f25cf-3eba-5b47-9938-35ec800d380b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
