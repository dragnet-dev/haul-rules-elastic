// Dragnet [Ransomware]: dragnet-ransomware-2025-5032 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 89d08db0-5367-5bb4-987f-b226eafd3487

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
