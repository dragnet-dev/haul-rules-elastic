// Dragnet [Ransomware]: dragnet-ransomware-2025-2910 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 308bdc84-65c6-56da-ade1-ff94384998f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
