// Dragnet [Ransomware]: dragnet-ransomware-2025-4937 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: ab1c4153-c96e-5c66-9fe2-40f858d726be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
