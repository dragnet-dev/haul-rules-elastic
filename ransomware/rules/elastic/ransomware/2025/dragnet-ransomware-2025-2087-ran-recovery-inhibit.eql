// Dragnet [Ransomware]: dragnet-ransomware-2025-2087 — Recovery Inhibition (RunSomeWares)
// Status: experimental | Level: high | ID: 8c83a2fb-01fc-5cd5-a5da-30f8756c4420

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
