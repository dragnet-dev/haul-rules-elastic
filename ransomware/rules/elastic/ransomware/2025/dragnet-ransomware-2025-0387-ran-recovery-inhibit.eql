// Dragnet [Ransomware]: dragnet-ransomware-2025-0387 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 915a963b-54f4-512a-bbb7-b814771c27ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
