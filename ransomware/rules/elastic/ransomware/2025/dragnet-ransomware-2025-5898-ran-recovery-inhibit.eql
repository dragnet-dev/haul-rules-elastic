// Dragnet [Ransomware]: dragnet-ransomware-2025-5898 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: a5c9e1de-6c5f-5c24-a900-28a542d3835e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
