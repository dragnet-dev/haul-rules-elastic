// Dragnet [Ransomware]: dragnet-ransomware-2025-3151 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b47ee989-3a9c-55e0-8b65-262ad38b3265

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
