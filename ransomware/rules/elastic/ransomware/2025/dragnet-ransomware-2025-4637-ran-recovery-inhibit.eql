// Dragnet [Ransomware]: dragnet-ransomware-2025-4637 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: eeeb722b-cfbf-5252-ae6f-152f0d845b4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
