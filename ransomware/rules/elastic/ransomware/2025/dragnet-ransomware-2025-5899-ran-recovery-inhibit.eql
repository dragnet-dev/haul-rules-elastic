// Dragnet [Ransomware]: dragnet-ransomware-2025-5899 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 6d125f23-2c35-51de-8283-f77859959cba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
