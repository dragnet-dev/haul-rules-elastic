// Dragnet [Ransomware]: dragnet-ransomware-2025-5479 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: f284c751-38e2-5282-9d39-2f18b7e8a74c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
