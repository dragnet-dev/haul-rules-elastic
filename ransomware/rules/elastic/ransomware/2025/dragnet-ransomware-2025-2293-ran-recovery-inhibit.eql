// Dragnet [Ransomware]: dragnet-ransomware-2025-2293 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: ab706ae3-f434-5364-824f-6d181e1293e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
