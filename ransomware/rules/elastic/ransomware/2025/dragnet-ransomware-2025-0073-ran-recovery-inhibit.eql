// Dragnet [Ransomware]: dragnet-ransomware-2025-0073 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: b03b3118-ae76-5ef0-9d86-2e71058db34f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
