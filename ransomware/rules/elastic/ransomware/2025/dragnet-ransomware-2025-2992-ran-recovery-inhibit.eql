// Dragnet [Ransomware]: dragnet-ransomware-2025-2992 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 249920ea-4a04-5620-b209-08eefd0b1d29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
