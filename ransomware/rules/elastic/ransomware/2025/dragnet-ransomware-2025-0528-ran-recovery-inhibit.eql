// Dragnet [Ransomware]: dragnet-ransomware-2025-0528 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 377f3537-4899-59ba-946f-9cb451eb8728

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
