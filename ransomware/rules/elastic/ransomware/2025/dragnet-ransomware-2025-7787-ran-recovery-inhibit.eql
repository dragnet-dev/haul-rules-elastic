// Dragnet [Ransomware]: dragnet-ransomware-2025-7787 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: c9f55041-5d15-5287-8ffb-791d728d5586

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
