// Dragnet [Ransomware]: dragnet-ransomware-2025-7414 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 9eade15f-132e-5f78-986c-e23da849e751

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
