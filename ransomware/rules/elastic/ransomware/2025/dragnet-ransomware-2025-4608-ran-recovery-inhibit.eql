// Dragnet [Ransomware]: dragnet-ransomware-2025-4608 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 4c44873f-08c5-5f94-b141-86129a88f7a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
