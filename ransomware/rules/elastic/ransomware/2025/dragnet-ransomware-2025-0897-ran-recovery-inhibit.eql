// Dragnet [Ransomware]: dragnet-ransomware-2025-0897 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: ad54e587-587b-5026-af3f-2c114c17bff3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
