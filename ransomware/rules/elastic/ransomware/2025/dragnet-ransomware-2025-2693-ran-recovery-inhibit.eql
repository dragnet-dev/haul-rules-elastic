// Dragnet [Ransomware]: dragnet-ransomware-2025-2693 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: dafdc5e3-63d6-5d12-af21-a3b871d30baa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
