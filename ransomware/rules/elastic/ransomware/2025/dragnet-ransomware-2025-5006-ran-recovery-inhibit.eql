// Dragnet [Ransomware]: dragnet-ransomware-2025-5006 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 4b65abef-8920-562c-a063-8a791d09f5ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
