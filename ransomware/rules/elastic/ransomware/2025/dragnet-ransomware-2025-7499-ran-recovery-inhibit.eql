// Dragnet [Ransomware]: dragnet-ransomware-2025-7499 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6cb66708-8a38-58ff-b505-ae3b967e2171

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
