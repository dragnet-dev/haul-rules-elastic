// Dragnet [Ransomware]: dragnet-ransomware-2025-5088 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 1c072523-ba49-5812-b906-6e00c8213c6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
