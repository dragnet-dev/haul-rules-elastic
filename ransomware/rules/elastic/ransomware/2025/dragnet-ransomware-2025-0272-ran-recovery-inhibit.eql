// Dragnet [Ransomware]: dragnet-ransomware-2025-0272 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 966f9ea8-a388-5c18-97a2-dd3e710e7a99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
