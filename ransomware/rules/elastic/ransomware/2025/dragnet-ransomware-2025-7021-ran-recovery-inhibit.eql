// Dragnet [Ransomware]: dragnet-ransomware-2025-7021 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: fe9fcf3a-7d55-5fee-a657-58f3de4cfa47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
