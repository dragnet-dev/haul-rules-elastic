// Dragnet [Ransomware]: dragnet-ransomware-2025-7890 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 58a25732-06a5-5746-9a1a-fd7c56912f05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
