// Dragnet [Ransomware]: dragnet-ransomware-2025-1063 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ecc843d9-29a1-530c-bdd7-6af00bdd91f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
