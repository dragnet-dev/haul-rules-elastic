// Dragnet [Ransomware]: dragnet-ransomware-2025-3329 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7b5525d3-6d0e-5777-8329-6e16b9bd4506

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
