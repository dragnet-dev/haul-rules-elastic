// Dragnet [Ransomware]: dragnet-ransomware-2025-5838 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 9c0dea37-ccc3-566a-8ca4-5343cc7d3f7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
