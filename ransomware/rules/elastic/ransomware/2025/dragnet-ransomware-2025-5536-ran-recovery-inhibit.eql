// Dragnet [Ransomware]: dragnet-ransomware-2025-5536 — Recovery Inhibition (teamxxx)
// Status: experimental | Level: high | ID: cec805c8-f426-5b59-ba73-799b6418d543

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
