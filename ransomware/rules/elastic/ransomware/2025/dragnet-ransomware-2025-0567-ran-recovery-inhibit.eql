// Dragnet [Ransomware]: dragnet-ransomware-2025-0567 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: 694cebfd-ed5f-561d-92ba-abde0fed2ca0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
