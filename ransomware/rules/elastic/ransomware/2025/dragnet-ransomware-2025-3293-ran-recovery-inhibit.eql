// Dragnet [Ransomware]: dragnet-ransomware-2025-3293 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: b747cafd-5dc7-5aa8-9ad3-7bc0ec057569

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
