// Dragnet [Ransomware]: dragnet-ransomware-2025-5792 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: dc3edfcd-0114-5366-8f71-097bd6dc4cd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
