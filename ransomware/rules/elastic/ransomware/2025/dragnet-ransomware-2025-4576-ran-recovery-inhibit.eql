// Dragnet [Ransomware]: dragnet-ransomware-2025-4576 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 8d93ca18-27a8-52b3-88a8-4ff3906ab99d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
