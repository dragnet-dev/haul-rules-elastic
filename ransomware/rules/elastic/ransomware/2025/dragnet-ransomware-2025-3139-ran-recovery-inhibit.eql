// Dragnet [Ransomware]: dragnet-ransomware-2025-3139 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 4f343346-f5a6-5b15-95fe-099aed99b444

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
