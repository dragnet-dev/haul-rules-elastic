// Dragnet [Ransomware]: dragnet-ransomware-2025-7276 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 7297804a-65b3-5e6a-89ee-e65566fbd5c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
