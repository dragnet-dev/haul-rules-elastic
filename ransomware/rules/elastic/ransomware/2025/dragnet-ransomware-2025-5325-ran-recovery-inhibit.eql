// Dragnet [Ransomware]: dragnet-ransomware-2025-5325 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 189bb570-6365-5627-883d-e4bd88740241

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
