// Dragnet [Ransomware]: dragnet-ransomware-2025-4540 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 350cae8d-53c4-5d96-adc3-d07133c89876

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
