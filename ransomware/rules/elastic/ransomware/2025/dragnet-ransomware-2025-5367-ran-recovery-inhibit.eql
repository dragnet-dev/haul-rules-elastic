// Dragnet [Ransomware]: dragnet-ransomware-2025-5367 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 289ac6de-f6b2-5ef2-8bef-426a6a5c842a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
