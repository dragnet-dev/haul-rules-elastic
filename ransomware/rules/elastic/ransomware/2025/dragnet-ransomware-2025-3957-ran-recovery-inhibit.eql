// Dragnet [Ransomware]: dragnet-ransomware-2025-3957 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 4c74b027-bb75-54ba-9b73-7274295f9faf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
