// Dragnet [Ransomware]: dragnet-ransomware-2025-3218 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 45c97a94-1f39-59e6-a150-5afbf324dbb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
