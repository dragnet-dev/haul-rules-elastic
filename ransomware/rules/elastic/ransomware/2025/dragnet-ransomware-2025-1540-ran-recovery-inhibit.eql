// Dragnet [Ransomware]: dragnet-ransomware-2025-1540 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: cc8162e1-4dbe-599b-aa6d-5884eaf76e06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
