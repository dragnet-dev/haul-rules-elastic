// Dragnet [Ransomware]: dragnet-ransomware-2025-0015 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: ea07aeed-2655-5b39-abdb-4d06d47bbbc3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
