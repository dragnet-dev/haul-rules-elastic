// Dragnet [Ransomware]: dragnet-ransomware-2025-7046 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: aa853cf3-d141-57f6-aad1-e5f293a56856

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
