// Dragnet [Ransomware]: dragnet-ransomware-2025-6022 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 312a7aac-422a-5e6c-bc09-45fa9d2e8dbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
