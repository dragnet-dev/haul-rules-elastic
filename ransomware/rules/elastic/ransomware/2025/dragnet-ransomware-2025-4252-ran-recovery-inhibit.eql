// Dragnet [Ransomware]: dragnet-ransomware-2025-4252 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5f4b1529-ed28-5ccc-bdde-2ec98fc71578

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
