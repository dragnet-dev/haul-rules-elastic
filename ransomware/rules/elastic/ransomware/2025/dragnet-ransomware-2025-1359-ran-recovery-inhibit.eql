// Dragnet [Ransomware]: dragnet-ransomware-2025-1359 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: e28d1d29-9c39-5f93-896b-2421b174c9fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
