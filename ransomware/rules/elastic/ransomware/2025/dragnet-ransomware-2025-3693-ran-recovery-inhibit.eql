// Dragnet [Ransomware]: dragnet-ransomware-2025-3693 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: a6cc9e69-03b0-50a7-aacc-ba7465374fb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
