// Dragnet [Ransomware]: dragnet-ransomware-2025-2727 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 797b3aa9-eba5-5b0b-bf89-6485360a6491

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
