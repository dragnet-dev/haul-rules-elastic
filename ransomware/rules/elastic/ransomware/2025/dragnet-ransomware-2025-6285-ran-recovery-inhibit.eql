// Dragnet [Ransomware]: dragnet-ransomware-2025-6285 — Recovery Inhibition (tridentlocker)
// Status: experimental | Level: high | ID: 625615e1-39b4-5018-8567-10207d42c5b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
