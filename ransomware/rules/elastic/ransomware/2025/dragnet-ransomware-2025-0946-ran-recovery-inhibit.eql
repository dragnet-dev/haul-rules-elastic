// Dragnet [Ransomware]: dragnet-ransomware-2025-0946 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: c4085316-021f-54e5-a0a5-f3929114a898

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
