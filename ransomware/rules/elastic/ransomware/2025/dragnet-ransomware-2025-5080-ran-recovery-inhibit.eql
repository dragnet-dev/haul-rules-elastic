// Dragnet [Ransomware]: dragnet-ransomware-2025-5080 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: a605fb87-e6dd-5206-84a6-aa49df59ca8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
