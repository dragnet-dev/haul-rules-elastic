// Dragnet [Ransomware]: dragnet-ransomware-2025-4565 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fa2cd7c0-3c41-5bc3-b369-6c615c9c721c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
