// Dragnet [Ransomware]: dragnet-ransomware-2025-4283 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 35b2eb58-80ee-57c9-b156-f75bb7424602

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
