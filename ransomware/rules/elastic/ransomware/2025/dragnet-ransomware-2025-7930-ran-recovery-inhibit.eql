// Dragnet [Ransomware]: dragnet-ransomware-2025-7930 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 6b09272c-a077-55fa-9d54-bce987eb91b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
