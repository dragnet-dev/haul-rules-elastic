// Dragnet [Ransomware]: dragnet-ransomware-2025-3716 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: d37dc2b1-5c54-508a-a598-be544b1d78e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
