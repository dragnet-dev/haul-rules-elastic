// Dragnet [Ransomware]: dragnet-ransomware-2025-6651 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: e45cc85d-2274-541c-ba3d-e46674ab2073

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
