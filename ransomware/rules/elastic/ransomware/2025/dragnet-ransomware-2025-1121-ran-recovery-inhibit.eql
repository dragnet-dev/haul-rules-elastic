// Dragnet [Ransomware]: dragnet-ransomware-2025-1121 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ee75d919-3ad8-5520-b4ed-b365fb0c3297

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
