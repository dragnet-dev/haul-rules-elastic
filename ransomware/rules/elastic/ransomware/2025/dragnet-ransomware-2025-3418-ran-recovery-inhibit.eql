// Dragnet [Ransomware]: dragnet-ransomware-2025-3418 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: de959277-774f-546e-9f97-955772bce853

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
