// Dragnet [Ransomware]: dragnet-ransomware-2025-4248 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: a198a194-2a90-5de2-aeb6-596642d214e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
