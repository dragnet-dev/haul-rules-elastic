// Dragnet [Ransomware]: dragnet-ransomware-2025-7370 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 92342294-d80e-5c14-b8cf-38e4e8094c44

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
