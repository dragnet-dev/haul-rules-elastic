// Dragnet [Ransomware]: dragnet-ransomware-2025-0578 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c84c4981-1aa3-504a-899b-79e4236e8407

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
