// Dragnet [Ransomware]: dragnet-ransomware-2025-4696 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 3c52b71a-c7e1-5f03-b1cb-70a7fa946db5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
