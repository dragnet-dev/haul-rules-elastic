// Dragnet [Ransomware]: dragnet-ransomware-2025-5393 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 109d9892-b689-59bf-9023-7f04ddc26424

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
