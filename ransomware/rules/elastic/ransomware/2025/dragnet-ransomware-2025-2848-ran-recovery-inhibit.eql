// Dragnet [Ransomware]: dragnet-ransomware-2025-2848 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 6eb68802-726e-5ebd-b704-de82ff559611

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
