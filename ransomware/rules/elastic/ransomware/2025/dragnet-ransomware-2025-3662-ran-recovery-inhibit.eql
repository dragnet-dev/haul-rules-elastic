// Dragnet [Ransomware]: dragnet-ransomware-2025-3662 — Recovery Inhibition (termite)
// Status: experimental | Level: high | ID: e76d10e7-875e-5299-9575-b6b220b7adf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
