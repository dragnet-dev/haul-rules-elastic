// Dragnet [Ransomware]: dragnet-ransomware-2025-6622 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: d1a2d5ba-c530-503c-a688-5d22f1c9484f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
