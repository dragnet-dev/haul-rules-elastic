// Dragnet [Ransomware]: dragnet-ransomware-2025-7909 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: fd2a6092-231d-512e-882d-db31a62cc06c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
