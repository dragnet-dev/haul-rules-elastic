// Dragnet [Ransomware]: dragnet-ransomware-2025-1732 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: dd61a25c-6105-5d96-8be5-f0d7b55fa320

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
