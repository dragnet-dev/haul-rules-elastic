// Dragnet [Ransomware]: dragnet-ransomware-2025-6869 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 692c9962-94bf-506f-8dfb-af6aafd1c715

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
