// Dragnet [Ransomware]: dragnet-ransomware-2025-6335 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 35218127-1814-50e0-9256-4e8d7ff67177

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
