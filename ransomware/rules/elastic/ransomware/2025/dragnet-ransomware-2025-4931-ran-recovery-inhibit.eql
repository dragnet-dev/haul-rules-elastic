// Dragnet [Ransomware]: dragnet-ransomware-2025-4931 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: cff0a43c-4ca9-5bb4-b873-3384526cda96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
