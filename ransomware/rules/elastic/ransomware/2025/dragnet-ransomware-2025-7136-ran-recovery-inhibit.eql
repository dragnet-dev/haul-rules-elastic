// Dragnet [Ransomware]: dragnet-ransomware-2025-7136 — Recovery Inhibition (insomnia)
// Status: test | Level: high | ID: 148a37f5-c688-5419-bba1-ba5d17920538

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
