// Dragnet [Ransomware]: dragnet-ransomware-2025-7195 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 48130ad1-7e4a-5d6e-b6df-e28f88ddc4fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
