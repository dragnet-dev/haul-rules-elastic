// Dragnet [Ransomware]: dragnet-ransomware-2025-6194 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 2d4b49ce-eec4-5c8f-921f-6af83c579c6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
