// Dragnet [Ransomware]: dragnet-ransomware-2025-0071 — Recovery Inhibition (handala)
// Status: test | Level: high | ID: 904b15b0-07ed-5b45-a65f-126d8078093f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
