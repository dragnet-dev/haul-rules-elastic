// Dragnet [Ransomware]: dragnet-ransomware-2025-5065 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: a24f4eda-5a87-535c-b684-8ca019388384

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
