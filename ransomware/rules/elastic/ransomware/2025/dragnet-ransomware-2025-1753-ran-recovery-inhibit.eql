// Dragnet [Ransomware]: dragnet-ransomware-2025-1753 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b54f9494-7332-5d43-b10b-608f37419e00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
