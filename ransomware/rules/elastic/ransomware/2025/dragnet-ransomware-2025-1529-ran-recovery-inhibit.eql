// Dragnet [Ransomware]: dragnet-ransomware-2025-1529 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 35626135-2132-5148-abb5-dff278ed5a0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
