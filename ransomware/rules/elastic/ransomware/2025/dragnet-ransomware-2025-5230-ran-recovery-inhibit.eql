// Dragnet [Ransomware]: dragnet-ransomware-2025-5230 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: ad7bb2b0-b1de-5a45-a0f5-d5b6c80db436

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
