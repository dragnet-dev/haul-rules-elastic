// Dragnet [Ransomware]: dragnet-ransomware-2025-1762 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3fa458eb-dc48-5f13-9743-9b44d1673db3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
