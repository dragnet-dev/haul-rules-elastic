// Dragnet [Ransomware]: dragnet-ransomware-2025-2648 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 68558522-385e-5be5-917d-eadffe2e22e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
