// Dragnet [Ransomware]: dragnet-ransomware-2025-1479 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: ecaa9b51-0270-5462-888e-ddc636bd6f69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
