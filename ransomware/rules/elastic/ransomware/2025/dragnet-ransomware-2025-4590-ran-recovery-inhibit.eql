// Dragnet [Ransomware]: dragnet-ransomware-2025-4590 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 651d1f1b-458b-5207-89a2-a7f88ef148ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
