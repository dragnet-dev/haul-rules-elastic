// Dragnet [Ransomware]: dragnet-ransomware-2025-2171 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: d63b4a9d-50aa-588b-bea7-5e4431eb279a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
