// Dragnet [Ransomware]: dragnet-ransomware-2025-4046 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: d5a81d69-d00a-535a-9113-45e8615b8cce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
