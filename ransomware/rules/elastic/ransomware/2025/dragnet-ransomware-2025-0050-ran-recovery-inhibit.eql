// Dragnet [Ransomware]: dragnet-ransomware-2025-0050 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: fe5523fa-0791-5476-b704-240a476b7f0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
