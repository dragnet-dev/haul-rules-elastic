// Dragnet [Ransomware]: dragnet-ransomware-2025-6045 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: e150c9fc-be47-5601-8265-8f536a7e3876

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
