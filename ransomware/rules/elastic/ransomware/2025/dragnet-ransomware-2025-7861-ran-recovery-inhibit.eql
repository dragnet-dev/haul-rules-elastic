// Dragnet [Ransomware]: dragnet-ransomware-2025-7861 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: ec95b55a-cc8c-51e2-826c-3e078568ca2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
