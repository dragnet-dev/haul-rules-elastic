// Dragnet [Ransomware]: dragnet-ransomware-2025-1919 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: b2142c19-c193-5dfb-ba4c-349ddefc7b9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
