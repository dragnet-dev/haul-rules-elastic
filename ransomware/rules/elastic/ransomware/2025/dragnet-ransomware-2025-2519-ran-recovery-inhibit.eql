// Dragnet [Ransomware]: dragnet-ransomware-2025-2519 — Recovery Inhibition (rebornvc)
// Status: deprecated | Level: high | ID: 3106cf6e-def3-5d83-9b78-f312783ee348

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
