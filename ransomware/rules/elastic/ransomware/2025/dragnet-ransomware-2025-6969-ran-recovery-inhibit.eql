// Dragnet [Ransomware]: dragnet-ransomware-2025-6969 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 5d72d972-7c89-5f03-a24a-64e5b5ff949f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
