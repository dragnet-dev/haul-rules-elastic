// Dragnet [Ransomware]: dragnet-ransomware-2025-7844 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 152fc260-7d98-5d8b-9d6d-b25f33af9faf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
