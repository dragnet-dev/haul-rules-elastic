// Dragnet [Ransomware]: dragnet-ransomware-2025-2996 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 506f4dc8-1bf9-58f9-a968-d2bee86af345

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
