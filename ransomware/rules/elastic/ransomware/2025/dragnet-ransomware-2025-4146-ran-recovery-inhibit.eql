// Dragnet [Ransomware]: dragnet-ransomware-2025-4146 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: cbf634eb-2f15-5091-a3ec-60f26987a93d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
