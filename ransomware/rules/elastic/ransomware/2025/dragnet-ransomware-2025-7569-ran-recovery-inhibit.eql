// Dragnet [Ransomware]: dragnet-ransomware-2025-7569 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 8256e8e5-35bd-5778-b9a1-1f1d30c8b40c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
