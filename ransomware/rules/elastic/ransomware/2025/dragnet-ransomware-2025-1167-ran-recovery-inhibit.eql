// Dragnet [Ransomware]: dragnet-ransomware-2025-1167 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: dc57e20c-262f-5252-83d0-5bf129b023a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
