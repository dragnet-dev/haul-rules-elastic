// Dragnet [Ransomware]: dragnet-ransomware-2025-4947 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 193ae404-eb03-57d2-bf33-0a63ec661984

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
