// Dragnet [Ransomware]: dragnet-ransomware-2025-6117 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 429dd802-59eb-5160-b1fc-837bfc8c2576

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
