// Dragnet [Ransomware]: dragnet-ransomware-2025-3099 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 72b1ff7a-971b-5ffb-975e-d868953d4402

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
