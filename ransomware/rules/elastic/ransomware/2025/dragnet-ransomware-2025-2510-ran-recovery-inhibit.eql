// Dragnet [Ransomware]: dragnet-ransomware-2025-2510 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 891ed70b-e826-5104-99ba-5e46a23ccf3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
