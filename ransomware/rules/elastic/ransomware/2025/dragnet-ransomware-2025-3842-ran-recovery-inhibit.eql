// Dragnet [Ransomware]: dragnet-ransomware-2025-3842 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 38d78071-7007-517b-a661-7d186f283fec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
