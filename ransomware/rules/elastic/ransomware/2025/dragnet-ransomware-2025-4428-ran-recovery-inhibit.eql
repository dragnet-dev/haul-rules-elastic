// Dragnet [Ransomware]: dragnet-ransomware-2025-4428 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 03737a9f-ec7e-55dc-94ac-54f2c827e65a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
