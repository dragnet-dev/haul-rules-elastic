// Dragnet [Ransomware]: dragnet-ransomware-2025-2915 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: d6ada7de-ce52-5862-ab4f-4671dfd9c554

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
