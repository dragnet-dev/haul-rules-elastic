// Dragnet [Ransomware]: dragnet-ransomware-2025-5822 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0fd57107-5b91-5af5-8f4c-ed809790ec42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
