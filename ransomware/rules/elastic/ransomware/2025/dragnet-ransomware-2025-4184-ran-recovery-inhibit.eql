// Dragnet [Ransomware]: dragnet-ransomware-2025-4184 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2aa29560-111a-5c29-89df-471ef8d5194a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
