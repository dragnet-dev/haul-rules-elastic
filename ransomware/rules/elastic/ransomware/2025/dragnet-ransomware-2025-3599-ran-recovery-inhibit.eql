// Dragnet [Ransomware]: dragnet-ransomware-2025-3599 — Recovery Inhibition (linkc)
// Status: experimental | Level: high | ID: 72f90adf-e091-5199-9433-0696c410db01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
