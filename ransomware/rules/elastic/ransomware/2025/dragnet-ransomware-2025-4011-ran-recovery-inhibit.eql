// Dragnet [Ransomware]: dragnet-ransomware-2025-4011 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: b923deea-5743-5ac5-a5a8-7ae8cb495c92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
