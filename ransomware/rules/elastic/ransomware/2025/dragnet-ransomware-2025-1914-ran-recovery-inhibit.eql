// Dragnet [Ransomware]: dragnet-ransomware-2025-1914 — Recovery Inhibition (blacknevas)
// Status: test | Level: high | ID: 455ad18d-24f1-57b3-ba5e-3a134212cb24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
