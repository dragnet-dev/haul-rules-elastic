// Dragnet [Ransomware]: dragnet-ransomware-2025-2865 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4201a820-883f-5c4a-8fd3-2a26fa84a621

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
