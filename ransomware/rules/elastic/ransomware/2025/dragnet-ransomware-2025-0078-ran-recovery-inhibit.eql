// Dragnet [Ransomware]: dragnet-ransomware-2025-0078 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e9b3beec-84f0-5ea3-bcbc-29330440d266

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
