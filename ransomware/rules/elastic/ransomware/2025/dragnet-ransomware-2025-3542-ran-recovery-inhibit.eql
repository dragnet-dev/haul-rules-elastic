// Dragnet [Ransomware]: dragnet-ransomware-2025-3542 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 23bc2287-5fb2-5c8f-ad90-434f2f98671a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
