// Dragnet [Ransomware]: dragnet-ransomware-2025-7543 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 00e6698f-b2ca-5307-8fcf-2e5fc388c131

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
