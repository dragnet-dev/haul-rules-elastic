// Dragnet [Ransomware]: dragnet-ransomware-2025-1419 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 4347af8c-fe4e-5b20-8c03-57f0c6302158

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
