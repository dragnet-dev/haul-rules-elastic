// Dragnet [Ransomware]: dragnet-ransomware-2025-7026 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: ab486a99-2527-51f4-b364-6bd77c460ffd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
