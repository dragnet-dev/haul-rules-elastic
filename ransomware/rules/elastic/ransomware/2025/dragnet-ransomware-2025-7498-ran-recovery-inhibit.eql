// Dragnet [Ransomware]: dragnet-ransomware-2025-7498 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 5d593d90-f08b-5f50-9f75-9c05035248e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
