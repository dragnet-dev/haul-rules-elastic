// Dragnet [Ransomware]: dragnet-ransomware-2025-4956 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a9e830b5-9928-550f-aba9-d8499dde5a01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
