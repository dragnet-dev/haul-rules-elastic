// Dragnet [Ransomware]: dragnet-ransomware-2025-4167 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: fd7334bb-f081-5769-a719-a9f2902fabc6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
