// Dragnet [Ransomware]: dragnet-ransomware-2025-3878 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6a9d4b9a-8e8e-5639-8cf9-4ab7560254cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
