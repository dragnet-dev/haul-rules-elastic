// Dragnet [Ransomware]: dragnet-ransomware-2025-3133 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 3fb7dd5d-7643-5e1a-9ef9-fbb3c72ab374

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
