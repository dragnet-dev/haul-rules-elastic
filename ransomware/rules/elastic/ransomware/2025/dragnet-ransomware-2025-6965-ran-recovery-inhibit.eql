// Dragnet [Ransomware]: dragnet-ransomware-2025-6965 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 44a76d27-3b2d-53c1-94da-99a5dadc80d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
