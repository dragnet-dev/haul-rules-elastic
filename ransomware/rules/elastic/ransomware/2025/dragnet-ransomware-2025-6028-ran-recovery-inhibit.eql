// Dragnet [Ransomware]: dragnet-ransomware-2025-6028 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 66b63221-bc2c-5ce3-9705-773e6a781a10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
