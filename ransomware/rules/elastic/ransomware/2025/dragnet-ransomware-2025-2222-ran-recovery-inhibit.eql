// Dragnet [Ransomware]: dragnet-ransomware-2025-2222 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: afc8be70-9295-5b93-a793-631643bf0bce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
