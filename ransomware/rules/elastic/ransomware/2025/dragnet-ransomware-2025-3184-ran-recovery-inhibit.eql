// Dragnet [Ransomware]: dragnet-ransomware-2025-3184 — Recovery Inhibition (anubis)
// Status: experimental | Level: high | ID: 767fdf9c-11a8-550e-a3a7-6d1e10a492ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
