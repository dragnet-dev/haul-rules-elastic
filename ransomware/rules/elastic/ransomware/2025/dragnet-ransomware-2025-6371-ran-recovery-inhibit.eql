// Dragnet [Ransomware]: dragnet-ransomware-2025-6371 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 6d0d45ac-c3bb-5326-b5c2-ab8c5f52fcda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
