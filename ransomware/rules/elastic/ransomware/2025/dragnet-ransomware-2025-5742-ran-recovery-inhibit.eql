// Dragnet [Ransomware]: dragnet-ransomware-2025-5742 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 97dfd4e0-6e54-5954-85af-373335badf2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
