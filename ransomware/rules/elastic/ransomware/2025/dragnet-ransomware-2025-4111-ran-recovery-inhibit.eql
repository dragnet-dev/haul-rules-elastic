// Dragnet [Ransomware]: dragnet-ransomware-2025-4111 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: d5f6d710-1f60-59ce-8197-41a99204897e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
