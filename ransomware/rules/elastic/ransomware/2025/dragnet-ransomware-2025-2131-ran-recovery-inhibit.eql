// Dragnet [Ransomware]: dragnet-ransomware-2025-2131 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: 19e3fa41-baea-588a-ad71-af1d24efc72d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
