// Dragnet [Ransomware]: dragnet-ransomware-2025-2385 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 829d89e5-7d9f-5330-abd7-d71b152963d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
