// Dragnet [Ransomware]: dragnet-ransomware-2025-2594 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 05367688-00e2-51da-b418-6e0bd520f95f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
