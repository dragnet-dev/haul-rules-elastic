// Dragnet [Ransomware]: dragnet-ransomware-2025-2303 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: dbe3ed77-584c-5e56-bed6-7bcd1c3f9deb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
