// Dragnet [Ransomware]: dragnet-ransomware-2025-3268 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 3a0ef02e-59c3-5b5f-b2d4-b3de0caa55fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
