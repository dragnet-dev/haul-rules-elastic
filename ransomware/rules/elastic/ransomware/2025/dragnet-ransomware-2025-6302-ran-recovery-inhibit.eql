// Dragnet [Ransomware]: dragnet-ransomware-2025-6302 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 438c5335-e80f-5b9b-982e-ca9910666546

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
