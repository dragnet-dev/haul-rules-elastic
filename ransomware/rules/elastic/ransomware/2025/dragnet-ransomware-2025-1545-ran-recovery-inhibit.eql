// Dragnet [Ransomware]: dragnet-ransomware-2025-1545 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: f9160fea-e3ec-5803-b13f-415c7aeb9d9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
