// Dragnet [Ransomware]: dragnet-ransomware-2025-3551 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 48088e4b-cf11-54e2-8426-a651a1c5ae06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
