// Dragnet [Ransomware]: dragnet-ransomware-2025-5562 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d6d03ece-2e66-5623-808b-4455e7d3ab2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
