// Dragnet [Ransomware]: dragnet-ransomware-2025-1180 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 7a248aa1-f58e-5453-b18b-083d59e432c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
