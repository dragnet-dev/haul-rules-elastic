// Dragnet [Ransomware]: dragnet-ransomware-2025-5895 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: a0292796-5fd5-5c4c-bb56-c7b3dd82e757

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
