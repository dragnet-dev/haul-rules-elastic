// Dragnet [Ransomware]: dragnet-ransomware-2025-5497 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 2e595555-c564-58b3-98ca-47f75cc8338e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
