// Dragnet [Ransomware]: dragnet-ransomware-2025-7786 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: c68a1a50-f692-515a-93db-c1348f58e619

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
