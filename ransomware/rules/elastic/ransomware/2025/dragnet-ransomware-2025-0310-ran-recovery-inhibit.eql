// Dragnet [Ransomware]: dragnet-ransomware-2025-0310 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: 2750cbd5-5318-50b2-9249-31e34d818343

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
