// Dragnet [Ransomware]: dragnet-ransomware-2025-6380 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 7f9a15a0-61aa-5898-bb81-dabd4c9c6749

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
