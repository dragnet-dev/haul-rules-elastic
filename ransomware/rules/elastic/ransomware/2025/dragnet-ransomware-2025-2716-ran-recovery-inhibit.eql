// Dragnet [Ransomware]: dragnet-ransomware-2025-2716 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 3784e475-b198-5b45-a118-10a0e037f6d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
