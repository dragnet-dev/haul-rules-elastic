// Dragnet [Ransomware]: dragnet-ransomware-2025-5738 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 68bff528-2338-5c33-b83a-27a5f2e338b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
