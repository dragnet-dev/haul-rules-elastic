// Dragnet [Ransomware]: dragnet-ransomware-2025-6912 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a369f2df-36ad-5ec8-a3fd-609090b359a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
