// Dragnet [Ransomware]: dragnet-ransomware-2025-0178 — Recovery Inhibition (kraken)
// Status: experimental | Level: high | ID: 5e28565a-e13d-5422-ad80-0efad134cb30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
