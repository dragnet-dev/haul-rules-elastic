// Dragnet [Ransomware]: dragnet-ransomware-2025-4668 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3bcdb51c-0fd2-582f-8c35-df57093dbca1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
