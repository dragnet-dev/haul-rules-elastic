// Dragnet [Ransomware]: dragnet-ransomware-2025-7850 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 63331300-971a-56a5-92a6-ba3850f91ce4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
