// Dragnet [Ransomware]: dragnet-ransomware-2025-4812 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 4da777cd-7dd0-52b0-a793-5abfcd9279a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
