// Dragnet [Ransomware]: dragnet-ransomware-2025-1320 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d785e48c-a7f1-5837-a320-06703a9d2db1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
