// Dragnet [Ransomware]: dragnet-ransomware-2025-6565 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1dd2332b-38d2-51a6-9900-32558f148d10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
