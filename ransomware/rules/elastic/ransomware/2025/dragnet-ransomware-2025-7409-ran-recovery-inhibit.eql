// Dragnet [Ransomware]: dragnet-ransomware-2025-7409 — Recovery Inhibition (hellcat)
// Status: deprecated | Level: high | ID: be59ba00-22c7-5f95-b607-06a0c9b62bd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
