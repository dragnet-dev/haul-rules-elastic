// Dragnet [Ransomware]: dragnet-ransomware-2025-6276 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 3d53d3a1-b7bb-5c8f-8b97-cbd0a11222b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
