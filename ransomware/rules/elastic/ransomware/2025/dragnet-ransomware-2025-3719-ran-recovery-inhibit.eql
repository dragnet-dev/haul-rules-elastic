// Dragnet [Ransomware]: dragnet-ransomware-2025-3719 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: fefe4465-9115-55d1-b7ef-7cdf7537a0dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
