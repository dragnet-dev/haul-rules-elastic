// Dragnet [Ransomware]: dragnet-ransomware-2025-4441 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9b5de076-1395-5269-9158-4300ba102aa4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
