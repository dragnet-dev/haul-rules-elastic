// Dragnet [Ransomware]: dragnet-ransomware-2025-0827 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 7cd5c6e2-2317-5210-8a8f-ebfd080e2f55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
