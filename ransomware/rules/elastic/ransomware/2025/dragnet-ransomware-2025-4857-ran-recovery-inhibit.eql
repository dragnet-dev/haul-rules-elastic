// Dragnet [Ransomware]: dragnet-ransomware-2025-4857 — Recovery Inhibition (IMNCrew)
// Status: experimental | Level: high | ID: 77eeb5e7-378c-52f2-911b-b28b6b70dfb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
