// Dragnet [Ransomware]: dragnet-ransomware-2025-3147 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 7f309292-f425-51f4-be97-61af15764ba3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
