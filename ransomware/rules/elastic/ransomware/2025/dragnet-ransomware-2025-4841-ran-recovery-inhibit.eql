// Dragnet [Ransomware]: dragnet-ransomware-2025-4841 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 31bca651-284b-5449-9faa-fd52efeef8ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
