// Dragnet [Ransomware]: dragnet-ransomware-2025-2538 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 13afac0f-f4ad-5c78-a5cf-5cff07719d64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
