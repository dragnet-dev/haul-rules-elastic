// Dragnet [Ransomware]: dragnet-ransomware-2025-2989 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1c8541b1-f094-58b3-8623-a4ee7d8c1c1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
