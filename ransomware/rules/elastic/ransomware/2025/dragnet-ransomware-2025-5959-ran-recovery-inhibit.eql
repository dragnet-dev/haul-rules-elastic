// Dragnet [Ransomware]: dragnet-ransomware-2025-5959 — Recovery Inhibition (medusa)
// Status: test | Level: high | ID: f2716f32-0d9f-57a4-bd8f-fa2bd3ee48e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
