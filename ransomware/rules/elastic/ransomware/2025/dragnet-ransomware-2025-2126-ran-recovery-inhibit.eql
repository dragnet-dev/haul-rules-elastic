// Dragnet [Ransomware]: dragnet-ransomware-2025-2126 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f917a7f0-ba37-53cf-8933-93e5eed34484

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
