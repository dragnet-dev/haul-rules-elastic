// Dragnet [Ransomware]: dragnet-ransomware-2025-6693 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 3b8608b0-aa3d-500a-8fea-1daf98a23342

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
