// Dragnet [Ransomware]: dragnet-ransomware-2025-4122 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 924d71a5-a176-5e3d-b9c1-20cd747cfc5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
