// Dragnet [Ransomware]: dragnet-ransomware-2025-6306 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e501d1d1-40f2-515b-95d9-f4c502d545a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
