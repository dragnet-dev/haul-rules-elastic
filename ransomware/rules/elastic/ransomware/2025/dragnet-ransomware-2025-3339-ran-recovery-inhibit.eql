// Dragnet [Ransomware]: dragnet-ransomware-2025-3339 — Recovery Inhibition (termite)
// Status: experimental | Level: high | ID: c9015039-a610-5f85-9c23-cc4a98c6077f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
