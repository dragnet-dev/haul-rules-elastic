// Dragnet [Ransomware]: dragnet-ransomware-2025-7488 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2b2cb977-e18c-5ec7-8f77-f5d6a696bdea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
