// Dragnet [Ransomware]: dragnet-ransomware-2025-5361 — Recovery Inhibition (securotrop)
// Status: experimental | Level: high | ID: 4f913de9-0613-5580-8da5-194106943f13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
