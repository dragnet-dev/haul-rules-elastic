// Dragnet [Ransomware]: dragnet-ransomware-2025-6408 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: e26a4efd-0b50-54f4-89f7-be183b50ccd1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
