// Dragnet [Ransomware]: dragnet-ransomware-2025-5341 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 584af00c-d995-5a9d-b429-7deb306bb90e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
