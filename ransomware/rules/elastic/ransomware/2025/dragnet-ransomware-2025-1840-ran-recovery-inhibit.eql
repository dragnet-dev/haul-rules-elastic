// Dragnet [Ransomware]: dragnet-ransomware-2025-1840 — Recovery Inhibition (gunra)
// Status: experimental | Level: high | ID: d946d3be-0fc5-56c7-9f01-2d4bc183fe27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
