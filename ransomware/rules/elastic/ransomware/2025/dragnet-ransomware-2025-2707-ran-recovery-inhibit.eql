// Dragnet [Ransomware]: dragnet-ransomware-2025-2707 — Recovery Inhibition (ransomhouse)
// Status: test | Level: high | ID: 5c62445b-b124-5671-bf69-89121a71baa8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
