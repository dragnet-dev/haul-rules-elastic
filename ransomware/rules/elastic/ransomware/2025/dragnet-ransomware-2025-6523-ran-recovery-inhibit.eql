// Dragnet [Ransomware]: dragnet-ransomware-2025-6523 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d0b4c7a3-679b-5ae8-a462-8eb41f15df29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
