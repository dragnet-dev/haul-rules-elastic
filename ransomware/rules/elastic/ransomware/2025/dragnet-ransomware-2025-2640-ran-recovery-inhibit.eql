// Dragnet [Ransomware]: dragnet-ransomware-2025-2640 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 664c5038-108d-51a5-b2e7-fe3dbf21944c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
