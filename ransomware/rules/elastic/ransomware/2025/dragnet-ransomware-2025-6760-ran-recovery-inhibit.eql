// Dragnet [Ransomware]: dragnet-ransomware-2025-6760 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 33e709f9-a6d6-54de-b81b-7fccea2a8c8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
