// Dragnet [Ransomware]: dragnet-ransomware-2025-4002 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: e948584d-4024-5e75-89f3-84a6ffb07a16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
