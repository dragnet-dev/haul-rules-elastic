// Dragnet [Ransomware]: dragnet-ransomware-2025-0773 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 586a67ec-ea04-59ba-b7c9-d6bae08b94ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
