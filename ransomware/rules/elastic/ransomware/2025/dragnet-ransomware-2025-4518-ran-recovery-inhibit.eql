// Dragnet [Ransomware]: dragnet-ransomware-2025-4518 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 0fb11153-765b-5ac7-a05c-125f426c387c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
