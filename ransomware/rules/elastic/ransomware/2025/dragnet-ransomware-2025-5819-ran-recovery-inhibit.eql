// Dragnet [Ransomware]: dragnet-ransomware-2025-5819 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: c9a8e92e-cf7e-5849-a7eb-ed75858022dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
