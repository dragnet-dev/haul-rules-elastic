// Dragnet [Ransomware]: dragnet-ransomware-2025-3568 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: ae0193cc-4639-546e-bdbf-39c62432a55a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
