// Dragnet [Ransomware]: dragnet-ransomware-2025-2349 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 12272778-7a73-5cb9-aec4-9c17e9b65f45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
