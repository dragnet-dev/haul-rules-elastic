// Dragnet [Ransomware]: dragnet-ransomware-2025-5395 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: e2fe71ed-aa2f-577b-b324-0031e44804f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
