// Dragnet [Ransomware]: dragnet-ransomware-2025-6432 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 44ecea62-9d1e-5470-a49d-e781c5f0eb9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
