// Dragnet [Ransomware]: dragnet-ransomware-2025-2038 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 8c77510f-73cc-53e1-87d8-300aabed02eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
