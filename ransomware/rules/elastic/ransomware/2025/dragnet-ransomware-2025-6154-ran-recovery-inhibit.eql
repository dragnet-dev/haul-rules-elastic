// Dragnet [Ransomware]: dragnet-ransomware-2025-6154 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 51ce7661-4ba1-5798-b262-733813af3e9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
