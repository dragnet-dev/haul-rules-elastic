// Dragnet [Ransomware]: dragnet-ransomware-2025-5766 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 8a5d167e-9862-5926-aeff-a53d10469750

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
