// Dragnet [Ransomware]: dragnet-ransomware-2025-1376 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 3d501461-3bfb-5f9f-ab1c-919d6f8e914d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
