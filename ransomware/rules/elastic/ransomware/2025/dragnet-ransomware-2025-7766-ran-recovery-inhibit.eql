// Dragnet [Ransomware]: dragnet-ransomware-2025-7766 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 02721d30-b225-5bbd-b61c-13c9f5fbc406

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
