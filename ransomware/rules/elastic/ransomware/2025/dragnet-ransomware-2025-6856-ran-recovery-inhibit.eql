// Dragnet [Ransomware]: dragnet-ransomware-2025-6856 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 95d7a011-9a04-54d4-ab0f-55c4c88f430a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
