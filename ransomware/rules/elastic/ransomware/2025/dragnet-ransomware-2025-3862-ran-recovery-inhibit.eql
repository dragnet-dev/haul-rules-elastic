// Dragnet [Ransomware]: dragnet-ransomware-2025-3862 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 2084aa0f-ba4f-53d7-a817-8e062aa8d990

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
