// Dragnet [Ransomware]: dragnet-ransomware-2025-6381 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: bccd23eb-c734-519d-a274-b2d353d3a51c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
