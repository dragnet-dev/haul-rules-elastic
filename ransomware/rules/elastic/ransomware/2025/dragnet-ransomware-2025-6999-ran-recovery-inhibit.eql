// Dragnet [Ransomware]: dragnet-ransomware-2025-6999 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: b7f9af10-94d0-5049-a712-88a561efad83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
