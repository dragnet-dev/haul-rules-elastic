// Dragnet [Ransomware]: dragnet-ransomware-2025-6659 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7234bd10-493c-5bc0-bed9-0a007a31b896

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
