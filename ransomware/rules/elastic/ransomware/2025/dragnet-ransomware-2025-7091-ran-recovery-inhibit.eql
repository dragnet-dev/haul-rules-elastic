// Dragnet [Ransomware]: dragnet-ransomware-2025-7091 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 5d7b1d5f-f0d4-5e5c-9464-48d8b620f3fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
