// Dragnet [Ransomware]: dragnet-ransomware-2025-2621 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 5b637673-a303-56b8-b080-e84f54d7b416

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
