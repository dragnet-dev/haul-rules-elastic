// Dragnet [Ransomware]: dragnet-ransomware-2025-7444 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: cf0f2892-0d55-5bd8-9a69-b83522e383fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
