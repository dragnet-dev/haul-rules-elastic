// Dragnet [Ransomware]: dragnet-ransomware-2025-1352 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: f94c431a-3a56-5e64-8baa-32df9be3b15f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
