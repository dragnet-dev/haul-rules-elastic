// Dragnet [Ransomware]: dragnet-ransomware-2025-3740 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: cb885963-a6b5-5e14-abde-016491871c47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
