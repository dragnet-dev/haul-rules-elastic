// Dragnet [Ransomware]: dragnet-ransomware-2025-3087 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 90450621-fde9-5068-99ce-c7497ba3292c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
