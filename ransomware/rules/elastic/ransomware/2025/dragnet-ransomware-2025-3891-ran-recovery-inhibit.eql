// Dragnet [Ransomware]: dragnet-ransomware-2025-3891 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: fd9bb58f-f885-5b17-b14a-d2692bb68ae4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
