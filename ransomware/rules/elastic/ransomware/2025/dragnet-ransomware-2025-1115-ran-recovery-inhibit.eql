// Dragnet [Ransomware]: dragnet-ransomware-2025-1115 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f50ec1a3-5c65-5047-afcd-123ca04f58f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
