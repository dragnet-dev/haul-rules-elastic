// Dragnet [Ransomware]: dragnet-ransomware-2025-2985 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: b9367278-ad83-5e00-9f44-e1292c7f1b0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
