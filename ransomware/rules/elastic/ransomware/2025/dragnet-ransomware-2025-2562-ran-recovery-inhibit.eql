// Dragnet [Ransomware]: dragnet-ransomware-2025-2562 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5431e55b-8517-5130-89bf-00f2ae10df06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
