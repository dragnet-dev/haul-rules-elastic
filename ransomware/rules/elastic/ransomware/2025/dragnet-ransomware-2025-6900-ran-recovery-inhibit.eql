// Dragnet [Ransomware]: dragnet-ransomware-2025-6900 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 1c1b1e7b-1188-5900-8394-0ef3572db80c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
