// Dragnet [Ransomware]: dragnet-ransomware-2025-1800 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 6b7cc86c-dac7-54cf-8667-d939387b648a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
