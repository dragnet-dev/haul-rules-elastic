// Dragnet [Ransomware]: dragnet-ransomware-2025-0784 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 95e840a2-c7bc-594a-8246-8def88e8cba8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
