// Dragnet [Ransomware]: dragnet-ransomware-2025-4921 — Recovery Inhibition (kraken)
// Status: experimental | Level: high | ID: bf2d91ff-3b8f-5f0b-b929-e60ec029741a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
