// Dragnet [Ransomware]: dragnet-ransomware-2025-2993 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: b049ac4f-16d6-591d-b4e1-201c1755c114

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
