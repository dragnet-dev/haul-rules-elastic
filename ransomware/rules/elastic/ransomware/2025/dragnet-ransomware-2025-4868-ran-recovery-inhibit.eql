// Dragnet [Ransomware]: dragnet-ransomware-2025-4868 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 354c9e75-64f8-589a-a817-1aba828cc17a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
