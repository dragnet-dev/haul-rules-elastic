// Dragnet [Ransomware]: dragnet-ransomware-2025-3799 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 8792a0b1-f371-5ff8-bff7-b70268527023

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
