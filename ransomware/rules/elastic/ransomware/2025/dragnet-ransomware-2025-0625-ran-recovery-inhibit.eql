// Dragnet [Ransomware]: dragnet-ransomware-2025-0625 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 64960e8b-1d52-5ab8-8901-b555268a4c67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
