// Dragnet [Ransomware]: dragnet-ransomware-2025-0118 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: e5471cdc-32df-5058-818c-ca416364f52b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
