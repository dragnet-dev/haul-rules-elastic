// Dragnet [Ransomware]: dragnet-ransomware-2025-0526 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6c4fadc8-85eb-5a27-bf55-bc52a2c333a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
