// Dragnet [Ransomware]: dragnet-ransomware-2025-5967 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c4063d6b-fc4e-5ca3-abfe-5eff15f07b02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
