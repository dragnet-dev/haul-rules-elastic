// Dragnet [Ransomware]: dragnet-ransomware-2025-4446 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: d9c92dd0-940d-5680-84bd-170d1079683f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
