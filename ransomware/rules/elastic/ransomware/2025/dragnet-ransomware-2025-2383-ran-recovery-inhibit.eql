// Dragnet [Ransomware]: dragnet-ransomware-2025-2383 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8f1a172f-34c6-53f5-94bb-a2fc090995bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
