// Dragnet [Ransomware]: dragnet-ransomware-2025-6718 — Recovery Inhibition (gunra)
// Status: experimental | Level: high | ID: 9882e385-03b3-595d-b7af-c8d78631ff49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
