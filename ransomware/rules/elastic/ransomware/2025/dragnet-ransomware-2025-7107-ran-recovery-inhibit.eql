// Dragnet [Ransomware]: dragnet-ransomware-2025-7107 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3eb4116a-0b69-5e59-8721-4d2bfdd3b374

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
