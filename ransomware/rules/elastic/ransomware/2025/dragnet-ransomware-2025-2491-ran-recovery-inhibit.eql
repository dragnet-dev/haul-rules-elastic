// Dragnet [Ransomware]: dragnet-ransomware-2025-2491 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e43f4fe3-e995-512d-a2e0-81d0496b7af9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
