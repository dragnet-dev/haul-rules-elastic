// Dragnet [Ransomware]: dragnet-ransomware-2025-1784 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: dd0b2ba8-ca24-5b93-add7-75d0748837db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
