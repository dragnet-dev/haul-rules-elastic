// Dragnet [Ransomware]: dragnet-ransomware-2025-0525 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: b9c46d37-c5a8-5377-82ec-af185b893f74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
