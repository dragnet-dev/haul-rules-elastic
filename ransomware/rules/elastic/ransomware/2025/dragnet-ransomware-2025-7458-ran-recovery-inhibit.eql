// Dragnet [Ransomware]: dragnet-ransomware-2025-7458 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f7bccbc2-d71c-5fdf-9256-c89f42ec2efd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
