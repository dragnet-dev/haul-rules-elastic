// Dragnet [Ransomware]: dragnet-ransomware-2025-1241 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: dc8c2673-3d2d-582a-b77a-b58dbe83dd25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
