// Dragnet [Ransomware]: dragnet-ransomware-2025-1240 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: ebeb7174-85fc-5d2a-87f1-fda71ab40fe2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
