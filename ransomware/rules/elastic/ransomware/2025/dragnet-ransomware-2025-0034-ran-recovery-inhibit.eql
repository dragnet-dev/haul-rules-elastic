// Dragnet [Ransomware]: dragnet-ransomware-2025-0034 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: ef2f77a0-db9a-599f-b9e5-1169ac4b2638

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
