// Dragnet [Ransomware]: dragnet-ransomware-2025-3614 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: caf7c5b1-c732-5f1f-b956-d1c7a42e5812

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
