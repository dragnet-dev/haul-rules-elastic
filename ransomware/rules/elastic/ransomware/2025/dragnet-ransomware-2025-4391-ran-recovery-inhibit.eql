// Dragnet [Ransomware]: dragnet-ransomware-2025-4391 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 9c78300c-a674-58ac-be47-b73d33ef461a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
