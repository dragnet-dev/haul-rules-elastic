// Dragnet [Ransomware]: dragnet-ransomware-2025-7927 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 61a43d4e-2445-56e6-b665-9877b65ac78d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
