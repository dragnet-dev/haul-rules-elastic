// Dragnet [Ransomware]: dragnet-ransomware-2025-0630 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 08943b18-276d-5102-a245-d70994a430aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
