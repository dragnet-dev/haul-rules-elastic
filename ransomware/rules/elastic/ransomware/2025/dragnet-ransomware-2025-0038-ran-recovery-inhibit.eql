// Dragnet [Ransomware]: dragnet-ransomware-2025-0038 — Recovery Inhibition (insomnia)
// Status: experimental | Level: high | ID: c8d23db5-5226-5dae-a74c-f4d677de23bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
