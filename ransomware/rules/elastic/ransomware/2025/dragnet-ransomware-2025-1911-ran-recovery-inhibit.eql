// Dragnet [Ransomware]: dragnet-ransomware-2025-1911 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3274f071-c827-5977-8eea-6a617d9ecb8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
