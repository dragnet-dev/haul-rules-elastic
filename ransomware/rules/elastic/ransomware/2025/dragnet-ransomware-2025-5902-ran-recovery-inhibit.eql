// Dragnet [Ransomware]: dragnet-ransomware-2025-5902 — Recovery Inhibition (handala)
// Status: test | Level: high | ID: fa7b837b-4840-55e9-81ff-f528456e7632

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
