// Dragnet [Ransomware]: dragnet-ransomware-2025-0223 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 430bf5eb-9121-54e3-817c-602b5851efde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
