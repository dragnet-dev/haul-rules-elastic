// Dragnet [Ransomware]: dragnet-ransomware-2025-7138 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: f7ad6056-0fa1-523b-85dc-6011472900f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
