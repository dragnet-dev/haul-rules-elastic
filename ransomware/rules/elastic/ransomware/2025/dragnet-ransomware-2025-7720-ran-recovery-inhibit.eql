// Dragnet [Ransomware]: dragnet-ransomware-2025-7720 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 00f2cbb7-0d99-5afb-b761-a20880883ec6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
