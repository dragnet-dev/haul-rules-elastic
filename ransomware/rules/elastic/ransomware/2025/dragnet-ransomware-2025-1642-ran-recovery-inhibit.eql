// Dragnet [Ransomware]: dragnet-ransomware-2025-1642 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ef2a9af9-09d3-5b7e-8498-f4f6968237b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
