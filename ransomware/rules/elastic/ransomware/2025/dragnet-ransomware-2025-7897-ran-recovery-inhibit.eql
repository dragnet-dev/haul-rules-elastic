// Dragnet [Ransomware]: dragnet-ransomware-2025-7897 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 283d01fe-bb3f-5a17-a42e-77ea917c4b1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
