// Dragnet [Ransomware]: dragnet-ransomware-2025-6346 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f0e9b23e-6b14-5648-99b9-4f4304822066

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
