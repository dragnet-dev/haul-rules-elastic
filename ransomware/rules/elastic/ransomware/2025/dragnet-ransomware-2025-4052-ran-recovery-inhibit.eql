// Dragnet [Ransomware]: dragnet-ransomware-2025-4052 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 95421a0f-4d7e-529a-8b56-df2e35fcc4de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
