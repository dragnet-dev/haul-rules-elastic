// Dragnet [Ransomware]: dragnet-ransomware-2025-1536 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 992e6760-773c-585c-9c5d-748e5d468c4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
