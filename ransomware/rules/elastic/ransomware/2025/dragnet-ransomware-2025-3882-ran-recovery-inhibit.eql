// Dragnet [Ransomware]: dragnet-ransomware-2025-3882 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2ed25674-4be0-5ed6-911c-7778914cf125

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
