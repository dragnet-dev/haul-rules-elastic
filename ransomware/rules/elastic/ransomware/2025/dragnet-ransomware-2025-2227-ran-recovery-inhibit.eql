// Dragnet [Ransomware]: dragnet-ransomware-2025-2227 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 1d468f79-8e8f-5afa-babb-e47d5665e261

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
