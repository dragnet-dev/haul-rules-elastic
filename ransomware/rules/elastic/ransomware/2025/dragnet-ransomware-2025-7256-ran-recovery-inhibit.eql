// Dragnet [Ransomware]: dragnet-ransomware-2025-7256 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7b499d4f-2983-528d-a404-c37ca020b74b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
