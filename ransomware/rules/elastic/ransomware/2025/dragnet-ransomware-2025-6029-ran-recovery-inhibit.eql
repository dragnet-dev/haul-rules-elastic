// Dragnet [Ransomware]: dragnet-ransomware-2025-6029 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1637859c-295f-56af-8623-6606e53bd52a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
