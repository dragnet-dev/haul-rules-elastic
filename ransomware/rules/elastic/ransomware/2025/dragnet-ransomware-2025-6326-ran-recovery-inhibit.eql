// Dragnet [Ransomware]: dragnet-ransomware-2025-6326 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 9607308b-1a2c-5825-9961-b2eb8e8328d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
