// Dragnet [Ransomware]: dragnet-ransomware-2025-3803 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: b0197252-9541-5105-838a-f6e627e80156

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
