// Dragnet [Ransomware]: dragnet-ransomware-2025-3543 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3598bbf7-7258-58d1-a20b-64d8739eb57b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
