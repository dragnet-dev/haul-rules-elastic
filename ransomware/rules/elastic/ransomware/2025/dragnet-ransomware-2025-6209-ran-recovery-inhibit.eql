// Dragnet [Ransomware]: dragnet-ransomware-2025-6209 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3feb50c1-e5ca-56cd-98e7-05c11466bce3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
