// Dragnet [Ransomware]: dragnet-ransomware-2025-5409 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 76c83774-13d4-537e-be86-e322e7609374

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
