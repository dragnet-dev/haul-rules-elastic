// Dragnet [Ransomware]: dragnet-ransomware-2025-1728 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 9e17b1e1-910d-5740-bb54-2479456a6afa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
