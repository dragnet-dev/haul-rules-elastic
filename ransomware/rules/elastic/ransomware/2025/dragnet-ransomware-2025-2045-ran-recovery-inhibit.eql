// Dragnet [Ransomware]: dragnet-ransomware-2025-2045 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 30dcfbe6-fdec-56a6-93d0-455a8501434d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
