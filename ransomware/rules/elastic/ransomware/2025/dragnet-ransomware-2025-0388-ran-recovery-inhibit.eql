// Dragnet [Ransomware]: dragnet-ransomware-2025-0388 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 62626907-f980-5877-be62-7d0523251a56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
