// Dragnet [Ransomware]: dragnet-ransomware-2025-6983 — Recovery Inhibition (securotrop)
// Status: test | Level: high | ID: 93a46710-a7ee-551b-9750-49cc951813bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
