// Dragnet [Ransomware]: dragnet-ransomware-2025-3678 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d94087a3-7237-5b3b-8547-554686c79c64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
