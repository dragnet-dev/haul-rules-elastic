// Dragnet [Ransomware]: dragnet-ransomware-2025-2623 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 83bcafaf-e537-5127-a269-7d1816d91870

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
