// Dragnet [Ransomware]: dragnet-ransomware-2025-5696 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: b1344800-6eea-55a0-84eb-357a7e0debff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
