// Dragnet [Ransomware]: dragnet-ransomware-2025-6279 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 84cfbf3d-1d55-5f8c-a8e9-90f69fa73a7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
