// Dragnet [Ransomware]: dragnet-ransomware-2025-7534 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 5b922935-ee8d-5bb8-ada5-beb00a049f9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
