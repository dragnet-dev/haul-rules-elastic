// Dragnet [Ransomware]: dragnet-ransomware-2025-2115 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 5b5b54d5-439c-59be-af53-235207297083

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
