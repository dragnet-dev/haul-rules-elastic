// Dragnet [Ransomware]: dragnet-ransomware-2025-3118 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 1bd3003d-b654-515b-870a-f71731450d86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
