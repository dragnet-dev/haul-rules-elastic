// Dragnet [Ransomware]: dragnet-ransomware-2025-1720 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 9270d94e-db9b-5093-8586-55342d27e0b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
