// Dragnet [Ransomware]: dragnet-ransomware-2025-7353 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 8ead5467-5971-56dc-934e-519116d49891

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
