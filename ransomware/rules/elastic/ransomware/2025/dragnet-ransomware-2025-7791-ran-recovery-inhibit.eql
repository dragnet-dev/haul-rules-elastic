// Dragnet [Ransomware]: dragnet-ransomware-2025-7791 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 18d1c0b7-d489-5ff0-b628-286ecc2ddacf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
