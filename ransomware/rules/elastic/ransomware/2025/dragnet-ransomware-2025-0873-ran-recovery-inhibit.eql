// Dragnet [Ransomware]: dragnet-ransomware-2025-0873 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 92a79099-6978-5555-910f-2d9518458204

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
