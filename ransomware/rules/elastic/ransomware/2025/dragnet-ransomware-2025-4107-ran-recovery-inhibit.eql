// Dragnet [Ransomware]: dragnet-ransomware-2025-4107 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e669519f-d3cf-59c6-868c-745008b57dda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
