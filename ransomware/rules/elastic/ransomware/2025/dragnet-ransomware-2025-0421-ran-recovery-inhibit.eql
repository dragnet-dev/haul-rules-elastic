// Dragnet [Ransomware]: dragnet-ransomware-2025-0421 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 207cc88e-f53f-51b2-bf47-c13b43a892fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
