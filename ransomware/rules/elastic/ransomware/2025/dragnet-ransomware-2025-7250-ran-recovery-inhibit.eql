// Dragnet [Ransomware]: dragnet-ransomware-2025-7250 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: b0348278-fafd-5eb2-b71b-5271ac3885ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
