// Dragnet [Ransomware]: dragnet-ransomware-2025-1521 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 3c3082db-9d69-5741-b512-ac978ccf1b8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
