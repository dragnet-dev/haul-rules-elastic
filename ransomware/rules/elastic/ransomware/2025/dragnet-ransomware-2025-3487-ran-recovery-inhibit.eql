// Dragnet [Ransomware]: dragnet-ransomware-2025-3487 — Recovery Inhibition (obscura)
// Status: deprecated | Level: high | ID: dacb5e96-5f17-5d54-927e-5eff58f2660a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
