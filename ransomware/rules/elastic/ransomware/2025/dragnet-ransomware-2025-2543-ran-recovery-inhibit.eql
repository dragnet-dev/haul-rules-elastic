// Dragnet [Ransomware]: dragnet-ransomware-2025-2543 — Recovery Inhibition (spacebears)
// Status: test | Level: high | ID: 02d80f35-81ee-5f51-a1f0-c37e8cb545ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
