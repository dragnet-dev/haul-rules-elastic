// Dragnet [Ransomware]: dragnet-ransomware-2025-3423 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 735d6af3-7989-5269-b33f-a9cf515a46de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
