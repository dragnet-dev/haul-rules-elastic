// Dragnet [Ransomware]: dragnet-ransomware-2025-6369 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 0a06beb9-6832-554b-80a8-5454021afba1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
