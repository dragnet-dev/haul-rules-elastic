// Dragnet [Ransomware]: dragnet-ransomware-2025-6215 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: b37a3c92-8ee5-51ca-a8b8-9fdfe83adb1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
