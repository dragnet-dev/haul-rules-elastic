// Dragnet [Ransomware]: dragnet-ransomware-2025-3484 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7520d725-5281-55da-87a1-36b5ed8d6ab7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
