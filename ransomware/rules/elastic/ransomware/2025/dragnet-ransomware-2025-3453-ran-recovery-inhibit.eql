// Dragnet [Ransomware]: dragnet-ransomware-2025-3453 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: cd7838ce-4bc0-5981-b560-18d098d056f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
