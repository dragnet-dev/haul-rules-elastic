// Dragnet [Ransomware]: dragnet-ransomware-2025-5269 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: edba6f86-389f-5460-8efb-f161dd6dba74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
