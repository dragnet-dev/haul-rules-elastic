// Dragnet [Ransomware]: dragnet-ransomware-2025-0736 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 85257364-4797-5035-9741-18d43ec732a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
