// Dragnet [Ransomware]: dragnet-ransomware-2025-4193 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 18ee103f-6bd7-57b0-ab71-f3c68435e998

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
