// Dragnet [Ransomware]: dragnet-ransomware-2025-0196 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 39531ea1-9f4d-5e48-ac25-cab35151f005

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
