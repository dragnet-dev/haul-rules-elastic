// Dragnet [Ransomware]: dragnet-ransomware-2025-5351 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: cac5d674-30f9-5c53-a70e-db8b3c04adf4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
