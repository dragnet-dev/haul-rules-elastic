// Dragnet [Ransomware]: dragnet-ransomware-2025-7073 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 8b8e865c-7377-596b-925d-83facb6e93d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
