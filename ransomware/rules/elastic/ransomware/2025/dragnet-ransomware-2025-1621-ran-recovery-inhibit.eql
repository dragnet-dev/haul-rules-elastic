// Dragnet [Ransomware]: dragnet-ransomware-2025-1621 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: eb8d0ca0-f378-59d2-9957-a122eb96c270

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
