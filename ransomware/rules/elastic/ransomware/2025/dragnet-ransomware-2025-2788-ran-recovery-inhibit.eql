// Dragnet [Ransomware]: dragnet-ransomware-2025-2788 — Recovery Inhibition (blackshrantac)
// Status: experimental | Level: high | ID: e59fe3ea-3697-54d5-ae6d-4d492ffb87e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
