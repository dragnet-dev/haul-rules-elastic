// Dragnet [Ransomware]: dragnet-ransomware-2025-4303 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: f8067a31-f603-5c59-a740-5927bc684be1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
