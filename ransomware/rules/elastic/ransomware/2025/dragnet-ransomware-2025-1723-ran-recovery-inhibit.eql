// Dragnet [Ransomware]: dragnet-ransomware-2025-1723 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: c0a5a0d7-389e-5a18-98d0-ddd665c28b6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
