// Dragnet [Ransomware]: dragnet-ransomware-2025-4654 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: e16a2547-ab7b-5e9a-93d8-25a46808b013

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
