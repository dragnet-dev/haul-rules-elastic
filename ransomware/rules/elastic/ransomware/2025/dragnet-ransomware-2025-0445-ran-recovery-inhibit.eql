// Dragnet [Ransomware]: dragnet-ransomware-2025-0445 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: beaeb65a-6827-5086-8fb5-1720da6255ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
