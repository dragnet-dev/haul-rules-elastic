// Dragnet [Ransomware]: dragnet-ransomware-2025-3611 — Recovery Inhibition (bert)
// Status: experimental | Level: high | ID: 6191bbd8-44f0-5cf2-a16e-14c83e99121b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
