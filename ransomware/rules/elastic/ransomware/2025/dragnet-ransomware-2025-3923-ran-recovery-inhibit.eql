// Dragnet [Ransomware]: dragnet-ransomware-2025-3923 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 965ab497-2e41-57da-9faf-ffe5981ba9b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
