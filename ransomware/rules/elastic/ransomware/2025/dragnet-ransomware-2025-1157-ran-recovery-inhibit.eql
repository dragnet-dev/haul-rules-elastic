// Dragnet [Ransomware]: dragnet-ransomware-2025-1157 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 0503e801-2e1e-53d4-9b5a-d155f313373c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
