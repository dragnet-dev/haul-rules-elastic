// Dragnet [Ransomware]: dragnet-ransomware-2025-6342 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 03e9e04c-c5ae-5ac5-ba27-a2fe2bd51fac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
