// Dragnet [Ransomware]: dragnet-ransomware-2025-2186 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: dc67f98c-312d-58aa-a0d1-dec72e6000c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
