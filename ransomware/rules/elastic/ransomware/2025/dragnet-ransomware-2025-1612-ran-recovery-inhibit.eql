// Dragnet [Ransomware]: dragnet-ransomware-2025-1612 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: b52e91d3-6673-5822-b19a-7032a59a1284

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
