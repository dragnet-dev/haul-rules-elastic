// Dragnet [Ransomware]: dragnet-ransomware-2025-4754 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 05360ef2-96b1-5fbc-b332-dc4cf7b67f4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
