// Dragnet [Ransomware]: dragnet-ransomware-2025-3721 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 7797ea0c-5aa9-58cb-8254-72a140431164

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
