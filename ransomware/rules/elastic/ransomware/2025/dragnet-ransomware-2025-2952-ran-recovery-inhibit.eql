// Dragnet [Ransomware]: dragnet-ransomware-2025-2952 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 65bcbfb6-36c2-5db5-ac1d-f5af14a9f0fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
