// Dragnet [Ransomware]: dragnet-ransomware-2025-2079 — Recovery Inhibition (trinity)
// Status: experimental | Level: high | ID: 618029fb-94dd-5250-84e6-46ab121d9fec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
