// Dragnet [Ransomware]: dragnet-ransomware-2025-4296 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 6dd38d76-e4d2-5953-9493-ea1e31b1796f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
