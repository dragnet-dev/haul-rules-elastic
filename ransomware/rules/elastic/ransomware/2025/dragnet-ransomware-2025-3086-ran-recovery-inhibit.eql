// Dragnet [Ransomware]: dragnet-ransomware-2025-3086 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c1525d54-fa7f-528b-85e9-1ed7c549463e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
