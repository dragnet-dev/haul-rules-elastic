// Dragnet [Ransomware]: dragnet-ransomware-2025-4312 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0d9a2dc0-26a8-5b67-b5c5-f9ee3ae78aea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
