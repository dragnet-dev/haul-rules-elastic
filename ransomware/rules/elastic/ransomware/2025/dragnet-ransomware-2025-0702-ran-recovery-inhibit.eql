// Dragnet [Ransomware]: dragnet-ransomware-2025-0702 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 15773274-708f-57b1-b727-7451593841dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
