// Dragnet [Ransomware]: dragnet-ransomware-2025-6144 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4fc22b06-5124-54c0-9846-241fd06c689b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
