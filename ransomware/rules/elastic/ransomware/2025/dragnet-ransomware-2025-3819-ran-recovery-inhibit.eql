// Dragnet [Ransomware]: dragnet-ransomware-2025-3819 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: b70d138d-7926-5374-9a5a-428780e2cdcb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
