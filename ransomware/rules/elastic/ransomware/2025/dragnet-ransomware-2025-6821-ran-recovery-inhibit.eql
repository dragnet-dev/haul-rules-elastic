// Dragnet [Ransomware]: dragnet-ransomware-2025-6821 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 071a965b-9249-51de-b28f-645730e08796

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
