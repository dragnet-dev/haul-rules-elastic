// Dragnet [Ransomware]: dragnet-ransomware-2025-3294 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: 388c5efd-b731-56ed-b470-218101ee5f00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
