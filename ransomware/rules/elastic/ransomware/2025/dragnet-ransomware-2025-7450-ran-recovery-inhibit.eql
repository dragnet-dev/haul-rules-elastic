// Dragnet [Ransomware]: dragnet-ransomware-2025-7450 — Recovery Inhibition (ralord)
// Status: experimental | Level: high | ID: 0341a9ea-8fd5-5bbd-b41b-de327868fbc0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
