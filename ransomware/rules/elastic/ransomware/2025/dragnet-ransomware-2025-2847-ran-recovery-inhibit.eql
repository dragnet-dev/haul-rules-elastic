// Dragnet [Ransomware]: dragnet-ransomware-2025-2847 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 894f5478-334e-5294-abf3-b78ce0912171

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
