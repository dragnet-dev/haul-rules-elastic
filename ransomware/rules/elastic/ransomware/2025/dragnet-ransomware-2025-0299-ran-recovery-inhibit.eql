// Dragnet [Ransomware]: dragnet-ransomware-2025-0299 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: edcb5354-c995-53c0-87cf-9ead073d0da7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
