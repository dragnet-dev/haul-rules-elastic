// Dragnet [Ransomware]: dragnet-ransomware-2025-7590 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5af93bfc-0b44-5ce8-96a0-4bbbf7c05424

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
