// Dragnet [Ransomware]: dragnet-ransomware-2025-4732 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 0ffa22b0-9014-5ba8-82e2-0bd3b542f760

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
