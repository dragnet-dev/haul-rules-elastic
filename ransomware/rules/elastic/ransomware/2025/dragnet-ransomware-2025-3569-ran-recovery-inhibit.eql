// Dragnet [Ransomware]: dragnet-ransomware-2025-3569 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8231b16a-083c-5f05-9989-f5809ec88b4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
