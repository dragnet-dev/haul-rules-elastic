// Dragnet [Ransomware]: dragnet-ransomware-2025-4390 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ebe56047-4f4b-59cc-bd47-6cf5e98e736b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
