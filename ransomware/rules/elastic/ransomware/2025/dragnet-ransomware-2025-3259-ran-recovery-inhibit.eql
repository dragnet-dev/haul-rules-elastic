// Dragnet [Ransomware]: dragnet-ransomware-2025-3259 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 63065894-bf8a-511e-ae4a-866737accb71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
