// Dragnet [Ransomware]: dragnet-ransomware-2025-4962 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 3a023b1b-59da-53cd-8bf9-46eaee486243

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
