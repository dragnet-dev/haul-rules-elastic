// Dragnet [Ransomware]: dragnet-ransomware-2025-3595 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 04141ea6-e127-5a01-8e80-4cb552817b33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
