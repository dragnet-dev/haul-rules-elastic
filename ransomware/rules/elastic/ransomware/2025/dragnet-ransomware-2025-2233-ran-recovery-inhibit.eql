// Dragnet [Ransomware]: dragnet-ransomware-2025-2233 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: ed01ce0e-7726-5941-8dde-0ec6bf3461d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
