// Dragnet [Ransomware]: dragnet-ransomware-2025-0231 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 6d411692-57f9-5871-876e-edb7ddc3f775

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
