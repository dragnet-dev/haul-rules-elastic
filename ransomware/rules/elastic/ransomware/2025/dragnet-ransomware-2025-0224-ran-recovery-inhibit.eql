// Dragnet [Ransomware]: dragnet-ransomware-2025-0224 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: cb0c5f45-3743-5a6b-a2df-ab103faebb48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
