// Dragnet [Ransomware]: dragnet-ransomware-2025-0360 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3cd6882e-4cc3-5ab9-9718-27aa8e5cf75b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
