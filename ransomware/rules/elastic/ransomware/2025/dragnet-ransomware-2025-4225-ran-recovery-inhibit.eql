// Dragnet [Ransomware]: dragnet-ransomware-2025-4225 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: ec327e54-586a-58c5-a350-94ec3f575db7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
