// Dragnet [Ransomware]: dragnet-ransomware-2025-4655 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 3dace89b-013b-5794-8ade-082afb79e52e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
