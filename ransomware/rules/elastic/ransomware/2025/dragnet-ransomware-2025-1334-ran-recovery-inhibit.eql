// Dragnet [Ransomware]: dragnet-ransomware-2025-1334 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 7570e489-8afe-5e7c-baed-d02ff465b808

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
