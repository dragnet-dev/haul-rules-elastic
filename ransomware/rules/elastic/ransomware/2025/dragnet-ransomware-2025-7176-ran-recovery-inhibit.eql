// Dragnet [Ransomware]: dragnet-ransomware-2025-7176 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 0202b5fe-cbf8-545c-935f-bfeaeb68bb5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
