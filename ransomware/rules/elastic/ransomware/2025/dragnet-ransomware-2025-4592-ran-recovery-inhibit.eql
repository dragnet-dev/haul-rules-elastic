// Dragnet [Ransomware]: dragnet-ransomware-2025-4592 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 62978c3a-43ec-5983-aaab-f29c3bcf16c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
