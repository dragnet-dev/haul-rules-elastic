// Dragnet [Ransomware]: dragnet-ransomware-2025-5511 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 66497392-0b4d-55a8-9398-a13c2528449c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
