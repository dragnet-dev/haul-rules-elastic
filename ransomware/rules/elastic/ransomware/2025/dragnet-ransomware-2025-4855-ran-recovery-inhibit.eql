// Dragnet [Ransomware]: dragnet-ransomware-2025-4855 — Recovery Inhibition (IMNCrew)
// Status: experimental | Level: high | ID: b1666cc0-2739-5155-8b38-747ab27a9b4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
