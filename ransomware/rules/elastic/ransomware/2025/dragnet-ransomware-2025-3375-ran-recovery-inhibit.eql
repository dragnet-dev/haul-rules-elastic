// Dragnet [Ransomware]: dragnet-ransomware-2025-3375 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d92b1c37-478f-567b-aeed-7b6fd61fedc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
