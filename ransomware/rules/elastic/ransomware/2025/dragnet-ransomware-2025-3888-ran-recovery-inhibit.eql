// Dragnet [Ransomware]: dragnet-ransomware-2025-3888 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 6e1dd638-7f3a-58b5-991a-34a758de0147

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
