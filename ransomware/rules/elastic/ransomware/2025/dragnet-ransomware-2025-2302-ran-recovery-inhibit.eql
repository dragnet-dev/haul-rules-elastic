// Dragnet [Ransomware]: dragnet-ransomware-2025-2302 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1193b53f-d9ae-566b-b33c-c1db1e75fe10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
