// Dragnet [Ransomware]: dragnet-ransomware-2025-1683 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: dd5a05bd-8577-519d-a596-994fedb1e036

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
