// Dragnet [Ransomware]: dragnet-ransomware-2025-4616 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: b2aa6fa9-e7f7-5add-b314-abdc3acce4c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
