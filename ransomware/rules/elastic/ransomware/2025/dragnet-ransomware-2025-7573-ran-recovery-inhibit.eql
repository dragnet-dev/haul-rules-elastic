// Dragnet [Ransomware]: dragnet-ransomware-2025-7573 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: cc556d93-7412-54a4-bded-585b75b4ed06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
