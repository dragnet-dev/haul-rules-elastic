// Dragnet [Ransomware]: dragnet-ransomware-2025-5010 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 2dc0182d-22ff-525d-98f8-fe46eb8fae45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
