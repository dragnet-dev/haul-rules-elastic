// Dragnet [Ransomware]: dragnet-ransomware-2025-1439 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: cd57f12e-d0f8-5cd8-ae3f-db74b1af890a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
