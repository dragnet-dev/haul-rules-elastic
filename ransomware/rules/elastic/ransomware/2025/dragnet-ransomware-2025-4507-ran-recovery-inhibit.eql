// Dragnet [Ransomware]: dragnet-ransomware-2025-4507 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: cd0a39e5-cd58-5e8d-8de9-8420e636ca99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
