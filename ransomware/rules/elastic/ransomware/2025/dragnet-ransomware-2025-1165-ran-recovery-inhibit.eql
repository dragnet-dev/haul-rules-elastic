// Dragnet [Ransomware]: dragnet-ransomware-2025-1165 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: c6e2a07f-420d-53ba-a2ed-c8f83d66356a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
