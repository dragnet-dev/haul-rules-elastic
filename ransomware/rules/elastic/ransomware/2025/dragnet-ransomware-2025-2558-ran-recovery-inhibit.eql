// Dragnet [Ransomware]: dragnet-ransomware-2025-2558 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ad6d20e1-21c8-5b55-9947-6cf6126f3cc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
