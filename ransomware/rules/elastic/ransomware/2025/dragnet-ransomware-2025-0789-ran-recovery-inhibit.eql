// Dragnet [Ransomware]: dragnet-ransomware-2025-0789 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 65b96318-c5c8-561b-b57d-88e0907371ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
