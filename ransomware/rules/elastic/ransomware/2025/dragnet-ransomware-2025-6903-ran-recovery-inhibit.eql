// Dragnet [Ransomware]: dragnet-ransomware-2025-6903 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 7b34e252-f889-533f-ac21-5e20db4632c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
