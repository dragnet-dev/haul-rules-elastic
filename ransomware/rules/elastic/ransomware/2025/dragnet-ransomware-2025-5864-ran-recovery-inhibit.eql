// Dragnet [Ransomware]: dragnet-ransomware-2025-5864 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b0586bcf-f012-548a-8fea-9706f70269fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
