// Dragnet [Ransomware]: dragnet-ransomware-2025-3672 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 700c552c-a13d-5c96-a968-729fcaae0af5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
