// Dragnet [Ransomware]: dragnet-ransomware-2025-0243 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 9fc0af71-c393-5f61-8c6b-5c3304be4ffe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
