// Dragnet [Ransomware]: dragnet-ransomware-2025-5724 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 0691c178-b4f7-55bd-bc0c-218dafff90fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
