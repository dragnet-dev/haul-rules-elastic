// Dragnet [Ransomware]: dragnet-ransomware-2025-1715 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: a55c86cf-4099-5d82-b002-35248ff017e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
