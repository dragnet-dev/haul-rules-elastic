// Dragnet [Ransomware]: dragnet-ransomware-2025-6305 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 003d8238-e998-5aff-87d9-023629b8a165

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
