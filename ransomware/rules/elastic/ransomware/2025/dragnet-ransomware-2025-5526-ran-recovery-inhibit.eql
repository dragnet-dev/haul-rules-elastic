// Dragnet [Ransomware]: dragnet-ransomware-2025-5526 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: fd942e2e-23e9-54bd-b8ec-6ebb54786f15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
