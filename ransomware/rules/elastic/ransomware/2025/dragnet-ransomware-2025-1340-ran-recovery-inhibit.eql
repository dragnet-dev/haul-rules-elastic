// Dragnet [Ransomware]: dragnet-ransomware-2025-1340 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: f2c4ec50-0add-5893-abe3-89630408aec8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
