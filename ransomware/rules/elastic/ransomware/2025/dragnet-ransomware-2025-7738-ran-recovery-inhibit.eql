// Dragnet [Ransomware]: dragnet-ransomware-2025-7738 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8fb7ab63-f5a1-5dc1-99d4-723a0f9fc4df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
