// Dragnet [Ransomware]: dragnet-ransomware-2025-6924 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b214c1a5-5e91-5124-b0e6-de7477cedbd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
