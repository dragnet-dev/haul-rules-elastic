// Dragnet [Ransomware]: dragnet-ransomware-2025-0061 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: b4aef021-378a-518a-996a-5d7a365b152e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
