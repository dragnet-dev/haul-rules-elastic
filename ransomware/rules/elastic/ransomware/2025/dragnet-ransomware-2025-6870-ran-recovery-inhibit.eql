// Dragnet [Ransomware]: dragnet-ransomware-2025-6870 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e3f59522-8386-530f-8876-92fe7d1f20f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
