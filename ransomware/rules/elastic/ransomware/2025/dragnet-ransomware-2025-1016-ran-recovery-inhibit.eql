// Dragnet [Ransomware]: dragnet-ransomware-2025-1016 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: c1fefbe5-73cb-5c7e-9088-033765762fd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
