// Dragnet [Ransomware]: dragnet-ransomware-2025-4861 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9d5ad85a-dc14-5533-8b95-99eb9df5ba42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
