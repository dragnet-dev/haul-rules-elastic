// Dragnet [Ransomware]: dragnet-ransomware-2025-3616 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 14e66a5a-1a04-5c4d-b407-f0a08b198953

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
