// Dragnet [Ransomware]: dragnet-ransomware-2025-5678 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 8ab7c400-d42c-5098-9f6c-add44e698b0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
