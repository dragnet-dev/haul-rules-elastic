// Dragnet [Ransomware]: dragnet-ransomware-2025-3849 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: dcd5ee02-18a3-5e34-bfa3-0de57cb3d8a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
