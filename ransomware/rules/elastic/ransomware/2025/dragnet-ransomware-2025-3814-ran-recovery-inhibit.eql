// Dragnet [Ransomware]: dragnet-ransomware-2025-3814 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 75de055b-aaee-583b-ac77-773756697d7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
