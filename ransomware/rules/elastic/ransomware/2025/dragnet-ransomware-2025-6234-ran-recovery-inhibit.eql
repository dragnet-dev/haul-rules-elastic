// Dragnet [Ransomware]: dragnet-ransomware-2025-6234 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: d85767ad-c6f0-5b4d-b0a3-4eee4782161d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
