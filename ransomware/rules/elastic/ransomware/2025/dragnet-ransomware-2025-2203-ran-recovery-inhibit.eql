// Dragnet [Ransomware]: dragnet-ransomware-2025-2203 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 0472064e-9386-53c5-9c7a-fc46cb638906

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
