// Dragnet [Ransomware]: dragnet-ransomware-2025-6037 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 75570d38-81a2-5858-b044-6285d2d225a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
