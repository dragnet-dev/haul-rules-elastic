// Dragnet [Ransomware]: dragnet-ransomware-2025-6914 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 146ae8c5-1260-5f6c-b64f-89d60f1c147a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
