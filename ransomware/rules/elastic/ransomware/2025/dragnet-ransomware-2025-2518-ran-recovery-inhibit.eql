// Dragnet [Ransomware]: dragnet-ransomware-2025-2518 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: e936fd07-4e6d-5f3a-9ff7-e6e826afbdc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
