// Dragnet [Ransomware]: dragnet-ransomware-2025-4828 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 93ffc944-4ff5-58af-9cc7-25ae466bab0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
