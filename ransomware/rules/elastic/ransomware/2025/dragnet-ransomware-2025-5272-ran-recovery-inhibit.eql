// Dragnet [Ransomware]: dragnet-ransomware-2025-5272 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f3c67346-198e-543d-b0ad-f43221c00a4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
