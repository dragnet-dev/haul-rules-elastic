// Dragnet [Ransomware]: dragnet-ransomware-2025-6759 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 9c0945b3-b376-5086-9e8e-876e6edb0e42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
