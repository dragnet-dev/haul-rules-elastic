// Dragnet [Ransomware]: dragnet-ransomware-2025-1523 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 8c117bd3-9292-5552-834b-424e2b600c3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
