// Dragnet [Ransomware]: dragnet-ransomware-2025-5832 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 465961fe-847d-5e0a-bb5f-e5a138bfe265

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
