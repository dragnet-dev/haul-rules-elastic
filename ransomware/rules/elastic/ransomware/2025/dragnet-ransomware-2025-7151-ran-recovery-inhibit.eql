// Dragnet [Ransomware]: dragnet-ransomware-2025-7151 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 6ff250a6-83a2-5527-ae42-050cda0e3756

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
