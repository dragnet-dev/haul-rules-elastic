// Dragnet [Ransomware]: dragnet-ransomware-2025-3650 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 484d72bc-6332-5678-9f20-d7a4b6949020

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
