// Dragnet [Ransomware]: dragnet-ransomware-2025-7049 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 8b89509c-7710-5cde-a3af-58cbb451e320

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
