// Dragnet [Ransomware]: dragnet-ransomware-2025-0296 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 63ce433c-5062-5149-afb9-54c3e9f31479

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
