// Dragnet [Ransomware]: dragnet-ransomware-2025-5531 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f9bafb65-3b87-5755-b6a8-6f30576fac2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
