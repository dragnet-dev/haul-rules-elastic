// Dragnet [Ransomware]: dragnet-ransomware-2025-7527 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c4391b46-a639-54fc-b106-cbb495b49b4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
