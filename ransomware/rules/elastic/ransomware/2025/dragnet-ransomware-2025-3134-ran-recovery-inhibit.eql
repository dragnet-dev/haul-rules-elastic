// Dragnet [Ransomware]: dragnet-ransomware-2025-3134 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 392335be-6d4f-52c1-9a81-0c3563b31e58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
