// Dragnet [Ransomware]: dragnet-ransomware-2025-5007 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e24665b5-a978-5208-8278-90242c15f62f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
