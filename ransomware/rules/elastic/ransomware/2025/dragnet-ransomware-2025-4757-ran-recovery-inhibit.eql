// Dragnet [Ransomware]: dragnet-ransomware-2025-4757 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 75d6ac14-d16e-5d35-b8d7-849281b3ed0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
