// Dragnet [Ransomware]: dragnet-ransomware-2025-7133 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 6554c077-b4b8-5bfe-9075-8d05cef1bbd2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
