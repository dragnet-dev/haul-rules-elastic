// Dragnet [Ransomware]: dragnet-ransomware-2025-3433 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 337c9e33-b134-5210-b26c-0fc88e7572b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
