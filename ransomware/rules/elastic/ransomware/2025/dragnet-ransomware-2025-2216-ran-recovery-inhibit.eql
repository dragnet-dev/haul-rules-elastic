// Dragnet [Ransomware]: dragnet-ransomware-2025-2216 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: bbb29fa2-3491-54c0-9f6d-9d4e03c37b97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
