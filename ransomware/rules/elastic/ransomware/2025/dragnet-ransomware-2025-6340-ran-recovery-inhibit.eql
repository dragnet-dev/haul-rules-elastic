// Dragnet [Ransomware]: dragnet-ransomware-2025-6340 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: f102f8d9-9142-5685-885d-da4f7c7be455

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
