// Dragnet [Ransomware]: dragnet-ransomware-2025-2256 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2ec35e7d-e2e1-5606-8798-fa0699f35cdc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
