// Dragnet [Ransomware]: dragnet-ransomware-2025-3824 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0cdafc51-348f-58d9-9ce4-db0c21efe9d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
