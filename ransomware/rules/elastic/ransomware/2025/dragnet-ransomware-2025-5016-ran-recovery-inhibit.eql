// Dragnet [Ransomware]: dragnet-ransomware-2025-5016 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ed0c8f61-aea1-5f22-b310-fe1cba676b12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
