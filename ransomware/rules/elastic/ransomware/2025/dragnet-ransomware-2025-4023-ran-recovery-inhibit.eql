// Dragnet [Ransomware]: dragnet-ransomware-2025-4023 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: 585ab47f-165f-5612-91e9-bad97a2e40e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
