// Dragnet [Ransomware]: dragnet-ransomware-2025-3811 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: c99a579a-ebb3-53a6-bffd-8945eb023279

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
