// Dragnet [Ransomware]: dragnet-ransomware-2025-7893 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a8697862-dd7f-55db-8331-f337eb692b98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
