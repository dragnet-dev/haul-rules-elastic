// Dragnet [Ransomware]: dragnet-ransomware-2025-7755 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: f41ff1ec-bbf3-5dd3-b57b-27761cd90a2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
