// Dragnet [Ransomware]: dragnet-ransomware-2025-4588 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9fb3ad56-25bb-5d2f-92dc-b66d460a5033

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
