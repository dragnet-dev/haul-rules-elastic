// Dragnet [Ransomware]: dragnet-ransomware-2025-3834 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 13846272-9912-5e23-9b7a-0ff7e1af1d75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
