// Dragnet [Ransomware]: dragnet-ransomware-2025-7757 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 41d76916-3d81-5b80-9090-54625e532d02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
