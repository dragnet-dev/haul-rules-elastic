// Dragnet [Ransomware]: dragnet-ransomware-2025-0430 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 33e794f2-8953-5b9b-95fe-71355ef3c49d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
