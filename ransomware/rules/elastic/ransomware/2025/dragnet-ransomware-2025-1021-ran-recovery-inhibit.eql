// Dragnet [Ransomware]: dragnet-ransomware-2025-1021 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 233bd74e-f17e-5ea7-b96a-38b63b51fbc1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
