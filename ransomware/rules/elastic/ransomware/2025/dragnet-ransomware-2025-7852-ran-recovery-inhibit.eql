// Dragnet [Ransomware]: dragnet-ransomware-2025-7852 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 9ca2efeb-a2a6-5320-892b-c7dd4a95d71a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
