// Dragnet [Ransomware]: dragnet-ransomware-2025-4824 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 0716f873-0369-5ac0-b998-e303e78840c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
