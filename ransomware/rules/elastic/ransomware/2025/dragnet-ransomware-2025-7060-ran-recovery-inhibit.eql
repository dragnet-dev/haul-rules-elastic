// Dragnet [Ransomware]: dragnet-ransomware-2025-7060 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 1577f04e-80c1-5a69-a207-0550f64a1180

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
