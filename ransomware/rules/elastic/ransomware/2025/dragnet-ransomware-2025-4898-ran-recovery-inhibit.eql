// Dragnet [Ransomware]: dragnet-ransomware-2025-4898 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 7fa3e44e-d74f-57ec-b239-e372ec098992

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
