// Dragnet [Ransomware]: dragnet-ransomware-2025-7608 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 78c4cd98-8b42-5741-a91b-870f741c4eec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
