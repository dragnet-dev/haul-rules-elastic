// Dragnet [Ransomware]: dragnet-ransomware-2025-0043 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: cdd14683-90fd-5de5-a742-356381bbd16c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
