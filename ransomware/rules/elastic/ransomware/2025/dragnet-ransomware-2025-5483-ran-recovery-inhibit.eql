// Dragnet [Ransomware]: dragnet-ransomware-2025-5483 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: fd69fcdf-eceb-52e9-bef9-768557a9ddf1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
