// Dragnet [Ransomware]: dragnet-ransomware-2025-1744 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: d7fe3384-1c01-529e-a585-daf5418cf6bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
