// Dragnet [Ransomware]: dragnet-ransomware-2025-0005 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 5707ee02-2281-5742-93fc-f943dbfe93ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
