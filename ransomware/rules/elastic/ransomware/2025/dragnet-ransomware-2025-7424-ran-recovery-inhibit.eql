// Dragnet [Ransomware]: dragnet-ransomware-2025-7424 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e402b5ea-866d-5985-aec3-b66ebce07172

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
