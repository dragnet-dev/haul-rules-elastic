// Dragnet [Ransomware]: dragnet-ransomware-2025-6240 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 0d1601a5-fced-550b-a874-8a9493756581

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
