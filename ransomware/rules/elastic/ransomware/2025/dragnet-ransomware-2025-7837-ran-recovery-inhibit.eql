// Dragnet [Ransomware]: dragnet-ransomware-2025-7837 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 5e882cf5-0dff-5df7-9e05-79a0f353b6e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
