// Dragnet [Ransomware]: dragnet-ransomware-2025-4733 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c783d514-05ba-5e65-932c-05cedade9fef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
