// Dragnet [Ransomware]: dragnet-ransomware-2025-3472 — Recovery Inhibition (arkana)
// Status: experimental | Level: high | ID: 4c4eca1e-e8e8-57d8-96e6-fbd2484a9990

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
