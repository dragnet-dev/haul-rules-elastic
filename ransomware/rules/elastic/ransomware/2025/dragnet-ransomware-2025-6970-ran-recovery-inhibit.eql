// Dragnet [Ransomware]: dragnet-ransomware-2025-6970 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: ef434138-3f53-59b1-8853-bc032b003862

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
