// Dragnet [Ransomware]: dragnet-ransomware-2025-2358 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 28f1c326-6589-529d-96d3-6d112972215c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
