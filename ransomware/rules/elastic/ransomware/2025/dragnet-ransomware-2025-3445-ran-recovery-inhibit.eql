// Dragnet [Ransomware]: dragnet-ransomware-2025-3445 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: f5509180-3ac0-562f-9005-5648482e048d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
