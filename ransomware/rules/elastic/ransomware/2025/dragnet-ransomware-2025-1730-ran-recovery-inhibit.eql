// Dragnet [Ransomware]: dragnet-ransomware-2025-1730 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: d5874361-ecaa-58d5-ace3-3ff3c1f9723a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
