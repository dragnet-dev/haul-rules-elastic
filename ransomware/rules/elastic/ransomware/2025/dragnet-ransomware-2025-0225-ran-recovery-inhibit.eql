// Dragnet [Ransomware]: dragnet-ransomware-2025-0225 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 08850c68-9432-53c2-bf7a-2f4203633120

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
