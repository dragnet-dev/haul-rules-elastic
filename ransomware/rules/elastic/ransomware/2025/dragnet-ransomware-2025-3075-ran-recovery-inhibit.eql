// Dragnet [Ransomware]: dragnet-ransomware-2025-3075 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 2b9c4108-82ee-50c1-94bb-b5d1fad130b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
