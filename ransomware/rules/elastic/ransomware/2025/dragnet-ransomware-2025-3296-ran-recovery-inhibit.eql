// Dragnet [Ransomware]: dragnet-ransomware-2025-3296 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 2e3dcb87-4680-5236-8449-d63a8b38b3c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
