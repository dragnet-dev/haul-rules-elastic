// Dragnet [Ransomware]: dragnet-ransomware-2025-2318 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6d1b5a26-052e-5530-a92a-0712a5982577

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
