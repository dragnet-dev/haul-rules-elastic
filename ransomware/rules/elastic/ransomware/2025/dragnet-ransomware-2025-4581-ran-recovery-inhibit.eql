// Dragnet [Ransomware]: dragnet-ransomware-2025-4581 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3358ffa1-2df6-5b31-8277-4ccbe683a873

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
