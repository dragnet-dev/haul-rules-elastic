// Dragnet [Ransomware]: dragnet-ransomware-2025-3962 — Recovery Inhibition (worldleaks)
// Status: test | Level: high | ID: f6dfb271-b7ad-50ee-8a3c-e1c331aa28c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
