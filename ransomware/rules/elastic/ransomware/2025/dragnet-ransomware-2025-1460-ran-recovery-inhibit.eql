// Dragnet [Ransomware]: dragnet-ransomware-2025-1460 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: dc433a78-3b50-5f42-bf04-42afecea9e8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
