// Dragnet [Ransomware]: dragnet-ransomware-2025-1295 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 24696561-5e69-5206-8299-acbacbe917d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
