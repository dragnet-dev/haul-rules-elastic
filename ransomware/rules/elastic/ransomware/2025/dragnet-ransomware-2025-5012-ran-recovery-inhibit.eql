// Dragnet [Ransomware]: dragnet-ransomware-2025-5012 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 8888c49d-c47b-5b4a-a4d6-337cf1f411bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
