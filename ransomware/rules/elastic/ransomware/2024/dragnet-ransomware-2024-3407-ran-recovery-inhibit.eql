// Dragnet [Ransomware]: dragnet-ransomware-2024-3407 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 2e70f8d1-2f95-5be9-b5b0-67248d3db95d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
