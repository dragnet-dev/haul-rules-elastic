// Dragnet [Ransomware]: dragnet-ransomware-2024-1536 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 5fc6b538-e324-55b0-905f-c7d9b7969e6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
