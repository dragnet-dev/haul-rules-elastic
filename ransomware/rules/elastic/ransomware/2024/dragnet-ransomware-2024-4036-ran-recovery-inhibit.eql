// Dragnet [Ransomware]: dragnet-ransomware-2024-4036 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: ab0a7cf6-7107-5cca-a726-41558fb3966c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
