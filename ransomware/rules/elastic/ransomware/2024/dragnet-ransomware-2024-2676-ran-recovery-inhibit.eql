// Dragnet [Ransomware]: dragnet-ransomware-2024-2676 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5fb58e94-735a-50b2-801c-836c0e646c7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
