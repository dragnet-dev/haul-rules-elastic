// Dragnet [Ransomware]: dragnet-ransomware-2024-4633 — Recovery Inhibition (qiulong)
// Status: experimental | Level: high | ID: 164b2af7-458e-5381-ab33-ae7ad09ee58c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
