// Dragnet [Ransomware]: dragnet-ransomware-2024-3172 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7e651dc1-b203-5cb1-8ee5-5119587cff11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
