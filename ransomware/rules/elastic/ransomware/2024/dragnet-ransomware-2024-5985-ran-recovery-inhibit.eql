// Dragnet [Ransomware]: dragnet-ransomware-2024-5985 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 13c8936d-d872-52c3-ac54-60b5f8411c22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
