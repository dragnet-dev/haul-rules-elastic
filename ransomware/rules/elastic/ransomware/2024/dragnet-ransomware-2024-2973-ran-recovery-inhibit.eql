// Dragnet [Ransomware]: dragnet-ransomware-2024-2973 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 83a9b586-2f5f-5a96-b385-51e8375d2426

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
