// Dragnet [Ransomware]: dragnet-ransomware-2024-0182 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 76da0fa0-7423-5ab9-9ebc-8f8bf4b97be8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
