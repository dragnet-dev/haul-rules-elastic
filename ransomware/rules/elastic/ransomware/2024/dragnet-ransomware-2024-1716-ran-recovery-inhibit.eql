// Dragnet [Ransomware]: dragnet-ransomware-2024-1716 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4d073c09-97e6-5a14-88b3-3ab3d175fe68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
