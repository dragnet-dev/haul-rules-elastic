// Dragnet [Ransomware]: dragnet-ransomware-2024-4893 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 8df71f46-f445-5981-968b-2b0b828805ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
