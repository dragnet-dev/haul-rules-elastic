// Dragnet [Ransomware]: dragnet-ransomware-2024-1100 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0d6011f7-9579-51e7-a9dc-ac29b52802fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
