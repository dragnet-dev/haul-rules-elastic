// Dragnet [Ransomware]: dragnet-ransomware-2024-1569 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 2ed9a67a-369c-5a5f-a942-9cba9c51cb81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
