// Dragnet [Ransomware]: dragnet-ransomware-2024-3402 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 2a176acd-3f65-59e1-8627-486061c685c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
