// Dragnet [Ransomware]: dragnet-ransomware-2024-5376 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: c5ef8712-3d60-552a-a521-9fc8be10f88a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
