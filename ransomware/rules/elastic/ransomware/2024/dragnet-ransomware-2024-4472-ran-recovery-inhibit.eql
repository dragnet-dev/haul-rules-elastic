// Dragnet [Ransomware]: dragnet-ransomware-2024-4472 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 2c748628-e218-5379-a0d0-4fcc1ce71c00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
