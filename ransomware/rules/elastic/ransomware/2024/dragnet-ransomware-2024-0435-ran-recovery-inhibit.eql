// Dragnet [Ransomware]: dragnet-ransomware-2024-0435 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 500c899a-d767-577a-bb3e-fec8c78bbaeb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
