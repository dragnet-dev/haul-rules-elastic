// Dragnet [Ransomware]: dragnet-ransomware-2024-0909 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 45a78ccf-5c89-5494-9d41-d26635dde738

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
