// Dragnet [Ransomware]: dragnet-ransomware-2024-6032 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: aaf5a1e5-cf4e-58c1-85d9-91065d014797

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
