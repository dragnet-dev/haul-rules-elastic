// Dragnet [Ransomware]: dragnet-ransomware-2024-5261 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 035da179-78e5-5039-a2d1-4e23f1a1b62a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
