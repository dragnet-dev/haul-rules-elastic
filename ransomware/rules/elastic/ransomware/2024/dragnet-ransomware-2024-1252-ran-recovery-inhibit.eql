// Dragnet [Ransomware]: dragnet-ransomware-2024-1252 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: b772f706-ff5c-5f06-abce-08d213449e3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
