// Dragnet [Ransomware]: dragnet-ransomware-2024-1427 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 103a6a9b-f351-5f0d-8a64-ff46430232ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
