// Dragnet [Ransomware]: dragnet-ransomware-2024-4510 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: e45bc8f0-ca9a-5f0b-ba5b-992de9646d4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
