// Dragnet [Ransomware]: dragnet-ransomware-2024-3370 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 1056ee29-3f88-5c40-bedd-4ebcc266f3c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
