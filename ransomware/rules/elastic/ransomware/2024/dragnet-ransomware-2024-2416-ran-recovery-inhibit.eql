// Dragnet [Ransomware]: dragnet-ransomware-2024-2416 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: aa3092f7-38d7-5728-950d-d876a5a0c555

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
