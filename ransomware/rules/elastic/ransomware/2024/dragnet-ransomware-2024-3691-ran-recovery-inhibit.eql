// Dragnet [Ransomware]: dragnet-ransomware-2024-3691 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: fd676548-fd2f-5348-b061-8c2ce711297f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
