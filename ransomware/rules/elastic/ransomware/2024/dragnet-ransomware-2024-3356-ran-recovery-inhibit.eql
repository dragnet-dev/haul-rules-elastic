// Dragnet [Ransomware]: dragnet-ransomware-2024-3356 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 77b5af7f-3c48-5ac5-99b9-de44601d5e2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
