// Dragnet [Ransomware]: dragnet-ransomware-2024-4939 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 1fb335e0-5da6-5800-90fe-617e86b6f7e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
