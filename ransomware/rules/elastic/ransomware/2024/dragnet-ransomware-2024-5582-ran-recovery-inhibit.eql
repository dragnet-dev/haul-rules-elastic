// Dragnet [Ransomware]: dragnet-ransomware-2024-5582 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: baa16958-59ed-596f-9579-cb5a1066291d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
