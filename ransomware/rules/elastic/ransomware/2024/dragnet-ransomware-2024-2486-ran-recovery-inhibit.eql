// Dragnet [Ransomware]: dragnet-ransomware-2024-2486 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: c5b24044-468b-5027-a31c-f2d912bea941

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
