// Dragnet [Ransomware]: dragnet-ransomware-2024-4320 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 975bce58-1189-5a50-a109-bcc338413076

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
