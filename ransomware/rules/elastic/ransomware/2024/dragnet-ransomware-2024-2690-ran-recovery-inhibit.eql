// Dragnet [Ransomware]: dragnet-ransomware-2024-2690 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 1cff5bdf-077a-5544-9911-7675da655b77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
