// Dragnet [Ransomware]: dragnet-ransomware-2024-5897 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 64f0523d-6b45-52c0-8127-d0baecfb2b40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
