// Dragnet [Ransomware]: dragnet-ransomware-2024-2890 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 11371d19-07ce-5ea0-9174-226ae340a29e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
