// Dragnet [Ransomware]: dragnet-ransomware-2024-4124 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a1498546-b152-586f-aaee-3c63df6082cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
