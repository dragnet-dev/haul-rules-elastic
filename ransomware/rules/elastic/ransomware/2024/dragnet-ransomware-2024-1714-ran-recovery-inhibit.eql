// Dragnet [Ransomware]: dragnet-ransomware-2024-1714 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 6b6cddf2-e04c-523e-a747-2737a72824f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
