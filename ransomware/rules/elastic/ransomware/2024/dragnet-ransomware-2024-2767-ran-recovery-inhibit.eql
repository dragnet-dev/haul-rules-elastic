// Dragnet [Ransomware]: dragnet-ransomware-2024-2767 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5b833a01-3377-5e77-9714-661bdda50ea8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
