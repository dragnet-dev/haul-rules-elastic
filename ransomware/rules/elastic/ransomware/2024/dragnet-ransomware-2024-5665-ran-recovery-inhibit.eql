// Dragnet [Ransomware]: dragnet-ransomware-2024-5665 — Recovery Inhibition (redransomware)
// Status: deprecated | Level: high | ID: fd7480d8-4e9e-57ad-acd1-0257671157a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
