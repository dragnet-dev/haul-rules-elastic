// Dragnet [Ransomware]: dragnet-ransomware-2024-4781 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: eb5c3273-688c-5212-8d38-dcd8b4281222

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
