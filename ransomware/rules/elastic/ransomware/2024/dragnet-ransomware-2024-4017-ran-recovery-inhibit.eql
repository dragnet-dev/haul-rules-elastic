// Dragnet [Ransomware]: dragnet-ransomware-2024-4017 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 6615cb4f-dea1-5236-9e79-a5afecccd314

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
