// Dragnet [Ransomware]: dragnet-ransomware-2024-1321 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 55cd0819-d528-5ff4-baeb-6d8d662bd35a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
