// Dragnet [Ransomware]: dragnet-ransomware-2024-3861 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8c6ec81e-b71e-52c0-a537-98f40e793d3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
