// Dragnet [Ransomware]: dragnet-ransomware-2024-3832 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 853e6edc-5e46-5661-b9dc-2e4d2cc4a1e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
