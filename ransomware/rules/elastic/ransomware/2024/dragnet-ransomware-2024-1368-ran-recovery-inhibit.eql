// Dragnet [Ransomware]: dragnet-ransomware-2024-1368 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d73e7655-01f4-5a7b-a0fd-a6467018e3b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
