// Dragnet [Ransomware]: dragnet-ransomware-2024-4114 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: b95904cf-992b-533e-82da-70eea5207a71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
