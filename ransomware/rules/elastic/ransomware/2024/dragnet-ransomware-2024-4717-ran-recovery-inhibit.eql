// Dragnet [Ransomware]: dragnet-ransomware-2024-4717 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c898b2c8-7700-5798-8fc2-74139836406c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
