// Dragnet [Ransomware]: dragnet-ransomware-2024-5001 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: a8f40580-3761-5f5e-925c-47059d48aefc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
