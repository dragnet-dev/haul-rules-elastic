// Dragnet [Ransomware]: dragnet-ransomware-2024-0818 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b36e8072-8c61-5e0a-b026-7367d301c439

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
