// Dragnet [Ransomware]: dragnet-ransomware-2024-2368 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: c23c6508-59bd-5a81-aca6-2a1850807b11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
