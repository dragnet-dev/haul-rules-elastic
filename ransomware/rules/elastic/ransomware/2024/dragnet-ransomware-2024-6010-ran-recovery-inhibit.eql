// Dragnet [Ransomware]: dragnet-ransomware-2024-6010 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 1348b9b1-517f-5351-ac7f-d8a259aac941

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
