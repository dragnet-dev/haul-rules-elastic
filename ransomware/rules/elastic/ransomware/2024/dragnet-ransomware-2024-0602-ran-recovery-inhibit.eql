// Dragnet [Ransomware]: dragnet-ransomware-2024-0602 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a698a8ff-fa87-5336-9871-16bf917c5454

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
