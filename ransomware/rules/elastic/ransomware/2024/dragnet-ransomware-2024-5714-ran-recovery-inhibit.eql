// Dragnet [Ransomware]: dragnet-ransomware-2024-5714 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 57e92299-bf43-50d6-ac0f-d2eb6b5a783c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
