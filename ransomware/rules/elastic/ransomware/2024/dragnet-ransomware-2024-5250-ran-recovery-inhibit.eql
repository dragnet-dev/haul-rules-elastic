// Dragnet [Ransomware]: dragnet-ransomware-2024-5250 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 424b4032-5e5d-5471-b70d-61560398ea1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
