// Dragnet [Ransomware]: dragnet-ransomware-2024-4941 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: abcb43ea-f592-5531-807b-3fed655f5604

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
