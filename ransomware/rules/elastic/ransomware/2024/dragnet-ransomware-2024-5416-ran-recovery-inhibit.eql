// Dragnet [Ransomware]: dragnet-ransomware-2024-5416 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b1e39a5a-85e6-5f75-81a5-a67450798e2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
