// Dragnet [Ransomware]: dragnet-ransomware-2024-5470 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: c45cb72b-0a40-512c-8968-3546825db7b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
