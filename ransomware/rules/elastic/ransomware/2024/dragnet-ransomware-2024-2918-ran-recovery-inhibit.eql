// Dragnet [Ransomware]: dragnet-ransomware-2024-2918 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: cec28664-c36c-5f64-8f55-b6904ae94a08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
