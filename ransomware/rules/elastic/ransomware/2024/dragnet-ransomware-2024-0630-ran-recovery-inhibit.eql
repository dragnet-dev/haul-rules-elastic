// Dragnet [Ransomware]: dragnet-ransomware-2024-0630 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 2245e6ef-28d7-5368-a277-0b270b2be71f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
