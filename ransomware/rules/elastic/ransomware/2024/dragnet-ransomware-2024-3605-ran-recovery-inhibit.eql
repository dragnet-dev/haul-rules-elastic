// Dragnet [Ransomware]: dragnet-ransomware-2024-3605 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 4d887c2a-8c6d-5448-8067-0e9fce08b33f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
