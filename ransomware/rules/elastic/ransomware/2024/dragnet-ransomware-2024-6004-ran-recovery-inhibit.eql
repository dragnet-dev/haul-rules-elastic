// Dragnet [Ransomware]: dragnet-ransomware-2024-6004 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: b9c2f9fe-05b4-5f78-a3c2-cadc1f0ada3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
