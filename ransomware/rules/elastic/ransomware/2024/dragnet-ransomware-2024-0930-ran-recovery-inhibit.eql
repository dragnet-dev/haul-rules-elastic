// Dragnet [Ransomware]: dragnet-ransomware-2024-0930 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 425ae428-f06c-5fd6-8cd2-54da8c5956ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
