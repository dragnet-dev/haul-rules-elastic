// Dragnet [Ransomware]: dragnet-ransomware-2024-6034 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: dc993e47-0318-552e-84df-aa8707485ce9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
