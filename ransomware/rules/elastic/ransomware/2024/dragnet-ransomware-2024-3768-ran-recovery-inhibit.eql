// Dragnet [Ransomware]: dragnet-ransomware-2024-3768 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: 60f01212-0f32-501f-bbf4-8c986c2d2d7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
