// Dragnet [Ransomware]: dragnet-ransomware-2024-1904 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 59f553b4-e5b2-5299-b6d9-177597c18dce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
