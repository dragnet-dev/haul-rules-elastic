// Dragnet [Ransomware]: dragnet-ransomware-2024-3728 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: bae71131-616c-565a-8bf4-40a070bbe7c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
