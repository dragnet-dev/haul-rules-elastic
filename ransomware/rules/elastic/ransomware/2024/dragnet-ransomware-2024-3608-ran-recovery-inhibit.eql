// Dragnet [Ransomware]: dragnet-ransomware-2024-3608 — Recovery Inhibition (redransomware)
// Status: deprecated | Level: high | ID: 5b5e590a-7329-5c27-9aa2-b701590e14a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
