// Dragnet [Ransomware]: dragnet-ransomware-2024-2515 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 51f68879-0d3b-523d-9dac-17d2f8387892

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
