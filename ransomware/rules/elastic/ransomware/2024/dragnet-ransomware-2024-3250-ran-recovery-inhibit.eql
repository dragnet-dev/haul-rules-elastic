// Dragnet [Ransomware]: dragnet-ransomware-2024-3250 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8d991b2f-03ce-5800-856a-794f316aa10b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
