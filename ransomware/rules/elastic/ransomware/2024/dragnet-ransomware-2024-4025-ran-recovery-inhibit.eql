// Dragnet [Ransomware]: dragnet-ransomware-2024-4025 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: cbdecee8-aa3e-5eb6-8890-bfc28affa210

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
