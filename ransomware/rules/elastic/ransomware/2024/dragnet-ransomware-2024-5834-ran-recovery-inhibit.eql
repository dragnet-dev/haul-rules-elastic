// Dragnet [Ransomware]: dragnet-ransomware-2024-5834 — Recovery Inhibition (argonauts)
// Status: experimental | Level: high | ID: a9777756-979e-594b-b735-dd8c29c14074

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
