// Dragnet [Ransomware]: dragnet-ransomware-2024-5072 — Recovery Inhibition (frag)
// Status: deprecated | Level: high | ID: 6aa7d98b-a769-5bf5-845f-4c357778cde5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
