// Dragnet [Ransomware]: dragnet-ransomware-2024-4256 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c13e1076-115d-594a-bc52-9863893b0627

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
