// Dragnet [Ransomware]: dragnet-ransomware-2024-3085 — Recovery Inhibition (moneymessage)
// Status: experimental | Level: high | ID: 2448a3c6-18fa-5cbd-8797-c6cb7b510653

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
