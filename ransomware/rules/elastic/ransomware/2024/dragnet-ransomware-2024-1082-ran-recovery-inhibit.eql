// Dragnet [Ransomware]: dragnet-ransomware-2024-1082 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 253fb7d4-7ae0-593e-9305-2f914500ca2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
