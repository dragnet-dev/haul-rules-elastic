// Dragnet [Ransomware]: dragnet-ransomware-2024-4623 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: be0582ae-e318-5c07-b0ac-43a3279625a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
