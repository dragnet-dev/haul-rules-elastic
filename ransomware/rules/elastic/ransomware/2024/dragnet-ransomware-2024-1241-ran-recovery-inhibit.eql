// Dragnet [Ransomware]: dragnet-ransomware-2024-1241 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f0a3a793-05ff-586e-9c25-8783c3b9b008

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
