// Dragnet [Ransomware]: dragnet-ransomware-2024-1962 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 451afba2-7da7-5e25-b11e-f8bbccffe796

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
