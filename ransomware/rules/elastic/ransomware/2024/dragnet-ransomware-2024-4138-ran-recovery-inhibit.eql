// Dragnet [Ransomware]: dragnet-ransomware-2024-4138 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 100170c0-7556-5236-af5a-0dba80ffebe6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
