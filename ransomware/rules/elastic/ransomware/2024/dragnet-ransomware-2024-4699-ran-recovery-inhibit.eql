// Dragnet [Ransomware]: dragnet-ransomware-2024-4699 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: bce16c6e-dd2c-5d36-98a6-42d93ff2d018

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
