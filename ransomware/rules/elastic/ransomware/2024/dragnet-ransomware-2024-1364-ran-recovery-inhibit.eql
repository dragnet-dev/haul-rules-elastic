// Dragnet [Ransomware]: dragnet-ransomware-2024-1364 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: a80ace79-f4a9-512e-8a8e-4cbf7e1e0ba7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
