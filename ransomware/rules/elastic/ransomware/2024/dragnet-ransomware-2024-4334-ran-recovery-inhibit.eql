// Dragnet [Ransomware]: dragnet-ransomware-2024-4334 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 1ef38a79-9526-5635-9372-8bb7257368a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
