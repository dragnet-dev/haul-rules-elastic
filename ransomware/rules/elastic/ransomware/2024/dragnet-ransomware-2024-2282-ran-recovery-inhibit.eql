// Dragnet [Ransomware]: dragnet-ransomware-2024-2282 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2ca48c00-9afb-51fc-bc68-118c02a9635e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
