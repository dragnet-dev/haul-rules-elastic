// Dragnet [Ransomware]: dragnet-ransomware-2024-2372 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: fd777593-5468-5250-a765-06299a5b6724

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
