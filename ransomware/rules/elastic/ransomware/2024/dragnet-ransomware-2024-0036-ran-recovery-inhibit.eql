// Dragnet [Ransomware]: dragnet-ransomware-2024-0036 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: 2944ac94-796c-5ccf-a411-0d1ac9f6c400

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
