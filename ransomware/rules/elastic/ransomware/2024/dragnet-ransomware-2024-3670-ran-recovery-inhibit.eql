// Dragnet [Ransomware]: dragnet-ransomware-2024-3670 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: e1902aa4-0ae3-5b1f-b7e9-94c49feb6d90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
