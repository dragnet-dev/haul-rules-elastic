// Dragnet [Ransomware]: dragnet-ransomware-2024-2712 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 5b41bbb0-c012-58cb-ba58-b218d60a5fb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
