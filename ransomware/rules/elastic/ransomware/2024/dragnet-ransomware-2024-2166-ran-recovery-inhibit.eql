// Dragnet [Ransomware]: dragnet-ransomware-2024-2166 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 8e4c560a-665b-5a33-93ae-7a06aa69d177

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
