// Dragnet [Ransomware]: dragnet-ransomware-2024-5125 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 60604d59-8efa-5d02-95f4-ccd7796652fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
