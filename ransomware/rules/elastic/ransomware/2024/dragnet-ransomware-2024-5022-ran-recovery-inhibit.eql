// Dragnet [Ransomware]: dragnet-ransomware-2024-5022 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 0796e20f-3f47-509d-bfef-0159ecff4f72

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
