// Dragnet [Ransomware]: dragnet-ransomware-2024-6007 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: deaa5789-073f-5509-a939-b5fb4d018d81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
