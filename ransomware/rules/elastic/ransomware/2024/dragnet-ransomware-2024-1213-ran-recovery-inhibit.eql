// Dragnet [Ransomware]: dragnet-ransomware-2024-1213 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 00b67d36-160a-5bf4-a479-2583511a12e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
