// Dragnet [Ransomware]: dragnet-ransomware-2024-2465 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a75de9de-08a1-502a-bb4f-14ed5b61553a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
