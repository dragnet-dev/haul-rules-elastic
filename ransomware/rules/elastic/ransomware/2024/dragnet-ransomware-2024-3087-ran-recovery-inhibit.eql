// Dragnet [Ransomware]: dragnet-ransomware-2024-3087 — Recovery Inhibition (moneymessage)
// Status: experimental | Level: high | ID: 2b450f42-5b6b-5023-be42-83af34585c6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
