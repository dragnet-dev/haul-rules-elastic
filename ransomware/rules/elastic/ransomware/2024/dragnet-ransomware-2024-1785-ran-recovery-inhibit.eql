// Dragnet [Ransomware]: dragnet-ransomware-2024-1785 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 2b9c62e3-55ba-5c3b-a722-33b2adaabacd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
