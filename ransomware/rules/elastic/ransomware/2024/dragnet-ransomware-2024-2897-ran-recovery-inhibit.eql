// Dragnet [Ransomware]: dragnet-ransomware-2024-2897 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 3a7bcb2a-425c-5eeb-8889-0b0196f7613b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
