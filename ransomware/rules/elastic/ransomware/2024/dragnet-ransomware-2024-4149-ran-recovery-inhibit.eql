// Dragnet [Ransomware]: dragnet-ransomware-2024-4149 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 748abce5-5e4e-5e07-be4a-02e1d144d94a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
