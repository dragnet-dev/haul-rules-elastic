// Dragnet [Ransomware]: dragnet-ransomware-2024-1828 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 9f7b8f62-bd07-5cf9-accf-c3d20cc31ee9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
