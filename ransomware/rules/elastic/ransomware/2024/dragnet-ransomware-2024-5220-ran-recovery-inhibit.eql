// Dragnet [Ransomware]: dragnet-ransomware-2024-5220 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: b27e8339-6b0b-5351-af3e-8e3a3a697720

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
