// Dragnet [Ransomware]: dragnet-ransomware-2024-6014 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 69cca247-f9e1-5181-9c9c-1a27318abdd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
