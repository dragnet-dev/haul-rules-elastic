// Dragnet [Ransomware]: dragnet-ransomware-2024-4921 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ad738505-7e4a-5f97-88d9-83107c6fbf16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
