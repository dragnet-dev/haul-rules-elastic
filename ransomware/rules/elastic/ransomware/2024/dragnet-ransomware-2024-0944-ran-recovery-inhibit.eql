// Dragnet [Ransomware]: dragnet-ransomware-2024-0944 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 5fad790a-d28e-544b-8b59-18780e0c3bfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
