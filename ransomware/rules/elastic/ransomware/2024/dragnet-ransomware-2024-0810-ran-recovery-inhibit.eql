// Dragnet [Ransomware]: dragnet-ransomware-2024-0810 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: fcadfd98-1b17-543f-8bbd-25d584b9eb5e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
