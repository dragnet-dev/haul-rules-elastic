// Dragnet [Ransomware]: dragnet-ransomware-2024-0605 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 1572700c-9b70-5029-9444-864de3dc1c8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
