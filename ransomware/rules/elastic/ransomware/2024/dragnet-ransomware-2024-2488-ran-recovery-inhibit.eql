// Dragnet [Ransomware]: dragnet-ransomware-2024-2488 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 8e82874c-5d16-54e0-8e12-42093686182a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
