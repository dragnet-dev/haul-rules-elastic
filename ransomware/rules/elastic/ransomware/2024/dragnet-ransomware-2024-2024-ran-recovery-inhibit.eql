// Dragnet [Ransomware]: dragnet-ransomware-2024-2024 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 131ca4a4-a94d-565a-ad91-582b35b23d12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
