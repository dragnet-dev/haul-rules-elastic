// Dragnet [Ransomware]: dragnet-ransomware-2024-2844 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0ec4b34b-1f3c-5fce-a611-4f75bddf654a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
