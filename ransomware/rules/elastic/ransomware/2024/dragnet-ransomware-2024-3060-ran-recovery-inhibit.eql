// Dragnet [Ransomware]: dragnet-ransomware-2024-3060 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 86e732e2-5084-51f1-9a89-180d5a1debf6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
