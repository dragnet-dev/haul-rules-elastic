// Dragnet [Ransomware]: dragnet-ransomware-2024-3730 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 975d6be4-2253-516e-9b2a-596b923abe07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
