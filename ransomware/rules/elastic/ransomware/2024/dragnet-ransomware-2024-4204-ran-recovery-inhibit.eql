// Dragnet [Ransomware]: dragnet-ransomware-2024-4204 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 01e1f15c-a99d-576b-a821-d691081c4bc1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
