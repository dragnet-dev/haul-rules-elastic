// Dragnet [Ransomware]: dragnet-ransomware-2024-4431 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 72cafb5c-414f-52bf-b211-388d79ed6967

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
