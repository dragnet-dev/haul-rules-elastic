// Dragnet [Ransomware]: dragnet-ransomware-2024-5936 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 2b1a4013-2a42-5394-a4cc-53aae0eb45b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
