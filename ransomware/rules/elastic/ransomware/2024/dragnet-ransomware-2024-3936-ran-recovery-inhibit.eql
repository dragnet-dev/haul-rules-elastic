// Dragnet [Ransomware]: dragnet-ransomware-2024-3936 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 90e80605-e8c1-5e3e-a5de-7590f9089105

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
