// Dragnet [Ransomware]: dragnet-ransomware-2024-2628 — Recovery Inhibition (redransomware)
// Status: deprecated | Level: high | ID: 431c7e4a-7121-5f5f-8f92-bd677d66a8eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
