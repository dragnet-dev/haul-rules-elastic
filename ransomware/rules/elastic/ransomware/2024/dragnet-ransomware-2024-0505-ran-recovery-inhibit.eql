// Dragnet [Ransomware]: dragnet-ransomware-2024-0505 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 26398831-47f8-57cd-8784-4337688c1157

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
