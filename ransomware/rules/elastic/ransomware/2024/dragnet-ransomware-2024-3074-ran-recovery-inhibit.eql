// Dragnet [Ransomware]: dragnet-ransomware-2024-3074 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6abffff0-219f-55fb-8743-d0d3162602ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
