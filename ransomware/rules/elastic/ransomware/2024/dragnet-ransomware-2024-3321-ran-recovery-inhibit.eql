// Dragnet [Ransomware]: dragnet-ransomware-2024-3321 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 0b8641a8-808a-5e87-973f-9b0c31ec4f3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
