// Dragnet [Ransomware]: dragnet-ransomware-2024-1418 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 243b8fc9-ba66-50ff-9068-6609da691969

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
