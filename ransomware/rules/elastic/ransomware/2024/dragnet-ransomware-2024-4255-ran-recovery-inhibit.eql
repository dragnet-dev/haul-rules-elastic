// Dragnet [Ransomware]: dragnet-ransomware-2024-4255 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 537398a3-a368-5f0e-8c92-4f77eabcf227

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
