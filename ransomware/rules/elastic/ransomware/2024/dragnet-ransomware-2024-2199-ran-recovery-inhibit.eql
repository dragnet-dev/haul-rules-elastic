// Dragnet [Ransomware]: dragnet-ransomware-2024-2199 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 5d75fa6a-803e-5a54-870b-b1ea34a83634

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
