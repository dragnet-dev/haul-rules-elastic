// Dragnet [Ransomware]: dragnet-ransomware-2024-5472 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: e3deeae5-4a71-5016-9f29-8895fcc93b6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
