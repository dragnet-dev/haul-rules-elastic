// Dragnet [Ransomware]: dragnet-ransomware-2024-0301 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: d9a978b1-642f-5fcc-8879-d2e38ac4b6f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
