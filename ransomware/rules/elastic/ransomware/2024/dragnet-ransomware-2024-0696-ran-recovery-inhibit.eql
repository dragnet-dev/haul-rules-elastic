// Dragnet [Ransomware]: dragnet-ransomware-2024-0696 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: c1d55cea-6fd0-5f74-9ea1-49b509a0dcad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
