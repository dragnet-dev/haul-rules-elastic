// Dragnet [Ransomware]: dragnet-ransomware-2024-0354 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 0fdc17f3-d02e-5c5e-9f3d-fe24810c40d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
