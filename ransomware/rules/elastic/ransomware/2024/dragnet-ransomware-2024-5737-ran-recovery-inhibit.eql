// Dragnet [Ransomware]: dragnet-ransomware-2024-5737 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7d4f3dd6-f60e-5f4b-80bc-81b4e4802762

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
