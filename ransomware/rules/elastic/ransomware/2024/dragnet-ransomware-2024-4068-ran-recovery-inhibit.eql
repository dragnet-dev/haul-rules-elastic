// Dragnet [Ransomware]: dragnet-ransomware-2024-4068 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: ea76ca99-4d2d-535f-ba7c-0d6d1850b3b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
