// Dragnet [Ransomware]: dragnet-ransomware-2024-0294 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: bfbdb5ed-e04b-533e-8397-8c114550e336

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
