// Dragnet [Ransomware]: dragnet-ransomware-2024-0811 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a963a3f0-7b86-5eb6-be86-7c9c580af178

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
