// Dragnet [Ransomware]: dragnet-ransomware-2024-5797 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: e3d0b4db-8032-56b6-876e-be6e4639f20b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
