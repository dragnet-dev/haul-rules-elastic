// Dragnet [Ransomware]: dragnet-ransomware-2024-4498 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f0034a80-edfe-5eee-b7e7-5e981a363b9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
