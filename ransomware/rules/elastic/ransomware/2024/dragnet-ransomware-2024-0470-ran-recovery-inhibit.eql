// Dragnet [Ransomware]: dragnet-ransomware-2024-0470 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: d918ec6c-ec35-5305-8dc2-ea7a7ccde929

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
