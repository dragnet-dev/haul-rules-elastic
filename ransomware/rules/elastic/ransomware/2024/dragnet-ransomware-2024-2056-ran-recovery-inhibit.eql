// Dragnet [Ransomware]: dragnet-ransomware-2024-2056 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 03bab988-5170-5efd-88ef-2bc51f2b3a43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
