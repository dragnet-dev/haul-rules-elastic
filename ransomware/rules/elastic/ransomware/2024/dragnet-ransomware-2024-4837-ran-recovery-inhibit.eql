// Dragnet [Ransomware]: dragnet-ransomware-2024-4837 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 772d00e5-5993-51f1-bf99-fb4796794d95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
