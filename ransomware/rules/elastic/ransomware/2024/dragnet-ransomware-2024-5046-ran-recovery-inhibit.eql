// Dragnet [Ransomware]: dragnet-ransomware-2024-5046 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: e3532469-b229-5122-82b7-db190003c194

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
