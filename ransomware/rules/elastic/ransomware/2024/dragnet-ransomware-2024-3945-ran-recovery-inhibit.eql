// Dragnet [Ransomware]: dragnet-ransomware-2024-3945 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e337e112-ffbe-55ce-9c53-ecd69f9b7152

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
