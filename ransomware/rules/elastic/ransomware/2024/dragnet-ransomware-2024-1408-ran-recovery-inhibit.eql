// Dragnet [Ransomware]: dragnet-ransomware-2024-1408 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: bbff48d2-ee26-5443-b472-9cf15b35ea84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
