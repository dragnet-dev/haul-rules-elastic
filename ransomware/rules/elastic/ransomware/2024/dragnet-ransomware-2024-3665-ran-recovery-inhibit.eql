// Dragnet [Ransomware]: dragnet-ransomware-2024-3665 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 15234ac3-9fd4-5d04-a533-60b7cf185f33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
