// Dragnet [Ransomware]: dragnet-ransomware-2024-3573 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: ee550296-f77a-5df3-a6c6-8959be0adb1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
