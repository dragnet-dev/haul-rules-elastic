// Dragnet [Ransomware]: dragnet-ransomware-2024-4872 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 7de8561a-6610-53f2-87e5-4500c76b16f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
