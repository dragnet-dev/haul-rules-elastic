// Dragnet [Ransomware]: dragnet-ransomware-2024-1316 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: e54b26c3-e094-5d88-ba4b-2858b41a3611

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
