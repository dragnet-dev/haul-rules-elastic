// Dragnet [Ransomware]: dragnet-ransomware-2024-5684 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c15af0a0-c6e4-5d30-9851-63015e979eec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
