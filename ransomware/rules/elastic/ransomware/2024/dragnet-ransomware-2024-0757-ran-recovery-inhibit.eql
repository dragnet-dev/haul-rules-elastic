// Dragnet [Ransomware]: dragnet-ransomware-2024-0757 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 4a3a8262-956a-53b5-a790-022ec1e47a04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
