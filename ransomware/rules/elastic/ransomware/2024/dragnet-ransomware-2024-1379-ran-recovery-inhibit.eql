// Dragnet [Ransomware]: dragnet-ransomware-2024-1379 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 93511920-0ef1-5dfb-be67-13dbe4660939

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
