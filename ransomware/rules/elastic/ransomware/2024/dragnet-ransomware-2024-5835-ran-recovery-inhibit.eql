// Dragnet [Ransomware]: dragnet-ransomware-2024-5835 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: b579a14c-b64d-5bff-81bb-3d96226e891c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
