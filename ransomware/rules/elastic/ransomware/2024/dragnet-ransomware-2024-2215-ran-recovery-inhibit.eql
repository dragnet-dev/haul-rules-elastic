// Dragnet [Ransomware]: dragnet-ransomware-2024-2215 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d424ac75-f85f-5f5f-a333-4cebf7173ac1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
