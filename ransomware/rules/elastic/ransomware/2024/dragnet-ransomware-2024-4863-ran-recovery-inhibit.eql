// Dragnet [Ransomware]: dragnet-ransomware-2024-4863 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 86a7638f-e999-5067-884a-d328252b7ec6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
