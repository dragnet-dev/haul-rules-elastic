// Dragnet [Ransomware]: dragnet-ransomware-2024-2939 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8621eadd-6b0d-5f20-bf1e-978f486c953e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
