// Dragnet [Ransomware]: dragnet-ransomware-2024-5718 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5dcfc2bc-156c-526e-87a3-2ce8ba6e3247

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
