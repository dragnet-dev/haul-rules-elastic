// Dragnet [Ransomware]: dragnet-ransomware-2024-3746 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 9af4d42f-2c3b-54b8-b164-1d7619e26eaf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
