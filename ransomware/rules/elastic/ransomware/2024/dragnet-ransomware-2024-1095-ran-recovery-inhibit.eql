// Dragnet [Ransomware]: dragnet-ransomware-2024-1095 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 3e65ffe9-8a65-55e6-b171-506b7ab21b9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
