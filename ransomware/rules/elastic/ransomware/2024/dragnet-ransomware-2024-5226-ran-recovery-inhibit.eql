// Dragnet [Ransomware]: dragnet-ransomware-2024-5226 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6660c848-1557-57e7-acdc-3ba5646babd3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
