// Dragnet [Ransomware]: dragnet-ransomware-2024-2033 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 5ae3aeae-82c1-5a43-9208-e76b10ba8d49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
