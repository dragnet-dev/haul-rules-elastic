// Dragnet [Ransomware]: dragnet-ransomware-2024-0202 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ae665417-803b-5c13-8210-d6b264a50cf9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
