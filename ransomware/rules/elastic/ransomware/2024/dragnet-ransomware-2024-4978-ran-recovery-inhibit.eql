// Dragnet [Ransomware]: dragnet-ransomware-2024-4978 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 45af5fa5-c347-53a3-a2b4-77dcc8110c2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
