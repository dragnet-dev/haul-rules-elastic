// Dragnet [Ransomware]: dragnet-ransomware-2024-1629 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 9f89c0d2-cfb2-54aa-b20b-92ea58e2dc60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
