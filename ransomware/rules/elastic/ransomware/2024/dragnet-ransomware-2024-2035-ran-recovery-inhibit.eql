// Dragnet [Ransomware]: dragnet-ransomware-2024-2035 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: a12af6f2-fd63-5b33-b2e8-2574544225f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
