// Dragnet [Ransomware]: dragnet-ransomware-2024-3601 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7e3e40d5-3975-5971-b07d-1b5e3d361ff0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
