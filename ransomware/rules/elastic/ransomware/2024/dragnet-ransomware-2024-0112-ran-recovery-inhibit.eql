// Dragnet [Ransomware]: dragnet-ransomware-2024-0112 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: e4ea49df-9115-5dc6-87e0-01743657518e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
