// Dragnet [Ransomware]: dragnet-ransomware-2024-5893 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: d885175c-0819-5a80-a9aa-cc55271dddd3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
