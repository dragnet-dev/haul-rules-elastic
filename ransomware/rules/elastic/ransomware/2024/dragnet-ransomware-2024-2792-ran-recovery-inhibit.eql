// Dragnet [Ransomware]: dragnet-ransomware-2024-2792 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7c8e4f76-dd9d-54d9-9a74-3fc70de5709e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
