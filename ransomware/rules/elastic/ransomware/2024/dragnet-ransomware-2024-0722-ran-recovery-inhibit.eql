// Dragnet [Ransomware]: dragnet-ransomware-2024-0722 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ecbcc81c-c813-5d7c-b3ed-d345f5ec0a12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
