// Dragnet [Ransomware]: dragnet-ransomware-2024-3118 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 91ff0738-e61f-516a-b62b-7f5ab1813de1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
