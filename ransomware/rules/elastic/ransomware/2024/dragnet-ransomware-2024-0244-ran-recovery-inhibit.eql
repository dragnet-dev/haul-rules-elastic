// Dragnet [Ransomware]: dragnet-ransomware-2024-0244 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 6cf220fd-c8df-5584-8095-a25a2899b316

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
