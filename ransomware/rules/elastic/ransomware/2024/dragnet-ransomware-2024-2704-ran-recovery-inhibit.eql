// Dragnet [Ransomware]: dragnet-ransomware-2024-2704 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 7281405d-49a7-513d-81f5-103eeeff5d39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
