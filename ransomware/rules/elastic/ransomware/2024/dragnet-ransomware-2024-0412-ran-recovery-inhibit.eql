// Dragnet [Ransomware]: dragnet-ransomware-2024-0412 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 07646517-6b2c-54eb-b71e-7a35f2d6cf1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
