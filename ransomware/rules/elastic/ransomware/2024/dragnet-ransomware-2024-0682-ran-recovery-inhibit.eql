// Dragnet [Ransomware]: dragnet-ransomware-2024-0682 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b349bcf3-082c-5097-96b4-8ac7741e4b6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
