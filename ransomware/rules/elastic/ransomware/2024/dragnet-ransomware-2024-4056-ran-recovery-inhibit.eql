// Dragnet [Ransomware]: dragnet-ransomware-2024-4056 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: 80feccc6-3261-5702-8a39-78dc78745da0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
