// Dragnet [Ransomware]: dragnet-ransomware-2024-0311 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 1b903c55-b50d-52d4-a253-4629a38621b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
