// Dragnet [Ransomware]: dragnet-ransomware-2024-1036 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: a2dcfd1d-d2dd-52cb-a44f-ddeb0daf7345

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
