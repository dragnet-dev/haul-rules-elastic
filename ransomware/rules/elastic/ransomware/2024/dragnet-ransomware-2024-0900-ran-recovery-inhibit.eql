// Dragnet [Ransomware]: dragnet-ransomware-2024-0900 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: faaee147-816e-5ff0-aae1-8c289a22cf63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
