// Dragnet [Ransomware]: dragnet-ransomware-2024-1164 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 74077b05-aa6b-59cb-ad7a-73b5d5d24590

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
