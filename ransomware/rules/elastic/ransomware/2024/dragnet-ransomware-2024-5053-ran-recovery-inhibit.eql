// Dragnet [Ransomware]: dragnet-ransomware-2024-5053 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5870e290-3403-5348-b94d-2ebc3dce3045

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
