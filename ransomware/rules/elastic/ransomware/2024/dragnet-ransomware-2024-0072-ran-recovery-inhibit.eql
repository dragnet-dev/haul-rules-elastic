// Dragnet [Ransomware]: dragnet-ransomware-2024-0072 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: bca95e49-489f-5ab6-820d-e8f1368ccabf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
