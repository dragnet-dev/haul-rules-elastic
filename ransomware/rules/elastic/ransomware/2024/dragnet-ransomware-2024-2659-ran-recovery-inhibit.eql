// Dragnet [Ransomware]: dragnet-ransomware-2024-2659 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 833e3ace-ed58-5e3d-b5a0-8a7b9f3614b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
