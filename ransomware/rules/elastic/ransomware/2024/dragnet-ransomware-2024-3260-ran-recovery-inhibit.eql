// Dragnet [Ransomware]: dragnet-ransomware-2024-3260 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: aded4376-6046-5e3a-b54d-9391980bf60a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
