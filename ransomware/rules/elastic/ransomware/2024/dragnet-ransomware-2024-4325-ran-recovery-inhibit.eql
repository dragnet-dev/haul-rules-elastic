// Dragnet [Ransomware]: dragnet-ransomware-2024-4325 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: 2e6c7907-97c1-5e86-bf87-79c1c7e6d108

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
