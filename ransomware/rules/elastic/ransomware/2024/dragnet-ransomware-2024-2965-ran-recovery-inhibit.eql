// Dragnet [Ransomware]: dragnet-ransomware-2024-2965 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: fdd3b0e5-ebca-5f31-ba93-9bd83a10aabe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
