// Dragnet [Ransomware]: dragnet-ransomware-2024-4376 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 14f43786-ec08-5321-b50e-c588719d1dc9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
