// Dragnet [Ransomware]: dragnet-ransomware-2024-4356 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 35223458-0f01-5bc7-8611-8479ca07c00e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
