// Dragnet [Ransomware]: dragnet-ransomware-2024-1891 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: 639fc022-788b-54b3-84ad-a98518099067

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
