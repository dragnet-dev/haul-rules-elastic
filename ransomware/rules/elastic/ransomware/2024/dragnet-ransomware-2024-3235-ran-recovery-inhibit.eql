// Dragnet [Ransomware]: dragnet-ransomware-2024-3235 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3a695b3d-f24a-51e2-b52c-8fe7c8d7916d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
