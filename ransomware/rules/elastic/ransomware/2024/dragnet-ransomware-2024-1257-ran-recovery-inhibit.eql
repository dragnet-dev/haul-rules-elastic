// Dragnet [Ransomware]: dragnet-ransomware-2024-1257 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ae80db1f-d470-56db-8b50-860418e4ecff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
