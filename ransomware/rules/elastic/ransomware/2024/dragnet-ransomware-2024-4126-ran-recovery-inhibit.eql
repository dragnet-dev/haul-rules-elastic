// Dragnet [Ransomware]: dragnet-ransomware-2024-4126 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: beaff77d-01a6-5bfa-88b1-f30f5e9c12bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
