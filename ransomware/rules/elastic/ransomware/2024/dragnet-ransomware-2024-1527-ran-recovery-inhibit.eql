// Dragnet [Ransomware]: dragnet-ransomware-2024-1527 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5849437d-fa86-51cf-9b4b-56774b04efd2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
