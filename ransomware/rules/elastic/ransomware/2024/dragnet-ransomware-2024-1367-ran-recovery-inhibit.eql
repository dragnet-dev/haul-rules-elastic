// Dragnet [Ransomware]: dragnet-ransomware-2024-1367 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: bb0ac967-ab55-5c18-8779-b3a65c0d69bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
