// Dragnet [Ransomware]: dragnet-ransomware-2024-4215 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 68b9743e-2d7c-5ceb-974c-0f765aeda810

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
