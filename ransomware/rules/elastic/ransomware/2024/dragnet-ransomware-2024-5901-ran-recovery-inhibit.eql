// Dragnet [Ransomware]: dragnet-ransomware-2024-5901 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1ca3755e-f1f9-5cc5-8e5c-0af191c44951

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
