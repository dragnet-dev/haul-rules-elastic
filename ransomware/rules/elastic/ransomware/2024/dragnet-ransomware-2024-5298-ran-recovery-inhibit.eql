// Dragnet [Ransomware]: dragnet-ransomware-2024-5298 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a13f104f-232e-5f3b-830c-29ef4aca3df4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
