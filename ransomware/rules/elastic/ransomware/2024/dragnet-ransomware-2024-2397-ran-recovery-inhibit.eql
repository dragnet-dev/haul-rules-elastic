// Dragnet [Ransomware]: dragnet-ransomware-2024-2397 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2612eb0e-c42b-56b5-bad8-755a692d346d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
