// Dragnet [Ransomware]: dragnet-ransomware-2024-0194 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 7b6b9c2f-50c7-5268-946b-54946e5237eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
