// Dragnet [Ransomware]: dragnet-ransomware-2024-0108 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: b19a55a8-c6a9-51d9-9d77-8b16c2476d3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
