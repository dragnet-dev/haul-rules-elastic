// Dragnet [Ransomware]: dragnet-ransomware-2024-3305 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 37ff6bd5-dc33-524b-9964-9882bbe14625

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
