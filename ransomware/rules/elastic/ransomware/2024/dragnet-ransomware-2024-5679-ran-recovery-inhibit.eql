// Dragnet [Ransomware]: dragnet-ransomware-2024-5679 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: db7bea8b-717a-58c2-8b31-5cbab79f652d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
