// Dragnet [Ransomware]: dragnet-ransomware-2024-5971 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1d649f87-1c83-5f4f-bbf4-b07f41716767

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
