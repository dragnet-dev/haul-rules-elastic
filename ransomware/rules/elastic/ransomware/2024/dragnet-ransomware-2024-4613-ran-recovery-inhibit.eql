// Dragnet [Ransomware]: dragnet-ransomware-2024-4613 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 074540f3-0a36-5ed3-b35b-8e5cc6ab191a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
