// Dragnet [Ransomware]: dragnet-ransomware-2024-1117 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: cdf5a527-9d46-52dc-9576-c9bbd2ac0398

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
