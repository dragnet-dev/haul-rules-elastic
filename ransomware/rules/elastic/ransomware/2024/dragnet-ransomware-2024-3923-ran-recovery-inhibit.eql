// Dragnet [Ransomware]: dragnet-ransomware-2024-3923 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: cafc4f74-8c36-538f-b3f0-830660b4bff9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
