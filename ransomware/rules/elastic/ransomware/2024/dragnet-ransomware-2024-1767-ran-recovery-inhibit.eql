// Dragnet [Ransomware]: dragnet-ransomware-2024-1767 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 9c290127-2241-5b24-abec-2fc4f94e9ac3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
