// Dragnet [Ransomware]: dragnet-ransomware-2024-0225 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: 24b50457-b432-5801-9fba-c2e0a7e344fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
