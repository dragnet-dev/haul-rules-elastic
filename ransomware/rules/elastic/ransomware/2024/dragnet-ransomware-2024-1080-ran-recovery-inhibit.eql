// Dragnet [Ransomware]: dragnet-ransomware-2024-1080 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 70332999-f386-5966-8e8b-47286d0ec37f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
