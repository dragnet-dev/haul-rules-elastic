// Dragnet [Ransomware]: dragnet-ransomware-2024-5513 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b6603b1f-66ce-5401-8512-29a9b34505e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
