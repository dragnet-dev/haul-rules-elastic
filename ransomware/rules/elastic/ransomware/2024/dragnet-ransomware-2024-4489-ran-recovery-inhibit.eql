// Dragnet [Ransomware]: dragnet-ransomware-2024-4489 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 5e566790-dd4f-5b72-afa7-76c9fcf8a9db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
