// Dragnet [Ransomware]: dragnet-ransomware-2024-1540 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: bc485bbe-b020-5358-be63-a50d74ff3994

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
