// Dragnet [Ransomware]: dragnet-ransomware-2024-4919 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: afc85238-b7e9-55a7-98dd-17dbe848cc77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
