// Dragnet [Ransomware]: dragnet-ransomware-2024-3921 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 3e9d78d4-eccf-56e9-8192-bfac6b94bb61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
