// Dragnet [Ransomware]: dragnet-ransomware-2024-1993 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 642fbc7f-efdd-509e-bcf0-153a00967ece

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
