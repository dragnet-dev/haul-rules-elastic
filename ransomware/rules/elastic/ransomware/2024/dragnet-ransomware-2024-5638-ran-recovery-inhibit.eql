// Dragnet [Ransomware]: dragnet-ransomware-2024-5638 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 81d313cc-1e6d-53ee-b4a4-3cc76cf2de1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
