// Dragnet [Ransomware]: dragnet-ransomware-2024-2337 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a8822fcd-7275-59fe-a1b1-7be36b2131fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
