// Dragnet [Ransomware]: dragnet-ransomware-2024-2025 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1cc6e716-d19d-5d21-88c0-9f404d14650e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
