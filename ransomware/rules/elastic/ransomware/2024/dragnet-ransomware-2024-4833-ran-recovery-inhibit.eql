// Dragnet [Ransomware]: dragnet-ransomware-2024-4833 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: eab7adf8-8469-5b6b-ad42-86404abf7ba5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
