// Dragnet [Ransomware]: dragnet-ransomware-2024-5866 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: c24b0332-3f0f-51c6-a136-0ce88498e3dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
