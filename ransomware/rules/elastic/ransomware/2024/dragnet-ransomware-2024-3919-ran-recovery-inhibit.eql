// Dragnet [Ransomware]: dragnet-ransomware-2024-3919 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 53f8b1fc-9e82-577d-aade-b81c39912c59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
