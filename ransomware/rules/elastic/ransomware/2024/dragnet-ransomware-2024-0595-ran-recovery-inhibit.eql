// Dragnet [Ransomware]: dragnet-ransomware-2024-0595 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 742fe8f9-66b8-50b7-a178-b8139a4789f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
