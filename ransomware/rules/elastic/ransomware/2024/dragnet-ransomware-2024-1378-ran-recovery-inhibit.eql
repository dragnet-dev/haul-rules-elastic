// Dragnet [Ransomware]: dragnet-ransomware-2024-1378 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d0af423f-cc91-5b61-ae0f-2bce3266042c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
