// Dragnet [Ransomware]: dragnet-ransomware-2024-2614 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: a3556898-899f-57f6-a9f1-d560b302f85e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
