// Dragnet [Ransomware]: dragnet-ransomware-2024-0109 — Recovery Inhibition (ElDorado)
// Status: experimental | Level: high | ID: a255be6c-2fde-54ca-b2f5-ba7ea5005591

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
