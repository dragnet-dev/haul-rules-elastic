// Dragnet [Ransomware]: dragnet-ransomware-2024-1711 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ccb05f9a-8315-5332-875b-58885caed6e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
