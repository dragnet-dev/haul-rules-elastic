// Dragnet [Ransomware]: dragnet-ransomware-2024-5888 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: a77d4c00-2605-59ff-96e8-e8da058f4361

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
