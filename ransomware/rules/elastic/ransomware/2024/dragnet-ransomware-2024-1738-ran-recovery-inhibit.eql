// Dragnet [Ransomware]: dragnet-ransomware-2024-1738 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 249e6147-0c61-5f53-8e7b-c12da0e1977a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
