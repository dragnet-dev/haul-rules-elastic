// Dragnet [Ransomware]: dragnet-ransomware-2024-4798 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 60049631-7d9c-5702-a07d-3346978ecd93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
