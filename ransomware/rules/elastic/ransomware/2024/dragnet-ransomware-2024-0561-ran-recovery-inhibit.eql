// Dragnet [Ransomware]: dragnet-ransomware-2024-0561 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 9cb1d882-03b7-5104-aa58-dfee3689506b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
