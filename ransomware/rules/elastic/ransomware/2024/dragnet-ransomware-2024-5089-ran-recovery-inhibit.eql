// Dragnet [Ransomware]: dragnet-ransomware-2024-5089 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 97fff5fd-11d5-588a-a112-aad7cb4006c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
