// Dragnet [Ransomware]: dragnet-ransomware-2024-4345 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 3da25bff-6b44-527f-8127-3d3b3920a9e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
