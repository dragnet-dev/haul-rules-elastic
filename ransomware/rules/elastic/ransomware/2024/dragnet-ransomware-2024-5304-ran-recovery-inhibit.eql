// Dragnet [Ransomware]: dragnet-ransomware-2024-5304 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: ba1dc50f-68a5-5fd8-bb66-4aac3daa042a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
