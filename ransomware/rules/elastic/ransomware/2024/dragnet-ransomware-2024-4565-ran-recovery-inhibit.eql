// Dragnet [Ransomware]: dragnet-ransomware-2024-4565 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: aabb8eac-2033-56d4-b19c-6340b10bf5c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
