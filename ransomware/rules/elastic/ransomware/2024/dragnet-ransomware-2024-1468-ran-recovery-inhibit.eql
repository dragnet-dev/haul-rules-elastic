// Dragnet [Ransomware]: dragnet-ransomware-2024-1468 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 630f368f-1ec3-54f8-b4ff-f2cd0ef92c79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
