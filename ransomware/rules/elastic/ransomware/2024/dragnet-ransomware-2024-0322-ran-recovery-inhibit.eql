// Dragnet [Ransomware]: dragnet-ransomware-2024-0322 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 4c89cd64-f03f-5de0-8e3e-19e1c75dfaee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
