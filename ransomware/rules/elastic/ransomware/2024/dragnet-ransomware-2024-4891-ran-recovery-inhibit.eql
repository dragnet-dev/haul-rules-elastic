// Dragnet [Ransomware]: dragnet-ransomware-2024-4891 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: bb68738e-4a14-5883-9e4b-f49b6a6fef38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
