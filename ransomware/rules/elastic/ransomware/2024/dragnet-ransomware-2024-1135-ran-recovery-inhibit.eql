// Dragnet [Ransomware]: dragnet-ransomware-2024-1135 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 890a01ed-a0a6-5fdb-b71a-e1bb423ee04a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
