// Dragnet [Ransomware]: dragnet-ransomware-2024-4233 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: eb9d18aa-0ac2-5ee8-9818-ad43f48d93e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
