// Dragnet [Ransomware]: dragnet-ransomware-2024-5996 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2225bee8-a4a7-5e23-99a3-a14e3955f998

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
