// Dragnet [Ransomware]: dragnet-ransomware-2024-0369 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 40c9533e-728f-563f-8efb-ac7a2b1682b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
