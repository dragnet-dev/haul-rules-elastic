// Dragnet [Ransomware]: dragnet-ransomware-2024-0940 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 10721f62-9322-5e3c-99fd-ac8621dbd0ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
