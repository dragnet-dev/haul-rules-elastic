// Dragnet [Ransomware]: dragnet-ransomware-2024-1655 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 48a876aa-f7f9-5909-8da9-257c8ba5dfd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
