// Dragnet [Ransomware]: dragnet-ransomware-2024-0831 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 10fbeb12-a072-5552-87ea-c3ccb3ccb0f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
