// Dragnet [Ransomware]: dragnet-ransomware-2024-3826 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 52c11a2b-8789-5148-8b57-7fb5d717ed93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
