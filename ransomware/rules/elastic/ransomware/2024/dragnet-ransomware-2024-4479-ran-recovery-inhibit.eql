// Dragnet [Ransomware]: dragnet-ransomware-2024-4479 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: e8b42c8f-328e-51af-b87e-7588bc1b9f95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
