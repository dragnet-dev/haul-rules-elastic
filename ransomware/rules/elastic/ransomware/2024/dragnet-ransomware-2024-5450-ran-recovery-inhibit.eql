// Dragnet [Ransomware]: dragnet-ransomware-2024-5450 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ab26703d-4135-576b-b882-ba94821fa2ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
