// Dragnet [Ransomware]: dragnet-ransomware-2024-4413 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 54a31e49-6aad-5677-adcb-542513a923a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
