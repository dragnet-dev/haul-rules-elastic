// Dragnet [Ransomware]: dragnet-ransomware-2024-1723 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 51d4ca86-2787-528c-9cf2-477e6c72a76a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
