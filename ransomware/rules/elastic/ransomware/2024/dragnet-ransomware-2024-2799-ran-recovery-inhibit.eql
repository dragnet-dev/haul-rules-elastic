// Dragnet [Ransomware]: dragnet-ransomware-2024-2799 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: a99c6cb0-a29a-537b-9a5c-3fdfc8351ef9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
