// Dragnet [Ransomware]: dragnet-ransomware-2024-5412 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 2627e9e6-a26e-538a-822b-5c327ac7f30f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
