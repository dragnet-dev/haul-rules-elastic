// Dragnet [Ransomware]: dragnet-ransomware-2024-2384 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 10a2b41a-4ab0-5e9a-81ea-15ddb8c340fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
