// Dragnet [Ransomware]: dragnet-ransomware-2024-0959 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5db5cafc-cdcf-5a24-a7a2-c006a1fade07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
