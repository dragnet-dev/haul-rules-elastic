// Dragnet [Ransomware]: dragnet-ransomware-2024-5889 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 4a1acf35-8256-51c8-90bc-b0d89da18fa1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
