// Dragnet [Ransomware]: dragnet-ransomware-2024-5050 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 0c01ef48-4696-510e-b025-efc266c65ba7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
