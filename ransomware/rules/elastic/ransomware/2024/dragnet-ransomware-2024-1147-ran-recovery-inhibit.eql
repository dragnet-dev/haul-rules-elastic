// Dragnet [Ransomware]: dragnet-ransomware-2024-1147 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3f7cf4b3-7d2a-5aec-973e-8ac1fd17277f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
