// Dragnet [Ransomware]: dragnet-ransomware-2024-4018 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c5b49374-2981-5d70-9148-a0d47489cc64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
