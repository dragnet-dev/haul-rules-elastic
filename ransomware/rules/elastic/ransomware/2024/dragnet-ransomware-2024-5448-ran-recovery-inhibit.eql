// Dragnet [Ransomware]: dragnet-ransomware-2024-5448 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a304384e-e7bd-5fdd-be12-af9529db9ca2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
