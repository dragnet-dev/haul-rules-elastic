// Dragnet [Ransomware]: dragnet-ransomware-2024-0606 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 632d5dd8-bc0f-5a57-833c-f64f09b4bbeb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
