// Dragnet [Ransomware]: dragnet-ransomware-2024-3428 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d158e0b9-22bf-5d6b-9b4c-79da4a0bb483

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
