// Dragnet [Ransomware]: dragnet-ransomware-2024-4737 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 987579a1-73ec-5865-a6b6-8ef4007b39f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
