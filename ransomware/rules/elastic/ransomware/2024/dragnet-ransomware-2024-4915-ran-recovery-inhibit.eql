// Dragnet [Ransomware]: dragnet-ransomware-2024-4915 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 1954cd01-1e01-542b-adac-92d75be6e69e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
