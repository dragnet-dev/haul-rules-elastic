// Dragnet [Ransomware]: dragnet-ransomware-2024-1586 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 96763cfe-1db2-5fd2-b1e2-f4b97633f093

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
