// Dragnet [Ransomware]: dragnet-ransomware-2024-4487 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: cb9b8cb4-407c-5f47-82b0-fa8906093117

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
