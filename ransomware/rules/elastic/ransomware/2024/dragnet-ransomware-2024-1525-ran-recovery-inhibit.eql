// Dragnet [Ransomware]: dragnet-ransomware-2024-1525 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 71157752-a48e-5e04-8776-d68dcecbbb8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
