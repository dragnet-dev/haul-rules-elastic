// Dragnet [Ransomware]: dragnet-ransomware-2024-0011 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3189f001-ef79-533d-9455-e061f5b861a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
