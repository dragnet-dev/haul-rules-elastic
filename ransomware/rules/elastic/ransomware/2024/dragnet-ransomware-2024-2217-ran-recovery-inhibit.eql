// Dragnet [Ransomware]: dragnet-ransomware-2024-2217 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: d33724d5-d390-5661-9231-64eaab4be200

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
