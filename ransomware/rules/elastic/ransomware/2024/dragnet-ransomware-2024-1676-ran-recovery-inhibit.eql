// Dragnet [Ransomware]: dragnet-ransomware-2024-1676 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: fb63f240-41d8-5dac-b3e1-58efcbbe3e12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
