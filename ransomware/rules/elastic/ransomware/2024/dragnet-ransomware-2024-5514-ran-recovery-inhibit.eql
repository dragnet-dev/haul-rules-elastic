// Dragnet [Ransomware]: dragnet-ransomware-2024-5514 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: e34eebe6-a08a-5382-8ad9-ffd5aba453e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
