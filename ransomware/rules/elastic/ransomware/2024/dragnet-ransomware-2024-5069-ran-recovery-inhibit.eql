// Dragnet [Ransomware]: dragnet-ransomware-2024-5069 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: f9933eed-9348-5506-86cb-580870d5a17f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
