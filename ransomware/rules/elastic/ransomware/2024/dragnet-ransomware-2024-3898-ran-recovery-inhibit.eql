// Dragnet [Ransomware]: dragnet-ransomware-2024-3898 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: bb6dd534-ed72-5bd2-abe2-30e6f93803a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
