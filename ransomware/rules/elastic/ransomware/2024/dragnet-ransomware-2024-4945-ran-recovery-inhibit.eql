// Dragnet [Ransomware]: dragnet-ransomware-2024-4945 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 414bc6dc-370a-5627-9fb1-1380b460a7a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
