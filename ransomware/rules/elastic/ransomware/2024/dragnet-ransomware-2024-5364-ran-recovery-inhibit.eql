// Dragnet [Ransomware]: dragnet-ransomware-2024-5364 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 56aff0c6-4203-5ee1-acd1-b85189f2e6af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
