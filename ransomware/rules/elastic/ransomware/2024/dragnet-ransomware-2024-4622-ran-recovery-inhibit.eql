// Dragnet [Ransomware]: dragnet-ransomware-2024-4622 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: fd2d0027-936b-5d23-b867-fdc8ca9e7da8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
