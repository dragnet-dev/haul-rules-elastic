// Dragnet [Ransomware]: dragnet-ransomware-2024-2848 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 442e6c87-693c-5358-a7ff-b4a6167cac58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
