// Dragnet [Ransomware]: dragnet-ransomware-2024-1976 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d1ba3f09-eef2-5857-9371-15c959f946f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
