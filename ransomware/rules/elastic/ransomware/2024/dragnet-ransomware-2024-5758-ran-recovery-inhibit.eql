// Dragnet [Ransomware]: dragnet-ransomware-2024-5758 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 965b0a9c-280c-5abe-9b1d-74aabb866531

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
