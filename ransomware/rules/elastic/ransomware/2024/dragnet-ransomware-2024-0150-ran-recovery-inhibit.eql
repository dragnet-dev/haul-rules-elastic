// Dragnet [Ransomware]: dragnet-ransomware-2024-0150 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e03fb1b7-3ed2-5b07-a43e-0a3455d93aac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
