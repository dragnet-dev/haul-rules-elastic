// Dragnet [Ransomware]: dragnet-ransomware-2024-3332 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 39bb229e-91cf-5f68-9f08-c922b06f0649

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
