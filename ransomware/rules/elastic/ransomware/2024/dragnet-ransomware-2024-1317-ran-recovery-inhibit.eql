// Dragnet [Ransomware]: dragnet-ransomware-2024-1317 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 554bc6e8-b1dd-523c-b8f8-c75564fb31de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
