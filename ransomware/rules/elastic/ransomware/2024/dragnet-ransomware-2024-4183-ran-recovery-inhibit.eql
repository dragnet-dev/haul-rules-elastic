// Dragnet [Ransomware]: dragnet-ransomware-2024-4183 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4331985a-9b7f-5f06-876c-7e7f4c6f2a5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
