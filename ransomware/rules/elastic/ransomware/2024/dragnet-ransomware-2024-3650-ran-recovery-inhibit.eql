// Dragnet [Ransomware]: dragnet-ransomware-2024-3650 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: dbfc799a-2715-511b-80bb-b42f8e9c847b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
