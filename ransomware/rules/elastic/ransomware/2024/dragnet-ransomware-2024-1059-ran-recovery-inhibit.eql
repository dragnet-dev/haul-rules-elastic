// Dragnet [Ransomware]: dragnet-ransomware-2024-1059 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: bd9fd9e8-8c83-5500-aca0-2b93ecf61127

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
