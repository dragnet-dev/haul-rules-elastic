// Dragnet [Ransomware]: dragnet-ransomware-2024-1113 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: da3516ec-643a-582a-a897-09990b093558

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
