// Dragnet [Ransomware]: dragnet-ransomware-2024-4247 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 5e8646ef-5613-514e-adff-01f19381a847

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
