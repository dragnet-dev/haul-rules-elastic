// Dragnet [Ransomware]: dragnet-ransomware-2024-1564 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 60db2f7c-2f8f-5746-9656-63a99032d781

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
