// Dragnet [Ransomware]: dragnet-ransomware-2024-0825 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 3352f42c-201f-5316-b125-e7687d9d709e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
