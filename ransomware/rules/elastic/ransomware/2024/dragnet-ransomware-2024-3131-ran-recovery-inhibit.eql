// Dragnet [Ransomware]: dragnet-ransomware-2024-3131 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 974446d8-c2f9-58cf-a5bf-cf00786f6c82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
