// Dragnet [Ransomware]: dragnet-ransomware-2024-1601 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 4d6e6e3c-bb71-50da-937e-e8c1dcf04c90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
