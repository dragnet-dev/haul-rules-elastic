// Dragnet [Ransomware]: dragnet-ransomware-2024-2237 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 35911ad7-00db-5cc8-80a0-5b63d7d017c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
