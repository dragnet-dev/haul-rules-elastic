// Dragnet [Ransomware]: dragnet-ransomware-2024-3353 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: e301c7ad-0d44-5e53-8445-6f18d33f18fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
