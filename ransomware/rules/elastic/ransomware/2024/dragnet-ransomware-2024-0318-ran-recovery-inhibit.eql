// Dragnet [Ransomware]: dragnet-ransomware-2024-0318 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f8d44ca6-c5f7-5628-8b37-8c90c9ac2f5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
