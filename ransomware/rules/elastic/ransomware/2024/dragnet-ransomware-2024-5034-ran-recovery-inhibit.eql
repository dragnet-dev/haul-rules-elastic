// Dragnet [Ransomware]: dragnet-ransomware-2024-5034 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2ae2ea38-fd3a-5ec1-adcd-b3e56c7eec39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
