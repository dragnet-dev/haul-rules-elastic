// Dragnet [Ransomware]: dragnet-ransomware-2024-2894 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 54706029-43fc-51dd-92dc-f5f37bec76c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
