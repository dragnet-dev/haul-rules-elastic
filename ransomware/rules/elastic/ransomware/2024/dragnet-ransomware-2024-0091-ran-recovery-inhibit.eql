// Dragnet [Ransomware]: dragnet-ransomware-2024-0091 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 77742731-998d-5330-8a73-7b02f2c26ddb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
