// Dragnet [Ransomware]: dragnet-ransomware-2024-1441 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: bed36351-22fe-5261-936a-35c1f7b8ef22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
