// Dragnet [Ransomware]: dragnet-ransomware-2024-2535 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 8457aa8d-f42a-59c9-8a15-6bd6af895c2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
