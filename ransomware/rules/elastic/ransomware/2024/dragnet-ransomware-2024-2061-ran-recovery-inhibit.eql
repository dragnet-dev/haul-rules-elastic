// Dragnet [Ransomware]: dragnet-ransomware-2024-2061 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: 480b3e67-ce55-502e-b69e-1752b9415a95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
