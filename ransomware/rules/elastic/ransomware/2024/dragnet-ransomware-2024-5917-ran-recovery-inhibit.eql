// Dragnet [Ransomware]: dragnet-ransomware-2024-5917 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: db84d8ce-81dc-5c67-88d4-4c17befdcf1f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
