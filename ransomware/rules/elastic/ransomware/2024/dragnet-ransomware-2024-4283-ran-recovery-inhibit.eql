// Dragnet [Ransomware]: dragnet-ransomware-2024-4283 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: cdd699dd-2f35-536a-a4a6-22405e9c8185

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
