// Dragnet [Ransomware]: dragnet-ransomware-2024-2479 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ec79d8ae-37f7-5d8c-9619-4cd208fded91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
