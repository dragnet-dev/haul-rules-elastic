// Dragnet [Ransomware]: dragnet-ransomware-2024-4767 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 1be4a167-f71d-5773-b77d-362d2c245a8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
