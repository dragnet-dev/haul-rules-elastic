// Dragnet [Ransomware]: dragnet-ransomware-2024-3053 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 88f21f5c-0801-56ed-9990-0439b9c01266

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
