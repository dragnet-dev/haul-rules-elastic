// Dragnet [Ransomware]: dragnet-ransomware-2024-4022 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 793da74b-b52a-5647-8559-97995fe23ba0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
