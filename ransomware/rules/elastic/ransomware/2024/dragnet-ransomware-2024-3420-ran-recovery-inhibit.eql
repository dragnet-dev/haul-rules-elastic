// Dragnet [Ransomware]: dragnet-ransomware-2024-3420 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: ec4ecef0-9e4e-52db-a39e-7efc8c816dac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
