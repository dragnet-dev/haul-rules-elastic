// Dragnet [Ransomware]: dragnet-ransomware-2024-3896 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: b6d58804-d36f-5850-9b72-b12fab5c687f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
