// Dragnet [Ransomware]: dragnet-ransomware-2024-1199 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: e6dad158-e786-5f4c-af2d-585d223e1f6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
