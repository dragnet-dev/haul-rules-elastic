// Dragnet [Ransomware]: dragnet-ransomware-2024-4835 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 74ffaa52-f41b-538d-a0c9-c52abcd85a3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
