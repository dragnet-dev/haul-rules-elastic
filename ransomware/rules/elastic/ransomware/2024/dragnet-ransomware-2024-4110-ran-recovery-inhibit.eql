// Dragnet [Ransomware]: dragnet-ransomware-2024-4110 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 9306fb9f-9783-5d01-abea-28a4a5f5653c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
