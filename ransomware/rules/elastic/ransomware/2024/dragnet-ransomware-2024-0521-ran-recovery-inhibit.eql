// Dragnet [Ransomware]: dragnet-ransomware-2024-0521 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 58fea4e5-2785-54a6-8c2d-6754c3c3a30d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
