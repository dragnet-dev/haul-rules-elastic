// Dragnet [Ransomware]: dragnet-ransomware-2024-2664 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 10b294d7-b972-5e29-a6f5-a752845c8db6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
