// Dragnet [Ransomware]: dragnet-ransomware-2024-3352 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: 2adfdc3a-a685-5c3a-864d-7b890ef52a0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
