// Dragnet [Ransomware]: dragnet-ransomware-2024-3785 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f2917974-a723-5d07-81da-6f9f770a41f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
