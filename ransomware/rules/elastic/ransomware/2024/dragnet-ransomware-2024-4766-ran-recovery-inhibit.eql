// Dragnet [Ransomware]: dragnet-ransomware-2024-4766 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: a18e2949-37b0-5d31-920f-b4e7596a3aaa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
