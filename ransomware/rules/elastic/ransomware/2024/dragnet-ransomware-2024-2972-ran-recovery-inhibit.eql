// Dragnet [Ransomware]: dragnet-ransomware-2024-2972 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bc1e6755-316c-5b9a-a977-60fd4207f8b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
