// Dragnet [Ransomware]: dragnet-ransomware-2024-0063 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 885c9eb0-204f-58a9-87c3-448410b4f6f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
