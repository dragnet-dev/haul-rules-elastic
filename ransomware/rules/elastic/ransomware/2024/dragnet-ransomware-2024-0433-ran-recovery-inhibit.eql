// Dragnet [Ransomware]: dragnet-ransomware-2024-0433 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2938fb2b-9083-5414-a3f5-79a213ecc1f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
