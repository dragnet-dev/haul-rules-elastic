// Dragnet [Ransomware]: dragnet-ransomware-2024-1944 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: a2e20fdf-1edc-5af7-8600-69f1c0ac13d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
