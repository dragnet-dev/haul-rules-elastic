// Dragnet [Ransomware]: dragnet-ransomware-2024-2790 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 916b4986-a481-5ff3-aebf-7294ef3e5de3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
