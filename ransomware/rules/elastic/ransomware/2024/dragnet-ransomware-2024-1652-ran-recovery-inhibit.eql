// Dragnet [Ransomware]: dragnet-ransomware-2024-1652 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 48aaf91f-6788-5947-8cc5-38fa63700779

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
