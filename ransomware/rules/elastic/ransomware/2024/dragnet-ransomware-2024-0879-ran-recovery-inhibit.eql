// Dragnet [Ransomware]: dragnet-ransomware-2024-0879 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7c42ae4a-db49-5fd4-93e3-751ab5d966c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
