// Dragnet [Ransomware]: dragnet-ransomware-2024-5829 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 26436dfa-bad5-5423-8dce-f8753383381f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
