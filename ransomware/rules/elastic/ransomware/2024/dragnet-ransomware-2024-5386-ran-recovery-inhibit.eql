// Dragnet [Ransomware]: dragnet-ransomware-2024-5386 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: fabc4763-8edc-53c0-9702-320f1f000869

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
