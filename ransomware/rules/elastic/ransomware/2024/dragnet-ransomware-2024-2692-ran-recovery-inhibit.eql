// Dragnet [Ransomware]: dragnet-ransomware-2024-2692 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 4879f272-06c9-57a5-9001-19a859734fe0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
