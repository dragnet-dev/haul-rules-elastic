// Dragnet [Ransomware]: dragnet-ransomware-2024-0392 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 0f6cb7b1-31b8-5de0-a3c9-7acd4e8f6c83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
