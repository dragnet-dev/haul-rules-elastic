// Dragnet [Ransomware]: dragnet-ransomware-2024-3429 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 3d0c3bde-bc6e-5f49-8aeb-ec277addf99e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
