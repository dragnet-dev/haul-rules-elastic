// Dragnet [Ransomware]: dragnet-ransomware-2024-1597 — Recovery Inhibition (argonauts)
// Status: experimental | Level: high | ID: c1bce421-209e-52f6-be95-9ab0edf114b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
