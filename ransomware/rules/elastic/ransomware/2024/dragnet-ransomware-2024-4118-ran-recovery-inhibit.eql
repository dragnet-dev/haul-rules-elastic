// Dragnet [Ransomware]: dragnet-ransomware-2024-4118 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2c7b647b-c0f1-5325-a717-55130e22f7b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
