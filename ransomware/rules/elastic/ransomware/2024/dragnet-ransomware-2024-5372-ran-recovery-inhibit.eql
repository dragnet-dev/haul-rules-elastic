// Dragnet [Ransomware]: dragnet-ransomware-2024-5372 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 043237a3-1908-5044-b5df-515452019f43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
