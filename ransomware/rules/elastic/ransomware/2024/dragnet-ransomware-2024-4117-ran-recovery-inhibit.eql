// Dragnet [Ransomware]: dragnet-ransomware-2024-4117 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c1d0d5a2-d0b3-5bfa-8de5-8386a454a024

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
