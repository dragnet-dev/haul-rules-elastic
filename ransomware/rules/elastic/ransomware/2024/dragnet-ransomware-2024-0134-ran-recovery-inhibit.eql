// Dragnet [Ransomware]: dragnet-ransomware-2024-0134 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 978991d4-8ebd-5e9d-bad5-6ebf4600df9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
