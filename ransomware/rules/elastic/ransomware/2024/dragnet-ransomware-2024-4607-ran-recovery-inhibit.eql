// Dragnet [Ransomware]: dragnet-ransomware-2024-4607 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d0ea60d0-866e-565b-89ee-4ad48aaba07f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
