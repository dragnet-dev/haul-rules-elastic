// Dragnet [Ransomware]: dragnet-ransomware-2024-5702 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 499e7deb-7fff-5660-8239-0f078d1aa1e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
