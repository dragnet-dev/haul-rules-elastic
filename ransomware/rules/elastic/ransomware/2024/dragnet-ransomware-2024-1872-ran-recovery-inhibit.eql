// Dragnet [Ransomware]: dragnet-ransomware-2024-1872 — Recovery Inhibition (redransomware)
// Status: deprecated | Level: high | ID: b5048dd3-7be3-5f9b-a228-79f77e1fb570

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
