// Dragnet [Ransomware]: dragnet-ransomware-2024-3219 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 774c6679-dc25-5c9d-9f4a-3a05b7c2a235

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
