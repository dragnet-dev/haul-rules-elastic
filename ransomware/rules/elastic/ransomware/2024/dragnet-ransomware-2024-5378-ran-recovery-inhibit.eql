// Dragnet [Ransomware]: dragnet-ransomware-2024-5378 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 26ffd045-fac3-56e4-bc94-8a9ec71c14d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
