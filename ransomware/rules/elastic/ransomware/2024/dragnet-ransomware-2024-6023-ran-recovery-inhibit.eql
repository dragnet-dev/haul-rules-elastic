// Dragnet [Ransomware]: dragnet-ransomware-2024-6023 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: fcd696a6-00cb-504e-8591-0f6f23da4a2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
