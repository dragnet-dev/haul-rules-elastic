// Dragnet [Ransomware]: dragnet-ransomware-2024-5730 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 0115c408-aa96-5971-8fba-a672007d30af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
