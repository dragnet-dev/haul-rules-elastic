// Dragnet [Ransomware]: dragnet-ransomware-2024-0277 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: 1cfedce7-91ce-5d5a-99a4-d55bf66c5b00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
