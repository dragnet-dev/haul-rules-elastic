// Dragnet [Ransomware]: dragnet-ransomware-2024-4513 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 1b9a10a4-c9fc-5438-b4b8-df87bbd9909e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
