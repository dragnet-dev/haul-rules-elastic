// Dragnet [Ransomware]: dragnet-ransomware-2024-1653 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c8ea2e92-bc85-54b4-bee9-5391ed9d1d63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
