// Dragnet [Ransomware]: dragnet-ransomware-2024-1376 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 44524d71-676c-5b39-b167-91e94eca8b86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
