// Dragnet [Ransomware]: dragnet-ransomware-2024-5196 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e75aedef-15ba-5f0a-9689-420d15ff4d3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
