// Dragnet [Ransomware]: dragnet-ransomware-2024-2779 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: f930c3e7-8fca-5675-944d-dcc3536f5716

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
