// Dragnet [Ransomware]: dragnet-ransomware-2024-3065 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: eee19832-6602-532b-b94a-3bc53bba6622

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
