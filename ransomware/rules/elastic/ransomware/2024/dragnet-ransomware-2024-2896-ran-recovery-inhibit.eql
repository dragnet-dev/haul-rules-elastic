// Dragnet [Ransomware]: dragnet-ransomware-2024-2896 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 0e34e263-fa8b-5413-9e15-821ecd815523

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
