// Dragnet [Ransomware]: dragnet-ransomware-2024-1981 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 7cd81c44-736e-5fd1-a58c-7eb2409e5302

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
