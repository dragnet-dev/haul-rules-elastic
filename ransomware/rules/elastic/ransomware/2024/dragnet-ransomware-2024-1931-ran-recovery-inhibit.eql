// Dragnet [Ransomware]: dragnet-ransomware-2024-1931 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 3fd006da-e86a-57fc-b319-db22aef62582

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
