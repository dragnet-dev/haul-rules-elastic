// Dragnet [Ransomware]: dragnet-ransomware-2024-2207 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 3881e574-742f-55d0-b3b4-2f68fcb5ffcf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
