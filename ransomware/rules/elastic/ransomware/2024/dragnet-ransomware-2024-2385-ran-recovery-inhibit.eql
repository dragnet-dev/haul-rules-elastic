// Dragnet [Ransomware]: dragnet-ransomware-2024-2385 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 39f5b1ae-deb3-5b68-abdc-a6794fa0c323

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
