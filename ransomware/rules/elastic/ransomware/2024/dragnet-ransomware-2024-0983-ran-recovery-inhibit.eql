// Dragnet [Ransomware]: dragnet-ransomware-2024-0983 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 405fbef4-486b-51e3-bdce-8ced1654122e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
