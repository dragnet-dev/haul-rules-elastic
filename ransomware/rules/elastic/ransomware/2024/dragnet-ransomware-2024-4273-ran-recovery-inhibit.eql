// Dragnet [Ransomware]: dragnet-ransomware-2024-4273 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 430ea046-8de0-5e25-ae12-5da2e236a2f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
