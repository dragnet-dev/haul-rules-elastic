// Dragnet [Ransomware]: dragnet-ransomware-2024-5076 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: c434ae1b-5649-5491-9f74-2099593b3730

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
