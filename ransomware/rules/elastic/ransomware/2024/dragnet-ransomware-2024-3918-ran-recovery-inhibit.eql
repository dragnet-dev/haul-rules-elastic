// Dragnet [Ransomware]: dragnet-ransomware-2024-3918 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 9b3b03ee-6a1f-5426-82e4-52ec5f2d8524

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
