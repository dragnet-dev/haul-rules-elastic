// Dragnet [Ransomware]: dragnet-ransomware-2024-2606 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: aa21f48e-0235-5475-94a0-8062e731efea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
