// Dragnet [Ransomware]: dragnet-ransomware-2024-5339 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 63253af0-a4ff-590e-935f-910b3ec65cb3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
