// Dragnet [Ransomware]: dragnet-ransomware-2024-2577 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 79d4acdc-308b-52dd-9924-4314cab265d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
