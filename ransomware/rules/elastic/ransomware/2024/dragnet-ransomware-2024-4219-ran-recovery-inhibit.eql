// Dragnet [Ransomware]: dragnet-ransomware-2024-4219 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a09b738d-899e-5dad-a52e-f92ffc147ebd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
