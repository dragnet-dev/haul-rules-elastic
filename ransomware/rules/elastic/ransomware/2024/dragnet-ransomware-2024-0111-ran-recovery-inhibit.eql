// Dragnet [Ransomware]: dragnet-ransomware-2024-0111 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 1ae0bddb-0968-5f01-9a29-800044ff31a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
