// Dragnet [Ransomware]: dragnet-ransomware-2024-1795 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 75467a63-3c11-5e04-b2af-12fdc78779f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
