// Dragnet [Ransomware]: dragnet-ransomware-2024-1703 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: e3e1cd54-c43b-561f-99bc-a2f2abbe68dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
