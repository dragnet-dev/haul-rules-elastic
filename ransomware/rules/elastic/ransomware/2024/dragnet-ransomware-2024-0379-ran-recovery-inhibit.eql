// Dragnet [Ransomware]: dragnet-ransomware-2024-0379 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 36189d0e-e999-5f44-b155-0098515a304f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
