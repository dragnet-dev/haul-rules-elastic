// Dragnet [Ransomware]: dragnet-ransomware-2024-1275 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 9e82c30f-73a1-56fa-b740-2c95892816bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
