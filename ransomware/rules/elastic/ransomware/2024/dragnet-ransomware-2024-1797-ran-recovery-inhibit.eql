// Dragnet [Ransomware]: dragnet-ransomware-2024-1797 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f673d289-050c-5fd4-ac82-ff05f07c8897

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
