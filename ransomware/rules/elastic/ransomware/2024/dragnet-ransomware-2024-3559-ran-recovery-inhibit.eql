// Dragnet [Ransomware]: dragnet-ransomware-2024-3559 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 270e778d-1301-54fd-bb48-c079d0b8f77f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
