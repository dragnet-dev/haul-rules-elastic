// Dragnet [Ransomware]: dragnet-ransomware-2024-4914 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: e97d5fc5-81fe-56ea-b08e-1f5fd4377477

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
