// Dragnet [Ransomware]: dragnet-ransomware-2024-4933 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 4e7b3dbc-c941-5bb5-b831-505f8cfd7063

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
