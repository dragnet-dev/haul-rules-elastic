// Dragnet [Ransomware]: dragnet-ransomware-2024-4561 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 373c7283-b4c9-5a99-9a3d-4a9d108b0a6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
