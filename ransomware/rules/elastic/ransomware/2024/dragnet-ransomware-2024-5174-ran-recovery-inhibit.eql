// Dragnet [Ransomware]: dragnet-ransomware-2024-5174 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: dbfcd09e-4e35-56bb-b672-34d4a790a073

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
