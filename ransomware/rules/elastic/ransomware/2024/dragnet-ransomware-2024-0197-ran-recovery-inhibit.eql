// Dragnet [Ransomware]: dragnet-ransomware-2024-0197 — Recovery Inhibition (redransomware)
// Status: deprecated | Level: high | ID: 724c20da-4fa3-515b-a82d-79560a237fbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
