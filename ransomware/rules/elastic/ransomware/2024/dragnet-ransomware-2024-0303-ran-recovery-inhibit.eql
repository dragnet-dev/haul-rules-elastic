// Dragnet [Ransomware]: dragnet-ransomware-2024-0303 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 80008cec-ec41-552c-bec3-8e6233739257

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
