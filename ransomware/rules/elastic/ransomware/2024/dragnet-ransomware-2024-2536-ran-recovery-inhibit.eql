// Dragnet [Ransomware]: dragnet-ransomware-2024-2536 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: a1427992-f541-54d2-8281-4722597df17d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
