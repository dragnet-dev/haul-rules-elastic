// Dragnet [Ransomware]: dragnet-ransomware-2024-4667 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 0a611bd1-4f1c-554f-9e2d-90f2459ce5ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
