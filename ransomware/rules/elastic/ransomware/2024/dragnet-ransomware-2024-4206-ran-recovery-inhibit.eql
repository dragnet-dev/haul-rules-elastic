// Dragnet [Ransomware]: dragnet-ransomware-2024-4206 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8d58c79b-a099-58d7-b868-b1bd4e687973

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
