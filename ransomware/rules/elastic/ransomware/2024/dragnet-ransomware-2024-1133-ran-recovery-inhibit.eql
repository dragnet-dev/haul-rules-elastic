// Dragnet [Ransomware]: dragnet-ransomware-2024-1133 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a5ecd660-ab96-5282-85ef-8634b60aec71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
