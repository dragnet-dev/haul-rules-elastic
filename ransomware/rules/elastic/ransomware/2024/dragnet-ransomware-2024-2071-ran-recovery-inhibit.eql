// Dragnet [Ransomware]: dragnet-ransomware-2024-2071 — Recovery Inhibition (donex)
// Status: experimental | Level: high | ID: 24d136fb-346b-5394-8bd1-4b195db669dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
