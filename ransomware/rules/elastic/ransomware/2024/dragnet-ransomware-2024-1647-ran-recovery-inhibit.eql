// Dragnet [Ransomware]: dragnet-ransomware-2024-1647 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bb29040b-b207-54ad-b688-44de29a6bda3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
