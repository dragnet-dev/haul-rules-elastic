// Dragnet [Ransomware]: dragnet-ransomware-2024-0901 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: d7eb72c1-4758-565b-a4d7-973040294f74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
