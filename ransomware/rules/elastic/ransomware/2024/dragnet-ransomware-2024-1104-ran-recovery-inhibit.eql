// Dragnet [Ransomware]: dragnet-ransomware-2024-1104 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: ad7ce863-57f8-51cc-8a09-cad8edc7feab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
