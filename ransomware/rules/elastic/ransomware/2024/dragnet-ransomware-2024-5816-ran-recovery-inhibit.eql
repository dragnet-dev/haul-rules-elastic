// Dragnet [Ransomware]: dragnet-ransomware-2024-5816 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: d88198d5-0bc6-57d1-8caf-0e98f2b1ef0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
