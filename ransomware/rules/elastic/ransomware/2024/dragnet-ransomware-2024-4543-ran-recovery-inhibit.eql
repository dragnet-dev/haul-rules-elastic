// Dragnet [Ransomware]: dragnet-ransomware-2024-4543 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 28e7a3cf-04cf-58b2-b3bf-348f9510e608

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
