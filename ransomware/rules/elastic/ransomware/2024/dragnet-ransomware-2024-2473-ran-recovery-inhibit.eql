// Dragnet [Ransomware]: dragnet-ransomware-2024-2473 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 2e0c0d76-39a0-5c47-8b25-a3b08e819ef7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
