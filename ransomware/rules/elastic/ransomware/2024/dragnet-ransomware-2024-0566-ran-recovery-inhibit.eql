// Dragnet [Ransomware]: dragnet-ransomware-2024-0566 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 75d0ef82-c328-5b51-a839-c2fa562914f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
