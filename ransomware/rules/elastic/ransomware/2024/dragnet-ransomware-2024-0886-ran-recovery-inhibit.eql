// Dragnet [Ransomware]: dragnet-ransomware-2024-0886 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: dc47b4a7-b40e-5a9e-991d-43bdca78a99c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
