// Dragnet [Ransomware]: dragnet-ransomware-2024-2586 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: e04ba003-bb77-52b6-8f9e-0bec964806d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
