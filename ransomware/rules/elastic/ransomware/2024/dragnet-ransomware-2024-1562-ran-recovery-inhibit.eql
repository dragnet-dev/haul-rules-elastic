// Dragnet [Ransomware]: dragnet-ransomware-2024-1562 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0f43122f-4d5b-5cd3-8c94-3ae811f8bc14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
