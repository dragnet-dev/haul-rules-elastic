// Dragnet [Ransomware]: dragnet-ransomware-2024-2114 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 562e82e7-1388-5173-bc53-e40178ada05d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
