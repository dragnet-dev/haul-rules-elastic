// Dragnet [Ransomware]: dragnet-ransomware-2024-0394 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: d65a678b-e95e-510e-993d-ec6e4f079c9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
