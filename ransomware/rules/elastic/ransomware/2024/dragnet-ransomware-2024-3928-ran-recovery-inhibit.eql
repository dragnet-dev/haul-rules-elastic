// Dragnet [Ransomware]: dragnet-ransomware-2024-3928 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 502e8327-2c2f-54e9-add5-b5bbdf067be2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
