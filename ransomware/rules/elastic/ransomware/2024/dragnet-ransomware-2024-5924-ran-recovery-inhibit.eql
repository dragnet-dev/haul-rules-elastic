// Dragnet [Ransomware]: dragnet-ransomware-2024-5924 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: cc2c5ce5-15be-5cef-a8fb-59673890b5f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
