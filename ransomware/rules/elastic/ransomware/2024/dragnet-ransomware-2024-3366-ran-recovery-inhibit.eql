// Dragnet [Ransomware]: dragnet-ransomware-2024-3366 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 06ba2463-4e20-55a3-8455-a9392d53e68c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
