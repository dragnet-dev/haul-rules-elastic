// Dragnet [Ransomware]: dragnet-ransomware-2024-1153 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6af510eb-2348-5717-96fc-133ed2899175

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
