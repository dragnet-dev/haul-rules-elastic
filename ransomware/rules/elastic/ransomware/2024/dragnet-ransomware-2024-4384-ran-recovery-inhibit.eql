// Dragnet [Ransomware]: dragnet-ransomware-2024-4384 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 093f5312-d76c-5cac-a448-e8ad4f9b41cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
