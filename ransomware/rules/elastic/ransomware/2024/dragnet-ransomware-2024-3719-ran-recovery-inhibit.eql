// Dragnet [Ransomware]: dragnet-ransomware-2024-3719 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 8030fd51-8493-5d46-a3c3-7d0d5f64395f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
