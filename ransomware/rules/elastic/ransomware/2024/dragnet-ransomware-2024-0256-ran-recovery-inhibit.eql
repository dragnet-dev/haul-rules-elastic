// Dragnet [Ransomware]: dragnet-ransomware-2024-0256 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: baae7876-9db2-5672-b614-5cae0007c81f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
