// Dragnet [Ransomware]: dragnet-ransomware-2024-0494 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a1466a09-18cf-5ca5-b110-66dbcc94b971

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
