// Dragnet [Ransomware]: dragnet-ransomware-2024-4845 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: 6473b369-a669-562f-bcb4-44f4deaf9132

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
