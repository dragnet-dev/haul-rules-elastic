// Dragnet [Ransomware]: dragnet-ransomware-2024-0305 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: 1756fd95-6d32-5978-86ea-26cf204bb7c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
