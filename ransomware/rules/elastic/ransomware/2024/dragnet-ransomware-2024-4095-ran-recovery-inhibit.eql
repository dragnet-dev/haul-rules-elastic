// Dragnet [Ransomware]: dragnet-ransomware-2024-4095 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: c57e5b03-d813-5ac2-8ba8-f5a4b7a3bf10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
