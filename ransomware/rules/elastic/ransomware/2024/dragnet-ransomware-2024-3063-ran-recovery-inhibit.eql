// Dragnet [Ransomware]: dragnet-ransomware-2024-3063 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c28d0a75-59ad-5a50-8f4f-966de5a29c6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
