// Dragnet [Ransomware]: dragnet-ransomware-2024-4733 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 2f3803f1-365c-5c80-b417-441213acb1f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
