// Dragnet [Ransomware]: dragnet-ransomware-2024-1845 — Recovery Inhibition (qiulong)
// Status: experimental | Level: high | ID: 1eb05ac5-ca75-5db8-8f42-2a17aa17f1ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
