// Dragnet [Ransomware]: dragnet-ransomware-2024-4290 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e3097d02-7b79-580c-bd5b-65f5e91837a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
