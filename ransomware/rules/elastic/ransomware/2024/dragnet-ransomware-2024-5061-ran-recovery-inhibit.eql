// Dragnet [Ransomware]: dragnet-ransomware-2024-5061 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d71ff71d-f698-58c4-95c8-51e8cb63c8ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
