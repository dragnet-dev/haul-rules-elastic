// Dragnet [Ransomware]: dragnet-ransomware-2024-2392 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: f542a518-dcdd-55e4-9a13-8d275b4cd6f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
