// Dragnet [Ransomware]: dragnet-ransomware-2024-2130 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 9d1d4797-6f86-5bfe-94c8-11d290839682

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
