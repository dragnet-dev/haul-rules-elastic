// Dragnet [Ransomware]: dragnet-ransomware-2024-1033 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 0426f282-1322-5fe5-bc57-0aedcbe3a032

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
