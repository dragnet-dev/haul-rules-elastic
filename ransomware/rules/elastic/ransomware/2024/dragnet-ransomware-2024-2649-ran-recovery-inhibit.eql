// Dragnet [Ransomware]: dragnet-ransomware-2024-2649 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: ea3dd2c0-8e0e-537e-ada1-7f9c7989fee6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
