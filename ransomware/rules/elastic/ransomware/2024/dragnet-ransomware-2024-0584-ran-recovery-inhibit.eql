// Dragnet [Ransomware]: dragnet-ransomware-2024-0584 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 089446b9-778b-5c65-aa22-3fb908871a09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
