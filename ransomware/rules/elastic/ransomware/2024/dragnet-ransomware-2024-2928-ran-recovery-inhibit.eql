// Dragnet [Ransomware]: dragnet-ransomware-2024-2928 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 61e434aa-127b-54a0-8ec7-4cb41692a37f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
