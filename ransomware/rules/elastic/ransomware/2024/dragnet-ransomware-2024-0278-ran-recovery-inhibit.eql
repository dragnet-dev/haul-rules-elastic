// Dragnet [Ransomware]: dragnet-ransomware-2024-0278 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bdc708f4-1577-5a0c-88a6-4b1be4bd0d4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
