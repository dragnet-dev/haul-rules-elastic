// Dragnet [Ransomware]: dragnet-ransomware-2024-1951 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 0936d5f0-456e-58b3-a05d-8ad51c3d1b63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
