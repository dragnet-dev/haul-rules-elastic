// Dragnet [Ransomware]: dragnet-ransomware-2024-3816 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 6730eeab-ed07-5263-b38f-b19b8875af65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
