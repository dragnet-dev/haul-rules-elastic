// Dragnet [Ransomware]: dragnet-ransomware-2024-2178 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: a9324c85-78c5-5b97-8a67-4df6597f6ec0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
