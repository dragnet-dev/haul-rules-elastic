// Dragnet [Ransomware]: dragnet-ransomware-2024-0483 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: 5d36f11f-c7c0-5c34-9894-bbbfac0f9dab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
