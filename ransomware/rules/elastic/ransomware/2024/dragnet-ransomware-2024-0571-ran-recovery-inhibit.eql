// Dragnet [Ransomware]: dragnet-ransomware-2024-0571 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 510ea358-9eed-5f34-8c7a-88ff5596ca8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
