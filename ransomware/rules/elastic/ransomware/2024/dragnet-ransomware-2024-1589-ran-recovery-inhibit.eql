// Dragnet [Ransomware]: dragnet-ransomware-2024-1589 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 105109d4-b803-5336-8ffb-eda82acd875a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
