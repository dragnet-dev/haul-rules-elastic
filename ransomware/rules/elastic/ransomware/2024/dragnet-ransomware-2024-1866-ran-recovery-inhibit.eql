// Dragnet [Ransomware]: dragnet-ransomware-2024-1866 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 2ea1c7ba-fb9e-517f-9cfc-aa8c7cb6672d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
