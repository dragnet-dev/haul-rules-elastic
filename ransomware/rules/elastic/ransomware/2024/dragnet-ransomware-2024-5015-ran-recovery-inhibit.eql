// Dragnet [Ransomware]: dragnet-ransomware-2024-5015 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 3ae9eb15-daf4-5e85-b4e3-73bdcc4ca116

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
