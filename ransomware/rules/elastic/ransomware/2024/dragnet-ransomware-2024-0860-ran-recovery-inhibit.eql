// Dragnet [Ransomware]: dragnet-ransomware-2024-0860 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 16359008-4d0d-5084-88ff-35ba7f840b78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
