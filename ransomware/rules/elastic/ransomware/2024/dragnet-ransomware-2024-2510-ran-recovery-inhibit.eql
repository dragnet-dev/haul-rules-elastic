// Dragnet [Ransomware]: dragnet-ransomware-2024-2510 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 122049ae-5783-5dfe-b015-a52e851d1e20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
