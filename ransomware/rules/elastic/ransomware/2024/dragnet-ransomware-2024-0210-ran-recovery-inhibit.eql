// Dragnet [Ransomware]: dragnet-ransomware-2024-0210 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1e502cb3-df6b-5da9-b812-af481c248ca1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
