// Dragnet [Ransomware]: dragnet-ransomware-2024-2986 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: c62e45ab-423d-562a-9e8d-63bd99586234

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
