// Dragnet [Ransomware]: dragnet-ransomware-2024-5221 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: a262bdd9-d2c6-5346-b255-08274ef28d7c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
