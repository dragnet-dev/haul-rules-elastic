// Dragnet [Ransomware]: dragnet-ransomware-2024-5815 — Recovery Inhibition (redransomware)
// Status: deprecated | Level: high | ID: fef98110-c35d-52d4-8cc6-7905047ef697

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
