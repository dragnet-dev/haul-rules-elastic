// Dragnet [Ransomware]: dragnet-ransomware-2024-0453 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: cfa03e02-dd42-5c3a-9eaf-9464ec08074d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
