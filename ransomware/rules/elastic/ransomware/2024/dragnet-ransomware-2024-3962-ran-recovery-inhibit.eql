// Dragnet [Ransomware]: dragnet-ransomware-2024-3962 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 543c23d1-fd02-508b-bdc5-18007b41a526

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
