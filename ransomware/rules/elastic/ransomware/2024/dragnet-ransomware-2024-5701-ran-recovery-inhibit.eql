// Dragnet [Ransomware]: dragnet-ransomware-2024-5701 — Recovery Inhibition (bluebox)
// Status: experimental | Level: high | ID: 92a33e08-0503-5eb5-8fe0-38740b5eebfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
