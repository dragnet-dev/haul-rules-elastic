// Dragnet [Ransomware]: dragnet-ransomware-2024-2956 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: 101563f2-882c-51d7-8d01-a4e0a137e7f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
