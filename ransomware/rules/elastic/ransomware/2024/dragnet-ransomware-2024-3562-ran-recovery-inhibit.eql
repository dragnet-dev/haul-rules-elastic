// Dragnet [Ransomware]: dragnet-ransomware-2024-3562 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f29a3a46-7611-5c27-8071-d56bc5fe2624

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
