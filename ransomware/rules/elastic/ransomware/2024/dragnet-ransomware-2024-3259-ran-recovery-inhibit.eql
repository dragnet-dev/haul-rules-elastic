// Dragnet [Ransomware]: dragnet-ransomware-2024-3259 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 7b1285ff-e590-518f-aa76-53c30643f503

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
