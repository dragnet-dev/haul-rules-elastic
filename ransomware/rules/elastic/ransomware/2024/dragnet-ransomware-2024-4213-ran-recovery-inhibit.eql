// Dragnet [Ransomware]: dragnet-ransomware-2024-4213 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 19f1b82c-3330-5b79-8523-0dffe65595b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
