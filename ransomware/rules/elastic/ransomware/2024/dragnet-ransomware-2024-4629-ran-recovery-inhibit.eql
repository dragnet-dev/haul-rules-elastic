// Dragnet [Ransomware]: dragnet-ransomware-2024-4629 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 66f1d6d9-f5d4-54db-abc5-6924c0f9f257

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
