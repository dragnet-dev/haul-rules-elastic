// Dragnet [Ransomware]: dragnet-ransomware-2024-4443 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: a1b427ed-0599-580f-81f3-73a7667a6e91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
