// Dragnet [Ransomware]: dragnet-ransomware-2024-2394 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 2534245a-8aa7-5954-9411-9188c4340c54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
