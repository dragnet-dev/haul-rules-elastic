// Dragnet [Ransomware]: dragnet-ransomware-2024-2250 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 05bc88d6-1249-5577-86f1-85ff4d12be3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
