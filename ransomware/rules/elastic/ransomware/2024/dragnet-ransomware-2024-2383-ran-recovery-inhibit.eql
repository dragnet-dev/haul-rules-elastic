// Dragnet [Ransomware]: dragnet-ransomware-2024-2383 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: df172d10-25aa-5645-a0cc-0a24eaec9c57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
