// Dragnet [Ransomware]: dragnet-ransomware-2024-1405 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7e88e6c8-e432-5fd5-83fc-a09b91dee6d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
