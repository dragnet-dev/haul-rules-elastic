// Dragnet [Ransomware]: dragnet-ransomware-2024-2121 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 3f80ba9d-57ad-559b-9eb7-59fa72952f06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
