// Dragnet [Ransomware]: dragnet-ransomware-2024-4650 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 4acdbf74-b4c0-5ad8-a6ce-2ac8e0453cda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
