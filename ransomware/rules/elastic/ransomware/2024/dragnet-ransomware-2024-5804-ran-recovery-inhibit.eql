// Dragnet [Ransomware]: dragnet-ransomware-2024-5804 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1a03f075-921f-5d0a-9164-92e40cf1d27e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
