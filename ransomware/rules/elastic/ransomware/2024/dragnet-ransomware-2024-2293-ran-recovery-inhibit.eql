// Dragnet [Ransomware]: dragnet-ransomware-2024-2293 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: a86d4d74-84e3-5f79-b2da-d85c59167fee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
