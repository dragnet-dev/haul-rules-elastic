// Dragnet [Ransomware]: dragnet-ransomware-2024-5707 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 606cb973-c4b7-5052-83d3-2b0e63709268

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
