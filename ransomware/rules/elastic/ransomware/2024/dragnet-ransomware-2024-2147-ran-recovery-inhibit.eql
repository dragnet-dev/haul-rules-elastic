// Dragnet [Ransomware]: dragnet-ransomware-2024-2147 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: aee09cdf-9ece-53af-a683-3d831b2db120

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
