// Dragnet [Ransomware]: dragnet-ransomware-2024-1855 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 72875f15-be41-5578-9d02-1468dc7d6629

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
