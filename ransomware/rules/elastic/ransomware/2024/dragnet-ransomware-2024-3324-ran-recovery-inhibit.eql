// Dragnet [Ransomware]: dragnet-ransomware-2024-3324 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 694eaf65-6ff6-5278-929a-4a10683370a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
