// Dragnet [Ransomware]: dragnet-ransomware-2024-3720 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 1b995f43-b88e-59c7-ba51-0be95eab1b05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
