// Dragnet [Ransomware]: dragnet-ransomware-2024-0857 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 24ecf9f8-4744-58a5-baa4-3a7b64b0e613

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
