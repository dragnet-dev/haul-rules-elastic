// Dragnet [Ransomware]: dragnet-ransomware-2024-0123 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: cbb31be9-535f-5f35-b916-d514aa1a8cf7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
