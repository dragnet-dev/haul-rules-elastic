// Dragnet [Ransomware]: dragnet-ransomware-2024-5794 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 570388ca-bd6e-5a69-8b32-03685f9eb8e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
