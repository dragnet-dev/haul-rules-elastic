// Dragnet [Ransomware]: dragnet-ransomware-2024-4160 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: 2555af27-19ec-5307-b338-5e18dc773b04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
