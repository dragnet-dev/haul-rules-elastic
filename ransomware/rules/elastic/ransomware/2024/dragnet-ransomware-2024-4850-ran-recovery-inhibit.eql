// Dragnet [Ransomware]: dragnet-ransomware-2024-4850 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e10c4964-a158-50ee-8b72-18afd123dde1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
