// Dragnet [Ransomware]: dragnet-ransomware-2024-2102 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1fba5e79-5e94-5c81-be33-64f5ae69b30c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
