// Dragnet [Ransomware]: dragnet-ransomware-2024-4960 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1e6b7ac9-dd59-5872-a0ee-e5ec320acd69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
