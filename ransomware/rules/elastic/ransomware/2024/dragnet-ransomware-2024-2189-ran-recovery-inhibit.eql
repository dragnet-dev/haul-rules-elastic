// Dragnet [Ransomware]: dragnet-ransomware-2024-2189 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f58b464d-5d8d-5378-aefa-9d12359b25aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
