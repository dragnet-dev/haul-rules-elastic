// Dragnet [Ransomware]: dragnet-ransomware-2024-3682 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: 3d838ca7-bb3a-50e4-9092-89474770dda9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
