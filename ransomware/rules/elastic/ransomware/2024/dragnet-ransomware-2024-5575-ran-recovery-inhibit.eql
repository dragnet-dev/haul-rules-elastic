// Dragnet [Ransomware]: dragnet-ransomware-2024-5575 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 31c81612-0f18-5556-a955-7e50be39a06c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
