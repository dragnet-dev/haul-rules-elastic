// Dragnet [Ransomware]: dragnet-ransomware-2024-4360 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 80eaf214-606d-53c4-bb35-21becab170d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
