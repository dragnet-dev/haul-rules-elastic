// Dragnet [Ransomware]: dragnet-ransomware-2024-4175 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b60b888a-6c4a-586b-8aab-41567946f7eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
