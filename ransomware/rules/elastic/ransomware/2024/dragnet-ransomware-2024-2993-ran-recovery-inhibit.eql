// Dragnet [Ransomware]: dragnet-ransomware-2024-2993 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: ca89e2ed-3ce0-5694-b4d8-457f77d163fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
