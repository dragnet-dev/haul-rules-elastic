// Dragnet [Ransomware]: dragnet-ransomware-2024-0608 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c992e737-fd82-540e-8c58-ceb97de91793

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
