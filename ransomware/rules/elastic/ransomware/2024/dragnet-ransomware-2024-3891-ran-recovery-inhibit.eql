// Dragnet [Ransomware]: dragnet-ransomware-2024-3891 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 5f9d1e30-72c7-553c-abef-6b4729b65f5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
