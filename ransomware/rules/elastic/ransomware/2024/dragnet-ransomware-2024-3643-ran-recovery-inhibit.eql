// Dragnet [Ransomware]: dragnet-ransomware-2024-3643 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 51733cdc-92ca-5adb-87f2-f665a9bc548d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
