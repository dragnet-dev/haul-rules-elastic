// Dragnet [Ransomware]: dragnet-ransomware-2024-3987 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 20b57864-f3d6-51d7-bdc9-8cdcaf9fa35e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
