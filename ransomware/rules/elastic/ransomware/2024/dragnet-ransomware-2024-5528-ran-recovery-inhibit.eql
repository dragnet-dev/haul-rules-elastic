// Dragnet [Ransomware]: dragnet-ransomware-2024-5528 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5227a959-f590-55aa-917e-fcd40805d4d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
