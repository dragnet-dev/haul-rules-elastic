// Dragnet [Ransomware]: dragnet-ransomware-2024-5952 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7b2cf3bd-9efb-54c8-a315-0de482d8c3f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
