// Dragnet [Ransomware]: dragnet-ransomware-2024-2982 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: c123a478-9cf2-590d-b56e-1cb419de74f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
