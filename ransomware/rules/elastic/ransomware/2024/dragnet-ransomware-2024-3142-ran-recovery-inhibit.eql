// Dragnet [Ransomware]: dragnet-ransomware-2024-3142 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: bee21643-19bd-5adc-b617-64784b2673da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
