// Dragnet [Ransomware]: dragnet-ransomware-2024-3468 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 199e06bd-490b-5c6f-a887-54d97476cff7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
