// Dragnet [Ransomware]: dragnet-ransomware-2024-1734 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: e73a834e-286f-5e90-a039-5e91602f7c11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
