// Dragnet [Ransomware]: dragnet-ransomware-2024-3755 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: e7effc65-1635-5351-a632-6482ce70ae3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
