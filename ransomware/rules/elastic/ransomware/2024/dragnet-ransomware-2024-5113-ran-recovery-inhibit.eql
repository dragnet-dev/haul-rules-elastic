// Dragnet [Ransomware]: dragnet-ransomware-2024-5113 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 84900c04-7910-5108-8110-253034617364

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
