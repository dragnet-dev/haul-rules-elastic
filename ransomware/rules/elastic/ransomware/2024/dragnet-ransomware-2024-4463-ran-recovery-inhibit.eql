// Dragnet [Ransomware]: dragnet-ransomware-2024-4463 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 3f65daac-808d-50e8-bdb0-69c5f3931a33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
