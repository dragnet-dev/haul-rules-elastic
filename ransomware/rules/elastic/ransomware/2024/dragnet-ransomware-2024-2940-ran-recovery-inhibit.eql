// Dragnet [Ransomware]: dragnet-ransomware-2024-2940 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: f0f8fd62-cceb-5ef5-806b-c955173a3c00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
