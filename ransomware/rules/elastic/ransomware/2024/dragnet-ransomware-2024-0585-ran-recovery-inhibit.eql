// Dragnet [Ransomware]: dragnet-ransomware-2024-0585 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ae947a9f-0a30-589e-997f-6cc923bb7297

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
