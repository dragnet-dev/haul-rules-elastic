// Dragnet [Ransomware]: dragnet-ransomware-2024-2669 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 454a1786-f3cf-52b2-bf1b-949d4859107d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
