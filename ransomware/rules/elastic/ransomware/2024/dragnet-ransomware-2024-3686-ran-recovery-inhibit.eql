// Dragnet [Ransomware]: dragnet-ransomware-2024-3686 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: ccb2ae2c-c460-59f4-aa53-a0175005ed88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
