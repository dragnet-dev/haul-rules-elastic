// Dragnet [Ransomware]: dragnet-ransomware-2024-0594 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7cad0588-528d-5e13-8b15-6cb166442dde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
