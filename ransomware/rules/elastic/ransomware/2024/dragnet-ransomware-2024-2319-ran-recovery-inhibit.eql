// Dragnet [Ransomware]: dragnet-ransomware-2024-2319 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 0bc64a0e-b609-5dd0-ba02-c1e5dd6856a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
