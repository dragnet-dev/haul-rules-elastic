// Dragnet [Ransomware]: dragnet-ransomware-2024-1910 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: a72feccc-5bf4-512d-a23a-70b8bc161d01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
