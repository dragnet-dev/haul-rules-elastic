// Dragnet [Ransomware]: dragnet-ransomware-2024-3786 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: b08a30ed-dd12-515f-b47f-eafae38dddc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
