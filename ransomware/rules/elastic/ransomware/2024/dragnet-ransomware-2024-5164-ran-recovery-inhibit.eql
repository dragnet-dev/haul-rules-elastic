// Dragnet [Ransomware]: dragnet-ransomware-2024-5164 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: e5c425da-2bc0-55b4-91ef-c2047212760c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
