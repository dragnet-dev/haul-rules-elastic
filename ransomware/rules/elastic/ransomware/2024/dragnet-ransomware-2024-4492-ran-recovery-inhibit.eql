// Dragnet [Ransomware]: dragnet-ransomware-2024-4492 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: c70899c9-9447-5dee-927e-6c368e1b478a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
