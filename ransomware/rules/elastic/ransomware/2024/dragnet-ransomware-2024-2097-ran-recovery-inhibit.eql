// Dragnet [Ransomware]: dragnet-ransomware-2024-2097 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 8674ea29-3a21-50b3-af2f-aaad5200cfe2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
