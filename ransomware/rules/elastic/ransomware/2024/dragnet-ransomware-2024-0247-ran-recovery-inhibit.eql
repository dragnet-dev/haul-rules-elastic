// Dragnet [Ransomware]: dragnet-ransomware-2024-0247 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 20150164-c80d-5457-bba5-fe6c63682d20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
