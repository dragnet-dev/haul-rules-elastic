// Dragnet [Ransomware]: dragnet-ransomware-2024-3964 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 4cb0faa3-ea0e-5f5c-a12b-b2b627b54af2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
