// Dragnet [Ransomware]: dragnet-ransomware-2024-5650 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 8314145c-e45f-57f8-b57d-f6dda2575b2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
