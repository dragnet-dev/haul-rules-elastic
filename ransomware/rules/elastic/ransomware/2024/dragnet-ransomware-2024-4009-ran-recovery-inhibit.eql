// Dragnet [Ransomware]: dragnet-ransomware-2024-4009 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8fc81584-6ada-51d2-895c-f198be704c95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
