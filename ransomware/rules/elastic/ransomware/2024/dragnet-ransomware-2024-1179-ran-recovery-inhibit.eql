// Dragnet [Ransomware]: dragnet-ransomware-2024-1179 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: 48b3e6ab-c50a-5843-a614-d291868fb569

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
