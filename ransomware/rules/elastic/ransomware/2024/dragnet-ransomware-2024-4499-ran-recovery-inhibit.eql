// Dragnet [Ransomware]: dragnet-ransomware-2024-4499 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f7b2e79e-7a17-5aec-a463-8768b9201024

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
