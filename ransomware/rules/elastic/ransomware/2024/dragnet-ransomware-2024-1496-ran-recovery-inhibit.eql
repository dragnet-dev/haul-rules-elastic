// Dragnet [Ransomware]: dragnet-ransomware-2024-1496 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 103f4454-e3dd-5b9a-a46e-2514a6db250a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
