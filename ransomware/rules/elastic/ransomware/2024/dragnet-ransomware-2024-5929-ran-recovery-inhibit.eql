// Dragnet [Ransomware]: dragnet-ransomware-2024-5929 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 254b8224-928d-5e14-be19-1e01e3777ff7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
