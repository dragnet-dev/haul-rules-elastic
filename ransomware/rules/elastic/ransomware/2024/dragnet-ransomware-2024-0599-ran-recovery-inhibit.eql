// Dragnet [Ransomware]: dragnet-ransomware-2024-0599 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: fc07e143-d408-57e0-80e8-9600916cebf8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
