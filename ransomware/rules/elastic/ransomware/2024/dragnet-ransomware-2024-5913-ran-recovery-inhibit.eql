// Dragnet [Ransomware]: dragnet-ransomware-2024-5913 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1db897fe-13f6-520f-a4c5-672ea985221d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
