// Dragnet [Ransomware]: dragnet-ransomware-2024-1759 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 82af2c92-aa14-59bb-ab9f-eff152558623

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
