// Dragnet [Ransomware]: dragnet-ransomware-2024-2909 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: fd76a8d7-abff-5747-bab9-519366dbeb78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
