// Dragnet [Ransomware]: dragnet-ransomware-2024-5400 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 92cc65cb-87ba-5f77-8272-108d7ad1f734

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
