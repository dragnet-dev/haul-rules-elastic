// Dragnet [Ransomware]: dragnet-ransomware-2024-2899 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: bf3e28e8-6464-513c-bb9c-0f41aa2f1e86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
