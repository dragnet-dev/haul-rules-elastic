// Dragnet [Ransomware]: dragnet-ransomware-2024-0249 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c866b32b-3206-5434-9d1a-537c6980967d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
