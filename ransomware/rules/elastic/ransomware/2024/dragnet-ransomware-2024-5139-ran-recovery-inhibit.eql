// Dragnet [Ransomware]: dragnet-ransomware-2024-5139 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: c5e59c09-5095-578a-8a3b-1f842f551aa1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
