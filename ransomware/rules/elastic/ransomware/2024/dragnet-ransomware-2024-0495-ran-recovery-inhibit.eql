// Dragnet [Ransomware]: dragnet-ransomware-2024-0495 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 6160f249-5e39-5046-bf73-c4140ede9df9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
