// Dragnet [Ransomware]: dragnet-ransomware-2024-1002 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 2ca721d8-68cd-50cb-b534-9117b3f2de87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
