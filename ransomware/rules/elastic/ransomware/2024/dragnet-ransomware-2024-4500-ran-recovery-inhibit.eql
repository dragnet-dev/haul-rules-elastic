// Dragnet [Ransomware]: dragnet-ransomware-2024-4500 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: 08c25faa-0880-54fb-84a1-3b5309b0f401

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
