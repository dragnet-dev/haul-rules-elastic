// Dragnet [Ransomware]: dragnet-ransomware-2024-0649 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: 8af0070f-ed31-59ca-9949-b50fd19fae2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
