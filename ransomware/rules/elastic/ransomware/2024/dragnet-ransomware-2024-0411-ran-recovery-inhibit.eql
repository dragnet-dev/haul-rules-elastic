// Dragnet [Ransomware]: dragnet-ransomware-2024-0411 — Recovery Inhibition (ElDorado)
// Status: experimental | Level: high | ID: 1a611758-419d-5835-86f6-f9ab38231b45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
