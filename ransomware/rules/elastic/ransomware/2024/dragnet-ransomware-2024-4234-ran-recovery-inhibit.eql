// Dragnet [Ransomware]: dragnet-ransomware-2024-4234 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: fde27162-7641-557c-8b3e-395e503e39ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
