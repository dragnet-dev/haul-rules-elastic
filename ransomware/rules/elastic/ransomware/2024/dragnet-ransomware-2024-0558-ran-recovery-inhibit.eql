// Dragnet [Ransomware]: dragnet-ransomware-2024-0558 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: a650586d-88a5-597c-bd2c-6bcccc096cdc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
