// Dragnet [Ransomware]: dragnet-ransomware-2024-2540 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 316a9522-f83d-5c2e-a0ff-096cf6264af6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
