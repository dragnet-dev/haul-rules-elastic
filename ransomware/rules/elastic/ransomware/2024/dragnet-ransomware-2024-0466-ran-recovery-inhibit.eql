// Dragnet [Ransomware]: dragnet-ransomware-2024-0466 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f73d8068-21b6-543d-8a2d-6f9362b5c140

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
