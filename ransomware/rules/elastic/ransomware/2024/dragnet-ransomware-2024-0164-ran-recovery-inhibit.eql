// Dragnet [Ransomware]: dragnet-ransomware-2024-0164 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4560ff56-2abf-5e76-aa89-9829c0a369e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
