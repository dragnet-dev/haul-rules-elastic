// Dragnet [Ransomware]: dragnet-ransomware-2024-3864 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 0ca57667-5345-5ab9-b036-8554b7238092

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
