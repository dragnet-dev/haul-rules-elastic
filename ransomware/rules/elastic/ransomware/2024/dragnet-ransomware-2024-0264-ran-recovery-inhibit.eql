// Dragnet [Ransomware]: dragnet-ransomware-2024-0264 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1189d2de-632b-591b-b588-1f1d29bac48b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
