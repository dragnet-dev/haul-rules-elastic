// Dragnet [Ransomware]: dragnet-ransomware-2024-2906 — Recovery Inhibition (redransomware)
// Status: deprecated | Level: high | ID: a5f50082-32b6-5e91-9104-245aeb469db1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
