// Dragnet [Ransomware]: dragnet-ransomware-2024-4852 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c2716fa2-ced7-5323-83b9-cdbe661345e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
