// Dragnet [Ransomware]: dragnet-ransomware-2024-0260 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ce1edf0d-14f4-5d4e-87b5-2616f82fde3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
