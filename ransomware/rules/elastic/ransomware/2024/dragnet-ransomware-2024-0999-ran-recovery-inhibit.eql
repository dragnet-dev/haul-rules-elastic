// Dragnet [Ransomware]: dragnet-ransomware-2024-0999 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: d4354c53-22b5-588f-a470-fbbbc99274dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
