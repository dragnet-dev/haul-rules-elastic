// Dragnet [Ransomware]: dragnet-ransomware-2024-0877 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 38b95701-8be0-588a-b001-91a844a84a66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
