// Dragnet [Ransomware]: dragnet-ransomware-2024-4032 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1d889698-ca25-5932-83fe-dc8f1daf7809

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
