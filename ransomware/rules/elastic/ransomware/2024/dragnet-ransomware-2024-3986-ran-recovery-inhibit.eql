// Dragnet [Ransomware]: dragnet-ransomware-2024-3986 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: aea99958-ee1b-5e4c-b1b4-d4614b3b3f1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
