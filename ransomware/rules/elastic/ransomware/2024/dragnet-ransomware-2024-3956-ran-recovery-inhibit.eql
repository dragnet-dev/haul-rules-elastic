// Dragnet [Ransomware]: dragnet-ransomware-2024-3956 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 463e84aa-c814-522c-8d6c-2ac77b6b8c02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
