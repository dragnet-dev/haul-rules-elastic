// Dragnet [Ransomware]: dragnet-ransomware-2024-4687 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 18f8dd06-926a-5c25-99b2-75da2b4c019a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
