// Dragnet [Ransomware]: dragnet-ransomware-2024-5006 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: bf3cdad7-1469-5acc-987e-abf163e2109b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
