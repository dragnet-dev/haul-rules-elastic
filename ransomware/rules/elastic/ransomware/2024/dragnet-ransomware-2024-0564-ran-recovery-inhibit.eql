// Dragnet [Ransomware]: dragnet-ransomware-2024-0564 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 064865b6-0dc9-5403-a88b-b2e466433a4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
