// Dragnet [Ransomware]: dragnet-ransomware-2024-0457 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 60619236-ebfe-5d15-ae52-4e0afe9fc64d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
