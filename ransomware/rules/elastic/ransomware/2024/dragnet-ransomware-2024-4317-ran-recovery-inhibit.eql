// Dragnet [Ransomware]: dragnet-ransomware-2024-4317 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 24c1d565-cb2e-511b-b779-d8750e9e33c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
