// Dragnet [Ransomware]: dragnet-ransomware-2024-3228 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4ba3d795-1268-58a3-be58-cb57af73689e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
