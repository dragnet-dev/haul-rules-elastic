// Dragnet [Ransomware]: dragnet-ransomware-2024-4328 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: abeccbe6-46a4-5073-9ac8-16d0a87bf059

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
