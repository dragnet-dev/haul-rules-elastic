// Dragnet [Ransomware]: dragnet-ransomware-2024-0179 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: c5a1dcea-1a47-5a18-8d8e-b3352fe48d6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
