// Dragnet [Ransomware]: dragnet-ransomware-2024-1233 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 52a1b8d1-0c64-52e6-afcb-4aa4bc0144b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
