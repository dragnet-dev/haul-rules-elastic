// Dragnet [Ransomware]: dragnet-ransomware-2024-1455 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: af762162-b2aa-5e33-bdab-42fa9a80ca98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
