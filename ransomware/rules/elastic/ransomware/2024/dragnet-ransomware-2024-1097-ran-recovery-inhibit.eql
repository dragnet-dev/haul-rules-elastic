// Dragnet [Ransomware]: dragnet-ransomware-2024-1097 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 725e904b-77e1-53cf-9165-f4b95c764dbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
