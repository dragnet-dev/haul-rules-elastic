// Dragnet [Ransomware]: dragnet-ransomware-2024-4051 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 6932a4e1-ba60-5212-86c7-24a168a66a82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
