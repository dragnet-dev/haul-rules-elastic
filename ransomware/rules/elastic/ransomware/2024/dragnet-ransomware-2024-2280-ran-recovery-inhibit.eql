// Dragnet [Ransomware]: dragnet-ransomware-2024-2280 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: fa4319e7-f5f6-504d-b69d-aec6124609c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
