// Dragnet [Ransomware]: dragnet-ransomware-2024-2239 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 5db40c7a-8a23-5717-ad0b-262dfed4985a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
