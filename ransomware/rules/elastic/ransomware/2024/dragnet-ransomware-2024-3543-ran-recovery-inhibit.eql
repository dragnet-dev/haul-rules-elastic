// Dragnet [Ransomware]: dragnet-ransomware-2024-3543 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: cb522cfa-126e-5bda-813b-99c7e239ad6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
