// Dragnet [Ransomware]: dragnet-ransomware-2024-3230 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 5a667753-5787-5385-9b7b-bcf66567a5a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
