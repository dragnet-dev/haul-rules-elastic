// Dragnet [Ransomware]: dragnet-ransomware-2024-1452 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: 330924a7-aac6-51be-87a6-a1ef1978985e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
