// Dragnet [Ransomware]: dragnet-ransomware-2024-0023 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: db29d404-cd90-5141-83fe-202ebcc27e66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
