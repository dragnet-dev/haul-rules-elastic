// Dragnet [Ransomware]: dragnet-ransomware-2024-1833 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: fe245329-3663-58c3-b185-0a83a50f0951

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
