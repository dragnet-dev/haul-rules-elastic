// Dragnet [Ransomware]: dragnet-ransomware-2024-2442 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9804d087-96eb-54e0-9233-7eccd04ac5dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
