// Dragnet [Ransomware]: dragnet-ransomware-2024-1463 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: eabd0bab-e9a1-518f-9aa3-53a4438eb03c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
