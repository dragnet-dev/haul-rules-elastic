// Dragnet [Ransomware]: dragnet-ransomware-2024-0046 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: cdedea7c-5e1c-5488-a24c-e30da3a0f653

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
