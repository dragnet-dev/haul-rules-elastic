// Dragnet [Ransomware]: dragnet-ransomware-2024-0759 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: b2c29871-230f-538d-ad4b-b1f47a17276f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
