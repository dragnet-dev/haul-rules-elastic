// Dragnet [Ransomware]: dragnet-ransomware-2024-5141 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: cdae451f-1550-5530-bdc0-7e1c98ccbdda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
