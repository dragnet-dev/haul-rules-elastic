// Dragnet [Ransomware]: dragnet-ransomware-2024-0242 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: e8501938-eb5f-5893-b9d8-beeb0d9ee806

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
