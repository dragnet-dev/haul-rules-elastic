// Dragnet [Ransomware]: dragnet-ransomware-2024-1523 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7c7ea0a8-3206-59a9-b0ce-6b7397aeff93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
