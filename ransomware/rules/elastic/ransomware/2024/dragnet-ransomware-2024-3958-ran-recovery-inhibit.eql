// Dragnet [Ransomware]: dragnet-ransomware-2024-3958 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 2f95f89d-e771-5e11-a90f-0e30f9cfbd2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
