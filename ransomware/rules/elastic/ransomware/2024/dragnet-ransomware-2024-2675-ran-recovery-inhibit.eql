// Dragnet [Ransomware]: dragnet-ransomware-2024-2675 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: e9686e58-6c6a-55e8-b02a-72ef7e2e93d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
