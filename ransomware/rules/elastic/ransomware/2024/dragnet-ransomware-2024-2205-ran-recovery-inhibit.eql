// Dragnet [Ransomware]: dragnet-ransomware-2024-2205 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c30f3662-84b0-544d-8bce-a052a430c5eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
