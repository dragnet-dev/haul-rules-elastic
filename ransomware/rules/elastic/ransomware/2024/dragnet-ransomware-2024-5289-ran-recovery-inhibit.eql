// Dragnet [Ransomware]: dragnet-ransomware-2024-5289 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 0a06e067-880b-568d-99de-2b09d639622e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
