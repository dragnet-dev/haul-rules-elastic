// Dragnet [Ransomware]: dragnet-ransomware-2024-3579 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: ee14ab95-0665-5152-b6b3-0b9113e98939

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
