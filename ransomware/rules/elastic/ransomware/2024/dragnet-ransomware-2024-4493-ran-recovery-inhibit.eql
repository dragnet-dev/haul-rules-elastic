// Dragnet [Ransomware]: dragnet-ransomware-2024-4493 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 5b8192ba-d01f-54fe-9833-75bb2fbe20a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
