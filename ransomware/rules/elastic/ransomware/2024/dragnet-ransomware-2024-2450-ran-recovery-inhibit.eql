// Dragnet [Ransomware]: dragnet-ransomware-2024-2450 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 704e10fa-5c1f-597c-8a9c-b4bb4eb4df54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
