// Dragnet [Ransomware]: dragnet-ransomware-2024-5747 — Recovery Inhibition (argonauts)
// Status: experimental | Level: high | ID: d0c28f0f-d931-56c9-8948-786ea9d7c74f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
