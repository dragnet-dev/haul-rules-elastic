// Dragnet [Ransomware]: dragnet-ransomware-2024-0044 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 3ef0dfee-c851-51e2-8243-8558338e288e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
