// Dragnet [Ransomware]: dragnet-ransomware-2024-5871 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 44996a43-4a35-5f6b-a674-6b8c26296164

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
