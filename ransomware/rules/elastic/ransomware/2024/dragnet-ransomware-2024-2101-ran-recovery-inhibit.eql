// Dragnet [Ransomware]: dragnet-ransomware-2024-2101 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: a7738232-79af-5413-b500-4bdd9d5f28ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
