// Dragnet [Ransomware]: dragnet-ransomware-2024-3838 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c1a228b4-e463-52a9-ab66-283f558f0ad4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
