// Dragnet [Ransomware]: dragnet-ransomware-2024-5641 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 5a7430dc-1686-5212-a1e9-2326cdb8803c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
