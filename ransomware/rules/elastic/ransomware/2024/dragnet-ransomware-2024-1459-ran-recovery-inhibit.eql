// Dragnet [Ransomware]: dragnet-ransomware-2024-1459 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c94cc9af-c3b0-53c2-9064-7221586e4bff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
