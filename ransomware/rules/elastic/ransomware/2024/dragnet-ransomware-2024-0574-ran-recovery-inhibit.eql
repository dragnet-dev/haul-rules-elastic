// Dragnet [Ransomware]: dragnet-ransomware-2024-0574 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ed2d1261-feaa-5f57-ba1f-3023fb98a61b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
