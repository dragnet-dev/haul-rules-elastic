// Dragnet [Ransomware]: dragnet-ransomware-2024-1513 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 483391b0-d364-58d2-a941-83d0d8a2d4f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
