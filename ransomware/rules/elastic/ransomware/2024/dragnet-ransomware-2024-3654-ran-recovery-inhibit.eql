// Dragnet [Ransomware]: dragnet-ransomware-2024-3654 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 823381eb-d21e-5133-8f32-31b4e49057b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
