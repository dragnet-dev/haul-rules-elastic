// Dragnet [Ransomware]: dragnet-ransomware-2024-4148 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: cd0d21e1-995a-5c08-9513-234c4cbf817d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
