// Dragnet [Ransomware]: dragnet-ransomware-2024-0168 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: b00e2e2a-fedb-5ad0-b9a2-b50c067e2726

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
