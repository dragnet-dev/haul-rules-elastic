// Dragnet [Ransomware]: dragnet-ransomware-2024-2082 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d17b51ac-12ba-5821-8cb9-7539dcdab091

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
