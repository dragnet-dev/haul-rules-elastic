// Dragnet [Ransomware]: dragnet-ransomware-2024-0953 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: d8ec31f1-dc06-5b04-a2c6-0cc13d38dfce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
