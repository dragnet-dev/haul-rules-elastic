// Dragnet [Ransomware]: dragnet-ransomware-2024-5620 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: cad96b32-bb8e-56d9-aaf0-764114448a3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
