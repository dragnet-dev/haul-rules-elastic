// Dragnet [Ransomware]: dragnet-ransomware-2024-0014 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 8393c5ad-8608-5ead-b01c-c41b5c56fe34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
