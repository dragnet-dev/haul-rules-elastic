// Dragnet [Ransomware]: dragnet-ransomware-2024-1137 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 93b15835-9eca-59de-9688-7f7cbfeb0c0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
