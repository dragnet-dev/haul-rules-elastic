// Dragnet [Ransomware]: dragnet-ransomware-2024-3383 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: 0f5784fd-cdb7-5831-aab0-7e8ab6253d44

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
