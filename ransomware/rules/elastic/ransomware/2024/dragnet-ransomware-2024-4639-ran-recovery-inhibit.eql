// Dragnet [Ransomware]: dragnet-ransomware-2024-4639 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2ed7d466-a6bd-5584-97d6-e4a0d8bc3bb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
