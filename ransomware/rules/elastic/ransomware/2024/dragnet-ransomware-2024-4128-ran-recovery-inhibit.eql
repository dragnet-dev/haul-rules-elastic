// Dragnet [Ransomware]: dragnet-ransomware-2024-4128 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: 73b9ca76-5658-52a2-b228-eaf9a91053e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
