// Dragnet [Ransomware]: dragnet-ransomware-2024-0809 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3c029256-a869-5535-8b65-69882915fb64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
