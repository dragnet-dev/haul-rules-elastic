// Dragnet [Ransomware]: dragnet-ransomware-2024-4838 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 1897c4e6-5548-598f-bcd5-836c6237c6a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
