// Dragnet [Ransomware]: dragnet-ransomware-2024-4378 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1fdd320d-dbde-5c9b-b62d-476cdf359690

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
