// Dragnet [Ransomware]: dragnet-ransomware-2024-0779 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4703a788-5f8d-51fc-b4d3-66d3c01f7dd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
