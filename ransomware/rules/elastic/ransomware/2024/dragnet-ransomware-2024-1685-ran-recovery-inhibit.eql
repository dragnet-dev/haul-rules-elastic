// Dragnet [Ransomware]: dragnet-ransomware-2024-1685 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 15eaaf1b-54e8-500b-a63d-92eb24f8bd9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
