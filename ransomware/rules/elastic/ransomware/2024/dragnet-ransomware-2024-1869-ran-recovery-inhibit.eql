// Dragnet [Ransomware]: dragnet-ransomware-2024-1869 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 687fe538-9bb1-5347-b9cf-1e8e977f84b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
