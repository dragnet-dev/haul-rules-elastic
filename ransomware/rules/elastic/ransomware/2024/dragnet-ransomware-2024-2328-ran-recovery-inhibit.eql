// Dragnet [Ransomware]: dragnet-ransomware-2024-2328 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 98448e15-e6f3-5b7d-9d5b-5d80ac86f984

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
