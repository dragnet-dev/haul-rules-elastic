// Dragnet [Ransomware]: dragnet-ransomware-2024-1453 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 976bdb6f-32b3-59a1-8a2e-70519e06a82d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
