// Dragnet [Ransomware]: dragnet-ransomware-2024-2723 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 6827bc96-06c5-5767-98fb-bee9a4a0a621

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
