// Dragnet [Ransomware]: dragnet-ransomware-2024-3994 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5df762d3-c3ca-5e4c-b6c7-21a86156dde5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
