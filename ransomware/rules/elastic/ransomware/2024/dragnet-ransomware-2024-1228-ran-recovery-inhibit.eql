// Dragnet [Ransomware]: dragnet-ransomware-2024-1228 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: a912170f-b2cd-51af-8400-7a5b168da604

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
