// Dragnet [Ransomware]: dragnet-ransomware-2024-4465 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 6ea242d3-5acb-5999-bd80-a14c9911f43a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
