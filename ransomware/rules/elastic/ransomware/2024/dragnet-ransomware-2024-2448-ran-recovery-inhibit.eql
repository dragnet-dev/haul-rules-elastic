// Dragnet [Ransomware]: dragnet-ransomware-2024-2448 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c01870db-9670-5435-9593-603bebd973ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
