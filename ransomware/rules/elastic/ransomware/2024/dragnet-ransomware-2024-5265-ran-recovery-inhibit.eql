// Dragnet [Ransomware]: dragnet-ransomware-2024-5265 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: dc0fff86-d873-5ecf-b548-57c27d370c9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
