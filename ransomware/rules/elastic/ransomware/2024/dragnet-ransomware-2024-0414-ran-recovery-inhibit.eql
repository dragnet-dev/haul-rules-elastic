// Dragnet [Ransomware]: dragnet-ransomware-2024-0414 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: f24b255d-e6c1-50b1-ac2c-4696ba8b9dd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
