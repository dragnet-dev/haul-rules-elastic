// Dragnet [Ransomware]: dragnet-ransomware-2024-5423 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 248156ee-0652-5c3c-9458-91e8b3c35514

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
