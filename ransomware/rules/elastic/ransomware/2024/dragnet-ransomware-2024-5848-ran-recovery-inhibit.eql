// Dragnet [Ransomware]: dragnet-ransomware-2024-5848 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 12142603-b757-5096-a779-12c6dd54f9e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
