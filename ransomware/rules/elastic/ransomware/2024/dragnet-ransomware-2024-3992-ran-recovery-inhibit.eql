// Dragnet [Ransomware]: dragnet-ransomware-2024-3992 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 97878339-07e7-54e2-8deb-e36d9c3a243d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
