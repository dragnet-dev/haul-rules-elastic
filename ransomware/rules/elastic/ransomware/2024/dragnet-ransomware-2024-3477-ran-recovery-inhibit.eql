// Dragnet [Ransomware]: dragnet-ransomware-2024-3477 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 6b1e80b1-a4f2-5543-8429-c36455b93599

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
