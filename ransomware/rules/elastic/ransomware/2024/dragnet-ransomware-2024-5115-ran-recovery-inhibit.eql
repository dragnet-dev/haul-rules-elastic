// Dragnet [Ransomware]: dragnet-ransomware-2024-5115 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 9096b7b1-e8f8-5b10-8f0d-54c111df027b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
