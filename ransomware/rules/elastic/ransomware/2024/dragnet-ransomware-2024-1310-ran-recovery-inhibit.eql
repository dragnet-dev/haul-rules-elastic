// Dragnet [Ransomware]: dragnet-ransomware-2024-1310 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 565a884d-15f8-5a61-bcbc-43d58e02bb37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
