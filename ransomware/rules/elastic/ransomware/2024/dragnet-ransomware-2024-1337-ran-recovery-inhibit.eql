// Dragnet [Ransomware]: dragnet-ransomware-2024-1337 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 60326432-06e2-5009-a096-6e49fdc0a792

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
