// Dragnet [Ransomware]: dragnet-ransomware-2024-3991 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 78bc0cea-eadf-58c0-a409-57a57023e33b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
