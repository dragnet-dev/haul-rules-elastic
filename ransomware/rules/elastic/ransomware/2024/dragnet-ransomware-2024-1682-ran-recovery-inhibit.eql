// Dragnet [Ransomware]: dragnet-ransomware-2024-1682 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f44401a6-9baa-5f38-afed-c5b57bcbfcc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
