// Dragnet [Ransomware]: dragnet-ransomware-2024-0407 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: bc0e70d4-e6ed-50c7-8a19-522345984137

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
