// Dragnet [Ransomware]: dragnet-ransomware-2024-3852 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0b8ce36b-a3bc-58a9-abe7-074606958948

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
