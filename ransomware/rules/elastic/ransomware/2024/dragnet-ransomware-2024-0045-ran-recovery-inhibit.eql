// Dragnet [Ransomware]: dragnet-ransomware-2024-0045 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 93540007-4501-520b-b693-16071757eeb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
