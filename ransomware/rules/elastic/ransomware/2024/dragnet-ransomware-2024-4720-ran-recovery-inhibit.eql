// Dragnet [Ransomware]: dragnet-ransomware-2024-4720 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: b0666f61-8d3d-5e87-a640-6672dda08e79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
