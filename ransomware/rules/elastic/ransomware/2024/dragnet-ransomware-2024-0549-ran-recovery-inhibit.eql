// Dragnet [Ransomware]: dragnet-ransomware-2024-0549 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1ca6b48c-ab34-50be-862f-2f45f66469d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
