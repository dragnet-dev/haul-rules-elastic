// Dragnet [Ransomware]: dragnet-ransomware-2024-3521 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 1f402563-2c39-560a-8e87-d4d17ebf9fc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
