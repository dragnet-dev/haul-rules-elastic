// Dragnet [Ransomware]: dragnet-ransomware-2024-1626 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c614bb86-4112-57f5-b827-7e31f3e62a80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
