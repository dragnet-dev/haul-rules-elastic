// Dragnet [Ransomware]: dragnet-ransomware-2024-3107 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 71e7199b-d203-5f33-89dd-884d1f64f0a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
