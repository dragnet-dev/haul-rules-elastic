// Dragnet [Ransomware]: dragnet-ransomware-2024-2902 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 3c4736a2-4001-597c-b79f-959f151377c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
