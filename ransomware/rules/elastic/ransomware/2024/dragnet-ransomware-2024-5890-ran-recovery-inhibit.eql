// Dragnet [Ransomware]: dragnet-ransomware-2024-5890 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: ace00e35-b0c3-5094-bf9f-53e69c04dae7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
