// Dragnet [Ransomware]: dragnet-ransomware-2024-1267 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6cf9d08c-8ddd-5b02-91db-eccfde1949fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
