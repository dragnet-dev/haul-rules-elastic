// Dragnet [Ransomware]: dragnet-ransomware-2024-4133 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e5f8fbc9-8551-53bb-b61e-4160225876bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
