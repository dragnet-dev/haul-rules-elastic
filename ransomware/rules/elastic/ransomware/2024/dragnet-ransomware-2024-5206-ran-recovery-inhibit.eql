// Dragnet [Ransomware]: dragnet-ransomware-2024-5206 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: aa43830f-d0b9-5f2e-87ea-0cb4c7f8ff16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
