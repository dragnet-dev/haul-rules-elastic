// Dragnet [Ransomware]: dragnet-ransomware-2024-5430 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: ab2a80c3-419e-5d5f-9653-bb7a5737367e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
