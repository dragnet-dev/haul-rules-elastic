// Dragnet [Ransomware]: dragnet-ransomware-2024-2196 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: cfe87819-5131-5bfc-beaf-6f9a5d477c47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
