// Dragnet [Ransomware]: dragnet-ransomware-2024-3577 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 72f07470-2d67-5ce9-9a39-aae4870732d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
