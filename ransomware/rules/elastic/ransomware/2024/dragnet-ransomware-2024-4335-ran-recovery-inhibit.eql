// Dragnet [Ransomware]: dragnet-ransomware-2024-4335 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: bdf75b63-146c-5c62-be7d-5478af92b998

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
