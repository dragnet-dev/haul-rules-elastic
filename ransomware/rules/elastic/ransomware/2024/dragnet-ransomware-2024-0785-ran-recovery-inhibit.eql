// Dragnet [Ransomware]: dragnet-ransomware-2024-0785 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: f3b02d3d-64d8-509f-9e0d-17b836a52844

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
