// Dragnet [Ransomware]: dragnet-ransomware-2024-5880 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 02f48592-bf5b-5288-a092-cb6e5e239067

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
