// Dragnet [Ransomware]: dragnet-ransomware-2024-0165 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 376c9a91-4985-55b5-bfe6-b468e24f58d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
