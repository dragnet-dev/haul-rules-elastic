// Dragnet [Ransomware]: dragnet-ransomware-2024-4174 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 56751913-52aa-510b-afb4-f9c7e099690c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
