// Dragnet [Ransomware]: dragnet-ransomware-2024-1402 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2638dbdd-6ed3-5367-82e9-d02c9aa5279e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
