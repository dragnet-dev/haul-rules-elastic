// Dragnet [Ransomware]: dragnet-ransomware-2024-5385 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: eb85212e-97b7-537a-8142-5a5c7f44979c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
