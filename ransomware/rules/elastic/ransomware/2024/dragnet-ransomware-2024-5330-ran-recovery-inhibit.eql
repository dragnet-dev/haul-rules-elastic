// Dragnet [Ransomware]: dragnet-ransomware-2024-5330 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1aa1290d-cc69-5cbc-b4cf-05488c7358e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
