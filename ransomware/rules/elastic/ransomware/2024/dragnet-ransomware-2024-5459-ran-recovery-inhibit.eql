// Dragnet [Ransomware]: dragnet-ransomware-2024-5459 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 00717346-870f-5bcd-b748-c0364c311465

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
