// Dragnet [Ransomware]: dragnet-ransomware-2024-3189 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 928dff56-8613-5243-887a-e35c4369f48c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
