// Dragnet [Ransomware]: dragnet-ransomware-2024-2105 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7bf9661d-d93b-5262-991d-cdc67a1fcbc1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
