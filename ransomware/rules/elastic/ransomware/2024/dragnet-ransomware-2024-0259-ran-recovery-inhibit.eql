// Dragnet [Ransomware]: dragnet-ransomware-2024-0259 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: bef70287-43de-5341-9bb1-675304f82b4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
