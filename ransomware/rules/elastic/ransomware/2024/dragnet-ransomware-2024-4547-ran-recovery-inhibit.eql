// Dragnet [Ransomware]: dragnet-ransomware-2024-4547 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8ac8aab4-edf2-5c1c-b601-307bcd409d22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
