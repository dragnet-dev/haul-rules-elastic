// Dragnet [Ransomware]: dragnet-ransomware-2024-3792 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 80b8f48c-133a-5633-95ed-02dc7634cd01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
