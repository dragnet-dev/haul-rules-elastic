// Dragnet [Ransomware]: dragnet-ransomware-2024-0939 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: a7e44c27-f9fb-530b-b061-608d1ca38b59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
