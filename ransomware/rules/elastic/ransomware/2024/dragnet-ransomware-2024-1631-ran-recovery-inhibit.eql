// Dragnet [Ransomware]: dragnet-ransomware-2024-1631 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 743ca8c8-cb06-52d6-adce-9bcbf7416202

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
