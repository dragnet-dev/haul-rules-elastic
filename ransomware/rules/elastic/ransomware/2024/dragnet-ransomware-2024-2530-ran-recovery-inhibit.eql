// Dragnet [Ransomware]: dragnet-ransomware-2024-2530 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b0c48825-54c0-58a7-b123-33f4e5b25147

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
