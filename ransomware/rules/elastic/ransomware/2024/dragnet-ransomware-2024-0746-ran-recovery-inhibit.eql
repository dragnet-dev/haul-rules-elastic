// Dragnet [Ransomware]: dragnet-ransomware-2024-0746 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 24fc3b3f-eefa-5f1e-a260-26005f66b98b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
