// Dragnet [Ransomware]: dragnet-ransomware-2024-3397 — Recovery Inhibition (mogilevich)
// Status: deprecated | Level: high | ID: 3d94b737-86f2-5e51-8b4f-c42311a1f748

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
