// Dragnet [Ransomware]: dragnet-ransomware-2024-3245 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b736b964-903a-5b12-b765-190484f3c80d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
