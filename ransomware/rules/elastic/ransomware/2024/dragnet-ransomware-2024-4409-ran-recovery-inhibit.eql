// Dragnet [Ransomware]: dragnet-ransomware-2024-4409 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 42f5274e-9e8b-5879-9ab9-b4ed7d5b0cff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
