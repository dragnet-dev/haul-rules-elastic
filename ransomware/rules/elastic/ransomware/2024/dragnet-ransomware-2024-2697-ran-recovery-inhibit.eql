// Dragnet [Ransomware]: dragnet-ransomware-2024-2697 — Recovery Inhibition (chort)
// Status: deprecated | Level: high | ID: 0c3b5d7b-b4ad-568f-bf3a-2f15902d57f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
