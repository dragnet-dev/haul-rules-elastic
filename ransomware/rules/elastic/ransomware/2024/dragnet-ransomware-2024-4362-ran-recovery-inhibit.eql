// Dragnet [Ransomware]: dragnet-ransomware-2024-4362 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 213281d1-0f13-5b69-8524-3c0fb87bfacd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
