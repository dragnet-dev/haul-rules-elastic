// Dragnet [Ransomware]: dragnet-ransomware-2024-2592 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: e879ac88-40e5-56b7-8482-1008af968dff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
