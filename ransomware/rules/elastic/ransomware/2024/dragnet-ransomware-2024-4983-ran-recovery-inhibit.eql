// Dragnet [Ransomware]: dragnet-ransomware-2024-4983 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 523181c3-5306-5f02-8a7d-0d1e1ccf315f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
