// Dragnet [Ransomware]: dragnet-ransomware-2024-2140 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: be39a470-7b09-5a34-b3dc-dd45b36df727

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
