// Dragnet [Ransomware]: dragnet-ransomware-2024-5085 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 60db375e-523f-5c01-8dbe-14e7250d66f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
