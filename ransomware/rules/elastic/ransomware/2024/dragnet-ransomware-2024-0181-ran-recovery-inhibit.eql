// Dragnet [Ransomware]: dragnet-ransomware-2024-0181 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 3ae57fb4-139a-51ca-adbe-f00c595e7d56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
