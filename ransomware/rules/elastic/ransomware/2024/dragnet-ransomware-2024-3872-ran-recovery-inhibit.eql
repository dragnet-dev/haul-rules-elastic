// Dragnet [Ransomware]: dragnet-ransomware-2024-3872 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 93f24f89-1cb1-5507-92f9-2e84362ea9de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
