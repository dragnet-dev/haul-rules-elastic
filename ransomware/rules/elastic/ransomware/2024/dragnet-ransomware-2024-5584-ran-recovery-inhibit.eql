// Dragnet [Ransomware]: dragnet-ransomware-2024-5584 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 9f7be1cc-c38c-56b4-9f52-5723e6ca5b13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
