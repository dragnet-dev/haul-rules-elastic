// Dragnet [Ransomware]: dragnet-ransomware-2024-4696 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f71afc1c-97d8-5482-b8db-cd995797d5a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
