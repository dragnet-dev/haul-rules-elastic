// Dragnet [Ransomware]: dragnet-ransomware-2024-4427 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: f0626c34-0bf4-553d-9704-2f7a389627af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
