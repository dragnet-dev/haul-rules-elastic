// Dragnet [Ransomware]: dragnet-ransomware-2024-1248 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: dc8efd5b-a543-5198-a043-6db6c4ee1a8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
