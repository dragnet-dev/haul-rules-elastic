// Dragnet [Ransomware]: dragnet-ransomware-2024-2903 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 76d3a7e2-d893-5e18-b878-f291a797c829

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
