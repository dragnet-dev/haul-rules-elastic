// Dragnet [Ransomware]: dragnet-ransomware-2024-3157 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 80c35567-df88-5be7-9ceb-26fe447d4eba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
