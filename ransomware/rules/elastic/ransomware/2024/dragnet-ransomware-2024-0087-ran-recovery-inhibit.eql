// Dragnet [Ransomware]: dragnet-ransomware-2024-0087 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: f7d89370-8e31-527c-8df3-b943410c425c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
