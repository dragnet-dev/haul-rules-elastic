// Dragnet [Ransomware]: dragnet-ransomware-2024-0552 — Recovery Inhibition (argonauts)
// Status: experimental | Level: high | ID: 3f177064-59e4-5221-ada0-1174052994f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
