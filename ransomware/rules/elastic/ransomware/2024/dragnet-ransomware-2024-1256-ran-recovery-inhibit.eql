// Dragnet [Ransomware]: dragnet-ransomware-2024-1256 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 67a435a2-c26c-5438-8e2b-621dcf331b7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
