// Dragnet [Ransomware]: dragnet-ransomware-2024-2317 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: 212afea6-b98d-580d-be8c-e246f35bcab1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
