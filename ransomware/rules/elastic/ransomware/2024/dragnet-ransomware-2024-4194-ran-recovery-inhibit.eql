// Dragnet [Ransomware]: dragnet-ransomware-2024-4194 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f35fb61f-86c8-59c4-92d1-45c4d56fb3cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
