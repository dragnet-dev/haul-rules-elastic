// Dragnet [Ransomware]: dragnet-ransomware-2024-1424 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6770eb0b-4c13-5a9c-8e71-54d56e7100c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
