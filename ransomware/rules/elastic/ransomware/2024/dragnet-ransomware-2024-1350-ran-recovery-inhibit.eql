// Dragnet [Ransomware]: dragnet-ransomware-2024-1350 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ff3531c6-738c-5c3e-acb0-681133957b87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
