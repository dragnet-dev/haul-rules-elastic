// Dragnet [Ransomware]: dragnet-ransomware-2024-3340 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 465b9049-5ca5-5b8e-ab5d-4f0577402f77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
