// Dragnet [Ransomware]: dragnet-ransomware-2024-4926 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: e67cb025-d0a1-5cdf-901a-19b7567d9d59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
