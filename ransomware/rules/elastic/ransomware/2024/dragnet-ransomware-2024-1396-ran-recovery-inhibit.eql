// Dragnet [Ransomware]: dragnet-ransomware-2024-1396 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 57ac62c0-2965-53ab-aa2a-0a9345750a9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
