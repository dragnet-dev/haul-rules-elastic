// Dragnet [Ransomware]: dragnet-ransomware-2024-5179 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e6b6f599-f55c-5dfa-ac5c-370d42ef3338

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
