// Dragnet [Ransomware]: dragnet-ransomware-2024-3436 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 51201964-227c-54bc-a56f-946e3cdc54fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
