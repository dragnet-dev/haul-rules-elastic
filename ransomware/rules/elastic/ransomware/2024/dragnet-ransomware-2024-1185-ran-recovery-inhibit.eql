// Dragnet [Ransomware]: dragnet-ransomware-2024-1185 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 47f306ba-2e3a-51c6-b904-20e2efc6cd5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
