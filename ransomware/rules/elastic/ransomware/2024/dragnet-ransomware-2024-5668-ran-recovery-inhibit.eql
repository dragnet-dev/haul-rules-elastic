// Dragnet [Ransomware]: dragnet-ransomware-2024-5668 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: 55cc0494-7582-5227-b705-0e51ea113238

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
