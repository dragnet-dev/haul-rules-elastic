// Dragnet [Ransomware]: dragnet-ransomware-2024-4777 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 869512d7-02d6-5502-be26-e77e412cc5eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
