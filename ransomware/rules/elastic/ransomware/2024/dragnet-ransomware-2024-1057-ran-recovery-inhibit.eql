// Dragnet [Ransomware]: dragnet-ransomware-2024-1057 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 041c28bb-2636-5bd7-ba08-8c4c63f5619f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
