// Dragnet [Ransomware]: dragnet-ransomware-2024-4024 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: aa76d6d0-5ab4-5a2f-b620-31fafba1085d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
