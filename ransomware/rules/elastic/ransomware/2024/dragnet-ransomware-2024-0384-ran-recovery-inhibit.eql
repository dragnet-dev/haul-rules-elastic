// Dragnet [Ransomware]: dragnet-ransomware-2024-0384 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 69237600-5dda-53cd-b501-41b89a0dda75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
