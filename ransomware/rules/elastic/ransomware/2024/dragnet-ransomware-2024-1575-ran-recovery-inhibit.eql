// Dragnet [Ransomware]: dragnet-ransomware-2024-1575 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: a2215d45-8502-5413-8f36-bfc7a0589018

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
