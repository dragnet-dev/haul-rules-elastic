// Dragnet [Ransomware]: dragnet-ransomware-2024-5592 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 9fd322d0-02e5-5b44-8b06-0c1b955f254b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
