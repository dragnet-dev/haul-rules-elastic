// Dragnet [Ransomware]: dragnet-ransomware-2024-3540 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 2733cede-ddff-59cf-a331-372988953adc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
