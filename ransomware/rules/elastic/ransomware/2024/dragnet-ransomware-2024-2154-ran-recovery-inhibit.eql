// Dragnet [Ransomware]: dragnet-ransomware-2024-2154 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9b07aa0d-00bf-5db9-a6c2-5a9166e0d9e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
