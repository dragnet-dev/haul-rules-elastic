// Dragnet [Ransomware]: dragnet-ransomware-2024-1992 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: df409fe8-4533-5807-b29a-68e943779078

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
