// Dragnet [Ransomware]: dragnet-ransomware-2024-1101 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: 719ca1eb-d569-5eeb-a1e9-acea7eee33e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
