// Dragnet [Ransomware]: dragnet-ransomware-2024-4719 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0839e2e3-1e49-53d8-a5c7-ad8cbf35781c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
