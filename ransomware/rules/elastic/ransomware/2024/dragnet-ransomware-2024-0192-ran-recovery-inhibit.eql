// Dragnet [Ransomware]: dragnet-ransomware-2024-0192 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: a37d06dc-8d25-5a8a-80cb-db7c87ee5f3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
