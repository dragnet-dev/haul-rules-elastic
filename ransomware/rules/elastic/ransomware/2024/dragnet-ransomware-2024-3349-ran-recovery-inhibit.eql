// Dragnet [Ransomware]: dragnet-ransomware-2024-3349 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: bf63b147-48a3-5b20-b50f-52c176c786c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
