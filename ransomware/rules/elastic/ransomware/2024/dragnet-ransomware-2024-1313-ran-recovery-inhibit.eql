// Dragnet [Ransomware]: dragnet-ransomware-2024-1313 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2c68ebb4-2ae2-516e-b4d8-01601ce3617e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
