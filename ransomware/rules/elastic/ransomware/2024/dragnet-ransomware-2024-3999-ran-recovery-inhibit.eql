// Dragnet [Ransomware]: dragnet-ransomware-2024-3999 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 942fbfee-e9e1-5613-b03c-5b67904a0874

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
