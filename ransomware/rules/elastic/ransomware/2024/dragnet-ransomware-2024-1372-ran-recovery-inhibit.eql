// Dragnet [Ransomware]: dragnet-ransomware-2024-1372 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: ccc8a78b-c08c-539e-86f0-c1ad22aa22d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
