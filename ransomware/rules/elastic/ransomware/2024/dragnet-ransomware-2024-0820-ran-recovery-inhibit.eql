// Dragnet [Ransomware]: dragnet-ransomware-2024-0820 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 3184fcf1-a6fb-5cb3-adac-68fef1ed50bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
