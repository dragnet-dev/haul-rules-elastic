// Dragnet [Ransomware]: dragnet-ransomware-2024-5688 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 06c196eb-9866-5ab4-ab1c-9d3149b63ca4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
