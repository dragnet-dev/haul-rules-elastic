// Dragnet [Ransomware]: dragnet-ransomware-2024-1644 — Recovery Inhibition (apos)
// Status: experimental | Level: high | ID: c831cf6b-6904-5706-aeb2-11ce745ddacf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
