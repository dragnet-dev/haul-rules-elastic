// Dragnet [Ransomware]: dragnet-ransomware-2024-1091 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 662551b3-3299-5635-9a1b-9e816263b0fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
