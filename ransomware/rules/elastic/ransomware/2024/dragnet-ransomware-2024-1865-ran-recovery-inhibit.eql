// Dragnet [Ransomware]: dragnet-ransomware-2024-1865 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 922d6a9f-dce8-59c1-be88-a61aa8e1dbef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
