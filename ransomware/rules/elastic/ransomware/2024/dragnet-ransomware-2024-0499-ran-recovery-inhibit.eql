// Dragnet [Ransomware]: dragnet-ransomware-2024-0499 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 4fcafb45-bf3b-5a3b-8059-f635e13544a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
