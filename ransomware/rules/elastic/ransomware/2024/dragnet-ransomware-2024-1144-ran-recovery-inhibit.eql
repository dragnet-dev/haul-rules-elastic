// Dragnet [Ransomware]: dragnet-ransomware-2024-1144 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 17a5822f-9711-5a58-bf0e-b814a55b389b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
