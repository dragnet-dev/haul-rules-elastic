// Dragnet [Ransomware]: dragnet-ransomware-2024-1066 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2a9cb873-78a3-5ea7-89ea-9e725b68f141

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
