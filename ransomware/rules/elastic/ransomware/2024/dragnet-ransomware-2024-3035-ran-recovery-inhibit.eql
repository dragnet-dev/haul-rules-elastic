// Dragnet [Ransomware]: dragnet-ransomware-2024-3035 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b5f85daa-4fee-5e71-90b2-f0813659ab10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
