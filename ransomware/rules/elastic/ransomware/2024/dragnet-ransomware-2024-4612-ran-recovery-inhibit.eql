// Dragnet [Ransomware]: dragnet-ransomware-2024-4612 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 88129e59-187c-5947-a213-6f05e78a77f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
