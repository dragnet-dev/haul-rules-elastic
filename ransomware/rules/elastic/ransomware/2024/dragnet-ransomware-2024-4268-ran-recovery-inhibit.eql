// Dragnet [Ransomware]: dragnet-ransomware-2024-4268 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 8148c8cc-1668-5132-89fa-0dacec27d21f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
