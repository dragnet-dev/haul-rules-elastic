// Dragnet [Ransomware]: dragnet-ransomware-2024-3500 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 1f0219b1-0845-5158-b471-a6e725889d61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
