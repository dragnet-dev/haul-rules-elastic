// Dragnet [Ransomware]: dragnet-ransomware-2024-4342 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 37e8d6d5-ae06-5e9a-a3fc-1ef25c04a0fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
