// Dragnet [Ransomware]: dragnet-ransomware-2024-3782 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b51fabe7-7fcd-55ef-a98a-1769f83cbc1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
