// Dragnet [Ransomware]: dragnet-ransomware-2024-2411 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: c9070503-08bb-5ed7-9126-782cef8dcc81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
