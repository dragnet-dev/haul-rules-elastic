// Dragnet [Ransomware]: dragnet-ransomware-2024-0844 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 3f5b2939-6dec-5dd4-a3d9-a8a3e4770822

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
