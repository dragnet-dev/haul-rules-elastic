// Dragnet [Ransomware]: dragnet-ransomware-2024-1991 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1564c7d5-b351-5ddc-9479-26027463c580

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
