// Dragnet [Ransomware]: dragnet-ransomware-2024-2860 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9662edff-3f60-55e9-95bc-6e1631e6f34e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
