// Dragnet [Ransomware]: dragnet-ransomware-2024-3467 — Recovery Inhibition (chort)
// Status: experimental | Level: high | ID: 70217ce0-d441-5e59-b184-4484a393ef42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
