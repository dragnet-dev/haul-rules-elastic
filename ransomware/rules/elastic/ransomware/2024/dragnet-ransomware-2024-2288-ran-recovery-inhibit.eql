// Dragnet [Ransomware]: dragnet-ransomware-2024-2288 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: fab0fd7e-59ce-5b8f-b9e5-105aaf5e1f0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
