// Dragnet [Ransomware]: dragnet-ransomware-2024-4197 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 095b2419-6a76-50cb-a3b4-c092019705c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
