// Dragnet [Ransomware]: dragnet-ransomware-2024-5655 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: a07c6518-9725-560d-b3e0-7aec1fe894b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
