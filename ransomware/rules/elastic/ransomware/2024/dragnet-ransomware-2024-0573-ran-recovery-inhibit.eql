// Dragnet [Ransomware]: dragnet-ransomware-2024-0573 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: b8f4dcdb-c8bb-505c-9053-4180be32159a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
