// Dragnet [Ransomware]: dragnet-ransomware-2024-1149 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 26a5ce47-c442-5f01-b34c-13ab334a3c9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
