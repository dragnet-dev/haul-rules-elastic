// Dragnet [Ransomware]: dragnet-ransomware-2024-4300 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 307f1acc-5695-5016-935a-9a7a0a6cc5ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
