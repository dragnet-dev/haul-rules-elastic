// Dragnet [Ransomware]: dragnet-ransomware-2024-5881 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7c62360e-a025-5208-be32-531485aee0a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
