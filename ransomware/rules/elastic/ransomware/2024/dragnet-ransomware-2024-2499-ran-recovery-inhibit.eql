// Dragnet [Ransomware]: dragnet-ransomware-2024-2499 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: e0609e9c-681a-5321-a750-03ce4b3abed6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
