// Dragnet [Ransomware]: dragnet-ransomware-2024-1696 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: fe41bf76-ea02-5f69-849c-f31a687c5dee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
