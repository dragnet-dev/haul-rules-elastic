// Dragnet [Ransomware]: dragnet-ransomware-2024-1554 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 7361550c-f3a1-5b71-a000-8d666cdff099

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
