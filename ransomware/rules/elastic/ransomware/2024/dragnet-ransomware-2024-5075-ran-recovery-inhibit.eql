// Dragnet [Ransomware]: dragnet-ransomware-2024-5075 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8112ddca-5a3c-571d-ad63-ec3f053ef6eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
