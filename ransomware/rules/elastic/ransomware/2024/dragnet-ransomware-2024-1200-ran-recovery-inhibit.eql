// Dragnet [Ransomware]: dragnet-ransomware-2024-1200 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 926d3002-8dd5-517c-8fcc-0288e759ad28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
