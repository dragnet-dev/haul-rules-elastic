// Dragnet [Ransomware]: dragnet-ransomware-2024-3100 — Recovery Inhibition (argonauts)
// Status: experimental | Level: high | ID: 2b40dd40-6d9d-516d-a049-f9b7d9a3dbd4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
