// Dragnet [Ransomware]: dragnet-ransomware-2024-0464 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: f702fd33-b58b-54e9-aaac-cf787e260519

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
