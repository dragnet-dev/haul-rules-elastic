// Dragnet [Ransomware]: dragnet-ransomware-2024-3234 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 6602b7e8-34a8-55b6-88a6-7db67d85a949

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
