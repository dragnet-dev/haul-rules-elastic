// Dragnet [Ransomware]: dragnet-ransomware-2024-0710 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: 46ac4f4e-c325-5e78-9d04-b7762554e0ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
