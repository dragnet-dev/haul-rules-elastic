// Dragnet [Ransomware]: dragnet-ransomware-2024-1298 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: b17d5c00-7db6-5b93-a928-a537216d5721

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
