// Dragnet [Ransomware]: dragnet-ransomware-2024-3990 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 80943bb6-f27d-54da-b072-cfdca8a40563

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
