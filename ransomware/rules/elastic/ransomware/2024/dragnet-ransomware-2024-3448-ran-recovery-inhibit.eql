// Dragnet [Ransomware]: dragnet-ransomware-2024-3448 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ecf51d71-ca20-5a66-9e90-c563dbca77d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
