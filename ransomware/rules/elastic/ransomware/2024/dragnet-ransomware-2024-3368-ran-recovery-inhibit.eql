// Dragnet [Ransomware]: dragnet-ransomware-2024-3368 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: d6d4bef5-d0be-5aee-8c08-daaa2072636b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
