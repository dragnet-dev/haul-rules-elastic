// Dragnet [Ransomware]: dragnet-ransomware-2024-2520 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 56f73a1a-dffd-533d-84a7-b3fac9ba2dab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
