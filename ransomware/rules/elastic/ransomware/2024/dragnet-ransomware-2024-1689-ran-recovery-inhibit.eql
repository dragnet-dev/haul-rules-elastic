// Dragnet [Ransomware]: dragnet-ransomware-2024-1689 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 9ea37862-3849-5873-8a02-e3abf8ddb17b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
