// Dragnet [Ransomware]: dragnet-ransomware-2024-4874 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 99bb7c3f-bd96-538e-b622-48edeede8403

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
