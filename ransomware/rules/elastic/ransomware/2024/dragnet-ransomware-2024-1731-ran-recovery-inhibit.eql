// Dragnet [Ransomware]: dragnet-ransomware-2024-1731 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 898ee6ac-40e1-5d7a-bda0-8b54486df877

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
