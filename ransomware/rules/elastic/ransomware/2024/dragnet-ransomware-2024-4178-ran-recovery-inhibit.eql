// Dragnet [Ransomware]: dragnet-ransomware-2024-4178 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5ad5c882-cd18-5681-8a07-8d9cf4b7d858

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
