// Dragnet [Ransomware]: dragnet-ransomware-2024-0677 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7cd7c542-df50-543f-a198-bb75025a80c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
