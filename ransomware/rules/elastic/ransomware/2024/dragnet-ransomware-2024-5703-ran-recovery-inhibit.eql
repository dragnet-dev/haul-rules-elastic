// Dragnet [Ransomware]: dragnet-ransomware-2024-5703 — Recovery Inhibition (underground)
// Status: experimental | Level: high | ID: a7f1581a-6f60-5b55-86c3-64a922b76cc6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
