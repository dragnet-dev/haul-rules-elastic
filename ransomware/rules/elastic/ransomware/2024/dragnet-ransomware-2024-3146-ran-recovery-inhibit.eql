// Dragnet [Ransomware]: dragnet-ransomware-2024-3146 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d0d6f155-e2d6-514a-9edf-09ba572df537

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
