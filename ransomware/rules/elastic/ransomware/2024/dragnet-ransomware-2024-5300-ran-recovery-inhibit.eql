// Dragnet [Ransomware]: dragnet-ransomware-2024-5300 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 7308521a-3068-5589-92ea-44bf187c0d1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
