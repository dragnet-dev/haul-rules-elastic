// Dragnet [Ransomware]: dragnet-ransomware-2024-5942 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 4f1dd183-d407-5b30-8bcf-9a6b4410ca9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
