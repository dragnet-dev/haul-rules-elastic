// Dragnet [Ransomware]: dragnet-ransomware-2024-5483 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e6266b2c-f6a1-5954-bd17-6d1b224fe90a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
