// Dragnet [Ransomware]: dragnet-ransomware-2024-2764 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c3ec5dff-7577-530b-857f-9f9b7f7ea482

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
