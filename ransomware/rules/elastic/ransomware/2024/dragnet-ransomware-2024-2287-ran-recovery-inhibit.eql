// Dragnet [Ransomware]: dragnet-ransomware-2024-2287 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: d9c270d9-fb00-5be6-9792-b9c04c995abc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
