// Dragnet [Ransomware]: dragnet-ransomware-2024-5973 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f28c47a3-bafa-5e2e-9431-87589f1ad60d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
