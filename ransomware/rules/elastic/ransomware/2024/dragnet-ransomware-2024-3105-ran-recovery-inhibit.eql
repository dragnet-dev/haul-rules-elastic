// Dragnet [Ransomware]: dragnet-ransomware-2024-3105 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: 9af95375-d2e0-55d3-a548-d777676b74fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
