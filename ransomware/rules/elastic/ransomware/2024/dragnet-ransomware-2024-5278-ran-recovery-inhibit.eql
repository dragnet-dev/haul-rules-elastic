// Dragnet [Ransomware]: dragnet-ransomware-2024-5278 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: e7da4514-4ea9-5c1c-b29a-1bfdc3f6235d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
