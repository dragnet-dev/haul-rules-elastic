// Dragnet [Ransomware]: dragnet-ransomware-2024-4096 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 4ff6b93c-9249-5e09-88f4-7f5ed6b12590

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
