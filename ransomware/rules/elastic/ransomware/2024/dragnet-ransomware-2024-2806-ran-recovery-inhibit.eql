// Dragnet [Ransomware]: dragnet-ransomware-2024-2806 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: cf7eaa2f-7cb6-5d29-a8b6-7616a62d6772

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
