// Dragnet [Ransomware]: dragnet-ransomware-2024-2131 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 960abad9-dd55-5031-8338-1fb7bbec3235

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
