// Dragnet [Ransomware]: dragnet-ransomware-2024-1244 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: bdfe7a08-5099-5eed-a40f-2f2061bbb6ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
