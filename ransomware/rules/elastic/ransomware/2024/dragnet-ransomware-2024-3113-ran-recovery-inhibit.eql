// Dragnet [Ransomware]: dragnet-ransomware-2024-3113 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b1d55d1a-462f-5dfd-912c-4423cb18a810

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
