// Dragnet [Ransomware]: dragnet-ransomware-2024-5219 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: e50a2bae-b34a-5cba-ad71-153d6cd4735a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
