// Dragnet [Ransomware]: dragnet-ransomware-2024-5296 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 5df6032b-4534-57da-80f4-c93939efa585

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
