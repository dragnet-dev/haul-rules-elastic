// Dragnet [Ransomware]: dragnet-ransomware-2024-4971 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 5c9cb2c1-fd20-5508-b688-dadf338f0380

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
