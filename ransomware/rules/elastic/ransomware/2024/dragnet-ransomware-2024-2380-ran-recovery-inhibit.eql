// Dragnet [Ransomware]: dragnet-ransomware-2024-2380 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a1a23860-6cbc-58fa-9443-ca2c7f8eeaf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
