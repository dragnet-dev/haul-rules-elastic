// Dragnet [Ransomware]: dragnet-ransomware-2024-0484 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2461fa3b-45c8-5179-a34f-57f92d497f40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
