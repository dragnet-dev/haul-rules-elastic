// Dragnet [Ransomware]: dragnet-ransomware-2024-2791 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 25fe88d4-68d1-5971-970c-4293dd34c993

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
