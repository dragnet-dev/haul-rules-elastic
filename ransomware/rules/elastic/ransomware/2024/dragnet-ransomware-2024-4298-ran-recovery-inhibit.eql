// Dragnet [Ransomware]: dragnet-ransomware-2024-4298 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ea4ccf6e-fdc6-58f2-a1fa-5483987ef2fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
