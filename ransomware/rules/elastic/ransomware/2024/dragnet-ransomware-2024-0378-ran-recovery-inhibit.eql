// Dragnet [Ransomware]: dragnet-ransomware-2024-0378 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: a4049e6a-e09d-5c94-89e9-020a9f35329a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
