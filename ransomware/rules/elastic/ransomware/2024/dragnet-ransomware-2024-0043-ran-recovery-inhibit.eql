// Dragnet [Ransomware]: dragnet-ransomware-2024-0043 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 9b65eab8-d5ee-506b-89c1-b46e17b56599

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
