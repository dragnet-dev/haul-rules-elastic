// Dragnet [Ransomware]: dragnet-ransomware-2024-6025 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f14dcbac-e8cb-53a2-9f03-6b7eeb7969d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
