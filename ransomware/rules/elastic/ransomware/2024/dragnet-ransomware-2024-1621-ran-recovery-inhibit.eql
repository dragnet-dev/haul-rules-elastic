// Dragnet [Ransomware]: dragnet-ransomware-2024-1621 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: d82d2ab3-1f1e-568b-95b1-cfc84b6caf29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
