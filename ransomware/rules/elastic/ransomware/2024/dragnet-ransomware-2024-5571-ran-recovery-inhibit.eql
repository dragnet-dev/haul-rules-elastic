// Dragnet [Ransomware]: dragnet-ransomware-2024-5571 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 5045be9f-a30a-5b36-bce0-4ea6cf8320f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
