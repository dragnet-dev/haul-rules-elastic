// Dragnet [Ransomware]: dragnet-ransomware-2024-3431 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 35dd4a31-fe77-5715-89a8-ae7596039982

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
