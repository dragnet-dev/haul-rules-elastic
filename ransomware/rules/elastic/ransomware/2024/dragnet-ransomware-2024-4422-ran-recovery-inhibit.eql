// Dragnet [Ransomware]: dragnet-ransomware-2024-4422 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: e14ab71c-dcdd-562c-b830-e29ba755e0d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
