// Dragnet [Ransomware]: dragnet-ransomware-2024-5324 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1f4f0814-7734-541e-826b-c07f1b9da886

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
