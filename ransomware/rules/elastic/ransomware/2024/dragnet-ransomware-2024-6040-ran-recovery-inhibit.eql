// Dragnet [Ransomware]: dragnet-ransomware-2024-6040 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 572014f5-d73d-5a48-bd74-72b6fede555e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
