// Dragnet [Ransomware]: dragnet-ransomware-2024-0151 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: bc3d7439-a227-5754-bbfd-629ffee24b99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
