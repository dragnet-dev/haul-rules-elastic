// Dragnet [Ransomware]: dragnet-ransomware-2024-2507 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: ffaff7cc-6442-5fa7-b129-c560af802a1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
