// Dragnet [Ransomware]: dragnet-ransomware-2024-4267 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 50a062fd-5578-50cb-b7e1-a288b61534d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
