// Dragnet [Ransomware]: dragnet-ransomware-2024-4281 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1f716973-047d-57dd-9b38-5cde2a319654

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
