// Dragnet [Ransomware]: dragnet-ransomware-2024-5078 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 10ce14db-b738-5db4-a52d-45f499a5db73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
