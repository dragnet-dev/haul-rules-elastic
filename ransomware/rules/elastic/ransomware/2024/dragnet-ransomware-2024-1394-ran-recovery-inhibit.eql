// Dragnet [Ransomware]: dragnet-ransomware-2024-1394 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 23337480-7dab-5b45-9399-6ec72cb7e362

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
