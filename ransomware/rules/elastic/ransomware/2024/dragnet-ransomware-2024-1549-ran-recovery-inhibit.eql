// Dragnet [Ransomware]: dragnet-ransomware-2024-1549 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 08715350-68e8-5057-83fa-d8154fe048e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
