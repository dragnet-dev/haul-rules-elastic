// Dragnet [Ransomware]: dragnet-ransomware-2024-1568 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 711283e5-5ab9-550c-a184-6e5e9653b1ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
