// Dragnet [Ransomware]: dragnet-ransomware-2024-1522 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: a9579674-dc51-5383-b609-2509ffa1315d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
