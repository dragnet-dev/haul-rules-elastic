// Dragnet [Ransomware]: dragnet-ransomware-2024-3708 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 6229117c-97c3-5d2e-b2b1-688edbe2036a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
