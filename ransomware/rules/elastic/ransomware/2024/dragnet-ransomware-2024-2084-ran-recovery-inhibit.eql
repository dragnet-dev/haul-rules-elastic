// Dragnet [Ransomware]: dragnet-ransomware-2024-2084 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 40fa0c63-5aee-5f87-9466-f3afa83cfd08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
