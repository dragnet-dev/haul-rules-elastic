// Dragnet [Ransomware]: dragnet-ransomware-2024-0491 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 1853559b-79db-5b7a-b41d-59747d04a53c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
