// Dragnet [Ransomware]: dragnet-ransomware-2024-5649 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 5c513379-83a2-519f-933c-4146b2a33edf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
