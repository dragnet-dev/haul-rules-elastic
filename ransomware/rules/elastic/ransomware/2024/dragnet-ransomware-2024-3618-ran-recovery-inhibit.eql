// Dragnet [Ransomware]: dragnet-ransomware-2024-3618 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 537bbbbc-9019-5592-8360-26c1de1ff0e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
