// Dragnet [Ransomware]: dragnet-ransomware-2024-2893 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a2d84846-3cda-5a0e-a3ff-c70cd95052d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
