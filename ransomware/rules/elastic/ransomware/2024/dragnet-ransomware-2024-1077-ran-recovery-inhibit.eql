// Dragnet [Ransomware]: dragnet-ransomware-2024-1077 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 6d0802de-3bfe-5db5-bd01-d21b4c15e002

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
