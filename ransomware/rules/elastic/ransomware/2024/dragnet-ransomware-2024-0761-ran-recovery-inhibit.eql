// Dragnet [Ransomware]: dragnet-ransomware-2024-0761 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: eaff9d15-671e-5853-8740-0a963aa81812

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
