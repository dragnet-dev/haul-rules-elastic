// Dragnet [Ransomware]: dragnet-ransomware-2024-5861 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: b3685bd5-7b73-5058-bd9e-b9dc6e13a6cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
