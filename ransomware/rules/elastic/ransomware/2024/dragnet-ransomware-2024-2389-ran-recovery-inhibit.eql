// Dragnet [Ransomware]: dragnet-ransomware-2024-2389 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: afc9c25a-a0b8-578b-a290-76b69ff84464

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
