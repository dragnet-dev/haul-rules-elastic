// Dragnet [Ransomware]: dragnet-ransomware-2024-4519 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a2051269-b105-5f49-a955-1887d53b454b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
