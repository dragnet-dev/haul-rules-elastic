// Dragnet [Ransomware]: dragnet-ransomware-2024-4909 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 1290f51a-6edf-531b-877b-4489f8143d90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
