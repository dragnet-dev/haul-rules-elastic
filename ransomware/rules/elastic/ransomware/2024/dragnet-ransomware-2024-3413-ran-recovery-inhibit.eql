// Dragnet [Ransomware]: dragnet-ransomware-2024-3413 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 691a39bb-31f3-502c-b3a3-afb0889b7140

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
