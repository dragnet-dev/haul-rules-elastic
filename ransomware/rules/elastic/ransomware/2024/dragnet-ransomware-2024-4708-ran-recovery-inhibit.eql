// Dragnet [Ransomware]: dragnet-ransomware-2024-4708 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 25c1afa2-75b7-570e-a6ca-cf339ca52af0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
