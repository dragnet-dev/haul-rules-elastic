// Dragnet [Ransomware]: dragnet-ransomware-2024-3660 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 965b8645-41ed-599d-84a5-ded252523ed4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
