// Dragnet [Ransomware]: dragnet-ransomware-2024-3010 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: d14cd8e8-3611-5806-b6fe-3ca576bf1e33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
