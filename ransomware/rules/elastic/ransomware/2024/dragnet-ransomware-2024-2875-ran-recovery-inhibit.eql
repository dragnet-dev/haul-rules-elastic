// Dragnet [Ransomware]: dragnet-ransomware-2024-2875 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: 1028c5fb-70be-56fb-a907-1f230f374143

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
