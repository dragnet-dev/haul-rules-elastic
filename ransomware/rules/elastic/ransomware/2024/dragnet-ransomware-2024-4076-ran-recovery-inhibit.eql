// Dragnet [Ransomware]: dragnet-ransomware-2024-4076 — Recovery Inhibition (madliberator)
// Status: experimental | Level: high | ID: b6831325-5255-553d-9807-2df8570f4656

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
