// Dragnet [Ransomware]: dragnet-ransomware-2024-3863 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 90cd3a22-123f-5bef-b0d3-6999892241f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
