// Dragnet [Ransomware]: dragnet-ransomware-2024-3302 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: c040d3de-f640-5d0b-afff-169225d19f46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
