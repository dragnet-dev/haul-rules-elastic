// Dragnet [Ransomware]: dragnet-ransomware-2024-3524 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: fba047a8-e2be-5bd1-a170-9348f6adca6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
