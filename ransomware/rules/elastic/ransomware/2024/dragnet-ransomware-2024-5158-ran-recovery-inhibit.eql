// Dragnet [Ransomware]: dragnet-ransomware-2024-5158 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: f64d3db9-ada3-5103-9a42-9ad1b708cb4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
