// Dragnet [Ransomware]: dragnet-ransomware-2024-4490 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 456ee8c8-b4c7-581f-99f0-8d1782710eb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
