// Dragnet [Ransomware]: dragnet-ransomware-2024-4439 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 77efe46b-b656-5f78-bf37-3635b93379ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
