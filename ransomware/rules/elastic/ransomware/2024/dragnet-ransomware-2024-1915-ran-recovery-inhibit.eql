// Dragnet [Ransomware]: dragnet-ransomware-2024-1915 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: 81d11a93-f7fe-54ee-92ea-a9639e342539

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
