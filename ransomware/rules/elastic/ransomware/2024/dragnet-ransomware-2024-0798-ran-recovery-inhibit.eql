// Dragnet [Ransomware]: dragnet-ransomware-2024-0798 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 983704cb-b8a9-5e3e-bdb2-bee6d39f4c14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
