// Dragnet [Ransomware]: dragnet-ransomware-2024-3529 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: d26f9427-4cee-5fb1-9041-6fc0326af3e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
