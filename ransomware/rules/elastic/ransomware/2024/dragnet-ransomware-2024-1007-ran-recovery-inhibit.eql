// Dragnet [Ransomware]: dragnet-ransomware-2024-1007 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 9f1f778b-f8f6-5535-ab92-b894a077c6f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
