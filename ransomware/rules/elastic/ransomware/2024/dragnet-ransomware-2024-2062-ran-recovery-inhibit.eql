// Dragnet [Ransomware]: dragnet-ransomware-2024-2062 — Recovery Inhibition (apos)
// Status: experimental | Level: high | ID: 957fa34e-6159-5d8c-825c-6516d2ff0f93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
