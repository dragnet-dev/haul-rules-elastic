// Dragnet [Ransomware]: dragnet-ransomware-2024-5045 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: c23682b7-d8c4-5b6d-b0d7-45fb5478e224

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
