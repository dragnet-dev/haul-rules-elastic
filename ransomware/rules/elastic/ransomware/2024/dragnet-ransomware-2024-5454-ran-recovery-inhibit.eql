// Dragnet [Ransomware]: dragnet-ransomware-2024-5454 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: bc63f835-9352-5ec8-a279-12cf77ac8eda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
