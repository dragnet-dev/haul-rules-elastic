// Dragnet [Ransomware]: dragnet-ransomware-2024-4712 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: 9ca3f83c-daab-504c-b66b-79ab81634f4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
