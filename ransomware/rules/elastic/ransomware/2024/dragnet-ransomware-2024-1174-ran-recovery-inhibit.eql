// Dragnet [Ransomware]: dragnet-ransomware-2024-1174 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 0679716d-91d2-53c8-a987-a65db684232f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
