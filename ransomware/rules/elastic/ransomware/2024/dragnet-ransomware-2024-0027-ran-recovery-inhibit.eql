// Dragnet [Ransomware]: dragnet-ransomware-2024-0027 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: cf1c85e2-4422-5a05-93b6-f8c8198fdc7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
