// Dragnet [Ransomware]: dragnet-ransomware-2024-3837 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: d3c5c148-83e0-5a95-8000-b852d91d02c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
