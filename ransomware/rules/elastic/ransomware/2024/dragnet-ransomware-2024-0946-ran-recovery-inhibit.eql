// Dragnet [Ransomware]: dragnet-ransomware-2024-0946 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 5e044831-6ac9-5f26-a0dd-8d4221b6798c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
