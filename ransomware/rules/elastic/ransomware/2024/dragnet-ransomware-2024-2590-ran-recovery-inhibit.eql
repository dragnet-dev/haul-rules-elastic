// Dragnet [Ransomware]: dragnet-ransomware-2024-2590 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 8f957580-d1a0-5053-b96d-40e388cb2b29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
