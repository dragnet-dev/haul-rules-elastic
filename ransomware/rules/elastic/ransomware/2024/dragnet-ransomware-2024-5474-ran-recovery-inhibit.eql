// Dragnet [Ransomware]: dragnet-ransomware-2024-5474 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 60281469-3b65-51c7-a133-6594075f36e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
