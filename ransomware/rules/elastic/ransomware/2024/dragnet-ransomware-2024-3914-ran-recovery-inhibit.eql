// Dragnet [Ransomware]: dragnet-ransomware-2024-3914 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: b22a736d-a7ee-5565-a9cc-f2d54413c5ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
