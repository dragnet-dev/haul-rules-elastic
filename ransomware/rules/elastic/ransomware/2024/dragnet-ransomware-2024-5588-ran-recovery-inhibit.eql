// Dragnet [Ransomware]: dragnet-ransomware-2024-5588 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: f6a6897a-4e91-56dd-be15-996ff921808b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
