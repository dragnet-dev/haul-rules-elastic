// Dragnet [Ransomware]: dragnet-ransomware-2024-3942 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 0398779b-83cb-59da-959e-ac845e431f1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
