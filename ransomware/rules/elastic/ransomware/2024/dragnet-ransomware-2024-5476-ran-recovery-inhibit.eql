// Dragnet [Ransomware]: dragnet-ransomware-2024-5476 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 26e7ef6d-f518-5e6a-8cba-ab029882e28a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
