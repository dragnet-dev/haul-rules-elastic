// Dragnet [Ransomware]: dragnet-ransomware-2024-4675 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c73a693b-6a99-591e-879d-096423a2bf9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
