// Dragnet [Ransomware]: dragnet-ransomware-2024-2641 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: 87fcce83-8886-550e-a2b3-da2c9b7e20c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
