// Dragnet [Ransomware]: dragnet-ransomware-2024-5319 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 97836123-25ab-5b2b-a2dd-7fc7212657a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
