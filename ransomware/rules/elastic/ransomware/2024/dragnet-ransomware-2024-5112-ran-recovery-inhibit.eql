// Dragnet [Ransomware]: dragnet-ransomware-2024-5112 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 724131ee-1b27-5107-9443-e8347050ea51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
