// Dragnet [Ransomware]: dragnet-ransomware-2024-5431 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5a089f62-f2d8-593b-be5b-85f5f0f6237d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
