// Dragnet [Ransomware]: dragnet-ransomware-2024-2618 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b0e4a6dd-3793-5c1a-b0b0-ce6f644ed9a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
