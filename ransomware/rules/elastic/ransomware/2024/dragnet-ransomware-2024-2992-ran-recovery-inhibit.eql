// Dragnet [Ransomware]: dragnet-ransomware-2024-2992 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 2e79154b-600c-54fa-9a8f-6f591be78a37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
