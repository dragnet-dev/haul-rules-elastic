// Dragnet [Ransomware]: dragnet-ransomware-2024-5922 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 15699fb3-49bb-5cc5-a10c-108a6bc271d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
