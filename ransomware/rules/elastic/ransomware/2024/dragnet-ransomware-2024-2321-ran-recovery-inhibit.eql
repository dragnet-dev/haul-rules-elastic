// Dragnet [Ransomware]: dragnet-ransomware-2024-2321 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: d09fa8a9-89d2-58ec-addd-b9398bb0b1d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
