// Dragnet [Ransomware]: dragnet-ransomware-2024-1401 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d458deef-5b5a-50a4-bc7a-e7862ee500b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
