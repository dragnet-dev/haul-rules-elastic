// Dragnet [Ransomware]: dragnet-ransomware-2024-2094 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: 7d7d4bed-2613-56e3-9894-afb830ccace9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
