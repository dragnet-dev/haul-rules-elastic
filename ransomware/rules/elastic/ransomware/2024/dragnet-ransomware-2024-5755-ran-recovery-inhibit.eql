// Dragnet [Ransomware]: dragnet-ransomware-2024-5755 — Recovery Inhibition (chort)
// Status: experimental | Level: high | ID: ee248941-4460-513e-a283-441c075773ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
