// Dragnet [Ransomware]: dragnet-ransomware-2024-4896 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 05900ae4-f813-5a60-a3e8-04185fd11149

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
