// Dragnet [Ransomware]: dragnet-ransomware-2024-3692 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 0f9767a5-0903-5db1-a0b2-f8af8438b478

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
