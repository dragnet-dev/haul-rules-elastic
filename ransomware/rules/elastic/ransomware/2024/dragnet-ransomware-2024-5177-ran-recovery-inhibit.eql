// Dragnet [Ransomware]: dragnet-ransomware-2024-5177 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 8e8c7bd7-265c-5702-934f-299b3e30ba2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
