// Dragnet [Ransomware]: dragnet-ransomware-2024-3499 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 634dfb25-13ef-55b6-97fd-cd6630139ef4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
