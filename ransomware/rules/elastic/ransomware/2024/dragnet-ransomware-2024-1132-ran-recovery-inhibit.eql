// Dragnet [Ransomware]: dragnet-ransomware-2024-1132 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ccc0d8bc-40d0-594e-b69b-329c0378303e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
