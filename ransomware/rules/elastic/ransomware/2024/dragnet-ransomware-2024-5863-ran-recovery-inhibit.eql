// Dragnet [Ransomware]: dragnet-ransomware-2024-5863 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 711b331d-295d-5ef2-a2f1-cd27788fdae2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
