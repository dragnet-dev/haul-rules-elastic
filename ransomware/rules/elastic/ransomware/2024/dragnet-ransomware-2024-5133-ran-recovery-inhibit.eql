// Dragnet [Ransomware]: dragnet-ransomware-2024-5133 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e3c879d1-177a-57cd-8d22-9ccdcaeb63e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
