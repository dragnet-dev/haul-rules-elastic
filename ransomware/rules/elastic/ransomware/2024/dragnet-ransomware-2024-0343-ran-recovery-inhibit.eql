// Dragnet [Ransomware]: dragnet-ransomware-2024-0343 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ad914692-0264-5541-8649-adb71b544844

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
