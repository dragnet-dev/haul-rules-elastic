// Dragnet [Ransomware]: dragnet-ransomware-2024-2717 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 8ca1fb38-d925-58c7-8c72-ba75e0850a2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
