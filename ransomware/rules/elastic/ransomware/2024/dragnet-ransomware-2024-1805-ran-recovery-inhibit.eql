// Dragnet [Ransomware]: dragnet-ransomware-2024-1805 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 33239235-8274-524a-a0d3-dfddf01668f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
