// Dragnet [Ransomware]: dragnet-ransomware-2024-0587 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 637f44cb-aa48-5a65-a6e3-69dc8253e709

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
