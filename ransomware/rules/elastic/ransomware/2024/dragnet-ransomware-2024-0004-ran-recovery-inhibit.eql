// Dragnet [Ransomware]: dragnet-ransomware-2024-0004 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9fa26a4b-2d9a-59f3-bfec-6b6db3143777

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
