// Dragnet [Ransomware]: dragnet-ransomware-2024-4016 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: d5cbee0a-e3d4-5322-a5b4-177368a04fb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
