// Dragnet [Ransomware]: dragnet-ransomware-2024-0185 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6d46084c-29ae-5f41-8045-6a7b6e179d9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
