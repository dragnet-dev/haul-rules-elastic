// Dragnet [Ransomware]: dragnet-ransomware-2024-4855 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 4f22e645-4858-534b-96ae-046d59aefa24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
