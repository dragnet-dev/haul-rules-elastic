// Dragnet [Ransomware]: dragnet-ransomware-2024-3377 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: fd974292-a9f0-56a4-ab4f-d370e795a6b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
