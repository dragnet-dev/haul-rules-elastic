// Dragnet [Ransomware]: dragnet-ransomware-2024-1420 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d330fa69-a666-5f2e-b130-8028b562950c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
