// Dragnet [Ransomware]: dragnet-ransomware-2024-3006 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1ba865e9-1480-56f1-ab6c-f1fd19042deb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
