// Dragnet [Ransomware]: dragnet-ransomware-2024-4652 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 7521f862-d06d-5685-b3b4-91e7610205e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
