// Dragnet [Ransomware]: dragnet-ransomware-2024-5480 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: eeb33af7-495b-5efb-a539-56fedc775c32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
