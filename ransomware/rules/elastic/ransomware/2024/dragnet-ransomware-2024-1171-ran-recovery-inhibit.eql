// Dragnet [Ransomware]: dragnet-ransomware-2024-1171 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f523d4d8-41b0-58b4-8a66-d63e5341e93d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
