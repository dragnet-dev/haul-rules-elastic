// Dragnet [Ransomware]: dragnet-ransomware-2024-1409 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 828eea8f-e2d0-5b91-b805-5dccd4d643ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
