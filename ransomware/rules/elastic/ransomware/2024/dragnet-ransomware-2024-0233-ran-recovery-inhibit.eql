// Dragnet [Ransomware]: dragnet-ransomware-2024-0233 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: a6c4abe3-8451-5da8-8561-773222bc3d53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
