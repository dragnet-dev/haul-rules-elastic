// Dragnet [Ransomware]: dragnet-ransomware-2024-1289 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: bc93a1fd-62d1-5f46-80d3-1d262fd84ae1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
