// Dragnet [Ransomware]: dragnet-ransomware-2024-1198 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 5951095b-6ea9-52ee-9271-a501876d587b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
