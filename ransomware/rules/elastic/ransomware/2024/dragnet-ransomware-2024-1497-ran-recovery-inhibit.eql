// Dragnet [Ransomware]: dragnet-ransomware-2024-1497 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e698f251-c36c-5701-b582-9e56d2431721

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
