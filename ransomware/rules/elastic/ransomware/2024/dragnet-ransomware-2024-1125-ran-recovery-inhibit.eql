// Dragnet [Ransomware]: dragnet-ransomware-2024-1125 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 47bcc4da-2bfe-59cf-b74a-8d5110807d14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
