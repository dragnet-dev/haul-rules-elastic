// Dragnet [Ransomware]: dragnet-ransomware-2024-5210 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 294bdb93-74d2-59d0-89af-5dfdecc886d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
