// Dragnet [Ransomware]: dragnet-ransomware-2024-0241 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 68b8abcd-38b8-54f2-bfdd-1f1509403889

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
