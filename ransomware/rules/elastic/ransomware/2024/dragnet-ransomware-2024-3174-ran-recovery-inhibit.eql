// Dragnet [Ransomware]: dragnet-ransomware-2024-3174 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0c2ec189-0d32-5605-be56-80744e89dcdf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
