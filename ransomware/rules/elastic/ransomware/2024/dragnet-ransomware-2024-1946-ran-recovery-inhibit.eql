// Dragnet [Ransomware]: dragnet-ransomware-2024-1946 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: a9b5c5da-9889-5fca-9062-ca7ef0051f96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
