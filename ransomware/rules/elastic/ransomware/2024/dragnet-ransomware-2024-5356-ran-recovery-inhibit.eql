// Dragnet [Ransomware]: dragnet-ransomware-2024-5356 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 34e5e1a6-5c6d-59d2-8258-5947ca027845

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
