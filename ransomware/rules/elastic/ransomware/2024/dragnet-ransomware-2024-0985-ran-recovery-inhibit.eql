// Dragnet [Ransomware]: dragnet-ransomware-2024-0985 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3f7a46ef-7eec-5267-914c-f86470575c38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
