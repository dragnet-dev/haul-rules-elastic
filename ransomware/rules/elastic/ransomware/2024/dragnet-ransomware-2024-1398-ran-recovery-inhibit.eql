// Dragnet [Ransomware]: dragnet-ransomware-2024-1398 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 59c94401-f189-547f-b8c6-19113d0518f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
