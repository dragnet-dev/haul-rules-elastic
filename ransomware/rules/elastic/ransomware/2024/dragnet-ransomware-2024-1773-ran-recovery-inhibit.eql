// Dragnet [Ransomware]: dragnet-ransomware-2024-1773 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e92359bb-f6e8-5591-b995-b472c879c500

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
