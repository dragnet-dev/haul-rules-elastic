// Dragnet [Ransomware]: dragnet-ransomware-2024-0190 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 573a573a-de4d-59e1-8664-b14626c58ac5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
