// Dragnet [Ransomware]: dragnet-ransomware-2024-1096 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 1fcfbc8d-cf4a-5e2e-a2c5-2eb6b8e80bbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
