// Dragnet [Ransomware]: dragnet-ransomware-2024-3223 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 15d7819a-e332-56a9-9b57-287b8288b937

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
