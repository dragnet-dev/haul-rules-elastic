// Dragnet [Ransomware]: dragnet-ransomware-2024-3056 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8475c961-6aca-5ba3-811b-4906dbea7369

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
