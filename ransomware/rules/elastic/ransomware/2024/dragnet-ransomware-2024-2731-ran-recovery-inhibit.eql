// Dragnet [Ransomware]: dragnet-ransomware-2024-2731 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: a3f9ddde-adbe-56dc-b8fa-7c06cf9f2b29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
