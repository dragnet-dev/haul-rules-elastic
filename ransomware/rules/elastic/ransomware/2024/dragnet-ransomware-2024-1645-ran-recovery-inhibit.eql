// Dragnet [Ransomware]: dragnet-ransomware-2024-1645 — Recovery Inhibition (frag)
// Status: deprecated | Level: high | ID: 44c81064-fb53-5934-a2ad-9859db526f4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
