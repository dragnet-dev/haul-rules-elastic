// Dragnet [Ransomware]: dragnet-ransomware-2024-5477 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: b6d7fe51-ad7a-5cd3-8e37-d067edd14138

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
