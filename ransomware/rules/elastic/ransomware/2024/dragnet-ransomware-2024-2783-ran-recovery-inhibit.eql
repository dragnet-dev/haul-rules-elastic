// Dragnet [Ransomware]: dragnet-ransomware-2024-2783 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 6734477a-0a44-5c40-8452-8a93789c27ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
