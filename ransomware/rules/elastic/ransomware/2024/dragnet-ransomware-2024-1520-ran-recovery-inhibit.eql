// Dragnet [Ransomware]: dragnet-ransomware-2024-1520 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: bc8abb20-94fd-5d2e-be9e-0584c895f423

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
