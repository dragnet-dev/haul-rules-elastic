// Dragnet [Ransomware]: dragnet-ransomware-2024-5148 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 35976902-c3af-5a7a-8a89-1bba66d12c63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
