// Dragnet [Ransomware]: dragnet-ransomware-2024-2108 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: acff1c95-ada3-51ba-8e99-884015b0c404

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
