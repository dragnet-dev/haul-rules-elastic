// Dragnet [Ransomware]: dragnet-ransomware-2024-4991 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: aeca1b01-81aa-58d2-b30d-1e193ddf0414

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
