// Dragnet [Ransomware]: dragnet-ransomware-2024-1169 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: e3fd2d73-c23f-5f13-ba37-f52a6ba8a415

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
