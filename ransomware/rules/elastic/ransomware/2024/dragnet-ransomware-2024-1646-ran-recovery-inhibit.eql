// Dragnet [Ransomware]: dragnet-ransomware-2024-1646 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a31dfb51-71af-5613-8a2c-8641fafe4196

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
