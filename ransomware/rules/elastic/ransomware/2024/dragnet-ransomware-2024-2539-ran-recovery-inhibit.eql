// Dragnet [Ransomware]: dragnet-ransomware-2024-2539 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 9d98021c-9702-5365-b443-43bb34d608a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
