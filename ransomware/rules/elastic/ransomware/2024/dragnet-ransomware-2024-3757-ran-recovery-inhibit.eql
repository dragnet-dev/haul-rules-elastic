// Dragnet [Ransomware]: dragnet-ransomware-2024-3757 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 73480af7-8198-5887-95a3-859d643eafa4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
