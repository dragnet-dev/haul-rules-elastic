// Dragnet [Ransomware]: dragnet-ransomware-2024-0170 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 319040c8-e286-56be-b77d-a6352baa90a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
