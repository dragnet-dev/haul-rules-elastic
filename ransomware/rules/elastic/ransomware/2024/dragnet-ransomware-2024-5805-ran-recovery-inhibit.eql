// Dragnet [Ransomware]: dragnet-ransomware-2024-5805 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: cf3398db-1f97-5eef-8192-6ff41efbf2fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
