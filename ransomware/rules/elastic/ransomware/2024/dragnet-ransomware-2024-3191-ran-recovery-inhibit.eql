// Dragnet [Ransomware]: dragnet-ransomware-2024-3191 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: e997a5e7-bea9-50c9-a607-c555c18a16c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
