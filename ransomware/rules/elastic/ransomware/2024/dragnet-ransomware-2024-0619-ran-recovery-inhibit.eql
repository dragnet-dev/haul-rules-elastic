// Dragnet [Ransomware]: dragnet-ransomware-2024-0619 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 30ab92f5-e281-5989-9e90-2c5208e2b4ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
