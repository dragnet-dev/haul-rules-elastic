// Dragnet [Ransomware]: dragnet-ransomware-2024-1191 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: adbedad3-cbe6-5a23-8297-d84a8c992afb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
