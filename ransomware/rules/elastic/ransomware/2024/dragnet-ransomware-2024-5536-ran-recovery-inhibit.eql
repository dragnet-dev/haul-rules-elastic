// Dragnet [Ransomware]: dragnet-ransomware-2024-5536 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ff42d9f3-fbfb-5c7f-965a-a34653014335

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
