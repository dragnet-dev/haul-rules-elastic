// Dragnet [Ransomware]: dragnet-ransomware-2024-4736 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c1e4fc9b-ddc1-5b5e-a687-b34adfcb85cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
