// Dragnet [Ransomware]: dragnet-ransomware-2024-3989 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1f9bf3d7-e269-533c-a999-9b22dbe17409

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
