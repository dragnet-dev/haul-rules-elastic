// Dragnet [Ransomware]: dragnet-ransomware-2024-2500 — Recovery Inhibition (termite)
// Status: experimental | Level: high | ID: bc30f08e-d5ce-5143-848d-278a57fd84d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
