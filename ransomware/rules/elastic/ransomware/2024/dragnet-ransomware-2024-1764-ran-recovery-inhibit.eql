// Dragnet [Ransomware]: dragnet-ransomware-2024-1764 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d7f873a8-478d-5d95-b814-75396a881349

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
