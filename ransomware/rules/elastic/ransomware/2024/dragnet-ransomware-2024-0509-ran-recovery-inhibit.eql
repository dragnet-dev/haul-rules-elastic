// Dragnet [Ransomware]: dragnet-ransomware-2024-0509 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 9e330c55-8431-52f8-98d7-f2e5731710fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
