// Dragnet [Ransomware]: dragnet-ransomware-2024-0313 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 64122346-2511-5046-927e-585ced1707bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
