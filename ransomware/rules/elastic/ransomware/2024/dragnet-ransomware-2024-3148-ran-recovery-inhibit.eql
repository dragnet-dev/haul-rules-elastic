// Dragnet [Ransomware]: dragnet-ransomware-2024-3148 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 3c5a88a1-e799-5806-9d3a-e64a62762cd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
