// Dragnet [Ransomware]: dragnet-ransomware-2024-0883 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d5a93265-d704-5b11-98fb-2d19c7b32113

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
