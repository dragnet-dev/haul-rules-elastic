// Dragnet [Ransomware]: dragnet-ransomware-2024-1642 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7391f08b-01d8-5090-bcf6-f503c239599d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
