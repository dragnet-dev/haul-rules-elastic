// Dragnet [Ransomware]: dragnet-ransomware-2024-1461 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: b3153003-2313-50ee-b779-4d8c823fc4e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
