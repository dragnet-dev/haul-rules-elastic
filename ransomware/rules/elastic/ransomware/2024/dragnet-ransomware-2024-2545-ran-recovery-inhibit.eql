// Dragnet [Ransomware]: dragnet-ransomware-2024-2545 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 30b88613-dd41-5141-9bf7-a952daa833fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
