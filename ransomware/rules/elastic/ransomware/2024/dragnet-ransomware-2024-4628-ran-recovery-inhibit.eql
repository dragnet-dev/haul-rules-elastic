// Dragnet [Ransomware]: dragnet-ransomware-2024-4628 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: aa07347b-7758-53df-894a-87276c8989f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
