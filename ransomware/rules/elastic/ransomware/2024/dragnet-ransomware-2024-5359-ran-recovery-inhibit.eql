// Dragnet [Ransomware]: dragnet-ransomware-2024-5359 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f9902b07-65ff-5924-a4a9-e5cdd12855bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
