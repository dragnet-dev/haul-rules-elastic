// Dragnet [Ransomware]: dragnet-ransomware-2024-3178 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 05d1a79a-3e9f-52e0-8055-74a472f0ee93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
