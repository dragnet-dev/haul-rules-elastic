// Dragnet [Ransomware]: dragnet-ransomware-2024-3456 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 2071e339-08d2-54a2-a267-eab818c969ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
