// Dragnet [Ransomware]: dragnet-ransomware-2024-2197 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e3c56d5c-6426-51ea-b427-afe2d7337b93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
