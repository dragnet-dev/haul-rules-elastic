// Dragnet [Ransomware]: dragnet-ransomware-2024-0742 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: b5dcaf20-e4f3-5b98-93e9-3c6a21b53db1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
