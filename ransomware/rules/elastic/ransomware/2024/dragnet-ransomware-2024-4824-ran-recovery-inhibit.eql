// Dragnet [Ransomware]: dragnet-ransomware-2024-4824 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: ddecb314-385a-503e-a4d3-7637e5b46be7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
