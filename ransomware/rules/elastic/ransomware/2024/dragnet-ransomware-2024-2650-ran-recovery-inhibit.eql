// Dragnet [Ransomware]: dragnet-ransomware-2024-2650 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: f8a293c0-bc7c-5f4c-a608-f2cd8dd56de9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
