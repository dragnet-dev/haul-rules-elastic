// Dragnet [Ransomware]: dragnet-ransomware-2024-1781 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 217bf17c-5794-5ae1-b228-e98bd18a9e04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
