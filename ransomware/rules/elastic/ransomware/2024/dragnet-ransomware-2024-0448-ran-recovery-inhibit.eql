// Dragnet [Ransomware]: dragnet-ransomware-2024-0448 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: 97c77d55-fd97-53e1-b232-0a47ac1e939c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
