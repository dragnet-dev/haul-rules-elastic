// Dragnet [Ransomware]: dragnet-ransomware-2024-4509 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: cbe42452-fadf-5dd5-a2b9-5f5cd5edb570

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
