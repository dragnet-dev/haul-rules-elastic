// Dragnet [Ransomware]: dragnet-ransomware-2024-0398 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: fa1440e5-8f65-5b8a-93ad-6e667c1e01ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
