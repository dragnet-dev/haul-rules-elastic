// Dragnet [Ransomware]: dragnet-ransomware-2024-3233 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: ecca57e1-11cc-5807-8e73-a7d2f268a085

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
