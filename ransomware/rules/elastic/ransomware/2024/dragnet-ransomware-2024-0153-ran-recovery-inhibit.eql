// Dragnet [Ransomware]: dragnet-ransomware-2024-0153 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: b54598cc-35c1-52c1-b150-98e28c669317

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
