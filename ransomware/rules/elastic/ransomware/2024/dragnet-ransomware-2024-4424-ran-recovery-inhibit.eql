// Dragnet [Ransomware]: dragnet-ransomware-2024-4424 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 5b2cf2b2-35c4-59c2-9d1d-3aa81a0e5827

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
