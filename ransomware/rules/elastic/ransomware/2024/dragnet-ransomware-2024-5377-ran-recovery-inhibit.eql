// Dragnet [Ransomware]: dragnet-ransomware-2024-5377 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 02229d34-eadc-5ef4-9647-34514400f75c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
