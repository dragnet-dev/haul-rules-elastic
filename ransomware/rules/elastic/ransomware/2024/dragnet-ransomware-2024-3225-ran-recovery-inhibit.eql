// Dragnet [Ransomware]: dragnet-ransomware-2024-3225 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6d72dc99-dd31-5308-adb8-520dcae1a938

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
