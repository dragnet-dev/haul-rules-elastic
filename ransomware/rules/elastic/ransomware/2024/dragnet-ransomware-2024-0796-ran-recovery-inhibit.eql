// Dragnet [Ransomware]: dragnet-ransomware-2024-0796 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c8abcc35-5bff-59e3-b121-eed9ebc5b05d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
