// Dragnet [Ransomware]: dragnet-ransomware-2024-5661 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: df578c06-6af5-5707-8d39-c15220e14b23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
