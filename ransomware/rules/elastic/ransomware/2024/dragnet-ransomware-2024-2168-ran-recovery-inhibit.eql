// Dragnet [Ransomware]: dragnet-ransomware-2024-2168 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: c40d0877-2ca9-5aa4-8e9b-ce8b4f49b817

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
