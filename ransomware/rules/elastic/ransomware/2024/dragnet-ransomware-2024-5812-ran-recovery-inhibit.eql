// Dragnet [Ransomware]: dragnet-ransomware-2024-5812 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a7e7399a-931c-5ab4-bf2a-fc6429557df4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
