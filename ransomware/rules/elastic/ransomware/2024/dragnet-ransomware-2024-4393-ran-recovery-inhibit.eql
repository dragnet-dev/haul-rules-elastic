// Dragnet [Ransomware]: dragnet-ransomware-2024-4393 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1d94e195-dc0e-5202-8a31-22c72dac14fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
