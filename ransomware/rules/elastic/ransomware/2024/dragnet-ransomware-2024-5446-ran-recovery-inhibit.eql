// Dragnet [Ransomware]: dragnet-ransomware-2024-5446 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 9192117e-bae9-506e-acb6-00a7d81183f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
