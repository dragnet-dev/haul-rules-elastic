// Dragnet [Ransomware]: dragnet-ransomware-2024-5390 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: a520e8ef-43a2-53bf-ac02-33675e9a62ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
