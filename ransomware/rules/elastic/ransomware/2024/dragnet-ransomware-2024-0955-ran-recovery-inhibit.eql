// Dragnet [Ransomware]: dragnet-ransomware-2024-0955 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 6a6ff3d6-9539-5d6c-98d6-bb639c12a647

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
