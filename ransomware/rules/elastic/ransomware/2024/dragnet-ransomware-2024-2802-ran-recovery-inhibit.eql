// Dragnet [Ransomware]: dragnet-ransomware-2024-2802 — Recovery Inhibition (blackout)
// Status: experimental | Level: high | ID: 82d030b9-9fe5-5b4c-9c58-91bd3fb47ea8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
