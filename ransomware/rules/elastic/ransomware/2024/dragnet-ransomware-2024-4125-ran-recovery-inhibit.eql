// Dragnet [Ransomware]: dragnet-ransomware-2024-4125 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8eff6f94-7607-514b-8aec-7d735603373e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
