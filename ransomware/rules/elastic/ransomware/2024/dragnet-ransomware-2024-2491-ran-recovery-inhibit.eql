// Dragnet [Ransomware]: dragnet-ransomware-2024-2491 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 94490d9f-a4d0-546e-ba20-741caa105611

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
