// Dragnet [Ransomware]: dragnet-ransomware-2024-1400 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: fb9a327b-b5f8-5a64-a023-1dc4c9c9c981

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
