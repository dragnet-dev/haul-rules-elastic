// Dragnet [Ransomware]: dragnet-ransomware-2024-5535 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: df358008-2316-55cf-82e1-f49f3917cbf1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
