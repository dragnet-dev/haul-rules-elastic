// Dragnet [Ransomware]: dragnet-ransomware-2024-3092 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7395bc3d-10c8-5b9a-b462-4574bd21b840

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
