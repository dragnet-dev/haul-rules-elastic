// Dragnet [Ransomware]: dragnet-ransomware-2024-3839 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 816a70bf-f9df-52eb-8921-920ba87ea837

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
