// Dragnet [Ransomware]: dragnet-ransomware-2024-3147 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: 043f5cb5-31a2-5fbd-b925-f704efb5852a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
