// Dragnet [Ransomware]: dragnet-ransomware-2024-3486 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ad7da833-fe98-56d9-8291-68acbebe24fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
