// Dragnet [Ransomware]: dragnet-ransomware-2024-2643 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: ad12649a-9db0-538c-b274-1067938baf68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
