// Dragnet [Ransomware]: dragnet-ransomware-2024-5502 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: c76dd6ac-3ea7-5f00-8b7b-64e63c3219b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
