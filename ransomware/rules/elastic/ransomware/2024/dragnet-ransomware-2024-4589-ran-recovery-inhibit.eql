// Dragnet [Ransomware]: dragnet-ransomware-2024-4589 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 05954ba8-11c0-5722-bbaf-e675d5f83ff4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
