// Dragnet [Ransomware]: dragnet-ransomware-2024-2301 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 85b26c50-117f-54a7-af37-8a0e12f609c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
