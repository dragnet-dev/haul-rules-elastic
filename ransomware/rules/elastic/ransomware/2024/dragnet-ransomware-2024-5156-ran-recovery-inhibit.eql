// Dragnet [Ransomware]: dragnet-ransomware-2024-5156 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: cb988983-2ff6-5068-820e-115851af078e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
