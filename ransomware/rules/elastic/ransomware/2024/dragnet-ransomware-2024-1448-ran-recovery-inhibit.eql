// Dragnet [Ransomware]: dragnet-ransomware-2024-1448 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 90983da7-4590-52a3-85b1-192711787272

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
