// Dragnet [Ransomware]: dragnet-ransomware-2024-0760 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 75a3e225-9704-55b8-8baf-9bc77bdc38f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
