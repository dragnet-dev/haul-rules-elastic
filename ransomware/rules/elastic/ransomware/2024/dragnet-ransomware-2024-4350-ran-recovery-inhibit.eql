// Dragnet [Ransomware]: dragnet-ransomware-2024-4350 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: f9e9ebdc-fad4-5962-a3cd-6b39f866e2eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
