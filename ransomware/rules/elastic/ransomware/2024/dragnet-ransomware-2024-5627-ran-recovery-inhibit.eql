// Dragnet [Ransomware]: dragnet-ransomware-2024-5627 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 9c2a24a7-bc32-5bff-b945-db6b9a97b398

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
