// Dragnet [Ransomware]: dragnet-ransomware-2024-1765 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: a40a2b38-897a-5b12-be72-ff43a078cac9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
