// Dragnet [Ransomware]: dragnet-ransomware-2024-1103 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 232964d1-1114-5236-9b82-7672e9b4c7fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
