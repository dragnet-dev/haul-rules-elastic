// Dragnet [Ransomware]: dragnet-ransomware-2024-1412 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 592d1ee4-6a90-54c0-a59d-6df500193a41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
