// Dragnet [Ransomware]: dragnet-ransomware-2024-3677 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 5f7d2e24-f63c-5777-b792-d3466fa806f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
