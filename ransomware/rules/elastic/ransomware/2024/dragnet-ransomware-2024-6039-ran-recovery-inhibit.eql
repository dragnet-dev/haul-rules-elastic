// Dragnet [Ransomware]: dragnet-ransomware-2024-6039 — Recovery Inhibition (ransomcortex)
// Status: experimental | Level: high | ID: 941cc16e-5853-55bf-8a4e-cc519ee8e92c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
