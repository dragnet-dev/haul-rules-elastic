// Dragnet [Ransomware]: dragnet-ransomware-2024-2588 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 9fec02f4-9930-50b1-af90-ab5e9323b5fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
