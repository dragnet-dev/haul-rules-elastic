// Dragnet [Ransomware]: dragnet-ransomware-2024-3634 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e5d50174-ad29-53a7-86ba-1a06ccd91131

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
