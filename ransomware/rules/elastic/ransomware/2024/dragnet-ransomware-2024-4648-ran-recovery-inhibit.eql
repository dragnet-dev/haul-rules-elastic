// Dragnet [Ransomware]: dragnet-ransomware-2024-4648 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: e9c6a779-e474-5be1-b465-e24b34b22fcf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
