// Dragnet [Ransomware]: dragnet-ransomware-2024-0842 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0dd6f7ed-761f-539f-b4ee-a5d68820b505

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
