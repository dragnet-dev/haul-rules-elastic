// Dragnet [Ransomware]: dragnet-ransomware-2024-4346 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 5df74335-de9c-58fc-a55e-9389cb62ab47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
