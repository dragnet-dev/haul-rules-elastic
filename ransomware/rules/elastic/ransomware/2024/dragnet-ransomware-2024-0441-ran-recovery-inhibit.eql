// Dragnet [Ransomware]: dragnet-ransomware-2024-0441 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: edc5d90b-5fe0-5f0c-825c-7a9991d9fda1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
