// Dragnet [Ransomware]: dragnet-ransomware-2024-2268 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 755e01c6-ff8a-5110-a0bb-877c79a7aa04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
