// Dragnet [Ransomware]: dragnet-ransomware-2024-0239 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0b93013e-d5f4-53c9-bdc3-c1da6a748a12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
