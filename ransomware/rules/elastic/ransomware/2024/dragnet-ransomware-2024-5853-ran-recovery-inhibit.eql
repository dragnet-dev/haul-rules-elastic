// Dragnet [Ransomware]: dragnet-ransomware-2024-5853 — Recovery Inhibition (trinity)
// Status: experimental | Level: high | ID: f402827b-8b98-58fc-bc7a-275c15f07efa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
