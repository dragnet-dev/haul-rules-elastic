// Dragnet [Ransomware]: dragnet-ransomware-2024-1006 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b06e76af-9396-5127-a1be-8e2f89e40f47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
