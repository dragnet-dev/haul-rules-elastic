// Dragnet [Ransomware]: dragnet-ransomware-2024-2077 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 8c277b43-4a2a-5b60-9afc-c582e91bd80c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
