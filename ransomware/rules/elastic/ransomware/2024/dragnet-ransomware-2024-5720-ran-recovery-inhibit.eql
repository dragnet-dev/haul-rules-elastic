// Dragnet [Ransomware]: dragnet-ransomware-2024-5720 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 782f20cc-a69d-527d-a195-8ba7996a5e35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
