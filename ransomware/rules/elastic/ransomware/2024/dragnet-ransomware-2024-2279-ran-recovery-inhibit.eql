// Dragnet [Ransomware]: dragnet-ransomware-2024-2279 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 389ae2c8-482a-5016-b36d-8f2c7ac8dbc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
