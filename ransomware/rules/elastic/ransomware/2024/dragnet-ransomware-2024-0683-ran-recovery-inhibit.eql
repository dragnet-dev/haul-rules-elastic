// Dragnet [Ransomware]: dragnet-ransomware-2024-0683 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: 99b87cff-1efa-56d8-a5b4-f45ca50e0dd1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
