// Dragnet [Ransomware]: dragnet-ransomware-2024-5118 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 675dd4cf-c126-5049-a914-924dbb6f5a21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
