// Dragnet [Ransomware]: dragnet-ransomware-2024-1118 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0827c016-0a79-589a-be85-39134fb00c3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
