// Dragnet [Ransomware]: dragnet-ransomware-2024-0647 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 6dd99dbe-bded-5cfe-a447-b347266ee2dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
