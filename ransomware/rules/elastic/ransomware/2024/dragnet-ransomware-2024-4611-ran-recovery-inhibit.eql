// Dragnet [Ransomware]: dragnet-ransomware-2024-4611 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2791864e-256e-5284-a2b1-8ccdb98c7ee3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
