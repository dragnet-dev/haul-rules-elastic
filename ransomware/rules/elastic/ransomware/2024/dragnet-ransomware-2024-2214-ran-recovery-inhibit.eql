// Dragnet [Ransomware]: dragnet-ransomware-2024-2214 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 4b63a531-2480-5f6a-a2be-3c1c5765c6c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
