// Dragnet [Ransomware]: dragnet-ransomware-2024-0805 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 6965c801-3d62-518b-b5ac-ed442fa9b76c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
