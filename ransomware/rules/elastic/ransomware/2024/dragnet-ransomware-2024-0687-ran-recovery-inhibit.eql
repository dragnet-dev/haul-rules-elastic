// Dragnet [Ransomware]: dragnet-ransomware-2024-0687 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 2ea0f9e0-2bd9-5958-8bf1-e7eec6207317

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
