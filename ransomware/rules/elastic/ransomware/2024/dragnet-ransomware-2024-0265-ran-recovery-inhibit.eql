// Dragnet [Ransomware]: dragnet-ransomware-2024-0265 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8d280db1-3ba5-51b5-b7fd-ad6a96149cbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
