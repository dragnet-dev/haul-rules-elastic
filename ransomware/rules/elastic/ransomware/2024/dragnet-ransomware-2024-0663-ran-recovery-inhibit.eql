// Dragnet [Ransomware]: dragnet-ransomware-2024-0663 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 03cc5e45-0208-5556-90b2-7ab523fb3648

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
