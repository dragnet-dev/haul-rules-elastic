// Dragnet [Ransomware]: dragnet-ransomware-2024-2355 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a0ebc3db-3fa5-5db1-9680-8ca59d50159f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
