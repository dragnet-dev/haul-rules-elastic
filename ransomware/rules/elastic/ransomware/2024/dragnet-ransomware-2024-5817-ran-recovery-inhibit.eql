// Dragnet [Ransomware]: dragnet-ransomware-2024-5817 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1fca29b3-14e5-50e7-9dfc-bd6f2356125c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
