// Dragnet [Ransomware]: dragnet-ransomware-2024-1518 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 59f9b044-9f5e-5ed6-b851-bc2166fae484

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
