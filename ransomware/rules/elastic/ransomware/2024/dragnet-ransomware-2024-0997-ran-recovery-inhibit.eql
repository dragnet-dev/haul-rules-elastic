// Dragnet [Ransomware]: dragnet-ransomware-2024-0997 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 437e0dc5-7e6d-504b-b3f1-cd5fbbd7af21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
