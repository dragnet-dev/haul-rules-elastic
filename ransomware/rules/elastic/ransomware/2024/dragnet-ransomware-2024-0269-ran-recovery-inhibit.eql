// Dragnet [Ransomware]: dragnet-ransomware-2024-0269 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: ad7b87bd-9143-5e79-b418-1e92623263f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
