// Dragnet [Ransomware]: dragnet-ransomware-2024-0780 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 1921fd57-67d0-54bc-8d6b-5430fd0e27a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
