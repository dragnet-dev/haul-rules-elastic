// Dragnet [Ransomware]: dragnet-ransomware-2024-2106 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: fabc382f-2b57-520a-a8d4-1e7e23c48f68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
