// Dragnet [Ransomware]: dragnet-ransomware-2024-5315 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8db37451-b840-53c6-a882-d5cedd904293

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
