// Dragnet [Ransomware]: dragnet-ransomware-2024-1594 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 5cac7862-8ec8-50da-8303-3aad13c44f73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
