// Dragnet [Ransomware]: dragnet-ransomware-2024-2533 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d9004856-932e-5429-bf7f-dcd417902311

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
