// Dragnet [Ransomware]: dragnet-ransomware-2024-3739 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 077897e4-c19b-5e0c-bcfd-e3d65a91df98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
