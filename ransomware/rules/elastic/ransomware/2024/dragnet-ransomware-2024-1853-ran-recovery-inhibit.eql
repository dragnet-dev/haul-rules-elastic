// Dragnet [Ransomware]: dragnet-ransomware-2024-1853 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d870582d-c532-5a7b-bcbe-374ac828dbf1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
