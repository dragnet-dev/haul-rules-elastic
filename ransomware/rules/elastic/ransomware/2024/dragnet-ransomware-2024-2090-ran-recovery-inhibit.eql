// Dragnet [Ransomware]: dragnet-ransomware-2024-2090 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 865b21a4-4501-5246-b115-b97e0e6038fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
