// Dragnet [Ransomware]: dragnet-ransomware-2024-0762 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1325fe51-42ec-53b6-837d-42f481fe9d05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
