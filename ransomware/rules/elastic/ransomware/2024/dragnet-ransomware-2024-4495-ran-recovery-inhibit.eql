// Dragnet [Ransomware]: dragnet-ransomware-2024-4495 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 42a0d92c-31c6-583c-a9d9-d8ce13fcc31c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
