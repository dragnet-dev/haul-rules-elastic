// Dragnet [Ransomware]: dragnet-ransomware-2024-0399 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8ede26fe-40b7-5e08-8068-85522eb33ee6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
