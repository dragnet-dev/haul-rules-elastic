// Dragnet [Ransomware]: dragnet-ransomware-2024-5256 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 420bad7f-29b4-5f92-9a9c-626ceed869ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
