// Dragnet [Ransomware]: dragnet-ransomware-2024-5346 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: d8e0be07-3517-5d64-b153-1e294bca44c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
