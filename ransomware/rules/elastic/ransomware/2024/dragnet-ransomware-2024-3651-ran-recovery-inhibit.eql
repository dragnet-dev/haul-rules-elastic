// Dragnet [Ransomware]: dragnet-ransomware-2024-3651 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 9e0d5013-eb9d-5296-9393-790647d2eb8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
