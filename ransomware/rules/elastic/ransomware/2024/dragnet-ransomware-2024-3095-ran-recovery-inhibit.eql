// Dragnet [Ransomware]: dragnet-ransomware-2024-3095 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 9e005442-816b-5618-827f-b7ec29c58ee8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
