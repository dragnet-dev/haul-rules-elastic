// Dragnet [Ransomware]: dragnet-ransomware-2024-1673 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8791d52c-6f95-5422-9bf3-120b4afe71e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
