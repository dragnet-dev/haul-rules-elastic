// Dragnet [Ransomware]: dragnet-ransomware-2024-4314 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 75e16bd6-dec3-56f2-969b-5e2576cc347c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
