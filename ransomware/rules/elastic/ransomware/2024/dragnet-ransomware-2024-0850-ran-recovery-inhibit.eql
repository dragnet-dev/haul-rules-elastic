// Dragnet [Ransomware]: dragnet-ransomware-2024-0850 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 4e395cbb-7582-5f15-ad37-b4dee836ac4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
