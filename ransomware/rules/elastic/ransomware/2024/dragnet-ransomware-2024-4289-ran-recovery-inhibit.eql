// Dragnet [Ransomware]: dragnet-ransomware-2024-4289 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: b5e95889-52d0-5377-92db-712479626bb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
