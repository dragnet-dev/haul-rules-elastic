// Dragnet [Ransomware]: dragnet-ransomware-2024-5215 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: e3deeb26-dec0-56de-8b9b-06dfe5a45a54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
