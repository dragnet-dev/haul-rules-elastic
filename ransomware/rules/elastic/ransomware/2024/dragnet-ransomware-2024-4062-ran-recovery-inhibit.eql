// Dragnet [Ransomware]: dragnet-ransomware-2024-4062 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 1ddd12cb-2005-559d-a380-1ce125f84c59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
