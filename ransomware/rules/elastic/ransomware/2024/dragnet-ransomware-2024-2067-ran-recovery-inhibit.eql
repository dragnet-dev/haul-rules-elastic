// Dragnet [Ransomware]: dragnet-ransomware-2024-2067 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 93fca505-d816-5665-87b5-f65d9c056b98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
