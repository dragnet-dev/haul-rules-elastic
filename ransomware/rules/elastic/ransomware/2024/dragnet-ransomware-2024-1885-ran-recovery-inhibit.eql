// Dragnet [Ransomware]: dragnet-ransomware-2024-1885 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: da976733-16b3-5f8c-90f8-ffadade57ff5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
