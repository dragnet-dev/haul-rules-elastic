// Dragnet [Ransomware]: dragnet-ransomware-2024-5624 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: c1d3e2f7-b838-55a6-a458-66cf7a1d2fe4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
