// Dragnet [Ransomware]: dragnet-ransomware-2024-1128 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f39899f1-aa8a-5b0c-a081-6f6751d2ae00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
