// Dragnet [Ransomware]: dragnet-ransomware-2024-1106 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: b5b3e6fc-0c1c-56b0-afbd-60e5e7c18df6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
