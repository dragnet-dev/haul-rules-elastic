// Dragnet [Ransomware]: dragnet-ransomware-2024-5305 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 7a7ad9a1-b07b-502d-a550-06836e7bf5a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
