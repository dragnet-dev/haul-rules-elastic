// Dragnet [Ransomware]: dragnet-ransomware-2024-4331 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 8021ece1-3f6a-5d43-a531-7a23d3eba85d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
