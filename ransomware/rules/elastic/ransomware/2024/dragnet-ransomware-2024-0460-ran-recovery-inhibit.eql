// Dragnet [Ransomware]: dragnet-ransomware-2024-0460 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e7cda94f-a1e3-541e-9864-f2008b0557a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
