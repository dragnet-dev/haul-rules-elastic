// Dragnet [Ransomware]: dragnet-ransomware-2024-1142 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5a172082-cca7-59ce-b83c-3e841a05e40b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
