// Dragnet [Ransomware]: dragnet-ransomware-2024-0625 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 8f309dc2-bbf2-5f6c-950c-583708ff7fb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
