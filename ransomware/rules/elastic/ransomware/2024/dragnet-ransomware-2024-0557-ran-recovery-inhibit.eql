// Dragnet [Ransomware]: dragnet-ransomware-2024-0557 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6874dec3-9c7e-5dca-b705-ad005e9e27c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
