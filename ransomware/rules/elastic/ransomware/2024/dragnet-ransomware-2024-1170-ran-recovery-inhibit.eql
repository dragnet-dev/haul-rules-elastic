// Dragnet [Ransomware]: dragnet-ransomware-2024-1170 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: ff9e2c52-5cb2-54fe-8f88-65a288634be4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
