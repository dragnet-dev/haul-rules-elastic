// Dragnet [Ransomware]: dragnet-ransomware-2024-2652 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: a1d1674e-ed16-557e-ad78-6ae83754dc83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
