// Dragnet [Ransomware]: dragnet-ransomware-2024-0095 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 9233c89c-8635-5585-b62a-38dd796c9841

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
