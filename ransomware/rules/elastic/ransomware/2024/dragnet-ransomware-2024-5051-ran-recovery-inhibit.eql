// Dragnet [Ransomware]: dragnet-ransomware-2024-5051 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 9fb39834-3d58-5679-baf2-6ee80801a3f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
