// Dragnet [Ransomware]: dragnet-ransomware-2024-1583 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: ea8c7791-5f58-56ec-95e3-429bc0a0d738

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
