// Dragnet [Ransomware]: dragnet-ransomware-2024-1014 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 5b0fc7c6-5939-52e1-afd2-1905378f09a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
