// Dragnet [Ransomware]: dragnet-ransomware-2024-2468 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4969d213-cd13-5bba-9e55-5666e57d3963

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
