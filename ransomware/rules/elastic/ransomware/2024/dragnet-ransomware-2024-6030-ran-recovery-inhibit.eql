// Dragnet [Ransomware]: dragnet-ransomware-2024-6030 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 8257f674-5820-57f3-9d09-5c47c15ea514

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
