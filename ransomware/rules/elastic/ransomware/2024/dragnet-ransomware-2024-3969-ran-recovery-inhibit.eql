// Dragnet [Ransomware]: dragnet-ransomware-2024-3969 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0b0a6ed2-c3fb-5e6b-aa25-a2d347fc8ec2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
