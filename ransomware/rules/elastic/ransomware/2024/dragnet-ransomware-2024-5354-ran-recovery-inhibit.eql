// Dragnet [Ransomware]: dragnet-ransomware-2024-5354 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: ef6c7ab8-048c-5678-b5f9-2e1d3ff60c7c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
