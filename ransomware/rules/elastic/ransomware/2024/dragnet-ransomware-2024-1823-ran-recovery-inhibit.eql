// Dragnet [Ransomware]: dragnet-ransomware-2024-1823 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 38d7ad64-2081-5060-b3e5-acf9c0f76b00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
