// Dragnet [Ransomware]: dragnet-ransomware-2024-4913 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 58f7de65-0366-583f-9c31-d9b4425ab314

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
