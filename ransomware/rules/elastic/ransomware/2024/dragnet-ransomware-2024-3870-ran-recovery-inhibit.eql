// Dragnet [Ransomware]: dragnet-ransomware-2024-3870 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 74189a11-a7c2-5140-866a-d757cb9aa111

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
