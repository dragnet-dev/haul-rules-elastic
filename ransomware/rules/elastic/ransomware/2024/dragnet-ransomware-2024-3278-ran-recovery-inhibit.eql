// Dragnet [Ransomware]: dragnet-ransomware-2024-3278 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 90e69f79-2939-5e31-bd38-ec1ba394ae5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
