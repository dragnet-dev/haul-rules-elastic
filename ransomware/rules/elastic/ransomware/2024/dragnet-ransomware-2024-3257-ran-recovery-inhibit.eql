// Dragnet [Ransomware]: dragnet-ransomware-2024-3257 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: ec178e76-ff2a-55a8-bbc2-ede83e42c393

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
