// Dragnet [Ransomware]: dragnet-ransomware-2024-5340 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: f69d8803-82e1-57d5-b8ac-04176fd11230

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
