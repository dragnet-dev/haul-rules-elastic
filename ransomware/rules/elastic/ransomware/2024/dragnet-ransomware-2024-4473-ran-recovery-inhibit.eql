// Dragnet [Ransomware]: dragnet-ransomware-2024-4473 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6503dd54-b9e3-57d5-b001-a2d6e648ff53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
