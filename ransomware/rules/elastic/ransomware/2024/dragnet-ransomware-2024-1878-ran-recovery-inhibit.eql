// Dragnet [Ransomware]: dragnet-ransomware-2024-1878 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: e4ccbb56-7499-593d-9fc6-2750059bed62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
