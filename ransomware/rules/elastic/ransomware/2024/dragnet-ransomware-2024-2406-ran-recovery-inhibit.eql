// Dragnet [Ransomware]: dragnet-ransomware-2024-2406 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 8901d300-0e99-5cf2-9fde-d3ec4b56d44b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
