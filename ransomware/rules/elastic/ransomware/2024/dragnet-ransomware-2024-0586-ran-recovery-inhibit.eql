// Dragnet [Ransomware]: dragnet-ransomware-2024-0586 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 10b77c4f-9580-541c-ad5c-a73c164b4d45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
