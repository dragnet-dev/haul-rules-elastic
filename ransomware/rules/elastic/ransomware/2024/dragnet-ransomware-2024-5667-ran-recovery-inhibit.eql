// Dragnet [Ransomware]: dragnet-ransomware-2024-5667 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: dd1c45c7-d5ac-59ee-bde5-2653c3c0bcb9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
