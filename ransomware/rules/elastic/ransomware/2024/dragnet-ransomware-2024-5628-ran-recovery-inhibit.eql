// Dragnet [Ransomware]: dragnet-ransomware-2024-5628 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: f7e8b8d7-bde2-5045-bd63-fb9f5ee6b68e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
