// Dragnet [Ransomware]: dragnet-ransomware-2024-3624 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: b5e16ccf-37b3-5069-9e93-4b7f656526b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
