// Dragnet [Ransomware]: dragnet-ransomware-2024-6008 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: c8e7f0eb-775d-5177-b0e5-ccc0f3a40c30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
