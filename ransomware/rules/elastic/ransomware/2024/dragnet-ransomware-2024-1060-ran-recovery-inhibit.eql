// Dragnet [Ransomware]: dragnet-ransomware-2024-1060 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: d845c30f-8864-5e98-b5d8-9a125a8ff935

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
