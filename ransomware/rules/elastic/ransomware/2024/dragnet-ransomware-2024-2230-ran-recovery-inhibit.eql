// Dragnet [Ransomware]: dragnet-ransomware-2024-2230 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 615c4266-e544-5e4a-914a-4e4a1cf5b28c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
