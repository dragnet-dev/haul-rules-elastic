// Dragnet [Ransomware]: dragnet-ransomware-2024-4995 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 58f87761-980a-5694-9f53-d67fc87e301d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
