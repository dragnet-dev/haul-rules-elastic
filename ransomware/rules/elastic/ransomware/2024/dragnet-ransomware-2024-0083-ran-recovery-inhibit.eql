// Dragnet [Ransomware]: dragnet-ransomware-2024-0083 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: a134fa7f-5096-5301-a4b0-b777a3d9ad0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
