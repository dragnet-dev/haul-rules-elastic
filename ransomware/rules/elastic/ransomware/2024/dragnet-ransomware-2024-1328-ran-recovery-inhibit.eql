// Dragnet [Ransomware]: dragnet-ransomware-2024-1328 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d009ce34-e225-50cb-ab8e-18baccbad2a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
