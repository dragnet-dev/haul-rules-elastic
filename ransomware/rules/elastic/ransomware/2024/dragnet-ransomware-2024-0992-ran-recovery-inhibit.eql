// Dragnet [Ransomware]: dragnet-ransomware-2024-0992 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a24021a7-50e1-51e7-b299-22a080885011

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
