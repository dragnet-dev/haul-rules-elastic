// Dragnet [Ransomware]: dragnet-ransomware-2024-1686 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 6ee76ec2-9403-5fa6-b7df-d4d665df9cfc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
