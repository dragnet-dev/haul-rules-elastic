// Dragnet [Ransomware]: dragnet-ransomware-2024-4553 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5d8e3373-bb31-5418-b6b5-becbbb1b5ebc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
