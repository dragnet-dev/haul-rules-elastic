// Dragnet [Ransomware]: dragnet-ransomware-2024-3661 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: 7d4fac7e-420d-55b5-bff4-c180f3601380

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
