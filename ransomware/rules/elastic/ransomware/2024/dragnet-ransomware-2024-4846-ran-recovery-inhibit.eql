// Dragnet [Ransomware]: dragnet-ransomware-2024-4846 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: a258d4a5-df00-53ee-a717-5192650b4358

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
