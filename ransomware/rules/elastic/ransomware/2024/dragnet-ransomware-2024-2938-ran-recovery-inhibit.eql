// Dragnet [Ransomware]: dragnet-ransomware-2024-2938 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: de3a766d-d535-5d4b-ba8a-17378bc547fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
