// Dragnet [Ransomware]: dragnet-ransomware-2024-5185 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 49217314-18da-504e-b35d-0cdbf2cc0198

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
