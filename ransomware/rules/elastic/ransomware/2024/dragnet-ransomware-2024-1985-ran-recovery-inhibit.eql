// Dragnet [Ransomware]: dragnet-ransomware-2024-1985 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: fc95bb75-2df9-53dc-87a1-0c7b4c0e3961

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
