// Dragnet [Ransomware]: dragnet-ransomware-2024-1035 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 59c043a5-8c08-5fdb-b264-9546e75f3722

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
