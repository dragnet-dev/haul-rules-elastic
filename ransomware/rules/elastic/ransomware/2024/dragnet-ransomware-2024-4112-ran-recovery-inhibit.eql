// Dragnet [Ransomware]: dragnet-ransomware-2024-4112 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e5265c1c-c531-5175-b65f-45967e0df654

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
