// Dragnet [Ransomware]: dragnet-ransomware-2024-4769 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: c86c8fd1-25ec-5b8c-a6f3-277c70f67980

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
