// Dragnet [Ransomware]: dragnet-ransomware-2024-3841 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 0e0c3f8a-21a0-5d5e-af5d-c3497faae2b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
