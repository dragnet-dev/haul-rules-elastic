// Dragnet [Ransomware]: dragnet-ransomware-2024-3405 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: cdead17f-a3d5-5a8a-8279-fe09ea16464c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
