// Dragnet [Ransomware]: dragnet-ransomware-2024-0733 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0398659c-fb9a-5b55-98d8-7da89ec31e67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
