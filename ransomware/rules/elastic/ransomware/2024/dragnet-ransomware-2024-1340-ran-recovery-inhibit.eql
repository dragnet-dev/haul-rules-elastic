// Dragnet [Ransomware]: dragnet-ransomware-2024-1340 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2085106e-95a9-503f-91d2-dd92a1cc95d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
