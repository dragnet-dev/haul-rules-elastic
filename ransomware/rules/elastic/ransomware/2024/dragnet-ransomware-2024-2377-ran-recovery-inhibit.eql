// Dragnet [Ransomware]: dragnet-ransomware-2024-2377 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3ec6c5bb-c364-5581-83a6-4880fbb57e5e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
