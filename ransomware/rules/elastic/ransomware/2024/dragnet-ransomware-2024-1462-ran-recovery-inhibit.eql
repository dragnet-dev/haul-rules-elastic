// Dragnet [Ransomware]: dragnet-ransomware-2024-1462 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: badff4d3-e1e7-5991-b6fa-dc46eebc7641

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
