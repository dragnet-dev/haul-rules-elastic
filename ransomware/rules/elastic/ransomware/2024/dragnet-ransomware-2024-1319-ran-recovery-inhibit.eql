// Dragnet [Ransomware]: dragnet-ransomware-2024-1319 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 593e2aa5-f810-53c6-9c8d-44f9b360d1b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
