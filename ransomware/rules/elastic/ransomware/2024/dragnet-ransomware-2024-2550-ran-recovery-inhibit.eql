// Dragnet [Ransomware]: dragnet-ransomware-2024-2550 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a73c6f35-cc3c-54a2-8105-a24c006a84b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
