// Dragnet [Ransomware]: dragnet-ransomware-2024-5568 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: cbfdf2fc-1798-567c-be9b-64ce300485cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
