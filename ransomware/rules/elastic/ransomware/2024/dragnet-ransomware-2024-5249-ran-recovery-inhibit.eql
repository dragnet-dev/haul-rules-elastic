// Dragnet [Ransomware]: dragnet-ransomware-2024-5249 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0ff5779f-8017-5880-a3cd-9bc91e469d26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
