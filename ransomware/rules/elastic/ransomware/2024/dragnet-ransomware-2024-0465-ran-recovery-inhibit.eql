// Dragnet [Ransomware]: dragnet-ransomware-2024-0465 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 25483da6-1b15-54b5-9301-a26d740f5452

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
