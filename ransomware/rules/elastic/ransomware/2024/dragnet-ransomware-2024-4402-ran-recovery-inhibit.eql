// Dragnet [Ransomware]: dragnet-ransomware-2024-4402 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: cfb386b1-133d-5ce0-ad81-571a0a57b7d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
