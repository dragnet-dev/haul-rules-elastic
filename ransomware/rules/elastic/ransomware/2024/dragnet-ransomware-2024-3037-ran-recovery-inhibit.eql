// Dragnet [Ransomware]: dragnet-ransomware-2024-3037 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 995e3876-c465-5eee-b9be-347f0a438df0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
