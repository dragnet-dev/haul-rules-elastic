// Dragnet [Ransomware]: dragnet-ransomware-2024-3834 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 98834a4e-8540-5ec8-86a0-ca55ea02b5f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
