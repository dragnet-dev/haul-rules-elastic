// Dragnet [Ransomware]: dragnet-ransomware-2024-5671 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 61e4cdab-c60b-5ac7-858f-88b1f6af08cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
