// Dragnet [Ransomware]: dragnet-ransomware-2024-4963 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 0e308225-452c-5d2b-8546-ac6f93402eb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
