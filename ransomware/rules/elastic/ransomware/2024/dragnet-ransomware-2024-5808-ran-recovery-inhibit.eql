// Dragnet [Ransomware]: dragnet-ransomware-2024-5808 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 5aac210a-bcde-5427-9300-37ae19c6a441

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
