// Dragnet [Ransomware]: dragnet-ransomware-2024-5868 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f89a4145-b8af-5576-88f0-7948ed735ce4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
