// Dragnet [Ransomware]: dragnet-ransomware-2024-4040 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: cea320a1-2207-5ab2-9bce-2f64a94bfd74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
