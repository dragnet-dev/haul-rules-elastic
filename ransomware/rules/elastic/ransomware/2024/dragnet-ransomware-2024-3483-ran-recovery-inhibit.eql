// Dragnet [Ransomware]: dragnet-ransomware-2024-3483 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: f3c98ee3-500c-5cfa-aa8a-538c43829c83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
