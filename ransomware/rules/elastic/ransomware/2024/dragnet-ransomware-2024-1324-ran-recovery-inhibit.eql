// Dragnet [Ransomware]: dragnet-ransomware-2024-1324 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9ec0d94c-6673-507a-92a9-c4028b1637cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
