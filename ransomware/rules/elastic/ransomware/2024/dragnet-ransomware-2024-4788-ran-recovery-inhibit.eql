// Dragnet [Ransomware]: dragnet-ransomware-2024-4788 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 67b7b9e9-befa-58d9-8c87-d6184ff79acb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
