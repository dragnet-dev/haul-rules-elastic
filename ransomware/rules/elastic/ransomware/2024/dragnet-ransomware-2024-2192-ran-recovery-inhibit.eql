// Dragnet [Ransomware]: dragnet-ransomware-2024-2192 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: ee759928-a434-5999-bf0d-267479134eb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
