// Dragnet [Ransomware]: dragnet-ransomware-2024-2400 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 29bf9e16-1169-596c-8c96-c3065a2d897a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
