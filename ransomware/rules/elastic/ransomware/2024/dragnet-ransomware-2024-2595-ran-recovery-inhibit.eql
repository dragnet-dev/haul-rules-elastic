// Dragnet [Ransomware]: dragnet-ransomware-2024-2595 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d9f57706-536a-5525-8093-9946adb8a888

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
