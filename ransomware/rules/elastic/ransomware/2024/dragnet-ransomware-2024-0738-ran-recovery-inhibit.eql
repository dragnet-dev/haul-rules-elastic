// Dragnet [Ransomware]: dragnet-ransomware-2024-0738 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: cae159d1-8d0e-5798-909d-f3f736885c57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
