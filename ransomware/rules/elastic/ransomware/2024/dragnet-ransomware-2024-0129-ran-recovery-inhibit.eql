// Dragnet [Ransomware]: dragnet-ransomware-2024-0129 — Recovery Inhibition (cloak)
// Status: experimental | Level: high | ID: ead7c44a-4d75-5b55-a37a-22560de983f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
