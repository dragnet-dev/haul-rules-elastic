// Dragnet [Ransomware]: dragnet-ransomware-2024-2054 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: 8c3cd8fd-809a-598b-94b2-4bd49d923c63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
