// Dragnet [Ransomware]: dragnet-ransomware-2024-4486 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: fb0a5d4a-bce7-54e5-a74d-c08bf661dbda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
