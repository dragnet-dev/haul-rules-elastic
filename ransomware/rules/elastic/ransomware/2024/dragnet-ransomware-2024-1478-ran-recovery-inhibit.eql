// Dragnet [Ransomware]: dragnet-ransomware-2024-1478 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: cdaf68cc-009a-5165-8a49-a02ab84f6a05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
