// Dragnet [Ransomware]: dragnet-ransomware-2024-1246 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: f0186244-45b9-53f5-8f42-d89847bdafb9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
