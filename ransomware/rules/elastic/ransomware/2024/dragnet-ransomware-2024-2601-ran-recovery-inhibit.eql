// Dragnet [Ransomware]: dragnet-ransomware-2024-2601 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: bee61633-080c-5f62-810c-893da6494744

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
