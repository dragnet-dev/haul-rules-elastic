// Dragnet [Ransomware]: dragnet-ransomware-2024-4475 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 0a97fd7f-88da-5c9b-87d6-e2b0e9137ebb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
