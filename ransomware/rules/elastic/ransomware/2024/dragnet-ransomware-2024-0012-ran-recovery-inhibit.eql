// Dragnet [Ransomware]: dragnet-ransomware-2024-0012 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1b831738-1cdd-525f-873c-271035feb3a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
