// Dragnet [Ransomware]: dragnet-ransomware-2024-2626 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f1d121c4-f549-534b-965c-2c9a52bbc7df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
