// Dragnet [Ransomware]: dragnet-ransomware-2024-3399 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 984d7254-d207-560b-9e95-702b9d243e09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
