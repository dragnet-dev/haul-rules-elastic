// Dragnet [Ransomware]: dragnet-ransomware-2024-0580 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 548bb98b-ed9d-5c9e-8a2b-7038d440e8b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
