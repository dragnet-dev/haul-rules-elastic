// Dragnet [Ransomware]: dragnet-ransomware-2024-3480 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: 33e27ec2-d34c-5145-8caf-b3f5165b39f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
