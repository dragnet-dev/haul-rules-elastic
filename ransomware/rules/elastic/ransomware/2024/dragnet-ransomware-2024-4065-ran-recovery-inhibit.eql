// Dragnet [Ransomware]: dragnet-ransomware-2024-4065 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: a0668a07-734b-5e25-85c7-63d6a34d62b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
