// Dragnet [Ransomware]: dragnet-ransomware-2024-2011 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 390a9081-4077-5a9a-9ed9-7baf63c84b1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
