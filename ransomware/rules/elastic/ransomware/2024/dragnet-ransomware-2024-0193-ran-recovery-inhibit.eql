// Dragnet [Ransomware]: dragnet-ransomware-2024-0193 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 5839d14f-e8c5-5f4d-a409-2ac64fb520c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
