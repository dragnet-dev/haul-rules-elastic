// Dragnet [Ransomware]: dragnet-ransomware-2024-1449 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 75b8359c-83d4-58d1-96b2-72720ce573c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
