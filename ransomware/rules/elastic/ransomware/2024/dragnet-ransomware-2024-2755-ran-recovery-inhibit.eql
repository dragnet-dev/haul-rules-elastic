// Dragnet [Ransomware]: dragnet-ransomware-2024-2755 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 2a1ce09f-a1d6-51a6-9ce4-cfbd049d405e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
