// Dragnet [Ransomware]: dragnet-ransomware-2024-2725 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 45a37e2f-1bbf-540f-816f-581062b80760

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
