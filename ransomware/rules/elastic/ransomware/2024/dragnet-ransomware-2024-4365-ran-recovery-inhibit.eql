// Dragnet [Ransomware]: dragnet-ransomware-2024-4365 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 3a2236b1-74c9-5afd-96d0-e3b76a5f1aa4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
