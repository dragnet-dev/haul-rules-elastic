// Dragnet [Ransomware]: dragnet-ransomware-2024-2718 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 633b7db7-bf06-501c-b821-fc0df5804507

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
