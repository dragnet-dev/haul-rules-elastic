// Dragnet [Ransomware]: dragnet-ransomware-2024-4867 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: c6c42ed5-b3b0-5f9e-bd0e-9b93dc56671b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
