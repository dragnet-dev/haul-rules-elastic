// Dragnet [Ransomware]: dragnet-ransomware-2024-1727 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: d7339646-2893-5bf3-b491-a9e646590d2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
