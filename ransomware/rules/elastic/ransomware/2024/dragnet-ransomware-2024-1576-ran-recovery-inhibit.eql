// Dragnet [Ransomware]: dragnet-ransomware-2024-1576 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: d2ffcf74-7f03-5a4c-b339-eac0905ed8f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
