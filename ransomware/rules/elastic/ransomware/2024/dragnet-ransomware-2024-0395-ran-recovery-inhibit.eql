// Dragnet [Ransomware]: dragnet-ransomware-2024-0395 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 343dc0ff-7bb8-5c77-a140-873ece43d366

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
