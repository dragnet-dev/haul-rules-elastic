// Dragnet [Ransomware]: dragnet-ransomware-2024-2874 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 583ceef2-ca2c-5809-9207-a52beb88a3a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
