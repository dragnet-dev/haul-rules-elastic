// Dragnet [Ransomware]: dragnet-ransomware-2024-3039 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 4e2d6a34-9a6e-502a-a5a5-1843492fdfa9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
