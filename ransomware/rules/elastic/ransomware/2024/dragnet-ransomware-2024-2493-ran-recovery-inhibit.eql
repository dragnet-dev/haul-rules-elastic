// Dragnet [Ransomware]: dragnet-ransomware-2024-2493 — Recovery Inhibition (redransomware)
// Status: deprecated | Level: high | ID: 729c06a9-5cdf-5471-8554-913f32ae5b06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
