// Dragnet [Ransomware]: dragnet-ransomware-2024-0931 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 24589064-6de8-5561-8d82-d8d08385c086

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
