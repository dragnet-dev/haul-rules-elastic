// Dragnet [Ransomware]: dragnet-ransomware-2024-0283 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: fec2ca0c-094a-5ece-ba9d-176d14ff7206

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
