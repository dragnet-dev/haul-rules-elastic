// Dragnet [Ransomware]: dragnet-ransomware-2024-5110 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 7810de54-f3ce-5ee7-a556-23ee83944dce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
