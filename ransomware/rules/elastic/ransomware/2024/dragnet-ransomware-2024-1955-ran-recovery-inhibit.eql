// Dragnet [Ransomware]: dragnet-ransomware-2024-1955 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: bb71163b-78cc-579b-acf4-45c56d188080

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
