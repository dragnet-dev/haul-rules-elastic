// Dragnet [Ransomware]: dragnet-ransomware-2024-4704 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7175b020-348b-5fa2-bb3b-301dda9d24a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
