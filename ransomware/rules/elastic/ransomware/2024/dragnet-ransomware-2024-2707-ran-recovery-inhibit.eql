// Dragnet [Ransomware]: dragnet-ransomware-2024-2707 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2a957b44-a220-5107-8733-66376cbafe67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
