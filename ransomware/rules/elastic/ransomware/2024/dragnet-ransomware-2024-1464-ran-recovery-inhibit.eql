// Dragnet [Ransomware]: dragnet-ransomware-2024-1464 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 3057027d-21eb-52ea-8393-baa5416b1df4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
