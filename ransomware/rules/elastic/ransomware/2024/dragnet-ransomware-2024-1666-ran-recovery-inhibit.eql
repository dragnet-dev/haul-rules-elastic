// Dragnet [Ransomware]: dragnet-ransomware-2024-1666 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 32db1d29-5f45-5f58-90d8-cbc227abab99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
