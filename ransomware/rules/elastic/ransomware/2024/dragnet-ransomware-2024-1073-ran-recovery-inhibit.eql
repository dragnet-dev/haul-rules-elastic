// Dragnet [Ransomware]: dragnet-ransomware-2024-1073 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 00253933-b592-5c18-87f0-56544e6816ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
