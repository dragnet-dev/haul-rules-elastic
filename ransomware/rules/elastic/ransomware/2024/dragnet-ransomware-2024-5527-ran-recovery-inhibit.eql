// Dragnet [Ransomware]: dragnet-ransomware-2024-5527 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 9d84a99d-eb60-5ae5-8c58-c3564fe01d94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
