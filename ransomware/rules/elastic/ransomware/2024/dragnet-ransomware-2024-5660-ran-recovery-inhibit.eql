// Dragnet [Ransomware]: dragnet-ransomware-2024-5660 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4105478e-7acf-52a8-9d02-fc5f7c1ceaac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
