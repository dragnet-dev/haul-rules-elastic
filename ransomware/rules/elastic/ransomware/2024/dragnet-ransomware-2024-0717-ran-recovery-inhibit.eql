// Dragnet [Ransomware]: dragnet-ransomware-2024-0717 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 4163ed11-e177-5d6d-8bd2-5d2166975422

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
