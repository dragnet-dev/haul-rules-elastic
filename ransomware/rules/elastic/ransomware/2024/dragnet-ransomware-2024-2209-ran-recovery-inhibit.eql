// Dragnet [Ransomware]: dragnet-ransomware-2024-2209 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f0edadf4-5de5-5be2-89b3-0987b5820cc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
