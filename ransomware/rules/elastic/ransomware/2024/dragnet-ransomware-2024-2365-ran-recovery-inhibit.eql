// Dragnet [Ransomware]: dragnet-ransomware-2024-2365 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: a42a84a3-f124-58cf-adb8-e5a9c8afb3f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
