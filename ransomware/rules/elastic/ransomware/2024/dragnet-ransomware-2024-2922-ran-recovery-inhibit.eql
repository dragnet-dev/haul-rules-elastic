// Dragnet [Ransomware]: dragnet-ransomware-2024-2922 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 997ccb31-6892-5beb-be2d-b6dcbe9e18d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
