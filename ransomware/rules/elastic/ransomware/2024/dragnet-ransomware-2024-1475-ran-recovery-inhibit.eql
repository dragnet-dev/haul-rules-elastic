// Dragnet [Ransomware]: dragnet-ransomware-2024-1475 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 6bab30d2-03aa-508f-b89b-f4d35d929e87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
