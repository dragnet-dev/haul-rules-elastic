// Dragnet [Ransomware]: dragnet-ransomware-2024-4131 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: 6d734344-8fd3-5435-a54b-8b722dce5997

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
