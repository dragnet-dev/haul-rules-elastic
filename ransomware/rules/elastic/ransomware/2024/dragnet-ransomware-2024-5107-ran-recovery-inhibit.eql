// Dragnet [Ransomware]: dragnet-ransomware-2024-5107 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: df349522-4c14-5500-8c63-887c57cadd9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
