// Dragnet [Ransomware]: dragnet-ransomware-2024-1813 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 02488e95-bd7b-54c9-bd6e-6238bc5df4f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
