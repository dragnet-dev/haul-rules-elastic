// Dragnet [Ransomware]: dragnet-ransomware-2024-4027 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: a3357aaa-7e38-59a7-b294-b65ebb1c941e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
