// Dragnet [Ransomware]: dragnet-ransomware-2024-3320 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 1524f5ae-0bc8-58a7-81a1-db4068293d21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
