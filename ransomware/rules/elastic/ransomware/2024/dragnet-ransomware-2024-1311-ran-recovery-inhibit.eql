// Dragnet [Ransomware]: dragnet-ransomware-2024-1311 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 630ecc4f-b174-50e2-a494-d363e8d0861c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
