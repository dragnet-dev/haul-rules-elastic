// Dragnet [Ransomware]: dragnet-ransomware-2024-5091 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: e4cd896c-8a74-5cf3-a5c9-6f2a162866d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
