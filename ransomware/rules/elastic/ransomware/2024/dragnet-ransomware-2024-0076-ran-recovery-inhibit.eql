// Dragnet [Ransomware]: dragnet-ransomware-2024-0076 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 59d0efe0-7867-55b1-915e-d79304e010fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
