// Dragnet [Ransomware]: dragnet-ransomware-2024-3793 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 1a5117cd-7418-531d-a97a-a6103531fba2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
