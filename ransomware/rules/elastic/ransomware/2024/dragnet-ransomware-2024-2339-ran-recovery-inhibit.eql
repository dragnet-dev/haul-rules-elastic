// Dragnet [Ransomware]: dragnet-ransomware-2024-2339 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 772fbdfe-e29c-56f6-859b-0c1881ffd82b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
