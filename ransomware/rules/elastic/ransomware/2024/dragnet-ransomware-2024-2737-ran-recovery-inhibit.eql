// Dragnet [Ransomware]: dragnet-ransomware-2024-2737 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 94b60a41-09d7-5dee-88b1-53c100f590c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
