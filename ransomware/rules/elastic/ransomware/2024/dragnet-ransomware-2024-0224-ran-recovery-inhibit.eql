// Dragnet [Ransomware]: dragnet-ransomware-2024-0224 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: c95f7b46-5df6-5e3f-b422-b7144bae8032

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
