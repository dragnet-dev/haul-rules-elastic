// Dragnet [Ransomware]: dragnet-ransomware-2024-5856 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 6c48d32e-afa4-51ac-b226-202bc5c02219

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
