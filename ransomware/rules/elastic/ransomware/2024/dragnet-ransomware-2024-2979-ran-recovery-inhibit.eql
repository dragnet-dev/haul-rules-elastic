// Dragnet [Ransomware]: dragnet-ransomware-2024-2979 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 92f1cec5-e441-5c62-b171-067050c0987a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
