// Dragnet [Ransomware]: dragnet-ransomware-2024-2987 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: bcca08fb-2668-54d5-aa7c-fa36951b163e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
