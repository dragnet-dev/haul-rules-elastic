// Dragnet [Ransomware]: dragnet-ransomware-2024-1001 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f7a1eda9-bd15-57cd-94e1-a662d4f3f4da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
