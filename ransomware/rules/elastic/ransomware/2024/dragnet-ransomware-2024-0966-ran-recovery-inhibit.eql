// Dragnet [Ransomware]: dragnet-ransomware-2024-0966 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 4a1c3be2-d24a-5d66-86f9-0133c6d431f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
