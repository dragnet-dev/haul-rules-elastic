// Dragnet [Ransomware]: dragnet-ransomware-2024-3528 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 587376f7-341e-5861-a77a-61112960242d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
