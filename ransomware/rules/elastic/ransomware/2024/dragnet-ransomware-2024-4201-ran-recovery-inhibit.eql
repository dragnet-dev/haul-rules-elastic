// Dragnet [Ransomware]: dragnet-ransomware-2024-4201 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: 6eec41bd-7e8f-568e-85e9-ecefe90dc781

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
