// Dragnet [Ransomware]: dragnet-ransomware-2024-1555 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e00bbf98-93a7-5bff-9201-687be2c3ad44

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
