// Dragnet [Ransomware]: dragnet-ransomware-2024-5388 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: d506f32b-4c73-5dae-bace-2f5be06f613b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
