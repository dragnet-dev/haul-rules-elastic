// Dragnet [Ransomware]: dragnet-ransomware-2024-0401 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 687cb1ab-9328-5598-81f8-031d877fe138

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
