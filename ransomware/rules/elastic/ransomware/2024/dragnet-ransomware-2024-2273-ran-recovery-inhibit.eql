// Dragnet [Ransomware]: dragnet-ransomware-2024-2273 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: d984a4d3-c8c6-5315-b1a5-ddad8e1373a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
