// Dragnet [Ransomware]: dragnet-ransomware-2024-1177 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 56351b3b-23b2-505a-9036-6357c246386d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
