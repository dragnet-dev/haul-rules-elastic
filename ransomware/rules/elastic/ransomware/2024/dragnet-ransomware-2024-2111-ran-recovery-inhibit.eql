// Dragnet [Ransomware]: dragnet-ransomware-2024-2111 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 290a94a8-4aa0-552a-bfdb-757169ed88a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
