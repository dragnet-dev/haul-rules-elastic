// Dragnet [Ransomware]: dragnet-ransomware-2024-1484 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 8d798e6c-bfc5-5f59-a2e4-00b9814284ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
