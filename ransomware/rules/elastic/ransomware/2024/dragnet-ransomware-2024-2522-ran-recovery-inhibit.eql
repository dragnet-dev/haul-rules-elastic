// Dragnet [Ransomware]: dragnet-ransomware-2024-2522 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: a19ef5ae-a208-5d8b-b76f-e3851a8551b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
