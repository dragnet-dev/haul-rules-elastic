// Dragnet [Ransomware]: dragnet-ransomware-2024-4942 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: abd77d91-2c8b-54c8-acc4-8c2b0f8e6cd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
