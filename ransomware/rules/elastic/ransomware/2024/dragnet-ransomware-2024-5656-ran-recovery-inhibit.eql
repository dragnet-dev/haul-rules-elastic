// Dragnet [Ransomware]: dragnet-ransomware-2024-5656 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: d615017d-100e-5be6-a141-576d7dab9bdd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
