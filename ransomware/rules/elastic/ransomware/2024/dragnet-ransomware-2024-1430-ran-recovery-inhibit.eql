// Dragnet [Ransomware]: dragnet-ransomware-2024-1430 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 78d75137-8084-5c55-9e8f-df8b0dc577fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
