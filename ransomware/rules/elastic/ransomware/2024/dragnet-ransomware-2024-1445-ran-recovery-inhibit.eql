// Dragnet [Ransomware]: dragnet-ransomware-2024-1445 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 7d293a2a-5a35-55de-84a8-c996cce47d21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
