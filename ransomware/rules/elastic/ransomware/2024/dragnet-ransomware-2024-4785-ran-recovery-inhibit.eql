// Dragnet [Ransomware]: dragnet-ransomware-2024-4785 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0668ecb8-d0a5-5217-8233-36c16fd4d035

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
