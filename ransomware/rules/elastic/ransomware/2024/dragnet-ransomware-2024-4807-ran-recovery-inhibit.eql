// Dragnet [Ransomware]: dragnet-ransomware-2024-4807 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 5e12d7d7-4eb1-52e5-9eeb-b8ee5624cefd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
