// Dragnet [Ransomware]: dragnet-ransomware-2024-3761 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 4c76f964-66b6-572f-b467-732de3173337

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
