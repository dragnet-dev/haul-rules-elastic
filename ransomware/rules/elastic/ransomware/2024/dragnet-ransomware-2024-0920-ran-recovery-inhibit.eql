// Dragnet [Ransomware]: dragnet-ransomware-2024-0920 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b22a6bdd-b22d-5f0a-856a-88bebc283dbd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
