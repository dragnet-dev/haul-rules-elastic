// Dragnet [Ransomware]: dragnet-ransomware-2024-4679 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c80edb57-d12c-53e2-b6f8-f4a7df74221c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
