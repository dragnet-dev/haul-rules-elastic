// Dragnet [Ransomware]: dragnet-ransomware-2024-3391 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2e7da66d-8af3-57c1-ae57-6997c0268a0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
