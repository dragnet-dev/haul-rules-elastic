// Dragnet [Ransomware]: dragnet-ransomware-2024-2462 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: fa60bf70-92c4-5639-a6af-14b8f291c068

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
