// Dragnet [Ransomware]: dragnet-ransomware-2024-2313 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 38509816-29a5-526e-b62c-a1e7419f99c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
