// Dragnet [Ransomware]: dragnet-ransomware-2024-2137 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 216bce53-1bc2-5f00-b694-9c2936221a74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
