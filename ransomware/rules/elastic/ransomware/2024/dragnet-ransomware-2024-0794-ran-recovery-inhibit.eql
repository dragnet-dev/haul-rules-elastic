// Dragnet [Ransomware]: dragnet-ransomware-2024-0794 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0fb6a8a5-d309-53d2-b4fc-66171ea41227

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
