// Dragnet [Ransomware]: dragnet-ransomware-2024-3294 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c071a570-39a6-527d-a74e-5bfc05b3849a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
