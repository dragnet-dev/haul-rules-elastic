// Dragnet [Ransomware]: dragnet-ransomware-2024-5114 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 14eed122-43ba-5bc1-b3b0-c1f02d8afdce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
