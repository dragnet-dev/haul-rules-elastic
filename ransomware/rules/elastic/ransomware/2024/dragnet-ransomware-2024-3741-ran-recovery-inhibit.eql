// Dragnet [Ransomware]: dragnet-ransomware-2024-3741 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 69707950-8b39-503a-8c04-45794931c49c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
