// Dragnet [Ransomware]: dragnet-ransomware-2024-4310 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 57065997-e067-552d-bfa7-d4c147089216

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
