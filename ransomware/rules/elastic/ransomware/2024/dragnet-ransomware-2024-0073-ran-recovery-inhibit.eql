// Dragnet [Ransomware]: dragnet-ransomware-2024-0073 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1f39b67b-7f73-5d8b-ba62-586e491b76e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
