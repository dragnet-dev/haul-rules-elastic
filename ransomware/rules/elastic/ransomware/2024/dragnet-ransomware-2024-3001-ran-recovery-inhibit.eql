// Dragnet [Ransomware]: dragnet-ransomware-2024-3001 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 42235cb0-fcdd-5044-9dc2-2efdf99aa495

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
