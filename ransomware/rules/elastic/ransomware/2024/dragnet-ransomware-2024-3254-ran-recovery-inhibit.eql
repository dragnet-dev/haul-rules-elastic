// Dragnet [Ransomware]: dragnet-ransomware-2024-3254 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 39e6ab71-09c7-5238-ba43-4d8934d8e5b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
