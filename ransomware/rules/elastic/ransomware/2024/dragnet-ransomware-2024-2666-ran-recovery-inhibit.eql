// Dragnet [Ransomware]: dragnet-ransomware-2024-2666 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b5151b54-5807-51a7-ad2b-5dc302469701

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
