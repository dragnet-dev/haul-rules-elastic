// Dragnet [Ransomware]: dragnet-ransomware-2024-3102 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 1fee98f5-53e0-54be-b24c-c6daf62c329b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
