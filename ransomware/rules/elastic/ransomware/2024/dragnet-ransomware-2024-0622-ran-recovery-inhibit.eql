// Dragnet [Ransomware]: dragnet-ransomware-2024-0622 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b913a8cb-79b7-510f-95e8-69174368a8fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
