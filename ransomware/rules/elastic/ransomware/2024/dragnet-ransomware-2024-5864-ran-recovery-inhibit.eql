// Dragnet [Ransomware]: dragnet-ransomware-2024-5864 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 5f1b5f4d-0709-58e2-addb-b6214e3241a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
