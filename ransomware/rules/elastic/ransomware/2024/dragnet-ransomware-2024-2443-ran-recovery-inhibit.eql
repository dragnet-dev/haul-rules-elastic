// Dragnet [Ransomware]: dragnet-ransomware-2024-2443 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 5f2272e4-e7f0-541c-94bc-959ec630ce1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
