// Dragnet [Ransomware]: dragnet-ransomware-2024-3072 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: edd239a5-fbec-57bf-9bc2-ff84ffbe17f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
