// Dragnet [Ransomware]: dragnet-ransomware-2024-3680 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 6b79c652-c39e-58cf-a1c9-be5430021a92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
