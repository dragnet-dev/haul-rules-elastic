// Dragnet [Ransomware]: dragnet-ransomware-2024-0110 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: dd98212b-f30d-5e8a-aef0-21fe006ff271

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
