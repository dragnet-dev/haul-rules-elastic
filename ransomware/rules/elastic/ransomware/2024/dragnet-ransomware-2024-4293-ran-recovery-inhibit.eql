// Dragnet [Ransomware]: dragnet-ransomware-2024-4293 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 90cdbd35-9b48-59b9-9039-5aac7d702ba1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
