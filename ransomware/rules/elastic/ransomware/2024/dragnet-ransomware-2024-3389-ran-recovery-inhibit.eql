// Dragnet [Ransomware]: dragnet-ransomware-2024-3389 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 9695b03a-ff02-5167-8fee-284cf35bff56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
