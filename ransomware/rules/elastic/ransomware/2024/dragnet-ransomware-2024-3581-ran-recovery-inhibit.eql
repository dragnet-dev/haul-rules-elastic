// Dragnet [Ransomware]: dragnet-ransomware-2024-3581 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: efe181bb-cb3a-514a-8088-b67504594729

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
