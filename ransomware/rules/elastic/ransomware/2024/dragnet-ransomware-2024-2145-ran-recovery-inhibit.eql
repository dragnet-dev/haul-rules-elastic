// Dragnet [Ransomware]: dragnet-ransomware-2024-2145 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 097e1687-4909-5e91-a8fe-04b819d1a2c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
