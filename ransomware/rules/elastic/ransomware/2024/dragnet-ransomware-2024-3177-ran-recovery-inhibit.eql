// Dragnet [Ransomware]: dragnet-ransomware-2024-3177 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 525f14c5-7db0-5fa9-b095-a7ea721fface

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
