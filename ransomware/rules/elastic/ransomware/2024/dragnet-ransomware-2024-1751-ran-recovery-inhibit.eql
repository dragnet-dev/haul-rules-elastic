// Dragnet [Ransomware]: dragnet-ransomware-2024-1751 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: af98bb00-9869-57dc-abc9-5777cfdcb29f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
