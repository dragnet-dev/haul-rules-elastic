// Dragnet [Ransomware]: dragnet-ransomware-2024-2637 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 5857dbae-7a79-5b3a-939d-642ba6cd25cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
