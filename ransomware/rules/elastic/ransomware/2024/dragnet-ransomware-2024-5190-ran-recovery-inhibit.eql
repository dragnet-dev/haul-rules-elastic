// Dragnet [Ransomware]: dragnet-ransomware-2024-5190 — Recovery Inhibition (underground)
// Status: experimental | Level: high | ID: f91fdd90-5a26-5c17-9475-41d31e9bd467

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
