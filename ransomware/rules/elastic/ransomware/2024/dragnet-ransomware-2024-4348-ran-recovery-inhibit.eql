// Dragnet [Ransomware]: dragnet-ransomware-2024-4348 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0ca1a969-4557-5891-8c52-b250ff080f48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
