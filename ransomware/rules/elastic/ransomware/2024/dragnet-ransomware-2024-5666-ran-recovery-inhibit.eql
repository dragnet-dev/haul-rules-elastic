// Dragnet [Ransomware]: dragnet-ransomware-2024-5666 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 2451113a-2ff3-52ed-885d-005222133cb2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
