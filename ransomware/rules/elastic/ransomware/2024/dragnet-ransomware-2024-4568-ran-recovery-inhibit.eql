// Dragnet [Ransomware]: dragnet-ransomware-2024-4568 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 10d540c8-a32d-57f2-8d11-73a58d693f4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
