// Dragnet [Ransomware]: dragnet-ransomware-2024-1166 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a2f2899e-d67e-5cff-bab4-2211da961dc3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
