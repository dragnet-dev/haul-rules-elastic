// Dragnet [Ransomware]: dragnet-ransomware-2024-0823 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: c7921157-efd1-5636-a33f-4f692e26f388

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
