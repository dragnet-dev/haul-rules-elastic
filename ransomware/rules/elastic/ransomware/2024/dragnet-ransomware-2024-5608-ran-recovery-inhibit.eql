// Dragnet [Ransomware]: dragnet-ransomware-2024-5608 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: a491a4fa-da7a-5460-bc67-8b1a5d755af9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
