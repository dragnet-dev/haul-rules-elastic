// Dragnet [Ransomware]: dragnet-ransomware-2024-4691 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: bf1eaad6-1669-5dde-8254-eb95046bfb30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
