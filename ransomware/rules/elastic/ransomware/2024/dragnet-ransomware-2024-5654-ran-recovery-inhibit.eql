// Dragnet [Ransomware]: dragnet-ransomware-2024-5654 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 8e41db9c-97a9-57ec-92cb-421919c8385f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
