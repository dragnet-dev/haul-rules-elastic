// Dragnet [Ransomware]: dragnet-ransomware-2024-1559 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 99d3114a-ebce-56fc-8ca5-bf667e528485

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
