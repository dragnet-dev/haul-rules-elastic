// Dragnet [Ransomware]: dragnet-ransomware-2024-1312 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 88f9cfa3-9abd-520a-afe8-d9688cbeabb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
