// Dragnet [Ransomware]: dragnet-ransomware-2024-2220 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 6c707b53-f20b-5cb1-a67c-0a13e9bced4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
