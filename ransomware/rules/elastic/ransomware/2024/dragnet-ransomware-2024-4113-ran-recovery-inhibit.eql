// Dragnet [Ransomware]: dragnet-ransomware-2024-4113 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 5d907184-2e01-5d46-9d96-6669d721ffd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
