// Dragnet [Ransomware]: dragnet-ransomware-2024-0973 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 5ce7bcce-512f-543d-a2eb-719d994010ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
