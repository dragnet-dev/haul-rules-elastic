// Dragnet [Ransomware]: dragnet-ransomware-2024-3049 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 5c3d771c-b552-5219-99a8-93e48b79df06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
