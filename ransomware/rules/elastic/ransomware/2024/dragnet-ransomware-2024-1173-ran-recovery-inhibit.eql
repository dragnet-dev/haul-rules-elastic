// Dragnet [Ransomware]: dragnet-ransomware-2024-1173 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1306d057-0d35-5c2f-ba75-95bd64bab58e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
