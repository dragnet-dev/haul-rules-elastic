// Dragnet [Ransomware]: dragnet-ransomware-2024-3645 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1c030761-2204-519c-bceb-0892ee507205

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
