// Dragnet [Ransomware]: dragnet-ransomware-2024-4862 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3df2cd01-c3c3-5554-82f0-1aa6d2ee1fd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
