// Dragnet [Ransomware]: dragnet-ransomware-2024-4974 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 7a05263b-a703-5576-a588-761fa622d3db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
