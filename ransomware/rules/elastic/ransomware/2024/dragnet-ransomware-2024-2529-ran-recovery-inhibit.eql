// Dragnet [Ransomware]: dragnet-ransomware-2024-2529 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 4b72a3d2-bb88-50f5-a52b-5a7f4f793c3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
