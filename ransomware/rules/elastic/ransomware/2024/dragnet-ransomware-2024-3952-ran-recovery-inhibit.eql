// Dragnet [Ransomware]: dragnet-ransomware-2024-3952 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1660de79-1668-5d21-bcfe-a587ac646cad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
