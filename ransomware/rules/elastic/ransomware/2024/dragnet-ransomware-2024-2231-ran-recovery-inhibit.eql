// Dragnet [Ransomware]: dragnet-ransomware-2024-2231 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 18934b39-0d1f-5702-bd41-22237d8643f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
