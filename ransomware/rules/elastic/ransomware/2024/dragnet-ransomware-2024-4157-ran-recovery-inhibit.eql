// Dragnet [Ransomware]: dragnet-ransomware-2024-4157 — Recovery Inhibition (werewolves)
// Status: experimental | Level: high | ID: dc2c2a4b-dd8c-50ce-9b8c-fa4baf04ccb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
