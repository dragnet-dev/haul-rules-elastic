// Dragnet [Ransomware]: dragnet-ransomware-2024-2393 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 21572a31-4e95-5955-8c85-910e028594d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
