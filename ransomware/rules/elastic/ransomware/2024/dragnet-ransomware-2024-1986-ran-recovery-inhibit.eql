// Dragnet [Ransomware]: dragnet-ransomware-2024-1986 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f1a9c7d1-63ac-503f-bb19-7b8c3b49e907

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
