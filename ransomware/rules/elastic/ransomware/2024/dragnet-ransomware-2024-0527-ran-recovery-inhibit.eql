// Dragnet [Ransomware]: dragnet-ransomware-2024-0527 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: e967a88e-6b71-52bd-b713-26b76af319a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
