// Dragnet [Ransomware]: dragnet-ransomware-2024-1896 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 76b58069-f4c4-5ed8-a2c4-db7fb3343df5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
