// Dragnet [Ransomware]: dragnet-ransomware-2024-1024 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: d66925c7-7783-5be8-bf54-06978dd5de17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
