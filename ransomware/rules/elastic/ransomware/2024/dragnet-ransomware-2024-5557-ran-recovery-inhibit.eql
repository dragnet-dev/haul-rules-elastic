// Dragnet [Ransomware]: dragnet-ransomware-2024-5557 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2d9ce8e4-f1c7-53c4-8c70-dda6062c737f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
