// Dragnet [Ransomware]: dragnet-ransomware-2024-0062 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: f66b1c93-323a-546c-bb00-995f52659b66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
