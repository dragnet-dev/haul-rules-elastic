// Dragnet [Ransomware]: dragnet-ransomware-2024-4332 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d375a9a6-a21d-5aa9-9106-6e30925edcef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
