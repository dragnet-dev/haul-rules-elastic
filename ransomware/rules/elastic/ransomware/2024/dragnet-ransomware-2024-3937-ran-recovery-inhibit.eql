// Dragnet [Ransomware]: dragnet-ransomware-2024-3937 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 29fc1a9b-46ca-5f1a-83dd-8d6ca55312a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
