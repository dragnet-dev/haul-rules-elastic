// Dragnet [Ransomware]: dragnet-ransomware-2024-0673 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 6e8f5036-5be3-51e7-88df-ef81cf2b49ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
