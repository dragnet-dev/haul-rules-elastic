// Dragnet [Ransomware]: dragnet-ransomware-2024-2711 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: 49710805-d8d5-595b-a5fd-0ed3e0417b43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
