// Dragnet [Ransomware]: dragnet-ransomware-2024-3083 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 95c408d2-c418-5afb-8453-f53a8d0235e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
