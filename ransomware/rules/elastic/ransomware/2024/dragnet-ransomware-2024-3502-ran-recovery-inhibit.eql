// Dragnet [Ransomware]: dragnet-ransomware-2024-3502 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 98a064ab-eef3-5cfa-ad62-b5633d068836

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
