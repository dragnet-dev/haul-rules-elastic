// Dragnet [Ransomware]: dragnet-ransomware-2024-2546 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 8c34fe9d-20eb-50dc-8696-3508356397ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
