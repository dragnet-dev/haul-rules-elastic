// Dragnet [Ransomware]: dragnet-ransomware-2024-3737 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: bdcd2296-6c0e-564d-8ddc-5b1c404fba56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
