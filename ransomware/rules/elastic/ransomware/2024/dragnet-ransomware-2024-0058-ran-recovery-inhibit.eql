// Dragnet [Ransomware]: dragnet-ransomware-2024-0058 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 02cd3a8d-cd01-56f6-972c-dabff85e2751

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
