// Dragnet [Ransomware]: dragnet-ransomware-2024-4026 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 7ba8fe9a-ddca-5dea-9553-d85109bd8cc0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
