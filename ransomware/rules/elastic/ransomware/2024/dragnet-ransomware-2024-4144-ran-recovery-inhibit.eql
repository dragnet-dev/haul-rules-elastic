// Dragnet [Ransomware]: dragnet-ransomware-2024-4144 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 64aac7ad-7687-5e79-ba8a-310a9b212249

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
