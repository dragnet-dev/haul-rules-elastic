// Dragnet [Ransomware]: dragnet-ransomware-2024-0617 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: 5fc4d889-e33d-529e-8c94-598f3a42c39d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
