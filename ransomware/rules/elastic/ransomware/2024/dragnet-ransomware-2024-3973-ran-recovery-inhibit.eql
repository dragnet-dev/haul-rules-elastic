// Dragnet [Ransomware]: dragnet-ransomware-2024-3973 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9781bebf-1b74-5e1f-9240-a21fd629d11a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
