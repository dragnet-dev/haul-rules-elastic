// Dragnet [Ransomware]: dragnet-ransomware-2024-4759 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b1c59547-367a-55d9-9527-bc5f2c98b154

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
