// Dragnet [Ransomware]: dragnet-ransomware-2024-1352 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 17f94881-0280-5f33-8386-9699b959f49b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
