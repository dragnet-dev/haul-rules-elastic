// Dragnet [Ransomware]: dragnet-ransomware-2024-5599 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 57294c42-0685-54e6-bd83-a1035f312aa8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
