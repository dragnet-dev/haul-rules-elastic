// Dragnet [Ransomware]: dragnet-ransomware-2024-0312 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 0946a8db-9c74-5fca-a9f3-06007727dd81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
