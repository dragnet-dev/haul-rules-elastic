// Dragnet [Ransomware]: dragnet-ransomware-2024-0657 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: af9453bd-7598-5833-9b36-a95b2357415d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
