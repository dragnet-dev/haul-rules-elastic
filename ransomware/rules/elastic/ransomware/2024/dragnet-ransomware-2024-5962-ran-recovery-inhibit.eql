// Dragnet [Ransomware]: dragnet-ransomware-2024-5962 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: f5933dab-40f5-557b-8721-d88942158bd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
