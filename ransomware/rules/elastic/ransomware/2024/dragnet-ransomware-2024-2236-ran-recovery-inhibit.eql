// Dragnet [Ransomware]: dragnet-ransomware-2024-2236 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 22a3d643-0739-53c1-bcce-da5c7fbe1d24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
