// Dragnet [Ransomware]: dragnet-ransomware-2024-4372 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: b7fb8498-9c63-55b5-9f70-7b3a60a7d85e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
