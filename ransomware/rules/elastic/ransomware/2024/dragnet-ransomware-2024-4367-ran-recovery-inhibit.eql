// Dragnet [Ransomware]: dragnet-ransomware-2024-4367 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: a518ac5e-093f-5c04-aacb-09c75b742ab5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
