// Dragnet [Ransomware]: dragnet-ransomware-2024-1181 — Recovery Inhibition (trinity)
// Status: experimental | Level: high | ID: 9a1a8ba7-d073-5438-bd24-c044c5302629

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
