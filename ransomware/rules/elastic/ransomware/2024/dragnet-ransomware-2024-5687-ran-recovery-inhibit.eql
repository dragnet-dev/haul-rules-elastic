// Dragnet [Ransomware]: dragnet-ransomware-2024-5687 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 40415265-7f27-5ffc-b3b4-4d828aa9cdd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
