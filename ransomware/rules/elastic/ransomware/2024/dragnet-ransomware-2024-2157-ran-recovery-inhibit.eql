// Dragnet [Ransomware]: dragnet-ransomware-2024-2157 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 80678aa9-41bc-5e9b-89b1-6ce3cdf75861

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
