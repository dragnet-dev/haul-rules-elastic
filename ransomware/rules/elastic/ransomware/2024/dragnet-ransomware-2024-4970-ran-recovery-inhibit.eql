// Dragnet [Ransomware]: dragnet-ransomware-2024-4970 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: a47bf772-d724-5d4b-8db3-8ca0f9df1d6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
