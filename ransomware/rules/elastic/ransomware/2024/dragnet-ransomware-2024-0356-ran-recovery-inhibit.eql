// Dragnet [Ransomware]: dragnet-ransomware-2024-0356 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: c756962d-9813-50e8-9c26-8feab75ae87e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
