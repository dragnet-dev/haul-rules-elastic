// Dragnet [Ransomware]: dragnet-ransomware-2024-0396 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 2b3b99c3-4bd5-5150-aabf-3cd137782058

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
