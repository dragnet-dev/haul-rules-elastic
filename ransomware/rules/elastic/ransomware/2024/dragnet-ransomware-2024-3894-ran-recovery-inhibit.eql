// Dragnet [Ransomware]: dragnet-ransomware-2024-3894 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 259ab859-7ee1-5589-b315-1efc612ed3d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
