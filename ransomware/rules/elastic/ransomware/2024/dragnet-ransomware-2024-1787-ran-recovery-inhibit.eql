// Dragnet [Ransomware]: dragnet-ransomware-2024-1787 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a7652106-e070-5deb-846a-adbddcbbb23d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
