// Dragnet [Ransomware]: dragnet-ransomware-2024-3071 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f0adb0fb-2f8f-5d8f-8380-0fd409687a99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
