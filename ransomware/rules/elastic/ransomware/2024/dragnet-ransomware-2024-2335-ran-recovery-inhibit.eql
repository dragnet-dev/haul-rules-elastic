// Dragnet [Ransomware]: dragnet-ransomware-2024-2335 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: cad3d889-533b-5664-ba9f-a0a734a7eb16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
