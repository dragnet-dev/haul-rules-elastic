// Dragnet [Ransomware]: dragnet-ransomware-2024-0964 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f000e32a-8d56-5147-b024-6645f9647dcd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
