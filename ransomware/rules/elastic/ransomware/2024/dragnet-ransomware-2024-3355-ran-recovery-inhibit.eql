// Dragnet [Ransomware]: dragnet-ransomware-2024-3355 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 17f3ad51-e342-55c8-8008-d5c1c4402702

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
