// Dragnet [Ransomware]: dragnet-ransomware-2024-5105 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 66396ce8-516e-5306-9913-fed7068ca6a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
