// Dragnet [Ransomware]: dragnet-ransomware-2024-4309 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 84b51768-55b4-56d1-8d00-5f0583e4fa44

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
