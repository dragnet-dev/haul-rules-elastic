// Dragnet [Ransomware]: dragnet-ransomware-2024-0196 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: b4830483-af9e-528a-8844-f8c6bec3d3bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
