// Dragnet [Ransomware]: dragnet-ransomware-2024-3860 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 926582b7-b7eb-55ea-8caa-3055c4bf6b81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
