// Dragnet [Ransomware]: dragnet-ransomware-2024-5533 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 49046268-6201-5b9f-9508-fd4b028ad052

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
