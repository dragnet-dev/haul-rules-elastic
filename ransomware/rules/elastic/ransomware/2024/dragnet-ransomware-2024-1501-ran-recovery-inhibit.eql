// Dragnet [Ransomware]: dragnet-ransomware-2024-1501 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 836c9080-4fb4-5189-a344-9850e45f23fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
