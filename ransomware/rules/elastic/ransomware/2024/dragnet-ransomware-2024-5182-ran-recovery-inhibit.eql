// Dragnet [Ransomware]: dragnet-ransomware-2024-5182 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 89766276-d728-590c-b91a-9e20ae9773d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
