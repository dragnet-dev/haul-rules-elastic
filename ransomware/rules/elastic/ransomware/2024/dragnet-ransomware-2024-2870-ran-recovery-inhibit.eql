// Dragnet [Ransomware]: dragnet-ransomware-2024-2870 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 2b5f8e93-235f-52f2-913b-2228ec7e2896

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
