// Dragnet [Ransomware]: dragnet-ransomware-2024-5439 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 49809e73-a16f-5086-a1b9-ef0bce826005

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
