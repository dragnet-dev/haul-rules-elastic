// Dragnet [Ransomware]: dragnet-ransomware-2024-1044 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 6645281a-cda8-5993-85e7-5be65d2a114e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
