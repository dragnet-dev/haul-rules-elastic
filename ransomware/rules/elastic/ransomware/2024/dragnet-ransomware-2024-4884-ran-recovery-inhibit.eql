// Dragnet [Ransomware]: dragnet-ransomware-2024-4884 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 70e650e6-4eba-5c02-b1c5-3c970e8a7d82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
