// Dragnet [Ransomware]: dragnet-ransomware-2024-0183 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: e290705b-0517-58c9-9f70-6b073566fe20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
