// Dragnet [Ransomware]: dragnet-ransomware-2024-0524 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d4420bdd-d2f5-5d2c-bf53-06710b70d89e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
