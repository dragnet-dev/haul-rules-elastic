// Dragnet [Ransomware]: dragnet-ransomware-2024-3797 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 05de1604-769b-51ac-90bf-18d65a99697b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
