// Dragnet [Ransomware]: dragnet-ransomware-2024-2029 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 5712fcbc-742f-543c-836c-e4f89d0c9ba6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
