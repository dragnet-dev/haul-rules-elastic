// Dragnet [Ransomware]: dragnet-ransomware-2024-2688 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 596563d8-5a23-51d2-bd05-ceb3b727ff4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
