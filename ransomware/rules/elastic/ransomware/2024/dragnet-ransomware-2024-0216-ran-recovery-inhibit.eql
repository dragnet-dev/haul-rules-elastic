// Dragnet [Ransomware]: dragnet-ransomware-2024-0216 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 27cbc51b-1746-5c80-8dfc-4447123489c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
