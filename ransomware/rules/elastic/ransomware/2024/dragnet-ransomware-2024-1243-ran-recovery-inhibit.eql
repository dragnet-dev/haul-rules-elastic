// Dragnet [Ransomware]: dragnet-ransomware-2024-1243 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 427086ee-c294-55dc-b6ac-805644baeeeb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
