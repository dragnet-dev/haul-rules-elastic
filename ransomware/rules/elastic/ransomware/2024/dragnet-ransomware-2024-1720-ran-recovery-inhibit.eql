// Dragnet [Ransomware]: dragnet-ransomware-2024-1720 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 87b23f44-49db-53f7-8a4e-3152c94c3b17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
