// Dragnet [Ransomware]: dragnet-ransomware-2024-3694 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 860fc3f3-adb4-5928-9091-1d00ecfd762e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
