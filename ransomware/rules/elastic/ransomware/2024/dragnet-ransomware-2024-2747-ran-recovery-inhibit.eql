// Dragnet [Ransomware]: dragnet-ransomware-2024-2747 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: aaa34a32-12f3-50bc-807e-19077573c9ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
