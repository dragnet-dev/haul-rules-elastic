// Dragnet [Ransomware]: dragnet-ransomware-2024-3465 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a130a78d-244b-5066-a79f-a973594a8acd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
