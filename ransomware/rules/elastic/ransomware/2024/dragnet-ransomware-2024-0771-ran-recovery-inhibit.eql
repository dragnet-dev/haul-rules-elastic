// Dragnet [Ransomware]: dragnet-ransomware-2024-0771 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 248cd194-2240-57a7-a12a-f21358460a6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
