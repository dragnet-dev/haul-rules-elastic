// Dragnet [Ransomware]: dragnet-ransomware-2024-1386 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: e2642e7b-a70f-5241-b12c-fb070cbaf98a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
