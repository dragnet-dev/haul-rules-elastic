// Dragnet [Ransomware]: dragnet-ransomware-2024-2460 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: a23d3e26-027f-5517-8dae-1f330aa8c7f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
