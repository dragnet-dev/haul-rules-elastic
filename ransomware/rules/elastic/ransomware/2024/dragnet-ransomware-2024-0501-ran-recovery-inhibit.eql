// Dragnet [Ransomware]: dragnet-ransomware-2024-0501 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 78007d15-6cd8-5654-9ed4-a24f57b50fec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
