// Dragnet [Ransomware]: dragnet-ransomware-2024-3533 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 3d4414aa-f10c-5b3b-a2c2-19b680c65fba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
