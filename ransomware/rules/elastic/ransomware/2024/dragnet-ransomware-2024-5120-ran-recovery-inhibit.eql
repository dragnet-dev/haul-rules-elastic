// Dragnet [Ransomware]: dragnet-ransomware-2024-5120 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 956eefbe-c3af-5069-8fbd-819e6a74c25a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
