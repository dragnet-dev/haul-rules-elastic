// Dragnet [Ransomware]: dragnet-ransomware-2024-0843 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 68ff2caa-ba62-5db8-877d-c7706adffb07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
