// Dragnet [Ransomware]: dragnet-ransomware-2024-5748 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 838fb2c9-778e-501a-892e-12360b5bcae2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
