// Dragnet [Ransomware]: dragnet-ransomware-2024-3578 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: ee99c271-29ab-577f-9b66-5100d96ae647

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
