// Dragnet [Ransomware]: dragnet-ransomware-2024-3510 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: ada95159-aa58-5f72-a745-ac9102932508

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
