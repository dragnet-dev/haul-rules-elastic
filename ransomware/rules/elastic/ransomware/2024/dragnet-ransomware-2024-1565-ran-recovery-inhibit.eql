// Dragnet [Ransomware]: dragnet-ransomware-2024-1565 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: 39d8cd61-8768-5eb9-8926-dbb5aa4f574e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
