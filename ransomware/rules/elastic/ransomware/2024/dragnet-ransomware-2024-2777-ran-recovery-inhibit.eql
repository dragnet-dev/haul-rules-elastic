// Dragnet [Ransomware]: dragnet-ransomware-2024-2777 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 444d2199-ff72-5347-855e-8a292467d7d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
