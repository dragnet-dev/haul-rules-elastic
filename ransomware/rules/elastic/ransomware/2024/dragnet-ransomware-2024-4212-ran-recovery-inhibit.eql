// Dragnet [Ransomware]: dragnet-ransomware-2024-4212 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9a49ba12-15a6-5b54-a75a-5ff2bc525f8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
