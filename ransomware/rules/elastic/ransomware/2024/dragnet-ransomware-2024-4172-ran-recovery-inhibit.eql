// Dragnet [Ransomware]: dragnet-ransomware-2024-4172 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: a96d8496-27a5-53cd-bfae-fc152cfbe46b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
