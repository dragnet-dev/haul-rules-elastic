// Dragnet [Ransomware]: dragnet-ransomware-2024-0309 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a733db8a-2584-5b6b-b76b-f35b69526553

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
