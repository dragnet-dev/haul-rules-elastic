// Dragnet [Ransomware]: dragnet-ransomware-2024-5052 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 8110cac9-a8b8-55a0-8888-3162ff6af30f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
