// Dragnet [Ransomware]: dragnet-ransomware-2024-4801 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: ab5d1cd1-55ad-52f9-8071-33138dc8e97c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
