// Dragnet [Ransomware]: dragnet-ransomware-2024-3319 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: d0f7f2cd-72e7-5043-8370-1aefbefcf36d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
