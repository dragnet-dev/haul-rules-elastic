// Dragnet [Ransomware]: dragnet-ransomware-2024-4609 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: 2ce21451-6a11-5eeb-b43f-1898138e292d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
