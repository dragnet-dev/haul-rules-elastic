// Dragnet [Ransomware]: dragnet-ransomware-2024-5540 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 10c9b7f4-d524-50e7-8b5e-7aeea40c3065

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
