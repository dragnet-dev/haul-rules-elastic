// Dragnet [Ransomware]: dragnet-ransomware-2024-2451 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 491d07c6-0dab-5cb8-80a9-40f32b602a9c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
