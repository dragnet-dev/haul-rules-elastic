// Dragnet [Ransomware]: dragnet-ransomware-2024-5807 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 64642ae1-d81a-5306-a459-9f199797cbdd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
