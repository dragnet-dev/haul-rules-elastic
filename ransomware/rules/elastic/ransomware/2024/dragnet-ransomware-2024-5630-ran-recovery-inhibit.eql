// Dragnet [Ransomware]: dragnet-ransomware-2024-5630 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 789733bf-c9f3-58f0-82e7-1b9b41dc23ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
