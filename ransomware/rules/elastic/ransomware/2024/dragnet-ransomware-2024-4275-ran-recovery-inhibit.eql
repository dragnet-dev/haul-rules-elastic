// Dragnet [Ransomware]: dragnet-ransomware-2024-4275 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: cfbb7ea1-d4a1-5e51-abfe-409fbc237021

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
