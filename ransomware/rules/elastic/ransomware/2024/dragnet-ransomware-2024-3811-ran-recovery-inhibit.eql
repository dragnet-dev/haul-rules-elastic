// Dragnet [Ransomware]: dragnet-ransomware-2024-3811 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2cd0457a-bcc3-5012-a1ae-f7763ae00a65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
