// Dragnet [Ransomware]: dragnet-ransomware-2024-3202 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: 0415072f-fa72-55d8-8cb9-efdd84f05e27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
