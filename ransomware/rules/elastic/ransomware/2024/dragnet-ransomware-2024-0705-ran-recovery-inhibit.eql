// Dragnet [Ransomware]: dragnet-ransomware-2024-0705 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: a9367af9-2309-5937-a270-63a18d77c584

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
