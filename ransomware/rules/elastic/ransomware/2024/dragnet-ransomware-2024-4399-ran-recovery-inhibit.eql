// Dragnet [Ransomware]: dragnet-ransomware-2024-4399 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 9f9cf724-c65d-5388-bf0c-3f4c4c560f97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
