// Dragnet [Ransomware]: dragnet-ransomware-2024-4618 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 35ae0419-874e-54b3-aba2-80aadf54119e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
