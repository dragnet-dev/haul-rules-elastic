// Dragnet [Ransomware]: dragnet-ransomware-2024-5419 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: fbb1cfc0-1131-5f0f-bace-0f15936ad4a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
