// Dragnet [Ransomware]: dragnet-ransomware-2024-2617 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 5d85a780-a0f9-54e4-b8b7-8cc4e592d89e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
