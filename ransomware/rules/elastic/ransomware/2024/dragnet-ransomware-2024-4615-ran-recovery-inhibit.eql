// Dragnet [Ransomware]: dragnet-ransomware-2024-4615 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 4d9e1c02-d6c1-5f39-bd2e-289a4858d654

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
