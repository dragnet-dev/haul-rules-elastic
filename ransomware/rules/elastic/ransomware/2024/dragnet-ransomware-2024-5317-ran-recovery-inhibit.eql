// Dragnet [Ransomware]: dragnet-ransomware-2024-5317 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 8a947a32-877a-5bda-a844-f205e921c53d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
