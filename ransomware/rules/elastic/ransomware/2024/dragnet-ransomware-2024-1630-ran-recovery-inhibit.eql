// Dragnet [Ransomware]: dragnet-ransomware-2024-1630 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 9d3d69db-0a7c-5774-b3de-557d1035d152

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
