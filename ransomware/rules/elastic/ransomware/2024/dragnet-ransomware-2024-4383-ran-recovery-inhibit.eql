// Dragnet [Ransomware]: dragnet-ransomware-2024-4383 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cf3070f4-d908-5112-b552-1ae412a0fd55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
