// Dragnet [Ransomware]: dragnet-ransomware-2024-3269 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 94c0fd35-3562-5653-abc8-f3beff349702

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
