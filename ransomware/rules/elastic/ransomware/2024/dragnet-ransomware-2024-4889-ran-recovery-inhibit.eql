// Dragnet [Ransomware]: dragnet-ransomware-2024-4889 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: cf495638-2c19-5c24-a51e-9564c4a503bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
