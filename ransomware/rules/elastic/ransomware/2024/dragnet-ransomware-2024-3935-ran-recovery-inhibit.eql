// Dragnet [Ransomware]: dragnet-ransomware-2024-3935 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ce090453-1ee2-5e51-9f5e-d818d0efae2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
