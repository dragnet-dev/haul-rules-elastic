// Dragnet [Ransomware]: dragnet-ransomware-2024-0347 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 1be1c6ae-4530-5944-be88-134c1fc10326

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
