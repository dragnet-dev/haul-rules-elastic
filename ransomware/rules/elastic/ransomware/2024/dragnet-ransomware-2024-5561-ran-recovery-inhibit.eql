// Dragnet [Ransomware]: dragnet-ransomware-2024-5561 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 00bf344f-31af-59aa-8853-c6878c7eb25f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
