// Dragnet [Ransomware]: dragnet-ransomware-2024-4454 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 79c27d56-1de3-5d52-903e-6bea5631cf7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
