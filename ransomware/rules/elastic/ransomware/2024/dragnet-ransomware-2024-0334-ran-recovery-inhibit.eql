// Dragnet [Ransomware]: dragnet-ransomware-2024-0334 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 70f3fc4b-b47a-5d36-8677-75d763489f67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
