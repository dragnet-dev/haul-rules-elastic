// Dragnet [Ransomware]: dragnet-ransomware-2024-5850 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8df171bf-6973-5f39-aa3f-687d4e119a0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
