// Dragnet [Ransomware]: dragnet-ransomware-2024-4063 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: bd759c52-2e0a-581b-afd0-e4e05e66a59f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
