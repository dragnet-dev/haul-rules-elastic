// Dragnet [Ransomware]: dragnet-ransomware-2024-5040 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 65536f67-5f91-5a15-881d-81a0803080ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
