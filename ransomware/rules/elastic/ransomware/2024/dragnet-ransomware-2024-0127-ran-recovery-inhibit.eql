// Dragnet [Ransomware]: dragnet-ransomware-2024-0127 — Recovery Inhibition (cloak)
// Status: experimental | Level: high | ID: 6111279c-4d48-543f-8d26-43bca3d23895

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
