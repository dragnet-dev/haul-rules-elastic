// Dragnet [Ransomware]: dragnet-ransomware-2024-4514 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2acc82dd-170e-54f6-8e27-3480b3169104

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
