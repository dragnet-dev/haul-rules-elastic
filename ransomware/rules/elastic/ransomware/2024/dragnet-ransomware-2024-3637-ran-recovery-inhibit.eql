// Dragnet [Ransomware]: dragnet-ransomware-2024-3637 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 1fef059d-300a-5019-a358-4c14ebb7ea28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
