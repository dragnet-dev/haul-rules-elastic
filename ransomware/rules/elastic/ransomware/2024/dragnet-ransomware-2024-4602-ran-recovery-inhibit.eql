// Dragnet [Ransomware]: dragnet-ransomware-2024-4602 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 040ebf89-a4c1-5350-a38c-5bc93cc09198

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
