// Dragnet [Ransomware]: dragnet-ransomware-2024-2926 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: fbd7b05b-9802-5d98-8696-fe66a59500bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
