// Dragnet [Ransomware]: dragnet-ransomware-2024-0744 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7918e583-dea4-521a-92e0-ebb310725da1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
