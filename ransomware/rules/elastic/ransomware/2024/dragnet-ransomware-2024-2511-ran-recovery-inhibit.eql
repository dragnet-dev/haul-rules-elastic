// Dragnet [Ransomware]: dragnet-ransomware-2024-2511 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: cdb31f99-56f5-558b-947c-afc8ce7625c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
