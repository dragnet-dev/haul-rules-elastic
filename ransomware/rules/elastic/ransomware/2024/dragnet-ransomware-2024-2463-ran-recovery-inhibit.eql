// Dragnet [Ransomware]: dragnet-ransomware-2024-2463 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0ebf7182-c99f-5330-b1b3-c33ea0d7993b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
