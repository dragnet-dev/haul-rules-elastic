// Dragnet [Ransomware]: dragnet-ransomware-2024-2739 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 51279a55-b0e9-5856-8697-ec58f9381013

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
