// Dragnet [Ransomware]: dragnet-ransomware-2024-2078 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 5d70bcff-7e4e-53a0-a78a-eca2457c3620

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
