// Dragnet [Ransomware]: dragnet-ransomware-2024-5468 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 9d0d3758-5095-5f0f-8390-a62e27ba9541

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
