// Dragnet [Ransomware]: dragnet-ransomware-2024-5204 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1ac27521-7a04-5384-857f-b4191cd46937

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
