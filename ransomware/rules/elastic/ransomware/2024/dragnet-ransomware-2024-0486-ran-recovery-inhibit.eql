// Dragnet [Ransomware]: dragnet-ransomware-2024-0486 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 32bf62d7-03fa-5eb7-a46d-7b9c52779948

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
