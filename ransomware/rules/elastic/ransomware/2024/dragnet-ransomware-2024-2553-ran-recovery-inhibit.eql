// Dragnet [Ransomware]: dragnet-ransomware-2024-2553 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: f750e4b2-8e6f-51e9-be92-8d674931848f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
