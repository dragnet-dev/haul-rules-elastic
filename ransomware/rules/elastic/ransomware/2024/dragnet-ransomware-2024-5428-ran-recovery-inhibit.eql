// Dragnet [Ransomware]: dragnet-ransomware-2024-5428 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 910814f7-b089-5c44-b04c-d5d32c19803c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
