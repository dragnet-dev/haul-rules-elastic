// Dragnet [Ransomware]: dragnet-ransomware-2024-1064 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 7cd0bc8f-c4eb-5ecc-98d0-beddd00e2b5e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
