// Dragnet [Ransomware]: dragnet-ransomware-2024-4241 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: b938639a-9e00-51d2-a769-d26689b7b53c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
