// Dragnet [Ransomware]: dragnet-ransomware-2024-2721 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 157431af-3144-5d5d-b4a7-9f9288dcd88a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
