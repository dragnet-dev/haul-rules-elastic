// Dragnet [Ransomware]: dragnet-ransomware-2024-2945 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 135722e1-c493-5d83-8f00-19074dc05a08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
