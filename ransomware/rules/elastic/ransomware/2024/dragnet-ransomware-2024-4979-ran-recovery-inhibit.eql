// Dragnet [Ransomware]: dragnet-ransomware-2024-4979 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e4e5632c-fddb-552c-8eac-6123d86559d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
