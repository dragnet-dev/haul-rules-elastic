// Dragnet [Ransomware]: dragnet-ransomware-2024-2857 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 4865c2f0-f411-518d-ba8c-3fc037240d49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
