// Dragnet [Ransomware]: dragnet-ransomware-2024-0430 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2973eb49-f05b-58ab-83fc-8056c05e85b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
