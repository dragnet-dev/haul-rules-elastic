// Dragnet [Ransomware]: dragnet-ransomware-2024-1491 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: a02f0ebd-29d0-5715-9cc6-b85a5e3d90ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
