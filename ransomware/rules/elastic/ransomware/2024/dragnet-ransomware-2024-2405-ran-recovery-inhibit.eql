// Dragnet [Ransomware]: dragnet-ransomware-2024-2405 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 13c680cf-4acd-5c45-82e0-9ef997af05a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
