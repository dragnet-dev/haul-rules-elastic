// Dragnet [Ransomware]: dragnet-ransomware-2024-4728 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: c6b0e674-cc64-570a-a943-9958c36ef186

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
