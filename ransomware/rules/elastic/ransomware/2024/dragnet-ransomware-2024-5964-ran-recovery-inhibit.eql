// Dragnet [Ransomware]: dragnet-ransomware-2024-5964 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 7ee94bc1-509b-51f8-921e-8d613e854226

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
