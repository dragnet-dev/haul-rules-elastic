// Dragnet [Ransomware]: dragnet-ransomware-2024-2508 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 20328385-c406-5a11-ba73-7935b19bc349

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
