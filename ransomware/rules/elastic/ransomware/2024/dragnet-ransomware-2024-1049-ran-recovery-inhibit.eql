// Dragnet [Ransomware]: dragnet-ransomware-2024-1049 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: a0dc8020-fb1e-53d6-98d0-fae4d1d65023

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
