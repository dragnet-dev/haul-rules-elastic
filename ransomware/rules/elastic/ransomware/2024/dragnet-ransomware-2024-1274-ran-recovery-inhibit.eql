// Dragnet [Ransomware]: dragnet-ransomware-2024-1274 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 8f5b14f4-0e0e-57a8-8a13-629802d4c50f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
