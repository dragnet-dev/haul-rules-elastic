// Dragnet [Ransomware]: dragnet-ransomware-2024-1551 — Recovery Inhibition (frag)
// Status: deprecated | Level: high | ID: 66bf841a-37e1-53c5-94e3-53bfe7e48977

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
