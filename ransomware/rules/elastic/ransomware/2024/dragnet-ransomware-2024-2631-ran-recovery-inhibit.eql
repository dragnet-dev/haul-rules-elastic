// Dragnet [Ransomware]: dragnet-ransomware-2024-2631 — Recovery Inhibition (donex)
// Status: experimental | Level: high | ID: 7e7e13b7-95e2-559c-aeb3-927ed7727d3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
