// Dragnet [Ransomware]: dragnet-ransomware-2024-1659 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 715cd481-346c-595c-9eae-eda89233bd6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
