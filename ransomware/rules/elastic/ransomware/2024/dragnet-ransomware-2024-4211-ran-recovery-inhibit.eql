// Dragnet [Ransomware]: dragnet-ransomware-2024-4211 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 069a1f83-1497-5df4-a707-cfc73f1b7c11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
