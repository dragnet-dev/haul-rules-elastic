// Dragnet [Ransomware]: dragnet-ransomware-2024-0725 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f01c7c99-030d-5e10-a411-3c0ac7899600

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
