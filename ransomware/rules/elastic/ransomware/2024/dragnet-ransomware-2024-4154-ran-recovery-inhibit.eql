// Dragnet [Ransomware]: dragnet-ransomware-2024-4154 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 78b27eeb-fc86-5af9-b37a-ea0163843129

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
