// Dragnet [Ransomware]: dragnet-ransomware-2024-1758 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: e2e0442c-3a49-5c8c-8d8e-e32601d9f2c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
