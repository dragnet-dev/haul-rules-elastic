// Dragnet [Ransomware]: dragnet-ransomware-2024-5043 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 66cef282-24b4-58ff-9b9b-f1b538103337

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
