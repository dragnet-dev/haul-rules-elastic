// Dragnet [Ransomware]: dragnet-ransomware-2024-2925 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d89bd634-1d6e-54d4-a700-8cdfd92e4913

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
