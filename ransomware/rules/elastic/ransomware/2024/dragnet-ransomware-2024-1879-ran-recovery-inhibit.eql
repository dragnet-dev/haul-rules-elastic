// Dragnet [Ransomware]: dragnet-ransomware-2024-1879 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0339ad68-d7fa-51b7-8246-397f73e3092d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
