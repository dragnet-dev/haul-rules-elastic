// Dragnet [Ransomware]: dragnet-ransomware-2024-3150 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: f8f68a9b-90cc-5606-87cd-bdeffe574644

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
