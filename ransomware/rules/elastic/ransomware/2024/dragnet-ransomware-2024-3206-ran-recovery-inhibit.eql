// Dragnet [Ransomware]: dragnet-ransomware-2024-3206 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: c53df534-3db3-5be8-ae4a-95897adf36e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
