// Dragnet [Ransomware]: dragnet-ransomware-2024-3766 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a0c075df-d92c-57ac-a262-0ec44d47e528

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
