// Dragnet [Ransomware]: dragnet-ransomware-2024-0654 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 2ec1b589-d61b-5e03-a958-429a6896302f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
