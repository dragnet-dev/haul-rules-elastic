// Dragnet [Ransomware]: dragnet-ransomware-2024-3847 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: dcf86372-3bab-5184-85e2-b4d16564a278

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
