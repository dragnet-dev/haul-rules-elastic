// Dragnet [Ransomware]: dragnet-ransomware-2024-4449 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 77e39d7c-f410-5d52-af30-da25237d1fe8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
