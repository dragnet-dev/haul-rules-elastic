// Dragnet [Ransomware]: dragnet-ransomware-2024-1433 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 9499f191-3d42-539b-88b1-cb89ee2b3b5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
