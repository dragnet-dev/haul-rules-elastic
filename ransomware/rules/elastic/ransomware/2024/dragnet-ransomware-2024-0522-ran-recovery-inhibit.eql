// Dragnet [Ransomware]: dragnet-ransomware-2024-0522 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 6de3c95c-98df-5108-a973-fd8dbc83c0f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
