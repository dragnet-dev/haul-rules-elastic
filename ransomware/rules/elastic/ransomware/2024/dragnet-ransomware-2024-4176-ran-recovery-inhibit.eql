// Dragnet [Ransomware]: dragnet-ransomware-2024-4176 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ea3d788b-e202-501a-b55e-c1e0761513c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
