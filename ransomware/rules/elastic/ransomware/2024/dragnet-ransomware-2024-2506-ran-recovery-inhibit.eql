// Dragnet [Ransomware]: dragnet-ransomware-2024-2506 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f833c5a6-9f51-5df4-9717-e02bedf6fa78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
