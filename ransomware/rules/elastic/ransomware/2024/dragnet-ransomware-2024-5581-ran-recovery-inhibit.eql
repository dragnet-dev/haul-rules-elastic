// Dragnet [Ransomware]: dragnet-ransomware-2024-5581 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 0235fe72-13c7-5dd7-b921-97821dc5a7fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
