// Dragnet [Ransomware]: dragnet-ransomware-2024-5766 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 93f957a1-98c3-56e0-b812-3f8eb547bf90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
