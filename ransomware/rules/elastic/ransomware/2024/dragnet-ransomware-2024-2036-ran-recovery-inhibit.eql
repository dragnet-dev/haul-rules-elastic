// Dragnet [Ransomware]: dragnet-ransomware-2024-2036 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: b6633a65-b17c-569e-82bc-5482e7971220

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
