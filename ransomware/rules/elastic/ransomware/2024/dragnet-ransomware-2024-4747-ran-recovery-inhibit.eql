// Dragnet [Ransomware]: dragnet-ransomware-2024-4747 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 25f153c4-2e81-51f1-9725-b81254bd5495

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
