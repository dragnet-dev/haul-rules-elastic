// Dragnet [Ransomware]: dragnet-ransomware-2024-1615 — Recovery Inhibition (ElDorado)
// Status: experimental | Level: high | ID: db167edc-7f0d-5336-aa98-a39e4f7947be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
