// Dragnet [Ransomware]: dragnet-ransomware-2024-0971 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: 44d1c9ec-5b15-5272-884a-445592d5a490

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
