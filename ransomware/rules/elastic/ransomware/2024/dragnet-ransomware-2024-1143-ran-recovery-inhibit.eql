// Dragnet [Ransomware]: dragnet-ransomware-2024-1143 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 5254be81-f95e-5b0d-865e-6efa03a762bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
