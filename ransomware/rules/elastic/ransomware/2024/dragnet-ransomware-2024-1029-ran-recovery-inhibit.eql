// Dragnet [Ransomware]: dragnet-ransomware-2024-1029 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f5f25f53-7c4d-5730-b4ff-4b5798243462

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
