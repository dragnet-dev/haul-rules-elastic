// Dragnet [Ransomware]: dragnet-ransomware-2024-5978 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 933ea590-77d7-5f74-aa01-25b228208197

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
