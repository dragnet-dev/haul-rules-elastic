// Dragnet [Ransomware]: dragnet-ransomware-2024-0198 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3d2250da-7720-5a0a-9a68-f7d57f5050e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
