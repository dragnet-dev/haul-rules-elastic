// Dragnet [Ransomware]: dragnet-ransomware-2024-4374 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: e851654f-2ffc-5a11-a874-a730cf4385c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
