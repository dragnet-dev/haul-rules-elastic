// Dragnet [Ransomware]: dragnet-ransomware-2024-5047 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 283e45e3-eafe-5c59-a49a-ef25557bb1e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
