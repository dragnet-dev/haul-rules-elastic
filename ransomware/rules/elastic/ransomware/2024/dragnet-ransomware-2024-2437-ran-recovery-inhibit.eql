// Dragnet [Ransomware]: dragnet-ransomware-2024-2437 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 964ce13e-83ff-595e-a151-f80f766737a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
