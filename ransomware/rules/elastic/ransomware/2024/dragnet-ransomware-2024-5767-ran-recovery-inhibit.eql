// Dragnet [Ransomware]: dragnet-ransomware-2024-5767 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bbada3ee-c989-5a22-beae-5f25ed825c41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
