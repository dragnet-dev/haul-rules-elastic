// Dragnet [Ransomware]: dragnet-ransomware-2024-5556 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 873c4791-5382-57f6-acb2-def7ad7bcae5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
