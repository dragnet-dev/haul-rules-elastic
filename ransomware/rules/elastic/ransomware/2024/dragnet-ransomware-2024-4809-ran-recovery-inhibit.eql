// Dragnet [Ransomware]: dragnet-ransomware-2024-4809 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 4b5e1056-9db8-54be-9de5-f4dbfa9a8883

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
