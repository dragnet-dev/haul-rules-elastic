// Dragnet [Ransomware]: dragnet-ransomware-2024-1397 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 50fda3ce-ee0c-5393-bb48-cf43deb13782

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
