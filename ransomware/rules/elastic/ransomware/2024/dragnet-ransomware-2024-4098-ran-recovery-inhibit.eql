// Dragnet [Ransomware]: dragnet-ransomware-2024-4098 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5276fb66-0665-50ff-820b-274d26739faf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
