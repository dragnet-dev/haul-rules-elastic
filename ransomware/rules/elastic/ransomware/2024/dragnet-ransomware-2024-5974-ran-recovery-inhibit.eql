// Dragnet [Ransomware]: dragnet-ransomware-2024-5974 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 08e16d85-7936-531d-b089-0c989ef3d5d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
