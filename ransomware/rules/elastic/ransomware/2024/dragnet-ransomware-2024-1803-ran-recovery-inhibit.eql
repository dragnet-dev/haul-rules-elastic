// Dragnet [Ransomware]: dragnet-ransomware-2024-1803 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 1f3ea485-3a8f-5a46-9e1f-95c6cd6ff464

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
