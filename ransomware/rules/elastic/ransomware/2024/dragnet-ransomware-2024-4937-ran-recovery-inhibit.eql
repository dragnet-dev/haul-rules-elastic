// Dragnet [Ransomware]: dragnet-ransomware-2024-4937 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8fa39e59-b8c3-532a-a210-483377581223

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
