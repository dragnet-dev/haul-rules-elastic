// Dragnet [Ransomware]: dragnet-ransomware-2024-3214 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b5e772ff-9d08-5ab4-960e-de476a2511b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
