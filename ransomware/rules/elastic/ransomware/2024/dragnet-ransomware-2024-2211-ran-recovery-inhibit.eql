// Dragnet [Ransomware]: dragnet-ransomware-2024-2211 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 240a38ae-ee2c-5369-b0df-787d232937a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
