// Dragnet [Ransomware]: dragnet-ransomware-2024-4732 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 98e2eeaa-4457-524b-9396-62c2d05b4a4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
