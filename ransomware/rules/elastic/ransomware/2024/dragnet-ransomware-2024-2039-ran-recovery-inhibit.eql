// Dragnet [Ransomware]: dragnet-ransomware-2024-2039 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 7c255187-d21a-5b6e-b67e-2636adda6ee6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
