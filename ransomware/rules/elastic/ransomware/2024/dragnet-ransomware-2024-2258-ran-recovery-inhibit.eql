// Dragnet [Ransomware]: dragnet-ransomware-2024-2258 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 051de018-c7e7-5b39-aa2e-ead7051018a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
