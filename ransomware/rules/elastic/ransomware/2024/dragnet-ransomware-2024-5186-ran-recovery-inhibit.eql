// Dragnet [Ransomware]: dragnet-ransomware-2024-5186 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 250571ba-35a2-5d24-879e-16c15e33c647

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
