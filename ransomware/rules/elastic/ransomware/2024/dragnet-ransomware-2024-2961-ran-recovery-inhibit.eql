// Dragnet [Ransomware]: dragnet-ransomware-2024-2961 — Recovery Inhibition (mallox)
// Status: experimental | Level: high | ID: 1f6e3daf-ea6f-50a8-8efe-31e7b5759eb9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
