// Dragnet [Ransomware]: dragnet-ransomware-2024-5121 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a3b78bc2-8766-500e-aeab-359b0f0b5296

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
