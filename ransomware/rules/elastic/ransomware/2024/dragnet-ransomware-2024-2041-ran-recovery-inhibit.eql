// Dragnet [Ransomware]: dragnet-ransomware-2024-2041 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 42530122-045a-500f-bb0e-73bb91fbfc70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
