// Dragnet [Ransomware]: dragnet-ransomware-2024-2970 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f445093c-925c-5110-b898-c63116018f3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
