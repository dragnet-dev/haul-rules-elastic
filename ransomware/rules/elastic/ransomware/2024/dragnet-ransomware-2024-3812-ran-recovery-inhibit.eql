// Dragnet [Ransomware]: dragnet-ransomware-2024-3812 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 285ffe6b-d8ad-5034-8d3e-279371740922

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
