// Dragnet [Ransomware]: dragnet-ransomware-2024-5516 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 843981e3-416e-576f-bbe8-56294c64fe9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
