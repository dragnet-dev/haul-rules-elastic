// Dragnet [Ransomware]: dragnet-ransomware-2024-0215 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 71b4a833-100c-5dde-809e-c7d2153b7fe0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
