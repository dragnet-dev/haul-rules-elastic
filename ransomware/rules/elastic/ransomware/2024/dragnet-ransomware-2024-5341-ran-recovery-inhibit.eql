// Dragnet [Ransomware]: dragnet-ransomware-2024-5341 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 8b1c6131-7ecd-530f-813e-1fca66b7de29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
