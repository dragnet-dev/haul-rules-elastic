// Dragnet [Ransomware]: dragnet-ransomware-2024-0300 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 7d80cf79-ea71-526b-940e-e392593a0d6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
