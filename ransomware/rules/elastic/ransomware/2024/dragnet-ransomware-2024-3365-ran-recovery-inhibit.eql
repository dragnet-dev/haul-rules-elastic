// Dragnet [Ransomware]: dragnet-ransomware-2024-3365 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 90dd5a5e-39a7-54f5-b223-13a03e11a2c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
