// Dragnet [Ransomware]: dragnet-ransomware-2024-4594 — Recovery Inhibition (termite)
// Status: experimental | Level: high | ID: 2d658f27-ae7a-51cb-8a25-4619739c0212

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
