// Dragnet [Ransomware]: dragnet-ransomware-2024-0895 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 468141fc-46ae-562d-80ed-b43c4807bcad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
