// Dragnet [Ransomware]: dragnet-ransomware-2024-5280 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6326eadc-efec-5afc-9549-cf4b018eb8e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
