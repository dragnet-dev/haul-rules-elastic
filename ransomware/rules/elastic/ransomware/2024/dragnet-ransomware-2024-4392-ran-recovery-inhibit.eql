// Dragnet [Ransomware]: dragnet-ransomware-2024-4392 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: eb4fb26e-8120-5acf-b75b-21148f3dfad0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
