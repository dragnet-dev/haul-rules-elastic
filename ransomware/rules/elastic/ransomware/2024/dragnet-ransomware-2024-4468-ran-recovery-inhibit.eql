// Dragnet [Ransomware]: dragnet-ransomware-2024-4468 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: ac20a93e-a925-56ec-a4cf-1f4d960235df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
