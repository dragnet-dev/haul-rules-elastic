// Dragnet [Ransomware]: dragnet-ransomware-2024-2429 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ce607a79-0451-523b-afdf-dd84f40be92b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
