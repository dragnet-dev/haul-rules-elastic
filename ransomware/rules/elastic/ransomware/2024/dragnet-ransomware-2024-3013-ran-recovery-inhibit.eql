// Dragnet [Ransomware]: dragnet-ransomware-2024-3013 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 61db6540-f444-544d-a14e-df4c038f132b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
