// Dragnet [Ransomware]: dragnet-ransomware-2024-4517 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8aefdad3-b85c-5e59-b7ba-ca990d581e06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
