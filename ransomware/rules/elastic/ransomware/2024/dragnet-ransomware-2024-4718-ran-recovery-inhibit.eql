// Dragnet [Ransomware]: dragnet-ransomware-2024-4718 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: fa005145-0e50-5842-90ca-f9d090263a9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
