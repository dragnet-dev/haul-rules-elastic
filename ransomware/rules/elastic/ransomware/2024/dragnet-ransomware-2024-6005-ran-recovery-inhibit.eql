// Dragnet [Ransomware]: dragnet-ransomware-2024-6005 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7062c055-f1f3-54e9-a1b6-c40d7a004030

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
