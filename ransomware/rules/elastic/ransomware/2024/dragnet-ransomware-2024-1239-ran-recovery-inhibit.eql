// Dragnet [Ransomware]: dragnet-ransomware-2024-1239 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 25241ead-fbfd-5c6b-8a37-3ec3d2bbf402

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
