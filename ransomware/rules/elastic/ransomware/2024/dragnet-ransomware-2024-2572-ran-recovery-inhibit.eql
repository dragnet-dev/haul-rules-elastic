// Dragnet [Ransomware]: dragnet-ransomware-2024-2572 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 3b611851-ec7c-54af-8672-7d5d37edd1e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
