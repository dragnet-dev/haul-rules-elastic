// Dragnet [Ransomware]: dragnet-ransomware-2024-1357 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 6938983f-89ce-54b6-addf-e25fee4c1bfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
