// Dragnet [Ransomware]: dragnet-ransomware-2024-1680 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 4a60a457-543e-5186-a30b-21b361226dd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
