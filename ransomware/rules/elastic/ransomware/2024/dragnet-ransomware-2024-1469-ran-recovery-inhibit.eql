// Dragnet [Ransomware]: dragnet-ransomware-2024-1469 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 1311eb25-6d6b-548a-bbca-f04dc28233f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
