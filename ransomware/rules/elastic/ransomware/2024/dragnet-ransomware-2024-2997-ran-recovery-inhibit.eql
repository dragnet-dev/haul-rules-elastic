// Dragnet [Ransomware]: dragnet-ransomware-2024-2997 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: e59bf22e-ac49-5f21-aef9-ef5a3a05fc43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
