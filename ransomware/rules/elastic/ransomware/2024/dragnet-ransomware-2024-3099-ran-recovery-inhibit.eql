// Dragnet [Ransomware]: dragnet-ransomware-2024-3099 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: bf3d460c-82e3-5923-bd0c-997a77507392

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
