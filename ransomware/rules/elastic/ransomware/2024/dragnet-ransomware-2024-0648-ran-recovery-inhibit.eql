// Dragnet [Ransomware]: dragnet-ransomware-2024-0648 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: ce945108-babb-5bfc-92fc-e7b711075e19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
