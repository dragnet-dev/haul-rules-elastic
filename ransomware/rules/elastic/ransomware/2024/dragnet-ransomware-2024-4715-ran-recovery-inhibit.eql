// Dragnet [Ransomware]: dragnet-ransomware-2024-4715 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8373c0b3-44fb-55f4-a84e-4351f7bdaebc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
