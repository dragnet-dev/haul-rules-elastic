// Dragnet [Ransomware]: dragnet-ransomware-2024-4106 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 61cbd7ea-e648-582a-9bb3-a64a7b664686

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
