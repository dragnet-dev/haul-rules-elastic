// Dragnet [Ransomware]: dragnet-ransomware-2024-1422 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d6ef007f-5305-575b-bc81-0bbc89c42004

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
