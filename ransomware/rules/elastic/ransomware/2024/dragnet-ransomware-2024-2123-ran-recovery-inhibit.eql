// Dragnet [Ransomware]: dragnet-ransomware-2024-2123 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 59a8ffc2-f47b-53c1-840b-5aa191e41087

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
