// Dragnet [Ransomware]: dragnet-ransomware-2024-0689 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 820ef905-e689-578f-9d6e-81e6d33ed051

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
