// Dragnet [Ransomware]: dragnet-ransomware-2024-5427 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 8f789f60-2637-5cd6-b53a-6f964c88ff8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
