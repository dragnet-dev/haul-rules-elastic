// Dragnet [Ransomware]: dragnet-ransomware-2024-3549 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 00627833-6923-520b-9369-c19a1409263c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
