// Dragnet [Ransomware]: dragnet-ransomware-2024-3179 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 653eaf85-8f9f-53ab-a739-a1faafb276f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
