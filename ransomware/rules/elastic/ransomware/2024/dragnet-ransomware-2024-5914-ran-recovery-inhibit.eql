// Dragnet [Ransomware]: dragnet-ransomware-2024-5914 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: fa0ad184-68a6-5f7c-b106-7874d90b36c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
