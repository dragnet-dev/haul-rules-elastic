// Dragnet [Ransomware]: dragnet-ransomware-2024-3721 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 22d127ca-4f68-5255-a31b-ccef62e14fb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
