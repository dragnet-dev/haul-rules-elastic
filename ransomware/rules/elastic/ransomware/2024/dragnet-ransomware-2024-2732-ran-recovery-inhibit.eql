// Dragnet [Ransomware]: dragnet-ransomware-2024-2732 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 1a151e63-e72e-5cbe-94ae-223eb3e89e18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
