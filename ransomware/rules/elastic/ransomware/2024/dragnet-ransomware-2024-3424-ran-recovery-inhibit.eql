// Dragnet [Ransomware]: dragnet-ransomware-2024-3424 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: b72d5fc2-fead-5ba1-a555-7e5d2ec5e0d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
