// Dragnet [Ransomware]: dragnet-ransomware-2024-0070 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b86c5a2b-2a00-52af-af1c-5cfb31882d0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
