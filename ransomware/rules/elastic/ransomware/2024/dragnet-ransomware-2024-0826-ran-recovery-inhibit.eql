// Dragnet [Ransomware]: dragnet-ransomware-2024-0826 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 298fea03-ae7c-5170-a70f-161147998ec9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
