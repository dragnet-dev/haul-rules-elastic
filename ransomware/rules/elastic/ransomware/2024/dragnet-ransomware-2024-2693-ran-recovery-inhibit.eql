// Dragnet [Ransomware]: dragnet-ransomware-2024-2693 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4323272b-1820-5035-ac20-c7da52b0d081

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
