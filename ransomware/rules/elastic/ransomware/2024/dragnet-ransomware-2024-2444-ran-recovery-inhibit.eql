// Dragnet [Ransomware]: dragnet-ransomware-2024-2444 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: f026a308-7879-595c-b67e-be28cf5ae559

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
