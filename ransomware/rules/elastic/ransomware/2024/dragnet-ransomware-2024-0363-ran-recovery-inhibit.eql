// Dragnet [Ransomware]: dragnet-ransomware-2024-0363 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f094f204-8782-588a-a8d0-66ad01569932

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
