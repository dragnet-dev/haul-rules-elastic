// Dragnet [Ransomware]: dragnet-ransomware-2024-1963 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 5d328f39-2b71-5479-b9fb-f6bdd24cce8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
