// Dragnet [Ransomware]: dragnet-ransomware-2024-3215 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 62ce17ad-a289-55b6-b022-4a2b8417c818

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
