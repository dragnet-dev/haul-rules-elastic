// Dragnet [Ransomware]: dragnet-ransomware-2024-5197 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 7a6bcfcc-6a0a-521c-a99d-59bec3eb7d5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
