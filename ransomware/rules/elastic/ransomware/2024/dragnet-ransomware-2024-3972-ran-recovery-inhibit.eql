// Dragnet [Ransomware]: dragnet-ransomware-2024-3972 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c2639046-9079-5e8d-8864-5a48779cdae1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
