// Dragnet [Ransomware]: dragnet-ransomware-2024-1665 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 571f680b-ce80-55d8-a8e0-df1b6849a26c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
