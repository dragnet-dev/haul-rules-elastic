// Dragnet [Ransomware]: dragnet-ransomware-2024-1187 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 5350105a-3dc6-5897-aa63-4474e9f2bdb3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
