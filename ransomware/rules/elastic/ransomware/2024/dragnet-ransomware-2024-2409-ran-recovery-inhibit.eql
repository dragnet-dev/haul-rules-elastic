// Dragnet [Ransomware]: dragnet-ransomware-2024-2409 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: 097e731a-b56d-519c-b5e8-03416bd5a0d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
