// Dragnet [Ransomware]: dragnet-ransomware-2024-3527 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 60f98137-f185-58b7-a497-a6a237bca5ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
