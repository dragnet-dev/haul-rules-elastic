// Dragnet [Ransomware]: dragnet-ransomware-2024-1700 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 2af95976-6719-523b-9f72-4475615ab7f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
