// Dragnet [Ransomware]: dragnet-ransomware-2024-3659 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4a68b6a4-7f7c-557c-9f13-482f2b22fe3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
