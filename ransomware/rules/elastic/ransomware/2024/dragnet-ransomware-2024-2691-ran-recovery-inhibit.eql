// Dragnet [Ransomware]: dragnet-ransomware-2024-2691 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 9a7030ad-82b0-5f43-91e4-4e4c1491d328

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
