// Dragnet [Ransomware]: dragnet-ransomware-2024-3267 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9831ebac-5676-55b5-8f7d-51127e8175bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
