// Dragnet [Ransomware]: dragnet-ransomware-2024-0248 — Recovery Inhibition (underground)
// Status: experimental | Level: high | ID: 040394df-8555-53bf-97bd-a3539f6a9239

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
