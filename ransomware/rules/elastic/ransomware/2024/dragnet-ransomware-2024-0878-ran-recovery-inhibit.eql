// Dragnet [Ransomware]: dragnet-ransomware-2024-0878 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c68e5e5f-46d4-5e97-b635-c68ddb2d259c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
