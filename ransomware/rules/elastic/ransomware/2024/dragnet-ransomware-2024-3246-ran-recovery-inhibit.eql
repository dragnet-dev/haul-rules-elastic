// Dragnet [Ransomware]: dragnet-ransomware-2024-3246 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 43adffdf-0cd2-59e7-b882-b3e91b0f4e05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
