// Dragnet [Ransomware]: dragnet-ransomware-2024-0914 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 9b45e405-46c7-5981-bdcf-3526703d4968

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
