// Dragnet [Ransomware]: dragnet-ransomware-2024-5080 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 81b39439-5861-5390-bd63-f32acb732a69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
