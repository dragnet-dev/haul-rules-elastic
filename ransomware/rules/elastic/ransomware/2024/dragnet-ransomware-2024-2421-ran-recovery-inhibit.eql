// Dragnet [Ransomware]: dragnet-ransomware-2024-2421 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 942b586c-95b1-5ac2-906d-acf0c6d97351

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
