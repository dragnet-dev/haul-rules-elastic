// Dragnet [Ransomware]: dragnet-ransomware-2024-5509 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 870752b9-41fd-5ec5-a169-04c496f13b6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
