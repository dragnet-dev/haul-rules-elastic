// Dragnet [Ransomware]: dragnet-ransomware-2024-1403 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2d8de4a3-e014-54e0-8e81-946ac44879b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
