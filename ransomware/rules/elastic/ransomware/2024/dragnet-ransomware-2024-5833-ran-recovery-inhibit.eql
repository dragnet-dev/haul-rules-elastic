// Dragnet [Ransomware]: dragnet-ransomware-2024-5833 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7e8e0268-57a9-5a60-b39c-be8652c5682b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
