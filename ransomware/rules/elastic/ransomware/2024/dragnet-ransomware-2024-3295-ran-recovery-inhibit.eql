// Dragnet [Ransomware]: dragnet-ransomware-2024-3295 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c3215222-dbea-5f75-b71f-ecf43ebd4765

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
