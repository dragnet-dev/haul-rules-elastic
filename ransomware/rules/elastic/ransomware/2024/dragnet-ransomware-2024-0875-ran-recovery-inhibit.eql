// Dragnet [Ransomware]: dragnet-ransomware-2024-0875 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: fe81ede9-4fca-519c-a398-6da5e44e8556

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
