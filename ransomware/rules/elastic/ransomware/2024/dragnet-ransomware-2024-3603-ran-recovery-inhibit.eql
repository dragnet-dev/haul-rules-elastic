// Dragnet [Ransomware]: dragnet-ransomware-2024-3603 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: abcb76b7-d3d2-5932-b608-70e4105e3811

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
