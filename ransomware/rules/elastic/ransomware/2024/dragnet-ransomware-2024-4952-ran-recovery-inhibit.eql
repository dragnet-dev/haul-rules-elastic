// Dragnet [Ransomware]: dragnet-ransomware-2024-4952 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 58e39ea8-403e-5f01-bbb2-b17fdec908ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
