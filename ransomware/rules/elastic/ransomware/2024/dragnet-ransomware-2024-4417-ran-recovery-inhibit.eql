// Dragnet [Ransomware]: dragnet-ransomware-2024-4417 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 2018d6c5-7231-5aaa-8bf3-2bf41416fd09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
