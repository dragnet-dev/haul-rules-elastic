// Dragnet [Ransomware]: dragnet-ransomware-2024-5639 — Recovery Inhibition (mogilevich)
// Status: deprecated | Level: high | ID: 85559718-a85b-5c1b-aa63-2c36280b79a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
