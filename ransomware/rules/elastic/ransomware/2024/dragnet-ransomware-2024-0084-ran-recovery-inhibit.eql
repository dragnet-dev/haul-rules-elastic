// Dragnet [Ransomware]: dragnet-ransomware-2024-0084 — Recovery Inhibition (datacarry)
// Status: deprecated | Level: high | ID: 81bdceb0-64a5-5d26-8ffd-2ce51d6d3370

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
