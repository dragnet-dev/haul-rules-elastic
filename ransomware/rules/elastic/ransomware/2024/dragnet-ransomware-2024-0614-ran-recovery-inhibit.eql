// Dragnet [Ransomware]: dragnet-ransomware-2024-0614 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b21c931c-1f0a-5dbe-8e03-8603ecdeb082

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
