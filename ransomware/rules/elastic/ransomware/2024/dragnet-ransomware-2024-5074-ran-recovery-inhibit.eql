// Dragnet [Ransomware]: dragnet-ransomware-2024-5074 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fbb39831-796f-5b87-b0f1-32c77ff0dd6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
