// Dragnet [Ransomware]: dragnet-ransomware-2024-5553 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 920bded3-fae7-5f4a-857f-ccd11d9a8c36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
