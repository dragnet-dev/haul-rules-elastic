// Dragnet [Ransomware]: dragnet-ransomware-2024-3145 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 55642b31-520c-57eb-9b09-fad9853d5c02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
