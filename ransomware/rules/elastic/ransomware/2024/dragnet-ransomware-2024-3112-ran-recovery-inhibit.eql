// Dragnet [Ransomware]: dragnet-ransomware-2024-3112 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 2ed117b1-5e26-5877-9fc8-d6efe66b79ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
