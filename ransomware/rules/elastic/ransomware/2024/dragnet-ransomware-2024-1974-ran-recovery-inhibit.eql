// Dragnet [Ransomware]: dragnet-ransomware-2024-1974 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: d6f3486e-b178-5cf2-aaca-46a2391f9d6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
