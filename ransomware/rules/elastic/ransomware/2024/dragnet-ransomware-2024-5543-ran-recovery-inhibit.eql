// Dragnet [Ransomware]: dragnet-ransomware-2024-5543 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 80c6f992-dbcc-5f60-a36c-09ed7a9239b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
