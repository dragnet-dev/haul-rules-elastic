// Dragnet [Ransomware]: dragnet-ransomware-2024-4046 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: 18acb896-682a-5c03-a9ee-e838e734da28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
