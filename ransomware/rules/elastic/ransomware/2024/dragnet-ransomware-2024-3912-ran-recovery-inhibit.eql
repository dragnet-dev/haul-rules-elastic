// Dragnet [Ransomware]: dragnet-ransomware-2024-3912 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 577428f5-2dd5-559b-a44e-e8ad2852571d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
