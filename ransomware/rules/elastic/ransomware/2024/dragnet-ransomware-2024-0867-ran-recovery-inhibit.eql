// Dragnet [Ransomware]: dragnet-ransomware-2024-0867 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0b82bff4-e6da-5f38-a2dd-d516963fdf6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
