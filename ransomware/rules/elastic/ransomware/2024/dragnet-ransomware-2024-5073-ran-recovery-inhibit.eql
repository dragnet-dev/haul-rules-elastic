// Dragnet [Ransomware]: dragnet-ransomware-2024-5073 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 29c8f0b3-3b33-59cb-af8b-bdc845a9747e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
