// Dragnet [Ransomware]: dragnet-ransomware-2024-5633 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: eeafee14-be9e-5e87-9935-d1648009492b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
