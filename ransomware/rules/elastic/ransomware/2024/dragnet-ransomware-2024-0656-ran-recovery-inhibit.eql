// Dragnet [Ransomware]: dragnet-ransomware-2024-0656 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 30026652-a2e1-540b-8999-f7a501df0d0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
