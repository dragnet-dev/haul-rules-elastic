// Dragnet [Ransomware]: dragnet-ransomware-2024-0559 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ad001243-44f4-537b-a69f-3b2bb731fc7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
