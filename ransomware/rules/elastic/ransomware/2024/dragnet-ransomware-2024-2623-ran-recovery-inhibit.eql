// Dragnet [Ransomware]: dragnet-ransomware-2024-2623 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 75977873-8f95-5556-a8b8-215370c1b55c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
