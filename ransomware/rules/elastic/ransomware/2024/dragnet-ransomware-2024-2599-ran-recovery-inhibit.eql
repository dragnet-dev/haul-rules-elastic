// Dragnet [Ransomware]: dragnet-ransomware-2024-2599 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: c24f1d3a-d4d1-5500-8744-36912c51f8fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
