// Dragnet [Ransomware]: dragnet-ransomware-2024-3657 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 3c210dd5-7cb4-52e0-8cc0-291b4c3880dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
