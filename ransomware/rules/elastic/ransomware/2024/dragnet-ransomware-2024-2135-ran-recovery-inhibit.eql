// Dragnet [Ransomware]: dragnet-ransomware-2024-2135 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7180161d-9e02-52b2-9c63-b4cc396ba4c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
