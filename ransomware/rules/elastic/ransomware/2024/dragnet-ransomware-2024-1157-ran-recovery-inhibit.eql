// Dragnet [Ransomware]: dragnet-ransomware-2024-1157 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 45226a94-961e-5bd4-8f9f-a78f1372f534

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
