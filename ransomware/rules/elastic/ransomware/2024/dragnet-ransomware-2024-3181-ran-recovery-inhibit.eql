// Dragnet [Ransomware]: dragnet-ransomware-2024-3181 — Recovery Inhibition (vanirgroup)
// Status: deprecated | Level: high | ID: 12c4685a-e9f2-5614-a8d6-7013b9db0c0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
