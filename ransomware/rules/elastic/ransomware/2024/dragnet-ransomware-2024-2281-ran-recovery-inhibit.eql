// Dragnet [Ransomware]: dragnet-ransomware-2024-2281 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fc87496a-d9c2-53fa-aa50-bad4421393ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
