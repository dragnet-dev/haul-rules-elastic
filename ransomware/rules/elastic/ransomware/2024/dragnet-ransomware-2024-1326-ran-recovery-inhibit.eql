// Dragnet [Ransomware]: dragnet-ransomware-2024-1326 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 18bb7e4f-1344-56b4-abcd-990d59d28366

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
