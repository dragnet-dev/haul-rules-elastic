// Dragnet [Ransomware]: dragnet-ransomware-2024-4881 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: 79e9fd44-5cf9-59bb-82b9-3f923028c950

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
