// Dragnet [Ransomware]: dragnet-ransomware-2024-4981 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: 81c226f6-3093-5842-b81d-3731a0cc72a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
