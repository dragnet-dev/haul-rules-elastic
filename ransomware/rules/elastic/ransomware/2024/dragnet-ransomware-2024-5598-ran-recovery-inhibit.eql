// Dragnet [Ransomware]: dragnet-ransomware-2024-5598 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 6bd6acab-1c65-573f-bfdf-0906a7050222

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
