// Dragnet [Ransomware]: dragnet-ransomware-2024-3892 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f4c35917-dd66-54f7-93ef-032963d4ea9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
