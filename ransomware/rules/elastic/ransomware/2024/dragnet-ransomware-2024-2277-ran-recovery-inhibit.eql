// Dragnet [Ransomware]: dragnet-ransomware-2024-2277 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 9a7a67f5-5578-545f-b164-11132e219371

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
