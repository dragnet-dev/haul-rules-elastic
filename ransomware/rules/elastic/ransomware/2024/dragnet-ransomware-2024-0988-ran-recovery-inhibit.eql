// Dragnet [Ransomware]: dragnet-ransomware-2024-0988 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bd118e16-02e9-51c3-b8fc-f63b6efc169a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
