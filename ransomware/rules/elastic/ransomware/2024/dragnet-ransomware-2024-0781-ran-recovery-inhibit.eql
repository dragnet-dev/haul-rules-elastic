// Dragnet [Ransomware]: dragnet-ransomware-2024-0781 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 4d18e945-ef40-5ab4-834e-fa3916fcf2a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
