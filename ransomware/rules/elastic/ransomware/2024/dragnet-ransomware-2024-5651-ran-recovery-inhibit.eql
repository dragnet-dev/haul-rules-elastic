// Dragnet [Ransomware]: dragnet-ransomware-2024-5651 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: cc38183b-9688-51b0-a7d0-9ceed28dd476

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
