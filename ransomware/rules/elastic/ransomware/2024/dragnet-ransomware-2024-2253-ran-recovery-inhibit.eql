// Dragnet [Ransomware]: dragnet-ransomware-2024-2253 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6b248f13-f89d-5653-9064-a55a35afcd2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
