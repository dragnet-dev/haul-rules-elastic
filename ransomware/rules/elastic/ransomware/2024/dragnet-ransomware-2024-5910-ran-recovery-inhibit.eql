// Dragnet [Ransomware]: dragnet-ransomware-2024-5910 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 2f6e8444-bd91-5477-b5a7-113a6a1907b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
