// Dragnet [Ransomware]: dragnet-ransomware-2024-1605 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: afe1df7c-269c-5dc9-b8dc-2505313b89e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
