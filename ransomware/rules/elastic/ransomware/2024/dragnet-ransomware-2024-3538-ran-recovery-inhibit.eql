// Dragnet [Ransomware]: dragnet-ransomware-2024-3538 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 3d8ff407-97b8-5d99-af75-015ff65925c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
