// Dragnet [Ransomware]: dragnet-ransomware-2024-3196 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 71e56d57-9618-5f64-bc04-8e394cf16570

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
