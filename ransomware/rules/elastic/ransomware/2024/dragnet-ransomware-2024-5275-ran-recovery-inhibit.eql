// Dragnet [Ransomware]: dragnet-ransomware-2024-5275 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 1a8a3618-58b4-5a37-bc81-7ed71330b897

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
