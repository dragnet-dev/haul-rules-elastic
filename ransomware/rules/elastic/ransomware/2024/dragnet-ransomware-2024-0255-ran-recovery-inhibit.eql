// Dragnet [Ransomware]: dragnet-ransomware-2024-0255 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: ee069000-2e0d-531a-b1a6-ae8449d5665f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
