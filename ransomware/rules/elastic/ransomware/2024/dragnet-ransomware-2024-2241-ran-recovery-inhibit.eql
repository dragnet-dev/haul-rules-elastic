// Dragnet [Ransomware]: dragnet-ransomware-2024-2241 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: c4164fb6-2ce6-5abc-b83c-b485215365df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
