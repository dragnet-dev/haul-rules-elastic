// Dragnet [Ransomware]: dragnet-ransomware-2024-0513 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: f70df59b-a976-5626-9496-19d0643ef1c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
