// Dragnet [Ransomware]: dragnet-ransomware-2024-0956 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: 6ab4f4b3-a277-5802-91ad-4b418f3d665c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
