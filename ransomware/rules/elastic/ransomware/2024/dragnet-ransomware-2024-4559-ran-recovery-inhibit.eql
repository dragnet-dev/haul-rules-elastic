// Dragnet [Ransomware]: dragnet-ransomware-2024-4559 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a9d5396b-7788-5f62-ad81-98bdf45b2ced

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
