// Dragnet [Ransomware]: dragnet-ransomware-2024-2343 — Recovery Inhibition (genesis)
// Status: experimental | Level: high | ID: 331477e8-14cb-504f-86e3-ecde9f790136

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
