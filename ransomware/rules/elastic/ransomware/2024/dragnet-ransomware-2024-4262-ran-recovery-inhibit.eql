// Dragnet [Ransomware]: dragnet-ransomware-2024-4262 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: dc1bb92f-3823-5152-9143-c9932f4652ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
