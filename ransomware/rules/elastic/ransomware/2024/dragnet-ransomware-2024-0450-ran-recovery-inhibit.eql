// Dragnet [Ransomware]: dragnet-ransomware-2024-0450 — Recovery Inhibition (ElDorado)
// Status: experimental | Level: high | ID: 99522889-018c-5bf3-99df-3aee0fc8beea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
