// Dragnet [Ransomware]: dragnet-ransomware-2024-2300 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: f1259640-879f-585a-93b8-75ec652de13a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
