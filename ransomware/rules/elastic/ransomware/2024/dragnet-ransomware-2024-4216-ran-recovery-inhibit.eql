// Dragnet [Ransomware]: dragnet-ransomware-2024-4216 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: e4f5ff78-7a13-5a09-a2b4-e448deac8c89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
