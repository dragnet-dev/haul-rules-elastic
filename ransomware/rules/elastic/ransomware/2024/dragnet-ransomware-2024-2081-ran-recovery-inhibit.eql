// Dragnet [Ransomware]: dragnet-ransomware-2024-2081 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0776174d-639e-583d-b170-18efeedbb906

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
