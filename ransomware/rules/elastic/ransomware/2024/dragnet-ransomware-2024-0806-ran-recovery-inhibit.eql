// Dragnet [Ransomware]: dragnet-ransomware-2024-0806 — Recovery Inhibition (frag)
// Status: deprecated | Level: high | ID: 0472bbfb-704d-5aa9-a5db-76ae1265bffb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
