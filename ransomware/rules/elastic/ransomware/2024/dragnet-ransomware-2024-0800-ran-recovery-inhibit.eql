// Dragnet [Ransomware]: dragnet-ransomware-2024-0800 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: a5fd8ba8-1067-55be-8af5-084158c334f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
