// Dragnet [Ransomware]: dragnet-ransomware-2024-0489 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 77e6e120-2aec-52f5-9fd6-018ffb90b3da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
