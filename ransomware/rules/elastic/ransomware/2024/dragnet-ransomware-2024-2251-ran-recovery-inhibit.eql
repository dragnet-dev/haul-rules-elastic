// Dragnet [Ransomware]: dragnet-ransomware-2024-2251 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 152d34fb-63b4-5b88-a8cf-94a802b4ebee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
