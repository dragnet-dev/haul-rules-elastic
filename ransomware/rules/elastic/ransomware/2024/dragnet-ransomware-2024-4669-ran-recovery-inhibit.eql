// Dragnet [Ransomware]: dragnet-ransomware-2024-4669 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 2f8ca0ea-6fcb-5eeb-b3d5-13ea7847d1d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
