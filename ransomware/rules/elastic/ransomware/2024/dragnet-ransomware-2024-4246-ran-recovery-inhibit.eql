// Dragnet [Ransomware]: dragnet-ransomware-2024-4246 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 19d38d30-867f-5190-8806-19a73d5ef930

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
