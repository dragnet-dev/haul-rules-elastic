// Dragnet [Ransomware]: dragnet-ransomware-2024-3614 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4c818c54-67ca-544b-9bc0-537f1faab1ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
