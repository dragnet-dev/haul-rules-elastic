// Dragnet [Ransomware]: dragnet-ransomware-2024-4764 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1f0391db-b41a-5065-b738-cbfdd5482ed7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
