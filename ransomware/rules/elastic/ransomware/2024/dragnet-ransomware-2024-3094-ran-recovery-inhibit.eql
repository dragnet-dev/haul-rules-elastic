// Dragnet [Ransomware]: dragnet-ransomware-2024-3094 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 1c64fa82-7a01-5a14-8a74-8374f9081fd3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
