// Dragnet [Ransomware]: dragnet-ransomware-2024-6015 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 17d02862-e9f9-534e-93ab-7bed181575eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
