// Dragnet [Ransomware]: dragnet-ransomware-2024-4249 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: d13ada02-4421-5157-996d-4353de92867a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
