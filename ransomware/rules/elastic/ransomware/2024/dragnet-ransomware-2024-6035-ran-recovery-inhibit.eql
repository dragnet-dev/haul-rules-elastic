// Dragnet [Ransomware]: dragnet-ransomware-2024-6035 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: d80020e5-7940-517f-bd43-b0cec7d5e206

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
