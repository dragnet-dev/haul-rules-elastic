// Dragnet [Ransomware]: dragnet-ransomware-2024-3007 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 8bcc8a13-634e-58b7-951d-ef37e6612268

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
