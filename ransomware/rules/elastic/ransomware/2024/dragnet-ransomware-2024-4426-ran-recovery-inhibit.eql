// Dragnet [Ransomware]: dragnet-ransomware-2024-4426 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 5970d0da-48f3-5072-8eb6-392a3a1d98e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
