// Dragnet [Ransomware]: dragnet-ransomware-2024-2709 — Recovery Inhibition (werewolves)
// Status: experimental | Level: high | ID: 1e1083db-d564-5cc3-8898-52e33fad661d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
