// Dragnet [Ransomware]: dragnet-ransomware-2024-3503 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: dd34a26e-1a8f-5083-b53a-347b8b82ab61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
