// Dragnet [Ransomware]: dragnet-ransomware-2024-4361 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 7a11cee0-8525-5b87-8e49-3078c3b0bfe0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
