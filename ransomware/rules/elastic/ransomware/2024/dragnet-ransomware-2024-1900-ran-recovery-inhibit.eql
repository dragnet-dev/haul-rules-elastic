// Dragnet [Ransomware]: dragnet-ransomware-2024-1900 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 0fe36de2-8b16-5c9f-ba07-7f6cf2c929fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
