// Dragnet [Ransomware]: dragnet-ransomware-2024-3953 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 352e61e2-4934-5bf1-aa53-86dcd402f849

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
