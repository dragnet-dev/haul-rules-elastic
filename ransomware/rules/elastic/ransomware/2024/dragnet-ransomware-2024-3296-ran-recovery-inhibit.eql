// Dragnet [Ransomware]: dragnet-ransomware-2024-3296 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: ffc2f514-e6af-52f0-80b2-8f9b862847bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
