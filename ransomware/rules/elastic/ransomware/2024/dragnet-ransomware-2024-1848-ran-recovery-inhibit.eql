// Dragnet [Ransomware]: dragnet-ransomware-2024-1848 — Recovery Inhibition (underground)
// Status: experimental | Level: high | ID: 637f1385-197d-5c3c-b8dd-f6074f10e858

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
