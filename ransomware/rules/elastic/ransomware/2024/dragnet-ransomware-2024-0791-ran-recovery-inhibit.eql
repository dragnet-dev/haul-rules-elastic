// Dragnet [Ransomware]: dragnet-ransomware-2024-0791 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 47bedee2-30aa-5feb-bd43-9af2e80ae172

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
