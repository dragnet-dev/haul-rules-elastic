// Dragnet [Ransomware]: dragnet-ransomware-2024-1735 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: c165a5a1-2793-591e-8b1f-7599187b29e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
