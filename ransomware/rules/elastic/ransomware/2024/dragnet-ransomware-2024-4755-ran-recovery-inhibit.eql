// Dragnet [Ransomware]: dragnet-ransomware-2024-4755 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a4d59c25-5655-5361-bf85-dea5ce395a17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
