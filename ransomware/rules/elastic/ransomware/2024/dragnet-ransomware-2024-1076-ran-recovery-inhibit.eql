// Dragnet [Ransomware]: dragnet-ransomware-2024-1076 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a4f6d0cd-a311-571e-a2b2-255b8ed95d0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
