// Dragnet [Ransomware]: dragnet-ransomware-2024-3237 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 548f0ffe-faea-576b-9d0c-37eacf6165b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
