// Dragnet [Ransomware]: dragnet-ransomware-2024-5258 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: de73f00f-2504-55cc-bbfe-08223379082c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
