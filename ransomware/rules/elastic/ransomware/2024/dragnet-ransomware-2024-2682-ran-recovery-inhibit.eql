// Dragnet [Ransomware]: dragnet-ransomware-2024-2682 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 43b5c906-9b92-5d10-8699-ea280cec143b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
