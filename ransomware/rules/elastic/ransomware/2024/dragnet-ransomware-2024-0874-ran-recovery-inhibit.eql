// Dragnet [Ransomware]: dragnet-ransomware-2024-0874 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 57b2a71e-3b7d-5cd8-aedb-d4ee96f92b50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
