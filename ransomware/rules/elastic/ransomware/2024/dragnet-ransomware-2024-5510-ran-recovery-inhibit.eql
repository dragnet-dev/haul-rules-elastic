// Dragnet [Ransomware]: dragnet-ransomware-2024-5510 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: afef2217-42dd-5d37-964c-03733643821d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
