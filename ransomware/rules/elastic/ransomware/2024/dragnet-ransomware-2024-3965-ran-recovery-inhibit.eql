// Dragnet [Ransomware]: dragnet-ransomware-2024-3965 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1f4e1583-d48c-52be-beb6-e2501dd1cbe2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
