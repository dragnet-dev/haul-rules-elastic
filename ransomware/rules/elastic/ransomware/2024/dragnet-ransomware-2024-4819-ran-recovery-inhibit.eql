// Dragnet [Ransomware]: dragnet-ransomware-2024-4819 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 3cabc36c-f732-550f-8315-c246624ce2a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
