// Dragnet [Ransomware]: dragnet-ransomware-2024-3425 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 52811e38-f73c-52ee-8cc1-cdbcef5a76cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
