// Dragnet [Ransomware]: dragnet-ransomware-2024-0097 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 4cecd075-ed8d-5443-a6ec-f73bf921ea91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
