// Dragnet [Ransomware]: dragnet-ransomware-2024-5900 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: cb1206d1-eb36-5fde-93f8-c9c87970a48f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
