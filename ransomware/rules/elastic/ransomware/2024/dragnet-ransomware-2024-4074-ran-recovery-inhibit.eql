// Dragnet [Ransomware]: dragnet-ransomware-2024-4074 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1ad63237-63ed-5a52-8888-5b6d97b04850

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
