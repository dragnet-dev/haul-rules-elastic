// Dragnet [Ransomware]: dragnet-ransomware-2024-0766 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e496a7e0-b214-5080-9935-16480f6d73ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
