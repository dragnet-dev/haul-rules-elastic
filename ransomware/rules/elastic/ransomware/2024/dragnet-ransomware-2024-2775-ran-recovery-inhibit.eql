// Dragnet [Ransomware]: dragnet-ransomware-2024-2775 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 809912cc-9b9a-53db-9bf7-efed2618f5f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
