// Dragnet [Ransomware]: dragnet-ransomware-2024-4107 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: f7b54dd7-a2de-5edc-ae88-fc1419287dfd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
