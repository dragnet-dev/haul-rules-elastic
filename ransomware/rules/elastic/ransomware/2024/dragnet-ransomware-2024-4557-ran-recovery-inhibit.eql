// Dragnet [Ransomware]: dragnet-ransomware-2024-4557 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 26307d1f-c925-57be-a591-5a367ce1854c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
