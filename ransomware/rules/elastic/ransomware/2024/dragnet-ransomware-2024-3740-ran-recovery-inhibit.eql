// Dragnet [Ransomware]: dragnet-ransomware-2024-3740 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 5421faa5-94e9-5b59-900d-55b32a4272d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
