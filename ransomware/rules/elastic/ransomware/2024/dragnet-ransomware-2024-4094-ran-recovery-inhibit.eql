// Dragnet [Ransomware]: dragnet-ransomware-2024-4094 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2c0ca144-90df-58c1-b71e-2eb765ddc112

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
