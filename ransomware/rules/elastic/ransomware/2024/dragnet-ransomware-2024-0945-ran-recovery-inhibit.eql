// Dragnet [Ransomware]: dragnet-ransomware-2024-0945 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 38b413eb-278c-50c7-9286-78170deeaa34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
