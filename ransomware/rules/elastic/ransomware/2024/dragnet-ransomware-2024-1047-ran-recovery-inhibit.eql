// Dragnet [Ransomware]: dragnet-ransomware-2024-1047 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7a6c5bd5-eda9-5c21-98e5-af4584e99f16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
