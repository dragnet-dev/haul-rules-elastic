// Dragnet [Ransomware]: dragnet-ransomware-2024-3783 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: 1dfd89e0-bc99-58fc-b6ff-c70e2d3c5fef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
