// Dragnet [Ransomware]: dragnet-ransomware-2024-3856 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: be1af4d6-4861-573e-9331-1e6778c5fc37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
