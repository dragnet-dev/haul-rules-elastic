// Dragnet [Ransomware]: dragnet-ransomware-2024-5972 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: f009df7c-6a7d-5029-9b96-f26021a1e6f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
