// Dragnet [Ransomware]: dragnet-ransomware-2024-0339 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: e4ff43ff-72d6-503a-acdf-7b0bfba251ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
