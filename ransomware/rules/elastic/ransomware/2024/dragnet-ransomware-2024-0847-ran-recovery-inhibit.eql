// Dragnet [Ransomware]: dragnet-ransomware-2024-0847 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 381913ce-8907-5528-aded-2e75c66d9ea9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
