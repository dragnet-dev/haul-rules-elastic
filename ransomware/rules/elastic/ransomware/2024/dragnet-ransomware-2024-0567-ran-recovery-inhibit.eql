// Dragnet [Ransomware]: dragnet-ransomware-2024-0567 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: d3807ed0-d932-501d-b726-3f2a4f3843dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
