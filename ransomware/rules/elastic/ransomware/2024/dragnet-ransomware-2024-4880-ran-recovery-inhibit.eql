// Dragnet [Ransomware]: dragnet-ransomware-2024-4880 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: f0b87e41-d375-5a71-8f76-6c6dc7e295b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
