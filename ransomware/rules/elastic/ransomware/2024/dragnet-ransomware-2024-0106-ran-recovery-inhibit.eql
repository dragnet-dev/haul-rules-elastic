// Dragnet [Ransomware]: dragnet-ransomware-2024-0106 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 54bc3187-3954-555a-8b26-65a0373207c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
