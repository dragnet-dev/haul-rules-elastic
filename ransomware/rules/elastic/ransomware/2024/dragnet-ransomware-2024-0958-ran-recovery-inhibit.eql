// Dragnet [Ransomware]: dragnet-ransomware-2024-0958 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 97327ac7-bfea-58a9-a048-6bd8e1cb9c0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
