// Dragnet [Ransomware]: dragnet-ransomware-2024-3360 — Recovery Inhibition (argonauts)
// Status: experimental | Level: high | ID: 183bed08-1460-56c8-a66b-5e96888d429e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
