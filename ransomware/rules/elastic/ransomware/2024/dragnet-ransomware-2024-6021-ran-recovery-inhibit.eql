// Dragnet [Ransomware]: dragnet-ransomware-2024-6021 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3bbe6288-d054-5977-b70e-6575c2ef0184

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
