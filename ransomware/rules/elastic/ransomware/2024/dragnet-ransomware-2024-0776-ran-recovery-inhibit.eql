// Dragnet [Ransomware]: dragnet-ransomware-2024-0776 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 2d1fedc3-95f2-5dfd-b79f-a1a65402c12e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
