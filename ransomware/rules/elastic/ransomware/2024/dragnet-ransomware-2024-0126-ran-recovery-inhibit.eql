// Dragnet [Ransomware]: dragnet-ransomware-2024-0126 — Recovery Inhibition (cloak)
// Status: experimental | Level: high | ID: 01a5e17c-53f5-57e7-9e43-6ac6b5211466

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
