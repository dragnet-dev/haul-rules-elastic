// Dragnet [Ransomware]: dragnet-ransomware-2024-2058 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 50594a8f-9927-5fbc-b1c7-7410e6f6b4f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
