// Dragnet [Ransomware]: dragnet-ransomware-2024-2966 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: a8c7d3ea-9978-54e5-84ef-d6c662f61d3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
