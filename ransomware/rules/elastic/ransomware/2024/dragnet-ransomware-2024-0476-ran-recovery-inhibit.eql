// Dragnet [Ransomware]: dragnet-ransomware-2024-0476 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7e7bf267-08dc-5bc8-a67f-7eb5249058e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
