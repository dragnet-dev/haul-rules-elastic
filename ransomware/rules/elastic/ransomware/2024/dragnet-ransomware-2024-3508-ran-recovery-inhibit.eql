// Dragnet [Ransomware]: dragnet-ransomware-2024-3508 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 83fbd2bb-ae01-5989-a2e1-dc06270391d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
