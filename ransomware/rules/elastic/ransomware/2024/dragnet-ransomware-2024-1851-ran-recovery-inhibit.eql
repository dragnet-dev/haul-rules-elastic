// Dragnet [Ransomware]: dragnet-ransomware-2024-1851 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: 2939f834-b282-5a27-80ba-1217507adcd3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
