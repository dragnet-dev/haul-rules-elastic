// Dragnet [Ransomware]: dragnet-ransomware-2024-3059 — Recovery Inhibition (mallox)
// Status: experimental | Level: high | ID: 476c58f6-6a61-5a28-89fe-c99b4ff7c25a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
