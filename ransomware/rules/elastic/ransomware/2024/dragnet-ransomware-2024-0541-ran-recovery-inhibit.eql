// Dragnet [Ransomware]: dragnet-ransomware-2024-0541 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 3397b546-de92-5e64-9428-da0a90e7d3e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
