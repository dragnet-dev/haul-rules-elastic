// Dragnet [Ransomware]: dragnet-ransomware-2024-5554 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 27570aa6-f730-58a3-989d-cd40f740d127

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
