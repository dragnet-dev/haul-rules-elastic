// Dragnet [Ransomware]: dragnet-ransomware-2024-1541 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 55873768-fef8-5618-ac87-8bd3939d4275

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
