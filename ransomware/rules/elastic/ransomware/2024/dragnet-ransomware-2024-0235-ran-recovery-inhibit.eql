// Dragnet [Ransomware]: dragnet-ransomware-2024-0235 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0d05887d-7215-5960-9c46-785a0db0615b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
