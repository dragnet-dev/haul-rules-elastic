// Dragnet [Ransomware]: dragnet-ransomware-2024-3716 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 5eee5568-037b-5f45-834d-208f60f186b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
