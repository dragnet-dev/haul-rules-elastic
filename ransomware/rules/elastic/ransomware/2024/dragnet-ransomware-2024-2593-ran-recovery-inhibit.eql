// Dragnet [Ransomware]: dragnet-ransomware-2024-2593 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: f869d169-680c-5833-85cb-d56cba117a59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
