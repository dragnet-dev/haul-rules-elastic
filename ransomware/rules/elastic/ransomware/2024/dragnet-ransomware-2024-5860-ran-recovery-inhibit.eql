// Dragnet [Ransomware]: dragnet-ransomware-2024-5860 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 7a764486-9318-554a-8dcd-9c40f23febac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
