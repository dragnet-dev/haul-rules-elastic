// Dragnet [Ransomware]: dragnet-ransomware-2024-2467 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: d828454c-8a58-5f95-a3be-0e49aa99b820

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
