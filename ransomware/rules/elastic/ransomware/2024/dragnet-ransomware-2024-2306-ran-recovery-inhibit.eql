// Dragnet [Ransomware]: dragnet-ransomware-2024-2306 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 00e55899-0304-5090-be25-52e6fba6bcd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
