// Dragnet [Ransomware]: dragnet-ransomware-2024-4662 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 9bc2707d-19dc-5269-b1df-efc9410b060f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
