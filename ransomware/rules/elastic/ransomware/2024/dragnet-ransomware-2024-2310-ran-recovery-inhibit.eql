// Dragnet [Ransomware]: dragnet-ransomware-2024-2310 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a2eff044-8667-5268-9577-c45443a8e714

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
