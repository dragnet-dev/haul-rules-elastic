// Dragnet [Ransomware]: dragnet-ransomware-2024-0098 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 913584e8-5282-531a-a016-1e27c3c3db5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
