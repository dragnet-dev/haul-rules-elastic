// Dragnet [Ransomware]: dragnet-ransomware-2024-2516 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: cf1f6a9c-cbbf-5027-b7b6-70e338172c76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
