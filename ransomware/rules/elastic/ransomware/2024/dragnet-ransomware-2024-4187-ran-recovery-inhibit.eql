// Dragnet [Ransomware]: dragnet-ransomware-2024-4187 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 21d93f22-6728-5c3a-a212-b041fe7f5692

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
