// Dragnet [Ransomware]: dragnet-ransomware-2024-1535 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 10929a25-079e-5039-b7c9-87bf3807f21a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
