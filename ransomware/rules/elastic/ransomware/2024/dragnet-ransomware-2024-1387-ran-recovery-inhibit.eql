// Dragnet [Ransomware]: dragnet-ransomware-2024-1387 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 944fe399-e582-5b17-8dab-5898908544ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
