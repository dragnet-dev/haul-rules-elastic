// Dragnet [Ransomware]: dragnet-ransomware-2024-1121 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c4e586b1-e1e5-5fa9-8c55-2d5abbb2b812

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
