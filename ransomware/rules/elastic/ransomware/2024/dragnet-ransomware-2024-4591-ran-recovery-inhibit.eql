// Dragnet [Ransomware]: dragnet-ransomware-2024-4591 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 67abcd46-6c6b-5d76-9b04-6fede5220c0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
