// Dragnet [Ransomware]: dragnet-ransomware-2024-4286 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0d038b22-250d-5557-8efc-a4faa7975555

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
