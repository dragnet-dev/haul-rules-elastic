// Dragnet [Ransomware]: dragnet-ransomware-2024-1524 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 58595f93-ee2d-5ece-8105-77fc293f4493

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
