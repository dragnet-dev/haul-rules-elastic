// Dragnet [Ransomware]: dragnet-ransomware-2024-1558 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: c9ea99db-8871-5e6a-a812-5d82cf55558b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
