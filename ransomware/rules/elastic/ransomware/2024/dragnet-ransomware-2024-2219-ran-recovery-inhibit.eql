// Dragnet [Ransomware]: dragnet-ransomware-2024-2219 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: b406b477-160a-5f70-8dea-848e99395622

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
