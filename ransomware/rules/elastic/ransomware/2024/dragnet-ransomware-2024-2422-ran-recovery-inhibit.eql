// Dragnet [Ransomware]: dragnet-ransomware-2024-2422 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1e4cf86a-38d7-5adb-9cf4-f674cc40130f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
