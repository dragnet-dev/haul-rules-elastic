// Dragnet [Ransomware]: dragnet-ransomware-2024-2013 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a3293475-74a5-5401-83c9-980f0e39b889

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
