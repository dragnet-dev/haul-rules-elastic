// Dragnet [Ransomware]: dragnet-ransomware-2024-0439 — Recovery Inhibition (redransomware)
// Status: deprecated | Level: high | ID: da86009f-de3d-5afe-aa2f-86454a5951a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
