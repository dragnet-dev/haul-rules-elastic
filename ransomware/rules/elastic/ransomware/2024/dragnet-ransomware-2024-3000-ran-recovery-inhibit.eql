// Dragnet [Ransomware]: dragnet-ransomware-2024-3000 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 28c98932-8423-5747-a7c5-4b4aa8971aef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
