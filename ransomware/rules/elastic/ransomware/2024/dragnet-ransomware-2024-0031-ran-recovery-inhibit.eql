// Dragnet [Ransomware]: dragnet-ransomware-2024-0031 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 8b77eb05-6e2b-5165-8989-60b1a2964e14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
