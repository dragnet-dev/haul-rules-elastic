// Dragnet [Ransomware]: dragnet-ransomware-2024-3317 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 9cee409b-7fad-5961-8dbd-71931ad71b58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
