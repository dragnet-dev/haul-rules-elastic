// Dragnet [Ransomware]: dragnet-ransomware-2024-5465 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ee310157-1a72-5dcf-b6b0-2fdd89518668

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
