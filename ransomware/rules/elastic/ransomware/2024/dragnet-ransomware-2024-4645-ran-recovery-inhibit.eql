// Dragnet [Ransomware]: dragnet-ransomware-2024-4645 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 27cbefea-11cf-59b4-9fc0-f1ebb40abc00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
