// Dragnet [Ransomware]: dragnet-ransomware-2024-4199 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 56164941-6341-529e-bef9-7c622cd056e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
