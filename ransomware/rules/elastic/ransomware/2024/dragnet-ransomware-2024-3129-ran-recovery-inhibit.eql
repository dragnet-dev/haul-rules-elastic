// Dragnet [Ransomware]: dragnet-ransomware-2024-3129 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: baadebb6-8596-5e41-8a62-49562dc8db84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
