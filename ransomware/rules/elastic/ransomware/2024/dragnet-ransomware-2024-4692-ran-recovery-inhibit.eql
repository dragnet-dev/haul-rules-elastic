// Dragnet [Ransomware]: dragnet-ransomware-2024-4692 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 1ca2d954-eb66-50e4-b07a-98e032461475

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
