// Dragnet [Ransomware]: dragnet-ransomware-2024-5694 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 033386d8-d388-52bc-9291-d5a533b3de7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
