// Dragnet [Ransomware]: dragnet-ransomware-2024-3564 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 61afab78-dfad-5f5c-b55b-9b03f19b079a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
