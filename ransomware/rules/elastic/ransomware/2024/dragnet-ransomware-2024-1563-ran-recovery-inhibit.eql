// Dragnet [Ransomware]: dragnet-ransomware-2024-1563 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 3cd3060b-c29a-5961-8c9b-8cba1d799309

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
