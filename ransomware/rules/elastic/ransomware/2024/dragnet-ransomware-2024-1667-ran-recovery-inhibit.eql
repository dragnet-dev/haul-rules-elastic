// Dragnet [Ransomware]: dragnet-ransomware-2024-1667 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 78a817a0-a824-54cc-9b4b-0ce3b0ab04cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
