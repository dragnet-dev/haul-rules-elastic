// Dragnet [Ransomware]: dragnet-ransomware-2024-5489 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a8b0b700-8302-5f55-8df5-8631359e75ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
