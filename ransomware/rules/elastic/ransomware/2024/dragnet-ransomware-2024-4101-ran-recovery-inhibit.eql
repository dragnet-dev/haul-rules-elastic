// Dragnet [Ransomware]: dragnet-ransomware-2024-4101 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 60cc1c1b-1f46-5919-89b8-e31dfa19c8b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
