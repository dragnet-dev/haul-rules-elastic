// Dragnet [Ransomware]: dragnet-ransomware-2024-3133 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 3e6fa5f9-648b-5304-aaca-ecaa159c1d9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
