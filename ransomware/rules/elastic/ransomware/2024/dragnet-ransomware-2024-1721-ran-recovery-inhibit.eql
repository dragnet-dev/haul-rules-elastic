// Dragnet [Ransomware]: dragnet-ransomware-2024-1721 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 46172247-18fd-586b-8e5c-4e27e61b669a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
