// Dragnet [Ransomware]: dragnet-ransomware-2024-5328 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 86156e4a-f929-5130-86ea-d0395d256a68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
