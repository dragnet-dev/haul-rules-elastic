// Dragnet [Ransomware]: dragnet-ransomware-2024-1067 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 7cb1c6e5-ee37-54cc-a7eb-8b263bd4aa2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
