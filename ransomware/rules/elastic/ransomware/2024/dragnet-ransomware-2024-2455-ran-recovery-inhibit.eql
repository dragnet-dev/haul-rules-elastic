// Dragnet [Ransomware]: dragnet-ransomware-2024-2455 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3b0c09c3-f61b-59d2-a76e-f5a30b2519c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
