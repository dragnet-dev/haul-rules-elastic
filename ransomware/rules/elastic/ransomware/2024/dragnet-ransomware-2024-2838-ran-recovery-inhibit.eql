// Dragnet [Ransomware]: dragnet-ransomware-2024-2838 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: e8ceca48-6828-5cd1-a22d-85b4a79def54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
