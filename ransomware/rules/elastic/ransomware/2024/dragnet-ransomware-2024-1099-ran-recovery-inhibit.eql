// Dragnet [Ransomware]: dragnet-ransomware-2024-1099 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: ad26038a-b61e-5a82-b792-e620a940210d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
