// Dragnet [Ransomware]: dragnet-ransomware-2024-1918 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0cc82c39-129d-5756-a47f-9c229e3dfbc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
