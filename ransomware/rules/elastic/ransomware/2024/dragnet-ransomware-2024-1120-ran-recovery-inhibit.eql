// Dragnet [Ransomware]: dragnet-ransomware-2024-1120 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 45d15c48-bfe3-5a10-87fd-1316748ee4d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
