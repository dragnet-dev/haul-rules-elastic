// Dragnet [Ransomware]: dragnet-ransomware-2024-4285 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 1f45a49b-d6f3-5dce-a81a-f00ee905e42b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
