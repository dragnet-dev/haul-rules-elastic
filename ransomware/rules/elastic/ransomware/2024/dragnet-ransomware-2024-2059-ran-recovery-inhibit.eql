// Dragnet [Ransomware]: dragnet-ransomware-2024-2059 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e2bce545-3782-59da-942a-e07d55a8b621

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
