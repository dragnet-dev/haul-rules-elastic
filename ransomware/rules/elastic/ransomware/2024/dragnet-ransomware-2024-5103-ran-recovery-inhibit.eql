// Dragnet [Ransomware]: dragnet-ransomware-2024-5103 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0a8b58c1-f234-5bec-9368-bbbc094cb241

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
