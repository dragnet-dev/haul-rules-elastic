// Dragnet [Ransomware]: dragnet-ransomware-2024-0113 — Recovery Inhibition (orca)
// Status: experimental | Level: high | ID: ad66d516-d23b-5011-bc34-c99aeb705a91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
