// Dragnet [Ransomware]: dragnet-ransomware-2024-5949 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f28dc9df-400d-5e6b-9c46-addeda03b9c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
