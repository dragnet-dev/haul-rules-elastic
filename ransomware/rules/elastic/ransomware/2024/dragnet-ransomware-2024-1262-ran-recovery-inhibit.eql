// Dragnet [Ransomware]: dragnet-ransomware-2024-1262 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 802b6cb6-dd78-5091-ac58-5100d2d97b4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
