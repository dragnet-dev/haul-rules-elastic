// Dragnet [Ransomware]: dragnet-ransomware-2024-0734 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6bac907b-82e7-5725-b67b-f64bcbe9bd63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
