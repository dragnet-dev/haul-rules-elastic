// Dragnet [Ransomware]: dragnet-ransomware-2024-4435 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: c93e2a01-b74e-5cf7-b9ec-f7e22e29ffe2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
