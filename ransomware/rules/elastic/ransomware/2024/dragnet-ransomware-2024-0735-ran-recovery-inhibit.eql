// Dragnet [Ransomware]: dragnet-ransomware-2024-0735 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 0d049543-b486-5c24-a15e-e5d13715172c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
