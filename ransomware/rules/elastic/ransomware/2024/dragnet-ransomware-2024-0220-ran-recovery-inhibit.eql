// Dragnet [Ransomware]: dragnet-ransomware-2024-0220 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: ccef094f-60e5-5644-a7f4-7005709b0ebe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
