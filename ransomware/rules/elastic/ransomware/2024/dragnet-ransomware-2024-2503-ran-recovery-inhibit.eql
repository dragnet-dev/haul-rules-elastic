// Dragnet [Ransomware]: dragnet-ransomware-2024-2503 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: bf422d61-14f0-5117-bafc-87e78e980bb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
