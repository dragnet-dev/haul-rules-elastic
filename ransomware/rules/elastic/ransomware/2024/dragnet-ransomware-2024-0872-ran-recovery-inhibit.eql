// Dragnet [Ransomware]: dragnet-ransomware-2024-0872 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: f70f4f24-026d-53eb-b483-8f9c2a0f915f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
