// Dragnet [Ransomware]: dragnet-ransomware-2024-2726 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6c9a4ae2-a0c3-5197-ba49-92573e20bbca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
