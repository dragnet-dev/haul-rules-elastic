// Dragnet [Ransomware]: dragnet-ransomware-2024-5411 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0d3805bf-643d-57ec-9fa3-16463cef99db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
