// Dragnet [Ransomware]: dragnet-ransomware-2024-3679 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 78a64bfa-8ff1-5d1b-ad1f-e11dcc72c7a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
