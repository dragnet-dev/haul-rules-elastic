// Dragnet [Ransomware]: dragnet-ransomware-2024-0479 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 502c7bf1-fd07-53c0-9517-959be4931996

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
