// Dragnet [Ransomware]: dragnet-ransomware-2024-2401 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 4f9d652e-5497-555e-b28c-9a0c0e1f22e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
