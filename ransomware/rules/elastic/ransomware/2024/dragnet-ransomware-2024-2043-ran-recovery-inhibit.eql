// Dragnet [Ransomware]: dragnet-ransomware-2024-2043 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a2df15e7-f4e0-5112-b06a-fdfd7bed7627

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
