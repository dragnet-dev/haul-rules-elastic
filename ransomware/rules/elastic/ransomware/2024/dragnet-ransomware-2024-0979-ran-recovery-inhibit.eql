// Dragnet [Ransomware]: dragnet-ransomware-2024-0979 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 26237460-0e6e-500b-9aff-557ca76e99c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
