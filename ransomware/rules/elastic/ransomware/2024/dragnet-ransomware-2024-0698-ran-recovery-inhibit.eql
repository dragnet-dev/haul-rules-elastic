// Dragnet [Ransomware]: dragnet-ransomware-2024-0698 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 394d67e0-b7f8-5e1b-821e-53e527a2c081

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
