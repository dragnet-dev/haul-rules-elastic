// Dragnet [Ransomware]: dragnet-ransomware-2024-0644 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 8d0530a0-cc6b-5113-b5ec-3a76cb384fcf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
