// Dragnet [Ransomware]: dragnet-ransomware-2024-0459 — Recovery Inhibition (daixin)
// Status: deprecated | Level: high | ID: 441c505a-fdf6-5c31-8e93-4d0caa1393c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
