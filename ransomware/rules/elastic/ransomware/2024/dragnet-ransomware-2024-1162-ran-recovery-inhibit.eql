// Dragnet [Ransomware]: dragnet-ransomware-2024-1162 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: b1980e04-bb22-55c9-bff6-80d551820143

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
