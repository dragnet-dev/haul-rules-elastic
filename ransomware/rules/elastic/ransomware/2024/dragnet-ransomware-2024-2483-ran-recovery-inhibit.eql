// Dragnet [Ransomware]: dragnet-ransomware-2024-2483 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 7b10f4a2-9163-5870-9501-0597eadb67e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
