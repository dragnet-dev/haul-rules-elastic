// Dragnet [Ransomware]: dragnet-ransomware-2024-3057 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 46fd9dbd-362a-5a12-885b-c64337d792d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
