// Dragnet [Ransomware]: dragnet-ransomware-2024-4774 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ba62257d-63cf-5e0b-8413-73fdb9cc5888

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
