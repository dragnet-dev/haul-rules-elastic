// Dragnet [Ransomware]: dragnet-ransomware-2024-1154 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 8100980c-26ec-529d-9934-4b40b3a727be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
