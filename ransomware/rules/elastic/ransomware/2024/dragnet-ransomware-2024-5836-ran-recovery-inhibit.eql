// Dragnet [Ransomware]: dragnet-ransomware-2024-5836 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f9ccdf22-ac87-589a-8090-af8f244e47f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
