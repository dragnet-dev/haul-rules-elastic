// Dragnet [Ransomware]: dragnet-ransomware-2024-5772 — Recovery Inhibition (underground)
// Status: experimental | Level: high | ID: 88dfe494-c025-559d-907c-a10f39211848

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
