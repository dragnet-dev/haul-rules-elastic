// Dragnet [Ransomware]: dragnet-ransomware-2024-3501 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: c089c443-3e6c-510b-b788-827a352ce17b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
