// Dragnet [Ransomware]: dragnet-ransomware-2024-2382 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: ee0d4046-e423-5e1e-965f-29483e4c53f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
