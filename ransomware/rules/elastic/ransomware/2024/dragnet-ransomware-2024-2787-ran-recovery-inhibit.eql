// Dragnet [Ransomware]: dragnet-ransomware-2024-2787 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 3689f2e3-9f28-59fa-bb2c-eb22beb88433

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
