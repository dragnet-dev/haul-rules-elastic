// Dragnet [Ransomware]: dragnet-ransomware-2024-0001 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0b1893f7-447c-5143-971d-c879abbddb1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
