// Dragnet [Ransomware]: dragnet-ransomware-2024-0081 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 73e32b4f-4dc3-5ed7-830e-6c27f12523ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
