// Dragnet [Ransomware]: dragnet-ransomware-2024-4477 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 25f0b38a-2970-577b-aeb5-4d06103f5843

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
