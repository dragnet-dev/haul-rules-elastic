// Dragnet [Ransomware]: dragnet-ransomware-2024-1775 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: cd4c441c-4048-58ee-ae6c-ec2a3bbcda2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
