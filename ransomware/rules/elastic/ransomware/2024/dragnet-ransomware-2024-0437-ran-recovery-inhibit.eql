// Dragnet [Ransomware]: dragnet-ransomware-2024-0437 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 44eafff4-eb79-5544-8b2e-1cc0f0a6ba75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
