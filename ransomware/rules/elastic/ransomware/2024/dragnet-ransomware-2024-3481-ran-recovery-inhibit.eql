// Dragnet [Ransomware]: dragnet-ransomware-2024-3481 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9a5a13c9-b1cc-5d63-9db5-6bfc6108df1f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
