// Dragnet [Ransomware]: dragnet-ransomware-2024-5773 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: f51393cb-abda-5a21-8e8c-d289e3cac2a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
