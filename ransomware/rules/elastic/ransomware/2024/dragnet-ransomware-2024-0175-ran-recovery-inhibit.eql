// Dragnet [Ransomware]: dragnet-ransomware-2024-0175 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: c432cdb4-9adf-51f6-bb02-3576e82c9e24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
