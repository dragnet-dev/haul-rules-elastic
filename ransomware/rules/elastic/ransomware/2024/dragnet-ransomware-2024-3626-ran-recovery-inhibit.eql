// Dragnet [Ransomware]: dragnet-ransomware-2024-3626 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: fda4aa82-76c3-586b-a658-49b18ab90f54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
