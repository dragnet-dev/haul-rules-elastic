// Dragnet [Ransomware]: dragnet-ransomware-2024-3030 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 33b8392d-6c70-5be8-aadf-be81fd21b141

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
