// Dragnet [Ransomware]: dragnet-ransomware-2024-0808 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: f1ae494b-8485-526d-ba03-46bc357758ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
