// Dragnet [Ransomware]: dragnet-ransomware-2024-0627 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 89cdb67d-b714-5cab-8810-365c5d6b75e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
