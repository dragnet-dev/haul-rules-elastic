// Dragnet [Ransomware]: dragnet-ransomware-2024-4244 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 65e07766-0a1c-5391-ba94-4318bd087f74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
