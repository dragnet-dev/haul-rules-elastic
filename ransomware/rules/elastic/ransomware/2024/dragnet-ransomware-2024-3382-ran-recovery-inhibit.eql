// Dragnet [Ransomware]: dragnet-ransomware-2024-3382 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7ae012e2-3db3-57d1-ab12-72f14e675909

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
