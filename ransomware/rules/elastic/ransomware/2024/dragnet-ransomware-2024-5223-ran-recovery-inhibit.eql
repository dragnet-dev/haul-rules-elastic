// Dragnet [Ransomware]: dragnet-ransomware-2024-5223 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4b197f32-7e36-5b3e-b7b7-d82631040b1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
