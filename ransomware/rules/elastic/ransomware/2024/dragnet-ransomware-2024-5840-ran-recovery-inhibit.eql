// Dragnet [Ransomware]: dragnet-ransomware-2024-5840 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: b2d10a08-5562-5b27-91e0-4141df773d87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
