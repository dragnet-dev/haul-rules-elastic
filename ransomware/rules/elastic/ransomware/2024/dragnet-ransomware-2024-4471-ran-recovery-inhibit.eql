// Dragnet [Ransomware]: dragnet-ransomware-2024-4471 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: b7bb4f2b-c30e-51e4-89f3-06201000456e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
