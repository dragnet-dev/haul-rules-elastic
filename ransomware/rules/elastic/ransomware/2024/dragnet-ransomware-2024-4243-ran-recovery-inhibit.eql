// Dragnet [Ransomware]: dragnet-ransomware-2024-4243 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 6ce7678b-010a-5a66-92ee-aef5994289cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
