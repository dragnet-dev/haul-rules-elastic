// Dragnet [Ransomware]: dragnet-ransomware-2024-1784 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c6199b4a-8db6-53ee-a646-9e3d0b7c8574

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
