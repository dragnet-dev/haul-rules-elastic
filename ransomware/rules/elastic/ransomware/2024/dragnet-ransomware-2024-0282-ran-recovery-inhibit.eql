// Dragnet [Ransomware]: dragnet-ransomware-2024-0282 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 4f2efe25-e749-57ef-94aa-2567280bf5d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
