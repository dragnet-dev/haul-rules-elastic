// Dragnet [Ransomware]: dragnet-ransomware-2024-5849 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 7d031afa-bcbe-546b-a5c2-85a4807a87b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
