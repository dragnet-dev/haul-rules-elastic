// Dragnet [Ransomware]: dragnet-ransomware-2024-4599 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0f8aaa34-4eb2-5be5-8d0e-bf4c10b91ae3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
