// Dragnet [Ransomware]: dragnet-ransomware-2024-2504 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 806d16df-88e3-57e3-a6f0-025478052f16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
