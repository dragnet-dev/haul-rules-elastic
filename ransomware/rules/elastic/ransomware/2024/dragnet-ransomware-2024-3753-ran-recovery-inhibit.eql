// Dragnet [Ransomware]: dragnet-ransomware-2024-3753 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: d3bfb18b-acd6-5891-8b18-969a72190186

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
