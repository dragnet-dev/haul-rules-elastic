// Dragnet [Ransomware]: dragnet-ransomware-2024-1460 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: edb078de-8199-5274-b714-3406bf1bc2ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
