// Dragnet [Ransomware]: dragnet-ransomware-2024-2423 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 021718c3-8f5b-56e4-a123-5a3192143515

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
