// Dragnet [Ransomware]: dragnet-ransomware-2024-2186 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ffd1f709-96d4-5202-af66-add0bf262554

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
