// Dragnet [Ransomware]: dragnet-ransomware-2024-3544 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a63652b1-bf9c-58a0-9d91-97d55d4d120d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
