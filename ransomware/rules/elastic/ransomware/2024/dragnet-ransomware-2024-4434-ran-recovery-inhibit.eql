// Dragnet [Ransomware]: dragnet-ransomware-2024-4434 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 75aa11c8-03db-567c-98ca-e7487074b447

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
