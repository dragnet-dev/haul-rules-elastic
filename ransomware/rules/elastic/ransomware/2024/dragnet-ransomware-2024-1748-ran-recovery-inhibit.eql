// Dragnet [Ransomware]: dragnet-ransomware-2024-1748 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: abccd623-2e04-5a1f-b961-a3da69386f2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
