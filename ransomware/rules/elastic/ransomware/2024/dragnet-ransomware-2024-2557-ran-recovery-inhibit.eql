// Dragnet [Ransomware]: dragnet-ransomware-2024-2557 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 7ef93074-87f2-5eec-8b00-119adddd4bf6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
