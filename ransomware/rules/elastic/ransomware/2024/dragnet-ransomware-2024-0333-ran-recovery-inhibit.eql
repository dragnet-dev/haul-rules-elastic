// Dragnet [Ransomware]: dragnet-ransomware-2024-0333 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 0984ce03-493e-5393-a298-870e452a2c07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
