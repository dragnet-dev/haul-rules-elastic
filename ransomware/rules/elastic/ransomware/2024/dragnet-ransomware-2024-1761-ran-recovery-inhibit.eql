// Dragnet [Ransomware]: dragnet-ransomware-2024-1761 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 92fcd021-d8a6-5353-84b3-44ad21f8e38e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
