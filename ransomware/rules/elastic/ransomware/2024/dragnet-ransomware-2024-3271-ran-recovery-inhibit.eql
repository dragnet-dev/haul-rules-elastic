// Dragnet [Ransomware]: dragnet-ransomware-2024-3271 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2c1f584e-095e-5640-95f7-83426b74edf6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
