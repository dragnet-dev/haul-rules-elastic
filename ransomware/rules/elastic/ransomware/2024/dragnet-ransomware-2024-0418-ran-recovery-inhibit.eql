// Dragnet [Ransomware]: dragnet-ransomware-2024-0418 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 313f3798-6526-5d47-86f7-8a321a1270d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
