// Dragnet [Ransomware]: dragnet-ransomware-2024-4685 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 5fa4ea36-d85d-5877-8827-37e4468d19ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
