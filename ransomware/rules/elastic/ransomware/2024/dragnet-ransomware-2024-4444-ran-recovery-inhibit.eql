// Dragnet [Ransomware]: dragnet-ransomware-2024-4444 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 6e0d4f0e-f149-5c1d-a199-3b9c54b5db7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
