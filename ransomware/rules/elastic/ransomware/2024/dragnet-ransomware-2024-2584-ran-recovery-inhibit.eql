// Dragnet [Ransomware]: dragnet-ransomware-2024-2584 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 27712b6a-3cc0-5068-90b7-444fb3d63ca7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
