// Dragnet [Ransomware]: dragnet-ransomware-2024-3401 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: b3f04afb-92f6-5816-bf3d-f71c3b57bb39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
