// Dragnet [Ransomware]: dragnet-ransomware-2024-0458 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 38e72730-dc77-5bdc-b7ae-add6b796d349

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
