// Dragnet [Ransomware]: dragnet-ransomware-2024-4129 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 80be833c-dd9e-5baa-995b-9652390a21aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
