// Dragnet [Ransomware]: dragnet-ransomware-2024-4224 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: af8396fb-27ed-5487-919f-c8cca36d0135

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
