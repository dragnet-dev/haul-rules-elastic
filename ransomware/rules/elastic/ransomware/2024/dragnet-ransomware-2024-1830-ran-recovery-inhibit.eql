// Dragnet [Ransomware]: dragnet-ransomware-2024-1830 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: a4533013-5811-5db6-a074-4a54a1785fc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
