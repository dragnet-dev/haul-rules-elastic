// Dragnet [Ransomware]: dragnet-ransomware-2024-0910 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 279bb991-f8aa-571b-9d30-bf662e739095

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
