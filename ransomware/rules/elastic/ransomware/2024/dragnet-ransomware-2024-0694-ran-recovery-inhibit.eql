// Dragnet [Ransomware]: dragnet-ransomware-2024-0694 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a1ce0d48-de4a-5c50-8f9f-5da7067b7d77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
