// Dragnet [Ransomware]: dragnet-ransomware-2024-3398 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: c6824953-041b-53c1-a360-12e78015e03d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
