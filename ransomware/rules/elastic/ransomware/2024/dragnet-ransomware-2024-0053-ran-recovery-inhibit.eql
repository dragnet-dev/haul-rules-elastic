// Dragnet [Ransomware]: dragnet-ransomware-2024-0053 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 75032296-433e-5536-9f39-ad8636647a69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
