// Dragnet [Ransomware]: dragnet-ransomware-2024-0529 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 1322995b-07db-5734-aef5-58b0cf94fa1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
