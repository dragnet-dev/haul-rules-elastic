// Dragnet [Ransomware]: dragnet-ransomware-2024-2272 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 62128963-342b-5431-87e6-5b09c402b0cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
