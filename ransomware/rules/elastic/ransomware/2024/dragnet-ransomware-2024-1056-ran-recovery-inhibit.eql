// Dragnet [Ransomware]: dragnet-ransomware-2024-1056 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 3a55a571-c338-508d-9cb6-632009aa32dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
