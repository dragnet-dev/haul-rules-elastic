// Dragnet [Ransomware]: dragnet-ransomware-2024-4469 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 5b7504d8-a892-5d8f-8d98-4861e7a7a908

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
