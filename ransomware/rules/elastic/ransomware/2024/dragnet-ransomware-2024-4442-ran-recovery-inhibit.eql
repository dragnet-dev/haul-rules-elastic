// Dragnet [Ransomware]: dragnet-ransomware-2024-4442 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: b0837c07-b123-5a14-9d57-5e9c2d3e1a58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
