// Dragnet [Ransomware]: dragnet-ransomware-2024-3966 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: e17cd973-daa9-5446-b5af-f60be640ea3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
