// Dragnet [Ransomware]: dragnet-ransomware-2024-5106 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3c2380cd-523d-57c0-a4ef-ed8180e5d6e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
