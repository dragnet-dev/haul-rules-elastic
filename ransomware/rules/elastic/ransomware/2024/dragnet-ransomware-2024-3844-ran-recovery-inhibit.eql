// Dragnet [Ransomware]: dragnet-ransomware-2024-3844 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 7283e584-c8f0-55d7-80a3-6b7bc789ec5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
