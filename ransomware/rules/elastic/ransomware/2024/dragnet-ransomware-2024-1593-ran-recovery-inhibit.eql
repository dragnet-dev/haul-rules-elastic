// Dragnet [Ransomware]: dragnet-ransomware-2024-1593 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 4bb29872-8b59-5712-9a36-56f588a75aab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
