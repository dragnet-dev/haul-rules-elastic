// Dragnet [Ransomware]: dragnet-ransomware-2024-5645 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 9b399464-f13f-5b29-901a-76bbc6cc7a29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
