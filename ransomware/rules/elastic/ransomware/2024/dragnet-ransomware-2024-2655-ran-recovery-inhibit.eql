// Dragnet [Ransomware]: dragnet-ransomware-2024-2655 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 907f3b83-ffc1-5497-92c3-cda59678db24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
