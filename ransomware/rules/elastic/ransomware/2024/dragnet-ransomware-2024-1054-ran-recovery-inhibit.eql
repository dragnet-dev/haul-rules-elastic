// Dragnet [Ransomware]: dragnet-ransomware-2024-1054 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f890e63d-0791-557b-ad64-5628b7040e9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
