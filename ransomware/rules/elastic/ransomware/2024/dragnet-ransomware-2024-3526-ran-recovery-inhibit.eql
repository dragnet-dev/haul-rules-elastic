// Dragnet [Ransomware]: dragnet-ransomware-2024-3526 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 66f9106b-3909-510a-80e3-0d7df800e7c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
