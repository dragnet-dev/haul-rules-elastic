// Dragnet [Ransomware]: dragnet-ransomware-2024-6013 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: f2c082e1-349b-5341-96fd-644afb9a94d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
