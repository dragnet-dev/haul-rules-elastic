// Dragnet [Ransomware]: dragnet-ransomware-2024-0290 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 0124aa82-c437-5208-876b-a71c060f02e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
