// Dragnet [Ransomware]: dragnet-ransomware-2024-2326 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 06e5a4f9-0f91-5c62-9c2f-487bbf779d82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
