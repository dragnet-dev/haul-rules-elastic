// Dragnet [Ransomware]: dragnet-ransomware-2024-5100 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 5cea53d6-28d5-5f51-96c8-6f9db9787530

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
