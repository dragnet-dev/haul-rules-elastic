// Dragnet [Ransomware]: dragnet-ransomware-2024-3418 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: ba666cbf-f59c-5fb7-9e2c-23f61583e958

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
