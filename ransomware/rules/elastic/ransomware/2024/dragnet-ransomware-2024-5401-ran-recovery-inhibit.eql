// Dragnet [Ransomware]: dragnet-ransomware-2024-5401 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 79384b76-6bdb-5e46-8cd2-c2b328e689b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
