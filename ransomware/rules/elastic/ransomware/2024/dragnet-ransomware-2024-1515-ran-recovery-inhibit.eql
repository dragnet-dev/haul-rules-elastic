// Dragnet [Ransomware]: dragnet-ransomware-2024-1515 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 79a2db92-f35c-5d5d-afe0-97d480d36b09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
