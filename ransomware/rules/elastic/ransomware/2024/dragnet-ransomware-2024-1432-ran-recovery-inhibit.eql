// Dragnet [Ransomware]: dragnet-ransomware-2024-1432 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3674c412-e049-5c8d-b20f-a96923416fec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
