// Dragnet [Ransomware]: dragnet-ransomware-2024-1598 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: c703bea4-be35-5751-a954-22c6dca6f1b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
