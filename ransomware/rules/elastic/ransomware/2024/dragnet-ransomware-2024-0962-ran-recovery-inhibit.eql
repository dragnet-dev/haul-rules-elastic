// Dragnet [Ransomware]: dragnet-ransomware-2024-0962 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 28064d82-fb5f-59be-8685-10dba4cb0a14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
