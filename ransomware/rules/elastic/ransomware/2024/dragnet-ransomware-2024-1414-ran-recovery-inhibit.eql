// Dragnet [Ransomware]: dragnet-ransomware-2024-1414 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 168853f8-317d-5665-b15b-56d1f5579a41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
