// Dragnet [Ransomware]: dragnet-ransomware-2024-5657 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 22ccc5b9-839d-5a75-892d-eb686322e81e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
