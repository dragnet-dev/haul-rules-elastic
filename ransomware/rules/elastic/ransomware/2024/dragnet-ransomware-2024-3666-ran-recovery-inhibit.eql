// Dragnet [Ransomware]: dragnet-ransomware-2024-3666 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 180ac4f0-807a-52a8-814d-450f7aa1d9db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
