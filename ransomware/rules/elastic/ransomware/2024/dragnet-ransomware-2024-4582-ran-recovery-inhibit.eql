// Dragnet [Ransomware]: dragnet-ransomware-2024-4582 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 10249e41-2bff-5602-be9f-014c2909f562

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
