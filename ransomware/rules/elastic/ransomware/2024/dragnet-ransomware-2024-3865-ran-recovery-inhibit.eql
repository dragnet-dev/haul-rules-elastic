// Dragnet [Ransomware]: dragnet-ransomware-2024-3865 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 9c2e2458-708e-52a7-a708-eb052670fef0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
