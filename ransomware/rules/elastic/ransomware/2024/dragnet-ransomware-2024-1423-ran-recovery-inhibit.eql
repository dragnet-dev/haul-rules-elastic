// Dragnet [Ransomware]: dragnet-ransomware-2024-1423 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3fc2fa79-b34d-5b18-a3ee-2377ab1b9039

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
