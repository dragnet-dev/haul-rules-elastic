// Dragnet [Ransomware]: dragnet-ransomware-2024-3313 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2d4f990d-ece6-5f97-8759-d9124765ec58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
