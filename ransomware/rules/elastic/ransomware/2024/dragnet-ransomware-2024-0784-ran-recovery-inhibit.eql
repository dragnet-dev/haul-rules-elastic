// Dragnet [Ransomware]: dragnet-ransomware-2024-0784 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: fee13551-9a81-5db3-937e-92f399e69ac1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
