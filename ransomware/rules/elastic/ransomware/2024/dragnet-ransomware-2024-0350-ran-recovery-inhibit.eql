// Dragnet [Ransomware]: dragnet-ransomware-2024-0350 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f5df045a-71ff-5fe2-a3b4-ce240795a914

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
