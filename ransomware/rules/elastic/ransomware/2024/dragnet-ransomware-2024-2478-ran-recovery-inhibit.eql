// Dragnet [Ransomware]: dragnet-ransomware-2024-2478 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 5f73b7bb-3a88-5dda-8261-2f5dc358d6ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
