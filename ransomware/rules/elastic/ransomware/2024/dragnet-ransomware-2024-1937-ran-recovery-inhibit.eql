// Dragnet [Ransomware]: dragnet-ransomware-2024-1937 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9a9c4ef3-5567-5e62-b5ce-f98ce3fb1cd3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
