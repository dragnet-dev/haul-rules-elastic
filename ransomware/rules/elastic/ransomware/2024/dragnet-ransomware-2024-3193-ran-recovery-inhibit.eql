// Dragnet [Ransomware]: dragnet-ransomware-2024-3193 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 6d8f877e-ea02-5b29-86d6-ba8f7a2080f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
