// Dragnet [Ransomware]: dragnet-ransomware-2024-2934 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: db47ac69-8e8e-5389-982d-652ca4373501

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
