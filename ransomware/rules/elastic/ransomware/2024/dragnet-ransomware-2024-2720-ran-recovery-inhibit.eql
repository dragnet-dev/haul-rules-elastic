// Dragnet [Ransomware]: dragnet-ransomware-2024-2720 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 412300c2-1e57-5199-813d-c30b6ae76e3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
