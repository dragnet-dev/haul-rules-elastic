// Dragnet [Ransomware]: dragnet-ransomware-2024-1507 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4d21869f-cd43-5c98-b432-6811087d06d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
