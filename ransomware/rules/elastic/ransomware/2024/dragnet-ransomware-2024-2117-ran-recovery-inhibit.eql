// Dragnet [Ransomware]: dragnet-ransomware-2024-2117 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6eab2e20-827c-5698-85a3-12a442b66b66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
