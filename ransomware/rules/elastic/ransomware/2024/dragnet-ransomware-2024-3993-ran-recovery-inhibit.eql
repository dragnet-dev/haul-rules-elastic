// Dragnet [Ransomware]: dragnet-ransomware-2024-3993 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: f365a04d-35c1-5147-ad68-b098710bb1fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
