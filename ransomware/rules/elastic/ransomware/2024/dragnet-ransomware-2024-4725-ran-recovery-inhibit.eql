// Dragnet [Ransomware]: dragnet-ransomware-2024-4725 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 61dd0568-6d3b-5ea6-bcf9-73fadbd9acf1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
