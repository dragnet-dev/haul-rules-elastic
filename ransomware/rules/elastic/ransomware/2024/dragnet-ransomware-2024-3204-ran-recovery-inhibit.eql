// Dragnet [Ransomware]: dragnet-ransomware-2024-3204 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 57173dda-2d94-5327-ae8f-5cfc53e179ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
