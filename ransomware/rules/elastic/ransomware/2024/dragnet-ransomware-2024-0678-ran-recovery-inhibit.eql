// Dragnet [Ransomware]: dragnet-ransomware-2024-0678 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 89dd305d-e628-5b9b-9d16-e694456e8476

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
