// Dragnet [Ransomware]: dragnet-ransomware-2024-5683 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c1ce27cf-1df3-5cc0-ba8e-bd028c38b162

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
