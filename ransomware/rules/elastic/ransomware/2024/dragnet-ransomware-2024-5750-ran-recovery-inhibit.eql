// Dragnet [Ransomware]: dragnet-ransomware-2024-5750 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ff56c26a-2f59-5e42-ab21-fe3be103da21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
