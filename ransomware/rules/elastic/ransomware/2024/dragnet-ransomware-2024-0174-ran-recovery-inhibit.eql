// Dragnet [Ransomware]: dragnet-ransomware-2024-0174 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 207d34d5-75bf-58b0-bd06-eb317422cd9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
