// Dragnet [Ransomware]: dragnet-ransomware-2024-1701 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 05eef478-0e06-59ad-927f-64194ccdb855

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
