// Dragnet [Ransomware]: dragnet-ransomware-2024-0817 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 57eab482-d88e-5c93-a83d-a8da8a8d1beb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
