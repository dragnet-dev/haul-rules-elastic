// Dragnet [Ransomware]: dragnet-ransomware-2024-4470 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 1376fc2d-c46f-5944-9885-26c30e0acf3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
