// Dragnet [Ransomware]: dragnet-ransomware-2024-5506 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9040181d-5908-5896-b36e-17428404dd0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
