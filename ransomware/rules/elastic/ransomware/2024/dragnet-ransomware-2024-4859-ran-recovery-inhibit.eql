// Dragnet [Ransomware]: dragnet-ransomware-2024-4859 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: f1316f9a-7e37-5f0d-ab44-a860fd79e26f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
