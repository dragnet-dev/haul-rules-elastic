// Dragnet [Ransomware]: dragnet-ransomware-2024-1320 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 33061b15-f740-5a68-b6a8-f0748baa52c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
