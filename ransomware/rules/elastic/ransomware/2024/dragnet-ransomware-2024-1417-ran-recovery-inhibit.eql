// Dragnet [Ransomware]: dragnet-ransomware-2024-1417 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 9d281efa-d6a2-55f9-96d8-db2542fec576

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
