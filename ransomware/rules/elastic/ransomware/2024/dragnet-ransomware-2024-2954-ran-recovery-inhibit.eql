// Dragnet [Ransomware]: dragnet-ransomware-2024-2954 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 30130437-160d-5d7f-b2ac-a26aa200b5df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
