// Dragnet [Ransomware]: dragnet-ransomware-2024-0319 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: fc225e23-ff5f-59b4-90da-3a500aa05118

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
