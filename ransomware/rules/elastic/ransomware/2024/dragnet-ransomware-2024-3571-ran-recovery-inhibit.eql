// Dragnet [Ransomware]: dragnet-ransomware-2024-3571 — Recovery Inhibition (blackout)
// Status: experimental | Level: high | ID: 21d531b3-051d-5cde-a17c-897c185871b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
