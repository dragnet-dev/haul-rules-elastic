// Dragnet [Ransomware]: dragnet-ransomware-2024-3437 — Recovery Inhibition (apos)
// Status: experimental | Level: high | ID: ae879b59-2631-576e-82fd-336b2f4f959c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
