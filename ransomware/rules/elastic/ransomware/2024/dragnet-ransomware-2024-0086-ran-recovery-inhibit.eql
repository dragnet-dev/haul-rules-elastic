// Dragnet [Ransomware]: dragnet-ransomware-2024-0086 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 9301a15e-fcb0-5f76-aa56-c3984444ea10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
