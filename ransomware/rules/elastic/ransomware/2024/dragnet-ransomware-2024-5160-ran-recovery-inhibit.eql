// Dragnet [Ransomware]: dragnet-ransomware-2024-5160 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a6c2a149-2fae-513c-b7e3-e508363cc9fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
