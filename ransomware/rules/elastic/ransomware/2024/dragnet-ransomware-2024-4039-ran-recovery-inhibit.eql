// Dragnet [Ransomware]: dragnet-ransomware-2024-4039 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 5c806877-5e0d-5a51-a7d7-901b7b3cdd96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
