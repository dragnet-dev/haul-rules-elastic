// Dragnet [Ransomware]: dragnet-ransomware-2024-0538 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 25ac826c-da94-591b-b357-057662d8bd81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
