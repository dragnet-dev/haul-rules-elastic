// Dragnet [Ransomware]: dragnet-ransomware-2024-4660 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: edb0e5e6-15bb-58e3-a48c-fa0a9c1d1e17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
