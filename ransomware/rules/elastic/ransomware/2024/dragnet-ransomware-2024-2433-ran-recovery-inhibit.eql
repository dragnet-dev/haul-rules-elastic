// Dragnet [Ransomware]: dragnet-ransomware-2024-2433 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: d4cd1365-71a9-5584-a814-40bbeb527344

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
