// Dragnet [Ransomware]: dragnet-ransomware-2024-5322 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: cb105683-9d97-5b52-a3fb-7c13ae8c060f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
