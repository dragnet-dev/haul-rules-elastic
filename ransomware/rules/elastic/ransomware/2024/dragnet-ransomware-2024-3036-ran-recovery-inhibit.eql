// Dragnet [Ransomware]: dragnet-ransomware-2024-3036 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: a64f63c0-acf2-5112-bc92-98654c109355

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
