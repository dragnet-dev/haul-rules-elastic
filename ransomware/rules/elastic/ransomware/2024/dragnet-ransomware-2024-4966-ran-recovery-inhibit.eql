// Dragnet [Ransomware]: dragnet-ransomware-2024-4966 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 9cff397a-7cae-58ad-9d5e-d028e5c5c159

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
