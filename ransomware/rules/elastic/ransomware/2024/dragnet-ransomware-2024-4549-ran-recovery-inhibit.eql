// Dragnet [Ransomware]: dragnet-ransomware-2024-4549 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7ceb8352-c826-59ce-ad75-3a4935771f70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
