// Dragnet [Ransomware]: dragnet-ransomware-2024-4316 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 98faa4cf-8fd2-50d5-8e6e-071a88bf1c98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
