// Dragnet [Ransomware]: dragnet-ransomware-2024-4993 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 338e3b02-f01e-51f9-ae2d-7a4bfdf9ebfb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
