// Dragnet [Ransomware]: dragnet-ransomware-2024-0359 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 636b5324-14df-55df-934d-ddcdb869809b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
