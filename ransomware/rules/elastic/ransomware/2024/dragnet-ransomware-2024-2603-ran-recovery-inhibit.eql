// Dragnet [Ransomware]: dragnet-ransomware-2024-2603 — Recovery Inhibition (underground)
// Status: experimental | Level: high | ID: c15ffe77-0996-5444-882c-63209dc5307b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
