// Dragnet [Ransomware]: dragnet-ransomware-2024-0632 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: b9d5632d-ffb5-5369-9f72-87591fd97c33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
