// Dragnet [Ransomware]: dragnet-ransomware-2024-3881 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 454f4be5-e9b0-5502-b9cb-15e0433ea3e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
