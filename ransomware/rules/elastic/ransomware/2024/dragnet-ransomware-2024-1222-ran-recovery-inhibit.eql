// Dragnet [Ransomware]: dragnet-ransomware-2024-1222 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f007565d-68b2-57e1-8591-aa5eb796347a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
