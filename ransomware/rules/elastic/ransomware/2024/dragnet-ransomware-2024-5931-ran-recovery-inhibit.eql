// Dragnet [Ransomware]: dragnet-ransomware-2024-5931 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5320b589-8649-58a4-90ef-fc16cbb73297

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
