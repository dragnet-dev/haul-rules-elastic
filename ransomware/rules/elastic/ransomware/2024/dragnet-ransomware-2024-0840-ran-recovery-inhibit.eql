// Dragnet [Ransomware]: dragnet-ransomware-2024-0840 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 87aa974a-8f4d-5592-965e-d20d5a9ffcec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
