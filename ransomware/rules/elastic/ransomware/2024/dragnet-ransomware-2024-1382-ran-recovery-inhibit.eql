// Dragnet [Ransomware]: dragnet-ransomware-2024-1382 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: dbe4f751-5445-5053-a047-d2851b35a843

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
