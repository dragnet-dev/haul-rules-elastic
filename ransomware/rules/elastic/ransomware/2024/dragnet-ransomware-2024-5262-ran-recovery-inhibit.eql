// Dragnet [Ransomware]: dragnet-ransomware-2024-5262 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7ccbf882-37b1-53bd-8052-a785771ee419

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
