// Dragnet [Ransomware]: dragnet-ransomware-2024-2378 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 0de110dd-5a0a-53ed-8680-1de2c58a8b15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
