// Dragnet [Ransomware]: dragnet-ransomware-2024-5444 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 45fba2e1-8f0b-5052-afc0-bb8acd5c67ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
