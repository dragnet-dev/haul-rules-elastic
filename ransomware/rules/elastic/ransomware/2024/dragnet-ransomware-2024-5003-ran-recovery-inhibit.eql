// Dragnet [Ransomware]: dragnet-ransomware-2024-5003 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 6e303523-a58c-5e06-b0bb-3d0dec1d292e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
