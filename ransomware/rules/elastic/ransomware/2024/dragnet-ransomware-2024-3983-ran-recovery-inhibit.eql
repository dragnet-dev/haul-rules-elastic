// Dragnet [Ransomware]: dragnet-ransomware-2024-3983 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: f7ed2346-d4ef-5236-aa9e-474ee1caa924

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
