// Dragnet [Ransomware]: dragnet-ransomware-2024-5501 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: c7eafe15-078a-5f60-8318-aacc5eadc6c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
