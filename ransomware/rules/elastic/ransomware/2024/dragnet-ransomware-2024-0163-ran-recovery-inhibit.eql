// Dragnet [Ransomware]: dragnet-ransomware-2024-0163 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 5c849952-f4e9-5df9-8447-93cb381aa5f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
