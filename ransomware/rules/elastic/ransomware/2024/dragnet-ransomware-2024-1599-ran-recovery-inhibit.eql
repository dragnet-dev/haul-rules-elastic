// Dragnet [Ransomware]: dragnet-ransomware-2024-1599 — Recovery Inhibition (unsafe)
// Status: deprecated | Level: high | ID: 5d4749df-bc9e-5490-be1e-593b25501526

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
