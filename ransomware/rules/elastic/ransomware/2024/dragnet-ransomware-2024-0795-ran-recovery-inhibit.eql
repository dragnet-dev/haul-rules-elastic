// Dragnet [Ransomware]: dragnet-ransomware-2024-0795 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 12da6327-d36f-5a4c-a213-3356f73cf1b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
