// Dragnet [Ransomware]: dragnet-ransomware-2024-4541 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8e7a6159-cfce-55d0-836a-79b0b1f40646

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
