// Dragnet [Ransomware]: dragnet-ransomware-2024-1354 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a244002c-62bd-531a-b4f6-644641b55e3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
