// Dragnet [Ransomware]: dragnet-ransomware-2024-1355 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 946275ab-6d77-5c7f-8265-f3bf8d05a493

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
