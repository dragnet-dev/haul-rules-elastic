// Dragnet [Ransomware]: dragnet-ransomware-2024-0528 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 75e185e4-2923-5775-9950-71bb4fde9284

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
