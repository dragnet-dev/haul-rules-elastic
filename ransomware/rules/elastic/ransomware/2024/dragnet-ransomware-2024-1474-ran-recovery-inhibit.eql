// Dragnet [Ransomware]: dragnet-ransomware-2024-1474 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 53bfed48-aece-546b-bc72-964e74cfe6cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
