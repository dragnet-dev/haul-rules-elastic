// Dragnet [Ransomware]: dragnet-ransomware-2024-2989 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 8aa8b1c2-ce41-5eea-8a5c-8c1c1bd4cb11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
