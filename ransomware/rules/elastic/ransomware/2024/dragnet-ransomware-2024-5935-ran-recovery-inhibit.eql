// Dragnet [Ransomware]: dragnet-ransomware-2024-5935 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: 4572a372-8ba2-5d38-bcc9-d53412b33e99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
