// Dragnet [Ransomware]: dragnet-ransomware-2024-4813 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: c988e087-7bdc-544a-b130-ba9ffba95c05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
