// Dragnet [Ransomware]: dragnet-ransomware-2024-3745 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 5296889c-17aa-5773-961a-8fa54699e7d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
