// Dragnet [Ransomware]: dragnet-ransomware-2024-3968 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7977fb87-41bb-505b-aeb5-135e205e0f93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
