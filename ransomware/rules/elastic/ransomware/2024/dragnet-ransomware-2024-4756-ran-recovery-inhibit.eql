// Dragnet [Ransomware]: dragnet-ransomware-2024-4756 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 850276cc-0b4a-5cfb-9108-444adfa69ab2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
