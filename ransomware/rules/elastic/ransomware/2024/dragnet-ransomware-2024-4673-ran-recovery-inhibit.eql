// Dragnet [Ransomware]: dragnet-ransomware-2024-4673 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: 6e403db2-da49-5bc8-b16e-7a6e915097a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
