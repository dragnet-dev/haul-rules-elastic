// Dragnet [Ransomware]: dragnet-ransomware-2024-5414 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: 6913ba3f-d0fa-5109-af19-30447570f483

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
