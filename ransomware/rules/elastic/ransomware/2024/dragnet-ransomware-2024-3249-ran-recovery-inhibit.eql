// Dragnet [Ransomware]: dragnet-ransomware-2024-3249 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 4fd662d4-c42f-521a-a2ea-a5bc50fc0487

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
