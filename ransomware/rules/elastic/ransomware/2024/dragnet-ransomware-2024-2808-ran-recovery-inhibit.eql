// Dragnet [Ransomware]: dragnet-ransomware-2024-2808 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 03a076e0-b1e5-5fc8-be1b-6ced8879cae8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
