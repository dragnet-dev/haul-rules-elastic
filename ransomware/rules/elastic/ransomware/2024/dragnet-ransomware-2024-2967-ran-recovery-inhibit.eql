// Dragnet [Ransomware]: dragnet-ransomware-2024-2967 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4f388716-bdda-5531-85aa-62ca95996ecb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
