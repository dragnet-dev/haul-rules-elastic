// Dragnet [Ransomware]: dragnet-ransomware-2024-3978 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 721dca2c-76e8-5ccf-af4b-5d1e91085647

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
