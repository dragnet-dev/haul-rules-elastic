// Dragnet [Ransomware]: dragnet-ransomware-2024-5335 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 564f26b5-5c0e-599d-85b3-dc0bcbebc16f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
