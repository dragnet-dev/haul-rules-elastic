// Dragnet [Ransomware]: dragnet-ransomware-2024-0118 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 453e8318-27d9-5b95-ae38-52fa24a211af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
