// Dragnet [Ransomware]: dragnet-ransomware-2024-0385 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: b5a14245-1135-5426-be3b-2f43080150ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
