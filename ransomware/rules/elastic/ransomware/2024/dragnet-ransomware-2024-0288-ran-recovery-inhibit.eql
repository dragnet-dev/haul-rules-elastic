// Dragnet [Ransomware]: dragnet-ransomware-2024-0288 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: 65101535-f961-5a68-a81d-dcf5baa4bfed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
