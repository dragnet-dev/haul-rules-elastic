// Dragnet [Ransomware]: dragnet-ransomware-2024-4467 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 1298c400-052a-59c0-b8d8-429634fde1aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
