// Dragnet [Ransomware]: dragnet-ransomware-2024-5918 — Recovery Inhibition (underground)
// Status: experimental | Level: high | ID: 50ebfff7-99b5-516c-ae9e-231818ba12ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
