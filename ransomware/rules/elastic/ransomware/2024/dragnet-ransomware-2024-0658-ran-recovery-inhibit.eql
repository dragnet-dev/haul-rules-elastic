// Dragnet [Ransomware]: dragnet-ransomware-2024-0658 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ca31ddde-db71-54ff-9082-562002319633

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
