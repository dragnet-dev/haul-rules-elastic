// Dragnet [Ransomware]: dragnet-ransomware-2024-4967 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 087d3e3e-d814-53a1-9716-d15ed71a9f96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
