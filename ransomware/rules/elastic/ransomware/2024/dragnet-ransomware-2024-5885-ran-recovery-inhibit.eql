// Dragnet [Ransomware]: dragnet-ransomware-2024-5885 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e53d9056-65e5-5716-b803-3e9eb4abaf5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
