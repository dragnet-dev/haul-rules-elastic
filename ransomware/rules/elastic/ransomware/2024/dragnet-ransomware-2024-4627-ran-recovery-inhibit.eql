// Dragnet [Ransomware]: dragnet-ransomware-2024-4627 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 2e84b0a6-51cc-56c5-b96f-fb698712d7e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
