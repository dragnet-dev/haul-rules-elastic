// Dragnet [Ransomware]: dragnet-ransomware-2024-0836 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: efb8e1e8-4364-508b-972d-a09d4ab8e52f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
