// Dragnet [Ransomware]: dragnet-ransomware-2024-1860 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: f5e9597b-951f-5881-a77f-dba8fe615799

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
