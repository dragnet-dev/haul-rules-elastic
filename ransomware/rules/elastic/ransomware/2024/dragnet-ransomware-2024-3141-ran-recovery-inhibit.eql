// Dragnet [Ransomware]: dragnet-ransomware-2024-3141 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 623f4d85-2d0e-590b-bfa1-edec8e3b170c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
