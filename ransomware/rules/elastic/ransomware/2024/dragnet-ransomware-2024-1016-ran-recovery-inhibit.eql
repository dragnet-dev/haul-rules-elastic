// Dragnet [Ransomware]: dragnet-ransomware-2024-1016 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: c70be7ee-0a70-51ae-b5e7-c36f9c3f77d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
