// Dragnet [Ransomware]: dragnet-ransomware-2024-4287 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 921f5d12-97fe-5e6b-9561-b18678dc77d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
