// Dragnet [Ransomware]: dragnet-ransomware-2024-3410 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5d9e5678-9cb1-5b11-83b7-344710cedd90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
