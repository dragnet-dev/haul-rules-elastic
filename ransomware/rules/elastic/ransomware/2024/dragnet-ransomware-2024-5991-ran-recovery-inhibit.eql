// Dragnet [Ransomware]: dragnet-ransomware-2024-5991 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d759bf8e-3753-5af4-b264-c69f95c993b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
