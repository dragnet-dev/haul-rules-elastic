// Dragnet [Ransomware]: dragnet-ransomware-2024-4403 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 32bda608-6172-55bb-9aff-25bf2aea066a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
