// Dragnet [Ransomware]: dragnet-ransomware-2024-0581 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3907cad7-d695-5128-a0a7-0a2cd7c13462

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
