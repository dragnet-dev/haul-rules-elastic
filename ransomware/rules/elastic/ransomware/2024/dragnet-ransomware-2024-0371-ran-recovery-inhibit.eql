// Dragnet [Ransomware]: dragnet-ransomware-2024-0371 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: e6874a24-b714-5c37-924b-e76b5be3c058

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
