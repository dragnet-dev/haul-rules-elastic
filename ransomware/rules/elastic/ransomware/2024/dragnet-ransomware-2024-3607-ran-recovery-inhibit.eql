// Dragnet [Ransomware]: dragnet-ransomware-2024-3607 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: ec51cdaf-99c6-588a-a1e5-c8fe2e78956b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
