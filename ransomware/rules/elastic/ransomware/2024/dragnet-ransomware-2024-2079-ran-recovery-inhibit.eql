// Dragnet [Ransomware]: dragnet-ransomware-2024-2079 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: fbd85f03-e44f-58a7-a971-7eef54f149f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
