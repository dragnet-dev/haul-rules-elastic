// Dragnet [Ransomware]: dragnet-ransomware-2024-5224 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ddc8b7b3-2e6d-5d99-a1ca-77f2dd96ef4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
