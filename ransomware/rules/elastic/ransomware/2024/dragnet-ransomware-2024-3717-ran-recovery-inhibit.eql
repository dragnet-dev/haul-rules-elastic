// Dragnet [Ransomware]: dragnet-ransomware-2024-3717 — Recovery Inhibition (blackout)
// Status: experimental | Level: high | ID: a3b8b470-e33c-5ab9-a2dd-8896be6aeda1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
