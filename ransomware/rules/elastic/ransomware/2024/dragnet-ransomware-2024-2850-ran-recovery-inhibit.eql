// Dragnet [Ransomware]: dragnet-ransomware-2024-2850 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 7b1afcfc-64ed-52c5-a38a-d0e9d36cae82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
