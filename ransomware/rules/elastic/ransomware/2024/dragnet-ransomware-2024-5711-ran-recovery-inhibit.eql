// Dragnet [Ransomware]: dragnet-ransomware-2024-5711 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: e07b28a5-2610-5e50-8e31-9f8d58d0b60e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
