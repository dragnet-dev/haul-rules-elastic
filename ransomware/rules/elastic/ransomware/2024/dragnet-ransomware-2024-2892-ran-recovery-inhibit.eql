// Dragnet [Ransomware]: dragnet-ransomware-2024-2892 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e37f59bd-c065-5cec-91dc-50ee2075e8c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
