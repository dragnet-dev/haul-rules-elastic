// Dragnet [Ransomware]: dragnet-ransomware-2024-3308 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: d8fed0af-d91d-515e-92e4-1a3349fac61b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
