// Dragnet [Ransomware]: dragnet-ransomware-2024-0743 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 4c83fbef-d951-5350-83eb-1ce99a5f6488

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
