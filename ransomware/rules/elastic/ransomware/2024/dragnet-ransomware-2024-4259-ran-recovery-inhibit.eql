// Dragnet [Ransomware]: dragnet-ransomware-2024-4259 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: e310d57c-7560-51f1-a994-a1219761676c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
