// Dragnet [Ransomware]: dragnet-ransomware-2024-2496 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: eb6fccba-9e8b-5686-a973-26b162b1daed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
