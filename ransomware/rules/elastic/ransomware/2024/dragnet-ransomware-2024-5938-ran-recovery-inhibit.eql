// Dragnet [Ransomware]: dragnet-ransomware-2024-5938 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 53ac0b71-b414-5bb7-8966-1ecc51318ff5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
