// Dragnet [Ransomware]: dragnet-ransomware-2024-4398 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 116613cc-cbb9-513c-b782-d594238ee4fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
