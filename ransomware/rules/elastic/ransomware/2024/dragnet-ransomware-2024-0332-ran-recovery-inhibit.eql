// Dragnet [Ransomware]: dragnet-ransomware-2024-0332 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: c8cb3f5c-923b-5496-9e09-7e2080d13fec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
