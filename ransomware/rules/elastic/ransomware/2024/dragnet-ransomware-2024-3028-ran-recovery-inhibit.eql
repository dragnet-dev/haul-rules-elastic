// Dragnet [Ransomware]: dragnet-ransomware-2024-3028 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ea9f2c04-e671-5a8c-bd7a-6728e39bbb4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
