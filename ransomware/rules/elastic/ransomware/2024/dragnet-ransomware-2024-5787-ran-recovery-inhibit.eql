// Dragnet [Ransomware]: dragnet-ransomware-2024-5787 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 1810d17e-e66c-56f0-be4c-f066cb0223de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
