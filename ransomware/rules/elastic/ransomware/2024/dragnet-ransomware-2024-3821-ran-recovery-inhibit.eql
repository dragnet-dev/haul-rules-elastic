// Dragnet [Ransomware]: dragnet-ransomware-2024-3821 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: f62b7b8d-1fe3-5c07-9460-7f5f0de67739

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
