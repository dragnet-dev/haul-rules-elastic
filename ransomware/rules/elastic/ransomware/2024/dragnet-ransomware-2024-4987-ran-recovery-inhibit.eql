// Dragnet [Ransomware]: dragnet-ransomware-2024-4987 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 901bc9c5-05ea-55b9-ad73-502eda600026

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
