// Dragnet [Ransomware]: dragnet-ransomware-2024-0565 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 611d6e1d-2c1e-5bfe-8d03-e29f64152111

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
