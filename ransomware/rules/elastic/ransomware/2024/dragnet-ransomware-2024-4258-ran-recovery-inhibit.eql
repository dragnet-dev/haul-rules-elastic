// Dragnet [Ransomware]: dragnet-ransomware-2024-4258 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 80c11edb-ccb2-5bf7-bae1-a6d5856c3c8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
