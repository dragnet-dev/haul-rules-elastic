// Dragnet [Ransomware]: dragnet-ransomware-2024-0576 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 1d121acf-25b6-5d91-a693-87a3887a88a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
