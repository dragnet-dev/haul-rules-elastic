// Dragnet [Ransomware]: dragnet-ransomware-2024-2835 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: c79bd9a0-0375-5d52-a1c3-0836b0687113

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
