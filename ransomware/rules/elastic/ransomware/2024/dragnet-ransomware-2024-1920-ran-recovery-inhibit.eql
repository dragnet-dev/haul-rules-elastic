// Dragnet [Ransomware]: dragnet-ransomware-2024-1920 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: e15a2fa8-3f9a-5645-ae45-f38ee6bba389

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
