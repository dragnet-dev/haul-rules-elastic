// Dragnet [Ransomware]: dragnet-ransomware-2024-4716 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 14aeb3f1-c341-5f04-b998-94debe72d583

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
