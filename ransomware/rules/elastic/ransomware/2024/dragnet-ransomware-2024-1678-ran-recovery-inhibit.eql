// Dragnet [Ransomware]: dragnet-ransomware-2024-1678 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: af46ffb6-9df0-55b9-b23e-8c95782d6aac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
