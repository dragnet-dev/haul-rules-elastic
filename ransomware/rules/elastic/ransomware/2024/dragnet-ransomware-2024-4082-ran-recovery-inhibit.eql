// Dragnet [Ransomware]: dragnet-ransomware-2024-4082 — Recovery Inhibition (madliberator)
// Status: experimental | Level: high | ID: 5af9e4b4-9140-5628-b2bd-ed8e85c42d23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
