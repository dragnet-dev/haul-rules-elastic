// Dragnet [Ransomware]: dragnet-ransomware-2024-5744 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 6e6ec6d4-8f0a-513a-8262-ba58f2cb4b30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
