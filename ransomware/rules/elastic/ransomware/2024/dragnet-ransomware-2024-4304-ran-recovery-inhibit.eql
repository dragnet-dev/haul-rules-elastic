// Dragnet [Ransomware]: dragnet-ransomware-2024-4304 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 10e9ef4c-8cf2-5f4d-b7cb-aaee941b4094

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
