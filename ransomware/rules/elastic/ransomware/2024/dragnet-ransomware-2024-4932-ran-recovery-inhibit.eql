// Dragnet [Ransomware]: dragnet-ransomware-2024-4932 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 472bc7d5-028a-5178-b33a-3ebec51da318

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
