// Dragnet [Ransomware]: dragnet-ransomware-2024-0438 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 864d6dd0-abd4-50c5-9c5d-0adf13a46eb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
