// Dragnet [Ransomware]: dragnet-ransomware-2024-2312 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 4b390a2f-c918-5e53-984f-06e12537f998

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
