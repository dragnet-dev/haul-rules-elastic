// Dragnet [Ransomware]: dragnet-ransomware-2024-5025 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 4c8affe2-efba-5310-b96c-99652c57e9c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
