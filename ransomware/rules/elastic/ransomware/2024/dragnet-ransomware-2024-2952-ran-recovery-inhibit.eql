// Dragnet [Ransomware]: dragnet-ransomware-2024-2952 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a65114a2-f084-571e-8653-1c23371c740b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
