// Dragnet [Ransomware]: dragnet-ransomware-2024-3183 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: ab50cdcf-ad2f-5c1a-a3b2-a51187954cd6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
