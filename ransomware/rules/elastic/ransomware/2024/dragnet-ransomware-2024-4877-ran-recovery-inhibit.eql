// Dragnet [Ransomware]: dragnet-ransomware-2024-4877 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a9fcb5d8-e253-5562-a010-381c9ff129d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
