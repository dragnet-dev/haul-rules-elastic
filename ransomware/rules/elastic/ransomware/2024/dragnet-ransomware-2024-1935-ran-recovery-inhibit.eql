// Dragnet [Ransomware]: dragnet-ransomware-2024-1935 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9018bcba-8c95-5b0d-927f-744809f216e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
