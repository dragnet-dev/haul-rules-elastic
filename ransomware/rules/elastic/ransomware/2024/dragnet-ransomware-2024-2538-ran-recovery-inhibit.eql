// Dragnet [Ransomware]: dragnet-ransomware-2024-2538 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 5d860937-0f38-5953-b445-ae9f0ffb20b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
