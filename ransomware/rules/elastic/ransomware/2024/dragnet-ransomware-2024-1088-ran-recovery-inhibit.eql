// Dragnet [Ransomware]: dragnet-ransomware-2024-1088 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f40a7b10-63e1-5106-b13c-7229199237ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
