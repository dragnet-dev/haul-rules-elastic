// Dragnet [Ransomware]: dragnet-ransomware-2024-1220 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: d9c4e02e-b4c5-5b48-8842-ed1a6ec52560

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
