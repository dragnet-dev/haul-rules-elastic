// Dragnet [Ransomware]: dragnet-ransomware-2024-1175 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3296b432-5fc5-5320-a1e3-27fcae6ac3a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
