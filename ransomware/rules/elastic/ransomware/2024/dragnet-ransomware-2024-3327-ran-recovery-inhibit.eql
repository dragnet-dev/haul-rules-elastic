// Dragnet [Ransomware]: dragnet-ransomware-2024-3327 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: cd38a416-72d4-5491-81a7-678ed3e4a41b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
