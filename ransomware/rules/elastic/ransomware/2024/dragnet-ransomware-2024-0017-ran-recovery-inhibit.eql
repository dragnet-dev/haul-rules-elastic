// Dragnet [Ransomware]: dragnet-ransomware-2024-0017 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 3960c1ea-09dc-5d4f-a0a1-5ab293841dd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
