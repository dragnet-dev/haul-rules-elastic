// Dragnet [Ransomware]: dragnet-ransomware-2024-1391 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 1c0874d2-8452-5dfd-9a81-c2b4d62f44c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
