// Dragnet [Ransomware]: dragnet-ransomware-2024-6003 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 0d508950-74e1-56cf-bf42-a78b4751cf82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
