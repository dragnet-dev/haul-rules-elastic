// Dragnet [Ransomware]: dragnet-ransomware-2024-5967 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 02a2699c-429f-51bf-a662-09fdde09d16c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
