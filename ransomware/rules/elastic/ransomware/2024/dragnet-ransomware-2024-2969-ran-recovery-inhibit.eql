// Dragnet [Ransomware]: dragnet-ransomware-2024-2969 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 455684e6-c169-5ba9-85f2-ba37133586d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
