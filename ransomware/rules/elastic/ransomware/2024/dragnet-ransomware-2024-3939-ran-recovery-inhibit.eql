// Dragnet [Ransomware]: dragnet-ransomware-2024-3939 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 911ba21d-e39b-52c3-968d-3f9bb13af664

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
