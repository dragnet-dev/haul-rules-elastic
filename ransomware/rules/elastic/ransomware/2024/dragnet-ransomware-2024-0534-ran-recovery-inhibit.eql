// Dragnet [Ransomware]: dragnet-ransomware-2024-0534 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a60aa9c8-a225-59e7-bc9f-1f5b03418326

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
