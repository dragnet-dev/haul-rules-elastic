// Dragnet [Ransomware]: dragnet-ransomware-2024-5311 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d7f34813-949c-56d0-95cc-375e050743ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
