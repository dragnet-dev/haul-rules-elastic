// Dragnet [Ransomware]: dragnet-ransomware-2024-5064 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 6411af95-be16-5bd2-8278-6caf9d7de101

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
