// Dragnet [Ransomware]: dragnet-ransomware-2024-3316 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f6f772f1-787b-595b-bb0d-7cc9cb61b2b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
