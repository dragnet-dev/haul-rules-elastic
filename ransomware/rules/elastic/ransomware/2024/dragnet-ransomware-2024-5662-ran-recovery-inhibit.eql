// Dragnet [Ransomware]: dragnet-ransomware-2024-5662 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 90b249a8-502a-5e23-b392-12e8623c7a7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
