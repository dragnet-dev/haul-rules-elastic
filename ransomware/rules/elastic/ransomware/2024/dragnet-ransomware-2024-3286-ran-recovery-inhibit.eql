// Dragnet [Ransomware]: dragnet-ransomware-2024-3286 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 0f110896-3967-5084-94a6-dee7fd52a683

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
