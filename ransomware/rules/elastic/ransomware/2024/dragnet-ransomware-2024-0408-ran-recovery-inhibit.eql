// Dragnet [Ransomware]: dragnet-ransomware-2024-0408 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: c4006801-cdde-5424-87bf-e55aac552db9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
