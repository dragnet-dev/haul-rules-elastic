// Dragnet [Ransomware]: dragnet-ransomware-2024-0924 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 874af9b3-8c91-5735-8fb2-630b7d282a26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
