// Dragnet [Ransomware]: dragnet-ransomware-2024-3376 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: b346ce69-0e56-5361-b1cd-206bffceab2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
