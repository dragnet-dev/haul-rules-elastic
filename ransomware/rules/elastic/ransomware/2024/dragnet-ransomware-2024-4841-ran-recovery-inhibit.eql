// Dragnet [Ransomware]: dragnet-ransomware-2024-4841 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 2a3a6621-36ea-5454-af47-a18363abc4b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
