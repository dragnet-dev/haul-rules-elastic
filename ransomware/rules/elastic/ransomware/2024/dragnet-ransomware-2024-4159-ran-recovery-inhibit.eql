// Dragnet [Ransomware]: dragnet-ransomware-2024-4159 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 5e35ee62-dd4f-5f51-b831-09b318185aa1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
