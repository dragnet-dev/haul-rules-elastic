// Dragnet [Ransomware]: dragnet-ransomware-2024-5738 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 60f13278-28c1-530b-8812-268dedf9c20b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
