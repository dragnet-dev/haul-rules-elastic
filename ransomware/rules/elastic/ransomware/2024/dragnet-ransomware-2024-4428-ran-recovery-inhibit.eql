// Dragnet [Ransomware]: dragnet-ransomware-2024-4428 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 1710a1ae-4f5f-53b3-ada4-dea9600cade1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
