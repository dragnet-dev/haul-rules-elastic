// Dragnet [Ransomware]: dragnet-ransomware-2024-5281 — Recovery Inhibition (slug)
// Status: experimental | Level: high | ID: 0e18361e-0378-5915-9478-521f63d85e7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
