// Dragnet [Ransomware]: dragnet-ransomware-2024-0029 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 3a872881-fabf-5669-9012-79c2a1e75de9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
