// Dragnet [Ransomware]: dragnet-ransomware-2024-2233 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f9f1ac20-db53-5a06-b100-923870875900

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
