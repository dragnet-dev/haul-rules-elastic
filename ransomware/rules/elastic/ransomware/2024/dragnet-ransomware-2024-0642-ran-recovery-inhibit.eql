// Dragnet [Ransomware]: dragnet-ransomware-2024-0642 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: d85cbf12-1496-50c6-acad-57eede4fd000

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
