// Dragnet [Ransomware]: dragnet-ransomware-2024-2331 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: daceb31a-310f-5031-af76-0836b7824df1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
