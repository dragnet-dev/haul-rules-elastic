// Dragnet [Ransomware]: dragnet-ransomware-2024-5327 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 6f3ddf0e-4e46-525d-abff-d2f29312b084

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
