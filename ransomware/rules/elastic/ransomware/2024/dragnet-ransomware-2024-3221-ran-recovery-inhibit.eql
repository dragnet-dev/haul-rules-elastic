// Dragnet [Ransomware]: dragnet-ransomware-2024-3221 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 65d97b04-5c62-5d1b-8c89-f5b3addd0d34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
