// Dragnet [Ransomware]: dragnet-ransomware-2024-4253 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 44d3d41a-0452-5bcf-9b06-a12f27e04501

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
