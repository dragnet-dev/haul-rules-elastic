// Dragnet [Ransomware]: dragnet-ransomware-2024-4142 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 567c457b-b5d2-547a-b85e-58c4e434c9a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
