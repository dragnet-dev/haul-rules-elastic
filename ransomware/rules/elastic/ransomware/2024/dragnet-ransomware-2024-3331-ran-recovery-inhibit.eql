// Dragnet [Ransomware]: dragnet-ransomware-2024-3331 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b4d1207d-7e5b-5b63-80f5-6396414c1ccf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
