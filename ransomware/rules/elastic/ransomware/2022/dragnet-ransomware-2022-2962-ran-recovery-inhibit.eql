// Dragnet [Ransomware]: dragnet-ransomware-2022-2962 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 5fdc5713-a854-5011-961d-d7c80ade2406

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
