// Dragnet [Ransomware]: dragnet-ransomware-2022-0718 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 97e548e7-ea54-580b-aeea-06e2e266427c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
