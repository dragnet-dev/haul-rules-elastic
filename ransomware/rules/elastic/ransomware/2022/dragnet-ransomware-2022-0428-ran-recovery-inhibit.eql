// Dragnet [Ransomware]: dragnet-ransomware-2022-0428 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 2d9141ca-e166-5cff-a15d-444998400455

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
