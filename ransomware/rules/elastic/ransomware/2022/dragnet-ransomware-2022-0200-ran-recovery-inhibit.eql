// Dragnet [Ransomware]: dragnet-ransomware-2022-0200 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 4137cebe-9113-5bc1-9c38-60cbd3b3e765

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
