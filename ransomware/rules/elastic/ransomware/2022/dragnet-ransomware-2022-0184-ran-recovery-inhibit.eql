// Dragnet [Ransomware]: dragnet-ransomware-2022-0184 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5950ec6e-1b01-57ce-b32c-03fa322eb01c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
