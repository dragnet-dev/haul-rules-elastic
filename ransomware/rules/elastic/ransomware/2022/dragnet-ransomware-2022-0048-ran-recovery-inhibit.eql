// Dragnet [Ransomware]: dragnet-ransomware-2022-0048 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: a1c7eca1-0060-52f3-94ad-1720c9952555

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
