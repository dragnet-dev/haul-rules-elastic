// Dragnet [Ransomware]: dragnet-ransomware-2022-1743 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 4d803ca1-ef45-52e3-b9e1-f3b3ced13e0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
