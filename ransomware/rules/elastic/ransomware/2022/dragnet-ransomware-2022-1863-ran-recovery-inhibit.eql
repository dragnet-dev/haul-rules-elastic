// Dragnet [Ransomware]: dragnet-ransomware-2022-1863 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: e94de20b-7a76-575f-bffe-b5418201647b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
