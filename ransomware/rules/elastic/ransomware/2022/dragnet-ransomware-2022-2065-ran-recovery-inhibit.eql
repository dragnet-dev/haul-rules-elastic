// Dragnet [Ransomware]: dragnet-ransomware-2022-2065 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 304f159e-690f-5499-88f3-18abc7b0b72c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
