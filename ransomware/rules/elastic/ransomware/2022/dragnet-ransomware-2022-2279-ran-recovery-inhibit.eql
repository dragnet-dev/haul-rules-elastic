// Dragnet [Ransomware]: dragnet-ransomware-2022-2279 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 31ac6820-6bfc-509b-a173-061a17593715

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
