// Dragnet [Ransomware]: dragnet-ransomware-2022-1939 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: f0e3ea01-6510-5b8c-9b9d-cd848cb6df1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
