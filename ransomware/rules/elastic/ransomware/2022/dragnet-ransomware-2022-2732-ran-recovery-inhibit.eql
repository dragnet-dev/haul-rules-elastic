// Dragnet [Ransomware]: dragnet-ransomware-2022-2732 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 40a27b10-a02a-52c2-bc58-36cead6c638c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
