// Dragnet [Ransomware]: dragnet-ransomware-2022-3072 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 2b6c3f30-6ae5-5bf5-b7e4-93815a8898a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
