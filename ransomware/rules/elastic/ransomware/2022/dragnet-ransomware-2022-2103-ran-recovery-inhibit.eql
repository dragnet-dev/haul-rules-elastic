// Dragnet [Ransomware]: dragnet-ransomware-2022-2103 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: dfb897b2-98b4-52ac-962f-8776ef80d40b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
