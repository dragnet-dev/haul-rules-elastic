// Dragnet [Ransomware]: dragnet-ransomware-2022-1244 — Recovery Inhibition (medusalocker)
// Status: deprecated | Level: high | ID: 214034ee-c1c9-5086-a2c5-5beaa113140c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
