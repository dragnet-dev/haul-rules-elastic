// Dragnet [Ransomware]: dragnet-ransomware-2022-2860 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 1e295386-165a-5927-810c-63e296de4098

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
