// Dragnet [Ransomware]: dragnet-ransomware-2022-1665 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: df661a75-db8a-5486-b51c-31ab3ffdf667

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
