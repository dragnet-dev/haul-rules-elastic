// Dragnet [Ransomware]: dragnet-ransomware-2022-2484 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 1d536392-6623-5be8-9377-2a2c1654b491

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
