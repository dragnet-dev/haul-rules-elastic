// Dragnet [Ransomware]: dragnet-ransomware-2022-0011 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 0a69e23e-3e88-5447-8b07-fb1448a1370a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
