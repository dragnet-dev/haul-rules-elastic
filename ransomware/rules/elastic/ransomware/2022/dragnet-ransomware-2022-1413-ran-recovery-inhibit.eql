// Dragnet [Ransomware]: dragnet-ransomware-2022-1413 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 65408782-7cad-5deb-a544-bdb6397435ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
