// Dragnet [Ransomware]: dragnet-ransomware-2022-1154 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 3aafb2c5-c5b7-5ec0-b249-5bb4004ce61f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
