// Dragnet [Ransomware]: dragnet-ransomware-2022-1448 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: ec898037-45d7-5635-a896-660574a8eba5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
