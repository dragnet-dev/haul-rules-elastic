// Dragnet [Ransomware]: dragnet-ransomware-2022-1911 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 7e5feff0-5d5f-5bc1-b3ab-4215a0e23cef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
