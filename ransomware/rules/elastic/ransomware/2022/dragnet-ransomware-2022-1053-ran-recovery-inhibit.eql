// Dragnet [Ransomware]: dragnet-ransomware-2022-1053 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9c35b67a-f02e-565f-aa33-a45944a670fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
