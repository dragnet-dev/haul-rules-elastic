// Dragnet [Ransomware]: dragnet-ransomware-2022-2158 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: f7ac9543-0f2c-5c31-8966-383491b7d4d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
