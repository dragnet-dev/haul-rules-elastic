// Dragnet [Ransomware]: dragnet-ransomware-2022-2706 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8bfcab2e-3c66-550f-bb5a-ca891f8d6ec4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
