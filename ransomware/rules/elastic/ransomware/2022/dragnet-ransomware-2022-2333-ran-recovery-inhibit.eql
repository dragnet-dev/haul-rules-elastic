// Dragnet [Ransomware]: dragnet-ransomware-2022-2333 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 812ef003-0e87-5b52-9dbb-d9e81110fbd4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
