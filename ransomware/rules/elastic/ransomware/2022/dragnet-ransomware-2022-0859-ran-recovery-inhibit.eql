// Dragnet [Ransomware]: dragnet-ransomware-2022-0859 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: befc000f-d0bb-590e-9d6d-9e5fa7f68760

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
