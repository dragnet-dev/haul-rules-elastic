// Dragnet [Ransomware]: dragnet-ransomware-2022-0750 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 166c9b9d-aa87-5651-a166-a5fa1de2e026

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
