// Dragnet [Ransomware]: dragnet-ransomware-2022-2903 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 939b2eac-b76a-5e90-914e-d0b167981cb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
