// Dragnet [Ransomware]: dragnet-ransomware-2022-2271 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8d350323-cb73-5879-b4f9-23cb6bb2c2fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
