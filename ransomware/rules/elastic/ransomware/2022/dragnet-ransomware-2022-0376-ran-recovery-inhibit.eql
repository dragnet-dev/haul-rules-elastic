// Dragnet [Ransomware]: dragnet-ransomware-2022-0376 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 2e7754e3-93cf-53fb-b621-922bf8c7b00d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
