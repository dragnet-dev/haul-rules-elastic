// Dragnet [Ransomware]: dragnet-ransomware-2022-1729 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 150b44fd-dcf5-53f7-baa6-bcd0f9d5b110

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
