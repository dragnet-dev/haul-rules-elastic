// Dragnet [Ransomware]: dragnet-ransomware-2022-2305 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 84e875ed-2015-532b-b656-fe83609c78f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
