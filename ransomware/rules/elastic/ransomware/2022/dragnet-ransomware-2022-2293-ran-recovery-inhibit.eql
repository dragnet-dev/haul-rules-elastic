// Dragnet [Ransomware]: dragnet-ransomware-2022-2293 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 4228ebff-b217-51ba-a1e5-d869a9d5474c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
