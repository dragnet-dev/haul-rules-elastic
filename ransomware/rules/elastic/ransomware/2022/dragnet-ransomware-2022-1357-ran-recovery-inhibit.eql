// Dragnet [Ransomware]: dragnet-ransomware-2022-1357 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: f2781cf1-ecf8-5924-bb96-6a20ebb369ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
