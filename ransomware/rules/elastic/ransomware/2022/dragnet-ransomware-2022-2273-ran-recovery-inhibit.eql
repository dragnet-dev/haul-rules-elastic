// Dragnet [Ransomware]: dragnet-ransomware-2022-2273 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: ac455912-4c4c-513a-9ea7-8f80e895d850

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
