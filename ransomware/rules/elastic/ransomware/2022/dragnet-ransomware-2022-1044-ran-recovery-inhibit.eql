// Dragnet [Ransomware]: dragnet-ransomware-2022-1044 — Recovery Inhibition (medusalocker)
// Status: deprecated | Level: high | ID: c816efbe-6628-5c84-a1fe-b9b2a23fbbea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
