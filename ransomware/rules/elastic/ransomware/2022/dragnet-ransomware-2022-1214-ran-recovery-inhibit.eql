// Dragnet [Ransomware]: dragnet-ransomware-2022-1214 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7f04416c-a7f8-5837-8e78-0cbdf3335a52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
