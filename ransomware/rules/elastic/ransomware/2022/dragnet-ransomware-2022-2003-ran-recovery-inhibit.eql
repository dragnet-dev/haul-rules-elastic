// Dragnet [Ransomware]: dragnet-ransomware-2022-2003 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 6e231850-2d50-5a6c-bb64-208b02d9799d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
