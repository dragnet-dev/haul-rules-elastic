// Dragnet [Ransomware]: dragnet-ransomware-2022-0163 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 18e8e07d-7ee5-5ae9-b0aa-01efe7c65898

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
