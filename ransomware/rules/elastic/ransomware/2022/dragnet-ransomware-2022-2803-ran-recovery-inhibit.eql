// Dragnet [Ransomware]: dragnet-ransomware-2022-2803 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8b273910-2b43-5e11-824b-bde9da6851d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
