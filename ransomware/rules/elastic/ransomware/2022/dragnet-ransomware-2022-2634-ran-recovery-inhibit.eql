// Dragnet [Ransomware]: dragnet-ransomware-2022-2634 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 8ac2e71b-fa92-568b-95c5-95bb4e8f2d0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
