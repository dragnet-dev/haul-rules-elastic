// Dragnet [Ransomware]: dragnet-ransomware-2022-1803 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 526db37d-fa3a-52e5-9dfc-ec3647f51ab0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
