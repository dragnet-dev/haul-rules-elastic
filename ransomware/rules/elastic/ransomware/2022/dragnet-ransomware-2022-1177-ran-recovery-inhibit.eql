// Dragnet [Ransomware]: dragnet-ransomware-2022-1177 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: 74cc5ace-4f8c-5f20-9478-b6bfa450d9fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
