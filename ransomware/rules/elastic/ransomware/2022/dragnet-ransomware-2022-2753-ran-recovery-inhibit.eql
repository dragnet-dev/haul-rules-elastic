// Dragnet [Ransomware]: dragnet-ransomware-2022-2753 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: e09ca500-2ddb-5977-8516-2ed18eac5b34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
