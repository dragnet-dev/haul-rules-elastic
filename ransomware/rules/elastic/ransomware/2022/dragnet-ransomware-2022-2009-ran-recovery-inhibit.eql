// Dragnet [Ransomware]: dragnet-ransomware-2022-2009 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: bdff1875-d1b5-57cd-ba01-f0fc47ecbea4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
