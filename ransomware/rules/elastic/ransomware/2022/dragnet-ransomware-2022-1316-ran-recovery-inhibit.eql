// Dragnet [Ransomware]: dragnet-ransomware-2022-1316 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ccf44afe-1201-5278-86c3-12ae8762c5e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
