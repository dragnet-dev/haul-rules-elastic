// Dragnet [Ransomware]: dragnet-ransomware-2022-2008 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 21f4ba1d-32ef-5a4b-893d-052e9cdedad2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
