// Dragnet [Ransomware]: dragnet-ransomware-2022-2429 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: edfef5ac-dc71-573c-b736-9e420ce543c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
