// Dragnet [Ransomware]: dragnet-ransomware-2022-0294 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 05cef5fb-f054-5da8-a7fb-9bac7daf0bcb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
