// Dragnet [Ransomware]: dragnet-ransomware-2022-3015 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: da4a77ae-5893-56b1-9636-cdbf659a27c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
