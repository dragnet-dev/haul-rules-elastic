// Dragnet [Ransomware]: dragnet-ransomware-2022-1751 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 4bd77a0f-dab4-5f77-affb-a2f5bfb96a35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
