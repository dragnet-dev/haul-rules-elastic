// Dragnet [Ransomware]: dragnet-ransomware-2022-1742 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: e4d13f90-56b3-5bab-ab01-d8647bd358e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
