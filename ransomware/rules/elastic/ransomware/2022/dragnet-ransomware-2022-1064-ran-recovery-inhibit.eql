// Dragnet [Ransomware]: dragnet-ransomware-2022-1064 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5dbbf3c1-b9f3-592a-8550-1002d854ca30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
