// Dragnet [Ransomware]: dragnet-ransomware-2022-2116 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 5a61e69d-abea-5d4d-a561-706b4f3dbe7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
