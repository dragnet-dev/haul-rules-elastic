// Dragnet [Ransomware]: dragnet-ransomware-2022-0693 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 39890cab-c1fd-549a-9564-2a5e45e2bb1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
