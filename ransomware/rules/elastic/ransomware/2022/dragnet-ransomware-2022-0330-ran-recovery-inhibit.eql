// Dragnet [Ransomware]: dragnet-ransomware-2022-0330 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a5695900-1bb6-55fb-9ef6-9dc03b5df2bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
