// Dragnet [Ransomware]: dragnet-ransomware-2022-1112 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 96da13ef-972e-5572-9e73-d345fc52944f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
