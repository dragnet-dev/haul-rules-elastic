// Dragnet [Ransomware]: dragnet-ransomware-2022-0108 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 78e90cad-2ff2-5a4a-9b5c-20ea60fd721d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
