// Dragnet [Ransomware]: dragnet-ransomware-2022-1907 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f3094f15-6ab5-5844-bac4-ca6603c64dba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
