// Dragnet [Ransomware]: dragnet-ransomware-2022-1433 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 8c9ce469-152e-5d15-99e9-b7f0b60aec85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
