// Dragnet [Ransomware]: dragnet-ransomware-2022-2873 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ab7904b9-0eea-5048-b971-ef14e2b2d581

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
