// Dragnet [Ransomware]: dragnet-ransomware-2022-2480 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b607da2d-bfa1-5afe-b31d-fc84471e4d5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
