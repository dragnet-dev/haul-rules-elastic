// Dragnet [Ransomware]: dragnet-ransomware-2022-3101 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: c6f28fc4-06a4-5697-8764-9d94cf7c53d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
