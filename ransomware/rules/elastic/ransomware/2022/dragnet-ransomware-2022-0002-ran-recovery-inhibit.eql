// Dragnet [Ransomware]: dragnet-ransomware-2022-0002 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e1beb48e-5c34-58bc-8fa6-e65cc902eb78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
