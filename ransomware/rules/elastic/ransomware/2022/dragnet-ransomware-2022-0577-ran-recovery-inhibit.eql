// Dragnet [Ransomware]: dragnet-ransomware-2022-0577 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: c2225067-9093-5322-8400-9577d8971db7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
