// Dragnet [Ransomware]: dragnet-ransomware-2022-1293 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 82e8148b-393d-5462-95ef-4319f67b8fa3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
