// Dragnet [Ransomware]: dragnet-ransomware-2022-2475 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 14ba5aa8-397a-5bf6-8653-808b25d1ed70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
