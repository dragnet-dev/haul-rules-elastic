// Dragnet [Ransomware]: dragnet-ransomware-2022-2835 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 9729ec8c-34a9-53a0-bd3a-a39638e8db1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
