// Dragnet [Ransomware]: dragnet-ransomware-2022-0137 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5fc80f37-8d7c-5be7-a9f1-9303567c672a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
