// Dragnet [Ransomware]: dragnet-ransomware-2022-0539 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 351f5b39-ae00-5b71-9556-82f309000918

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
