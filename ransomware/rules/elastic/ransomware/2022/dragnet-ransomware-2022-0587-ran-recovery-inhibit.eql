// Dragnet [Ransomware]: dragnet-ransomware-2022-0587 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 04e9f6b8-2381-537f-94fe-5b361129ed8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
