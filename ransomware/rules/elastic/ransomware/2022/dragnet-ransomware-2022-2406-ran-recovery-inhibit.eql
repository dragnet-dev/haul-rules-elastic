// Dragnet [Ransomware]: dragnet-ransomware-2022-2406 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 0adaf949-4bf8-578c-b9ca-8c55bcff87c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
