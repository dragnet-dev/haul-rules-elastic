// Dragnet [Ransomware]: dragnet-ransomware-2022-1954 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: dfecd6c7-ba58-5b94-9463-98776ea5d3bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
