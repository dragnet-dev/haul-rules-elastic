// Dragnet [Ransomware]: dragnet-ransomware-2022-1224 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 98ff8559-bfac-5795-9d0d-047d37c00479

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
