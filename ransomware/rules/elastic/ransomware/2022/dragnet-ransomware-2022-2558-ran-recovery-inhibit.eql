// Dragnet [Ransomware]: dragnet-ransomware-2022-2558 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 72259522-310f-5f3b-a1ed-156197ed79ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
