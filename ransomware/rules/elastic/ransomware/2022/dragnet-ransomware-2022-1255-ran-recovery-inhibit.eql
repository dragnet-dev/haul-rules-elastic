// Dragnet [Ransomware]: dragnet-ransomware-2022-1255 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e44d9c5a-6b7c-53a5-96f7-b977e5285e2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
