// Dragnet [Ransomware]: dragnet-ransomware-2022-2912 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: da0a4810-1e62-595e-86a3-3493522f52af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
