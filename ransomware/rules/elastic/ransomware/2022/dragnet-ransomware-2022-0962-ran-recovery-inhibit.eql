// Dragnet [Ransomware]: dragnet-ransomware-2022-0962 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: aefa0b69-1284-5d3e-816f-f55b1f3dfe4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
