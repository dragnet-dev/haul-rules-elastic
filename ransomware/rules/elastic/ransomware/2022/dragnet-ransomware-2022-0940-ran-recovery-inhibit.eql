// Dragnet [Ransomware]: dragnet-ransomware-2022-0940 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 059e43e1-14ba-517f-99d8-fa0b7bd3d92b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
