// Dragnet [Ransomware]: dragnet-ransomware-2022-2599 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 095b813d-39bc-5c44-85f4-51c4e228cf95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
