// Dragnet [Ransomware]: dragnet-ransomware-2022-1469 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: 27b94378-9bc7-560f-b75c-6122d3b56c0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
