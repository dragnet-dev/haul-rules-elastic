// Dragnet [Ransomware]: dragnet-ransomware-2022-0207 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 9c7bb292-618b-534b-8adb-bebda05abb11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
