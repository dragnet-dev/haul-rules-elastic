// Dragnet [Ransomware]: dragnet-ransomware-2022-1361 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: af6e7d39-061c-58f1-901e-ad8e598b720d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
