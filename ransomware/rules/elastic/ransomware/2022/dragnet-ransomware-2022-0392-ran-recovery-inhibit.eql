// Dragnet [Ransomware]: dragnet-ransomware-2022-0392 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 884d070b-070e-5e87-b97d-fa5854940750

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
