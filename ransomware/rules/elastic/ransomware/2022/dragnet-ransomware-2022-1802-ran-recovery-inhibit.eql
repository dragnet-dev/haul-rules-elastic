// Dragnet [Ransomware]: dragnet-ransomware-2022-1802 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b4253d7e-97b7-5e4e-823d-2daa94dcc8e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
