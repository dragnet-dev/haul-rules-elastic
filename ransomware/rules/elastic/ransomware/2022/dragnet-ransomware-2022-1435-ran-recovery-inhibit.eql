// Dragnet [Ransomware]: dragnet-ransomware-2022-1435 — Recovery Inhibition (freecivilian)
// Status: deprecated | Level: high | ID: e1dc6c24-20a0-5ebf-83e7-3eabee9bc62f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
