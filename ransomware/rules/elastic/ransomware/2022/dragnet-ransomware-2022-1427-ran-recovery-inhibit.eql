// Dragnet [Ransomware]: dragnet-ransomware-2022-1427 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 400dd4c3-4b51-5421-961c-6f78fbeb1f90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
