// Dragnet [Ransomware]: dragnet-ransomware-2022-1556 — Recovery Inhibition (daixin)
// Status: deprecated | Level: high | ID: 642b1c6c-13f0-528c-af8f-092a31c51810

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
