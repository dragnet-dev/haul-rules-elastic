// Dragnet [Ransomware]: dragnet-ransomware-2022-0594 — Recovery Inhibition (daixin)
// Status: deprecated | Level: high | ID: ce87d7ec-b0b7-5551-8099-0dfce91cb64c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
