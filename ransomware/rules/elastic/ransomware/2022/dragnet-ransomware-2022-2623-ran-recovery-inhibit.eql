// Dragnet [Ransomware]: dragnet-ransomware-2022-2623 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 31187d5d-a140-576f-98d0-5bbd374a0eb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
