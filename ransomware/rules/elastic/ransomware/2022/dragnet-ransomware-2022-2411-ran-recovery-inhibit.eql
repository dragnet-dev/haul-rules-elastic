// Dragnet [Ransomware]: dragnet-ransomware-2022-2411 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: d8780570-7a7d-520c-a328-ae9184ca48f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
