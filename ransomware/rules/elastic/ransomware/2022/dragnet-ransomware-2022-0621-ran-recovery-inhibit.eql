// Dragnet [Ransomware]: dragnet-ransomware-2022-0621 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: a86d53b5-2281-5c1a-9ea9-7b98a7b933d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
