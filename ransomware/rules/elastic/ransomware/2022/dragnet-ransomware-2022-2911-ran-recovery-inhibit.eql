// Dragnet [Ransomware]: dragnet-ransomware-2022-2911 — Recovery Inhibition (leaktheanalyst)
// Status: deprecated | Level: high | ID: 6db99309-4829-5341-b6ae-87994624337d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
