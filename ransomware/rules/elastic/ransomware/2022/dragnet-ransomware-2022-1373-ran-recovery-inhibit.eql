// Dragnet [Ransomware]: dragnet-ransomware-2022-1373 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: c2a097f4-d075-5178-84c9-7a4039fd833e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
