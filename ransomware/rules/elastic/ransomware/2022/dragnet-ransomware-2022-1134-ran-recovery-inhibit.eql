// Dragnet [Ransomware]: dragnet-ransomware-2022-1134 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 2bd1df7d-bb10-58a6-9aac-d595f74eec40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
