// Dragnet [Ransomware]: dragnet-ransomware-2022-0897 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 64c973eb-4c79-5e50-88ea-ebf089068bdd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
