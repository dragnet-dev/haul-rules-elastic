// Dragnet [Ransomware]: dragnet-ransomware-2022-0235 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 5c6e5127-7fc7-593b-9df9-b676a9b3979e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
