// Dragnet [Ransomware]: dragnet-ransomware-2022-2620 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ed59323b-9708-5fe4-8ba2-f5ae43044309

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
