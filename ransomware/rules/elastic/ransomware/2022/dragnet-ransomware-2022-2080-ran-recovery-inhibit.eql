// Dragnet [Ransomware]: dragnet-ransomware-2022-2080 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a41a26c8-a312-520a-9bf8-32837757dab4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
