// Dragnet [Ransomware]: dragnet-ransomware-2022-0732 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f2855df4-12ee-5ac1-b542-68d651cdf749

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
