// Dragnet [Ransomware]: dragnet-ransomware-2022-1056 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 2249e4ce-c91f-5e3d-b269-14f0d230682c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
