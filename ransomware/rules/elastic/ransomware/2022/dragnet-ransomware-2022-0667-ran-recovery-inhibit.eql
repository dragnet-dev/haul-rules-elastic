// Dragnet [Ransomware]: dragnet-ransomware-2022-0667 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a9fefec8-1209-511d-9e36-14a24ff8a780

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
