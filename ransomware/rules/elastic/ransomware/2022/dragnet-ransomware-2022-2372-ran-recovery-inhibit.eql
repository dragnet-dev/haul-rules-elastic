// Dragnet [Ransomware]: dragnet-ransomware-2022-2372 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 67147fc5-e57a-5b8c-be05-5b58bb472a49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
