// Dragnet [Ransomware]: dragnet-ransomware-2022-0459 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 27a3cd7f-9526-571f-a92c-da81121a1e6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
