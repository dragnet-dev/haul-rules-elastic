// Dragnet [Ransomware]: dragnet-ransomware-2022-2806 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 6f7a30cd-ac7c-552a-8046-3ef6e2f8eb2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
