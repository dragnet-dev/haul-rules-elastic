// Dragnet [Ransomware]: dragnet-ransomware-2022-2015 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 535647a3-8ca2-5dc8-a4d9-0162a6785b7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
