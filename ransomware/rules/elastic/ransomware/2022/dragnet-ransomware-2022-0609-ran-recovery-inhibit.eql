// Dragnet [Ransomware]: dragnet-ransomware-2022-0609 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7dd1dedd-4467-5a53-a4db-12d0e76eb997

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
