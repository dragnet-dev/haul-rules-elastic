// Dragnet [Ransomware]: dragnet-ransomware-2022-2465 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a12b69de-2a10-594d-9778-6ce135119d48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
