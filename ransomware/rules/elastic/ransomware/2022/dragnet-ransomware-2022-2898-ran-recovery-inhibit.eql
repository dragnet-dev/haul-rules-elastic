// Dragnet [Ransomware]: dragnet-ransomware-2022-2898 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 7c513a51-6172-523d-8622-a45baef38468

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
