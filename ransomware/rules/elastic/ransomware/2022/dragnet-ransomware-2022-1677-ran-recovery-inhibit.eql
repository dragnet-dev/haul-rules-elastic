// Dragnet [Ransomware]: dragnet-ransomware-2022-1677 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 4ead63a6-b26a-5edf-b874-7902dae70679

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
