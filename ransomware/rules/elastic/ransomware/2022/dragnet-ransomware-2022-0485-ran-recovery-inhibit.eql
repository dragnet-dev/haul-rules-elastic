// Dragnet [Ransomware]: dragnet-ransomware-2022-0485 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d4ca137f-3257-592b-ad56-6657dc1b06b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
