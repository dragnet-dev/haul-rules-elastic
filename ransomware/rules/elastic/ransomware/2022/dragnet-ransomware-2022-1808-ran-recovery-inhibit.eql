// Dragnet [Ransomware]: dragnet-ransomware-2022-1808 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: a620fdaa-8815-57aa-8b22-ef636966c6e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
