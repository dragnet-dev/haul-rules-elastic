// Dragnet [Ransomware]: dragnet-ransomware-2022-2262 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: de584036-2c83-5ea0-94f0-14831d8f2dc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
