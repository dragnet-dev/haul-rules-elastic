// Dragnet [Ransomware]: dragnet-ransomware-2022-2161 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: e69df4d2-d2bd-59b7-b3f1-678583b09952

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
