// Dragnet [Ransomware]: dragnet-ransomware-2022-1437 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: e2a7785c-da20-51ae-bc51-af3180d7ddd0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
