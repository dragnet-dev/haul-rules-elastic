// Dragnet [Ransomware]: dragnet-ransomware-2022-0790 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 1b055878-71e4-5e24-85ed-f6be0e3a7f3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
