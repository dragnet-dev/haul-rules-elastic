// Dragnet [Ransomware]: dragnet-ransomware-2022-1569 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e1cbb7c4-04e7-512e-8321-a1f2199d4508

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
