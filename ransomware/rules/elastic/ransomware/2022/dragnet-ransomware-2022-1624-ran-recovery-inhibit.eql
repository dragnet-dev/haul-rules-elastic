// Dragnet [Ransomware]: dragnet-ransomware-2022-1624 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: 4913bc76-02a2-5c19-aadc-2c68165a5298

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
