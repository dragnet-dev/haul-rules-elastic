// Dragnet [Ransomware]: dragnet-ransomware-2022-0988 — Recovery Inhibition (payloadbin)
// Status: deprecated | Level: high | ID: 4eeebf28-e02d-5607-8e57-e2d39c436ece

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
