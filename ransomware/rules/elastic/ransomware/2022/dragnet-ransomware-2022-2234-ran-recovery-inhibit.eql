// Dragnet [Ransomware]: dragnet-ransomware-2022-2234 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: f0f7902f-debc-5fad-99f4-1403a0d5ec2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
