// Dragnet [Ransomware]: dragnet-ransomware-2022-2079 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5e576340-6b2b-55c8-8d25-f90b3b6b8c75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
