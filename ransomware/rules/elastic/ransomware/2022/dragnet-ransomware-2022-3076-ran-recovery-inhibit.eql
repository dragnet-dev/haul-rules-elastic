// Dragnet [Ransomware]: dragnet-ransomware-2022-3076 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 397b3090-3680-5811-8379-086e55ac5f5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
