// Dragnet [Ransomware]: dragnet-ransomware-2022-2121 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 414bd575-91df-53e9-a7ec-3620ea936230

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
