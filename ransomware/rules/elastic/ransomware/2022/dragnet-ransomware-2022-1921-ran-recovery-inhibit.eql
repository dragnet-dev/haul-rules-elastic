// Dragnet [Ransomware]: dragnet-ransomware-2022-1921 — Recovery Inhibition (sabbath)
// Status: deprecated | Level: high | ID: 96021011-e924-51fc-8619-d86de5264584

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
