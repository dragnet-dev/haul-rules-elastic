// Dragnet [Ransomware]: dragnet-ransomware-2022-2223 — Recovery Inhibition (mindware)
// Status: deprecated | Level: high | ID: 73593da9-97c3-5edd-b2f4-5f2dc24c2ce8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
