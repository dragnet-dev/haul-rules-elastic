// Dragnet [Ransomware]: dragnet-ransomware-2022-1675 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 256da3e6-da30-519d-85ee-506d0f9b1f40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
