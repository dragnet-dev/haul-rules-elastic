// Dragnet [Ransomware]: dragnet-ransomware-2022-1132 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 0a609910-a37a-5b41-8331-2d8ba5f38634

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
