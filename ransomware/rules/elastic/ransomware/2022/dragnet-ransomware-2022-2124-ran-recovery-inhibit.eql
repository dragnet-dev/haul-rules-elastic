// Dragnet [Ransomware]: dragnet-ransomware-2022-2124 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 48bc53d7-68b7-5709-81ee-71078c96d86f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
