// Dragnet [Ransomware]: dragnet-ransomware-2022-0692 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 82e63bf7-4f43-549a-b3ff-31a0c61fba74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
