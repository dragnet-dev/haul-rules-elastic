// Dragnet [Ransomware]: dragnet-ransomware-2022-0033 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 7863938e-ee67-54ca-acb3-1a6371c472b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
