// Dragnet [Ransomware]: dragnet-ransomware-2022-2639 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 08bc0ec3-736d-5fac-a40e-5bb07c56459e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
