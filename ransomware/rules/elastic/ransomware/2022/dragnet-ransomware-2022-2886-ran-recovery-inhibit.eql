// Dragnet [Ransomware]: dragnet-ransomware-2022-2886 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: ec5764c1-d0f7-5901-8a81-f9abd9bb5b7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
