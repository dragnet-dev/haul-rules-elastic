// Dragnet [Ransomware]: dragnet-ransomware-2022-0433 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: a32f1bd2-7332-52ab-bbcb-d13c93decb81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
