// Dragnet [Ransomware]: dragnet-ransomware-2022-0328 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: b228c0c4-e7c4-5185-8759-f02ad68904ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
