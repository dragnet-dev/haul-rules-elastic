// Dragnet [Ransomware]: dragnet-ransomware-2022-2192 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8f4b2e7b-054d-5754-be37-dfa302bdbfae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
