// Dragnet [Ransomware]: dragnet-ransomware-2022-2474 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 38658585-e691-52d8-a2e1-15bd3be0a19e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
