// Dragnet [Ransomware]: dragnet-ransomware-2022-0107 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 4cee8ece-0c62-58b9-8bd5-055d41ab90f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
