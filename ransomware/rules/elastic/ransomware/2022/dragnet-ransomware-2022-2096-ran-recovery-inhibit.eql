// Dragnet [Ransomware]: dragnet-ransomware-2022-2096 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 1b85520f-c769-597e-8369-c9fde02aeb60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
