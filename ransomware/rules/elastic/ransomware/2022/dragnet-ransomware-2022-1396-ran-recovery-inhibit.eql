// Dragnet [Ransomware]: dragnet-ransomware-2022-1396 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 7b060824-e0ca-503f-98fb-8338a45d72f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
