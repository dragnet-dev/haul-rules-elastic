// Dragnet [Ransomware]: dragnet-ransomware-2022-2561 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: d08cab4d-1bfb-553f-a3be-956da617590b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
