// Dragnet [Ransomware]: dragnet-ransomware-2022-2588 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: 0bcc754a-28b9-5f46-98e0-46f2ce581848

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
