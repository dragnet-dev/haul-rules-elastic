// Dragnet [Ransomware]: dragnet-ransomware-2022-2823 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 7136681e-8026-51c0-854e-b6448d7d185f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
