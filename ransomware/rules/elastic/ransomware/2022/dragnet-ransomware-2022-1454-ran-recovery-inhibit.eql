// Dragnet [Ransomware]: dragnet-ransomware-2022-1454 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: dc92f0b4-a29e-5a75-a25a-f87b90e5a900

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
