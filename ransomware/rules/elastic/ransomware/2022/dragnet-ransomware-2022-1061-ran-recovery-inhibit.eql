// Dragnet [Ransomware]: dragnet-ransomware-2022-1061 — Recovery Inhibition (leaktheanalyst)
// Status: deprecated | Level: high | ID: 156bd07e-a0e9-5e08-ad85-7e2f381d7d1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
