// Dragnet [Ransomware]: dragnet-ransomware-2022-2028 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 60f60e59-d70f-540a-8088-5827f870293d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
