// Dragnet [Ransomware]: dragnet-ransomware-2022-2641 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 485fa36e-5b89-5057-be93-fa670cb06461

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
