// Dragnet [Ransomware]: dragnet-ransomware-2022-2502 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: b5ab6ac6-9403-5dc3-91ac-1f3d5ff07ab6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
