// Dragnet [Ransomware]: dragnet-ransomware-2022-1776 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 6b9b5838-056a-584d-83d8-e2f93851052a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
