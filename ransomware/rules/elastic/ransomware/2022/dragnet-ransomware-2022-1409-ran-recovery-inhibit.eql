// Dragnet [Ransomware]: dragnet-ransomware-2022-1409 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8b22e6e0-162e-500f-b6b0-d75621436e0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
