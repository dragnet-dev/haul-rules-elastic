// Dragnet [Ransomware]: dragnet-ransomware-2022-0287 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c39a653c-f8c5-584f-93f2-c03465aae68f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
