// Dragnet [Ransomware]: dragnet-ransomware-2022-1651 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4a51c1c7-b219-5ff7-bbd4-ce8dbd23f7bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
