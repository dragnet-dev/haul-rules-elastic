// Dragnet [Ransomware]: dragnet-ransomware-2022-2836 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 64cbf5d5-f317-509f-9f33-dbb7e415a54c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
