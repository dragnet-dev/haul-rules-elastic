// Dragnet [Ransomware]: dragnet-ransomware-2022-1925 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 2458dc93-2f0b-5c51-a6bd-6182f450987d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
