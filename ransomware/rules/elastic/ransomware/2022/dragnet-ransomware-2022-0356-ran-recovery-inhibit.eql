// Dragnet [Ransomware]: dragnet-ransomware-2022-0356 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 25886585-e09e-531a-9f4e-704aff139ffe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
