// Dragnet [Ransomware]: dragnet-ransomware-2022-2675 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: e96d17a0-34a3-584e-bc3f-ed018ff3206f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
