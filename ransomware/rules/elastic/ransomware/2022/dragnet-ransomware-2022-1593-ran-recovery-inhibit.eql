// Dragnet [Ransomware]: dragnet-ransomware-2022-1593 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 2e9f1103-66ef-54bc-ad6b-b57660da7752

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
