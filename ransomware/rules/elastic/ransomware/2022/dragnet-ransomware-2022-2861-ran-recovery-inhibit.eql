// Dragnet [Ransomware]: dragnet-ransomware-2022-2861 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 9c36afa8-aebe-5bb3-b1ca-799b88d146ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
