// Dragnet [Ransomware]: dragnet-ransomware-2022-1815 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4884720c-fa86-5496-808c-590b3956bd47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
