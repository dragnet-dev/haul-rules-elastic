// Dragnet [Ransomware]: dragnet-ransomware-2022-2249 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 24f9c1cc-9482-5deb-83f5-2687c107186e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
