// Dragnet [Ransomware]: dragnet-ransomware-2022-1347 — Recovery Inhibition (pandora)
// Status: deprecated | Level: high | ID: c3b209cd-f925-5989-a400-e1844e2f5b94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
