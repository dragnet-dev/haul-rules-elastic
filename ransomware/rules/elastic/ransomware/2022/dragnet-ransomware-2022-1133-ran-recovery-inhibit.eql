// Dragnet [Ransomware]: dragnet-ransomware-2022-1133 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 67559844-bb5a-5381-958b-9e8bd1292ecc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
