// Dragnet [Ransomware]: dragnet-ransomware-2022-1961 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 3b0a2ed0-0ce6-54f9-8ec6-b5ce9067be7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
