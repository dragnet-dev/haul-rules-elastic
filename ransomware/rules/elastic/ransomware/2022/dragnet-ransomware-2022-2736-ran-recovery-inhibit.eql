// Dragnet [Ransomware]: dragnet-ransomware-2022-2736 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 02d8bf90-7953-5eac-9285-5624d156f912

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
