// Dragnet [Ransomware]: dragnet-ransomware-2022-1725 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 3a2b11c4-a3e9-5fad-9b65-d2f69e5e1142

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
