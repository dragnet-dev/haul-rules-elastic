// Dragnet [Ransomware]: dragnet-ransomware-2022-0523 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: abdc1d11-6dd5-50fa-9ef3-b15b2629143e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
