// Dragnet [Ransomware]: dragnet-ransomware-2022-0397 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: f94c22e1-ec23-5229-bed6-2a08b84daaca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
