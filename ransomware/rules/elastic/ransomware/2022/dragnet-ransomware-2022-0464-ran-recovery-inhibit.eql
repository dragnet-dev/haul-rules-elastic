// Dragnet [Ransomware]: dragnet-ransomware-2022-0464 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 2c69859f-b626-5832-9b07-713621547624

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
