// Dragnet [Ransomware]: dragnet-ransomware-2022-2687 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 35d66abd-d371-5122-8d03-98f15b0d4f4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
