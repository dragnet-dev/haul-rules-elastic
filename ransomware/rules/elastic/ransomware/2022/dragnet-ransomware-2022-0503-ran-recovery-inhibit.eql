// Dragnet [Ransomware]: dragnet-ransomware-2022-0503 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5f50408f-2135-5333-b740-74bf8a9c69ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
