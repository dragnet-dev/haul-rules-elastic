// Dragnet [Ransomware]: dragnet-ransomware-2022-2969 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 89bc0939-636d-5a03-ae0c-d3ce43906d54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
