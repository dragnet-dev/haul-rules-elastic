// Dragnet [Ransomware]: dragnet-ransomware-2022-0908 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 92d403ef-3658-5bfb-a57e-8770b2a5a224

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
