// Dragnet [Ransomware]: dragnet-ransomware-2022-0304 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 243dbf15-1cf3-56a0-b1ab-02d9c373e9df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
