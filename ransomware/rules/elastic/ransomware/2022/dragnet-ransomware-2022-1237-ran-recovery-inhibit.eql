// Dragnet [Ransomware]: dragnet-ransomware-2022-1237 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6cedfb01-d15c-5765-9ee4-bfc85d4187a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
