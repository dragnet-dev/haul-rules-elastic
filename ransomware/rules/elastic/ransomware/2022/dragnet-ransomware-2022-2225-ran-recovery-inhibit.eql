// Dragnet [Ransomware]: dragnet-ransomware-2022-2225 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 9e6ea830-8d97-5e77-8f1d-817b088f683f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
