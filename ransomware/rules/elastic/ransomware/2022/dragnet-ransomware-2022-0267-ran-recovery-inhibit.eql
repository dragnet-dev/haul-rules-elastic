// Dragnet [Ransomware]: dragnet-ransomware-2022-0267 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5d2e319e-f65f-580c-80dd-d77fbdc04737

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
