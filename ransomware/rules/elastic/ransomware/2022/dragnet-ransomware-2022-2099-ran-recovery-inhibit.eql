// Dragnet [Ransomware]: dragnet-ransomware-2022-2099 — Recovery Inhibition (sparta)
// Status: deprecated | Level: high | ID: 640c8506-2d45-5197-93b8-61034ac3eeae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
