// Dragnet [Ransomware]: dragnet-ransomware-2022-1417 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 2cad7c0e-e0e3-5119-b49d-5d8de636b243

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
