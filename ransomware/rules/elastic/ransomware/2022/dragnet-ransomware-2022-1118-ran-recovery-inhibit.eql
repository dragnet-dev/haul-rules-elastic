// Dragnet [Ransomware]: dragnet-ransomware-2022-1118 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 220a3de1-8cd0-5b45-be3d-3718f2f98e31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
