// Dragnet [Ransomware]: dragnet-ransomware-2022-2705 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 198ef207-477c-5d5a-afde-86dd96ed4b26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
