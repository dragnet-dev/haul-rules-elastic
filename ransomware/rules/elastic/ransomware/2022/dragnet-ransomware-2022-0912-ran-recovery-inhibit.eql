// Dragnet [Ransomware]: dragnet-ransomware-2022-0912 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 67e18d2b-1047-556c-b107-e9d4188cfcec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
