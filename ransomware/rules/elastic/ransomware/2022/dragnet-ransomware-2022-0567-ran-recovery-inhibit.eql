// Dragnet [Ransomware]: dragnet-ransomware-2022-0567 — Recovery Inhibition (monti)
// Status: deprecated | Level: high | ID: d0dd2f42-b508-5c58-ba05-3899ea122e64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
