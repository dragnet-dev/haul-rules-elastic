// Dragnet [Ransomware]: dragnet-ransomware-2022-2054 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 0efd22b4-d5d2-5e63-ab35-21d2d58d13f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
