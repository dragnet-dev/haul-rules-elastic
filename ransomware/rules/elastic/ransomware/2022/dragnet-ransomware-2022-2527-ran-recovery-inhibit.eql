// Dragnet [Ransomware]: dragnet-ransomware-2022-2527 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: d33a8342-df85-5bee-b569-58d23d649204

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
