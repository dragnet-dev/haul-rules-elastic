// Dragnet [Ransomware]: dragnet-ransomware-2022-2368 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: c3ab18be-e5d5-5a84-b367-74baf3432b4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
