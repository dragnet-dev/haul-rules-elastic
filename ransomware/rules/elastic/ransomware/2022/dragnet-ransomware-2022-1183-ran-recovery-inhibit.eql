// Dragnet [Ransomware]: dragnet-ransomware-2022-1183 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ab7a0f23-bb7e-581d-bfee-4bfb501580d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
