// Dragnet [Ransomware]: dragnet-ransomware-2022-2325 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 8c350787-7c6c-59d8-8359-0259ec7182fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
