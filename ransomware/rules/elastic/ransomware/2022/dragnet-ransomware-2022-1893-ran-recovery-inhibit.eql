// Dragnet [Ransomware]: dragnet-ransomware-2022-1893 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: a9b1036b-c1fd-5a93-9864-740e29c7b398

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
