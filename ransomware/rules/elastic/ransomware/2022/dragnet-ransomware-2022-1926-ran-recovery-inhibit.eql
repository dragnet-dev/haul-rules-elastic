// Dragnet [Ransomware]: dragnet-ransomware-2022-1926 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: d47b8d36-14f1-599a-a47e-d8623020752b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
