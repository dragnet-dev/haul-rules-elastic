// Dragnet [Ransomware]: dragnet-ransomware-2022-1007 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 163973a9-6ddf-5e0e-ba2f-eb34e5b19309

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
