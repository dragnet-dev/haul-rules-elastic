// Dragnet [Ransomware]: dragnet-ransomware-2022-1367 — Recovery Inhibition (pandora)
// Status: deprecated | Level: high | ID: ec06ee5d-482d-552d-951c-61d836cd0856

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
