// Dragnet [Ransomware]: dragnet-ransomware-2022-2504 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2c499dd4-2c1c-52cd-aa80-d6b36471b180

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
