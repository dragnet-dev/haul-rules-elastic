// Dragnet [Ransomware]: dragnet-ransomware-2022-3054 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 42fd3c0a-a466-51e0-abfa-d1bc9dc84038

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
