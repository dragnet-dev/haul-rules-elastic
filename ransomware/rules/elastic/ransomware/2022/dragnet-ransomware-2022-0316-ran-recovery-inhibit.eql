// Dragnet [Ransomware]: dragnet-ransomware-2022-0316 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 69805600-1c70-53cb-a4ea-0927723991c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
