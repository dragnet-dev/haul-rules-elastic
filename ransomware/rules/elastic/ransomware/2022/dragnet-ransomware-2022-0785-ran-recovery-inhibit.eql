// Dragnet [Ransomware]: dragnet-ransomware-2022-0785 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b33e1bba-ee54-5ff1-b1fa-02676fedee3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
