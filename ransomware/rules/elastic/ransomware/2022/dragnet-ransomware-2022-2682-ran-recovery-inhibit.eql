// Dragnet [Ransomware]: dragnet-ransomware-2022-2682 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: fe2320c7-f318-508f-b374-5ac136695c2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
