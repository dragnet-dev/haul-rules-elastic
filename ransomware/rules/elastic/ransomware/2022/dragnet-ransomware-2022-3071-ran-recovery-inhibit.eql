// Dragnet [Ransomware]: dragnet-ransomware-2022-3071 — Recovery Inhibition (sabbath)
// Status: deprecated | Level: high | ID: 6a318691-1c51-5e85-9c35-d7050807587f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
