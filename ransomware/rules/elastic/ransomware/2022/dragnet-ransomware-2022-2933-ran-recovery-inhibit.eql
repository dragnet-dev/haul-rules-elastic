// Dragnet [Ransomware]: dragnet-ransomware-2022-2933 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8de9446c-cf22-5625-b76c-6034cfa14698

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
