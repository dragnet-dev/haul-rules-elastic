// Dragnet [Ransomware]: dragnet-ransomware-2022-1924 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 19249654-f061-539d-9a6b-7f8e3c3752c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
