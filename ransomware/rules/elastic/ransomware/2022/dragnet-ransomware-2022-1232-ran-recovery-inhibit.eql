// Dragnet [Ransomware]: dragnet-ransomware-2022-1232 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 1ebc8e56-9b1c-5d95-a0f3-4856012bab51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
