// Dragnet [Ransomware]: dragnet-ransomware-2022-0363 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: f15f79b7-f8fa-5e01-92f0-4e81818aea79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
