// Dragnet [Ransomware]: dragnet-ransomware-2022-1908 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 4b678bbe-ca69-5fa9-b0a7-d7a81106fac3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
