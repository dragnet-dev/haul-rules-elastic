// Dragnet [Ransomware]: dragnet-ransomware-2022-2308 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 07a757b1-feb6-5312-aaed-65263339a47a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
