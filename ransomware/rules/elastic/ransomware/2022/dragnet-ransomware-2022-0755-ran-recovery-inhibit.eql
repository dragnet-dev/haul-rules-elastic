// Dragnet [Ransomware]: dragnet-ransomware-2022-0755 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ec16b657-8057-5c1c-ad2d-47318b244e8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
