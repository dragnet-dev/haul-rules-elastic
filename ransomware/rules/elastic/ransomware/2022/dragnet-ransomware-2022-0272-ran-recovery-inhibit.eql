// Dragnet [Ransomware]: dragnet-ransomware-2022-0272 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 96802ce0-a655-559d-916a-c67c06f5e1ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
