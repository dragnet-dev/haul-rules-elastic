// Dragnet [Ransomware]: dragnet-ransomware-2022-0836 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 040dba23-e9e8-5463-83ae-8fe838d11654

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
