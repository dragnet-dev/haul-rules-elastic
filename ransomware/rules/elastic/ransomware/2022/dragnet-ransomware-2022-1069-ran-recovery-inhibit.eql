// Dragnet [Ransomware]: dragnet-ransomware-2022-1069 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: bdf85dd5-4a65-517b-81c8-e466a90a054d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
