// Dragnet [Ransomware]: dragnet-ransomware-2022-0116 — Recovery Inhibition (dataleak)
// Status: deprecated | Level: high | ID: 85612f95-5bd0-5756-8d97-0ff5e10b126f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
