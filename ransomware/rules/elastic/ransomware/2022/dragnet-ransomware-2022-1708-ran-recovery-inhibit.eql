// Dragnet [Ransomware]: dragnet-ransomware-2022-1708 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 49016184-d7d2-5360-8e3d-49078ee75ec7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
