// Dragnet [Ransomware]: dragnet-ransomware-2022-1700 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5b984260-b9c1-5adb-81dd-875963bd2820

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
