// Dragnet [Ransomware]: dragnet-ransomware-2022-1119 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: f899e1c6-974b-59e7-a2ad-4a5f3766460d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
