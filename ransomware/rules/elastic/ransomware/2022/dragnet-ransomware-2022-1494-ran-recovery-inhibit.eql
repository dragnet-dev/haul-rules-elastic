// Dragnet [Ransomware]: dragnet-ransomware-2022-1494 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 022cb5e6-db5a-5a99-b14f-51cb795ef7b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
