// Dragnet [Ransomware]: dragnet-ransomware-2022-0670 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 1cd67639-66b1-5ed2-994b-5676502500ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
