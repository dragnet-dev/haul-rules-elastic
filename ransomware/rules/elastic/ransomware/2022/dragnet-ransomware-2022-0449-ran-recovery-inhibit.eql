// Dragnet [Ransomware]: dragnet-ransomware-2022-0449 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 680a455a-73b4-5d6d-bba7-deaef01aad1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
