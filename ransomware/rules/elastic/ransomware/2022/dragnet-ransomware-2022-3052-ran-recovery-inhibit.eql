// Dragnet [Ransomware]: dragnet-ransomware-2022-3052 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: e2106778-3490-5cf7-ac06-1f5610f6adbd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
