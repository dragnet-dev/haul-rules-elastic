// Dragnet [Ransomware]: dragnet-ransomware-2022-2576 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 61f5ac98-2527-5471-a94a-c5641a1e49c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
