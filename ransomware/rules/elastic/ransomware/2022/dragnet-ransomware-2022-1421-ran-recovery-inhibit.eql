// Dragnet [Ransomware]: dragnet-ransomware-2022-1421 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 32920a3d-abb2-58b1-842a-abb205b932fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
