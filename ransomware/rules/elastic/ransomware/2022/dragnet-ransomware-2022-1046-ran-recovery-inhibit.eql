// Dragnet [Ransomware]: dragnet-ransomware-2022-1046 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 3138e6c0-b153-5ee5-87f3-7cd17f4388c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
