// Dragnet [Ransomware]: dragnet-ransomware-2022-2805 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: fbc6589a-7408-560e-ba9b-81d9f464ed39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
