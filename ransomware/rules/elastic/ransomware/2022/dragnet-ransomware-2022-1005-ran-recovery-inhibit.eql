// Dragnet [Ransomware]: dragnet-ransomware-2022-1005 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 2cc93033-1050-5e3f-b225-d84b523c3639

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
