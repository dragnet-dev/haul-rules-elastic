// Dragnet [Ransomware]: dragnet-ransomware-2022-0909 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: dfe08bef-17bc-56d7-8a49-eceedcd79575

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
