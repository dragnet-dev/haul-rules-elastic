// Dragnet [Ransomware]: dragnet-ransomware-2022-0430 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8edc5eb5-b98a-5a11-83b7-d59824ce9090

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
