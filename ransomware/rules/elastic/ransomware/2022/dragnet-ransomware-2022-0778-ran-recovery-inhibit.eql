// Dragnet [Ransomware]: dragnet-ransomware-2022-0778 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 10f3c829-7666-537c-b03d-ae0438358566

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
