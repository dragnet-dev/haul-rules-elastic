// Dragnet [Ransomware]: dragnet-ransomware-2022-0427 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e4e2292b-ce27-5735-974f-0085df07d347

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
