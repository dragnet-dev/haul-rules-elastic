// Dragnet [Ransomware]: dragnet-ransomware-2022-2257 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 47f3ea6c-f22f-5db0-95ad-3b8eb8f7adc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
