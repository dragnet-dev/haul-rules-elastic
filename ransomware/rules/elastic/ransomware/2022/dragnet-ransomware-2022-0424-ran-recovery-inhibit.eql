// Dragnet [Ransomware]: dragnet-ransomware-2022-0424 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: bc9e673a-bccf-5fcb-9bff-16768e6b3bb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
