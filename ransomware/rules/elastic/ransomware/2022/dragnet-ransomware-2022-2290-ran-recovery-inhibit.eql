// Dragnet [Ransomware]: dragnet-ransomware-2022-2290 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 155e0a43-da60-5061-851a-2e1b83983b3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
