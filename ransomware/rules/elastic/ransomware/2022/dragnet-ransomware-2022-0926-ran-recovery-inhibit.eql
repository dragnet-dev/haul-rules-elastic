// Dragnet [Ransomware]: dragnet-ransomware-2022-0926 — Recovery Inhibition (cheers)
// Status: deprecated | Level: high | ID: b6e44d10-5652-52a0-859d-6aba63b2a583

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
