// Dragnet [Ransomware]: dragnet-ransomware-2022-1985 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: 53aa5010-ca4b-5be6-9121-d409ea04288a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
