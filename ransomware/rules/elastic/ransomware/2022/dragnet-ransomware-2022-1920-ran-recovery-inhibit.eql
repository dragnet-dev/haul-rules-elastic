// Dragnet [Ransomware]: dragnet-ransomware-2022-1920 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: fd1e9352-5895-50d3-8dc2-b2156eaa8ab2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
