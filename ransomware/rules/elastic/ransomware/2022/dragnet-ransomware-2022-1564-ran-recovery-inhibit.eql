// Dragnet [Ransomware]: dragnet-ransomware-2022-1564 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: b274bf27-31ad-5078-83ec-c3dc7db11c0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
