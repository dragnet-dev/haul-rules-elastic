// Dragnet [Ransomware]: dragnet-ransomware-2022-1493 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5359b519-5fe4-5829-8fcc-92bcf086dba6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
