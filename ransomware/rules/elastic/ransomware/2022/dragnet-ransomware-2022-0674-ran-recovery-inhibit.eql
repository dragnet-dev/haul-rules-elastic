// Dragnet [Ransomware]: dragnet-ransomware-2022-0674 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 44ac880c-bd06-512c-ae76-a216ce0c07d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
