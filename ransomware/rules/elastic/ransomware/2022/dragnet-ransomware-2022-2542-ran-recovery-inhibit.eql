// Dragnet [Ransomware]: dragnet-ransomware-2022-2542 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 46719a09-b1c5-5fac-85af-7cbf7eb4a25e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
