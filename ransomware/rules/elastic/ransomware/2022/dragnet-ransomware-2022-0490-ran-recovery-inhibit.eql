// Dragnet [Ransomware]: dragnet-ransomware-2022-0490 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 84527fe2-bc3a-5fca-9961-7aef99725900

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
