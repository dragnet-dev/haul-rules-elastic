// Dragnet [Ransomware]: dragnet-ransomware-2022-1019 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 908b3909-f070-5645-a04d-86895900a401

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
