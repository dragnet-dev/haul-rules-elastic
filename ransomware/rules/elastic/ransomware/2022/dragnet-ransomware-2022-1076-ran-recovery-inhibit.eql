// Dragnet [Ransomware]: dragnet-ransomware-2022-1076 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 1078d7ba-baff-5f30-badc-4d9d34def585

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
