// Dragnet [Ransomware]: dragnet-ransomware-2022-0214 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 12838655-7b99-56c3-a115-54ba36f168da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
