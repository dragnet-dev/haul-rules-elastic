// Dragnet [Ransomware]: dragnet-ransomware-2022-0370 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: a6d14bc9-3a1e-5fd6-a0a1-7d74401d8c0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
