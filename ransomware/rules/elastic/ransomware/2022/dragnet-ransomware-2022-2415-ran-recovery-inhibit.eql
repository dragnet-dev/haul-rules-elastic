// Dragnet [Ransomware]: dragnet-ransomware-2022-2415 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 6df6a646-f20b-5d8e-84c0-8919ee1cf0b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
