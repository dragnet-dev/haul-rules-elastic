// Dragnet [Ransomware]: dragnet-ransomware-2022-0578 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: d6513f03-65a6-582f-967f-8eb4dc55fbda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
