// Dragnet [Ransomware]: dragnet-ransomware-2022-1902 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 3785f92e-451e-5b81-ba82-73bb64947dca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
