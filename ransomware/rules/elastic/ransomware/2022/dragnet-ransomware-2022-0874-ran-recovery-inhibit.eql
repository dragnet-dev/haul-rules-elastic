// Dragnet [Ransomware]: dragnet-ransomware-2022-0874 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: 6e93b653-122d-576a-b8bc-8b29abc0ed6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
