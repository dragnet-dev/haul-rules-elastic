// Dragnet [Ransomware]: dragnet-ransomware-2022-1358 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 7b41a948-b0a9-5119-8dad-eb19e0348070

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
