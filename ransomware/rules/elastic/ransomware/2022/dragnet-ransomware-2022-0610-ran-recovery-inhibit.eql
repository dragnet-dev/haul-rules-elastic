// Dragnet [Ransomware]: dragnet-ransomware-2022-0610 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: e1ee7b93-7354-55f4-8a2b-c150fe889bc3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
