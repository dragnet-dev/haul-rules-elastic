// Dragnet [Ransomware]: dragnet-ransomware-2022-3153 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ff73de0a-f77f-59d3-81e4-6248ebf0e890

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
