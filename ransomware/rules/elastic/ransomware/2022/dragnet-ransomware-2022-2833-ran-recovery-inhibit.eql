// Dragnet [Ransomware]: dragnet-ransomware-2022-2833 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2a954740-ad81-5fbd-b0a3-e7676a92a63b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
