// Dragnet [Ransomware]: dragnet-ransomware-2022-0042 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 3f19e75b-f574-5cab-9880-5c77e7c46d92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
