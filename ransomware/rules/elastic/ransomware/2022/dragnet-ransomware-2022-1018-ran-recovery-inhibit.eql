// Dragnet [Ransomware]: dragnet-ransomware-2022-1018 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 946a55fa-14f9-5805-811e-f63ceffab6ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
