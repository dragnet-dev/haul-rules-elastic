// Dragnet [Ransomware]: dragnet-ransomware-2022-1755 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 8cdb5763-72f6-5089-bfb6-3356bd708a99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
