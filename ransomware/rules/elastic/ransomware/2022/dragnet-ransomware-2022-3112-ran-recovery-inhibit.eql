// Dragnet [Ransomware]: dragnet-ransomware-2022-3112 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: d33404f1-aad7-5629-855e-701b5f74333e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
