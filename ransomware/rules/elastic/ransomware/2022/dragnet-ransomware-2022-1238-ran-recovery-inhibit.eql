// Dragnet [Ransomware]: dragnet-ransomware-2022-1238 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 2e6c2c3e-95e1-5108-9da0-99088007e37e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
