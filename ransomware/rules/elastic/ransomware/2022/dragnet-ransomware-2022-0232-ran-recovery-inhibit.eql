// Dragnet [Ransomware]: dragnet-ransomware-2022-0232 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: df3ea178-5f34-5ba3-aad0-09f753554821

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
