// Dragnet [Ransomware]: dragnet-ransomware-2022-2689 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5574491f-61f4-5d97-8966-a30964755a15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
