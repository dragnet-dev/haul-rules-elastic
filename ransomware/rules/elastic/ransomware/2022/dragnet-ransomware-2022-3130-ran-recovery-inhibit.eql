// Dragnet [Ransomware]: dragnet-ransomware-2022-3130 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 65a85fe5-4d7f-5537-9e5c-af1ce94f8179

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
