// Dragnet [Ransomware]: dragnet-ransomware-2022-2033 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 9f6ec38e-dce6-5eef-a6a5-f3a5934ee751

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
