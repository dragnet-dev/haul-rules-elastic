// Dragnet [Ransomware]: dragnet-ransomware-2022-0579 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: c3bec869-3578-5211-afb9-af874fe25e3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
