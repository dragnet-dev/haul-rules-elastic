// Dragnet [Ransomware]: dragnet-ransomware-2022-1693 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: b1682215-ff7f-51af-a534-dc1dafbae73a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
