// Dragnet [Ransomware]: dragnet-ransomware-2022-0919 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 818c0da0-87ad-55b2-90f1-e68bdd3b8844

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
