// Dragnet [Ransomware]: dragnet-ransomware-2022-1081 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 43aac365-a670-5f1e-aeab-97cc00301e63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
