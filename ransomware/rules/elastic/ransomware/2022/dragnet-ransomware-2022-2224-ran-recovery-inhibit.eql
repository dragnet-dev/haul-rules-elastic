// Dragnet [Ransomware]: dragnet-ransomware-2022-2224 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: bc6e73dd-fb17-5af0-9801-25eebf5020c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
