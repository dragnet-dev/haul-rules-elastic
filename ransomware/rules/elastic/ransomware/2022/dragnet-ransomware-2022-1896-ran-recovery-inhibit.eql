// Dragnet [Ransomware]: dragnet-ransomware-2022-1896 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c285a4a0-6707-58a3-a808-78870fb162d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
