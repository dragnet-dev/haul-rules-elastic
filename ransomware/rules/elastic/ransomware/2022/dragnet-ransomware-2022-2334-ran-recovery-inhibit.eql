// Dragnet [Ransomware]: dragnet-ransomware-2022-2334 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 8de3b99a-2256-59ee-9fbc-ce7d5526a14b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
