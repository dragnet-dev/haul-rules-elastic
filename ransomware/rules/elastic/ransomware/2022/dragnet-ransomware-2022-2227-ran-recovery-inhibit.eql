// Dragnet [Ransomware]: dragnet-ransomware-2022-2227 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 80377089-f21f-591d-8a54-e0bda24d9dde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
