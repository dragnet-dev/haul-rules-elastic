// Dragnet [Ransomware]: dragnet-ransomware-2022-2794 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: e250636c-81bc-5023-bb44-936ed7910587

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
