// Dragnet [Ransomware]: dragnet-ransomware-2022-0409 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: fc072068-14f5-5d7f-80e2-8c5cee95e914

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
