// Dragnet [Ransomware]: dragnet-ransomware-2022-0086 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: 05408dbe-6645-537c-acdd-320efbc09062

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
