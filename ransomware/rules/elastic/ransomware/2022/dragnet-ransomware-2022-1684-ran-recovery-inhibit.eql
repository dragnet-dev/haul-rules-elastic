// Dragnet [Ransomware]: dragnet-ransomware-2022-1684 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: fc35d172-cfa6-56f6-a355-67909f7b6731

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
