// Dragnet [Ransomware]: dragnet-ransomware-2022-2387 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 7694fca7-9b13-5001-9f15-8fe1419b6895

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
