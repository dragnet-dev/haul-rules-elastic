// Dragnet [Ransomware]: dragnet-ransomware-2022-0997 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: a84d4629-1d86-5d2d-8388-366017f1a4ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
