// Dragnet [Ransomware]: dragnet-ransomware-2022-0805 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 65b7b49b-141a-5691-af1a-7efa832d1a80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
