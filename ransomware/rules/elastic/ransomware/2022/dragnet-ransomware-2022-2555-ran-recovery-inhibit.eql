// Dragnet [Ransomware]: dragnet-ransomware-2022-2555 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 119dc991-a17f-5bdf-83a6-5a1d3e1a5956

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
