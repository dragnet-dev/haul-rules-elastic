// Dragnet [Ransomware]: dragnet-ransomware-2022-1631 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: bfde74b3-5df3-558d-b637-8cec2f65372f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
