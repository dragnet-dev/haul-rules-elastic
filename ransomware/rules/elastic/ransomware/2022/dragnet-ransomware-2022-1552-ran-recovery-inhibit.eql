// Dragnet [Ransomware]: dragnet-ransomware-2022-1552 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4fbecdf7-0e55-564e-9244-e5b36f73a002

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
