// Dragnet [Ransomware]: dragnet-ransomware-2022-1284 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: eab5a02c-981e-5851-9bfc-c02859c4344f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
