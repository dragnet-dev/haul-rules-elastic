// Dragnet [Ransomware]: dragnet-ransomware-2022-1158 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a21c5e67-2c15-56d6-bdc1-34905044928d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
