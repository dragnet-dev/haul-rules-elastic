// Dragnet [Ransomware]: dragnet-ransomware-2022-1881 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: e9bfac3b-746e-586e-8f3c-6ecffdfff9e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
