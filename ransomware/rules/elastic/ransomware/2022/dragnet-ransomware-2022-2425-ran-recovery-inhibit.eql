// Dragnet [Ransomware]: dragnet-ransomware-2022-2425 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: ed6790aa-0bc5-53bd-9dc7-2e8eeb988e2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
