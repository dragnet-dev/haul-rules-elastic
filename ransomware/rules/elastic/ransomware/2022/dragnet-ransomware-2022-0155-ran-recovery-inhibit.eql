// Dragnet [Ransomware]: dragnet-ransomware-2022-0155 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 53b53528-117d-53cb-b6e5-a557f13134a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
