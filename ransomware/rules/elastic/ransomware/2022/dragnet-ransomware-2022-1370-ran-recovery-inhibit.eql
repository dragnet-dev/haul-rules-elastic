// Dragnet [Ransomware]: dragnet-ransomware-2022-1370 — Recovery Inhibition (cheers)
// Status: deprecated | Level: high | ID: d945355b-85c8-5809-85b7-296fa95bf7f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
