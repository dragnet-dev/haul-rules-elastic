// Dragnet [Ransomware]: dragnet-ransomware-2022-1804 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: f95e8de4-8080-5841-975c-4bf57bbe7d78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
