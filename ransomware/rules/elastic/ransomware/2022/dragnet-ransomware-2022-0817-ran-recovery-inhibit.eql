// Dragnet [Ransomware]: dragnet-ransomware-2022-0817 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 430ff105-fce6-5f66-8bf4-599de852943f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
