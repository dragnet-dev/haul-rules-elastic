// Dragnet [Ransomware]: dragnet-ransomware-2022-0527 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 70c0fa41-b0e4-5be1-a348-511a2e35699b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
