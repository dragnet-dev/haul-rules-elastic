// Dragnet [Ransomware]: dragnet-ransomware-2022-0437 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: ac88a8df-b9f5-5ec5-9165-b3b9d6b05419

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
