// Dragnet [Ransomware]: dragnet-ransomware-2022-2151 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 45ea454a-54e8-5cab-a7a1-c7c555568470

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
