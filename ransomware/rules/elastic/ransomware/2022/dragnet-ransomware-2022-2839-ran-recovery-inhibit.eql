// Dragnet [Ransomware]: dragnet-ransomware-2022-2839 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: baa043cd-76af-5638-813e-129bc0f8c108

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
