// Dragnet [Ransomware]: dragnet-ransomware-2022-1960 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: 35777275-4496-5d52-a2ae-498b7b6bad18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
