// Dragnet [Ransomware]: dragnet-ransomware-2022-3040 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c507d72a-5139-57cb-8f13-8ed77b5805bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
