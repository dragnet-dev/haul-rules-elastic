// Dragnet [Ransomware]: dragnet-ransomware-2022-2738 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 2525ac02-3c3e-55e1-a772-8a2d9ad1940b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
