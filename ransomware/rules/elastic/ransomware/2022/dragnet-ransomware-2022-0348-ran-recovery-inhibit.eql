// Dragnet [Ransomware]: dragnet-ransomware-2022-0348 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: be9a1046-d3bd-564b-8150-3fae639e370d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
