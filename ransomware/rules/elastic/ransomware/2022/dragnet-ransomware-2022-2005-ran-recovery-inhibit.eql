// Dragnet [Ransomware]: dragnet-ransomware-2022-2005 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: c6474f9c-93be-5fe8-bb96-ed250e74c878

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
