// Dragnet [Ransomware]: dragnet-ransomware-2022-1141 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 817f7855-e659-5838-92a0-3fe5121c2857

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
