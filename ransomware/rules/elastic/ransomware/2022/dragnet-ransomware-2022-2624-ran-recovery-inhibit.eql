// Dragnet [Ransomware]: dragnet-ransomware-2022-2624 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 922d4682-e53c-50f0-a0cc-20f15d167224

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
