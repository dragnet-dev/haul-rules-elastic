// Dragnet [Ransomware]: dragnet-ransomware-2022-0373 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 51fbcf40-68f1-54e8-8863-4bd5a3d41f97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
