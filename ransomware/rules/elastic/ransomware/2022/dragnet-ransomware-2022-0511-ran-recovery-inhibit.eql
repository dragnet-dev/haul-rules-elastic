// Dragnet [Ransomware]: dragnet-ransomware-2022-0511 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 97f6e3fa-7ef2-5894-b669-9dcfe77c7872

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
