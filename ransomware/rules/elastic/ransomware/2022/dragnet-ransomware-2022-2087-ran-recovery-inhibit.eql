// Dragnet [Ransomware]: dragnet-ransomware-2022-2087 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 722f04e5-62ac-5d3e-a95c-daa3b2150c80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
