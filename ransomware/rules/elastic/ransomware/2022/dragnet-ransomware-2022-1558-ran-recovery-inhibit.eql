// Dragnet [Ransomware]: dragnet-ransomware-2022-1558 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: fb64742a-9637-5bc0-a3b1-0ae2b7e72df8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
