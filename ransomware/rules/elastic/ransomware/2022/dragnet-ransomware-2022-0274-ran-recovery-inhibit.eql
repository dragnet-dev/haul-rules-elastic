// Dragnet [Ransomware]: dragnet-ransomware-2022-0274 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: d341c550-94b7-5120-ad14-34cc568f6547

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
