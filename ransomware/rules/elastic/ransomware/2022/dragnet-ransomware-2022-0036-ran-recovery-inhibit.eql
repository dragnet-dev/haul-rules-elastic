// Dragnet [Ransomware]: dragnet-ransomware-2022-0036 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: bb08e5a1-e019-579a-8f84-1efe0f3da1eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
