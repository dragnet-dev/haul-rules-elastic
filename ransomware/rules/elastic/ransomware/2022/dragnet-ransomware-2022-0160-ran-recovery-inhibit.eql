// Dragnet [Ransomware]: dragnet-ransomware-2022-0160 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 7cfdab7c-e6c6-516d-ac1b-1bc930f5aab1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
