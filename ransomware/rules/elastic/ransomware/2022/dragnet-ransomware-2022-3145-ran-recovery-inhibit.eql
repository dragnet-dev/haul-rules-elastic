// Dragnet [Ransomware]: dragnet-ransomware-2022-3145 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a81afe7e-a6aa-5fe9-9e6f-45098842d73c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
