// Dragnet [Ransomware]: dragnet-ransomware-2022-2191 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 29dc646c-be81-56b9-bc7c-c1abe8b4a4e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
