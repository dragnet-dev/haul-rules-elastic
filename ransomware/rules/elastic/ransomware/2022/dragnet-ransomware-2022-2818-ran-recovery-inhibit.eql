// Dragnet [Ransomware]: dragnet-ransomware-2022-2818 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: dbbf9bbd-1642-5a6e-8c07-ae0d90380369

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
