// Dragnet [Ransomware]: dragnet-ransomware-2022-1490 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 292a298e-636d-5abe-b5be-34e0ca6fd675

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
