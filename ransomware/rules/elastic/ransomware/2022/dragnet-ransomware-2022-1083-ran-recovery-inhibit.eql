// Dragnet [Ransomware]: dragnet-ransomware-2022-1083 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: bdc10292-002a-593b-b08e-99d6b5aa8120

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
