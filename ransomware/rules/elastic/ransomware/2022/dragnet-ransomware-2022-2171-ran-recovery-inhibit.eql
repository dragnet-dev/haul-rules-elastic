// Dragnet [Ransomware]: dragnet-ransomware-2022-2171 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 93f6f9d0-9c77-5188-900f-189557df30df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
