// Dragnet [Ransomware]: dragnet-ransomware-2022-2510 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8cc463c5-3072-5a0f-8112-e36322400aa4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
