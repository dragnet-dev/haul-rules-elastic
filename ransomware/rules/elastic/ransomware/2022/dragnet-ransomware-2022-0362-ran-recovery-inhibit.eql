// Dragnet [Ransomware]: dragnet-ransomware-2022-0362 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: d3a1fcca-b2b1-5f5c-82db-ccd4d283242d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
