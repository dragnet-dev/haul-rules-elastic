// Dragnet [Ransomware]: dragnet-ransomware-2022-0534 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: f0d28067-9820-5062-a7a1-92a28826ef1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
