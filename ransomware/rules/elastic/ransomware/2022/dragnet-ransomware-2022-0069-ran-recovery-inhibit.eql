// Dragnet [Ransomware]: dragnet-ransomware-2022-0069 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 42ee53a0-c6b3-5299-933b-f908892a970c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
