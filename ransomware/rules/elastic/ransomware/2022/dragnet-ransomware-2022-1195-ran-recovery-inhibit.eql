// Dragnet [Ransomware]: dragnet-ransomware-2022-1195 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: a667cb98-c198-5f7d-8707-79674e25635d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
