// Dragnet [Ransomware]: dragnet-ransomware-2022-0769 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5232155b-df2c-556e-a0ad-df3a78e1effa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
