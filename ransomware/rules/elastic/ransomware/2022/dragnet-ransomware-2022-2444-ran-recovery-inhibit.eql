// Dragnet [Ransomware]: dragnet-ransomware-2022-2444 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2786617d-efe8-53db-baf3-34e17347a10d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
