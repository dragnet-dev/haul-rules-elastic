// Dragnet [Ransomware]: dragnet-ransomware-2022-1919 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c7e91500-34eb-5c9d-af15-835a6223c4a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
