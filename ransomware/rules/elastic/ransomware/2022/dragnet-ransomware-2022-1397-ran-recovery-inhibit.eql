// Dragnet [Ransomware]: dragnet-ransomware-2022-1397 — Recovery Inhibition (mindware)
// Status: deprecated | Level: high | ID: 0af1ee65-bf58-5c75-a642-305196f20322

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
