// Dragnet [Ransomware]: dragnet-ransomware-2022-0802 — Recovery Inhibition (medusalocker)
// Status: deprecated | Level: high | ID: 21f63fbd-7284-5f55-a278-c74b076fa265

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
