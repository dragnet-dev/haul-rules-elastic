// Dragnet [Ransomware]: dragnet-ransomware-2022-1057 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 3fc94bb4-eea2-5b5c-98b1-9131e2827ab7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
