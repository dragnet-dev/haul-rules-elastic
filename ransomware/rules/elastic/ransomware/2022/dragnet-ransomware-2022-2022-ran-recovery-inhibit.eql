// Dragnet [Ransomware]: dragnet-ransomware-2022-2022 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 067c5f3d-48a0-5285-8490-524ba7bf4387

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
