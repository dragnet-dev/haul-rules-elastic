// Dragnet [Ransomware]: dragnet-ransomware-2022-1936 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: d72f3877-e7a4-5dba-b76c-b14ac79c680d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
