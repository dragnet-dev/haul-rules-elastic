// Dragnet [Ransomware]: dragnet-ransomware-2022-0157 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ff4375be-5a17-5ac4-8406-36f1f6dc5fdd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
