// Dragnet [Ransomware]: dragnet-ransomware-2022-3123 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 76ceac82-ad36-5c24-8842-d631355bea7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
