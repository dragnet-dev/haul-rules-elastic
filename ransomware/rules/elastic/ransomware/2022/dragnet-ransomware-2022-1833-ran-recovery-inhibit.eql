// Dragnet [Ransomware]: dragnet-ransomware-2022-1833 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 36949cbf-313f-5f7d-a1f3-556fc503d233

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
