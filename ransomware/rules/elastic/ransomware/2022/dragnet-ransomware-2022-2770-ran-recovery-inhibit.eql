// Dragnet [Ransomware]: dragnet-ransomware-2022-2770 — Recovery Inhibition (0mega)
// Status: deprecated | Level: high | ID: b4cb4396-5578-51b0-886e-a206e2be8820

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
