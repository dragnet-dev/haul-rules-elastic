// Dragnet [Ransomware]: dragnet-ransomware-2022-1460 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: efab97e9-b380-557d-b18f-b0edc72e7718

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
