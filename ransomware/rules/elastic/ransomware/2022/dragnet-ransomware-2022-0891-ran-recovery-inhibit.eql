// Dragnet [Ransomware]: dragnet-ransomware-2022-0891 — Recovery Inhibition (pandora)
// Status: deprecated | Level: high | ID: cf4f1c2f-e700-520a-8cfd-f792a00a122b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
