// Dragnet [Ransomware]: dragnet-ransomware-2022-1662 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 26a7408c-f9ca-509b-836f-f42d815854a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
