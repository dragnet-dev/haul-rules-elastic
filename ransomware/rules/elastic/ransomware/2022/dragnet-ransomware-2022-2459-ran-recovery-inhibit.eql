// Dragnet [Ransomware]: dragnet-ransomware-2022-2459 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 29b0ac65-d638-5279-ae3b-6fa6c3804234

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
