// Dragnet [Ransomware]: dragnet-ransomware-2022-2814 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: d8ca0344-e2a1-5806-b46f-bc8201b9b05c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
