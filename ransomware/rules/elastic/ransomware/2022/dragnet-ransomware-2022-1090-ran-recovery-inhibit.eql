// Dragnet [Ransomware]: dragnet-ransomware-2022-1090 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 665f7d3e-577e-5a72-ac7e-c9c1b085293f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
