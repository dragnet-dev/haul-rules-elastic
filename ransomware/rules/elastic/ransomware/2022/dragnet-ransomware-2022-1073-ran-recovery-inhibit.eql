// Dragnet [Ransomware]: dragnet-ransomware-2022-1073 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0f7b6176-8403-53ca-bbb4-4bb831d724fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
