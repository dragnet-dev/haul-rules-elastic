// Dragnet [Ransomware]: dragnet-ransomware-2022-2320 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 83267cf9-570e-5362-851e-16e431f77e4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
