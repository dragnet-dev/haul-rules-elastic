// Dragnet [Ransomware]: dragnet-ransomware-2022-0806 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 51713db0-69b2-564e-b6cf-363bff786410

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
