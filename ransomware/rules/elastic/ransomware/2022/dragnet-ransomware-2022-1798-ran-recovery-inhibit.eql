// Dragnet [Ransomware]: dragnet-ransomware-2022-1798 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ca01adbb-6ba5-51f6-adcd-4f89ef98106a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
