// Dragnet [Ransomware]: dragnet-ransomware-2022-1822 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 784f7201-8790-5d82-8d5d-a335f847ffa2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
