// Dragnet [Ransomware]: dragnet-ransomware-2022-1832 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 532501b5-4489-5ad5-95cf-7109e18b2c53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
