// Dragnet [Ransomware]: dragnet-ransomware-2022-0479 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2da51300-26d5-5e38-b8d7-400663cd0987

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
