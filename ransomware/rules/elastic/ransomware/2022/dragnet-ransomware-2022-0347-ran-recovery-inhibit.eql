// Dragnet [Ransomware]: dragnet-ransomware-2022-0347 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: c7d1288e-00ba-5cfb-b9dd-54df5baf9827

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
