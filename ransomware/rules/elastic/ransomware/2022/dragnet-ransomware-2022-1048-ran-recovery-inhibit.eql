// Dragnet [Ransomware]: dragnet-ransomware-2022-1048 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: adde075f-39ca-504d-bc31-9b6401119f66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
