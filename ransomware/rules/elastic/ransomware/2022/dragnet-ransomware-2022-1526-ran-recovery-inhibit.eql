// Dragnet [Ransomware]: dragnet-ransomware-2022-1526 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 759f7586-a38f-583b-a1e0-b93d75fda364

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
