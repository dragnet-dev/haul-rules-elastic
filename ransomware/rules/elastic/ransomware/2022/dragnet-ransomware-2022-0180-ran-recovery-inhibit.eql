// Dragnet [Ransomware]: dragnet-ransomware-2022-0180 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 78f20163-c312-5ce6-b167-acc27b563695

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
