// Dragnet [Ransomware]: dragnet-ransomware-2022-0770 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: ea663ae7-7f04-5e3e-a169-e2a05a34d4c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
