// Dragnet [Ransomware]: dragnet-ransomware-2022-2583 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: d8af2fc4-6dd5-5909-9e76-9705791f9b9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
