// Dragnet [Ransomware]: dragnet-ransomware-2022-0227 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ceec49e7-0903-5923-8cf2-c93967720deb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
