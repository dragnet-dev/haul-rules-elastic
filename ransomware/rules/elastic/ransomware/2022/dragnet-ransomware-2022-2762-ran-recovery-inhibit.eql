// Dragnet [Ransomware]: dragnet-ransomware-2022-2762 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: d5dbba16-8c62-5824-8e81-c25890f5d727

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
