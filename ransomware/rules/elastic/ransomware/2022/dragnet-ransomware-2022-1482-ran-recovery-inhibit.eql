// Dragnet [Ransomware]: dragnet-ransomware-2022-1482 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6cf3a1b0-3a57-55cd-a698-8e5e72ea926d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
