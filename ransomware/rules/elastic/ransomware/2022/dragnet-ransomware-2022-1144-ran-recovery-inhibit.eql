// Dragnet [Ransomware]: dragnet-ransomware-2022-1144 — Recovery Inhibition (mindware)
// Status: deprecated | Level: high | ID: 2090041a-2987-50f3-9c0d-2eb9bfab1a99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
