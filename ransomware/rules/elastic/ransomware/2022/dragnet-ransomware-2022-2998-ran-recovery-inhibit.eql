// Dragnet [Ransomware]: dragnet-ransomware-2022-2998 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 4ea5847f-4b6b-51ef-9207-832e1934e21c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
