// Dragnet [Ransomware]: dragnet-ransomware-2022-1701 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 59281d02-b66f-5d6b-b097-bbc91d4a7e76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
