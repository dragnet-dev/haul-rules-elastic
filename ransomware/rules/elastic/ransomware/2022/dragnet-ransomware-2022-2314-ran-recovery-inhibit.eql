// Dragnet [Ransomware]: dragnet-ransomware-2022-2314 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 32b13429-caab-5dc8-ad47-a742bb6c8aa7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
