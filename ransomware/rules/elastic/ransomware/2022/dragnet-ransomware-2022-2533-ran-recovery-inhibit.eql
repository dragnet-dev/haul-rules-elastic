// Dragnet [Ransomware]: dragnet-ransomware-2022-2533 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e7342a5b-77f6-5e2a-ba95-31dfabc7ca18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
