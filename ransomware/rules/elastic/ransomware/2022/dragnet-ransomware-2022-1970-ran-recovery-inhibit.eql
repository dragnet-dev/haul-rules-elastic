// Dragnet [Ransomware]: dragnet-ransomware-2022-1970 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: e3918de4-4b64-54ae-ba0e-049e05964e14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
