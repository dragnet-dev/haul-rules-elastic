// Dragnet [Ransomware]: dragnet-ransomware-2022-1045 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: de189adf-5078-5d09-bc6f-f891d2c22f3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
