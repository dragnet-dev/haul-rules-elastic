// Dragnet [Ransomware]: dragnet-ransomware-2022-2155 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 00c86762-3222-5a7e-9640-296516bb596b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
