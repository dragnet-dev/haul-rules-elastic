// Dragnet [Ransomware]: dragnet-ransomware-2022-0797 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 9afc440f-7f45-5e6e-b082-d91a67dd0e1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
