// Dragnet [Ransomware]: dragnet-ransomware-2022-1333 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 7957887a-d909-5b90-a51c-cf4736a34969

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
