// Dragnet [Ransomware]: dragnet-ransomware-2022-1314 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 959ac555-5821-5f92-a8f3-632936b1aa33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
