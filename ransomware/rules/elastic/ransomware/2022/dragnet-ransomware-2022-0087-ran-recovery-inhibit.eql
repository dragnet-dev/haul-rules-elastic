// Dragnet [Ransomware]: dragnet-ransomware-2022-0087 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 80df684b-263a-5fcc-9920-92408d0691fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
