// Dragnet [Ransomware]: dragnet-ransomware-2022-1613 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: f70f34ff-d316-563e-bbe0-8d17d0e8fe56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
