// Dragnet [Ransomware]: dragnet-ransomware-2022-0901 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: fe5da020-be1a-52b9-a76c-f039caffcf73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
