// Dragnet [Ransomware]: dragnet-ransomware-2022-0500 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 80dfa10a-01d0-5f82-b85e-abcf8bfa7690

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
