// Dragnet [Ransomware]: dragnet-ransomware-2022-2663 — Recovery Inhibition (payloadbin)
// Status: deprecated | Level: high | ID: 77cfae71-9d2f-50ba-a10e-2fa2e1b7389b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
