// Dragnet [Ransomware]: dragnet-ransomware-2022-2410 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: d2947639-3572-5467-8b53-21549c9d49dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
