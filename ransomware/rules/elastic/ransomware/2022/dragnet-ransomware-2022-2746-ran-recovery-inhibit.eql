// Dragnet [Ransomware]: dragnet-ransomware-2022-2746 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 6b54c783-9103-5163-af7a-4935562b51a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
