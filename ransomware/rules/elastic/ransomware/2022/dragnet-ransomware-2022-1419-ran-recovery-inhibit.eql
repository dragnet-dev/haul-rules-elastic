// Dragnet [Ransomware]: dragnet-ransomware-2022-1419 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: d6f73937-688f-5509-a9a7-2269046612d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
