// Dragnet [Ransomware]: dragnet-ransomware-2022-0413 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 572b9dc2-3272-57f8-9128-af4bc5faf884

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
