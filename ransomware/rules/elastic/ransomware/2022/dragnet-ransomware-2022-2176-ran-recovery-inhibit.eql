// Dragnet [Ransomware]: dragnet-ransomware-2022-2176 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 10822368-b08f-5f60-90e1-7bb61140a52d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
