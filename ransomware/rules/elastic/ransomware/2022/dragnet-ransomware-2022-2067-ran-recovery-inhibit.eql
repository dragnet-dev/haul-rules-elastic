// Dragnet [Ransomware]: dragnet-ransomware-2022-2067 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: d40744c0-132e-5ceb-ae80-f88413aabe4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
