// Dragnet [Ransomware]: dragnet-ransomware-2022-1827 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 9fddd276-8b1f-5ea7-89ca-bbf11e10d7cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
