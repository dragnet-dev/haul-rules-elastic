// Dragnet [Ransomware]: dragnet-ransomware-2022-1084 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: f4baa4d6-c5b1-54b4-b34b-d4ddde249671

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
