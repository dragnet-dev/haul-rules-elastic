// Dragnet [Ransomware]: dragnet-ransomware-2022-1580 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 9476281d-88c5-55db-ad67-5d7852909910

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
