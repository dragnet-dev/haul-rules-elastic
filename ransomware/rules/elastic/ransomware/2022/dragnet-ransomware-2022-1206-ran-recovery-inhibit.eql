// Dragnet [Ransomware]: dragnet-ransomware-2022-1206 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: c2d341d4-af63-56fb-8f33-4b1d0f5fcce1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
