// Dragnet [Ransomware]: dragnet-ransomware-2022-2105 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 938910d2-d0a2-572b-b736-e77246eb29bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
