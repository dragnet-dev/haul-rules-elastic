// Dragnet [Ransomware]: dragnet-ransomware-2022-2443 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 58f28870-e386-5009-a182-aed129c02b1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
