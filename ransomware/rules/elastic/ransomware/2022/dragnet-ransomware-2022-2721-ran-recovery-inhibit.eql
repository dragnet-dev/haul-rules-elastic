// Dragnet [Ransomware]: dragnet-ransomware-2022-2721 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: 37963d43-4de1-5be4-aca2-f0b27f97e344

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
