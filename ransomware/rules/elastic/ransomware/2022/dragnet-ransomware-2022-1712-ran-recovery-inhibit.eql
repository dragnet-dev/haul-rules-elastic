// Dragnet [Ransomware]: dragnet-ransomware-2022-1712 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 0018d5b8-5065-5e51-adcf-e3603ced304e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
