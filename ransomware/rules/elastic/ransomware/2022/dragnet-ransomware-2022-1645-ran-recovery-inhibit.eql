// Dragnet [Ransomware]: dragnet-ransomware-2022-1645 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: fd538789-92ec-56e5-954f-376c2fe134c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
