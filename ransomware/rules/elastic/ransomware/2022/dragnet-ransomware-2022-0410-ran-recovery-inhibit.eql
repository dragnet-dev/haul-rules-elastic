// Dragnet [Ransomware]: dragnet-ransomware-2022-0410 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d4667bc1-d8c1-500c-a7da-4dc4ee682cdf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
