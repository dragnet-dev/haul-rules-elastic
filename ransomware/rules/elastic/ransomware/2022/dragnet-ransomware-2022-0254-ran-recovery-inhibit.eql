// Dragnet [Ransomware]: dragnet-ransomware-2022-0254 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 9a2e39cc-bd0f-5feb-8e0f-6961c0750abb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
