// Dragnet [Ransomware]: dragnet-ransomware-2022-0132 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7eea08f5-3a68-55a7-93bd-fc89163835d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
