// Dragnet [Ransomware]: dragnet-ransomware-2022-1455 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 6d3f0633-ff7c-5d3c-971d-cb840ab2fd27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
