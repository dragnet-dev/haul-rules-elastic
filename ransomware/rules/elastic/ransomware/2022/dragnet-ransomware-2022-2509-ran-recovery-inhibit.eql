// Dragnet [Ransomware]: dragnet-ransomware-2022-2509 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 2a8917ec-c767-518f-9ebd-39d93923d8c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
