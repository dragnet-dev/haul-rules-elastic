// Dragnet [Ransomware]: dragnet-ransomware-2022-1525 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 491c9857-1ae9-57a9-9e83-8e9e472dae29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
