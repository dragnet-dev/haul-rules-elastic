// Dragnet [Ransomware]: dragnet-ransomware-2022-1254 — Recovery Inhibition (dataleak)
// Status: deprecated | Level: high | ID: 34bf020f-b11e-59ec-90d2-01337922ee33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
