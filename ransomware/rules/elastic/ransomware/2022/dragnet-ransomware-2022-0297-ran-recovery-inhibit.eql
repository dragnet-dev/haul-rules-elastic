// Dragnet [Ransomware]: dragnet-ransomware-2022-0297 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d8fb4641-0d6c-5b76-8aea-4dacba68da95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
