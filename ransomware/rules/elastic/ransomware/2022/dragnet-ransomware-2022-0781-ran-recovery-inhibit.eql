// Dragnet [Ransomware]: dragnet-ransomware-2022-0781 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: f3426cc2-fdaa-59d3-9fae-e368134b4f8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
