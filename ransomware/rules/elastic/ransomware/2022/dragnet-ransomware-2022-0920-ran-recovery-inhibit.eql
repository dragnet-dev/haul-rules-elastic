// Dragnet [Ransomware]: dragnet-ransomware-2022-0920 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 35bb8902-9f0d-5066-997d-cb494a65a330

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
