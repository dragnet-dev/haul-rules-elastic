// Dragnet [Ransomware]: dragnet-ransomware-2022-0958 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 629bf162-69b6-54eb-978c-8dbada7cba2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
