// Dragnet [Ransomware]: dragnet-ransomware-2022-1462 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: c3fe5f25-7de5-5b0d-a5c5-6f72d649e3bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
