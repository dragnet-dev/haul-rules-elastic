// Dragnet [Ransomware]: dragnet-ransomware-2022-2388 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: b5b3ac6e-cdd6-58f1-9b29-ed291961e64e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
