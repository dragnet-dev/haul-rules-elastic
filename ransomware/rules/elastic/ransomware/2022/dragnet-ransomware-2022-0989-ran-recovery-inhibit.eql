// Dragnet [Ransomware]: dragnet-ransomware-2022-0989 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: 268feac7-c6d8-5a89-bf6f-8b8c0bc13395

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
