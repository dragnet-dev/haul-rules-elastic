// Dragnet [Ransomware]: dragnet-ransomware-2022-2367 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: fc1eff29-1ee8-5b08-bf18-548033fa322e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
