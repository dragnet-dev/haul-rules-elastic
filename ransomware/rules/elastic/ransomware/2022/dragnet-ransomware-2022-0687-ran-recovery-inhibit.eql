// Dragnet [Ransomware]: dragnet-ransomware-2022-0687 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3e5f7086-751f-5c15-84d7-811f25868f4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
