// Dragnet [Ransomware]: dragnet-ransomware-2022-1840 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 394be448-f5d7-5e10-8f55-e0cf138ea633

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
