// Dragnet [Ransomware]: dragnet-ransomware-2022-0202 — Recovery Inhibition (donutleaks)
// Status: deprecated | Level: high | ID: 8e469efe-24b8-50a1-86fd-2cfa8832c230

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
