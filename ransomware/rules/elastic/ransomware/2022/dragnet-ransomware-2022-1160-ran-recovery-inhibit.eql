// Dragnet [Ransomware]: dragnet-ransomware-2022-1160 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: bfecd537-273c-5419-93fb-ba24061a5a48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
