// Dragnet [Ransomware]: dragnet-ransomware-2022-2812 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: e64a3bde-ee39-5a71-8876-b69093154b74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
