// Dragnet [Ransomware]: dragnet-ransomware-2022-1343 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: cb9bc689-43f8-5ea1-a19f-a2d67bcbdfe1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
