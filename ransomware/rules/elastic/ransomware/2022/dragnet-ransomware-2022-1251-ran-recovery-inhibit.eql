// Dragnet [Ransomware]: dragnet-ransomware-2022-1251 — Recovery Inhibition (medusalocker)
// Status: deprecated | Level: high | ID: c03842b5-220a-5fb5-b8a2-668a68752f7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
