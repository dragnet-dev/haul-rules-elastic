// Dragnet [Ransomware]: dragnet-ransomware-2022-1582 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 57ec3748-3991-5b6b-97dc-6f45451fe902

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
