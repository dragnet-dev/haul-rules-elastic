// Dragnet [Ransomware]: dragnet-ransomware-2022-0712 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: ba22a707-7afc-5935-8483-0cd61b0e3348

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
