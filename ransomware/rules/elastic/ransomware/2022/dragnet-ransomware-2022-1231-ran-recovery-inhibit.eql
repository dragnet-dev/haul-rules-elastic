// Dragnet [Ransomware]: dragnet-ransomware-2022-1231 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: b9ef9db6-489f-54bc-9187-ec9dbd1038f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
