// Dragnet [Ransomware]: dragnet-ransomware-2022-2231 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: ba23f2da-e6e6-5b62-8d58-e968b25eddba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
