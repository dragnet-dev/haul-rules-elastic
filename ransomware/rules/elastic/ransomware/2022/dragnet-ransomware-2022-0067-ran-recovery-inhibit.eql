// Dragnet [Ransomware]: dragnet-ransomware-2022-0067 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: afda17f4-7e1f-5eff-9507-7562843d6ed9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
