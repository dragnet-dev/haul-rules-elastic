// Dragnet [Ransomware]: dragnet-ransomware-2022-0445 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4c03c00f-8a8a-5e44-8a8f-a09ae1c6a518

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
