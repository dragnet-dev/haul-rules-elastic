// Dragnet [Ransomware]: dragnet-ransomware-2022-1618 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 43d1b1e7-b7d5-5120-83ed-a8b26b66ca5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
