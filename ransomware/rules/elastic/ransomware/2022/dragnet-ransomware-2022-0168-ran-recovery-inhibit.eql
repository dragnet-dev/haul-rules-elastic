// Dragnet [Ransomware]: dragnet-ransomware-2022-0168 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 4c4695dd-9742-5bcd-8c85-9fff37014c54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
