// Dragnet [Ransomware]: dragnet-ransomware-2022-2082 — Recovery Inhibition (sparta)
// Status: deprecated | Level: high | ID: 7a7351a8-3ea9-56e4-993a-7e83bdc869c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
