// Dragnet [Ransomware]: dragnet-ransomware-2022-2450 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ab9b1dbe-88ac-5091-924b-b79d3b29a0f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
