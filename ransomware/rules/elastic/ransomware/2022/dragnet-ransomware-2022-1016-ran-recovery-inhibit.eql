// Dragnet [Ransomware]: dragnet-ransomware-2022-1016 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 1508d676-39a3-5795-bae2-0e3a6812d0f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
