// Dragnet [Ransomware]: dragnet-ransomware-2022-0830 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 84bd5546-1a90-5ea2-828a-3db1449b8b7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
