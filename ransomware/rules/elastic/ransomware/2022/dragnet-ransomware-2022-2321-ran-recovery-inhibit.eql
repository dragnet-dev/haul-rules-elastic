// Dragnet [Ransomware]: dragnet-ransomware-2022-2321 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: f66dcb5d-7868-525d-a799-d5a19e64214b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
