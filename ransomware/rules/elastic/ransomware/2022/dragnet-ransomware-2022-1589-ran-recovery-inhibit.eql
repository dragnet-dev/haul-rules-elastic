// Dragnet [Ransomware]: dragnet-ransomware-2022-1589 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 54b0b9d8-4ba4-5824-b491-f903abe5d0c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
