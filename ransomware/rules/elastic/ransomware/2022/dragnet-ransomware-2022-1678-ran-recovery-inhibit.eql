// Dragnet [Ransomware]: dragnet-ransomware-2022-1678 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d6e3fa31-19d4-5a37-9050-5bdf4ae414f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
