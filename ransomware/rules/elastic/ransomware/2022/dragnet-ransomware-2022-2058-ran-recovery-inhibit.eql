// Dragnet [Ransomware]: dragnet-ransomware-2022-2058 — Recovery Inhibition (donutleaks)
// Status: deprecated | Level: high | ID: 63ef1c05-c23f-53b0-8de9-0a34b421667c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
