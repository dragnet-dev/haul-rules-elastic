// Dragnet [Ransomware]: dragnet-ransomware-2022-3026 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 713ccb5d-90fd-50ac-a423-2b7c9bdb45c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
