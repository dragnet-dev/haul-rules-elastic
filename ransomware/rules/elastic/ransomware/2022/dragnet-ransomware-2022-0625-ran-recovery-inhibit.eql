// Dragnet [Ransomware]: dragnet-ransomware-2022-0625 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: d082bd48-31dc-51f2-8e44-7de296daddbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
