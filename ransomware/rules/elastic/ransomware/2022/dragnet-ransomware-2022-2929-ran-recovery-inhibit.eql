// Dragnet [Ransomware]: dragnet-ransomware-2022-2929 — Recovery Inhibition (dataleak)
// Status: deprecated | Level: high | ID: 208a9f40-3321-5304-84bb-1ee97e6039c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
