// Dragnet [Ransomware]: dragnet-ransomware-2022-2793 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5fba2aa7-8c29-5210-aef8-627d5e0f7809

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
