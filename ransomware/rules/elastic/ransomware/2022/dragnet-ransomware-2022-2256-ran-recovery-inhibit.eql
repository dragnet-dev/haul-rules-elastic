// Dragnet [Ransomware]: dragnet-ransomware-2022-2256 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: a3fc0c19-1d32-538b-8b0b-6651b41e8c62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
