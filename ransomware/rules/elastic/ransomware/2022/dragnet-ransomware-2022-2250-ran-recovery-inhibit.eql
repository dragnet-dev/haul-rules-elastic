// Dragnet [Ransomware]: dragnet-ransomware-2022-2250 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b8e0b57e-c207-5966-95e0-ddce088590bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
