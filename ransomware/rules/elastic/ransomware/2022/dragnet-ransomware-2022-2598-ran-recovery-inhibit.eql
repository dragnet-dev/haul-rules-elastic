// Dragnet [Ransomware]: dragnet-ransomware-2022-2598 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e0270232-0441-57ae-a285-29452f37c812

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
