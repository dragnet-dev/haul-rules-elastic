// Dragnet [Ransomware]: dragnet-ransomware-2022-0706 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: aa32f628-c22c-5b77-9d27-95bf582f834f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
