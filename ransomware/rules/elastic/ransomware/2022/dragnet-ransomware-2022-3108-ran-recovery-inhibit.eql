// Dragnet [Ransomware]: dragnet-ransomware-2022-3108 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: 54257dff-df3d-5370-8862-4c38ecfa6d0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
