// Dragnet [Ransomware]: dragnet-ransomware-2022-1324 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8f2300da-7620-5ba0-8bd2-bce1db0a5cc6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
