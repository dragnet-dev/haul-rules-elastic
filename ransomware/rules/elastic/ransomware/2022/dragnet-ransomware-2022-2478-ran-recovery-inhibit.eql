// Dragnet [Ransomware]: dragnet-ransomware-2022-2478 — Recovery Inhibition (mindware)
// Status: deprecated | Level: high | ID: 9b5a723a-704f-5c6b-8072-d62544b5556d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
