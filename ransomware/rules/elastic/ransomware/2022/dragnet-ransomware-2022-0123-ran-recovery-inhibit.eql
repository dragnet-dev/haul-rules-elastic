// Dragnet [Ransomware]: dragnet-ransomware-2022-0123 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 8760d3f5-4b34-5596-a2be-3cd21d55cc41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
