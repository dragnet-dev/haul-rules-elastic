// Dragnet [Ransomware]: dragnet-ransomware-2022-0441 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 266509cd-aaed-5e2f-9a6c-428ba0e6c6bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
