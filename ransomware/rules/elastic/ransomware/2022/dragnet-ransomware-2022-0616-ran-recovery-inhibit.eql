// Dragnet [Ransomware]: dragnet-ransomware-2022-0616 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 8f22363a-e8b6-5607-a27d-7090f30d6d4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
