// Dragnet [Ransomware]: dragnet-ransomware-2022-0022 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 3a6ff96f-aa4f-5910-8e9c-7fa755e1c829

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
