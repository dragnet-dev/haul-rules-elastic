// Dragnet [Ransomware]: dragnet-ransomware-2022-2383 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 7fcc2e8a-3842-5854-a2e9-c5ff79a2bb6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
