// Dragnet [Ransomware]: dragnet-ransomware-2022-2500 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 48dc9811-b8bf-5707-85c1-8dd38743b52c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
