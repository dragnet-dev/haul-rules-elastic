// Dragnet [Ransomware]: dragnet-ransomware-2022-2157 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 3d5476c2-0b12-551a-946c-d989968088f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
