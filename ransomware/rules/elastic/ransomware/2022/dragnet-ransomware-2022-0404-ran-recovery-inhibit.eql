// Dragnet [Ransomware]: dragnet-ransomware-2022-0404 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: 8bafa631-74c5-52dd-8265-aac1ae81953b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
