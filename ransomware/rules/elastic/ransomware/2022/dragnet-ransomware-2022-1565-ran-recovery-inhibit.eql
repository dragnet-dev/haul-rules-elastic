// Dragnet [Ransomware]: dragnet-ransomware-2022-1565 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 4e8ece58-29a9-521a-8c85-fc47265ffa04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
