// Dragnet [Ransomware]: dragnet-ransomware-2022-1325 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c3ae3b98-1eef-52d6-a6fb-d0d5cc5ecb48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
