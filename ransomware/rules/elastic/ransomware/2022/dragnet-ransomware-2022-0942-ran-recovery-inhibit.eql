// Dragnet [Ransomware]: dragnet-ransomware-2022-0942 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d9009630-3af5-546d-94f7-d02d2dd2e555

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
