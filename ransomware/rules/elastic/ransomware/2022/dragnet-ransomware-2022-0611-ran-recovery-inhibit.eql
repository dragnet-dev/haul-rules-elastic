// Dragnet [Ransomware]: dragnet-ransomware-2022-0611 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 70467a27-224c-58d8-bd8d-71c11a4381c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
