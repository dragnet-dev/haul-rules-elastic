// Dragnet [Ransomware]: dragnet-ransomware-2022-0383 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 1b9f6c0e-204f-50ab-be88-c04d17cac718

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
