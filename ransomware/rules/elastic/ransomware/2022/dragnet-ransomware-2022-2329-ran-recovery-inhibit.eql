// Dragnet [Ransomware]: dragnet-ransomware-2022-2329 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 08b50234-1a94-5088-8850-b831931cf843

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
