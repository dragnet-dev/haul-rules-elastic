// Dragnet [Ransomware]: dragnet-ransomware-2022-2125 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 0a9c888e-b89b-5c2f-98c1-5f21a0fa2ae5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
