// Dragnet [Ransomware]: dragnet-ransomware-2022-0128 — Recovery Inhibition (sparta)
// Status: deprecated | Level: high | ID: c3130353-0ad9-5ee4-a30e-3fd14445d68c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
