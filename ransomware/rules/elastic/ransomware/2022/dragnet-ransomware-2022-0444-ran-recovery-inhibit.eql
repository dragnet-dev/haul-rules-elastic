// Dragnet [Ransomware]: dragnet-ransomware-2022-0444 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: a8c8e251-0044-5edc-9ba6-3bdf1a69955f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
