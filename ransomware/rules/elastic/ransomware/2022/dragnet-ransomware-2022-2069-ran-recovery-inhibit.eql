// Dragnet [Ransomware]: dragnet-ransomware-2022-2069 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 56c29b9d-6b25-5e48-a4a2-4a4384c7da28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
