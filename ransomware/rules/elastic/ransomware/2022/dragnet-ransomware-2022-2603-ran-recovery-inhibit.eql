// Dragnet [Ransomware]: dragnet-ransomware-2022-2603 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e81bde96-dae2-5ffd-b165-935ae4d5cae4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
