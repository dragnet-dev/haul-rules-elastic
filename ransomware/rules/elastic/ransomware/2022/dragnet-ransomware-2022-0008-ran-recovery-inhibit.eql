// Dragnet [Ransomware]: dragnet-ransomware-2022-0008 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: 83eff6b6-3b2a-572c-ba4a-50c6f2be9cba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
