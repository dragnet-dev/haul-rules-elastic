// Dragnet [Ransomware]: dragnet-ransomware-2022-1929 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ebfcffb7-1bbe-5ccc-9748-d7adef610d5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
