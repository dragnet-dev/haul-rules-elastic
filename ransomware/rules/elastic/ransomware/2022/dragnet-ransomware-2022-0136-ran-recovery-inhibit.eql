// Dragnet [Ransomware]: dragnet-ransomware-2022-0136 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 72e4bd27-88c1-5178-8354-dc2e99431527

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
