// Dragnet [Ransomware]: dragnet-ransomware-2022-0558 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 699052e8-d381-55cc-b0db-e9a883783dbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
