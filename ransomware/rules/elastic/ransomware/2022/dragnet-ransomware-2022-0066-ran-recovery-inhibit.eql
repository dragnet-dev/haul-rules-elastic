// Dragnet [Ransomware]: dragnet-ransomware-2022-0066 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ddfd8672-f3b1-587b-9e46-ef1b0e704fa7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
