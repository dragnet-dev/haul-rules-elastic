// Dragnet [Ransomware]: dragnet-ransomware-2022-1915 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 26743e21-d387-5899-8406-39bea6b05c13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
