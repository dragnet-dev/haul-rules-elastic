// Dragnet [Ransomware]: dragnet-ransomware-2022-1023 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a8a8f92a-8e0e-5ad6-bc7e-9ff45788c060

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
