// Dragnet [Ransomware]: dragnet-ransomware-2022-1721 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 3b04dad4-3bc1-58f1-b020-fefadfe18d09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
