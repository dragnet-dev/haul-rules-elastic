// Dragnet [Ransomware]: dragnet-ransomware-2022-1184 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 7ab2464e-d235-597a-89c3-50fc6c118e1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
