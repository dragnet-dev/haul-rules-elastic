// Dragnet [Ransomware]: dragnet-ransomware-2022-1245 — Recovery Inhibition (leaktheanalyst)
// Status: deprecated | Level: high | ID: 14661485-b465-50e0-abd0-952b5d501c53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
