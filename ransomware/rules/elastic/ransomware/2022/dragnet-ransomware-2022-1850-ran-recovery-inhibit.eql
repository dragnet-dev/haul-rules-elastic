// Dragnet [Ransomware]: dragnet-ransomware-2022-1850 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: a83da0cd-4f8c-543d-9dac-117377595772

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
