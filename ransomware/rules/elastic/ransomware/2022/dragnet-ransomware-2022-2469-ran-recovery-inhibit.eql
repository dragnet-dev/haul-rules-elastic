// Dragnet [Ransomware]: dragnet-ransomware-2022-2469 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 943df887-7bdd-52f1-ac86-4e840da47412

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
