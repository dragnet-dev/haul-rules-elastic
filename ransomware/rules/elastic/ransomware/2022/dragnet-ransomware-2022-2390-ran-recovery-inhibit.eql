// Dragnet [Ransomware]: dragnet-ransomware-2022-2390 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 63771625-54b3-5de4-9919-b0c4dd23c9e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
