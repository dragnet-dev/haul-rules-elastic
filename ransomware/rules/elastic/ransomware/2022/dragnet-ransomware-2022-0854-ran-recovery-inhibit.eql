// Dragnet [Ransomware]: dragnet-ransomware-2022-0854 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 24023241-42a6-52fe-8f38-94bf8ad16e94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
