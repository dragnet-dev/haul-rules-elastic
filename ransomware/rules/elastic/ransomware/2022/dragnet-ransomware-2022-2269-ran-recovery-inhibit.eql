// Dragnet [Ransomware]: dragnet-ransomware-2022-2269 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 4d7235b2-9f0b-554e-9d88-55fb4227b24f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
