// Dragnet [Ransomware]: dragnet-ransomware-2022-0250 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6bb6f5dc-7dd3-5c98-b974-49e85cbe305b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
