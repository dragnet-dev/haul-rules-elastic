// Dragnet [Ransomware]: dragnet-ransomware-2022-0807 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: 0ee81592-fccd-5848-aa95-51f8b9ff20f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
