// Dragnet [Ransomware]: dragnet-ransomware-2022-0583 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ec8b622c-07f5-52e6-b0da-6f213a76058c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
