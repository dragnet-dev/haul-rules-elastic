// Dragnet [Ransomware]: dragnet-ransomware-2022-0249 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: dcdb74c0-86eb-5710-9960-21873ecf78dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
