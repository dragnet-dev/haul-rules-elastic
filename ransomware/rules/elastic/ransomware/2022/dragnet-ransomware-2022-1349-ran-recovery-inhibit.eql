// Dragnet [Ransomware]: dragnet-ransomware-2022-1349 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: a552b290-bf07-5538-a6bb-cb2bafa43560

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
