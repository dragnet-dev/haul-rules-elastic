// Dragnet [Ransomware]: dragnet-ransomware-2022-0957 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: aea171ff-d086-5bf6-8f5b-b46fa31a543a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
