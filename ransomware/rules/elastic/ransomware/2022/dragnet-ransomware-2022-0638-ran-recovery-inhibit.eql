// Dragnet [Ransomware]: dragnet-ransomware-2022-0638 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 3ebe2acb-7857-533d-a1f9-b359bacde4e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
