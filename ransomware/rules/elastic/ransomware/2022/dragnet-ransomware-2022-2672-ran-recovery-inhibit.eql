// Dragnet [Ransomware]: dragnet-ransomware-2022-2672 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 6059927b-2afb-5b9c-ad90-b408b4ba5f52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
