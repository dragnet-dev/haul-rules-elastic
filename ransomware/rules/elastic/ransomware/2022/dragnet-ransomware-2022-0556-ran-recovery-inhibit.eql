// Dragnet [Ransomware]: dragnet-ransomware-2022-0556 — Recovery Inhibition (cheers)
// Status: deprecated | Level: high | ID: 7b205173-6d84-5e6d-8102-dab59a8c56d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
