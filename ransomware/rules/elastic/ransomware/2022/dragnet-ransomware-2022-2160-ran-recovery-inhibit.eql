// Dragnet [Ransomware]: dragnet-ransomware-2022-2160 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: f466f302-8601-538c-b1fe-2b717b28d941

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
