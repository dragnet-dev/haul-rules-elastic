// Dragnet [Ransomware]: dragnet-ransomware-2022-2229 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 417219d1-65b6-585f-9d64-8f0675211d2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
