// Dragnet [Ransomware]: dragnet-ransomware-2022-3125 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 16606d22-e1ea-5aac-b2d4-3042eaec6c00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
