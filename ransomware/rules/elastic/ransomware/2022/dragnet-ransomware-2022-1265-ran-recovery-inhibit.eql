// Dragnet [Ransomware]: dragnet-ransomware-2022-1265 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: bced4f45-bc59-5822-a7b3-4910fcc5714b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
