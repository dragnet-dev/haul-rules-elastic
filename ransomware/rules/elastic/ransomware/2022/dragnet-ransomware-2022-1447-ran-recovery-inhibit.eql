// Dragnet [Ransomware]: dragnet-ransomware-2022-1447 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7da3220b-c134-56b6-b575-480a425ba592

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
