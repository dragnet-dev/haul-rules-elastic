// Dragnet [Ransomware]: dragnet-ransomware-2022-0848 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: e42c1007-b71f-59ee-8841-a7574a06819b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
