// Dragnet [Ransomware]: dragnet-ransomware-2022-2280 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 06359e53-e3c0-56e6-844b-a029f8168282

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
