// Dragnet [Ransomware]: dragnet-ransomware-2022-0733 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: 8c6e6134-7639-503e-be9d-9b2d32adcfc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
