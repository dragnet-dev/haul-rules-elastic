// Dragnet [Ransomware]: dragnet-ransomware-2022-1986 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2dda0ab0-1260-5bc0-8ca3-56dc2985e9ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
