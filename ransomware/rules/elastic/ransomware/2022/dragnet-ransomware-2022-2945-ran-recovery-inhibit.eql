// Dragnet [Ransomware]: dragnet-ransomware-2022-2945 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: f5f82e5b-e4cd-5bfe-afaa-f03f672db2e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
