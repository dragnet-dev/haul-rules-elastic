// Dragnet [Ransomware]: dragnet-ransomware-2022-0938 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 402e835b-fc53-5b19-850a-029158438317

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
