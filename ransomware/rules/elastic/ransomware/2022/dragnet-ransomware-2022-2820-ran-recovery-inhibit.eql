// Dragnet [Ransomware]: dragnet-ransomware-2022-2820 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 9d75e60d-8472-594b-a012-5756c2364837

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
