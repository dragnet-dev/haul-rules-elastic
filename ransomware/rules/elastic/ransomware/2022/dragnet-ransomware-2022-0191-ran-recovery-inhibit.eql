// Dragnet [Ransomware]: dragnet-ransomware-2022-0191 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: e6369bc3-9857-5c80-9f27-7132b0e02e02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
