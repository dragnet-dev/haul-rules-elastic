// Dragnet [Ransomware]: dragnet-ransomware-2022-1104 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: d0aa257e-9185-5dc3-9ea6-b16218da4aad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
