// Dragnet [Ransomware]: dragnet-ransomware-2022-1277 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: ed8c959f-e14d-51ce-9845-d9f29f4d2f81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
