// Dragnet [Ransomware]: dragnet-ransomware-2022-0355 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: d5fd7a17-2454-5bbd-9463-efd890c950a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
