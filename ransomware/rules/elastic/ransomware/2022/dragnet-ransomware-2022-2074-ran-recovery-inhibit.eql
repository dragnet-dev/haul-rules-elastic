// Dragnet [Ransomware]: dragnet-ransomware-2022-2074 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: f75809b1-053d-5f65-9aff-ff03442eda1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
