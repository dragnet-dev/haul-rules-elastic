// Dragnet [Ransomware]: dragnet-ransomware-2022-1659 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 88c23296-d78a-595c-a024-539683af9d0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
