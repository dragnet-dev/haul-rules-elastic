// Dragnet [Ransomware]: dragnet-ransomware-2022-0738 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 20441dcc-46dc-53cb-a729-12cc7055f995

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
