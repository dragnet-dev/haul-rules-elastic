// Dragnet [Ransomware]: dragnet-ransomware-2022-1242 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: ad47e0c5-0414-5040-80f7-0c32bb1460c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
