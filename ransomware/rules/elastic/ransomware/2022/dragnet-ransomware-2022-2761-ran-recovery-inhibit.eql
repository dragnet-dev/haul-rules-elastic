// Dragnet [Ransomware]: dragnet-ransomware-2022-2761 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: bc206389-c38a-5d64-89d3-431f6b26bbc0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
