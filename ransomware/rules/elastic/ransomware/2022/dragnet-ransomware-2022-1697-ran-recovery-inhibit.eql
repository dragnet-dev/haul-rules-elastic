// Dragnet [Ransomware]: dragnet-ransomware-2022-1697 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 358cbfe8-a2bb-5896-b309-074820b10eec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
