// Dragnet [Ransomware]: dragnet-ransomware-2022-1381 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 8f0695f3-0f5a-55ba-8b1b-4afd1e744a30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
