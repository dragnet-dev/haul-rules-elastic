// Dragnet [Ransomware]: dragnet-ransomware-2022-2445 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: de62e329-675f-5a01-bbc9-08ff64a9718d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
