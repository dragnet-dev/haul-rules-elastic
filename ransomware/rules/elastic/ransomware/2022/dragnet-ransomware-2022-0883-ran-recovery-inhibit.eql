// Dragnet [Ransomware]: dragnet-ransomware-2022-0883 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 92ed2e26-d6e7-56aa-8220-47322342c86e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
