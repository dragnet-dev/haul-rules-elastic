// Dragnet [Ransomware]: dragnet-ransomware-2022-0657 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 821df4be-6d46-5ecf-83d5-6bb37cc3c606

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
