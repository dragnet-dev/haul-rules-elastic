// Dragnet [Ransomware]: dragnet-ransomware-2022-2858 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: f0a567b0-c2de-5cea-a1e8-bb55884ee565

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
