// Dragnet [Ransomware]: dragnet-ransomware-2022-1240 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 90b6555e-0ae1-5ef5-a0ca-1246c04c0da4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
