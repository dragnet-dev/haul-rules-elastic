// Dragnet [Ransomware]: dragnet-ransomware-2022-0251 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 221b2bb8-85d3-548b-af37-4428f9e17eaa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
