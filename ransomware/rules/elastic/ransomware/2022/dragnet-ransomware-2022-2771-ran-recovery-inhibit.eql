// Dragnet [Ransomware]: dragnet-ransomware-2022-2771 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e64e50cf-77d7-5890-afe5-e3f266a35af0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
