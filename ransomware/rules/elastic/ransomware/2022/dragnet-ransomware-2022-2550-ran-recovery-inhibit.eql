// Dragnet [Ransomware]: dragnet-ransomware-2022-2550 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: afd1cb0c-9fe2-55a9-8056-babf914b6873

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
