// Dragnet [Ransomware]: dragnet-ransomware-2022-1778 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 76aca26f-12fb-57fa-a098-7854a4b7bf15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
