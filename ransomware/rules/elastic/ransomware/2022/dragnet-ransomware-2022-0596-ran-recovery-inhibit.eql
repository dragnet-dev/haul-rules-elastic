// Dragnet [Ransomware]: dragnet-ransomware-2022-0596 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: d9260c67-aa0a-5244-9a59-959fbebc18cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
