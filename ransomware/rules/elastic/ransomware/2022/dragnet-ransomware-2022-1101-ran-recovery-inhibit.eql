// Dragnet [Ransomware]: dragnet-ransomware-2022-1101 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: bf54691e-8acc-5970-83a3-d38e9d085fae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
