// Dragnet [Ransomware]: dragnet-ransomware-2022-2727 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 0b8ebbc2-2e7d-520e-a233-df5aa73e7755

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
