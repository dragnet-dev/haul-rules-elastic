// Dragnet [Ransomware]: dragnet-ransomware-2022-2467 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: fbbfeda6-a862-5c46-827d-5d62452666e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
