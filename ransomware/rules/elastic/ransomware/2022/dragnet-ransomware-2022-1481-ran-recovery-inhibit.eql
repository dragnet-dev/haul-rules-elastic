// Dragnet [Ransomware]: dragnet-ransomware-2022-1481 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: a21df3f5-6b55-53cd-9cae-b9bdc8f5f41b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
