// Dragnet [Ransomware]: dragnet-ransomware-2022-1015 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 432a03a4-3109-526a-be4c-8c30cb3b936c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
