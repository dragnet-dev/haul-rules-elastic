// Dragnet [Ransomware]: dragnet-ransomware-2022-1167 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 67814737-031a-5b7b-b2e0-afbf45bf0a98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
