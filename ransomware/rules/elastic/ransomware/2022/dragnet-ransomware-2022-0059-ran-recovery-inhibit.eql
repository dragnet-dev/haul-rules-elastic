// Dragnet [Ransomware]: dragnet-ransomware-2022-0059 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 53265a54-00e4-5a83-8e9c-ca4054d2f31e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
