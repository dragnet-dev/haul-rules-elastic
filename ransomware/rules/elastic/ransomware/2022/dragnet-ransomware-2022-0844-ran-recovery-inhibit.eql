// Dragnet [Ransomware]: dragnet-ransomware-2022-0844 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: eacd2ea9-d541-528f-bc75-c709351cc52e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
