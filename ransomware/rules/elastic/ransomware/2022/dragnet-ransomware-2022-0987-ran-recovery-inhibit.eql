// Dragnet [Ransomware]: dragnet-ransomware-2022-0987 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 7cd52246-cea0-5f29-9227-b82c4310347a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
