// Dragnet [Ransomware]: dragnet-ransomware-2022-1872 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: f1ba929d-9368-5460-a6b9-7276c2b1cd2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
