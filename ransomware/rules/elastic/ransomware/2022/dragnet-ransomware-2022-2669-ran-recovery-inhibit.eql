// Dragnet [Ransomware]: dragnet-ransomware-2022-2669 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: 692df846-4377-5a77-8849-e37063618c41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
