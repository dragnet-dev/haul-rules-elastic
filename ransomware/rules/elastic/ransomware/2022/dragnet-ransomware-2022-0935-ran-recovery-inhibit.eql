// Dragnet [Ransomware]: dragnet-ransomware-2022-0935 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 765c1449-b9ea-5d10-8bd1-3386380f3920

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
