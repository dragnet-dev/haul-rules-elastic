// Dragnet [Ransomware]: dragnet-ransomware-2022-2825 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 45de01e2-fde4-5e0b-a8e4-25e1dd655b68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
