// Dragnet [Ransomware]: dragnet-ransomware-2022-0968 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: c1db65ff-12f9-5030-a648-3e8b2588d224

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
