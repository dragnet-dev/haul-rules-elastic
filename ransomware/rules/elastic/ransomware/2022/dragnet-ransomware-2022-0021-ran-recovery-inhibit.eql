// Dragnet [Ransomware]: dragnet-ransomware-2022-0021 — Recovery Inhibition (cheers)
// Status: deprecated | Level: high | ID: 8cbce722-1233-5d99-94de-fdee9caa8a50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
