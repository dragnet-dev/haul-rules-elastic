// Dragnet [Ransomware]: dragnet-ransomware-2022-1122 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 710b3276-ec73-5191-a453-4bf7410b40a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
