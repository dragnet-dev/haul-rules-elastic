// Dragnet [Ransomware]: dragnet-ransomware-2022-0764 — Recovery Inhibition (freecivilian)
// Status: deprecated | Level: high | ID: a7faa629-c270-5622-9da8-2da6e5ead8f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
