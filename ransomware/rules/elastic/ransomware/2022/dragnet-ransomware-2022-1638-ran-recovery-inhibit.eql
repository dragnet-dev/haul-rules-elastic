// Dragnet [Ransomware]: dragnet-ransomware-2022-1638 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 45231b5b-f15c-58f9-bf22-8bc6d0f7394a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
