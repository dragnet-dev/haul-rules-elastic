// Dragnet [Ransomware]: dragnet-ransomware-2022-2481 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: c70d01b2-c4a5-56dd-8f2b-6c350eb96ceb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
