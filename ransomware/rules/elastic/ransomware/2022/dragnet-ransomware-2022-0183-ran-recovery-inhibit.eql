// Dragnet [Ransomware]: dragnet-ransomware-2022-0183 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: ba96d2e5-3f35-5faa-8cd1-774adc65fd5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
