// Dragnet [Ransomware]: dragnet-ransomware-2022-0710 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5efb57a7-af94-5a66-ba29-02b726758afa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
