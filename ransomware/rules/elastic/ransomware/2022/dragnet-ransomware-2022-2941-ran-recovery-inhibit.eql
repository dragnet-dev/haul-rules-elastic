// Dragnet [Ransomware]: dragnet-ransomware-2022-2941 — Recovery Inhibition (mindware)
// Status: deprecated | Level: high | ID: 72bd47aa-ffab-5a8d-a1a9-cb307f95e65b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
