// Dragnet [Ransomware]: dragnet-ransomware-2022-0894 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: d7da65c4-33a2-599f-8834-32e52ca11e5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
