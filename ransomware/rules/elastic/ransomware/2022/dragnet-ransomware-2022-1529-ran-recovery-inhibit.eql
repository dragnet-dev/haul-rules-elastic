// Dragnet [Ransomware]: dragnet-ransomware-2022-1529 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 7c02049e-0208-587d-9b63-7dd410d2ec66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
