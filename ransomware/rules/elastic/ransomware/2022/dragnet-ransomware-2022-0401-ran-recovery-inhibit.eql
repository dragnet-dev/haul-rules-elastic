// Dragnet [Ransomware]: dragnet-ransomware-2022-0401 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: f213dfba-893c-5b31-bbdd-2b76ac92d0c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
