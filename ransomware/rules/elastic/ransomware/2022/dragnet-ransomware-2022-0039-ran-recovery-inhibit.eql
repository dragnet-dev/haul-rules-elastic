// Dragnet [Ransomware]: dragnet-ransomware-2022-0039 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: c00331e3-7752-5c3a-bbd9-20f454a379d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
