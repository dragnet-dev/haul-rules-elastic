// Dragnet [Ransomware]: dragnet-ransomware-2022-0425 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: a5be79ca-c70d-5ab6-8a35-f0d6e5b7e60a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
