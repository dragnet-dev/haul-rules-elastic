// Dragnet [Ransomware]: dragnet-ransomware-2022-1309 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8dab017b-400e-5755-ba65-3f7bebe13730

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
