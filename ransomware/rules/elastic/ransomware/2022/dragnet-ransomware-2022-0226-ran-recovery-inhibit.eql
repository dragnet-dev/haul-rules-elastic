// Dragnet [Ransomware]: dragnet-ransomware-2022-0226 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 3cb88a79-b3cc-5f49-867d-10ca8e1f033f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
