// Dragnet [Ransomware]: dragnet-ransomware-2022-1511 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 1617fa21-2499-5b6d-8dbc-6432ceb81a11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
