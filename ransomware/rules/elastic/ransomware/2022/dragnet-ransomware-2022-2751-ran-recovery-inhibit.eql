// Dragnet [Ransomware]: dragnet-ransomware-2022-2751 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 1aaa337a-c956-54f0-8396-41e6844c1bee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
