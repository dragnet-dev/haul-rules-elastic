// Dragnet [Ransomware]: dragnet-ransomware-2022-0081 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 11484b60-aded-582a-bdb7-68adcb9e581a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
