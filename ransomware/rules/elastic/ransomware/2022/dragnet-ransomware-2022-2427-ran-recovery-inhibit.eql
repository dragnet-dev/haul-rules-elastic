// Dragnet [Ransomware]: dragnet-ransomware-2022-2427 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 18cd494d-7eed-5a71-8188-fff9b0b04a25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
