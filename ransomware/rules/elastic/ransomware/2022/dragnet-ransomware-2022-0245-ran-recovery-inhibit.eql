// Dragnet [Ransomware]: dragnet-ransomware-2022-0245 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: 3849e8a9-f350-5329-b7b8-d0cae520019e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
