// Dragnet [Ransomware]: dragnet-ransomware-2022-1794 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 278f2bcd-9daf-50f2-9d40-0076e13c88d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
