// Dragnet [Ransomware]: dragnet-ransomware-2022-1782 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 9e34dd81-738b-5018-940d-9bd8739b7db5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
