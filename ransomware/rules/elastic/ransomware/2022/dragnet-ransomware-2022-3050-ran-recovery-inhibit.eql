// Dragnet [Ransomware]: dragnet-ransomware-2022-3050 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: d79df289-35d3-57e4-afe6-7cf9142fee75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
