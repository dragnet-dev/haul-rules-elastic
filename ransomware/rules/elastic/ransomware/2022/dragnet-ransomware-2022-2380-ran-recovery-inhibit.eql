// Dragnet [Ransomware]: dragnet-ransomware-2022-2380 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 14f43322-1850-551a-9c46-5b255c868977

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
