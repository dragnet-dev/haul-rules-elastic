// Dragnet [Ransomware]: dragnet-ransomware-2022-1092 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: e02b2e52-7e5b-5852-b787-86280b19feb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
