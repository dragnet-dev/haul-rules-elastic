// Dragnet [Ransomware]: dragnet-ransomware-2022-1208 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: f455bb16-cb70-5c57-a9cc-9d0962e19187

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
