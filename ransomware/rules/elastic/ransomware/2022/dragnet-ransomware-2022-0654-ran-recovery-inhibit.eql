// Dragnet [Ransomware]: dragnet-ransomware-2022-0654 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ff18127e-2ef8-5ec3-89f5-914b3b6f51de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
