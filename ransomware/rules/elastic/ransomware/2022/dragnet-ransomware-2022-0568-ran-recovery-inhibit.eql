// Dragnet [Ransomware]: dragnet-ransomware-2022-0568 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a0b5d9ef-a7f9-516b-a8dd-a0d498f71498

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
