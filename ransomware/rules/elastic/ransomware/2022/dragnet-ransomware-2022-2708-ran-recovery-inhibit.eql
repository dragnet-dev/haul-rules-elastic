// Dragnet [Ransomware]: dragnet-ransomware-2022-2708 — Recovery Inhibition (sparta)
// Status: deprecated | Level: high | ID: 8e8ef2b7-7a6a-539a-b596-cc041a83c6b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
