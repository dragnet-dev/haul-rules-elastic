// Dragnet [Ransomware]: dragnet-ransomware-2022-0084 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: e02ea6e7-3ba9-522b-a9d3-311726d0aef4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
