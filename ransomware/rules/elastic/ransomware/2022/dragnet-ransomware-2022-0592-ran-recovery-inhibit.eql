// Dragnet [Ransomware]: dragnet-ransomware-2022-0592 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 22f29543-d6da-522c-a9de-3a0a1bc635e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
