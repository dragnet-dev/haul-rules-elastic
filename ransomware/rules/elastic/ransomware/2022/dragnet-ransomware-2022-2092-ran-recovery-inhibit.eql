// Dragnet [Ransomware]: dragnet-ransomware-2022-2092 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 832c2ab2-f7a2-5853-ae30-9fdf8fc0554a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
