// Dragnet [Ransomware]: dragnet-ransomware-2022-2232 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 67e31db1-6c22-50f5-bff4-a90bb906ecd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
