// Dragnet [Ransomware]: dragnet-ransomware-2022-0771 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 6e580e50-f484-57ec-978a-12fae1ac76e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
