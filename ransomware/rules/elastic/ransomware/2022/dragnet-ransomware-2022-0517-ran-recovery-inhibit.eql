// Dragnet [Ransomware]: dragnet-ransomware-2022-0517 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 6e1b80a5-4b14-5983-b4fa-14f5fe16ef2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
