// Dragnet [Ransomware]: dragnet-ransomware-2022-2364 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ee7a50dc-6c28-585c-bd16-31abde845e5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
