// Dragnet [Ransomware]: dragnet-ransomware-2022-2354 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 567bab3e-7afe-5b65-aa72-20657fc5892e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
