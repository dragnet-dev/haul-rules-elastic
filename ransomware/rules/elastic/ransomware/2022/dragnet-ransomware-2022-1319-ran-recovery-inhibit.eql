// Dragnet [Ransomware]: dragnet-ransomware-2022-1319 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: e64d88dc-db34-548c-a672-616d7b18310f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
