// Dragnet [Ransomware]: dragnet-ransomware-2022-2958 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 0136b109-8c98-53c2-9399-d045cf195cbd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
