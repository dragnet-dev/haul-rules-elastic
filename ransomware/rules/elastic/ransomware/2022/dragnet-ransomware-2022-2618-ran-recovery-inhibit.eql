// Dragnet [Ransomware]: dragnet-ransomware-2022-2618 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a9263e36-dcde-5c06-8b60-611fb4c24824

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
