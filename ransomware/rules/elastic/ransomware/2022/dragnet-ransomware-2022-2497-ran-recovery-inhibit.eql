// Dragnet [Ransomware]: dragnet-ransomware-2022-2497 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 13e211c5-2083-5f72-86af-27064db21094

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
