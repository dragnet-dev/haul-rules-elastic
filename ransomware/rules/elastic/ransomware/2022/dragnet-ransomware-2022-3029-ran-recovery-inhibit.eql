// Dragnet [Ransomware]: dragnet-ransomware-2022-3029 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 49dee93b-dce3-5f1c-b84b-b4d8c1bd709e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
