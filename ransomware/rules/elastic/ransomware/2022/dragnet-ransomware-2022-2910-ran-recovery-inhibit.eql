// Dragnet [Ransomware]: dragnet-ransomware-2022-2910 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a477163f-9448-5ade-939d-e43edba85c45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
