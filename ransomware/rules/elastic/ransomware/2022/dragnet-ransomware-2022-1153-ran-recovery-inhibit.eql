// Dragnet [Ransomware]: dragnet-ransomware-2022-1153 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 65736903-8f75-5378-8961-5c04e7af393d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
