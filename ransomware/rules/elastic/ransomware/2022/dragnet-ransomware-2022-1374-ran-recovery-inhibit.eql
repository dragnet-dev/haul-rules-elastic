// Dragnet [Ransomware]: dragnet-ransomware-2022-1374 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 616aea07-d283-57f7-be67-286c91115766

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
