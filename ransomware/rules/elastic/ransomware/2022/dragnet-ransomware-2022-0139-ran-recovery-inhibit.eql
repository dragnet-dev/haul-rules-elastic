// Dragnet [Ransomware]: dragnet-ransomware-2022-0139 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 0bc619eb-fbdb-50f6-b1e1-f163f95bea0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
