// Dragnet [Ransomware]: dragnet-ransomware-2022-0399 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: b2d5fe06-84bb-50cf-8d7b-f0bbc2cb592e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
