// Dragnet [Ransomware]: dragnet-ransomware-2022-0547 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 6e3a749c-0ff6-5c77-ac5a-a5639ffe823f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
