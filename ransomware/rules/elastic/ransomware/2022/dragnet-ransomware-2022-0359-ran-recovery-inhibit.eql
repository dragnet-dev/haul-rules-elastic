// Dragnet [Ransomware]: dragnet-ransomware-2022-0359 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 6bf72709-f643-5b49-9cb7-0651c23439b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
