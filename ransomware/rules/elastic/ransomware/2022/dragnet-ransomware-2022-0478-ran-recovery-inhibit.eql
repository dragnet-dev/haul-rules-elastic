// Dragnet [Ransomware]: dragnet-ransomware-2022-0478 — Recovery Inhibition (mindware)
// Status: deprecated | Level: high | ID: 316515f7-5f67-5c9c-8746-1f7d37a81e0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
