// Dragnet [Ransomware]: dragnet-ransomware-2022-1327 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 8accfd68-bc83-5851-97c5-cc4dc55d40cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
