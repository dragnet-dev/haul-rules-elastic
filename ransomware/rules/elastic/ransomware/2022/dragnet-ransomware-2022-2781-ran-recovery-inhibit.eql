// Dragnet [Ransomware]: dragnet-ransomware-2022-2781 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 2d2216f4-c1a3-5e98-add0-fb2a27ff9e1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
