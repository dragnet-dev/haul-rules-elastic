// Dragnet [Ransomware]: dragnet-ransomware-2022-2785 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5b79d302-c28d-5b65-9ddd-f9f9655c6c96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
