// Dragnet [Ransomware]: dragnet-ransomware-2022-0100 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 74be0956-a16f-599f-85f0-8e100a6871cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
