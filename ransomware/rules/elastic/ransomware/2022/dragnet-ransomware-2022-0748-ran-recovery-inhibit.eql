// Dragnet [Ransomware]: dragnet-ransomware-2022-0748 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 4ff65115-5409-5dea-a9aa-9c56ef5a56d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
