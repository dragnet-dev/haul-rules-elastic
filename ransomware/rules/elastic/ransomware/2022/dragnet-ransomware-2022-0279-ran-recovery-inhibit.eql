// Dragnet [Ransomware]: dragnet-ransomware-2022-0279 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 5a820ec7-4a33-59c8-afa1-9b994ebe0c17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
