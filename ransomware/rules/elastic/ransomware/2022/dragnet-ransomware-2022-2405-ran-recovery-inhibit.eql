// Dragnet [Ransomware]: dragnet-ransomware-2022-2405 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 47119af2-58a9-555f-8bad-42d764457be0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
