// Dragnet [Ransomware]: dragnet-ransomware-2022-3055 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: c1d40323-74a6-56bc-9fca-b167de105696

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
