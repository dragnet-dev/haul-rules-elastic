// Dragnet [Ransomware]: dragnet-ransomware-2022-1170 — Recovery Inhibition (lapsus$)
// Status: deprecated | Level: high | ID: b31e21a4-a459-5947-8914-b3cb769d0069

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
