// Dragnet [Ransomware]: dragnet-ransomware-2022-0456 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: b60796f5-d063-5b2c-8f08-7da1605bb227

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
