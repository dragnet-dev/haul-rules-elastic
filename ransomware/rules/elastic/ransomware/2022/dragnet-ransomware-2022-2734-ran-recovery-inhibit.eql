// Dragnet [Ransomware]: dragnet-ransomware-2022-2734 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: c7fa527b-579d-55a9-a70f-ca107a467e95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
