// Dragnet [Ransomware]: dragnet-ransomware-2022-1841 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: dc93b279-07c0-5282-aca5-7dd30967553f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
