// Dragnet [Ransomware]: dragnet-ransomware-2022-1026 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ecbb7334-3d86-536d-b394-6a3ac1b9277a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
