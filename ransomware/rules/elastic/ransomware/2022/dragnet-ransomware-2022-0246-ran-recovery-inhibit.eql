// Dragnet [Ransomware]: dragnet-ransomware-2022-0246 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: cd7d05de-8d29-57bd-8218-5431df3e33f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
