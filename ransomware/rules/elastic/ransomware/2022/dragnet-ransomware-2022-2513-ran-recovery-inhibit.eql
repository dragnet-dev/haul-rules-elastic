// Dragnet [Ransomware]: dragnet-ransomware-2022-2513 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 2f500575-462a-5138-b34b-32842873a229

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
