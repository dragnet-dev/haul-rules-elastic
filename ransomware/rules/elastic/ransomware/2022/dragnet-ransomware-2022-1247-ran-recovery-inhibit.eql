// Dragnet [Ransomware]: dragnet-ransomware-2022-1247 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: af2af7e9-ea40-5f98-87ea-e9785c8cc9ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
