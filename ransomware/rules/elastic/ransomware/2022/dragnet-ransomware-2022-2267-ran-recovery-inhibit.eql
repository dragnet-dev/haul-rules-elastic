// Dragnet [Ransomware]: dragnet-ransomware-2022-2267 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: e03988df-9abe-5bd0-9f80-f335ada03e9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
