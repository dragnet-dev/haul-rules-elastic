// Dragnet [Ransomware]: dragnet-ransomware-2022-0495 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: faffbc92-7761-5f4a-a8f8-98e22e8fa07a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
