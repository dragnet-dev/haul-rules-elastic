// Dragnet [Ransomware]: dragnet-ransomware-2022-1502 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 4856b95c-6f88-5dc8-a92a-eb43550586a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
