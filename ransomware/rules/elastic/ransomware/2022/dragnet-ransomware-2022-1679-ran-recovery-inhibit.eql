// Dragnet [Ransomware]: dragnet-ransomware-2022-1679 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: 859a37f1-6068-5a40-8bab-7b3258053b4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
