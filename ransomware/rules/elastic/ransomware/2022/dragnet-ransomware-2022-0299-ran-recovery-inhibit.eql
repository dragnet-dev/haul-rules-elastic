// Dragnet [Ransomware]: dragnet-ransomware-2022-0299 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 50152492-946c-5a69-a2dd-0e5b5561304f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
