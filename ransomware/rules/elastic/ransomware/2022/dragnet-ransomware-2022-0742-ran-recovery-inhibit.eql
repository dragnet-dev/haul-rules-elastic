// Dragnet [Ransomware]: dragnet-ransomware-2022-0742 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d59496da-cfae-5ff1-82a2-469c697af45e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
