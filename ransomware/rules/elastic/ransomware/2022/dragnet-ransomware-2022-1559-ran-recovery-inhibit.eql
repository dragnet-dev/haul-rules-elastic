// Dragnet [Ransomware]: dragnet-ransomware-2022-1559 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 5d174bd2-f0ae-521c-a277-8c7df65dc187

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
