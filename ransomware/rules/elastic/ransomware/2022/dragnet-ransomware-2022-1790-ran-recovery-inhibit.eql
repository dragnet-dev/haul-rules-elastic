// Dragnet [Ransomware]: dragnet-ransomware-2022-1790 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 68c21f9f-de38-514b-adbd-fb2bc4ab75f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
