// Dragnet [Ransomware]: dragnet-ransomware-2022-0451 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: c15d9570-253d-5507-813a-846b362512b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
