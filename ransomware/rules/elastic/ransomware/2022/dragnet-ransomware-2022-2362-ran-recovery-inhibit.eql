// Dragnet [Ransomware]: dragnet-ransomware-2022-2362 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d68d23b6-d2a4-51f3-aae6-eb908603d4f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
