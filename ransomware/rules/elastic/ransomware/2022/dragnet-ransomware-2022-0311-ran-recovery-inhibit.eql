// Dragnet [Ransomware]: dragnet-ransomware-2022-0311 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: cf46513f-4d83-577e-b1cb-d9c7f9d33e42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
