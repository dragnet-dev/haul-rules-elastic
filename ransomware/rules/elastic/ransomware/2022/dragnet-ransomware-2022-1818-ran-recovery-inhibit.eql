// Dragnet [Ransomware]: dragnet-ransomware-2022-1818 — Recovery Inhibition (pandora)
// Status: deprecated | Level: high | ID: 240a01be-109a-5960-b4c9-bcd052eb5715

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
