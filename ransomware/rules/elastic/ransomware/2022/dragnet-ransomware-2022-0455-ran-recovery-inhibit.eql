// Dragnet [Ransomware]: dragnet-ransomware-2022-0455 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 188c9354-242d-52b4-ba59-0b8f028d841f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
