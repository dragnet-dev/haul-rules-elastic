// Dragnet [Ransomware]: dragnet-ransomware-2022-1963 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: b8bfdbdc-496e-5e0a-914e-1d7b9406ac56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
