// Dragnet [Ransomware]: dragnet-ransomware-2022-0024 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: b352eedf-236d-5698-856b-9f17700612cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
