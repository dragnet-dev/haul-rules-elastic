// Dragnet [Ransomware]: dragnet-ransomware-2022-1656 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: bc73f2b4-ce1e-5a8e-8c96-dd9ef572b841

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
