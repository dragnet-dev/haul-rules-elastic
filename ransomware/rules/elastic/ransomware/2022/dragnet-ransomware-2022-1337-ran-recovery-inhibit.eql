// Dragnet [Ransomware]: dragnet-ransomware-2022-1337 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 4c1bbbf1-5bb6-5c36-9700-7ae3e2db70b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
