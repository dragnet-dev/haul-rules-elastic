// Dragnet [Ransomware]: dragnet-ransomware-2022-0566 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: dd711e71-5af8-5688-b334-b32620466959

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
