// Dragnet [Ransomware]: dragnet-ransomware-2022-0760 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 796572d7-7c3a-5ab8-b10a-2c799f7fbe67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
