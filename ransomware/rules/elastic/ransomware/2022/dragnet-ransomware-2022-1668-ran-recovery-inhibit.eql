// Dragnet [Ransomware]: dragnet-ransomware-2022-1668 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: cd62b936-4ba1-5516-b566-2c603eea918c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
