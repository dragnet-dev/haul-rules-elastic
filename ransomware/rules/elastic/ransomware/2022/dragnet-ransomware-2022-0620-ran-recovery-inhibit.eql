// Dragnet [Ransomware]: dragnet-ransomware-2022-0620 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: e5052050-3ad1-5294-9238-6ba391fd2be3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
