// Dragnet [Ransomware]: dragnet-ransomware-2022-2957 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: aed9d555-270b-5fd9-b5ed-f567e35d2045

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
