// Dragnet [Ransomware]: dragnet-ransomware-2022-2431 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: e057b0e6-9daa-592a-a06d-b1f54d81dd1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
