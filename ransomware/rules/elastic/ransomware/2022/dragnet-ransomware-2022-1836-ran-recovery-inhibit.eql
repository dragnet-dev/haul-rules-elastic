// Dragnet [Ransomware]: dragnet-ransomware-2022-1836 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 84b9e449-83d1-598c-ade6-44978e4739ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
