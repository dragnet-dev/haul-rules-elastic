// Dragnet [Ransomware]: dragnet-ransomware-2022-0749 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: bf341424-a179-5ea5-b9e1-97d2ad972b14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
