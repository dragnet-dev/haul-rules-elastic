// Dragnet [Ransomware]: dragnet-ransomware-2022-1150 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 34280835-b428-53ea-83fa-9656433e688f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
