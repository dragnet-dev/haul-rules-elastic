// Dragnet [Ransomware]: dragnet-ransomware-2022-0007 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 4b004582-a519-554a-847b-967803bb2d75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
