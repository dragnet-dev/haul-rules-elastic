// Dragnet [Ransomware]: dragnet-ransomware-2022-0985 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 8a2af13a-58ba-5af8-a79c-e56573a746b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
