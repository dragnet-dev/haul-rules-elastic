// Dragnet [Ransomware]: dragnet-ransomware-2022-1948 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: d9214fec-5f32-5e4e-9ae1-7c7cce454af4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
