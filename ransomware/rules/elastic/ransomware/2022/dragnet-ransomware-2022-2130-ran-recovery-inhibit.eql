// Dragnet [Ransomware]: dragnet-ransomware-2022-2130 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 5a78d5c9-7c02-5443-a6a1-4088694ffe56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
