// Dragnet [Ransomware]: dragnet-ransomware-2022-1785 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 830140e2-0929-5566-a2ce-d1aa1fe2df72

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
