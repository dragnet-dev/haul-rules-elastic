// Dragnet [Ransomware]: dragnet-ransomware-2022-3030 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e9b32fa8-ec9d-5207-b226-e9250226926f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
