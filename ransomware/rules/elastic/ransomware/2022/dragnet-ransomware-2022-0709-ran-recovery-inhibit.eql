// Dragnet [Ransomware]: dragnet-ransomware-2022-0709 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: d1202081-0bc3-57b5-909d-ad7e9eb82832

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
