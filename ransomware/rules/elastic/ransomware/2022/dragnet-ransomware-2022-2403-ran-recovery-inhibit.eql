// Dragnet [Ransomware]: dragnet-ransomware-2022-2403 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: f6eb8ff3-f8b0-575e-90cd-74e16699b478

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
