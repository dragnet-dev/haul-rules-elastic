// Dragnet [Ransomware]: dragnet-ransomware-2022-1450 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 411b33a9-3c95-5428-b4f4-87fc21a46d52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
