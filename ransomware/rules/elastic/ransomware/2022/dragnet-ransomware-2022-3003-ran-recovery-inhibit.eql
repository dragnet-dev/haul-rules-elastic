// Dragnet [Ransomware]: dragnet-ransomware-2022-3003 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 219f1770-06cc-594e-8d54-e1e97d000709

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
