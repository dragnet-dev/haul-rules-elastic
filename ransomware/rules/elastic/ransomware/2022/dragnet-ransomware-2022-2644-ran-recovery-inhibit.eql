// Dragnet [Ransomware]: dragnet-ransomware-2022-2644 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: cc49540f-d1f0-5ee6-b00b-2f3bec58de69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
