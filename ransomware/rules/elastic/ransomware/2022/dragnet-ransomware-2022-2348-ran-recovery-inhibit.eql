// Dragnet [Ransomware]: dragnet-ransomware-2022-2348 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a90be66f-da9a-590d-9d9e-86ca6169e1cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
