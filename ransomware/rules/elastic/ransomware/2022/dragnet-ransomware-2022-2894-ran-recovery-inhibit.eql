// Dragnet [Ransomware]: dragnet-ransomware-2022-2894 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 743d1cf0-b6b4-5a2c-bcc7-8c032e56f86b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
