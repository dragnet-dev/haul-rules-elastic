// Dragnet [Ransomware]: dragnet-ransomware-2022-3106 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ef655a86-cbaf-55e8-b834-66c4174b4454

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
