// Dragnet [Ransomware]: dragnet-ransomware-2022-2651 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: fb66aca0-7a6e-53bf-b3fc-3d3e34bd60ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
