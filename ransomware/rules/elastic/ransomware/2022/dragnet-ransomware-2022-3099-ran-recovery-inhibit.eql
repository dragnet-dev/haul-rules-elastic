// Dragnet [Ransomware]: dragnet-ransomware-2022-3099 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: b7161809-7734-5ce0-919f-f3fee2faa363

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
