// Dragnet [Ransomware]: dragnet-ransomware-2022-0703 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8145e073-7669-5662-841b-1928c7c5f307

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
