// Dragnet [Ransomware]: dragnet-ransomware-2022-0950 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: a11610c1-bc4d-5918-bf49-d5f86dfcfa0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
