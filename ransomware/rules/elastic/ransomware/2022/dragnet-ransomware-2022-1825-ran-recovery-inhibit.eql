// Dragnet [Ransomware]: dragnet-ransomware-2022-1825 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 8e8e04e4-623b-5eae-bca6-a21d9f3b3505

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
