// Dragnet [Ransomware]: dragnet-ransomware-2022-2616 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 7b47e22f-6825-56f3-944b-87f3253d5549

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
