// Dragnet [Ransomware]: dragnet-ransomware-2022-2452 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 0944d37c-40b9-5f99-9b30-559b86c80bbd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
