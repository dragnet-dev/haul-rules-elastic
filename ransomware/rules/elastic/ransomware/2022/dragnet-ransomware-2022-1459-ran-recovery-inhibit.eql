// Dragnet [Ransomware]: dragnet-ransomware-2022-1459 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 147bfde7-03e1-5592-88d7-2073a63a38fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
