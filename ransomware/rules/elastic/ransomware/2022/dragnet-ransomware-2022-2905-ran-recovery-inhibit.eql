// Dragnet [Ransomware]: dragnet-ransomware-2022-2905 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: f55ab0b6-07c7-52b0-8a68-ab7a12186efd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
