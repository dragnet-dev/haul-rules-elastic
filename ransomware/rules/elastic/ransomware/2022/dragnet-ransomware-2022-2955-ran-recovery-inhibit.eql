// Dragnet [Ransomware]: dragnet-ransomware-2022-2955 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 38208d64-0a5a-5688-8e9a-c14ee3153de3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
