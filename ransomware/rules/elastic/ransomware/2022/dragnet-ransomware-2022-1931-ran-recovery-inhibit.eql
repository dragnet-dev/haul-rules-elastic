// Dragnet [Ransomware]: dragnet-ransomware-2022-1931 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 543303d6-a76d-5d9a-829f-3cce98644679

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
