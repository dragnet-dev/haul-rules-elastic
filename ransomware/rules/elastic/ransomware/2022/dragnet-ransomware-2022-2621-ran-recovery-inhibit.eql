// Dragnet [Ransomware]: dragnet-ransomware-2022-2621 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 1d628357-da82-5d52-b3c3-ce1325f435fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
