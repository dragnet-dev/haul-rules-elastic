// Dragnet [Ransomware]: dragnet-ransomware-2022-0277 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 754abea0-921c-591a-8c30-d2ec79294f96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
