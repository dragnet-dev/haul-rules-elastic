// Dragnet [Ransomware]: dragnet-ransomware-2022-2464 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 53590203-caab-58b8-a283-aff7d8b7da04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
