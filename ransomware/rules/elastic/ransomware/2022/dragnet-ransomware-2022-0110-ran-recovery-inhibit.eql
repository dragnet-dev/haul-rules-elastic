// Dragnet [Ransomware]: dragnet-ransomware-2022-0110 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 37bea853-2d9c-5aec-a02a-b3ecb5728f01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
