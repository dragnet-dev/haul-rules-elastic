// Dragnet [Ransomware]: dragnet-ransomware-2022-2543 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 23a0d0a5-efb1-5587-8dd8-7edc7b2e2067

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
