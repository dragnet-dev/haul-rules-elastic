// Dragnet [Ransomware]: dragnet-ransomware-2022-1702 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: eb1ee507-9288-50aa-9691-4ebd31233129

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
