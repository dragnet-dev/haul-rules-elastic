// Dragnet [Ransomware]: dragnet-ransomware-2022-0259 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 14e20800-9783-5ca3-8544-c6b8659ad342

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
