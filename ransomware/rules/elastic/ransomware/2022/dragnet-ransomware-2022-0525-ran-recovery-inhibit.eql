// Dragnet [Ransomware]: dragnet-ransomware-2022-0525 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: e45d21c6-4a0d-530c-8a34-0a327afccdff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
