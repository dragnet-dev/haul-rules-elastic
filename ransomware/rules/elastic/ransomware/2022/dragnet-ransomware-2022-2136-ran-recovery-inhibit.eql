// Dragnet [Ransomware]: dragnet-ransomware-2022-2136 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: e879059b-9210-570d-9b42-805399babf7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
