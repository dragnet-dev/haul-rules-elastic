// Dragnet [Ransomware]: dragnet-ransomware-2022-2217 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 14b4add7-c207-54e1-924f-4d484f8d6d86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
