// Dragnet [Ransomware]: dragnet-ransomware-2022-0662 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: be07a719-297d-527a-b7d6-9cdcc8e4455c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
