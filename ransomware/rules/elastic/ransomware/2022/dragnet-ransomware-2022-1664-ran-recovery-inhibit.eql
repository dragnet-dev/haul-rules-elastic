// Dragnet [Ransomware]: dragnet-ransomware-2022-1664 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 0daa13dc-2f9d-54ce-8b1f-67c008704d4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
