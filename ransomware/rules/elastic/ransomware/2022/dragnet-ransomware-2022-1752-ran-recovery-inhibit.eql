// Dragnet [Ransomware]: dragnet-ransomware-2022-1752 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 3fae76bb-b1ac-5ba1-a939-27ef7238c44c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
