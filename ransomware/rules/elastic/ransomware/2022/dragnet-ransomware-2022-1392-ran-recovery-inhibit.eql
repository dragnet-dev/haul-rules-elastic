// Dragnet [Ransomware]: dragnet-ransomware-2022-1392 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 7a84dbee-3f23-5ed3-a9f6-83dd6e78ba77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
