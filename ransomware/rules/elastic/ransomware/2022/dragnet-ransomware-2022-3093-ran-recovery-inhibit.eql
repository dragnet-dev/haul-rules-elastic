// Dragnet [Ransomware]: dragnet-ransomware-2022-3093 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 81113881-e40d-52e4-bf78-645629a9f717

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
