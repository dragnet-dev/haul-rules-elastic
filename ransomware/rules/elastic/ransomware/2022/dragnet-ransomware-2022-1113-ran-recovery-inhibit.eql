// Dragnet [Ransomware]: dragnet-ransomware-2022-1113 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 165196bf-4f3f-5667-9709-89bc3dbbb532

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
