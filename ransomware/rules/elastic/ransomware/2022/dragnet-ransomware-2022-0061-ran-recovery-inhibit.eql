// Dragnet [Ransomware]: dragnet-ransomware-2022-0061 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ebdcef37-445f-5ec9-a416-1a67343a77e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
