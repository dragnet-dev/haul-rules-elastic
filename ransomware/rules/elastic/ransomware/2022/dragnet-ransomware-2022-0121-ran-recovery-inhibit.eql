// Dragnet [Ransomware]: dragnet-ransomware-2022-0121 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ec117226-ce05-586a-8fbe-3c9ce9ae5cfc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
