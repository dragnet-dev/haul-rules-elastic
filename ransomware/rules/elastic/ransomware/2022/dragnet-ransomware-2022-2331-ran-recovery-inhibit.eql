// Dragnet [Ransomware]: dragnet-ransomware-2022-2331 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 86ec3696-826d-5340-a3d7-901cd436015c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
