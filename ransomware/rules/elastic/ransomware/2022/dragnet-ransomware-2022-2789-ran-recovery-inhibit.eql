// Dragnet [Ransomware]: dragnet-ransomware-2022-2789 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: d5504afd-2864-5110-95dc-5f8f21653065

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
