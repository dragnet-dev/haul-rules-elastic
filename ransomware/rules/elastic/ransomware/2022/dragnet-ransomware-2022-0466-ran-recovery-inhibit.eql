// Dragnet [Ransomware]: dragnet-ransomware-2022-0466 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 53bf59b6-2ef9-5c83-b012-1619f26a2e3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
