// Dragnet [Ransomware]: dragnet-ransomware-2022-2536 — Recovery Inhibition (redalert)
// Status: deprecated | Level: high | ID: 2119e13f-8c72-547f-a83f-3bf7f9322ff7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
