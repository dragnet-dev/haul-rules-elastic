// Dragnet [Ransomware]: dragnet-ransomware-2022-0984 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 1dfd5abd-c306-541b-b384-578977c77a58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
