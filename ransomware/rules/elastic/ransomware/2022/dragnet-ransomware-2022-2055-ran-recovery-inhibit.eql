// Dragnet [Ransomware]: dragnet-ransomware-2022-2055 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 71fe4825-59b8-5f5f-a8dc-3c104f68be0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
