// Dragnet [Ransomware]: dragnet-ransomware-2022-1209 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 045cf0b4-2170-5363-87d6-a171b330b2f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
