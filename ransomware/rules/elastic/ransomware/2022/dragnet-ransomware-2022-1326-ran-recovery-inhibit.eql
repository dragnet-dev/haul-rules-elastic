// Dragnet [Ransomware]: dragnet-ransomware-2022-1326 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e66c7129-4554-5c5d-aae3-351257b96ee5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
