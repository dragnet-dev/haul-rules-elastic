// Dragnet [Ransomware]: dragnet-ransomware-2022-1395 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 31da68a1-a43f-50d2-8964-43bc2baf2747

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
