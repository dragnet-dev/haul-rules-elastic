// Dragnet [Ransomware]: dragnet-ransomware-2022-1969 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 04ad9f28-1f83-59ee-89a9-4d6745ac64c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
