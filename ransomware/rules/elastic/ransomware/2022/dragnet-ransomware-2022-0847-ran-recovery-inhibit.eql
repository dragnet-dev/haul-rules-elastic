// Dragnet [Ransomware]: dragnet-ransomware-2022-0847 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 7299e1c9-18e8-5d11-9ee1-b433abd13bd6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
