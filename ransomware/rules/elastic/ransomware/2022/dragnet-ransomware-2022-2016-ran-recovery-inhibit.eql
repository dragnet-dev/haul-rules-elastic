// Dragnet [Ransomware]: dragnet-ransomware-2022-2016 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 8e4a1981-e6ce-53c0-9732-046992973ed4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
