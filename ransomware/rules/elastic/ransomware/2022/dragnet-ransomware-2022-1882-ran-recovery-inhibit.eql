// Dragnet [Ransomware]: dragnet-ransomware-2022-1882 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 9ba04f76-8876-5f91-a397-e06c1a8648f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
