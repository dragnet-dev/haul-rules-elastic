// Dragnet [Ransomware]: dragnet-ransomware-2022-1038 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: 458977e4-c42a-5771-a8ac-92d696a037c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
