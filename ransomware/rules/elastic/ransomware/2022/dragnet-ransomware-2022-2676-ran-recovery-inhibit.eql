// Dragnet [Ransomware]: dragnet-ransomware-2022-2676 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 9f455129-18b6-576f-aea1-7245afe35238

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
