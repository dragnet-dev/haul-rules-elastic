// Dragnet [Ransomware]: dragnet-ransomware-2022-0263 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: e4ff672e-39a6-5547-bad9-4d8ae68dcfcd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
