// Dragnet [Ransomware]: dragnet-ransomware-2022-2328 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 04416be9-fcd3-5adf-8a68-7d9ffe927c87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
