// Dragnet [Ransomware]: dragnet-ransomware-2022-1937 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 2051461d-9ff9-55a4-b1b3-01e789eaab29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
