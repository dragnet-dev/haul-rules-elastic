// Dragnet [Ransomware]: dragnet-ransomware-2022-0746 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 27d2a52d-c50d-5f5c-a7c3-d36b4c8c9169

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
