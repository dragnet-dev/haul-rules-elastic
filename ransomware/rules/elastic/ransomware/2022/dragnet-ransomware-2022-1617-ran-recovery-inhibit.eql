// Dragnet [Ransomware]: dragnet-ransomware-2022-1617 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: bdcc35d9-1351-5f75-9d3f-7a949b54034c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
