// Dragnet [Ransomware]: dragnet-ransomware-2022-0220 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 52fe79c7-572b-54ce-a88b-3607cb7113c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
