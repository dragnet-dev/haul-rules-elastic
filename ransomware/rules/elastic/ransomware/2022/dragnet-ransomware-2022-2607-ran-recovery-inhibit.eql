// Dragnet [Ransomware]: dragnet-ransomware-2022-2607 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: fb06c1fa-563b-545a-ae47-2ee5b20c1f0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
