// Dragnet [Ransomware]: dragnet-ransomware-2022-2742 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: a9450961-341d-50db-b1a8-632b76599f93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
