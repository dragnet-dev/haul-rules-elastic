// Dragnet [Ransomware]: dragnet-ransomware-2022-0170 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: d63b844d-8d0d-57e8-ba07-c1363b194e06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
