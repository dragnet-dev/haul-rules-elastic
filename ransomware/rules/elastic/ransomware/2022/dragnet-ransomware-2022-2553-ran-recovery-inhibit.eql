// Dragnet [Ransomware]: dragnet-ransomware-2022-2553 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 3ef540c9-7e2c-52a7-9c07-9e31d56f6588

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
