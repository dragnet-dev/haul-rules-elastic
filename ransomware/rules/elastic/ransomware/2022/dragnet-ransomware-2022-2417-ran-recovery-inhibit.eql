// Dragnet [Ransomware]: dragnet-ransomware-2022-2417 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: a152b97f-716f-56ea-8f9d-e0b839655389

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
