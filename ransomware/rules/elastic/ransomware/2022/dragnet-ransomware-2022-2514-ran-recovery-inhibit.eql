// Dragnet [Ransomware]: dragnet-ransomware-2022-2514 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 89c62322-d9f6-55b1-95a0-8c73ec655d8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
