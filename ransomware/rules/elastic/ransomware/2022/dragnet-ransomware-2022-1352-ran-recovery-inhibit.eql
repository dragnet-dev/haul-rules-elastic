// Dragnet [Ransomware]: dragnet-ransomware-2022-1352 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: ae5dbc96-e001-5988-b4f3-47784b0e1ed3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
