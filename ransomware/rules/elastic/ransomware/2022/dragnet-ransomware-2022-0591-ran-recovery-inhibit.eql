// Dragnet [Ransomware]: dragnet-ransomware-2022-0591 — Recovery Inhibition (mindware)
// Status: deprecated | Level: high | ID: 7ad9789e-5f50-5f96-8df7-260473194f5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
