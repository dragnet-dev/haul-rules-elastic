// Dragnet [Ransomware]: dragnet-ransomware-2022-0627 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: d18409d4-6550-53b2-a8a5-11c13cc05196

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
