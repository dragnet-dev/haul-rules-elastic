// Dragnet [Ransomware]: dragnet-ransomware-2022-0323 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 34d78ccd-dc04-5184-9d08-c12fdd33ff5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
