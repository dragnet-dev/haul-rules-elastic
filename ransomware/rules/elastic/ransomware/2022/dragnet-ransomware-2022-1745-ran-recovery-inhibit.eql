// Dragnet [Ransomware]: dragnet-ransomware-2022-1745 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ae523c49-10e3-560a-93d0-477af98741d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
