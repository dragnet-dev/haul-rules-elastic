// Dragnet [Ransomware]: dragnet-ransomware-2022-2949 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2524a7c0-742d-5307-b4c0-f469c3d7efe5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
