// Dragnet [Ransomware]: dragnet-ransomware-2022-1165 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 833f8f67-b654-5531-ad58-fa048bfa5299

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
