// Dragnet [Ransomware]: dragnet-ransomware-2022-2302 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 31efcd5f-1582-5236-941d-68b354ade3b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
