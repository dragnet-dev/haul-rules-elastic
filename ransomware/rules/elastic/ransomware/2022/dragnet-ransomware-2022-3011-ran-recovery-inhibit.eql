// Dragnet [Ransomware]: dragnet-ransomware-2022-3011 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: 97708e4d-4bae-5868-b34a-80543510ed94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
