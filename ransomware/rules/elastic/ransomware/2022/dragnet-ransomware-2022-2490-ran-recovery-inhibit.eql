// Dragnet [Ransomware]: dragnet-ransomware-2022-2490 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d364c32a-e78e-532a-a614-75860fd828da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
