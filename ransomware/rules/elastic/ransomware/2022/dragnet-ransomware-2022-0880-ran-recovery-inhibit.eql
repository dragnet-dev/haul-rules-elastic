// Dragnet [Ransomware]: dragnet-ransomware-2022-0880 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 50cc025a-2244-543e-af20-065070e09aae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
