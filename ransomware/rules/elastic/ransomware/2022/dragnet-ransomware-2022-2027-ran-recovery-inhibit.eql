// Dragnet [Ransomware]: dragnet-ransomware-2022-2027 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: ef7eda9a-e292-56c9-8252-73e58b8384e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
