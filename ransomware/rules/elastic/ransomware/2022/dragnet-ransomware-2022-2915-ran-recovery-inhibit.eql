// Dragnet [Ransomware]: dragnet-ransomware-2022-2915 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: a12b6c7b-b931-59d4-b773-2dca26ffdbdb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
