// Dragnet [Ransomware]: dragnet-ransomware-2022-2319 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 1b3f31d2-37e9-5242-9fdc-3d5871ef14cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
