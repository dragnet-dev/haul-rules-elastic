// Dragnet [Ransomware]: dragnet-ransomware-2022-3046 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 7b4291cf-7611-57f1-86db-d0c7673e1bb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
