// Dragnet [Ransomware]: dragnet-ransomware-2022-2422 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: fb0a0423-6c39-5292-b31a-aaa4c1fb3679

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
