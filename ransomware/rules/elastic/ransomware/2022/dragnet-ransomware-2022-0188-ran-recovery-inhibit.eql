// Dragnet [Ransomware]: dragnet-ransomware-2022-0188 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 7bf08633-35d8-5fd3-9efd-d723ffdebd9c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
