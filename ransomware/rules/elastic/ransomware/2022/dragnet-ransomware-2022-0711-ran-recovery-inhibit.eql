// Dragnet [Ransomware]: dragnet-ransomware-2022-0711 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: b5b4cf88-b772-57b9-b692-0d64ec8cedb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
