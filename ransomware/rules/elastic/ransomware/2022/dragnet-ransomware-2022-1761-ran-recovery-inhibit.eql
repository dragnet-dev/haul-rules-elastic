// Dragnet [Ransomware]: dragnet-ransomware-2022-1761 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: a7baf676-f0d2-5ab8-be11-4f6a2ae6337c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
