// Dragnet [Ransomware]: dragnet-ransomware-2022-1611 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 06e03cac-80a9-53e6-94b1-2d0951c20cee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
