// Dragnet [Ransomware]: dragnet-ransomware-2022-0888 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 563a75f0-0ad4-5703-b31f-6ad005a30867

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
