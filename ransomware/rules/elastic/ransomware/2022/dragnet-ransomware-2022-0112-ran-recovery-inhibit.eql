// Dragnet [Ransomware]: dragnet-ransomware-2022-0112 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: 0aa3aa05-a765-53b5-9814-144e98216ee1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
