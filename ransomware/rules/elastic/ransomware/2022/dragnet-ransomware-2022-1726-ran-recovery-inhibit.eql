// Dragnet [Ransomware]: dragnet-ransomware-2022-1726 — Recovery Inhibition (unsafe)
// Status: deprecated | Level: high | ID: 60ff409c-0d8d-5a8f-acda-6fe40780533c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
