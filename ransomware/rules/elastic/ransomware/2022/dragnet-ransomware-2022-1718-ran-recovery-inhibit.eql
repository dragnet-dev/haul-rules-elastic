// Dragnet [Ransomware]: dragnet-ransomware-2022-1718 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 54b84987-1096-5778-afe3-0ab86a84362c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
