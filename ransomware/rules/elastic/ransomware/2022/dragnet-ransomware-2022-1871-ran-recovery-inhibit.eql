// Dragnet [Ransomware]: dragnet-ransomware-2022-1871 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: e893f63e-7954-54ca-8509-7945f9ef74ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
