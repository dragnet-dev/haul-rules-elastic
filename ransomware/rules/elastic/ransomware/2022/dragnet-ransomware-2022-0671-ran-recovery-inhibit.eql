// Dragnet [Ransomware]: dragnet-ransomware-2022-0671 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 0db8cb63-42c3-5f74-b673-339a89bfea6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
