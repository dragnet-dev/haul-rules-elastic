// Dragnet [Ransomware]: dragnet-ransomware-2022-2891 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 772ae68a-ba35-5bf0-894f-49398acb2bde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
