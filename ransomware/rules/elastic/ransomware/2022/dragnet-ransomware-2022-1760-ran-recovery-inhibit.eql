// Dragnet [Ransomware]: dragnet-ransomware-2022-1760 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 1b19c998-9872-51ea-a025-f97d8feab76b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
