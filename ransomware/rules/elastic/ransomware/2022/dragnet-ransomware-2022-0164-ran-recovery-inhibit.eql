// Dragnet [Ransomware]: dragnet-ransomware-2022-0164 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 91ef380b-9e55-5161-9de1-31ba75e1444c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
