// Dragnet [Ransomware]: dragnet-ransomware-2022-2170 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 24bc84ab-5b4b-5a0e-9fbb-30e7af284edc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
