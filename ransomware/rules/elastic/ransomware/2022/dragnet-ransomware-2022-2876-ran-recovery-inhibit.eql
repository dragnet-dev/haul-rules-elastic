// Dragnet [Ransomware]: dragnet-ransomware-2022-2876 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 92465a58-ce8f-51cf-bf05-bfc0c1c514d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
