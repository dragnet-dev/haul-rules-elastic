// Dragnet [Ransomware]: dragnet-ransomware-2022-2671 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: ee92a72b-7025-5646-a81e-773925be34e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
