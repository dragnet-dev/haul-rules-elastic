// Dragnet [Ransomware]: dragnet-ransomware-2022-0615 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 6b7fe3d9-aea4-5873-829d-cb86cc430c06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
