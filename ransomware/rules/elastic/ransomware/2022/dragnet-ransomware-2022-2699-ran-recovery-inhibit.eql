// Dragnet [Ransomware]: dragnet-ransomware-2022-2699 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: fe9809bf-09a9-50ec-8480-11470df936aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
