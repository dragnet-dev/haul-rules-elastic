// Dragnet [Ransomware]: dragnet-ransomware-2022-2284 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a4d66688-2805-5f83-ad80-21fb9822291b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
