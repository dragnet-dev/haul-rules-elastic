// Dragnet [Ransomware]: dragnet-ransomware-2022-2085 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: caf52176-29e9-5b42-a462-412352e3e75f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
