// Dragnet [Ransomware]: dragnet-ransomware-2022-0049 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: e69ca359-bf49-5907-8d13-a32938fc58ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
