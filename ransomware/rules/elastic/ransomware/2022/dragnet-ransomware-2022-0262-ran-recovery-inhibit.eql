// Dragnet [Ransomware]: dragnet-ransomware-2022-0262 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 0456e167-9587-5119-9aa5-72ed426d0cfb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
