// Dragnet [Ransomware]: dragnet-ransomware-2022-1415 — Recovery Inhibition (nokoyawa)
// Status: deprecated | Level: high | ID: 6ca20054-43c1-5e6e-b9bb-38ea86afe7d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
