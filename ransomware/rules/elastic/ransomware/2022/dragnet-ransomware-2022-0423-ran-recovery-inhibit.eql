// Dragnet [Ransomware]: dragnet-ransomware-2022-0423 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 63a102b7-4add-5a0a-8791-631cd3ee7282

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
