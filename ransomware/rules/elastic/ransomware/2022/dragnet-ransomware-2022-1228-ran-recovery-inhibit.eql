// Dragnet [Ransomware]: dragnet-ransomware-2022-1228 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 66fe00e7-7045-5d01-835f-bbacbb6207a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
