// Dragnet [Ransomware]: dragnet-ransomware-2022-0421 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 2eafc996-5e3d-5dbd-a100-b83fc59dc232

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
