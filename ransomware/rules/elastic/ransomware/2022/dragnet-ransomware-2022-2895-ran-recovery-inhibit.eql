// Dragnet [Ransomware]: dragnet-ransomware-2022-2895 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 64dba145-06ff-5a2d-8447-6b1b025bc3ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
