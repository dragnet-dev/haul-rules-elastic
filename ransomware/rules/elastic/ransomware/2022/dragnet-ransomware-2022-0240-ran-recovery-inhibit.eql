// Dragnet [Ransomware]: dragnet-ransomware-2022-0240 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 20b5eb18-356d-580f-973c-2876026afa5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
