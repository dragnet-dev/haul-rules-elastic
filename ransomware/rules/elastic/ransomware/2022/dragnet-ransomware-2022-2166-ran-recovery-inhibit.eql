// Dragnet [Ransomware]: dragnet-ransomware-2022-2166 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 2c4bc4d4-f986-5d9b-91be-5977578c36a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
