// Dragnet [Ransomware]: dragnet-ransomware-2022-0082 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8975870d-0720-5267-81ce-482f47366c6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
