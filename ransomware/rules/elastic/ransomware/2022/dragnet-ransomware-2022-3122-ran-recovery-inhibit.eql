// Dragnet [Ransomware]: dragnet-ransomware-2022-3122 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 537c2b76-0d15-5b3c-a3e8-11dbbbb059c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
