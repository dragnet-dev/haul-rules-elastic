// Dragnet [Ransomware]: dragnet-ransomware-2022-2265 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: b4dd019a-bce9-533f-abeb-9898c8e7ef13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
