// Dragnet [Ransomware]: dragnet-ransomware-2022-1508 — Recovery Inhibition (medusalocker)
// Status: deprecated | Level: high | ID: 27522035-658a-5560-8dec-c05a3fbd1c24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
