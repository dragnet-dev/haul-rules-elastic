// Dragnet [Ransomware]: dragnet-ransomware-2022-0553 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 2b1f3b66-2dc1-5a25-8cbf-51eb0aea22b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
