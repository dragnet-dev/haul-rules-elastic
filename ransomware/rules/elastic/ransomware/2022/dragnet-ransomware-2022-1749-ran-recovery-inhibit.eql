// Dragnet [Ransomware]: dragnet-ransomware-2022-1749 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 98119285-3f41-5fa0-b858-259b396ed500

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
