// Dragnet [Ransomware]: dragnet-ransomware-2022-2359 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 4f28a98e-7e94-5cad-bc1c-abef3ff5d809

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
