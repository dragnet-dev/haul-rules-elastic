// Dragnet [Ransomware]: dragnet-ransomware-2022-0105 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: a53e3f2b-4f47-51b7-8a6e-08f63a5b8b3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
