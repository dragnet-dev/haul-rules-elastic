// Dragnet [Ransomware]: dragnet-ransomware-2022-2718 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 173e0199-c634-511b-8ed2-51709a4aec44

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
