// Dragnet [Ransomware]: dragnet-ransomware-2022-1571 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: c9a7f470-5cbe-5202-9413-b38332da36ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
