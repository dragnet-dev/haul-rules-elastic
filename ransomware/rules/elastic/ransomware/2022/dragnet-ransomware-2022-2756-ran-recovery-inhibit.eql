// Dragnet [Ransomware]: dragnet-ransomware-2022-2756 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ecd32c27-41ac-584b-be08-2df9444df804

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
