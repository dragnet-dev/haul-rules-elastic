// Dragnet [Ransomware]: dragnet-ransomware-2022-0969 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5b96adca-66e4-5168-b48b-6d80b86b0a06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
