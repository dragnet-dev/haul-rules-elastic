// Dragnet [Ransomware]: dragnet-ransomware-2022-1330 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d0ba5345-88f5-593d-89f2-6370b390c014

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
