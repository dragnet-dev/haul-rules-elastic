// Dragnet [Ransomware]: dragnet-ransomware-2022-1401 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: c4fdc635-0183-5cf0-a75a-0bbc326a2b1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
