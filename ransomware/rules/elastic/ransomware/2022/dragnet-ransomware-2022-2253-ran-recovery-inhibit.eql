// Dragnet [Ransomware]: dragnet-ransomware-2022-2253 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: bfc86342-c91e-5195-b1d0-d41476b15954

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
