// Dragnet [Ransomware]: dragnet-ransomware-2022-0019 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 01938946-b715-5214-be9e-3c81e4bee2e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
