// Dragnet [Ransomware]: dragnet-ransomware-2022-1102 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 533b3470-809e-524d-a902-5fde47156c51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
