// Dragnet [Ransomware]: dragnet-ransomware-2022-2660 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: b1f5b3f6-71ab-5a89-8926-97ca32a85839

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
