// Dragnet [Ransomware]: dragnet-ransomware-2022-1797 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: df2f869d-534c-5889-8143-1e6866742950

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
