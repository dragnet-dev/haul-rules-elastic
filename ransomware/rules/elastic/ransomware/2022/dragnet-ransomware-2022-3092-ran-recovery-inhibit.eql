// Dragnet [Ransomware]: dragnet-ransomware-2022-3092 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 06417cea-e6ec-535e-9776-2234185e629d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
