// Dragnet [Ransomware]: dragnet-ransomware-2022-2792 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: a07c9b96-1e8f-556e-ad6e-e1e8cbdb2339

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
