// Dragnet [Ransomware]: dragnet-ransomware-2022-2063 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: f47c1597-36bc-583f-8836-11e238805536

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
