// Dragnet [Ransomware]: dragnet-ransomware-2022-1769 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 84596273-fbf5-53da-b36d-25e4ef6f37c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
