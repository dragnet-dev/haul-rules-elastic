// Dragnet [Ransomware]: dragnet-ransomware-2022-1989 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 1b6e41b8-a9e9-5707-a67a-5a87b3291408

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
