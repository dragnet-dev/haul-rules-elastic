// Dragnet [Ransomware]: dragnet-ransomware-2022-0492 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ab4ce413-93d4-5de9-b898-5ba85a97d48b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
