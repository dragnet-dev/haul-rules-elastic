// Dragnet [Ransomware]: dragnet-ransomware-2022-1971 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c242ac49-24b9-5faa-b590-20369900a263

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
