// Dragnet [Ransomware]: dragnet-ransomware-2022-0975 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b33b3de1-a867-5c54-b1c2-2285f33d712f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
