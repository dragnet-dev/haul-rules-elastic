// Dragnet [Ransomware]: dragnet-ransomware-2022-0529 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: bee3df2d-9e10-5334-96d6-04ca2d768d11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
