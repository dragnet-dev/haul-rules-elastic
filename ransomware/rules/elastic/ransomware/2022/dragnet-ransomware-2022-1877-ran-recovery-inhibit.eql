// Dragnet [Ransomware]: dragnet-ransomware-2022-1877 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 2d074ec2-28dc-5477-9380-7546b7567a7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
