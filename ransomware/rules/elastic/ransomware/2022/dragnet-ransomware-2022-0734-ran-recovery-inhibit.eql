// Dragnet [Ransomware]: dragnet-ransomware-2022-0734 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 628a2bef-c6cf-5760-bd93-e5cd983cd907

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
