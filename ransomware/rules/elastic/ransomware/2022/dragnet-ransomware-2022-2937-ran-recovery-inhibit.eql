// Dragnet [Ransomware]: dragnet-ransomware-2022-2937 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 048bba33-2add-5385-8d61-db70a23de9e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
