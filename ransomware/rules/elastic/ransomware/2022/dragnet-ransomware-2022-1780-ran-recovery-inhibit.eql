// Dragnet [Ransomware]: dragnet-ransomware-2022-1780 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: a73624ef-1b19-5a5d-b6d2-6c3d7efcd6ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
