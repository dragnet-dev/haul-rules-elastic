// Dragnet [Ransomware]: dragnet-ransomware-2022-1174 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: cce378e3-6840-52de-a917-cee585990258

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
