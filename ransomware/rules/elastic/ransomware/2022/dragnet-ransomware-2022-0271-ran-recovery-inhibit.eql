// Dragnet [Ransomware]: dragnet-ransomware-2022-0271 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 920bdcfe-d710-5d6f-b3d2-18226eb781da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
