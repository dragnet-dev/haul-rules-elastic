// Dragnet [Ransomware]: dragnet-ransomware-2022-2822 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 6013b603-04b9-57ea-806f-d005439097f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
