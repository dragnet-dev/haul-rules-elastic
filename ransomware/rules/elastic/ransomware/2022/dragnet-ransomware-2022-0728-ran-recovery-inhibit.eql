// Dragnet [Ransomware]: dragnet-ransomware-2022-0728 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 1988f3f3-4c4b-530f-9ad2-322c8a50a978

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
