// Dragnet [Ransomware]: dragnet-ransomware-2022-3149 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5e99eb65-d679-540d-9f1b-992ff0d50bb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
