// Dragnet [Ransomware]: dragnet-ransomware-2022-2924 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 94295d67-04b0-5242-8bcc-062206720331

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
