// Dragnet [Ransomware]: dragnet-ransomware-2022-2036 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: 93ae1aaa-4109-5a58-913e-ea9f0bdaef98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
