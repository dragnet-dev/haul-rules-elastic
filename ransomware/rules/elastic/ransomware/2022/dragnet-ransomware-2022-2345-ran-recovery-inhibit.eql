// Dragnet [Ransomware]: dragnet-ransomware-2022-2345 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 825ac2f3-dd80-5cff-bc78-d1f18bea3848

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
