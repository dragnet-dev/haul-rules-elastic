// Dragnet [Ransomware]: dragnet-ransomware-2022-0701 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 14890690-2c87-5e69-8640-3cc921bd0e8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
