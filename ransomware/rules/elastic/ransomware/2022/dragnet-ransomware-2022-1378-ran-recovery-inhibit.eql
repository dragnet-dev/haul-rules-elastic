// Dragnet [Ransomware]: dragnet-ransomware-2022-1378 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 4cbbbe2e-0b3d-58c0-a57f-b1aabddd95e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
