// Dragnet [Ransomware]: dragnet-ransomware-2022-3107 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ed513d95-9c72-57be-b599-852da7b3184a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
