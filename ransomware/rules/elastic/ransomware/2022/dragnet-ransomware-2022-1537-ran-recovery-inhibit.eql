// Dragnet [Ransomware]: dragnet-ransomware-2022-1537 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 9cfd018f-698e-57ea-9e57-081bff2380d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
