// Dragnet [Ransomware]: dragnet-ransomware-2022-1040 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 29fa5105-cb2e-5fe9-8d29-6342c4a7e0af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
