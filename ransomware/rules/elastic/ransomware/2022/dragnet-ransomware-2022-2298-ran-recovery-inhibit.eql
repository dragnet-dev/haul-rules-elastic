// Dragnet [Ransomware]: dragnet-ransomware-2022-2298 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: c0b5ab5a-21e4-5e20-802c-27dcd44c0957

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
