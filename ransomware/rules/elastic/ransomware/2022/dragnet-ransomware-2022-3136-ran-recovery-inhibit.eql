// Dragnet [Ransomware]: dragnet-ransomware-2022-3136 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: e3781084-dad4-52ab-bbfd-5917d76a526a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
