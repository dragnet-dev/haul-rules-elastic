// Dragnet [Ransomware]: dragnet-ransomware-2022-2307 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 6c8d3d30-369c-5345-954a-0889dff1ecfb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
