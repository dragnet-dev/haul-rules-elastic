// Dragnet [Ransomware]: dragnet-ransomware-2022-0391 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 87a62051-ebe1-5fe5-9f00-273ec395c400

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
