// Dragnet [Ransomware]: dragnet-ransomware-2022-0564 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 738421a1-f991-5663-b4f8-9cb8675a37ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
