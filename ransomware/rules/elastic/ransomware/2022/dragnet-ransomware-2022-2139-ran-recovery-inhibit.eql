// Dragnet [Ransomware]: dragnet-ransomware-2022-2139 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ffe7b719-0495-5322-af72-9d229a79050c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
