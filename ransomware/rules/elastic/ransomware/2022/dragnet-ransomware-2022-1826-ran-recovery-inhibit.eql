// Dragnet [Ransomware]: dragnet-ransomware-2022-1826 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: fe6db706-6a43-530e-bb4b-1e1426d90c91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
