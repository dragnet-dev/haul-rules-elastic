// Dragnet [Ransomware]: dragnet-ransomware-2022-2574 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: ea2386d8-1ca7-56c2-88c2-41ff78d839e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
