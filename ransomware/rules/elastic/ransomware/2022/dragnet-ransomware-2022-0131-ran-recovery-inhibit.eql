// Dragnet [Ransomware]: dragnet-ransomware-2022-0131 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 4d8c2805-cfcf-5c5c-9ed9-2e612b3ba32a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
