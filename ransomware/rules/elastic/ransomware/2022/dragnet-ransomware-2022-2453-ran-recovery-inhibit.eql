// Dragnet [Ransomware]: dragnet-ransomware-2022-2453 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: d767e7b5-e46c-5fef-811b-794adc60fc5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
