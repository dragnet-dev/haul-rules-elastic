// Dragnet [Ransomware]: dragnet-ransomware-2022-0658 — Recovery Inhibition (yanluowang)
// Status: deprecated | Level: high | ID: 0548c460-1335-5750-8a14-37fa0aa2c2f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
