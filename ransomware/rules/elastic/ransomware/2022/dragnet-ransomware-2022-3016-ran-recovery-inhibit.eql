// Dragnet [Ransomware]: dragnet-ransomware-2022-3016 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: fa361b99-ff57-5270-a0e2-1f1f6f911bed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
