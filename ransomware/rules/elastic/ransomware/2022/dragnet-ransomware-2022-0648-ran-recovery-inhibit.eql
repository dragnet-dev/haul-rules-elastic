// Dragnet [Ransomware]: dragnet-ransomware-2022-0648 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: be2184e7-1c4e-51aa-90ed-1b710e2edb7c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
