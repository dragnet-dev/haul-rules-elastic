// Dragnet [Ransomware]: dragnet-ransomware-2022-0900 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: b012de6d-2731-59a5-ac11-b74d4eae0a36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
