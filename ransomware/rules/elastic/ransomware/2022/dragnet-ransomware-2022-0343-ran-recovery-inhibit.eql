// Dragnet [Ransomware]: dragnet-ransomware-2022-0343 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 79a6be19-9626-57d9-a6b6-547ab9470d62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
