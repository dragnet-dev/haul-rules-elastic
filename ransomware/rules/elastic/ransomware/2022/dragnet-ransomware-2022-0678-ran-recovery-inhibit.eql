// Dragnet [Ransomware]: dragnet-ransomware-2022-0678 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ed00872d-b426-5bf6-9dd9-76884cd6c50a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
