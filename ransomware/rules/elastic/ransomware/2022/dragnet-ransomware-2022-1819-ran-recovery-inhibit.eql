// Dragnet [Ransomware]: dragnet-ransomware-2022-1819 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 028a920a-bb17-5877-a042-94eca884bc34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
