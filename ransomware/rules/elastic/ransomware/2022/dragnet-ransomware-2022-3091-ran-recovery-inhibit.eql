// Dragnet [Ransomware]: dragnet-ransomware-2022-3091 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 253927e2-a164-5372-b66a-0e30cdeae03b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
