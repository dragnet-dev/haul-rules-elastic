// Dragnet [Ransomware]: dragnet-ransomware-2022-3023 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 26c9b6bb-1f9a-5a7a-bb4c-4ae3d47f82c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
