// Dragnet [Ransomware]: dragnet-ransomware-2022-0869 — Recovery Inhibition (roadsweep)
// Status: deprecated | Level: high | ID: 2d4169a6-4c18-5ec0-8e4b-c3b3ff204cda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
