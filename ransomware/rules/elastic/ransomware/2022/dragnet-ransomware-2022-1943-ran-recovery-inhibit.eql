// Dragnet [Ransomware]: dragnet-ransomware-2022-1943 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: b3a45b1e-4f34-536c-a638-599b3a34bd2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
