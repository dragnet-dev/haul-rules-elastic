// Dragnet [Ransomware]: dragnet-ransomware-2022-2530 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2705cf43-8d37-5146-9167-ba395d9c6d59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
