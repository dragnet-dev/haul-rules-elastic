// Dragnet [Ransomware]: dragnet-ransomware-2022-0273 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 769cd11f-3d9a-54bd-90c8-dd367940c26d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
