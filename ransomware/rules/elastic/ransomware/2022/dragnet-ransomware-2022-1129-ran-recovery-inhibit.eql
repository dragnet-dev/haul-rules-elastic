// Dragnet [Ransomware]: dragnet-ransomware-2022-1129 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: 79a2193b-1d5d-5f86-9d72-00f653922263

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
