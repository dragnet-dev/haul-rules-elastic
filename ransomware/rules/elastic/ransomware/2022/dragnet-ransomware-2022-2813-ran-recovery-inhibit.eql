// Dragnet [Ransomware]: dragnet-ransomware-2022-2813 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: c740fe5c-659c-5644-9c73-65af04b68377

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
