// Dragnet [Ransomware]: dragnet-ransomware-2022-3089 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 357115a1-31a4-50af-8b81-2c5b03e73c2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
