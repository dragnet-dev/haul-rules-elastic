// Dragnet [Ransomware]: dragnet-ransomware-2022-2083 — Recovery Inhibition (medusalocker)
// Status: deprecated | Level: high | ID: e89a1545-49d4-5b5b-a5f9-de0fc08868fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
