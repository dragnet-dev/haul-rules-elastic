// Dragnet [Ransomware]: dragnet-ransomware-2022-0766 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c1135f8f-626a-5620-bad6-ae6edea3b056

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
