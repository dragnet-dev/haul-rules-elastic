// Dragnet [Ransomware]: dragnet-ransomware-2022-1176 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 78c8c14e-1f3f-5471-a9e9-a0d655c04bf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
