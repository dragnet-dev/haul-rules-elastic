// Dragnet [Ransomware]: dragnet-ransomware-2022-1591 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 1dbf86be-dbe0-50f8-93ba-08955a4ceffa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
