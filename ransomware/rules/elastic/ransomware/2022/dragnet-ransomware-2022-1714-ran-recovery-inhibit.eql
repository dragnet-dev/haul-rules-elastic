// Dragnet [Ransomware]: dragnet-ransomware-2022-1714 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 79f8d59b-bd68-56ba-b373-299512079d7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
