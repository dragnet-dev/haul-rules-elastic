// Dragnet [Ransomware]: dragnet-ransomware-2022-0852 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: fade09c8-43c4-561b-a5b9-8059d5125348

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
