// Dragnet [Ransomware]: dragnet-ransomware-2022-1950 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: a1b13a33-709f-5649-a8da-3c5deae066fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
