// Dragnet [Ransomware]: dragnet-ransomware-2022-2956 — Recovery Inhibition (yanluowang)
// Status: deprecated | Level: high | ID: a7b21972-b243-51d5-ad47-31c6522375d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
