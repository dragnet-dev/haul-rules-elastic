// Dragnet [Ransomware]: dragnet-ransomware-2022-2697 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 7004731f-3151-5731-8b24-4627375c91c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
