// Dragnet [Ransomware]: dragnet-ransomware-2022-1187 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: e39901b2-4f2b-5c2c-af33-925b1b001430

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
