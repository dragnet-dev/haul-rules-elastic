// Dragnet [Ransomware]: dragnet-ransomware-2022-0875 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 99462516-de88-564d-bd63-6b6a9fd5aaca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
