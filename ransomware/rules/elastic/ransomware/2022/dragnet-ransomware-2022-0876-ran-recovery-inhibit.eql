// Dragnet [Ransomware]: dragnet-ransomware-2022-0876 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: c723fe63-626c-5525-a0dc-6511a4ef8dd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
