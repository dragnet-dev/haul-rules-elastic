// Dragnet [Ransomware]: dragnet-ransomware-2022-0584 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: c81b8d28-2fed-5a03-b213-4a64a11bd752

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
