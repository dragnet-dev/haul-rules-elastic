// Dragnet [Ransomware]: dragnet-ransomware-2022-1554 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5104c4fd-2ebd-519e-a118-86406b6cc2f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
