// Dragnet [Ransomware]: dragnet-ransomware-2022-0774 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ff9fecb5-f2a7-542c-af45-8b230012005a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
