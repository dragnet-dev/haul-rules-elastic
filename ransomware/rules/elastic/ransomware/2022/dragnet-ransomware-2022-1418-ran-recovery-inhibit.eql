// Dragnet [Ransomware]: dragnet-ransomware-2022-1418 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 31e869bd-ec56-576b-8cc2-3b8867ac826d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
