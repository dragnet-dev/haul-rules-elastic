// Dragnet [Ransomware]: dragnet-ransomware-2022-2385 — Recovery Inhibition (leaktheanalyst)
// Status: deprecated | Level: high | ID: bf1f6100-fe9d-5c0f-aa05-dac2e1f93459

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
