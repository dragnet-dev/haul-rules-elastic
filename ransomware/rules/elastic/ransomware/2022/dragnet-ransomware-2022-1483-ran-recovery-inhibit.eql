// Dragnet [Ransomware]: dragnet-ransomware-2022-1483 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 57b46f2c-a296-5949-9d3c-f47f9b782537

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
