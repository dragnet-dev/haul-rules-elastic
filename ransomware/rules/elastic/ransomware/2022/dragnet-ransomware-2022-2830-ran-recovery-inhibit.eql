// Dragnet [Ransomware]: dragnet-ransomware-2022-2830 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: fe9f042f-7c9b-5477-bc0a-55dacc380cba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
