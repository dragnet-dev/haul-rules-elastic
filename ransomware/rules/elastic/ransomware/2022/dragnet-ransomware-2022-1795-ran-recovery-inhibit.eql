// Dragnet [Ransomware]: dragnet-ransomware-2022-1795 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 804bb7fe-4a0c-59e0-a2ed-21a61701a470

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
