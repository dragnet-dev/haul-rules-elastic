// Dragnet [Ransomware]: dragnet-ransomware-2022-1912 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: 0d468eea-2673-580c-a492-96b0c2d6579a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
