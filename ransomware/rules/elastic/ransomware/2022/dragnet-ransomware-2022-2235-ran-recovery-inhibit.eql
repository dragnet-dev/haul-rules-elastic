// Dragnet [Ransomware]: dragnet-ransomware-2022-2235 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 176a259c-7e65-50cc-961b-edf2f2bf6c08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
