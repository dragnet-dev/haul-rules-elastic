// Dragnet [Ransomware]: dragnet-ransomware-2022-2255 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 449f30c3-0bf8-5d33-b019-24501de08cf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
