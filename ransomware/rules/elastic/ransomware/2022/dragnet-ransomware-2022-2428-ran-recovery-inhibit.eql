// Dragnet [Ransomware]: dragnet-ransomware-2022-2428 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 749e9bd3-80d9-53c1-b35b-54bf2c1741de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
