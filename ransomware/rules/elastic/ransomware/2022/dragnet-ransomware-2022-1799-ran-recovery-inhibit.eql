// Dragnet [Ransomware]: dragnet-ransomware-2022-1799 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: 15765c22-1746-5120-b2f1-4e22d78b6722

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
