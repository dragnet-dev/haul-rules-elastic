// Dragnet [Ransomware]: dragnet-ransomware-2022-0835 — Recovery Inhibition (unsafe)
// Status: deprecated | Level: high | ID: 6d43da59-4bb8-5012-855b-1b0762ad3a16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
