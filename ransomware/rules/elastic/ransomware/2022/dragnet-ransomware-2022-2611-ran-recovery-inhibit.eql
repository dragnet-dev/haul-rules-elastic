// Dragnet [Ransomware]: dragnet-ransomware-2022-2611 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: 1f32c729-1069-55a9-9ea5-f91199efc0d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
