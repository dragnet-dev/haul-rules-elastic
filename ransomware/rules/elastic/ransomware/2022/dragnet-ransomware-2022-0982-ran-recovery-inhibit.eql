// Dragnet [Ransomware]: dragnet-ransomware-2022-0982 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 399087cd-0b37-5eab-b20b-2e5d9e8efb60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
