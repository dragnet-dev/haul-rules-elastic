// Dragnet [Ransomware]: dragnet-ransomware-2022-0135 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 64a2142d-0c8d-5c02-bcf1-2f0203d5f36a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
