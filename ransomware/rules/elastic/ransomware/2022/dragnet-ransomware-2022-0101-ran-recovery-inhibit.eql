// Dragnet [Ransomware]: dragnet-ransomware-2022-0101 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c9494f04-487e-557b-a727-fac38c60e1df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
