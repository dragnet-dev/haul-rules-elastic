// Dragnet [Ransomware]: dragnet-ransomware-2022-0129 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4c841bc6-6a89-5876-a797-34696d375ddc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
