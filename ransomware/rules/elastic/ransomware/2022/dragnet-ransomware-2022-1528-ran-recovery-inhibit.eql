// Dragnet [Ransomware]: dragnet-ransomware-2022-1528 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 404a44ed-0729-5a75-b5f4-d8c6ee1938f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
