// Dragnet [Ransomware]: dragnet-ransomware-2022-2977 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: be8aa161-816b-5150-87d6-ac10871a89f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
