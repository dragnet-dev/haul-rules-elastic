// Dragnet [Ransomware]: dragnet-ransomware-2022-2487 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 9922e1c2-b6a3-5733-8c23-c82d85e5c7ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
