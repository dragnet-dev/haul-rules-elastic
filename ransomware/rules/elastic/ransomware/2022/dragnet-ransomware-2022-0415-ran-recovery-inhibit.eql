// Dragnet [Ransomware]: dragnet-ransomware-2022-0415 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 84f7252c-9b88-58d6-aa7a-97269aba231a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
