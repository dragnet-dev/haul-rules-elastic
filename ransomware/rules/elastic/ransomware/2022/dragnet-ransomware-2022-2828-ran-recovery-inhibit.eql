// Dragnet [Ransomware]: dragnet-ransomware-2022-2828 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: c1a6e520-334b-5784-aab1-eca289626b6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
