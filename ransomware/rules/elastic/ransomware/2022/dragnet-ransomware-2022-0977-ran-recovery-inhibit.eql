// Dragnet [Ransomware]: dragnet-ransomware-2022-0977 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 42948e18-22cc-5d71-b678-c7de4080e79b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
