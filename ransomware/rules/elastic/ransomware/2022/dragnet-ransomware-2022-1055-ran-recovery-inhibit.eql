// Dragnet [Ransomware]: dragnet-ransomware-2022-1055 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 375025bb-8d3a-5d64-b5ee-f315efe99a0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
