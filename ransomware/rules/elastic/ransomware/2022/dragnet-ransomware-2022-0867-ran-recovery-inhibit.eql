// Dragnet [Ransomware]: dragnet-ransomware-2022-0867 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 0c63251f-42a9-5b85-b5ff-b19acf489f3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
