// Dragnet [Ransomware]: dragnet-ransomware-2022-1318 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 9c41c0be-f326-5494-b828-490d7f89c9e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
