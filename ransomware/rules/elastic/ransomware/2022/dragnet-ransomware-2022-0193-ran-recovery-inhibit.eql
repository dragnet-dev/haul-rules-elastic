// Dragnet [Ransomware]: dragnet-ransomware-2022-0193 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 6e2a64c1-8372-5a3b-bb75-cb5fac4f2fad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
