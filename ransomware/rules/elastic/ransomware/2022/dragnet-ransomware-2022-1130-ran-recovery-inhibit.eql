// Dragnet [Ransomware]: dragnet-ransomware-2022-1130 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 55d7240c-a600-5888-80ed-c6107e4d4f3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
