// Dragnet [Ransomware]: dragnet-ransomware-2022-1720 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 4dac4d0b-0bc5-5816-be36-be0ee26554ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
