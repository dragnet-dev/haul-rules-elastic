// Dragnet [Ransomware]: dragnet-ransomware-2022-2339 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 3667a147-3a7c-5cc7-8e2f-87033f1f5705

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
