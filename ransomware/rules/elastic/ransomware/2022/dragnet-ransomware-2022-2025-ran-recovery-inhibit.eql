// Dragnet [Ransomware]: dragnet-ransomware-2022-2025 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: c403f72c-ca40-54c3-be5e-bec8e31b711e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
