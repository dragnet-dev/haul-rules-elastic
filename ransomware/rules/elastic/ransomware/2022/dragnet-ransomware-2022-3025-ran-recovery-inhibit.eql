// Dragnet [Ransomware]: dragnet-ransomware-2022-3025 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 56a4d674-6c6a-517e-89ea-a096070f36e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
