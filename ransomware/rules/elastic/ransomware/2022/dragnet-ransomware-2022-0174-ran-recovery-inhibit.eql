// Dragnet [Ransomware]: dragnet-ransomware-2022-0174 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 543499f2-6d56-5a3e-a3d9-35f266d1d1e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
