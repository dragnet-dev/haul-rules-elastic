// Dragnet [Ransomware]: dragnet-ransomware-2022-2904 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: c2e6c77f-7540-58ed-a159-8fd8b88778a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
