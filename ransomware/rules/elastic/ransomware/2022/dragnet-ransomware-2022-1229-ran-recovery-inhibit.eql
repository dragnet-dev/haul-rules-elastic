// Dragnet [Ransomware]: dragnet-ransomware-2022-1229 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 026cda1f-61e1-5142-8336-d5d53e9888c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
