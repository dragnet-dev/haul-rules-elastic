// Dragnet [Ransomware]: dragnet-ransomware-2022-0652 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 3fe79beb-e3f2-57aa-8249-ce10a29e5050

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
