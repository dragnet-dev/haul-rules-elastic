// Dragnet [Ransomware]: dragnet-ransomware-2022-2725 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 2286b794-3935-5598-93d5-7550c169be2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
