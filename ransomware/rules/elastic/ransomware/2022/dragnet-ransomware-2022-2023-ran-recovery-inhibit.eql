// Dragnet [Ransomware]: dragnet-ransomware-2022-2023 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c9959b79-2241-5fe6-a9d8-9eb9dc891e75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
