// Dragnet [Ransomware]: dragnet-ransomware-2022-0758 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 7fad41d8-e8ee-562a-8025-fc204367e55c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
