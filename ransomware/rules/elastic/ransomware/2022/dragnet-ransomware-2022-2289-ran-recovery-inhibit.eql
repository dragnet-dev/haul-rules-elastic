// Dragnet [Ransomware]: dragnet-ransomware-2022-2289 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 2f4b50ef-2020-5525-8493-da1994d7ed7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
