// Dragnet [Ransomware]: dragnet-ransomware-2022-2638 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 82d01d53-9d86-5cb9-8807-5b10bf91efb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
