// Dragnet [Ransomware]: dragnet-ransomware-2022-1946 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 35e9b492-bb52-5a14-a759-1ac9aa7fdc3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
