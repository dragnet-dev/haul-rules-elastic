// Dragnet [Ransomware]: dragnet-ransomware-2022-2066 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: cd59a0b3-5455-5795-a648-2a426f64574a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
