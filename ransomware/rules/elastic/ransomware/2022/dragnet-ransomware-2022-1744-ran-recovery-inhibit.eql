// Dragnet [Ransomware]: dragnet-ransomware-2022-1744 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 65520d2c-9c53-5f83-aaad-5f8747ddf461

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
