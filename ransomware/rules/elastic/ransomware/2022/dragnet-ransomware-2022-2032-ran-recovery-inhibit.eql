// Dragnet [Ransomware]: dragnet-ransomware-2022-2032 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 78a5a283-19e5-5dbc-8abd-f18069814c96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
