// Dragnet [Ransomware]: dragnet-ransomware-2022-2758 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 31c9468a-b11f-524f-bc53-2587850aaa9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
