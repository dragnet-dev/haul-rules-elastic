// Dragnet [Ransomware]: dragnet-ransomware-2022-1999 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: eb5741ef-3c8c-58c6-bd6a-635ece75f2ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
