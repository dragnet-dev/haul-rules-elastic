// Dragnet [Ransomware]: dragnet-ransomware-2022-1420 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 1e02bac6-4399-5048-b7db-343aad8545fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
