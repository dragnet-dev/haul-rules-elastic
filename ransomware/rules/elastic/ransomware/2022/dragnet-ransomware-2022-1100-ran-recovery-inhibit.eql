// Dragnet [Ransomware]: dragnet-ransomware-2022-1100 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a48def8e-ba24-5aa7-be0c-58fc1c6b21e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
