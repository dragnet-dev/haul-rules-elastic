// Dragnet [Ransomware]: dragnet-ransomware-2022-0366 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 72c1d997-f08d-5a6f-a61e-8d690f7d370c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
