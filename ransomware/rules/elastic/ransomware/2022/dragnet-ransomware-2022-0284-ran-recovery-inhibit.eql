// Dragnet [Ransomware]: dragnet-ransomware-2022-0284 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: 2bc032cd-db09-54cf-b607-1407adc60810

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
