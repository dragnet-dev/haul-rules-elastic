// Dragnet [Ransomware]: dragnet-ransomware-2022-0212 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 456e698f-8481-53c1-8646-8aaad417972d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
