// Dragnet [Ransomware]: dragnet-ransomware-2022-0106 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 449f5408-a0b1-5972-aa95-056b0bb36b9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
