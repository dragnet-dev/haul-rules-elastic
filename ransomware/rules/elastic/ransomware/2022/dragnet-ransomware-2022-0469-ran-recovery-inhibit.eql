// Dragnet [Ransomware]: dragnet-ransomware-2022-0469 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 8389d696-7702-58d1-85d9-abe762cb430a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
