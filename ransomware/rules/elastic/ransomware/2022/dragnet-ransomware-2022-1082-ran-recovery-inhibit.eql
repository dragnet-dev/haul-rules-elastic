// Dragnet [Ransomware]: dragnet-ransomware-2022-1082 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: f6806cd7-a838-5d02-a25f-dfbdebc50499

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
