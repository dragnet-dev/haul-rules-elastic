// Dragnet [Ransomware]: dragnet-ransomware-2022-2981 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: a06cc66b-0a21-54eb-abe2-a98914223122

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
