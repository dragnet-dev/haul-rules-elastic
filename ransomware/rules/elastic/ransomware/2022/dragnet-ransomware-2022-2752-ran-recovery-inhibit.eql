// Dragnet [Ransomware]: dragnet-ransomware-2022-2752 — Recovery Inhibition (projectrelic)
// Status: deprecated | Level: high | ID: fc1dffd0-5e86-5ab4-ad9d-00eb4c3f7e92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
