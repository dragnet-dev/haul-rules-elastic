// Dragnet [Ransomware]: dragnet-ransomware-2022-1527 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 3c35aaa3-2c52-5371-9b1d-1c4b0e1fdb4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
