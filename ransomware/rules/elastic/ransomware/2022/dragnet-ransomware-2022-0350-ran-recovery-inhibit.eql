// Dragnet [Ransomware]: dragnet-ransomware-2022-0350 — Recovery Inhibition (rook)
// Status: deprecated | Level: high | ID: c1c48966-5553-5e08-b1f8-9daacfeeadf5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
