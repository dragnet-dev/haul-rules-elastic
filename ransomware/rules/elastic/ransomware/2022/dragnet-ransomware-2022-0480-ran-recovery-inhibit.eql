// Dragnet [Ransomware]: dragnet-ransomware-2022-0480 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 12eccedb-b0f8-5236-9c6c-271da00a28b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
