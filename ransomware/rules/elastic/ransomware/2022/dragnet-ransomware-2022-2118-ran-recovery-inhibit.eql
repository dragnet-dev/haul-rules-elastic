// Dragnet [Ransomware]: dragnet-ransomware-2022-2118 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 82b6c89d-245a-5ac3-abc0-045d391aabf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
