// Dragnet [Ransomware]: dragnet-ransomware-2022-2164 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: b618b568-cd72-5e0e-b3e3-078b818175de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
