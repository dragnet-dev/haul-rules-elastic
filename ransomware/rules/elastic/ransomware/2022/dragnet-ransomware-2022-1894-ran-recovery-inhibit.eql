// Dragnet [Ransomware]: dragnet-ransomware-2022-1894 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5654ea5a-5cd1-519b-8f13-c8a98207efb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
