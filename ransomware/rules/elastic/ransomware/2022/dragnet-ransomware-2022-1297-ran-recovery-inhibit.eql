// Dragnet [Ransomware]: dragnet-ransomware-2022-1297 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 88924470-0f09-50d5-9f98-13380939afdb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
