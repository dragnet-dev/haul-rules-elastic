// Dragnet [Ransomware]: dragnet-ransomware-2022-1416 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: 7c3e146c-98d8-5828-9690-07b129cfa08f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
