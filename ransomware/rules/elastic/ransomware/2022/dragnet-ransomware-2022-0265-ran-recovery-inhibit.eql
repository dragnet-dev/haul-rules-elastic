// Dragnet [Ransomware]: dragnet-ransomware-2022-0265 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: de5b9298-d858-5266-b82e-dba54060ba38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
