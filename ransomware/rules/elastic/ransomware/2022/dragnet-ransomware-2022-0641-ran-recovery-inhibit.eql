// Dragnet [Ransomware]: dragnet-ransomware-2022-0641 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: ef50926a-ec98-5c75-8df2-b6e61f342fc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
