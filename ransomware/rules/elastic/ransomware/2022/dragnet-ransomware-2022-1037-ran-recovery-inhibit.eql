// Dragnet [Ransomware]: dragnet-ransomware-2022-1037 — Recovery Inhibition (yanluowang)
// Status: deprecated | Level: high | ID: 7226131f-4f58-517e-9a37-a813eafbf269

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
