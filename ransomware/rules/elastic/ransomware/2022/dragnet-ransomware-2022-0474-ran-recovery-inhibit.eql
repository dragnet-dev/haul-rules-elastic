// Dragnet [Ransomware]: dragnet-ransomware-2022-0474 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f429eca9-5320-5305-937c-a288c273fec4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
