// Dragnet [Ransomware]: dragnet-ransomware-2022-1432 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: 78c16d66-570a-5935-a01e-e549fb700766

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
