// Dragnet [Ransomware]: dragnet-ransomware-2022-1466 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: aa934b1d-f4a5-5a36-8c48-4894081751db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
