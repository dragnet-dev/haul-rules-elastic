// Dragnet [Ransomware]: dragnet-ransomware-2022-2473 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 54f9c350-1fbb-589d-8201-2c0579c54399

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
