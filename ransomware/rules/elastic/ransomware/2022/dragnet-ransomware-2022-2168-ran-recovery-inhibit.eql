// Dragnet [Ransomware]: dragnet-ransomware-2022-2168 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 0383277f-2788-597a-aad7-e8540960694d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
