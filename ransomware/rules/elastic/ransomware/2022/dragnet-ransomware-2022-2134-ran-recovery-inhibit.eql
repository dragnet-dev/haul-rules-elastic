// Dragnet [Ransomware]: dragnet-ransomware-2022-2134 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 47f70fab-aa86-51d0-8ba4-2d3bba75aa63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
