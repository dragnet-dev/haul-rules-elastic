// Dragnet [Ransomware]: dragnet-ransomware-2022-2375 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: fc783d48-1dec-581f-b28d-fd5bbbe56029

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
