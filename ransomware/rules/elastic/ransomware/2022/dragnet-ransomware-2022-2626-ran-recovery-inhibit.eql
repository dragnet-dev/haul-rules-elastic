// Dragnet [Ransomware]: dragnet-ransomware-2022-2626 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 1e5661bc-c86d-544a-a027-e63e6315abd3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
