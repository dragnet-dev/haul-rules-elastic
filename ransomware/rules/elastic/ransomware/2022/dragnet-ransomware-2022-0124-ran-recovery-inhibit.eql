// Dragnet [Ransomware]: dragnet-ransomware-2022-0124 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 53090de5-5c96-5e7e-8f47-7c36c5a02049

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
