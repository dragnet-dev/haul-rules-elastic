// Dragnet [Ransomware]: dragnet-ransomware-2022-2010 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 004526bf-79c9-5508-bb60-f77ac7d08ace

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
