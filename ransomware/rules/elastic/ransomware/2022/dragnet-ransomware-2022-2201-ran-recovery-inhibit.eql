// Dragnet [Ransomware]: dragnet-ransomware-2022-2201 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: 3efc2cd8-100f-5bbb-92ac-3bee6bf62308

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
