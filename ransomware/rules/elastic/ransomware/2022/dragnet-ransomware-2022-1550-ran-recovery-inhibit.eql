// Dragnet [Ransomware]: dragnet-ransomware-2022-1550 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: d7dd71e1-74e1-5b4b-9638-d309a1072a9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
