// Dragnet [Ransomware]: dragnet-ransomware-2022-1867 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: c6a91ec6-808e-5b08-b792-9fb80a817189

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
