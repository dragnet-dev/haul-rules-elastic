// Dragnet [Ransomware]: dragnet-ransomware-2022-1278 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 806145bf-e12e-5c7e-a439-627a22ccc96a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
