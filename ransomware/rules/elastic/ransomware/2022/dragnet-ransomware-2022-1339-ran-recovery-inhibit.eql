// Dragnet [Ransomware]: dragnet-ransomware-2022-1339 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 44c881b6-f1fd-5432-88e0-bf1406f7c68e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
