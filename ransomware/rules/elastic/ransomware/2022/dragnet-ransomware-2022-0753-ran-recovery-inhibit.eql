// Dragnet [Ransomware]: dragnet-ransomware-2022-0753 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 078a19e1-89b2-5b1d-932c-8295943e816f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
