// Dragnet [Ransomware]: dragnet-ransomware-2022-0333 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a0b9ecc7-5cac-5463-8f5d-7b156f87bf08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
