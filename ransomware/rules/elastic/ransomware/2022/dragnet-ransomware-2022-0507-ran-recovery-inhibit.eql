// Dragnet [Ransomware]: dragnet-ransomware-2022-0507 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8baae7f9-a88b-580c-ac86-c5368b62392c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
