// Dragnet [Ransomware]: dragnet-ransomware-2022-1257 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: 38aa4b70-df61-53eb-a5a5-a616342dc1a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
