// Dragnet [Ransomware]: dragnet-ransomware-2022-1561 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 58025508-bfd1-5a15-86f2-6e5851ea81aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
