// Dragnet [Ransomware]: dragnet-ransomware-2022-2012 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 4dd1a143-42d2-52f8-b422-06423e5af42b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
