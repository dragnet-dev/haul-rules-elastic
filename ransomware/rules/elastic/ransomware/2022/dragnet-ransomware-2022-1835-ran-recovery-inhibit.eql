// Dragnet [Ransomware]: dragnet-ransomware-2022-1835 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 4c9fab85-9a18-52b5-93bf-502c1012083f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
