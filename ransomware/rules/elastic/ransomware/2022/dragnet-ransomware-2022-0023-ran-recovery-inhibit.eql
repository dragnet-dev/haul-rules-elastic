// Dragnet [Ransomware]: dragnet-ransomware-2022-0023 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 75dbda54-64a5-5848-bcdb-785f3ee82912

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
