// Dragnet [Ransomware]: dragnet-ransomware-2022-1753 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 90de1a25-7565-5508-b8de-e829b378a80d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
