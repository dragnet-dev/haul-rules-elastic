// Dragnet [Ransomware]: dragnet-ransomware-2022-0530 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: c41147ce-66ea-5f95-9146-a4de8fcf89bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
