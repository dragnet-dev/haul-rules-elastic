// Dragnet [Ransomware]: dragnet-ransomware-2022-0665 — Recovery Inhibition (freecivilian)
// Status: deprecated | Level: high | ID: 73ee548a-22f6-59e2-a0c8-fde2e74b58b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
