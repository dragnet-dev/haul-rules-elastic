// Dragnet [Ransomware]: dragnet-ransomware-2022-1022 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: dc06bf4c-f2ae-52da-aa09-e033860f9335

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
