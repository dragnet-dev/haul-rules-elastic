// Dragnet [Ransomware]: dragnet-ransomware-2022-2748 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 10a2492c-f6ab-5c6f-8073-63852b202ca9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
