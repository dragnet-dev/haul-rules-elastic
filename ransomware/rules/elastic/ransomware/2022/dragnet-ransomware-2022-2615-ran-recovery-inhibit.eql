// Dragnet [Ransomware]: dragnet-ransomware-2022-2615 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: 6d5de9c2-ef3d-57ec-b2a2-f59e8f5f2ef8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
