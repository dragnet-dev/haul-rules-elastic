// Dragnet [Ransomware]: dragnet-ransomware-2022-0156 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: ed9920f8-20a8-5161-b91d-b68b661d0e5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
