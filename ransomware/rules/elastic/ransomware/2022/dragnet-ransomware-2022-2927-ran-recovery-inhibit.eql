// Dragnet [Ransomware]: dragnet-ransomware-2022-2927 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 58bdf057-09fe-504a-8f68-6ffff9cb5d63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
