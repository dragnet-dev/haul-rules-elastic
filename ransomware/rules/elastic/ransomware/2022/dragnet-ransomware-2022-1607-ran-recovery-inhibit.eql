// Dragnet [Ransomware]: dragnet-ransomware-2022-1607 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 1619d944-4bc7-5a21-88a6-e5726d8a51d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
