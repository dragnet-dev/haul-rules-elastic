// Dragnet [Ransomware]: dragnet-ransomware-2022-0544 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 25e9ec42-8d06-5d3c-a8c3-72ab081913e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
