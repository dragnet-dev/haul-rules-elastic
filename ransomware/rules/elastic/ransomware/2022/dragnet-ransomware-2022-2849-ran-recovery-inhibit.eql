// Dragnet [Ransomware]: dragnet-ransomware-2022-2849 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 51e4bdde-695e-50be-a781-337823eee88a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
