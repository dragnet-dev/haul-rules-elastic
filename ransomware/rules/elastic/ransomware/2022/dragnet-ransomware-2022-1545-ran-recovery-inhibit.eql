// Dragnet [Ransomware]: dragnet-ransomware-2022-1545 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 3de01c7e-53d3-54f4-9bdc-95676a3565ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
