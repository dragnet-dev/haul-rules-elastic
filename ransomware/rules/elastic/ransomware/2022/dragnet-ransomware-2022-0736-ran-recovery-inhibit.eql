// Dragnet [Ransomware]: dragnet-ransomware-2022-0736 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 10d83d39-6018-580f-9c18-8766c5a9d566

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
