// Dragnet [Ransomware]: dragnet-ransomware-2022-1964 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 740c97a5-2e0c-5aa4-9433-907ce30dac0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
