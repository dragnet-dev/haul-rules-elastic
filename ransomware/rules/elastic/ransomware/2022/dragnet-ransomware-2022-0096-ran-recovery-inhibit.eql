// Dragnet [Ransomware]: dragnet-ransomware-2022-0096 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3c743138-4c30-5ae1-b8b9-05e1156dcfc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
