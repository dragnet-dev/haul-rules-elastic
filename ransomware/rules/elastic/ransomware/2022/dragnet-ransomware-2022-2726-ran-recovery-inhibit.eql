// Dragnet [Ransomware]: dragnet-ransomware-2022-2726 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: deb54f6e-5d3d-52ab-917e-abe62809adb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
