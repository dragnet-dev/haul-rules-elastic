// Dragnet [Ransomware]: dragnet-ransomware-2022-0078 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 68d1feba-7913-5b7e-aa9a-c6fd22dc638a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
