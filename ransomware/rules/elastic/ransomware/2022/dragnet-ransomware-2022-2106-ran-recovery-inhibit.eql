// Dragnet [Ransomware]: dragnet-ransomware-2022-2106 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 617336f1-ef52-57c8-84b3-cac53de90869

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
