// Dragnet [Ransomware]: dragnet-ransomware-2022-0881 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8a7dcd6b-e7b9-5be1-9b12-0cc657003e3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
