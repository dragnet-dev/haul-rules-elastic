// Dragnet [Ransomware]: dragnet-ransomware-2022-2661 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f023898d-8782-5699-af2d-a1d708331170

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
