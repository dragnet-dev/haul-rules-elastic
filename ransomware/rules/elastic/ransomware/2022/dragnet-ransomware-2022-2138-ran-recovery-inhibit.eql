// Dragnet [Ransomware]: dragnet-ransomware-2022-2138 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ecec7724-559e-50a2-bdaa-d64bdc4aba11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
