// Dragnet [Ransomware]: dragnet-ransomware-2022-2024 — Recovery Inhibition (leaktheanalyst)
// Status: deprecated | Level: high | ID: 2090404e-93ab-5a0f-982f-f35ecb41e07b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
