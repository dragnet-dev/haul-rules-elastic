// Dragnet [Ransomware]: dragnet-ransomware-2022-0572 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 97ec77cc-7597-5775-a520-8fd1eedc165f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
