// Dragnet [Ransomware]: dragnet-ransomware-2022-2951 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 0512a6db-179e-5f80-8933-dfac8304e1be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
