// Dragnet [Ransomware]: dragnet-ransomware-2022-2195 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 00b85d63-9da7-5bd5-8c67-78b30dbef6a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
