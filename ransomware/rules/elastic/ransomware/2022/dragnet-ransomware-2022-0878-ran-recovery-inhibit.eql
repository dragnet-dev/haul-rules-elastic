// Dragnet [Ransomware]: dragnet-ransomware-2022-0878 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: eec0c45d-7419-55ad-9d50-6d07712eeb6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
