// Dragnet [Ransomware]: dragnet-ransomware-2022-0161 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: ca4777a0-5639-5b29-8da2-1348a5c00f32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
