// Dragnet [Ransomware]: dragnet-ransomware-2022-0296 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 6a5f991d-fe3b-57cf-9447-f19acfd1d078

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
