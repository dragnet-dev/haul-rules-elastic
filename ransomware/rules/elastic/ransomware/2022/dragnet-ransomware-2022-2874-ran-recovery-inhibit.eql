// Dragnet [Ransomware]: dragnet-ransomware-2022-2874 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 7468908e-6d80-5859-b8f3-5eddaa85b971

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
