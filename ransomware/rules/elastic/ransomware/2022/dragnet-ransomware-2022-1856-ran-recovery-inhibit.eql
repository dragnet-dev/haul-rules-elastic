// Dragnet [Ransomware]: dragnet-ransomware-2022-1856 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: d8814a07-595b-5d6f-9a41-e3285bbfb8c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
