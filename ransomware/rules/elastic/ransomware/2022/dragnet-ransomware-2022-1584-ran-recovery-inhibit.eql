// Dragnet [Ransomware]: dragnet-ransomware-2022-1584 — Recovery Inhibition (medusalocker)
// Status: deprecated | Level: high | ID: 5019203f-f1a7-54e0-852e-ff011d3ad95f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
