// Dragnet [Ransomware]: dragnet-ransomware-2022-0309 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: a2a54f2a-b42b-55c9-a56b-5c90aebef347

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
