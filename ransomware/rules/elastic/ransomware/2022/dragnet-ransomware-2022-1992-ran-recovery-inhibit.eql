// Dragnet [Ransomware]: dragnet-ransomware-2022-1992 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: ce8ca97a-8a7e-5ee8-820f-913333c69512

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
