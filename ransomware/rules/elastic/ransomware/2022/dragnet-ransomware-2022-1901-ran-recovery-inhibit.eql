// Dragnet [Ransomware]: dragnet-ransomware-2022-1901 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 24c4de23-967e-52a5-a776-24af171543f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
