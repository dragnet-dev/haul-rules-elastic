// Dragnet [Ransomware]: dragnet-ransomware-2022-0675 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: dea8a232-f5e0-5cba-917d-fe1ad846b955

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
