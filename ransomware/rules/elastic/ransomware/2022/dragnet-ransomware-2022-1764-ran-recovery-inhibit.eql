// Dragnet [Ransomware]: dragnet-ransomware-2022-1764 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 1a5bd04f-95e0-5392-b4cf-f0a1ca15fb1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
