// Dragnet [Ransomware]: dragnet-ransomware-2022-1592 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ed804ac1-44b2-5d5e-a248-42c99197362c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
