// Dragnet [Ransomware]: dragnet-ransomware-2022-0618 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 57549742-578c-5e63-b912-8f1490022c94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
