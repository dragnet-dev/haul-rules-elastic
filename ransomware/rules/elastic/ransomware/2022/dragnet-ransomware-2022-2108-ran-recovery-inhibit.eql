// Dragnet [Ransomware]: dragnet-ransomware-2022-2108 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 4eb02669-d215-56c8-a389-0275610ec66e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
