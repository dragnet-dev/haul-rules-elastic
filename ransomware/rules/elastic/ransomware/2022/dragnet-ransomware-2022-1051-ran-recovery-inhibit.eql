// Dragnet [Ransomware]: dragnet-ransomware-2022-1051 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 4db0c23a-d685-5edd-97d1-1a10de9a8e67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
