// Dragnet [Ransomware]: dragnet-ransomware-2022-3147 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 532f81a3-e52d-5842-9f68-136280914d59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
