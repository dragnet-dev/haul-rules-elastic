// Dragnet [Ransomware]: dragnet-ransomware-2022-1756 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 300ad0b5-2a39-5c44-9eb8-0899b5584475

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
