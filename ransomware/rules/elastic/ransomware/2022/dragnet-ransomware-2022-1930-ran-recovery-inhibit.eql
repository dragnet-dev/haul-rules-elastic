// Dragnet [Ransomware]: dragnet-ransomware-2022-1930 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 08ab176f-a718-5ced-ae80-4d9f37261087

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
