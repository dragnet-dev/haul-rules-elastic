// Dragnet [Ransomware]: dragnet-ransomware-2022-0342 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 459cf559-8bc4-5127-a291-cc0794d053c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
