// Dragnet [Ransomware]: dragnet-ransomware-2022-2174 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 8cad10be-9012-51b0-8355-41b7ca9f21c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
