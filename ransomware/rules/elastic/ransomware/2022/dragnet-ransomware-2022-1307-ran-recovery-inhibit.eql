// Dragnet [Ransomware]: dragnet-ransomware-2022-1307 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 9bed3957-32b9-547e-b167-ea273252fa76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
