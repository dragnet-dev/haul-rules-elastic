// Dragnet [Ransomware]: dragnet-ransomware-2022-2610 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a28ef061-78eb-56bf-b67a-d1c69c87f445

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
