// Dragnet [Ransomware]: dragnet-ransomware-2022-2565 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5d4e5091-93d5-58b1-84bd-2bae12a68c9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
