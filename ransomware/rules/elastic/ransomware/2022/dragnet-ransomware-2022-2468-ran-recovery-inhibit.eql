// Dragnet [Ransomware]: dragnet-ransomware-2022-2468 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 86fecfaa-a665-5ac5-95dc-0c99a6f74a2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
