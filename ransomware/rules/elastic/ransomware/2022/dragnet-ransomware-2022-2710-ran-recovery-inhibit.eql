// Dragnet [Ransomware]: dragnet-ransomware-2022-2710 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: f3f43597-f9a9-573b-a44f-e664d1478b1f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
