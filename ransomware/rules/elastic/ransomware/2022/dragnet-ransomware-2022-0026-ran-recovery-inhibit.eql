// Dragnet [Ransomware]: dragnet-ransomware-2022-0026 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: f158fd9a-243d-5e9a-b42c-d5a875c4ba0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
