// Dragnet [Ransomware]: dragnet-ransomware-2022-1768 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: bdf56b8f-5ce4-56cb-8b7e-d1204f5e20b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
