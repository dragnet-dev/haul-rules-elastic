// Dragnet [Ransomware]: dragnet-ransomware-2022-1514 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 58e29578-19dd-5b91-a61a-02fdff30dc0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
