// Dragnet [Ransomware]: dragnet-ransomware-2022-1704 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: d4e57e1e-b3d9-5e00-b7b3-69ba42e92fee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
