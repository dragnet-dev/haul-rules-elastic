// Dragnet [Ransomware]: dragnet-ransomware-2022-2757 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: fdc862cb-3040-5951-9e81-45399fb86dc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
