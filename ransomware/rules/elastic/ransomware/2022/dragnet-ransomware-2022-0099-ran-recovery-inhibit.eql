// Dragnet [Ransomware]: dragnet-ransomware-2022-0099 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: 8e8bafd7-0ce3-5fe9-aa63-9da123fc33b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
