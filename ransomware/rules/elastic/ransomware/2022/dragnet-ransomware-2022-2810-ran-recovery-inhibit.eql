// Dragnet [Ransomware]: dragnet-ransomware-2022-2810 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: b976613d-c041-5380-a109-aa9250844997

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
