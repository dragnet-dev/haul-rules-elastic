// Dragnet [Ransomware]: dragnet-ransomware-2022-0963 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: eaffd064-befa-57b0-b96b-e2b7097d896c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
