// Dragnet [Ransomware]: dragnet-ransomware-2022-2109 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 1b600c5b-c9a0-5834-a54f-34abb6f745f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
