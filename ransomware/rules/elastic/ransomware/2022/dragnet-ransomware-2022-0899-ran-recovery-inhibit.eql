// Dragnet [Ransomware]: dragnet-ransomware-2022-0899 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 08d0337b-52e5-5adf-a540-28278d0bb0b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
