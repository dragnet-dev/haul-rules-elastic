// Dragnet [Ransomware]: dragnet-ransomware-2022-3088 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 17dc5df2-f570-53df-b45b-fd92b94d605b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
