// Dragnet [Ransomware]: dragnet-ransomware-2022-0767 — Recovery Inhibition (leaktheanalyst)
// Status: deprecated | Level: high | ID: d900b8d8-9edf-5b7b-a35d-82ea198442a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
