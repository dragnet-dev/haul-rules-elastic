// Dragnet [Ransomware]: dragnet-ransomware-2022-1171 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a679be14-227b-5f9f-9f7c-075a38e0c06e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
