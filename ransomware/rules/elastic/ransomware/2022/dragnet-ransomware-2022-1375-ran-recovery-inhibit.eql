// Dragnet [Ransomware]: dragnet-ransomware-2022-1375 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 98334694-e499-50fa-b2f6-8561912826df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
