// Dragnet [Ransomware]: dragnet-ransomware-2022-1400 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 290afbd9-f99d-53fe-8473-3305aa5c6464

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
