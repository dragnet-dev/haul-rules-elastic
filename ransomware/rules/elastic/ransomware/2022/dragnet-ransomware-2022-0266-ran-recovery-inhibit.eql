// Dragnet [Ransomware]: dragnet-ransomware-2022-0266 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 60393bd3-c337-585f-8415-0169bd8f4209

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
