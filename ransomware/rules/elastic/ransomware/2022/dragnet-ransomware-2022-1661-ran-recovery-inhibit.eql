// Dragnet [Ransomware]: dragnet-ransomware-2022-1661 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: f3ba0e01-e117-5f67-8472-e39a743b742f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
