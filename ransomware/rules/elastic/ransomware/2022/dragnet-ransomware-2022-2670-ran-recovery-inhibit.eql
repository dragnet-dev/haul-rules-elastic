// Dragnet [Ransomware]: dragnet-ransomware-2022-2670 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 0e32385c-6d67-5ac7-bb94-45d177f51177

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
