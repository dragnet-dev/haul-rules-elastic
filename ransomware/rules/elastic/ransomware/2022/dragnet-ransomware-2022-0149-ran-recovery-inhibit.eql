// Dragnet [Ransomware]: dragnet-ransomware-2022-0149 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 15b2f1ad-fd37-537d-9c09-26227255f539

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
