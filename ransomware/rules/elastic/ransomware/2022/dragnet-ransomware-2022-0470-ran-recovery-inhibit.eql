// Dragnet [Ransomware]: dragnet-ransomware-2022-0470 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 9e44d2f5-d8e8-5839-817a-bd744d5e4b9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
