// Dragnet [Ransomware]: dragnet-ransomware-2022-2424 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 38903515-407e-54a1-864b-1fde8c04e1e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
