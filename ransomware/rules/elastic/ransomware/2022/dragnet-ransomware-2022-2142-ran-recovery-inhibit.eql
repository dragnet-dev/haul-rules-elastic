// Dragnet [Ransomware]: dragnet-ransomware-2022-2142 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 7e3ad60c-6a1d-5b3f-85bc-964f24398781

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
