// Dragnet [Ransomware]: dragnet-ransomware-2022-1429 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 77d76fd9-f9d1-5860-a303-50807e0f1b24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
