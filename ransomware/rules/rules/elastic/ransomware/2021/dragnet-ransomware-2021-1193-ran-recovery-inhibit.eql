// Dragnet [Ransomware]: dragnet-ransomware-2021-1193 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 1f2ec3ae-6c5b-5b2a-9e91-a25bc6bd8130

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
