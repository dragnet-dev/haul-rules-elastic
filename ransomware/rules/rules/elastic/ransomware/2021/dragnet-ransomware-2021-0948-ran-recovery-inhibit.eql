// Dragnet [Ransomware]: dragnet-ransomware-2021-0948 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: bd2f6326-7c46-531f-801c-ecb7e8cc2edd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
