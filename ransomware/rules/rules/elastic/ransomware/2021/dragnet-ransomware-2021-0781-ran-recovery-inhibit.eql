// Dragnet [Ransomware]: dragnet-ransomware-2021-0781 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 2bd151a4-b252-58a5-90b3-b7acc752a449

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
