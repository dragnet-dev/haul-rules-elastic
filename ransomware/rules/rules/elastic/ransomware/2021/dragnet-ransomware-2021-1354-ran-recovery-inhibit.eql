// Dragnet [Ransomware]: dragnet-ransomware-2021-1354 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 13c37ac3-dab9-54cc-addb-6b7044d88c28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
