// Dragnet [Ransomware]: dragnet-ransomware-2021-0885 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 04a1dbc2-7221-5045-8e1e-5ea03d13f908

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
