// Dragnet [Ransomware]: dragnet-ransomware-2021-0246 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5041f969-e57b-540e-96fa-61b2b56f38cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
