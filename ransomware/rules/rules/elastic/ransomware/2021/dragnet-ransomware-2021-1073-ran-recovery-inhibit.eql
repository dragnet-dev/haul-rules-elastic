// Dragnet [Ransomware]: dragnet-ransomware-2021-1073 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 7947c530-1d89-5dfe-b1a3-fdf3f783e526

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
