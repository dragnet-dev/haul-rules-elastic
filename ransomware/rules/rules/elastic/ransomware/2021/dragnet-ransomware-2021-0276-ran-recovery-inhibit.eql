// Dragnet [Ransomware]: dragnet-ransomware-2021-0276 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: a375b213-4878-533d-8b70-1f60acb7f15d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
