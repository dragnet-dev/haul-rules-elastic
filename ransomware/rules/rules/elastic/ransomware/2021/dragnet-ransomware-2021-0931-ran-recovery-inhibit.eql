// Dragnet [Ransomware]: dragnet-ransomware-2021-0931 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 490d7151-67ac-5a0d-afc0-16199fe51350

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
