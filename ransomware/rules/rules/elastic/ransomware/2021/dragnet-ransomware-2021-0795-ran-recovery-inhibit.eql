// Dragnet [Ransomware]: dragnet-ransomware-2021-0795 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 94ba9f82-c707-5748-b674-5fdd2baa9141

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
