// Dragnet [Ransomware]: dragnet-ransomware-2021-0602 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5f1e5350-ece8-5291-8ee8-1766533fee03

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
