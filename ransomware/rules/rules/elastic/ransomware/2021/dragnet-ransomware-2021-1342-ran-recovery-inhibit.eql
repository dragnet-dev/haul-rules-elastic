// Dragnet [Ransomware]: dragnet-ransomware-2021-1342 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b3e25dd2-6770-5e15-86a7-bc161894ea4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
