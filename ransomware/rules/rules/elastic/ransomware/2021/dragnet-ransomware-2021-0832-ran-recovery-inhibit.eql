// Dragnet [Ransomware]: dragnet-ransomware-2021-0832 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: cf79dcb6-09cf-5eb3-926d-dc8cc620edfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
