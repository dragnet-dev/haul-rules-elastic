// Dragnet [Ransomware]: dragnet-ransomware-2021-0096 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: fad7b149-29c9-5dec-b778-943919debab6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
