// Dragnet [Ransomware]: dragnet-ransomware-2021-1803 — Recovery Inhibition (cryp70n1c0d3)
// Status: deprecated | Level: high | ID: 9c252397-4015-564e-af62-3bbc984a0f35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
