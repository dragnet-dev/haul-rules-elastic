// Dragnet [Ransomware]: dragnet-ransomware-2021-1534 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: 77ab24e9-0900-5a14-9354-009effb16542

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
