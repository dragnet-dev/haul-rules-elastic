// Dragnet [Ransomware]: dragnet-ransomware-2021-0329 — Recovery Inhibition (payloadbin)
// Status: deprecated | Level: high | ID: d4bc0c1a-3ec4-5bff-9491-7d3aeda52de2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
