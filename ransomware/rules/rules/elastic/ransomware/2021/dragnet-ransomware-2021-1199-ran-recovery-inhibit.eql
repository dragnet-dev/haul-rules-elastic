// Dragnet [Ransomware]: dragnet-ransomware-2021-1199 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 1587d076-8975-56db-ae4c-774826386fbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
