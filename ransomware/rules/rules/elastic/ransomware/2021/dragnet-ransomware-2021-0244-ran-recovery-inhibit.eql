// Dragnet [Ransomware]: dragnet-ransomware-2021-0244 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 402e970d-d7c2-5e7c-95d7-70624fe523de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
