// Dragnet [Ransomware]: dragnet-ransomware-2021-0955 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 3c51b45e-9936-55c7-adb7-ec5676a73f87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
