// Dragnet [Ransomware]: dragnet-ransomware-2021-0236 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6b9239df-23a6-543f-bb1a-9aee657a2036

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
