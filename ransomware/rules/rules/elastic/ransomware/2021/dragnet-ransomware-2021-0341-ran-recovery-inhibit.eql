// Dragnet [Ransomware]: dragnet-ransomware-2021-0341 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e75a78da-8d99-561a-abf3-99711d5b6bc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
