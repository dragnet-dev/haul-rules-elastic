// Dragnet [Ransomware]: dragnet-ransomware-2021-0156 — Recovery Inhibition (lockdata)
// Status: deprecated | Level: high | ID: 9a4ab590-4efe-5896-b295-3f6be5b884f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
