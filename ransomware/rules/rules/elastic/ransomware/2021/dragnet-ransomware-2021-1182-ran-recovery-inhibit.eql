// Dragnet [Ransomware]: dragnet-ransomware-2021-1182 — Recovery Inhibition (azroteam)
// Status: deprecated | Level: high | ID: a7764da8-e827-5fc0-bb94-0d87a55db52e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
