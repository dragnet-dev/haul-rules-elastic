// Dragnet [Ransomware]: dragnet-ransomware-2021-1557 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 7456f423-c953-5a32-8833-06f8662d93f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
