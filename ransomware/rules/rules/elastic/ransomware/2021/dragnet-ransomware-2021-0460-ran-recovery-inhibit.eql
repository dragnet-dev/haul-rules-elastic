// Dragnet [Ransomware]: dragnet-ransomware-2021-0460 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a0954d76-6736-5d7f-8757-ca493c491a6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
