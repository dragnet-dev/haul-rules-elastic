// Dragnet [Ransomware]: dragnet-ransomware-2021-1592 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 5aaaaa59-c755-5c04-b4ad-eab54b55a0cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
