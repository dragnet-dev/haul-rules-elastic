// Dragnet [Ransomware]: dragnet-ransomware-2021-0181 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 26cdafb4-0654-5d2a-a53d-16f8e08ff45d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
