// Dragnet [Ransomware]: dragnet-ransomware-2021-0655 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 2a15d697-fc3a-5229-87aa-084a5a82b663

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
