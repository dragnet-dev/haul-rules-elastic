// Dragnet [Ransomware]: dragnet-ransomware-2021-1136 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: e02a4712-9242-5fec-8f5d-ddcd680fdc4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
