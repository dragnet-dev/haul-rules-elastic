// Dragnet [Ransomware]: dragnet-ransomware-2021-0213 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: a55a9ad2-0213-5e0a-8fbe-6eaa1afcd6c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
