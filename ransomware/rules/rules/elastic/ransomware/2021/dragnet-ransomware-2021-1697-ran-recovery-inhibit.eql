// Dragnet [Ransomware]: dragnet-ransomware-2021-1697 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ff916163-3fdb-576e-a1cb-87810d849619

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
