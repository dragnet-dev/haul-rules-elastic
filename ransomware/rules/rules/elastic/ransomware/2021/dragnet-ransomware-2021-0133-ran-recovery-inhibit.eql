// Dragnet [Ransomware]: dragnet-ransomware-2021-0133 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 3c45aca9-ca86-52a9-86e8-4b22d9b5c005

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
