// Dragnet [Ransomware]: dragnet-ransomware-2021-1163 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: b52c29b8-b54b-5164-890b-b362c3575e13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
