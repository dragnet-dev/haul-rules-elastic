// Dragnet [Ransomware]: dragnet-ransomware-2021-0957 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: c4c31ccb-5e7d-5f84-822f-eaa87565895f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
