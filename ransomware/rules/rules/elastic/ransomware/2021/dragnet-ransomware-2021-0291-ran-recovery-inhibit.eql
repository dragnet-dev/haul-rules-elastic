// Dragnet [Ransomware]: dragnet-ransomware-2021-0291 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: aa8c9885-d5c9-5d25-bbd6-41a6ebeee7e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
