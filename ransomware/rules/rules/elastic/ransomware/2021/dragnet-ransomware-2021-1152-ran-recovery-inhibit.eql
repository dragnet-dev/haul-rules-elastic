// Dragnet [Ransomware]: dragnet-ransomware-2021-1152 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 91935f27-258a-56e0-a172-3ccd7a0dccc0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
