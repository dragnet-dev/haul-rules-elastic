// Dragnet [Ransomware]: dragnet-ransomware-2021-1635 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: a2bfe1f8-bb00-5839-b764-c201dbd92b87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
