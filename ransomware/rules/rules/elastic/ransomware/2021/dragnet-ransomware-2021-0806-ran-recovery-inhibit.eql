// Dragnet [Ransomware]: dragnet-ransomware-2021-0806 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 3264562e-6b42-57fe-98e6-185916b258b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
