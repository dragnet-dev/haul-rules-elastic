// Dragnet [Ransomware]: dragnet-ransomware-2021-1537 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: da381afe-8c2c-5312-946f-035c496c3784

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
