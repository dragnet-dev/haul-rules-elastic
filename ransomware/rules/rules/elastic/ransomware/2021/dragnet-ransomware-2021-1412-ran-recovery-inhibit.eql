// Dragnet [Ransomware]: dragnet-ransomware-2021-1412 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: e61d1169-8ee6-5b90-b0a8-0d5eb2ba8124

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
