// Dragnet [Ransomware]: dragnet-ransomware-2021-1019 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 40e0aa38-1e53-5be2-9637-56b39d28e5a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
