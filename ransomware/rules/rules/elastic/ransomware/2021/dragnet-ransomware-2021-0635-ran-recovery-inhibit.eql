// Dragnet [Ransomware]: dragnet-ransomware-2021-0635 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 76a48665-9fa6-54f9-89e8-0c4e373d1ccb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
