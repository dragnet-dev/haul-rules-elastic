// Dragnet [Ransomware]: dragnet-ransomware-2021-0109 — Recovery Inhibition (cryp70n1c0d3)
// Status: deprecated | Level: high | ID: 3ec31110-01b6-5f56-8076-408c85dfb557

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
