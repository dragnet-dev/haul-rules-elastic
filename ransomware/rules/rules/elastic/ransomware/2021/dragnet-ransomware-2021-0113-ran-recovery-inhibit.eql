// Dragnet [Ransomware]: dragnet-ransomware-2021-0113 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: a560a0d6-1148-5ae3-ae53-28f299f316a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
