// Dragnet [Ransomware]: dragnet-ransomware-2021-1216 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: df04dcba-38fa-5d09-9855-3e383a790259

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
