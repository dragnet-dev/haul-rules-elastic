// Dragnet [Ransomware]: dragnet-ransomware-2021-1775 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f5cc2581-4eaa-5d65-a862-7a683407189c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
