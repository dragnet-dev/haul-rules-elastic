// Dragnet [Ransomware]: dragnet-ransomware-2021-1204 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 2dbb5a54-59ea-5877-9065-b49c267062b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
