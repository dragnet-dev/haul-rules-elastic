// Dragnet [Ransomware]: dragnet-ransomware-2021-0836 — Recovery Inhibition (xinglocker)
// Status: deprecated | Level: high | ID: 3d67a7a6-8eae-52b5-a491-38eb28f16b69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
