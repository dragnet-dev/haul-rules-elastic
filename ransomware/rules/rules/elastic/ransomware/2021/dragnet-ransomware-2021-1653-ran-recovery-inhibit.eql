// Dragnet [Ransomware]: dragnet-ransomware-2021-1653 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 22f1a9d9-ff46-561b-a616-e496c131f467

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
