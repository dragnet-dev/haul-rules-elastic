// Dragnet [Ransomware]: dragnet-ransomware-2021-0549 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 475834f4-fa12-5c20-b289-afc021c5157f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
