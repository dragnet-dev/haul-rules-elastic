// Dragnet [Ransomware]: dragnet-ransomware-2021-1089 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 2d31447d-e180-590f-9cc2-e3ab5bc69537

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
