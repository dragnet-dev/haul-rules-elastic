// Dragnet [Ransomware]: dragnet-ransomware-2021-1617 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 36a73876-384d-558a-82e7-2699a4202c28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
