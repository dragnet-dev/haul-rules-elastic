// Dragnet [Ransomware]: dragnet-ransomware-2021-1120 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e65fba80-a065-5e6c-9f26-33bf22ace67f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
