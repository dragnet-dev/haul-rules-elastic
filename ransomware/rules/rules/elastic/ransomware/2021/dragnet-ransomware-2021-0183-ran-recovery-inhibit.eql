// Dragnet [Ransomware]: dragnet-ransomware-2021-0183 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 6da6c33d-b6fb-5798-9ff4-3feef800127d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
