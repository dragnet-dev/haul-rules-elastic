// Dragnet [Ransomware]: dragnet-ransomware-2021-1006 — Recovery Inhibition (mosesstaff)
// Status: deprecated | Level: high | ID: 54e1978a-f2a3-5533-a3df-f1af39cf9d1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
