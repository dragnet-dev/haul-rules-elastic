// Dragnet [Ransomware]: dragnet-ransomware-2021-1357 — Recovery Inhibition (groove)
// Status: deprecated | Level: high | ID: 65f9c4be-551e-5588-9c47-5a248f7bae2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
