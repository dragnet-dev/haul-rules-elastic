// Dragnet [Ransomware]: dragnet-ransomware-2021-1213 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 0ccbbad4-aaa0-5685-8db3-6d834ac80eec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
