// Dragnet [Ransomware]: dragnet-ransomware-2021-1072 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 568a9733-593d-5666-8805-fe999fafd19a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
