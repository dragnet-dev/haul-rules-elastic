// Dragnet [Ransomware]: dragnet-ransomware-2021-0779 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ac9baf04-a204-5977-9065-ea11ccb5307a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
