// Dragnet [Ransomware]: dragnet-ransomware-2021-1149 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: d30104c4-a83a-5e36-a3eb-1fe642075b7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
