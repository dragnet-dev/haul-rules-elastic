// Dragnet [Ransomware]: dragnet-ransomware-2021-0374 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 2bfbfd33-0d28-58d3-8e82-6f7fb34892d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
