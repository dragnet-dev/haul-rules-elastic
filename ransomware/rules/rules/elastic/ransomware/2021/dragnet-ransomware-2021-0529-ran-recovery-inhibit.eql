// Dragnet [Ransomware]: dragnet-ransomware-2021-0529 — Recovery Inhibition (sabbath)
// Status: deprecated | Level: high | ID: 5d1f918d-226f-5dd7-a18b-d245bfc59fba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
