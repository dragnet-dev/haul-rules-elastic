// Dragnet [Ransomware]: dragnet-ransomware-2021-1214 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 2ea090f4-7f2e-51de-8303-33b13abcbcd1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
