// Dragnet [Ransomware]: dragnet-ransomware-2021-1286 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: 8eae7be5-ac15-53d4-af7d-07829c4c51fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
