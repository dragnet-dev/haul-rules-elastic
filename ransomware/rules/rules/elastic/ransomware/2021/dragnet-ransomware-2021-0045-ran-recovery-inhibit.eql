// Dragnet [Ransomware]: dragnet-ransomware-2021-0045 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: d391e5ae-3d18-54b9-9d52-3f68d5b214fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
