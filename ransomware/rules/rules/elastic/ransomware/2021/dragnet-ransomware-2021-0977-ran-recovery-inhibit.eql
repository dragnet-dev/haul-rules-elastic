// Dragnet [Ransomware]: dragnet-ransomware-2021-0977 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 94b3c664-e955-53b5-ad92-c31ec03c16b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
