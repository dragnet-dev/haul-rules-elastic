// Dragnet [Ransomware]: dragnet-ransomware-2021-0813 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 585ef568-d82f-54ca-af87-f52f62a9e98e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
