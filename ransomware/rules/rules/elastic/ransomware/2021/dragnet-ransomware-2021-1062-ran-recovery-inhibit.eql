// Dragnet [Ransomware]: dragnet-ransomware-2021-1062 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: ac520779-0889-50d9-a8f2-c3962e09ba97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
