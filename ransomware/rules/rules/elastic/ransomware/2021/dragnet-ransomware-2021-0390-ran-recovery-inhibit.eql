// Dragnet [Ransomware]: dragnet-ransomware-2021-0390 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 40be7601-2999-5708-9bb0-a8610bb210f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
