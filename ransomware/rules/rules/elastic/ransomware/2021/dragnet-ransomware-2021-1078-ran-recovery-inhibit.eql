// Dragnet [Ransomware]: dragnet-ransomware-2021-1078 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 57ea4947-5f44-550f-9b3d-4e42ec5cb38e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
