// Dragnet [Ransomware]: dragnet-ransomware-2021-0874 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 80c5fba5-9c78-598a-a229-aa46d230a50c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
