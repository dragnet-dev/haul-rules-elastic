// Dragnet [Ransomware]: dragnet-ransomware-2021-1374 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: a813f19f-f147-5b4c-b036-ebf59cc2920b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
