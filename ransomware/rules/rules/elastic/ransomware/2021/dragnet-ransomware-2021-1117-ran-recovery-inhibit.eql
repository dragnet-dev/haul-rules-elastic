// Dragnet [Ransomware]: dragnet-ransomware-2021-1117 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 6f8e0cca-211c-5e2d-aae5-55b20b7e054b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
