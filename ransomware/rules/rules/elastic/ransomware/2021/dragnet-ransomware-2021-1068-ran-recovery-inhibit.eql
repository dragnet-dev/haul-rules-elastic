// Dragnet [Ransomware]: dragnet-ransomware-2021-1068 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 35141dc2-6b67-5ba7-a4e8-c9b8bf7527fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
