// Dragnet [Ransomware]: dragnet-ransomware-2021-0555 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: efdf42c3-ab4a-5a21-8132-335daaefec39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
