// Dragnet [Ransomware]: dragnet-ransomware-2021-1787 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 7c83d579-0e1c-5aa5-abfc-486b1d44ebb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
