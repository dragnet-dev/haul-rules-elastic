// Dragnet [Ransomware]: dragnet-ransomware-2021-1612 — Recovery Inhibition (doppelpaymer)
// Status: deprecated | Level: high | ID: cc6faef2-01cd-59e1-b044-22708b8fea93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
