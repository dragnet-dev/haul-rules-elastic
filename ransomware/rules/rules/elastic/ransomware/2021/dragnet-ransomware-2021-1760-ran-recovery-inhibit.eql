// Dragnet [Ransomware]: dragnet-ransomware-2021-1760 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ce2e7ec9-7cb3-5bfc-833c-94fcb01fe601

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
