// Dragnet [Ransomware]: dragnet-ransomware-2021-0304 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6fcfe84b-6edb-5b2b-86d4-40ddfc57326b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
