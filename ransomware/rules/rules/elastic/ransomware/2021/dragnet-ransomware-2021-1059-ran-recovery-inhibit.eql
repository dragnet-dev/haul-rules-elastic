// Dragnet [Ransomware]: dragnet-ransomware-2021-1059 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: ebf158a4-646c-5cf8-82c7-56a2392a3330

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
