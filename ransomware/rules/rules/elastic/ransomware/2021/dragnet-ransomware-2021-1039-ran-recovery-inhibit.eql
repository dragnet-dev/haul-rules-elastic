// Dragnet [Ransomware]: dragnet-ransomware-2021-1039 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: e03aa5db-b38c-5a3c-8b60-cc8d2de7d87f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
