// Dragnet [Ransomware]: dragnet-ransomware-2021-0695 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: cb5c78a1-393c-58d3-824f-2cd6bc6e8396

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
