// Dragnet [Ransomware]: dragnet-ransomware-2021-1341 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: dbdbfee0-c8a3-5ca4-8955-3d8bfb930cd7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
