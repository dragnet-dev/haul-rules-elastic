// Dragnet [Ransomware]: dragnet-ransomware-2021-0502 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 7b2a011b-51c0-5bc3-9070-0fe04304a9ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
