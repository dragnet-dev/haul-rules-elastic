// Dragnet [Ransomware]: dragnet-ransomware-2021-1595 — Recovery Inhibition (darkside)
// Status: deprecated | Level: high | ID: 8327aba8-71e2-5793-9ac6-a91b380a9775

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
