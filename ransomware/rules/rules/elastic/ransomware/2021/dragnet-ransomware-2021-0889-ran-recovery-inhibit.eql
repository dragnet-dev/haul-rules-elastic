// Dragnet [Ransomware]: dragnet-ransomware-2021-0889 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8e1f99af-667c-514d-9193-03aa00d20949

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
