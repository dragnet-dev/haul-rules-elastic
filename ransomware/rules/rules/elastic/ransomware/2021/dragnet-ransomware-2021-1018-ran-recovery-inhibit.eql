// Dragnet [Ransomware]: dragnet-ransomware-2021-1018 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: fb62ee00-5e12-53a3-9a4e-ff29d5fbdc34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
