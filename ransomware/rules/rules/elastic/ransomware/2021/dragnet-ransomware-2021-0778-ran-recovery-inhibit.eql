// Dragnet [Ransomware]: dragnet-ransomware-2021-0778 — Recovery Inhibition (payloadbin)
// Status: deprecated | Level: high | ID: 19520cc5-2d38-5580-b12f-7a4836558f05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
