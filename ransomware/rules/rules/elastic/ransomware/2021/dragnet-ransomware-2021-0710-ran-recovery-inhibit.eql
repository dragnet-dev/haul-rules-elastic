// Dragnet [Ransomware]: dragnet-ransomware-2021-0710 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: b7b24d24-cef8-526e-8d17-e041c07c982a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
