// Dragnet [Ransomware]: dragnet-ransomware-2021-1599 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: a63fda84-44be-5aeb-8ddc-c8ac37f7c238

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
