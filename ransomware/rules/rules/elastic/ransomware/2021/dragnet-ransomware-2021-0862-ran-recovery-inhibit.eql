// Dragnet [Ransomware]: dragnet-ransomware-2021-0862 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 3c2ac31b-8854-507f-9c67-9725bf8c7031

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
