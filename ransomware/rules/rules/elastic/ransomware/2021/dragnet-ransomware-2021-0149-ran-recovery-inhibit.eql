// Dragnet [Ransomware]: dragnet-ransomware-2021-0149 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: f8523cbd-2442-5f63-adbf-73effe55a4ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
