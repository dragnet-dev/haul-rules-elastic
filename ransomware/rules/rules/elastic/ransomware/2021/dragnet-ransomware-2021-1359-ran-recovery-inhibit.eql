// Dragnet [Ransomware]: dragnet-ransomware-2021-1359 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: f18b868b-0ca6-597b-a15a-b8692d5ad975

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
