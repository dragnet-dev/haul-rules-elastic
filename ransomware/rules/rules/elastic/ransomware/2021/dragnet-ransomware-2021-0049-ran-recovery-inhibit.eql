// Dragnet [Ransomware]: dragnet-ransomware-2021-0049 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d2e7cfdd-1295-5eb9-a3aa-ec9cb4ffad06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
