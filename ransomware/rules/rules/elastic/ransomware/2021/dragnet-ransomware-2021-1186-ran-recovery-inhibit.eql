// Dragnet [Ransomware]: dragnet-ransomware-2021-1186 — Recovery Inhibition (azroteam)
// Status: deprecated | Level: high | ID: cb074ca2-6381-54e2-9644-ed5a417def24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
