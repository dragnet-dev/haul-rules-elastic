// Dragnet [Ransomware]: dragnet-ransomware-2021-1160 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: b6767cf7-33c4-53bf-b914-39bfb9a857f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
