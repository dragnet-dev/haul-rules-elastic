// Dragnet [Ransomware]: dragnet-ransomware-2021-0318 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 743cbe54-be2f-5eae-9b2d-4a52b142546e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
