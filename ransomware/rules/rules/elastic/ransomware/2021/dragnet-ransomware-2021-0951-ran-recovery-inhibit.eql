// Dragnet [Ransomware]: dragnet-ransomware-2021-0951 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: cbf89db1-1677-554a-ab62-4d8af434278f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
