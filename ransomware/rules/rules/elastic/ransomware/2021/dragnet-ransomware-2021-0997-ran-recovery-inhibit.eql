// Dragnet [Ransomware]: dragnet-ransomware-2021-0997 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: a58ef644-bc06-5bd3-b4bd-1c02660a1126

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
