// Dragnet [Ransomware]: dragnet-ransomware-2021-0949 — Recovery Inhibition (doppelpaymer)
// Status: deprecated | Level: high | ID: 443abf99-ceee-5240-a8d3-e65942afad70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
