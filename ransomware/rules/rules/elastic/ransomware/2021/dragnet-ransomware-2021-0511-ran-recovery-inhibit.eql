// Dragnet [Ransomware]: dragnet-ransomware-2021-0511 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: f6a4791d-c11b-5410-abbd-b5f430bd1a8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
