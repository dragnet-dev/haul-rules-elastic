// Dragnet [Ransomware]: dragnet-ransomware-2021-1535 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5e1ea430-4082-545a-a490-b64f63e6b76a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
