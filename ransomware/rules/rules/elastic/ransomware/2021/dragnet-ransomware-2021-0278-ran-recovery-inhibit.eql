// Dragnet [Ransomware]: dragnet-ransomware-2021-0278 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 390dad70-95dc-5bd5-9741-51a6c5e6862a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
