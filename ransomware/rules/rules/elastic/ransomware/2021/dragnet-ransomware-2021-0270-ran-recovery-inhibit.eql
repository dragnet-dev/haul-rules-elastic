// Dragnet [Ransomware]: dragnet-ransomware-2021-0270 — Recovery Inhibition (bonacigroup)
// Status: deprecated | Level: high | ID: 159738b7-84f1-5cf1-90c9-f536fd505af8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
