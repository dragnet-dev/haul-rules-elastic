// Dragnet [Ransomware]: dragnet-ransomware-2021-1473 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: df07b5d7-3746-5df4-aef6-02c61c4c8e7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
