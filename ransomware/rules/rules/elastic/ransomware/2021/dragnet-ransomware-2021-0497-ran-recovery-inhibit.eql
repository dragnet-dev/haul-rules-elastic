// Dragnet [Ransomware]: dragnet-ransomware-2021-0497 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: c9b20b17-0619-552c-a71c-a957a36a6acb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
