// Dragnet [Ransomware]: dragnet-ransomware-2021-0289 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: c816723d-8fc8-5bea-9ec0-d7b20825c7ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
