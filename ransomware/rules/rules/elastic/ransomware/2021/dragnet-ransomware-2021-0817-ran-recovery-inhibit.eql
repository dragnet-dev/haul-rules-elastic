// Dragnet [Ransomware]: dragnet-ransomware-2021-0817 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 39fcaae5-f9ee-5f01-9902-1238f036a0b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
