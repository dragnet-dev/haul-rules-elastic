// Dragnet [Ransomware]: dragnet-ransomware-2021-0331 — Recovery Inhibition (karma)
// Status: deprecated | Level: high | ID: 966f3ef2-4fb6-5fe7-ad36-c7c07d9adb38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
