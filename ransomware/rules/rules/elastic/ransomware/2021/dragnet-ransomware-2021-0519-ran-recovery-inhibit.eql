// Dragnet [Ransomware]: dragnet-ransomware-2021-0519 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: f6f7c62d-681c-52d5-bf28-3033f4345ef3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
