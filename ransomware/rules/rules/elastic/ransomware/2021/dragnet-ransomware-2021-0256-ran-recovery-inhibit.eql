// Dragnet [Ransomware]: dragnet-ransomware-2021-0256 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c5ffeb31-8271-5981-bcd9-6e614107b028

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
