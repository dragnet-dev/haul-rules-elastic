// Dragnet [Ransomware]: dragnet-ransomware-2021-1416 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: d3b5d3cf-0c09-50d4-ae5d-2f68550c8036

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
