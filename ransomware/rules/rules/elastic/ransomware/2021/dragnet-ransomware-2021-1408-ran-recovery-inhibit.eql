// Dragnet [Ransomware]: dragnet-ransomware-2021-1408 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: c417d7b6-2e9a-5afb-a240-4a451f30b738

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
