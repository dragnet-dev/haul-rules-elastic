// Dragnet [Ransomware]: dragnet-ransomware-2021-0431 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 38d024fa-e282-5bff-a948-c9ae60208062

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
