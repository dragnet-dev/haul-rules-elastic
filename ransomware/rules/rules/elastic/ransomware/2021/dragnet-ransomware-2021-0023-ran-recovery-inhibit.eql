// Dragnet [Ransomware]: dragnet-ransomware-2021-0023 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: e0586e7a-ee52-5db7-a08d-172c759e5341

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
