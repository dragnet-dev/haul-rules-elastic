// Dragnet [Ransomware]: dragnet-ransomware-2021-1081 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4cff644c-6ccc-5de8-9d52-55e0549b1eee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
