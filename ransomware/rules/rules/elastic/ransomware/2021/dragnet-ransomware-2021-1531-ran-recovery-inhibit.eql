// Dragnet [Ransomware]: dragnet-ransomware-2021-1531 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a425611b-1d7a-5e09-9877-dec08210b0cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
