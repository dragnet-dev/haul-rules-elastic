// Dragnet [Ransomware]: dragnet-ransomware-2021-0479 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: 7a8ecdef-d2ed-56a5-81e2-439914d870e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
