// Dragnet [Ransomware]: dragnet-ransomware-2021-0265 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6928631c-f697-5efc-a772-feb86ca83ca8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
