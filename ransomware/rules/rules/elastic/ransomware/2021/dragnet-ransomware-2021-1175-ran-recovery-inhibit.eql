// Dragnet [Ransomware]: dragnet-ransomware-2021-1175 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: be87bc13-76e9-5ca2-9095-82c8a3c18c08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
