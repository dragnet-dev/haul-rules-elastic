// Dragnet [Ransomware]: dragnet-ransomware-2021-1511 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 65d967dc-8056-5582-8b70-ed86a1497494

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
