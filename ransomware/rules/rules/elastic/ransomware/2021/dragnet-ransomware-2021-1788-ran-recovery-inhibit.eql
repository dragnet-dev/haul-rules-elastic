// Dragnet [Ransomware]: dragnet-ransomware-2021-1788 — Recovery Inhibition (egregor)
// Status: deprecated | Level: high | ID: 4906c35a-61cc-55c1-a948-f5af9719efe8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
