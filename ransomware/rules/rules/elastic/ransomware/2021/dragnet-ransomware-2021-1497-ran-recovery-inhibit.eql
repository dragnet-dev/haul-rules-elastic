// Dragnet [Ransomware]: dragnet-ransomware-2021-1497 — Recovery Inhibition (payloadbin)
// Status: deprecated | Level: high | ID: bc122e5d-edf0-5ae9-9a46-76158aac2e82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
