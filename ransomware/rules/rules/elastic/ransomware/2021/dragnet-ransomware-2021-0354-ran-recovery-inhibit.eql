// Dragnet [Ransomware]: dragnet-ransomware-2021-0354 — Recovery Inhibition (xinglocker)
// Status: deprecated | Level: high | ID: 1729ecc8-95cb-511c-a779-979da773a2b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
