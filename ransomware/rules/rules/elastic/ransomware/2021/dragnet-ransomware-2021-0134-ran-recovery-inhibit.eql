// Dragnet [Ransomware]: dragnet-ransomware-2021-0134 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 137e46e4-83a8-5662-9033-c29366d766a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
