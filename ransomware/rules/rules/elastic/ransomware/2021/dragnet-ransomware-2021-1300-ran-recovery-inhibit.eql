// Dragnet [Ransomware]: dragnet-ransomware-2021-1300 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 14f34edd-c3c8-5589-bb85-cfe7d0ed5508

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
