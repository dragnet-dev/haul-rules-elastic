// Dragnet [Ransomware]: dragnet-ransomware-2021-1663 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 15244bfd-7a81-542b-8923-60271fda9db1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
