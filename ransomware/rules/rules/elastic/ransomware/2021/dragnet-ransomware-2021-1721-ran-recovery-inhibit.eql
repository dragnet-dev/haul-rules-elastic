// Dragnet [Ransomware]: dragnet-ransomware-2021-1721 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 139d61ea-282e-5eac-95a1-06f14ac02ae9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
