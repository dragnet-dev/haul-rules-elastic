// Dragnet [Ransomware]: dragnet-ransomware-2021-1138 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 90d59a11-fd72-5b34-8099-afd14128da85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
