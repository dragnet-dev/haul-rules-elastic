// Dragnet [Ransomware]: dragnet-ransomware-2021-0614 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 77079196-fd4f-5281-9a71-036b4df90945

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
