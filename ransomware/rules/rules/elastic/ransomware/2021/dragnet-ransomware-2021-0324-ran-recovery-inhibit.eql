// Dragnet [Ransomware]: dragnet-ransomware-2021-0324 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: c6d5b662-d888-509d-8bc2-08c4d379e869

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
