// Dragnet [Ransomware]: dragnet-ransomware-2021-1742 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: f5c3ae8a-e1df-5991-9462-58794ab95131

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
