// Dragnet [Ransomware]: dragnet-ransomware-2021-1597 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 66fae5be-eeeb-5c65-a8af-512188a2db60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
