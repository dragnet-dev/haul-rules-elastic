// Dragnet [Ransomware]: dragnet-ransomware-2021-1747 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 921af3d8-c3d5-5407-ac90-9e98f21a4f2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
