// Dragnet [Ransomware]: dragnet-ransomware-2021-0394 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 19395a4e-8168-5a58-a36f-7a1a5700e41d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
