// Dragnet [Ransomware]: dragnet-ransomware-2021-0684 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: d3e923b9-d05a-538f-802a-721a3fbb9eb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
