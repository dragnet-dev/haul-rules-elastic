// Dragnet [Ransomware]: dragnet-ransomware-2021-0749 — Recovery Inhibition (xinglocker)
// Status: deprecated | Level: high | ID: 0d367301-8695-5358-b1ad-f7f38eb5e110

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
