// Dragnet [Ransomware]: dragnet-ransomware-2021-0628 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2385e229-6332-55d6-95d4-947df0252e22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
