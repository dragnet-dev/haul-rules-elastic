// Dragnet [Ransomware]: dragnet-ransomware-2021-1548 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 931579b8-76bd-5423-8026-a47bcce965ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
