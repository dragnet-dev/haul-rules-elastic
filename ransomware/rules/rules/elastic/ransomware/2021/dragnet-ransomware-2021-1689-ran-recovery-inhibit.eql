// Dragnet [Ransomware]: dragnet-ransomware-2021-1689 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: d79c8f30-5a46-5016-8bc2-3b0f5789d74a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
