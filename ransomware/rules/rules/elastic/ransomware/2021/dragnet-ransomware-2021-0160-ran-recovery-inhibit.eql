// Dragnet [Ransomware]: dragnet-ransomware-2021-0160 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 44a95122-97ef-5171-8019-e3677895ec28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
