// Dragnet [Ransomware]: dragnet-ransomware-2021-0765 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 150c9cba-e2f8-5477-8920-a18552766e28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
