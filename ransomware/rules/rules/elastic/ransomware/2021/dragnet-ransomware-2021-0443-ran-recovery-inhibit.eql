// Dragnet [Ransomware]: dragnet-ransomware-2021-0443 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: dffae8ce-cef8-5729-9007-d0ee028b8eff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
