// Dragnet [Ransomware]: dragnet-ransomware-2021-1139 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 6f547698-29e0-5405-876f-780d9d93a1af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
