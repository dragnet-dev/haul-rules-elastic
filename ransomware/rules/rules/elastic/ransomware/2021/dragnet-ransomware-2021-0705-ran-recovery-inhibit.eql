// Dragnet [Ransomware]: dragnet-ransomware-2021-0705 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 668daee3-77ea-54b4-aafc-00935f72ee25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
