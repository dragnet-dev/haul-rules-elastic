// Dragnet [Ransomware]: dragnet-ransomware-2021-1487 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: 8972fce3-aed2-59c7-92da-d9f6a067bf50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
