// Dragnet [Ransomware]: dragnet-ransomware-2021-0661 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 938f52c8-0bf9-5660-b8a0-1027bcff1a0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
