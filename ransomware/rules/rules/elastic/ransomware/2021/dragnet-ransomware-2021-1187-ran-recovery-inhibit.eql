// Dragnet [Ransomware]: dragnet-ransomware-2021-1187 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: b155bd7d-89e7-522f-86fa-d8196f713882

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
