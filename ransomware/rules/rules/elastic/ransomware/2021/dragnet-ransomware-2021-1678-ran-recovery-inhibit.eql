// Dragnet [Ransomware]: dragnet-ransomware-2021-1678 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: ce9a27dd-2e34-5e4b-945b-42c77e607526

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
