// Dragnet [Ransomware]: dragnet-ransomware-2021-0164 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 9abaf4ec-2882-589f-99d2-13a09d9bc721

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
