// Dragnet [Ransomware]: dragnet-ransomware-2021-0237 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 29fe19c7-b190-5d56-bc4a-5506e984360b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
