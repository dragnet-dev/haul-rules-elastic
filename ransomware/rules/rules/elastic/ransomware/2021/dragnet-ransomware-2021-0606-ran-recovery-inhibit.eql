// Dragnet [Ransomware]: dragnet-ransomware-2021-0606 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: fbcb4048-772c-5e77-933b-e8d73f1fdbc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
