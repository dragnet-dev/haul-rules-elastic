// Dragnet [Ransomware]: dragnet-ransomware-2021-1738 — Recovery Inhibition (pay2key)
// Status: deprecated | Level: high | ID: c311b243-6525-5461-bb14-7ace2ed510b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
