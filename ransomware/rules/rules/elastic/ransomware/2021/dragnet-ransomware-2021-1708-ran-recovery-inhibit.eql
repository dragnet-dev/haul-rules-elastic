// Dragnet [Ransomware]: dragnet-ransomware-2021-1708 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f2f1af55-00db-55ab-bb5a-315c0006fe94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
