// Dragnet [Ransomware]: dragnet-ransomware-2021-0900 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 8900be37-02b8-5610-acdd-f28f74f9c874

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
