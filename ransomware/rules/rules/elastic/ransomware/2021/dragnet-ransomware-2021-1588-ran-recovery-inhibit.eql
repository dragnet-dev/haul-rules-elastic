// Dragnet [Ransomware]: dragnet-ransomware-2021-1588 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 3bfffeac-8b32-5a57-badd-f7bbe7172a85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
