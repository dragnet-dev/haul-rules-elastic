// Dragnet [Ransomware]: dragnet-ransomware-2021-0320 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: fbadb7cf-c643-53f8-a7cc-a3a27fd1871f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
