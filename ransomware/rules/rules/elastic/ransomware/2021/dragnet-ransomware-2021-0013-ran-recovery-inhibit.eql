// Dragnet [Ransomware]: dragnet-ransomware-2021-0013 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: dcd02e5d-d01b-5674-bb0c-ce7e9732723b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
