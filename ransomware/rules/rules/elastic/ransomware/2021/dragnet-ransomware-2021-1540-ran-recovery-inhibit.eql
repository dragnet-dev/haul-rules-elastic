// Dragnet [Ransomware]: dragnet-ransomware-2021-1540 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: e06dc668-7974-5a13-9bdb-97e04a64dda7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
