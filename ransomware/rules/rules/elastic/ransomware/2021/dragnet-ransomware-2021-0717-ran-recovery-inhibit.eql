// Dragnet [Ransomware]: dragnet-ransomware-2021-0717 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 664d2c1a-5c7d-5455-a9ee-74383715cddb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
