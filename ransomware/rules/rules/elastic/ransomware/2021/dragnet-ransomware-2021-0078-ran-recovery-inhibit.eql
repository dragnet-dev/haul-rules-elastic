// Dragnet [Ransomware]: dragnet-ransomware-2021-0078 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: fef2ba7d-cb16-5d41-b20a-eb5bb120b362

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
