// Dragnet [Ransomware]: dragnet-ransomware-2021-0834 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 124cd63f-ca44-5e16-a967-446cc602a750

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
