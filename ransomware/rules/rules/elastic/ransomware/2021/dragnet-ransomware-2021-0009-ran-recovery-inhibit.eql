// Dragnet [Ransomware]: dragnet-ransomware-2021-0009 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: 71dc00e1-e663-5f21-b05f-3c239436ffbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
