// Dragnet [Ransomware]: dragnet-ransomware-2021-0002 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 718c2729-36df-5495-81a2-bbe091057e16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
