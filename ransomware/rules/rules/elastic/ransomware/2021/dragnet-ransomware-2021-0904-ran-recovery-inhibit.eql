// Dragnet [Ransomware]: dragnet-ransomware-2021-0904 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 7358d692-830b-59fe-9b5b-196c28bc8b69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
