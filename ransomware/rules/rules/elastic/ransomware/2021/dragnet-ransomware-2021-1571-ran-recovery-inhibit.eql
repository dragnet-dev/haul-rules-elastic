// Dragnet [Ransomware]: dragnet-ransomware-2021-1571 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 47acdf81-a2ba-5ce5-8733-22afb36f803e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
