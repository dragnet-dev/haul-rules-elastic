// Dragnet [Ransomware]: dragnet-ransomware-2021-0402 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 6fbd12c8-2ca7-55bc-adb7-47e733eac474

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
