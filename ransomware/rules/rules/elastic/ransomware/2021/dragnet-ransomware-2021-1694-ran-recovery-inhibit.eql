// Dragnet [Ransomware]: dragnet-ransomware-2021-1694 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: 72204596-c9b0-57b9-9323-1cd42fafd7b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
