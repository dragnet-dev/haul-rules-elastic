// Dragnet [Ransomware]: dragnet-ransomware-2021-0786 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 16ea2aa2-1acd-5ef8-a526-145033fb13be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
