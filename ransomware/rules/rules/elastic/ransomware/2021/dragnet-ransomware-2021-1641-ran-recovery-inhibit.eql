// Dragnet [Ransomware]: dragnet-ransomware-2021-1641 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 696e46c9-2547-5095-876e-c815ef76f0ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
