// Dragnet [Ransomware]: dragnet-ransomware-2021-0193 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 29a87d0c-a9b5-552d-b359-8c1353acb7f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
