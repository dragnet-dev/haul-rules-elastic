// Dragnet [Ransomware]: dragnet-ransomware-2021-1458 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 86ea7f9e-fd60-583b-ac42-e1117565fce0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
