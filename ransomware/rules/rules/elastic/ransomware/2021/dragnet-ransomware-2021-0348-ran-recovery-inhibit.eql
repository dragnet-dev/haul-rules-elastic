// Dragnet [Ransomware]: dragnet-ransomware-2021-0348 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 5540e322-ce85-5877-bdda-cc5d13388d7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
