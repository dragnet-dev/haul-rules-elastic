// Dragnet [Ransomware]: dragnet-ransomware-2021-0427 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 3b813c39-7de8-5bcc-bd23-9b85e6acdd2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
