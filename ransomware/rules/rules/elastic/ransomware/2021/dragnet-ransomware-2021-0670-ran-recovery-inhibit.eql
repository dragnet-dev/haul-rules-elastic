// Dragnet [Ransomware]: dragnet-ransomware-2021-0670 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: d5e04050-5710-57f9-92a1-b3d974a97d83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
