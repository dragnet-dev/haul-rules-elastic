// Dragnet [Ransomware]: dragnet-ransomware-2021-0887 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: fed092e5-b5f5-5892-8b9d-ee034f938683

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
