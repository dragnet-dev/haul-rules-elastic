// Dragnet [Ransomware]: dragnet-ransomware-2021-0063 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4d551a7f-dd5f-5f8a-93be-01599957a154

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
