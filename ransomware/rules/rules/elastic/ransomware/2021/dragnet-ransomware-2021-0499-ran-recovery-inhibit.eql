// Dragnet [Ransomware]: dragnet-ransomware-2021-0499 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: de025680-01a7-53ee-8693-69cd86f29482

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
