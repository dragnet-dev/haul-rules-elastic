// Dragnet [Ransomware]: dragnet-ransomware-2021-0541 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 60d8827f-829f-52e3-8a2f-4774fca3a5b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
