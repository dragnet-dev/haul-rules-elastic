// Dragnet [Ransomware]: dragnet-ransomware-2021-0983 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 091df820-14b1-50ac-ad5b-ab4b6d72bffa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
