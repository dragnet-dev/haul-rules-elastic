// Dragnet [Ransomware]: dragnet-ransomware-2021-0945 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 3ee80c1d-60d6-54fd-bf59-07a342d53dd2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
