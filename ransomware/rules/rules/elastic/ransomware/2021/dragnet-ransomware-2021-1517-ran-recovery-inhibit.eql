// Dragnet [Ransomware]: dragnet-ransomware-2021-1517 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: e40d8fe2-e313-51b4-a17e-63b80a0f5611

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
