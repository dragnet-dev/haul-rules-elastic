// Dragnet [Ransomware]: dragnet-ransomware-2021-0392 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: cc8cb011-2bb0-5df8-9e62-d56bb67a9f88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
