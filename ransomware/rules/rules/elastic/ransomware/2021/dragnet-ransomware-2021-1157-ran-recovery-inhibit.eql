// Dragnet [Ransomware]: dragnet-ransomware-2021-1157 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 9813ce2a-f6b2-544f-9c9e-caace91a67e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
