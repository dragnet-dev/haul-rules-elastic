// Dragnet [Ransomware]: dragnet-ransomware-2021-1491 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 37a6f436-6c88-52df-b8b2-863228e53167

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
