// Dragnet [Ransomware]: dragnet-ransomware-2021-0316 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 48afbc97-17f7-50a8-8424-a50be676ab6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
