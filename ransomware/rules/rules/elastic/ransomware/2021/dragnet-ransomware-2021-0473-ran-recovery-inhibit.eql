// Dragnet [Ransomware]: dragnet-ransomware-2021-0473 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: 7b78ece8-37da-5cf6-9ea9-e21a862ffd48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
