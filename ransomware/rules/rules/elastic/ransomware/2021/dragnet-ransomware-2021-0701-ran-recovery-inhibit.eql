// Dragnet [Ransomware]: dragnet-ransomware-2021-0701 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 3b6c36f9-9ca4-5d29-9b65-80ba2b698563

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
