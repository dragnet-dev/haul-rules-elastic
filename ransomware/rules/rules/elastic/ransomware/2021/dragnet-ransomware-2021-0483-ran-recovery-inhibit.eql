// Dragnet [Ransomware]: dragnet-ransomware-2021-0483 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 02fd6317-a131-50fb-be6d-746e9d0f6803

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
