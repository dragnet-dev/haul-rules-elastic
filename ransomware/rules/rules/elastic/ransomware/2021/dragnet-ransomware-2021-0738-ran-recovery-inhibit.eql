// Dragnet [Ransomware]: dragnet-ransomware-2021-0738 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 297ed875-c279-56a8-b65a-f15ae532d922

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
