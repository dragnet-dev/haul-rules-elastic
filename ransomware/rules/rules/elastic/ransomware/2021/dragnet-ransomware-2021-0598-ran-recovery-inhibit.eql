// Dragnet [Ransomware]: dragnet-ransomware-2021-0598 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 3f27e47f-72ff-5d38-8848-3a950d5ba24d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
