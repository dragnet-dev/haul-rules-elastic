// Dragnet [Ransomware]: dragnet-ransomware-2021-0678 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6a70eea5-54b6-580f-bde5-ff25e0c45321

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
