// Dragnet [Ransomware]: dragnet-ransomware-2021-0986 — Recovery Inhibition (payloadbin)
// Status: deprecated | Level: high | ID: 29a948db-673d-56df-b68d-be750dc3a6fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
