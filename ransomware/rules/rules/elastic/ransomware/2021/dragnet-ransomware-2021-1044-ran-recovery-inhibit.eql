// Dragnet [Ransomware]: dragnet-ransomware-2021-1044 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 717f08c6-4896-5829-9ca3-abe40b9c7a96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
