// Dragnet [Ransomware]: dragnet-ransomware-2021-0262 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 0e955be4-bffe-53c3-b0f6-4a65711ec999

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
