// Dragnet [Ransomware]: dragnet-ransomware-2021-0118 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: 10c555c2-617f-5896-9553-76ca8bafdf48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
