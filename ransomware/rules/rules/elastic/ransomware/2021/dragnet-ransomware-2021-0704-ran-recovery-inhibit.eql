// Dragnet [Ransomware]: dragnet-ransomware-2021-0704 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 71715d66-08c1-52a8-a4ea-258cf7f51012

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
