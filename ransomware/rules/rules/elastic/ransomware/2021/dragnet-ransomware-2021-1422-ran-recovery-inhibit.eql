// Dragnet [Ransomware]: dragnet-ransomware-2021-1422 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: db11db64-73ab-5aef-9fed-c96fab3ac733

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
