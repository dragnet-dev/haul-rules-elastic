// Dragnet [Ransomware]: dragnet-ransomware-2021-0350 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: c9dedaa8-3c3a-5e99-b459-10744700edb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
