// Dragnet [Ransomware]: dragnet-ransomware-2021-0163 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 46a637b9-3fa3-5cfd-a4cf-3d0bf7a75aaa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
