// Dragnet [Ransomware]: dragnet-ransomware-2021-1188 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: f19b4073-24b6-54b9-8a9f-7ebf0fa0cc54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
