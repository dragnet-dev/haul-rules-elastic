// Dragnet [Ransomware]: dragnet-ransomware-2021-1457 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 1814679a-b13a-5173-933a-f11728346c70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
