// Dragnet [Ransomware]: dragnet-ransomware-2021-1240 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a818c2ba-3baa-5ab2-8196-47452841d8a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
