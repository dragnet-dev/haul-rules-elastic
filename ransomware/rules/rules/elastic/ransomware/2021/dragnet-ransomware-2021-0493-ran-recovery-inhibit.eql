// Dragnet [Ransomware]: dragnet-ransomware-2021-0493 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d2197db1-f9a2-5f9d-8fa3-15fe09c813c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
