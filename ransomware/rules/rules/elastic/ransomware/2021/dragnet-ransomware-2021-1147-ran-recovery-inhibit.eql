// Dragnet [Ransomware]: dragnet-ransomware-2021-1147 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c3eae878-bcf7-57b2-9484-c9a9db265d89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
