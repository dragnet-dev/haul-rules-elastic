// Dragnet [Ransomware]: dragnet-ransomware-2021-0395 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: b3ef651c-8bf7-5239-84c7-b4f1ad5f3eba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
