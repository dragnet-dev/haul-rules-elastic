// Dragnet [Ransomware]: dragnet-ransomware-2021-1281 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a3a09a3f-6916-5f91-a316-1aea43e1a844

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
