// Dragnet [Ransomware]: dragnet-ransomware-2021-0632 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: aefbf812-00c1-5c1d-9e6c-4612680614a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
