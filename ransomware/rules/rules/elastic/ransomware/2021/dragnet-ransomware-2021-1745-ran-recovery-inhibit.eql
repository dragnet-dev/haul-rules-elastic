// Dragnet [Ransomware]: dragnet-ransomware-2021-1745 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 724f3dd3-16f5-5499-b7b5-fa5dbe8c0a67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
