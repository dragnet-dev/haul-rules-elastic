// Dragnet [Ransomware]: dragnet-ransomware-2021-0785 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ee1d95a6-a376-5321-9be2-60e50878318b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
