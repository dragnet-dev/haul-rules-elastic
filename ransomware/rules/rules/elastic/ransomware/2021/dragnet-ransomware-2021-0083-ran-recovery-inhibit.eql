// Dragnet [Ransomware]: dragnet-ransomware-2021-0083 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 7052af36-368c-5ec0-91b5-c950abfc886d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
