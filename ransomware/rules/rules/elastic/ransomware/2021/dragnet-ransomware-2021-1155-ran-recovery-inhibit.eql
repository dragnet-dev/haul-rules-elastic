// Dragnet [Ransomware]: dragnet-ransomware-2021-1155 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: c38f90f1-e8ad-5fd7-b9b5-1d6556334896

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
