// Dragnet [Ransomware]: dragnet-ransomware-2021-0480 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 9993a236-e7f7-5025-8568-72a12bb1b866

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
