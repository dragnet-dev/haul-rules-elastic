// Dragnet [Ransomware]: dragnet-ransomware-2021-0585 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 474e5e1b-53a5-529f-82c7-3187058655be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
