// Dragnet [Ransomware]: dragnet-ransomware-2021-1024 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: cb4b22c2-25d4-5984-83a9-b290ef1a99e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
