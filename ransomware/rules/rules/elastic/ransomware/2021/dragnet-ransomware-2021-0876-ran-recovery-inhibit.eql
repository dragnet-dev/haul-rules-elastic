// Dragnet [Ransomware]: dragnet-ransomware-2021-0876 — Recovery Inhibition (rook)
// Status: deprecated | Level: high | ID: 7dbbc823-f554-5e77-bc46-a93f50a14b11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
