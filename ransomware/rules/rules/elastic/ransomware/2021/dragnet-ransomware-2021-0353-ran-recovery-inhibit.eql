// Dragnet [Ransomware]: dragnet-ransomware-2021-0353 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 3c3c0c1e-2c35-5f5a-b6d4-e1357777995d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
