// Dragnet [Ransomware]: dragnet-ransomware-2021-1065 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: d314c3bd-28cf-5cf6-8341-885212f8d2f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
