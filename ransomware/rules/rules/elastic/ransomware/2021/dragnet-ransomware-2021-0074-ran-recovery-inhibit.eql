// Dragnet [Ransomware]: dragnet-ransomware-2021-0074 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 241506c7-fbbe-5b76-81d8-70fc2ea08cbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
