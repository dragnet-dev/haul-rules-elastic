// Dragnet [Ransomware]: dragnet-ransomware-2021-0259 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: 67f9746a-25de-5ed8-b1d0-60f38c58d3e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
