// Dragnet [Ransomware]: dragnet-ransomware-2021-1259 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 9c207afb-f3b2-5435-ba0a-843fc240dd1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
