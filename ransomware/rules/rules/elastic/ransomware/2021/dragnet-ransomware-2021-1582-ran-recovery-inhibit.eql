// Dragnet [Ransomware]: dragnet-ransomware-2021-1582 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 7dda78a8-1ec4-57a5-b636-c38dbbfef211

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
