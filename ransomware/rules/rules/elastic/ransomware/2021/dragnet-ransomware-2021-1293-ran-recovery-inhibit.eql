// Dragnet [Ransomware]: dragnet-ransomware-2021-1293 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 171e2878-9b63-59ec-a569-9d1d492bb015

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
