// Dragnet [Ransomware]: dragnet-ransomware-2021-0615 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 9a7259b8-07bc-5799-98f8-6cc52e2478e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
