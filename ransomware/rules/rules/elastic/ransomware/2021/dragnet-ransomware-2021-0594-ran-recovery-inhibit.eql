// Dragnet [Ransomware]: dragnet-ransomware-2021-0594 — Recovery Inhibition (groove)
// Status: deprecated | Level: high | ID: 460e05f3-cb95-528c-9eed-1afd3d44009a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
