// Dragnet [Ransomware]: dragnet-ransomware-2021-1376 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 71eaa0e3-7ff9-5e49-bd80-1161e08b3ea9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
