// Dragnet [Ransomware]: dragnet-ransomware-2021-1217 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 0b46cb52-9d11-5e58-b7f6-6f599d84564b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
