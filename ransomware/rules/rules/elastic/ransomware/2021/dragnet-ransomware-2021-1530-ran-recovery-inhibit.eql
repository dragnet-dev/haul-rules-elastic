// Dragnet [Ransomware]: dragnet-ransomware-2021-1530 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: dc921ebb-c632-557e-910d-80d0e34517af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
