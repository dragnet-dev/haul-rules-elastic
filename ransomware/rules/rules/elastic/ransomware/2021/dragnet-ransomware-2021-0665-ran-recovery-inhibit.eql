// Dragnet [Ransomware]: dragnet-ransomware-2021-0665 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: f6e039ad-e631-5506-8cdc-ba7400c05072

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
