// Dragnet [Ransomware]: dragnet-ransomware-2021-1484 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 5a9f2197-1025-5a1a-853c-a175366b296b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
