// Dragnet [Ransomware]: dragnet-ransomware-2021-0873 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: da16d6f1-2cf1-5b35-bb8b-f716d687587f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
