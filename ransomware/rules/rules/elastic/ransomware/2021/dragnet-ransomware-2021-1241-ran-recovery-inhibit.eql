// Dragnet [Ransomware]: dragnet-ransomware-2021-1241 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: dc0a1c3f-07e8-51bb-8c80-857b66f9f694

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
