// Dragnet [Ransomware]: dragnet-ransomware-2021-1245 — Recovery Inhibition (lockdata)
// Status: deprecated | Level: high | ID: bfb1c3db-93c9-5f66-83b1-b0b0c0b78092

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
