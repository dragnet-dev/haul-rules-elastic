// Dragnet [Ransomware]: dragnet-ransomware-2021-1793 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 68e301b0-0e7e-501a-a0ab-47259f2203cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
