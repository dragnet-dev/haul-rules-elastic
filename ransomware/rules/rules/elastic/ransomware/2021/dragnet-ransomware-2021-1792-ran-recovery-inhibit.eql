// Dragnet [Ransomware]: dragnet-ransomware-2021-1792 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: a0dee500-1068-5fa7-9a5a-99df8838cf8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
