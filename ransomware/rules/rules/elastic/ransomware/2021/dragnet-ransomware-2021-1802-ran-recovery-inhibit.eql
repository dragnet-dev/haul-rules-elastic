// Dragnet [Ransomware]: dragnet-ransomware-2021-1802 — Recovery Inhibition (payloadbin)
// Status: deprecated | Level: high | ID: a907c473-1650-5c2f-9ce1-7af1ea4f6ce9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
