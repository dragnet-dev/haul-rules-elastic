// Dragnet [Ransomware]: dragnet-ransomware-2021-1196 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 7df623aa-802e-540b-aee5-de663fae225e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
