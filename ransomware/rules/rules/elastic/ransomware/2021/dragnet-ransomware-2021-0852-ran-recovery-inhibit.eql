// Dragnet [Ransomware]: dragnet-ransomware-2021-0852 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 6fd73873-bae4-5d19-a379-f87f1602ba84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
