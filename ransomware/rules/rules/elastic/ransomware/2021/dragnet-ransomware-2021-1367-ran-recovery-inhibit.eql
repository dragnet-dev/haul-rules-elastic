// Dragnet [Ransomware]: dragnet-ransomware-2021-1367 — Recovery Inhibition (mosesstaff)
// Status: deprecated | Level: high | ID: 926c04fb-4e69-5745-88d9-04c4cb93c6ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
