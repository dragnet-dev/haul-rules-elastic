// Dragnet [Ransomware]: dragnet-ransomware-2021-0597 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 1ddfc311-9e00-5fe4-b5dc-82373928108f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
