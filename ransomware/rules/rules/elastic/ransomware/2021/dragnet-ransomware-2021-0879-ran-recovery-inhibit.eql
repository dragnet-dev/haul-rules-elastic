// Dragnet [Ransomware]: dragnet-ransomware-2021-0879 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: b03431ab-c476-55ce-acb4-8a23dd4a6a75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
