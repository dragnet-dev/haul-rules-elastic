// Dragnet [Ransomware]: dragnet-ransomware-2021-1446 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: ba4bee9e-13ea-5990-b6e2-e26920387896

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
