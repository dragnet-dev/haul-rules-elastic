// Dragnet [Ransomware]: dragnet-ransomware-2021-1766 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 6b5a804a-641b-5568-a19a-ccbc4728909e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
