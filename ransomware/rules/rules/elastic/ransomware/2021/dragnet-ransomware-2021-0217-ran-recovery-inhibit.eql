// Dragnet [Ransomware]: dragnet-ransomware-2021-0217 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 44149dd8-6a6c-54e3-887e-0adab7d5c8c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
