// Dragnet [Ransomware]: dragnet-ransomware-2021-0151 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: fc86234a-eeba-5526-9a09-0fad64943e23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
