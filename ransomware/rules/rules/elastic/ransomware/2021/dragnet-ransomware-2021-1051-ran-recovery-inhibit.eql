// Dragnet [Ransomware]: dragnet-ransomware-2021-1051 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 1f424ba2-05d4-591a-8d4f-019bdcf5f7e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
