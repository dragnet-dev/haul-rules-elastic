// Dragnet [Ransomware]: dragnet-ransomware-2021-1451 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: faf83ee7-ebc0-5288-a9a6-e72a216aa7e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
