// Dragnet [Ransomware]: dragnet-ransomware-2021-0618 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: feafa969-bfc5-5429-aee0-b2ddb2512c5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
