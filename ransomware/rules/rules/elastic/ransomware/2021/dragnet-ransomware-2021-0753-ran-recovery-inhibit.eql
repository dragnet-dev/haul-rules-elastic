// Dragnet [Ransomware]: dragnet-ransomware-2021-0753 — Recovery Inhibition (darkside)
// Status: deprecated | Level: high | ID: 9915955d-a5d8-5a93-8613-9ccb7e17b303

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
