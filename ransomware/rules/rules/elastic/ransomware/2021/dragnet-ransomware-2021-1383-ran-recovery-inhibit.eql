// Dragnet [Ransomware]: dragnet-ransomware-2021-1383 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 0b9ab3cc-8aea-513b-82c1-252daa2f5cad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
