// Dragnet [Ransomware]: dragnet-ransomware-2021-1434 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: af6aa7e6-def4-5737-a0ac-d3ef846f260e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
