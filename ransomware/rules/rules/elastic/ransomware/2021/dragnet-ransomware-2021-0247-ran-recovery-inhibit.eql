// Dragnet [Ransomware]: dragnet-ransomware-2021-0247 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 7f8ea645-ebbb-5255-aa50-e32cfcaed682

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
