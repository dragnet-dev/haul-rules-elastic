// Dragnet [Ransomware]: dragnet-ransomware-2021-1413 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: e4ee95ba-7ac8-5f2c-b36d-bbd76c042621

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
