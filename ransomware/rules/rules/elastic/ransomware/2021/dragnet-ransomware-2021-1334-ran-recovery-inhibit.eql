// Dragnet [Ransomware]: dragnet-ransomware-2021-1334 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 5730b200-6a0a-5d90-a4b0-da6200e74ebb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
