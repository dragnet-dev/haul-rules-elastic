// Dragnet [Ransomware]: dragnet-ransomware-2021-0685 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 548882aa-f8ed-500f-863e-48505c28e2da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
