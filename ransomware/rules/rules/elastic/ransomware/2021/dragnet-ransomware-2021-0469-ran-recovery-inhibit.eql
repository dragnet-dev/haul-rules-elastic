// Dragnet [Ransomware]: dragnet-ransomware-2021-0469 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 9a75d5a6-9d0d-5f5c-9f24-3a054dc71bde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
