// Dragnet [Ransomware]: dragnet-ransomware-2021-0858 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 7147dec3-c74c-5c76-8d75-35e0002f2945

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
