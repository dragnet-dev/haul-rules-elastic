// Dragnet [Ransomware]: dragnet-ransomware-2021-0383 — Recovery Inhibition (darkside)
// Status: deprecated | Level: high | ID: 6bae5082-ec64-5416-9f5b-4f480bfab253

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
