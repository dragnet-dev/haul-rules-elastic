// Dragnet [Ransomware]: dragnet-ransomware-2021-0210 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: 4d2177e4-21f5-5b79-9eb9-9ffe54f707da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
