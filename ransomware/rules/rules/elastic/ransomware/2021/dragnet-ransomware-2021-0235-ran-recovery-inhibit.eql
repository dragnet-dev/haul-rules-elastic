// Dragnet [Ransomware]: dragnet-ransomware-2021-0235 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 0bc8cde6-27a9-5d0a-a425-2cfe977f3fd1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
