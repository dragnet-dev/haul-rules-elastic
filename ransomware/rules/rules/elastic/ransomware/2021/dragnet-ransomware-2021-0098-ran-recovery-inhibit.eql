// Dragnet [Ransomware]: dragnet-ransomware-2021-0098 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 8a237694-176d-5f6f-aca9-b79e82fe9e69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
