// Dragnet [Ransomware]: dragnet-ransomware-2021-1095 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 63ae275e-95ba-53e0-b33e-d301779fe7ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
