// Dragnet [Ransomware]: dragnet-ransomware-2021-1132 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 5dc9468b-5e29-5d72-bb53-821b3f883a97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
