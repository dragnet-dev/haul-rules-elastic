// Dragnet [Ransomware]: dragnet-ransomware-2021-0741 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ea12cba0-063e-52b9-9ede-25835a12d3e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
