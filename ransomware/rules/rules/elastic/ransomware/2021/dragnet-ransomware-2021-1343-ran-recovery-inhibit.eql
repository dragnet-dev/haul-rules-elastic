// Dragnet [Ransomware]: dragnet-ransomware-2021-1343 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 45fabeec-1c35-5d0b-91f2-c2106bf090a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
