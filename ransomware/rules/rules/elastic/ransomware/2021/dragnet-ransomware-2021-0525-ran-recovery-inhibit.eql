// Dragnet [Ransomware]: dragnet-ransomware-2021-0525 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 20b1147c-fa5f-573c-81e5-5b46f8da72fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
