// Dragnet [Ransomware]: dragnet-ransomware-2021-0422 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 48945c96-1964-54fb-b3b7-240c7a48bde1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
