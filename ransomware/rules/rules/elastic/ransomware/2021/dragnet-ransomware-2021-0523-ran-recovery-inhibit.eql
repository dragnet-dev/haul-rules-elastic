// Dragnet [Ransomware]: dragnet-ransomware-2021-0523 — Recovery Inhibition (xinglocker)
// Status: deprecated | Level: high | ID: 9406f480-4ae3-5c9c-acc1-63b5b3d35783

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
