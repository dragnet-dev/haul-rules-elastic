// Dragnet [Ransomware]: dragnet-ransomware-2021-1096 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: a363cc27-2d3e-5e65-b67d-1bf194abf32d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
