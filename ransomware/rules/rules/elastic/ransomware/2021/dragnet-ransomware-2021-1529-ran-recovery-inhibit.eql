// Dragnet [Ransomware]: dragnet-ransomware-2021-1529 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 2e44b537-1235-5c31-8ca1-a55ee54d6676

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
