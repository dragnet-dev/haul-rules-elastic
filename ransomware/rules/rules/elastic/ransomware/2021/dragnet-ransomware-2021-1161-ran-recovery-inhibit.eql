// Dragnet [Ransomware]: dragnet-ransomware-2021-1161 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: c50c9edf-73f6-5c81-9911-7f5a98616f25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
