// Dragnet [Ransomware]: dragnet-ransomware-2021-0724 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 597b8ec4-9db8-5043-ac3b-b09b1e2f6633

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
