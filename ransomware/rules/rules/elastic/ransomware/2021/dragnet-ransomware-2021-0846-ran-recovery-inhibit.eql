// Dragnet [Ransomware]: dragnet-ransomware-2021-0846 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: 1cdad625-0565-563b-9b88-4d28767f0a4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
