// Dragnet [Ransomware]: dragnet-ransomware-2021-1670 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8cc905ab-0aa3-5e3f-96a8-33e926c003d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
