// Dragnet [Ransomware]: dragnet-ransomware-2021-1623 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 71495a3d-98cf-57e5-b8df-3c650359a79e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
