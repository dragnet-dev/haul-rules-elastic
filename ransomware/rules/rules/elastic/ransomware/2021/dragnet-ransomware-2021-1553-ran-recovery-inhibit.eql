// Dragnet [Ransomware]: dragnet-ransomware-2021-1553 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 12aa3640-4ce5-5231-95eb-644eb05a097f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
