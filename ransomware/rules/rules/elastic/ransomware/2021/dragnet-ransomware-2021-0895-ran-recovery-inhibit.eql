// Dragnet [Ransomware]: dragnet-ransomware-2021-0895 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 3ec10bdb-e531-5ed3-b3c4-e91394d14f2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
