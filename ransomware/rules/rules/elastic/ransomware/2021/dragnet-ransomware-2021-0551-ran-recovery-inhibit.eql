// Dragnet [Ransomware]: dragnet-ransomware-2021-0551 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: 1724d9e7-ad07-595a-8345-f7605b525670

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
