// Dragnet [Ransomware]: dragnet-ransomware-2021-0030 — Recovery Inhibition (mosesstaff)
// Status: deprecated | Level: high | ID: 99a04993-64e9-54a8-abb6-a81613459f1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
