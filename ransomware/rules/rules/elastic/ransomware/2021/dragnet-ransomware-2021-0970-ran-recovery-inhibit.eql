// Dragnet [Ransomware]: dragnet-ransomware-2021-0970 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: df72c943-aff3-5bc2-b9f3-ecb8ecc24ef1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
