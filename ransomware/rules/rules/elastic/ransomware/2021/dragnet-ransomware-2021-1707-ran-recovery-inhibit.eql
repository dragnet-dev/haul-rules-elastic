// Dragnet [Ransomware]: dragnet-ransomware-2021-1707 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 04b3287b-aaab-526e-8527-00e8e4c115ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
