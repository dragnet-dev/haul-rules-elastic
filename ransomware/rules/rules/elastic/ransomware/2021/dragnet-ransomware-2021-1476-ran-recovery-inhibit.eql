// Dragnet [Ransomware]: dragnet-ransomware-2021-1476 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: d0be5a09-6727-5b35-aa0a-43f9e18860ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
