// Dragnet [Ransomware]: dragnet-ransomware-2021-1331 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: ad611fdc-49c6-5541-a33f-ebe5c2dfb843

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
