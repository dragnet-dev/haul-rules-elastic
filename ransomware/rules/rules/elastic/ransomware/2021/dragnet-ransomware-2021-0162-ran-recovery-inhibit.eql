// Dragnet [Ransomware]: dragnet-ransomware-2021-0162 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: 2b6189e0-f5b0-58c9-b4ba-8372378ddd59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
