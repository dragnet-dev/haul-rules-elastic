// Dragnet [Ransomware]: dragnet-ransomware-2021-0426 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: c61508fc-57b2-5204-baf0-1c6b30961b66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
