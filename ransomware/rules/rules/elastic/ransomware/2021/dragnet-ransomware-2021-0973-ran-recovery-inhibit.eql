// Dragnet [Ransomware]: dragnet-ransomware-2021-0973 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: c2d89de3-2af4-5afc-8762-e03169526f55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
