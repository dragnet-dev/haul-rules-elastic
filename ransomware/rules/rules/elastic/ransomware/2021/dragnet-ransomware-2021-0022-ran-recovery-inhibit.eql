// Dragnet [Ransomware]: dragnet-ransomware-2021-0022 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f41a83f5-8786-541d-84d8-b699ea936ca8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
