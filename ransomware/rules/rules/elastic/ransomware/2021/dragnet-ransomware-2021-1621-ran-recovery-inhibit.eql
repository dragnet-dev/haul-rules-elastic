// Dragnet [Ransomware]: dragnet-ransomware-2021-1621 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 3867cba3-0768-5cff-b80d-1f711ea88ea1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
