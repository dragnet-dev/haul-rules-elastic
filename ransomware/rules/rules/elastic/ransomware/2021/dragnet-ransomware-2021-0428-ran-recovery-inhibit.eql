// Dragnet [Ransomware]: dragnet-ransomware-2021-0428 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 8194f91b-8172-5b1d-b439-55d77af549f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
