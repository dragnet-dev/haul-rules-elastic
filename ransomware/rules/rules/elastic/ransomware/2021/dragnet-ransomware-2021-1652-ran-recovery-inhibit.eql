// Dragnet [Ransomware]: dragnet-ransomware-2021-1652 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: b8056766-dc06-5aaa-ab80-f76badedb487

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
