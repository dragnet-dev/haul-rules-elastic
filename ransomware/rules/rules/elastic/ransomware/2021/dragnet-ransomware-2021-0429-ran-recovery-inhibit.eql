// Dragnet [Ransomware]: dragnet-ransomware-2021-0429 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: 683b47e2-571e-5b47-b101-585b2b623b27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
