// Dragnet [Ransomware]: dragnet-ransomware-2021-1488 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: cae6b7b1-f6e2-5b98-8706-a1ae4da354fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
