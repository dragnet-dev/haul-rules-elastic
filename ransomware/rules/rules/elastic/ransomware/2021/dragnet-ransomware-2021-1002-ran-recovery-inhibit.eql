// Dragnet [Ransomware]: dragnet-ransomware-2021-1002 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 92a11fc8-8210-5785-a23c-cb8e081b0975

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
