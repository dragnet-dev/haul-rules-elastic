// Dragnet [Ransomware]: dragnet-ransomware-2021-1744 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a3bde969-ae1b-5e02-a925-9ce4900bcc3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
