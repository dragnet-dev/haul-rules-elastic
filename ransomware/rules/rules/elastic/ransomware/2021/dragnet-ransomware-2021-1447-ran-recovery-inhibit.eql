// Dragnet [Ransomware]: dragnet-ransomware-2021-1447 — Recovery Inhibition (ragnarok)
// Status: deprecated | Level: high | ID: 67cf16ed-8d6a-53c8-89b0-a5145beedf1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
