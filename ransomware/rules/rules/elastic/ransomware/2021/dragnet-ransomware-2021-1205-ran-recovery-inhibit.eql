// Dragnet [Ransomware]: dragnet-ransomware-2021-1205 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 971f3841-646c-564b-878e-61ef3d8e5119

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
