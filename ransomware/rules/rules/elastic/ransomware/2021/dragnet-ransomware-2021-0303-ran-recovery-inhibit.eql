// Dragnet [Ransomware]: dragnet-ransomware-2021-0303 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: e559d1c8-bb11-59d0-b81b-29c83265e4da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
