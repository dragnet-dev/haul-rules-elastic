// Dragnet [Ransomware]: dragnet-ransomware-2021-0947 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: a7b24168-73f2-57c3-b246-3c104304c010

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
