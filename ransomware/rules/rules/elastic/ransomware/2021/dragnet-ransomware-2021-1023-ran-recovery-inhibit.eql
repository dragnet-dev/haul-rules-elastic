// Dragnet [Ransomware]: dragnet-ransomware-2021-1023 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: e28c9be4-232e-5267-adc4-9dad1d6583b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
