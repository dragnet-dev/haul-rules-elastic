// Dragnet [Ransomware]: dragnet-ransomware-2021-0106 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f86a0e53-eb8b-58a6-ae66-9b4b863ec171

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
