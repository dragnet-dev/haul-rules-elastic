// Dragnet [Ransomware]: dragnet-ransomware-2021-0713 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 4d8423b3-eb85-5e2f-8745-b6a36ca1fb44

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
