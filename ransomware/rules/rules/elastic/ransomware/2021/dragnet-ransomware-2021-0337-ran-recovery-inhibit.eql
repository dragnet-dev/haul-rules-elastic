// Dragnet [Ransomware]: dragnet-ransomware-2021-0337 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a16da03b-028e-5d4d-a5fe-b3363409548a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
