// Dragnet [Ransomware]: dragnet-ransomware-2021-1469 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 7dee3d7e-d946-505c-8d4c-0d7e437ed6a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
