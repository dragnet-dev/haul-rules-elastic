// Dragnet [Ransomware]: dragnet-ransomware-2021-1056 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 509a83a2-1847-5ffb-bb9d-06651dd25a12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
