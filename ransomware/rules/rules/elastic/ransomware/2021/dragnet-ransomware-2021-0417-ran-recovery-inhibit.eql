// Dragnet [Ransomware]: dragnet-ransomware-2021-0417 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 6f3f881e-ba33-5088-9a84-bf65ec81375d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
