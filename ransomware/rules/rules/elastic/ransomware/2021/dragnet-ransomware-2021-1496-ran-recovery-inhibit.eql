// Dragnet [Ransomware]: dragnet-ransomware-2021-1496 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: f501a63e-517f-52b5-8d90-31e23f8cf41a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
