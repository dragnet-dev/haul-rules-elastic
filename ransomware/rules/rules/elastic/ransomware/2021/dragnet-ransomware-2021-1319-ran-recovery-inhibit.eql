// Dragnet [Ransomware]: dragnet-ransomware-2021-1319 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: d4102058-a8fd-548e-8822-69f19a273b4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
