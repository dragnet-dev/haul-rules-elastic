// Dragnet [Ransomware]: dragnet-ransomware-2021-1052 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 3b7a9ca9-b75d-5b6f-b6c3-f5860fc684af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
