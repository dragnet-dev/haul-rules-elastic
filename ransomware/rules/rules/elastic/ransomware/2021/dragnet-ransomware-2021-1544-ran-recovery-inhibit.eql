// Dragnet [Ransomware]: dragnet-ransomware-2021-1544 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 2c44736b-536e-5760-ab03-c18df1377987

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
