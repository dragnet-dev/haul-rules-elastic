// Dragnet [Ransomware]: dragnet-ransomware-2021-1028 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f35a32ff-04d0-5e08-8da2-8d84a367f8ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
