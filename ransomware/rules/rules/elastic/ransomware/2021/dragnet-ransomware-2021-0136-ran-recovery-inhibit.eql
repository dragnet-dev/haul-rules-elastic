// Dragnet [Ransomware]: dragnet-ransomware-2021-0136 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: 4faab122-0afc-5220-863a-c913201d0ee9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
