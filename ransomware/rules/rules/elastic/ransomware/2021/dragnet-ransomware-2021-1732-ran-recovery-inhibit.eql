// Dragnet [Ransomware]: dragnet-ransomware-2021-1732 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ed4a5db0-0420-5693-93c8-49ac30e7a2bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
