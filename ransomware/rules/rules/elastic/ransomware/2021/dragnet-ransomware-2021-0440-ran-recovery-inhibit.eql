// Dragnet [Ransomware]: dragnet-ransomware-2021-0440 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ead26f14-3069-5248-8674-e0adf3fa57c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
