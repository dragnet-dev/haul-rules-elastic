// Dragnet [Ransomware]: dragnet-ransomware-2021-0780 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: a76e64de-626e-53b5-8734-5e6a8dfa1c4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
