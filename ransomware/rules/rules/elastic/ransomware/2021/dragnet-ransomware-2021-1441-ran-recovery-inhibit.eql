// Dragnet [Ransomware]: dragnet-ransomware-2021-1441 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 12b882b0-0981-5e6d-8661-5d2d1cec8b12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
