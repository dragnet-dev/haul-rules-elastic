// Dragnet [Ransomware]: dragnet-ransomware-2021-1452 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: fc8947be-2159-585a-99b5-f6f89de5c50e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
