// Dragnet [Ransomware]: dragnet-ransomware-2021-1576 — Recovery Inhibition (xinglocker)
// Status: deprecated | Level: high | ID: 817b5121-3398-5a6d-81d8-f8d9cc97c90c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
