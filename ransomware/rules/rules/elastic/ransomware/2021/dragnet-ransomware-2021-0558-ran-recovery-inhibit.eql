// Dragnet [Ransomware]: dragnet-ransomware-2021-0558 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: 0b0769b5-2fa0-5284-9588-4d733d42418a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
