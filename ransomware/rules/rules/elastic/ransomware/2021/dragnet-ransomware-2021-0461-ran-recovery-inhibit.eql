// Dragnet [Ransomware]: dragnet-ransomware-2021-0461 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 14c8a438-7b68-58d3-82a5-2f1eca3da380

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
