// Dragnet [Ransomware]: dragnet-ransomware-2021-0586 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: 1f36e1ed-e59a-53cb-9499-fa153e104189

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
