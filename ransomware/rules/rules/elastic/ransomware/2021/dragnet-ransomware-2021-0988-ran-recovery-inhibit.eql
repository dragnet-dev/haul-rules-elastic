// Dragnet [Ransomware]: dragnet-ransomware-2021-0988 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 5748bb09-131d-5eee-89b4-df620d6b7bb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
