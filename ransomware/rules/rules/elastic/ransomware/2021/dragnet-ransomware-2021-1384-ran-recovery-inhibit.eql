// Dragnet [Ransomware]: dragnet-ransomware-2021-1384 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 14249758-f9f5-5aa6-ad04-cea860fe52a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
