// Dragnet [Ransomware]: dragnet-ransomware-2021-0639 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 174c97aa-c668-5053-a4d4-24666b935d47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
