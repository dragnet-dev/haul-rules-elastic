// Dragnet [Ransomware]: dragnet-ransomware-2021-1724 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: d7dce638-315a-5859-a6e2-6472b865c518

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
