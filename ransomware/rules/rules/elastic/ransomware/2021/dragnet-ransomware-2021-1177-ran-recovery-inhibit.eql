// Dragnet [Ransomware]: dragnet-ransomware-2021-1177 — Recovery Inhibition (payloadbin)
// Status: deprecated | Level: high | ID: e523dcd3-de2a-5e8a-8885-16efa2855d41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
