// Dragnet [Ransomware]: dragnet-ransomware-2021-1100 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: efb37160-6f97-553e-b1cd-b5a367617671

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
