// Dragnet [Ransomware]: dragnet-ransomware-2021-0991 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 8c331043-664f-5cd3-b396-237a5b1a6746

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
