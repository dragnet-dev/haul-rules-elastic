// Dragnet [Ransomware]: dragnet-ransomware-2021-1329 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: f269dc0c-35db-5d01-a0fe-1bdb3f9e7355

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
