// Dragnet [Ransomware]: dragnet-ransomware-2021-1053 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 5e04a1b0-bfe5-5c87-b79e-048935b80c84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
