// Dragnet [Ransomware]: dragnet-ransomware-2021-1169 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 503c71c6-50a6-5c62-85a8-51d9ae6c7577

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
