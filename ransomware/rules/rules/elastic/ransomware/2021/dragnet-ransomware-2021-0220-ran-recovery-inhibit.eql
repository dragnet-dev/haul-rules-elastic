// Dragnet [Ransomware]: dragnet-ransomware-2021-0220 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 44628b25-802d-5e11-ae26-37fd85f36ae8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
