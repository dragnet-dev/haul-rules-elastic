// Dragnet [Ransomware]: dragnet-ransomware-2021-0215 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: b5183bbb-1606-55eb-af5d-f43e2d69394b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
