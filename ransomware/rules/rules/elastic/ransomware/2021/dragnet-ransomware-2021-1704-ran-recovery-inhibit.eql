// Dragnet [Ransomware]: dragnet-ransomware-2021-1704 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 4740f5cf-6f46-50df-9499-f102c688d36b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
