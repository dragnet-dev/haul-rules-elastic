// Dragnet [Ransomware]: dragnet-ransomware-2021-0572 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 04e9daed-7c61-58ac-8359-9a586e0f2962

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
