// Dragnet [Ransomware]: dragnet-ransomware-2021-1427 — Recovery Inhibition (babuk)
// Status: experimental | Level: high | ID: 2cff2321-5427-59e5-8437-73d6946f2c6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
