// Dragnet [Ransomware]: dragnet-ransomware-2021-1679 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 70eed89a-ade5-5124-a4aa-ff335463ff7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
