// Dragnet [Ransomware]: dragnet-ransomware-2021-1263 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 0ae794ef-595b-5080-b783-28999acd3529

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
