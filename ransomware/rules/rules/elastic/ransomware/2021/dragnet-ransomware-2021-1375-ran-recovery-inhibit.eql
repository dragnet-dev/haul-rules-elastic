// Dragnet [Ransomware]: dragnet-ransomware-2021-1375 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 60f6bb36-2094-52dc-8401-1ecafd9e91e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
