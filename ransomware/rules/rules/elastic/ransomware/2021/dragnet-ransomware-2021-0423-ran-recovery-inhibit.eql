// Dragnet [Ransomware]: dragnet-ransomware-2021-0423 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 7cc02b4c-d99c-5801-864e-5090928b2875

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
