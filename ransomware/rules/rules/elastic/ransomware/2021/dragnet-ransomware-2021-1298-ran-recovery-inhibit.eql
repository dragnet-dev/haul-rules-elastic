// Dragnet [Ransomware]: dragnet-ransomware-2021-1298 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8dfacc28-6ef8-5a1a-bec4-464c82704d36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
