// Dragnet [Ransomware]: dragnet-ransomware-2021-0036 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: dbbaaebe-4382-5fb3-8f3c-ba203b84a357

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
