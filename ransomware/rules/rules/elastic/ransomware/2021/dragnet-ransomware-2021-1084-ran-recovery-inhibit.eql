// Dragnet [Ransomware]: dragnet-ransomware-2021-1084 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 43f4e26c-c0f9-5662-9c82-e78ded116512

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
