// Dragnet [Ransomware]: dragnet-ransomware-2021-0692 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 433b75a5-4518-5e97-ad54-301ad429a874

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
