// Dragnet [Ransomware]: dragnet-ransomware-2021-1672 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 2aeacc99-66ba-5916-a1f5-815ad1f5b8d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
