// Dragnet [Ransomware]: dragnet-ransomware-2021-0811 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b43f6be9-f736-5067-b8a1-5888ad1f9f6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
