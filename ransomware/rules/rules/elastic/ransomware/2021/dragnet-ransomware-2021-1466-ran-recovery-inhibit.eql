// Dragnet [Ransomware]: dragnet-ransomware-2021-1466 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: cad0d095-6d78-5ca4-8630-961704b5e1cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
