// Dragnet [Ransomware]: dragnet-ransomware-2021-1402 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6d5e893f-910c-53c4-a977-10cbff29dd5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
