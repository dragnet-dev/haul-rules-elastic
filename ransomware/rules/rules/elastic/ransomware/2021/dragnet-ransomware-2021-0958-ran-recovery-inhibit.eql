// Dragnet [Ransomware]: dragnet-ransomware-2021-0958 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: c61eb714-5a02-5f41-a24d-562b8f4cead4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
