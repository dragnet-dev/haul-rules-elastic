// Dragnet [Ransomware]: dragnet-ransomware-2021-1166 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: cf077a8e-d23b-5630-9767-71867272d287

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
