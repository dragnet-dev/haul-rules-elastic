// Dragnet [Ransomware]: dragnet-ransomware-2021-0446 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5a1569c2-8b45-5383-9d2c-ec96225492cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
