// Dragnet [Ransomware]: dragnet-ransomware-2021-1183 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: 418f04e0-0658-5539-ab22-6a78a9cdb787

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
