// Dragnet [Ransomware]: dragnet-ransomware-2021-0044 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 79a579bc-0392-5961-82b8-d5fc6f4004e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
