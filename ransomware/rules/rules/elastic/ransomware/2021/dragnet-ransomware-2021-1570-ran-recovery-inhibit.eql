// Dragnet [Ransomware]: dragnet-ransomware-2021-1570 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8a61fc78-def1-5f89-8607-96570813e769

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
