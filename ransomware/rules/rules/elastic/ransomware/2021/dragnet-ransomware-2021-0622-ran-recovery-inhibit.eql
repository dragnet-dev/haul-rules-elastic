// Dragnet [Ransomware]: dragnet-ransomware-2021-0622 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: 7ca31b82-ed90-5565-a734-1ac4a77b3cf3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
