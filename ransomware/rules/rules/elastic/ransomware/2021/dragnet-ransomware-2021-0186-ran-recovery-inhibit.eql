// Dragnet [Ransomware]: dragnet-ransomware-2021-0186 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a6045025-4920-52d2-b5b3-9c3e3d8f4f58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
