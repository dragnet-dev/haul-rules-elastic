// Dragnet [Ransomware]: dragnet-ransomware-2021-0680 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: f4809b56-ae01-56c9-9b2c-b4dbfa9fc2a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
