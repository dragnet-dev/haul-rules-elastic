// Dragnet [Ransomware]: dragnet-ransomware-2021-1494 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 5dc181ae-58ec-574c-b680-57ebb4a6c3cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
