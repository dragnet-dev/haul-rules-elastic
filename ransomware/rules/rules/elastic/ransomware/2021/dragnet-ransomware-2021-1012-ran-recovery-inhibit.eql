// Dragnet [Ransomware]: dragnet-ransomware-2021-1012 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c36747b8-499d-5854-bb90-1900ce95f6f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
