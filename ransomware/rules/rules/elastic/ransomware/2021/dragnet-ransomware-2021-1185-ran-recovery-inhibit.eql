// Dragnet [Ransomware]: dragnet-ransomware-2021-1185 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 3f043f8a-e088-5462-bf37-271e7df38fc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
