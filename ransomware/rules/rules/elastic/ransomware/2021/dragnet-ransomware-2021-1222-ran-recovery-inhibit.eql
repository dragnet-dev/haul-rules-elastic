// Dragnet [Ransomware]: dragnet-ransomware-2021-1222 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b5217fe3-5633-587f-83fe-371eec576770

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
