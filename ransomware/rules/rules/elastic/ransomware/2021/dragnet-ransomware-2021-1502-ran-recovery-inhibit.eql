// Dragnet [Ransomware]: dragnet-ransomware-2021-1502 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: d4a83758-78b4-51ec-9140-90606a126f85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
