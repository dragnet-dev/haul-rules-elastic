// Dragnet [Ransomware]: dragnet-ransomware-2021-1740 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8a9eeb84-b231-56d8-b848-6f66651f1b89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
