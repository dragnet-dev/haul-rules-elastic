// Dragnet [Ransomware]: dragnet-ransomware-2021-0014 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 1e1b2baa-bcab-5c3c-a779-8b338f2d4de3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
