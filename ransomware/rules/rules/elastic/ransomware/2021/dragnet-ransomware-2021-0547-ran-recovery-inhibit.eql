// Dragnet [Ransomware]: dragnet-ransomware-2021-0547 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: a4450b5f-0a58-5366-b0c1-8e1e3dcf0cfb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
