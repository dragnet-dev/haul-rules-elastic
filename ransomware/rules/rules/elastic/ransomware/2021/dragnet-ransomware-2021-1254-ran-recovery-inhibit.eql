// Dragnet [Ransomware]: dragnet-ransomware-2021-1254 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 3e8f5cfd-d0bf-580e-bda0-7079ec90abe6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
