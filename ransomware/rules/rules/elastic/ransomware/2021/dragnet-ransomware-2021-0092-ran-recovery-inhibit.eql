// Dragnet [Ransomware]: dragnet-ransomware-2021-0092 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 2cbd5194-1fbe-5bf4-9166-d5235ed4b9da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
