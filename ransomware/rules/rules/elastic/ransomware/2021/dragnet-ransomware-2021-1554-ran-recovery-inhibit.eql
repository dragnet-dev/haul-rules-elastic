// Dragnet [Ransomware]: dragnet-ransomware-2021-1554 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d97d5e9f-c2da-5715-a780-bfd213d85482

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
