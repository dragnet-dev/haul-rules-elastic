// Dragnet [Ransomware]: dragnet-ransomware-2021-1008 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 9873449e-3895-54e0-a386-1ef95d31e55f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
