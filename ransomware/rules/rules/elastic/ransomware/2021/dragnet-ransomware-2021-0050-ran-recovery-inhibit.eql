// Dragnet [Ransomware]: dragnet-ransomware-2021-0050 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 3be0840b-53eb-544a-b1bc-a6840a825ce9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
