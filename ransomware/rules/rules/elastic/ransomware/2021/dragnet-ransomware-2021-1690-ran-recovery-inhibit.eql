// Dragnet [Ransomware]: dragnet-ransomware-2021-1690 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 18dcb175-dc99-5cf5-838a-24c75c04e874

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
