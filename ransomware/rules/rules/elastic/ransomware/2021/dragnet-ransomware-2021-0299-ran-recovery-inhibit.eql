// Dragnet [Ransomware]: dragnet-ransomware-2021-0299 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: a7220558-8506-5335-b1e2-49cd815bb84f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
