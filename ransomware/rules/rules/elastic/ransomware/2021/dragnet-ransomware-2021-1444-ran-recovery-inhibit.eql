// Dragnet [Ransomware]: dragnet-ransomware-2021-1444 — Recovery Inhibition (mountlocker)
// Status: deprecated | Level: high | ID: 127a2f37-2def-51a3-8236-c31d572c627d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
