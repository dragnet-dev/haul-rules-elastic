// Dragnet [Ransomware]: dragnet-ransomware-2021-1781 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: db32e78d-fadd-5f26-9932-dcce35d9056f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
