// Dragnet [Ransomware]: dragnet-ransomware-2021-1055 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 1095caa9-cdba-5c49-82ce-2da580bad26e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
