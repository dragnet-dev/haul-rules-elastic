// Dragnet [Ransomware]: dragnet-ransomware-2021-0844 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 02cd1828-7f93-5ccb-a89a-52b8e1d3595c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
