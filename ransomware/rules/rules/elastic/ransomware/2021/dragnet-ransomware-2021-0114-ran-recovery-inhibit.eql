// Dragnet [Ransomware]: dragnet-ransomware-2021-0114 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 8929e0fb-efb6-5274-9563-bc37ed2ea000

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
