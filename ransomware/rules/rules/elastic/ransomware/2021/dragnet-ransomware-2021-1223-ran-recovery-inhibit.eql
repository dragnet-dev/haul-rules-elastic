// Dragnet [Ransomware]: dragnet-ransomware-2021-1223 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: b0ceaa1e-cad3-5d77-a5b2-3589adf3015f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
