// Dragnet [Ransomware]: dragnet-ransomware-2021-1562 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 05cc7953-39dc-599c-a88a-8e74907df88d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
