// Dragnet [Ransomware]: dragnet-ransomware-2021-0451 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f5971294-7a16-57b0-9edf-1d495e7e00fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
