// Dragnet [Ransomware]: dragnet-ransomware-2021-1741 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 3333ccaf-54eb-5282-a0d2-43610f920c7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
