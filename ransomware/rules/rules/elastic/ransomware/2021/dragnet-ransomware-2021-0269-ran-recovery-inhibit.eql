// Dragnet [Ransomware]: dragnet-ransomware-2021-0269 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6b5d7ae3-df88-5f15-865a-65075f175695

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
