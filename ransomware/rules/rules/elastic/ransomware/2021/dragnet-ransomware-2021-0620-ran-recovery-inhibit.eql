// Dragnet [Ransomware]: dragnet-ransomware-2021-0620 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 70606df0-3c91-5857-adc9-9eba9de2651c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
