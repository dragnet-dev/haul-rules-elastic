// Dragnet [Ransomware]: dragnet-ransomware-2021-0409 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 17f1df23-5a5c-5be7-9c0b-f0f102f63d77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
