// Dragnet [Ransomware]: dragnet-ransomware-2021-0869 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: f9a1d0c2-dfca-5aa7-a733-c5162bfb9137

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
