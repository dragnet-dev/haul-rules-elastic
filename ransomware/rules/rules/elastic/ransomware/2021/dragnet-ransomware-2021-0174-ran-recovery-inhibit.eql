// Dragnet [Ransomware]: dragnet-ransomware-2021-0174 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: bb6e549d-7c51-5bde-b16c-01fae6c38137

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
