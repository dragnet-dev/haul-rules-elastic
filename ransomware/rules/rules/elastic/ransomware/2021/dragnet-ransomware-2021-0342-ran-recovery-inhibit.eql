// Dragnet [Ransomware]: dragnet-ransomware-2021-0342 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: aa6ca57b-dad9-5d8b-b8ca-1b821bd9ad83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
