// Dragnet [Ransomware]: dragnet-ransomware-2021-1097 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 287f2974-58fe-5992-9e32-65962abdd9de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
