// Dragnet [Ransomware]: dragnet-ransomware-2021-1764 — Recovery Inhibition (atomsilo)
// Status: experimental | Level: high | ID: 7a04c41c-ed8e-54bc-8949-b81cefb95ffd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
