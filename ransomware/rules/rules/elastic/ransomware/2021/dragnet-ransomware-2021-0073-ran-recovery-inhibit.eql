// Dragnet [Ransomware]: dragnet-ransomware-2021-0073 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: ecce9321-0217-5e90-8652-c0cb2fa15f70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
