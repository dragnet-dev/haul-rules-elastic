// Dragnet [Ransomware]: dragnet-ransomware-2021-0683 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ec18c112-20a0-5135-889f-fbc18ab5a740

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
