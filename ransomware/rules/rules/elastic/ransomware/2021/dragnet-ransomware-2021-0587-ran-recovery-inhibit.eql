// Dragnet [Ransomware]: dragnet-ransomware-2021-0587 — Recovery Inhibition (zeppelin)
// Status: deprecated | Level: high | ID: fb47fbcc-c29e-51f4-8c56-e9a2fffa5b94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
