// Dragnet [Ransomware]: dragnet-ransomware-2021-1148 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 97ca0822-ed3d-59d5-a3c7-31c4903b3b61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
