// Dragnet [Ransomware]: dragnet-ransomware-2021-1203 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: e2ee2619-bfb8-585c-8c74-917f14ba79f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
