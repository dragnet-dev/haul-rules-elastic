// Dragnet [Ransomware]: dragnet-ransomware-2021-1445 — Recovery Inhibition (lockbit)
// Status: deprecated | Level: high | ID: ce0a5dd0-e7db-5176-b610-47cd5a1313fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
