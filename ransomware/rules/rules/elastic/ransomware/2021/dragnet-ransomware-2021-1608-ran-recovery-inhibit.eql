// Dragnet [Ransomware]: dragnet-ransomware-2021-1608 — Recovery Inhibition (nefilim)
// Status: deprecated | Level: high | ID: 29df5a71-a9dd-53d6-8b34-861bbd789772

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
