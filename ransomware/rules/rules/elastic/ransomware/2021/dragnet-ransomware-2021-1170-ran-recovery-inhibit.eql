// Dragnet [Ransomware]: dragnet-ransomware-2021-1170 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: a6b130a9-3cae-55a7-b52d-4a29d0d98103

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
