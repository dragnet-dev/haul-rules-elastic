// Dragnet [Ransomware]: dragnet-ransomware-2021-1124 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8038e6bb-fce0-51c0-9ef5-e023f28b9b0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
