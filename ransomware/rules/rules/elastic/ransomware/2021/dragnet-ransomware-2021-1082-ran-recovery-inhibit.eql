// Dragnet [Ransomware]: dragnet-ransomware-2021-1082 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 152fa232-2613-5045-9099-874d7d71ca67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
