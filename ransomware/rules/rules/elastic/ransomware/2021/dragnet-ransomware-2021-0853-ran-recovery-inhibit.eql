// Dragnet [Ransomware]: dragnet-ransomware-2021-0853 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6f2c3acd-782e-5031-8f38-9fcee05a4cea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
