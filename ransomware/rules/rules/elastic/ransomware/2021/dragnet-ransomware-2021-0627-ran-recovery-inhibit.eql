// Dragnet [Ransomware]: dragnet-ransomware-2021-0627 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 9307d396-04db-5a25-abb7-6576ae764f85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
