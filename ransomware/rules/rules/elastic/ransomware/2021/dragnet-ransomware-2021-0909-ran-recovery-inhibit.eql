// Dragnet [Ransomware]: dragnet-ransomware-2021-0909 — Recovery Inhibition (cryp70n1c0d3)
// Status: deprecated | Level: high | ID: 91fe94fe-379d-53d4-83be-b5a59156f116

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
