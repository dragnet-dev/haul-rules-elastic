// Dragnet [Ransomware]: dragnet-ransomware-2021-1498 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: ee427ece-f285-57fe-b3f5-c00dbe1f7284

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
