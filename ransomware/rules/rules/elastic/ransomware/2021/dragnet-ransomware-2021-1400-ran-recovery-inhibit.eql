// Dragnet [Ransomware]: dragnet-ransomware-2021-1400 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 3f48d21b-c529-5bea-b434-22cd8893368d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
