// Dragnet [Ransomware]: dragnet-ransomware-2021-0808 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 8cf4c55b-9b81-5cd3-94b1-ba7d53695f50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
