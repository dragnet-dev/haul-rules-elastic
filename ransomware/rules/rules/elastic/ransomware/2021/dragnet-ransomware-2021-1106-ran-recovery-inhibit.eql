// Dragnet [Ransomware]: dragnet-ransomware-2021-1106 — Recovery Inhibition (blackmatter)
// Status: deprecated | Level: high | ID: b74f9c93-1847-5d8f-94ca-8b3286022479

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
