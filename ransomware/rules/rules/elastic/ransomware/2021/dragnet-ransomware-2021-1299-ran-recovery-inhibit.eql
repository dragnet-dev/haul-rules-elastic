// Dragnet [Ransomware]: dragnet-ransomware-2021-1299 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 1adf6994-2e98-540e-a4c7-484da4d84287

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
