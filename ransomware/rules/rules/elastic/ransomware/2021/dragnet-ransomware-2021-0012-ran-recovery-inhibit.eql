// Dragnet [Ransomware]: dragnet-ransomware-2021-0012 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: efd10463-e49e-55a7-96d7-93deb0a961fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
