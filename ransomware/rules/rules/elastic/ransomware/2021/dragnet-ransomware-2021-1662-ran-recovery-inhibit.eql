// Dragnet [Ransomware]: dragnet-ransomware-2021-1662 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 2cc6c85e-6370-58cb-b57d-72bc0ae0eaf3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
