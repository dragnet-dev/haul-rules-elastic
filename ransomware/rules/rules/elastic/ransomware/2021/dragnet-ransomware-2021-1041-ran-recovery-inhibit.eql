// Dragnet [Ransomware]: dragnet-ransomware-2021-1041 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 89b49855-ba4d-5f0c-b5ee-da457ea229d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
