// Dragnet [Ransomware]: dragnet-ransomware-2021-0448 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 3bcec1ae-f285-5533-b6de-6cf9cf216527

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
