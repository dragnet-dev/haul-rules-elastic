// Dragnet [Ransomware]: dragnet-ransomware-2021-1757 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 51b9b8dd-f78c-53a6-b0bc-706e6a934017

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
