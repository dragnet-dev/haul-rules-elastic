// Dragnet [Ransomware]: dragnet-ransomware-2021-0169 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 5215d7a1-ce09-5412-9e73-980daf3f1732

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
