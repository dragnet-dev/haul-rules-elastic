// Dragnet [Ransomware]: dragnet-ransomware-2021-1261 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: ab7e6b0e-42cf-5931-943c-b04ba625fd09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
