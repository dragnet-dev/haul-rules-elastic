// Dragnet [Ransomware]: dragnet-ransomware-2021-0893 — Recovery Inhibition (rook)
// Status: deprecated | Level: high | ID: 5da68e8c-8969-533b-b24a-768697494529

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
