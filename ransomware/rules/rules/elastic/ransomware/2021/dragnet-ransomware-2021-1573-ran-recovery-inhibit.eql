// Dragnet [Ransomware]: dragnet-ransomware-2021-1573 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 49abe764-9336-5353-b1dd-6abe7b377135

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
