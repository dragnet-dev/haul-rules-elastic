// Dragnet [Ransomware]: dragnet-ransomware-2021-1279 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 08e2a8ca-0d18-5bc2-988c-60e501c4a02f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
