// Dragnet [Ransomware]: dragnet-ransomware-2021-1414 — Recovery Inhibition (babuk)
// Status: deprecated | Level: high | ID: 4e7fc267-7712-55fe-979f-665f8d84981f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
