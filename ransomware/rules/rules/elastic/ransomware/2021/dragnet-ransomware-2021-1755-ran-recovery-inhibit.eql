// Dragnet [Ransomware]: dragnet-ransomware-2021-1755 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: e9866198-e9f3-5c8c-925a-4098768bbb4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
