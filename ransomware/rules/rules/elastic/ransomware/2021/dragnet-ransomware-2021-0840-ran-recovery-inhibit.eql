// Dragnet [Ransomware]: dragnet-ransomware-2021-0840 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: fec4a886-34fe-5e2d-bbb8-31af93eac832

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
