// Dragnet [Ransomware]: dragnet-ransomware-2021-1369 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 56b101f0-d606-5363-84c7-9b906d3f7de6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
