// Dragnet [Ransomware]: dragnet-ransomware-2021-1415 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e0ffcfc5-037a-5108-9824-758d0c954b76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
