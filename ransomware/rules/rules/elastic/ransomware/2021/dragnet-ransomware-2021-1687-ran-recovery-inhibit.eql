// Dragnet [Ransomware]: dragnet-ransomware-2021-1687 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 1590b3a7-0899-5979-aca9-ddf0d5ec2bb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
