// Dragnet [Ransomware]: dragnet-ransomware-2021-0468 — Recovery Inhibition (groove)
// Status: deprecated | Level: high | ID: cd81e991-b17e-5707-a6ad-c8d35d9a3b26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
