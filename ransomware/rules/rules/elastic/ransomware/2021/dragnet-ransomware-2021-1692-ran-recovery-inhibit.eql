// Dragnet [Ransomware]: dragnet-ransomware-2021-1692 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: d8b7aa34-7a7b-55a0-8ba1-2822d6bc3c29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
