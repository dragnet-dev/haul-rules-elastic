// Dragnet [Ransomware]: dragnet-ransomware-2021-1693 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 0ce47084-a5b1-52b3-8bd3-edde1d564dbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
