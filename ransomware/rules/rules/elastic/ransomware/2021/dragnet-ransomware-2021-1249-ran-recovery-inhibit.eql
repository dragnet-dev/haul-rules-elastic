// Dragnet [Ransomware]: dragnet-ransomware-2021-1249 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 91e43810-134b-5727-8cc9-280cafe19fa7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
