// Dragnet [Ransomware]: dragnet-ransomware-2021-0544 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 4a602c0e-34ae-58ec-bc27-aaea24749c7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
