// Dragnet [Ransomware]: dragnet-ransomware-2021-1796 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 3bbf852c-e4a0-5bd4-9da0-970fe8024d65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
