// Dragnet [Ransomware]: dragnet-ransomware-2021-1372 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: c9f2de1b-4949-5311-bc06-87633396847e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
