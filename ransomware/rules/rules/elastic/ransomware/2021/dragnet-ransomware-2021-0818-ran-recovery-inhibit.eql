// Dragnet [Ransomware]: dragnet-ransomware-2021-0818 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e76b3b66-393b-5534-a3b9-507a8b1e22e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
