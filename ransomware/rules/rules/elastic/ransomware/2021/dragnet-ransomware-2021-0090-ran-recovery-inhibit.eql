// Dragnet [Ransomware]: dragnet-ransomware-2021-0090 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d94b2f3e-83f6-57b4-a224-4b67b1cca1e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
