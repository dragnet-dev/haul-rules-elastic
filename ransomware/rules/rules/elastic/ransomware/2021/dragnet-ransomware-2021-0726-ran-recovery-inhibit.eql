// Dragnet [Ransomware]: dragnet-ransomware-2021-0726 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 8ff18d4a-fc11-51d8-8d0b-da9dbdf1929e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
