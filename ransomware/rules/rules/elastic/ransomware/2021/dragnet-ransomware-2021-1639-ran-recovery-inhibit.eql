// Dragnet [Ransomware]: dragnet-ransomware-2021-1639 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 74d11954-7720-50ff-b766-c8aa6b71eb7c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
