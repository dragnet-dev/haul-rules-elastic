// Dragnet [Ransomware]: dragnet-ransomware-2021-0611 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 6e8cdb31-9031-5ff0-a695-f0284ceb7e38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
