// Dragnet [Ransomware]: dragnet-ransomware-2021-0153 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 852038ea-d26f-5336-935b-65fa32ac9fc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
