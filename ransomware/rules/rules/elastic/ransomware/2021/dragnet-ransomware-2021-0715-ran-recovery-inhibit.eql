// Dragnet [Ransomware]: dragnet-ransomware-2021-0715 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: a681be01-7722-5c0b-8ff5-114de5cf1547

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
