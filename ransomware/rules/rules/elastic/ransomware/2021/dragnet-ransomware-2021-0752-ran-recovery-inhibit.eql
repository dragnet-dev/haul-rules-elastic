// Dragnet [Ransomware]: dragnet-ransomware-2021-0752 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: e3485047-f9e6-5d4d-8dca-4b7a5ebec9d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
