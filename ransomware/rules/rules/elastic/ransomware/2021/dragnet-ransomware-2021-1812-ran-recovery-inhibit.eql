// Dragnet [Ransomware]: dragnet-ransomware-2021-1812 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: 92890b30-b39d-5d5b-ac4f-843ddf43ba89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
