// Dragnet [Ransomware]: dragnet-ransomware-2021-1809 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 22caf3d2-ff6e-50a5-943d-1ddc7e16c929

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
