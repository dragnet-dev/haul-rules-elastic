// Dragnet [Ransomware]: dragnet-ransomware-2021-0268 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 92cb1eac-5d43-5a5d-858e-9be5ce075fb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
