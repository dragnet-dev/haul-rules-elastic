// Dragnet [Ransomware]: dragnet-ransomware-2021-0209 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 2e1c5a07-86ce-584a-b95e-37f08b3f6d39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
