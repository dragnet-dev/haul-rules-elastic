// Dragnet [Ransomware]: dragnet-ransomware-2021-1622 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 0806e7a0-a7d8-5ae5-9296-68652b9b07c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
