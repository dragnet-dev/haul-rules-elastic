// Dragnet [Ransomware]: dragnet-ransomware-2021-1479 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 954410c3-f8fc-59d8-8337-10883a731159

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
