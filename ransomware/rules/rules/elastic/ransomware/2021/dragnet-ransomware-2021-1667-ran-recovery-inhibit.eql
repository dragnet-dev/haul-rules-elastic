// Dragnet [Ransomware]: dragnet-ransomware-2021-1667 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: a7786c3f-ee25-5e80-a746-20a5143628ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
