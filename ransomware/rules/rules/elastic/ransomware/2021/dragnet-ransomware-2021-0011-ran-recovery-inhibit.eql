// Dragnet [Ransomware]: dragnet-ransomware-2021-0011 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: c08055aa-86cc-53f9-8938-a4032e98cf49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
