// Dragnet [Ransomware]: dragnet-ransomware-2021-1575 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b080f4dc-63f9-550c-a097-c2cef4c896fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
