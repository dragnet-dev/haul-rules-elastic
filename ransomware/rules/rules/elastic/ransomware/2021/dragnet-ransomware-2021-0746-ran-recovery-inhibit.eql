// Dragnet [Ransomware]: dragnet-ransomware-2021-0746 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 2041a993-01df-5e36-a47d-6f14bb9e9ff5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
