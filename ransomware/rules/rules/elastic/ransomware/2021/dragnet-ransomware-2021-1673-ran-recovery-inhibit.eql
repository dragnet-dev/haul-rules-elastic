// Dragnet [Ransomware]: dragnet-ransomware-2021-1673 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: 0f2fb0b6-28b2-5269-8472-f5675bc91154

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
