// Dragnet [Ransomware]: dragnet-ransomware-2021-1247 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: be237c7d-f5e4-5ab2-9a3f-507704323f27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
