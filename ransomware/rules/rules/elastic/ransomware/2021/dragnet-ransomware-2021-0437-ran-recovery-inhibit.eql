// Dragnet [Ransomware]: dragnet-ransomware-2021-0437 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: 71c2d875-6c1f-5710-8401-ba2b51c5988d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
