// Dragnet [Ransomware]: dragnet-ransomware-2021-0077 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 5871cdab-93d0-5a07-af05-2fe671bcd306

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
