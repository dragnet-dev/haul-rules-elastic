// Dragnet [Ransomware]: dragnet-ransomware-2021-1481 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6517daa0-e045-52e8-86ef-049bbd4de976

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
