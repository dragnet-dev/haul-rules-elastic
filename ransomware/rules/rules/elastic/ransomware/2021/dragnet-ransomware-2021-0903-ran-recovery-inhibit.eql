// Dragnet [Ransomware]: dragnet-ransomware-2021-0903 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: b6aa7c31-40ec-5f35-8a1d-4d92c11806e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
