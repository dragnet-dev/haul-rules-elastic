// Dragnet [Ransomware]: dragnet-ransomware-2021-0733 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d1059066-f586-5496-b7b1-cf59482e642a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
