// Dragnet [Ransomware]: dragnet-ransomware-2021-1609 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: e41ff0e0-400a-5f8b-a806-c760e6f9e0f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
