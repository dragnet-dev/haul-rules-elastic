// Dragnet [Ransomware]: dragnet-ransomware-2021-1421 — Recovery Inhibition (karma)
// Status: deprecated | Level: high | ID: 648438d9-7fcc-51fc-b95f-74c3642d4f50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
