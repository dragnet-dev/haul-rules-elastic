// Dragnet [Ransomware]: dragnet-ransomware-2021-0760 — Recovery Inhibition (xinglocker)
// Status: deprecated | Level: high | ID: 34ee924e-38f1-5f69-8f88-9d21a5443c4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
