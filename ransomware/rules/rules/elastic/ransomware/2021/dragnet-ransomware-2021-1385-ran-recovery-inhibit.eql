// Dragnet [Ransomware]: dragnet-ransomware-2021-1385 — Recovery Inhibition (mosesstaff)
// Status: deprecated | Level: high | ID: 69e174cf-d2c3-5d3b-9863-baee79afc84b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
