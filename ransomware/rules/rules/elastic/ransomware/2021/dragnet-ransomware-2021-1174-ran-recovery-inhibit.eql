// Dragnet [Ransomware]: dragnet-ransomware-2021-1174 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 2eb8542b-4968-5bae-abc1-c046045bc329

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
