// Dragnet [Ransomware]: dragnet-ransomware-2021-1714 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 8d721cbf-edb1-5d4b-b2ea-be76777fada8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
