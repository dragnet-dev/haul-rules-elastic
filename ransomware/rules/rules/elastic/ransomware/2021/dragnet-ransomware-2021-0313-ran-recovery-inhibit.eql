// Dragnet [Ransomware]: dragnet-ransomware-2021-0313 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 9a39e988-6a36-56db-b2fb-4ffd0f91b902

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
