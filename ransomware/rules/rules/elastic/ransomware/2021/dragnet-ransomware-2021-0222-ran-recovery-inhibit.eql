// Dragnet [Ransomware]: dragnet-ransomware-2021-0222 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 9d999fa2-e774-5a88-b9b7-d35ee52eaf89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
