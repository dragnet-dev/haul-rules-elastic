// Dragnet [Ransomware]: dragnet-ransomware-2021-0079 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 3ac2b205-336f-5ba3-b46d-8812afc48bed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
