// Dragnet [Ransomware]: dragnet-ransomware-2021-0343 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 3f1207a0-ff75-5762-adbb-0721e62d1479

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
