// Dragnet [Ransomware]: dragnet-ransomware-2021-0896 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: 0900045d-4aa3-5b4d-b93c-4d4c74d4d6d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
