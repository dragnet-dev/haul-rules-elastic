// Dragnet [Ransomware]: dragnet-ransomware-2021-1556 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 1af3994e-05cc-5198-a3eb-85364ab2e795

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
