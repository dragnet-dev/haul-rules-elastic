// Dragnet [Ransomware]: dragnet-ransomware-2021-1572 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 62036b6b-d9ce-5a9f-b5c8-d938338d7d38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
