// Dragnet [Ransomware]: dragnet-ransomware-2021-0032 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 838a0623-d3a6-541d-ae40-4f533c4f4eea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
