// Dragnet [Ransomware]: dragnet-ransomware-2021-1079 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: a1f199c1-8e5e-5307-bd0f-bb4707bee677

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
