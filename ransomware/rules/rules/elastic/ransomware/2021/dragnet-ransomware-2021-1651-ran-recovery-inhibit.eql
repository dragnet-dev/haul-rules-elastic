// Dragnet [Ransomware]: dragnet-ransomware-2021-1651 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 52a32f99-d24b-5c4a-aca4-92b706b83e28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
