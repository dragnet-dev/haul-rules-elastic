// Dragnet [Ransomware]: dragnet-ransomware-2021-1804 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a8782ef7-519a-50ae-8c1a-4eeda3841aa6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
