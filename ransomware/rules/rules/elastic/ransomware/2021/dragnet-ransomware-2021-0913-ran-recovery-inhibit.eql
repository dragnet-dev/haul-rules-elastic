// Dragnet [Ransomware]: dragnet-ransomware-2021-0913 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: de8ed02a-587a-5de3-9ae8-80f284e6db94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
