// Dragnet [Ransomware]: dragnet-ransomware-2021-0866 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 057b48e6-0c6a-5d25-8b58-5f0ef0e34b08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
