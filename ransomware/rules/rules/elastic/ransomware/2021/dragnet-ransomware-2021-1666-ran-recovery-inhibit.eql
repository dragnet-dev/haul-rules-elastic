// Dragnet [Ransomware]: dragnet-ransomware-2021-1666 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: e3368fef-a870-5fbd-9995-1c81ce1af8ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
