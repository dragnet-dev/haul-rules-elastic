// Dragnet [Ransomware]: dragnet-ransomware-2021-1490 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: da4c94a1-75ec-5b9f-b9b4-a9e4671f969b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
