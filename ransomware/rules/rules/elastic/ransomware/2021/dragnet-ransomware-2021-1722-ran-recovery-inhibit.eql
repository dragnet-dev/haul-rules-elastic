// Dragnet [Ransomware]: dragnet-ransomware-2021-1722 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 566f5df3-6cbf-5c7f-9906-2cc0b3e65759

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
