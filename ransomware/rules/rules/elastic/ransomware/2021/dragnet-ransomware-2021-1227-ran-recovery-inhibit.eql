// Dragnet [Ransomware]: dragnet-ransomware-2021-1227 — Recovery Inhibition (marketo)
// Status: deprecated | Level: high | ID: ece9d678-9be6-51fd-adc3-e141605064d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
