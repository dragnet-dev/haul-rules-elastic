// Dragnet [Ransomware]: dragnet-ransomware-2021-1586 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 449ca7d9-c061-55b5-9c81-f8860d2911fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
