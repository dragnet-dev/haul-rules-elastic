// Dragnet [Ransomware]: dragnet-ransomware-2021-1058 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: a907ab32-6d81-5a27-a5c1-03e7ec9c2622

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
