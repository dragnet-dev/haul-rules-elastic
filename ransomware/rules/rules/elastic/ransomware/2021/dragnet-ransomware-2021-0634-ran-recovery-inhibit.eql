// Dragnet [Ransomware]: dragnet-ransomware-2021-0634 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 794c8312-480d-564e-80da-6ea4c9a578d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
