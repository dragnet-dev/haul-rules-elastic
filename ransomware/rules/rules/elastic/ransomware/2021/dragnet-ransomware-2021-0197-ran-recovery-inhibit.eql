// Dragnet [Ransomware]: dragnet-ransomware-2021-0197 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 67dc437d-340b-505a-88e0-06a1221a533a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
