// Dragnet [Ransomware]: dragnet-ransomware-2021-0323 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: b9717339-0f97-5cc2-b56c-4c1a0600eea0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
