// Dragnet [Ransomware]: dragnet-ransomware-2021-1504 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 0428bdd4-4964-54dd-8afe-cd63494f5ee6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
