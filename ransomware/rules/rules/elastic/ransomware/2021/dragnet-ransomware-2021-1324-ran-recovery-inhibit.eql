// Dragnet [Ransomware]: dragnet-ransomware-2021-1324 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 0255c78d-3058-5215-8d3e-5eb7be60ce5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
