// Dragnet [Ransomware]: dragnet-ransomware-2021-0361 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: fcea0473-7a50-55d2-830b-0cf1a93ff407

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
