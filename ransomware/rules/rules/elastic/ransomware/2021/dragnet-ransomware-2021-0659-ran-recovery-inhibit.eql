// Dragnet [Ransomware]: dragnet-ransomware-2021-0659 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: f4cf1a4b-34c8-505b-b27d-85f1f564d2b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
