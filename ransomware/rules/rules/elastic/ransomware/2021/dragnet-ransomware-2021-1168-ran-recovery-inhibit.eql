// Dragnet [Ransomware]: dragnet-ransomware-2021-1168 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 68564b53-6f9d-5307-b13d-c52c749471e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
