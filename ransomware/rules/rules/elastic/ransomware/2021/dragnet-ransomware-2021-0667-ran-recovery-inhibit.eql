// Dragnet [Ransomware]: dragnet-ransomware-2021-0667 — Recovery Inhibition (xinglocker)
// Status: deprecated | Level: high | ID: c0531287-93bf-5b6f-88f6-ec7f5f059465

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
