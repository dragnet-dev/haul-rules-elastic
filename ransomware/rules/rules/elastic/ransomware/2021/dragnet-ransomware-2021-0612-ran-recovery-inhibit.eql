// Dragnet [Ransomware]: dragnet-ransomware-2021-0612 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: de0b71f9-a73c-5983-ab09-37624f22b557

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
