// Dragnet [Ransomware]: dragnet-ransomware-2021-1282 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: df5dfa1f-2a82-5bff-808e-f26506bae9da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
