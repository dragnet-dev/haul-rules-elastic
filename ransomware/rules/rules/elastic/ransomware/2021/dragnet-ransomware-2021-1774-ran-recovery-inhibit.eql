// Dragnet [Ransomware]: dragnet-ransomware-2021-1774 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 6e152095-9e02-574e-8fa1-06aeba6624f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
