// Dragnet [Ransomware]: dragnet-ransomware-2021-1404 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ec5438f5-2732-5a4b-8778-f567601c6dc1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
