// Dragnet [Ransomware]: dragnet-ransomware-2021-0716 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: dff277ee-ee96-5b6e-859c-d8de485597b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
