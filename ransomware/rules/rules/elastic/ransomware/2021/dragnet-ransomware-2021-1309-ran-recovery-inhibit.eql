// Dragnet [Ransomware]: dragnet-ransomware-2021-1309 — Recovery Inhibition (avaddon)
// Status: deprecated | Level: high | ID: bfbd880f-2415-5a58-94ad-57f43c242498

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
