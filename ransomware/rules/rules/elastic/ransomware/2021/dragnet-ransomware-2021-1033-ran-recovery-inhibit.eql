// Dragnet [Ransomware]: dragnet-ransomware-2021-1033 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c50e6539-524d-5e7a-940c-535e2b4900e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
