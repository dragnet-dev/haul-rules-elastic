// Dragnet [Ransomware]: dragnet-ransomware-2021-0485 — Recovery Inhibition (mountlocker)
// Status: deprecated | Level: high | ID: 28f5a981-5bbf-52e8-b162-f7887d15a111

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
