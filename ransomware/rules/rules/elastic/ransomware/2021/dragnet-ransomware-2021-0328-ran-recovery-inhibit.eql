// Dragnet [Ransomware]: dragnet-ransomware-2021-0328 — Recovery Inhibition (spook)
// Status: deprecated | Level: high | ID: a127fe86-953c-57fc-a3b9-87795463f1aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
