// Dragnet [Ransomware]: dragnet-ransomware-2021-0542 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: bbb6a288-36de-5ae0-bdb1-5e26740a0f92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
