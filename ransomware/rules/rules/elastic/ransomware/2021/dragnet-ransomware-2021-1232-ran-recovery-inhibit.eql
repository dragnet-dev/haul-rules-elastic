// Dragnet [Ransomware]: dragnet-ransomware-2021-1232 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: a1c15ea5-97e0-5ecc-968d-309fc24654bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
