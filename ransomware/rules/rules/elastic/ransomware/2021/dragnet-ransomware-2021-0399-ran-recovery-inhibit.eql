// Dragnet [Ransomware]: dragnet-ransomware-2021-0399 — Recovery Inhibition (pysa)
// Status: deprecated | Level: high | ID: 0474e41a-d0a0-527e-b135-d72a342ad3cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
