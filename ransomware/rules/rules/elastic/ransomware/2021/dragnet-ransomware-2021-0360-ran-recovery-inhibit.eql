// Dragnet [Ransomware]: dragnet-ransomware-2021-0360 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 2fe9510d-2175-55f1-89df-ff84b254308c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
