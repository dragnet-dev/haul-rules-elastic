// Dragnet [Ransomware]: dragnet-ransomware-2021-1706 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 48278ce7-16e5-576c-bc88-645bfa809fe1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
