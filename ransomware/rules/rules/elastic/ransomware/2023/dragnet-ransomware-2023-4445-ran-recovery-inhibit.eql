// Dragnet [Ransomware]: dragnet-ransomware-2023-4445 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 5ef916dc-019c-5021-b7e8-d50e81eae147

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
