// Dragnet [Ransomware]: dragnet-ransomware-2023-5194 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 40347273-6f8c-500b-a403-edec08cf3739

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
