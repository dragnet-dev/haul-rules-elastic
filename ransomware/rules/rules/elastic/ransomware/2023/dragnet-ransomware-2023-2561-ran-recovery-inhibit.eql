// Dragnet [Ransomware]: dragnet-ransomware-2023-2561 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 0873fa69-602a-58b0-b413-f1d8dd6b9c69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
