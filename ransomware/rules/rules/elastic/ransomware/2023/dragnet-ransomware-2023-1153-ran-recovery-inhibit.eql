// Dragnet [Ransomware]: dragnet-ransomware-2023-1153 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 68e249c1-b4e4-5677-9c4a-c50e96e2333d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
