// Dragnet [Ransomware]: dragnet-ransomware-2023-0821 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: ef3666f6-7e11-561c-80d2-19ce84a44c96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
