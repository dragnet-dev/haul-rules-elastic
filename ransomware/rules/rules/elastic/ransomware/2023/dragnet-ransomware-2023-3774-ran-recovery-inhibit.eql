// Dragnet [Ransomware]: dragnet-ransomware-2023-3774 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c08a3777-2555-5cee-8535-0d50dd69748b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
