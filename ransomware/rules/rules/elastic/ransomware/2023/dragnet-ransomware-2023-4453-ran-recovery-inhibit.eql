// Dragnet [Ransomware]: dragnet-ransomware-2023-4453 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f8a26788-eeb6-541c-b7e4-85047ea8e4e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
