// Dragnet [Ransomware]: dragnet-ransomware-2023-1259 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: ec01a285-203f-538a-bb32-096b38736f7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
