// Dragnet [Ransomware]: dragnet-ransomware-2023-4071 — Recovery Inhibition (rancoz)
// Status: experimental | Level: high | ID: f2ed22ad-6cec-58ee-a47a-619983c676af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
