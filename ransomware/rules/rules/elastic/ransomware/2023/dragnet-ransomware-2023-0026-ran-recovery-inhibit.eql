// Dragnet [Ransomware]: dragnet-ransomware-2023-0026 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: b353c3a7-5e8f-5f58-bb03-96feffe42e20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
