// Dragnet [Ransomware]: dragnet-ransomware-2023-2635 — Recovery Inhibition (cuba)
// Status: experimental | Level: high | ID: c2f3bc7a-69bd-5d82-a0b3-2e5904135200

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
