// Dragnet [Ransomware]: dragnet-ransomware-2023-2934 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ca038bb8-67e1-5d19-98b5-852bb41b0f18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
