// Dragnet [Ransomware]: dragnet-ransomware-2023-5006 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 0f69ab36-691b-5230-89d4-035c00e199f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
