// Dragnet [Ransomware]: dragnet-ransomware-2023-1387 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 73b93631-3d30-5f49-8424-4359e6039918

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
