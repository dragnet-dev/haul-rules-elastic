// Dragnet [Ransomware]: dragnet-ransomware-2023-3361 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 76133d29-7bea-5763-b833-d34049a0d433

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
