// Dragnet [Ransomware]: dragnet-ransomware-2023-5216 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: cbfc29c6-e485-580a-b3d5-a193599db828

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
