// Dragnet [Ransomware]: dragnet-ransomware-2023-1243 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 98565f8e-ae97-56ac-863e-dc9d2522293d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
