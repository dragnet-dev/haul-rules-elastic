// Dragnet [Ransomware]: dragnet-ransomware-2023-0400 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: d4143125-4c4b-52e2-8864-f135c1f40713

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
