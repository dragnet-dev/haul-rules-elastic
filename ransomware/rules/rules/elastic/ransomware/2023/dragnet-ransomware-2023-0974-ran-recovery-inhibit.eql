// Dragnet [Ransomware]: dragnet-ransomware-2023-0974 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 0d05276f-cd1f-57e1-97a0-153592c14b12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
