// Dragnet [Ransomware]: dragnet-ransomware-2023-1945 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: 0af4c8fb-736c-5aca-9335-1376a4889ce5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
