// Dragnet [Ransomware]: dragnet-ransomware-2023-0937 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e297ebaf-ee76-5ddc-9fdf-13832ad5ba40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
