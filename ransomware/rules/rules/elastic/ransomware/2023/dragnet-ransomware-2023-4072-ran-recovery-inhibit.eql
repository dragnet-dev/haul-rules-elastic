// Dragnet [Ransomware]: dragnet-ransomware-2023-4072 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: aec980b0-4412-5ead-b8a1-a97f4a724a63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
