// Dragnet [Ransomware]: dragnet-ransomware-2023-4355 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 06759459-0cba-5955-84db-2494ccc8ef23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
