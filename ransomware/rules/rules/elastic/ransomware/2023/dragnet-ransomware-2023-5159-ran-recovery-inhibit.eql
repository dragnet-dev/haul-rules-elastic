// Dragnet [Ransomware]: dragnet-ransomware-2023-5159 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: 5fdddd29-2ce3-55ee-97d3-88b2d7402207

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
