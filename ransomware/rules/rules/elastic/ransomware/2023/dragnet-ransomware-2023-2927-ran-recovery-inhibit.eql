// Dragnet [Ransomware]: dragnet-ransomware-2023-2927 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 17e77ec8-418a-5b48-be53-1f9b23a06b0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
