// Dragnet [Ransomware]: dragnet-ransomware-2023-1963 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ebe4e660-7a9b-52cb-830f-410261a7971c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
