// Dragnet [Ransomware]: dragnet-ransomware-2023-1389 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 64369421-e85f-53fd-87af-bd06b742987f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
