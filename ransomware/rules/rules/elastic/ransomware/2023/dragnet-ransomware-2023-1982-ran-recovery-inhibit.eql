// Dragnet [Ransomware]: dragnet-ransomware-2023-1982 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 9f290b75-f9fc-5a65-a283-3b016acdd754

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
