// Dragnet [Ransomware]: dragnet-ransomware-2023-3381 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: 60225387-ecb9-5bef-a669-fc85fac176b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
