// Dragnet [Ransomware]: dragnet-ransomware-2023-4848 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 1651646e-db05-5f7a-950c-f4f694e95124

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
