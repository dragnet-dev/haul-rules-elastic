// Dragnet [Ransomware]: dragnet-ransomware-2023-0674 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: a5fc6af1-6aac-5ee5-918d-47523e7f360a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
