// Dragnet [Ransomware]: dragnet-ransomware-2023-1139 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 73aa8cb7-14d3-540f-8fe1-4f157870c6cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
