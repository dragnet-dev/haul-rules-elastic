// Dragnet [Ransomware]: dragnet-ransomware-2023-5108 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8ce7389b-7fcf-5238-9488-2cac67ca272d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
