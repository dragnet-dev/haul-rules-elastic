// Dragnet [Ransomware]: dragnet-ransomware-2023-4821 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: fe464f67-befd-51ec-9da5-dca8496f7812

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
