// Dragnet [Ransomware]: dragnet-ransomware-2023-3258 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 72694c57-bec3-5db9-b857-6119d39be395

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
