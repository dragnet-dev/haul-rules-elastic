// Dragnet [Ransomware]: dragnet-ransomware-2023-4615 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 58e4bd50-5593-58de-9938-2ccde1a9886d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
