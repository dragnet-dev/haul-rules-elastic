// Dragnet [Ransomware]: dragnet-ransomware-2023-0001 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: bd328361-1b75-5958-a872-4bd4f564aefa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
