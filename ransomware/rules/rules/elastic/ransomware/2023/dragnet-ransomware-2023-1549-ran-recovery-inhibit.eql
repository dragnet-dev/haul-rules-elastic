// Dragnet [Ransomware]: dragnet-ransomware-2023-1549 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 12bca5d7-ef84-5ee3-a2b8-6e081d3c2087

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
