// Dragnet [Ransomware]: dragnet-ransomware-2023-3539 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 48e0ca0a-5d52-51ca-9fce-3f64fa67b569

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
