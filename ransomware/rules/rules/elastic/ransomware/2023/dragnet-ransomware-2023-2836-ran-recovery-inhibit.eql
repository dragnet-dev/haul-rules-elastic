// Dragnet [Ransomware]: dragnet-ransomware-2023-2836 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: e661fca8-388a-5c62-a381-93b2d68aec8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
