// Dragnet [Ransomware]: dragnet-ransomware-2023-3034 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 068018a7-c168-5463-b8df-0064ab712a7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
