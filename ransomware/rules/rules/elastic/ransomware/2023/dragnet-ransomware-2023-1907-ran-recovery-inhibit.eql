// Dragnet [Ransomware]: dragnet-ransomware-2023-1907 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: f0810bfe-48d9-5a80-b11a-5eb7461911fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
