// Dragnet [Ransomware]: dragnet-ransomware-2023-5109 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: c4c9d138-865e-5f7a-9ec1-fd678406843d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
