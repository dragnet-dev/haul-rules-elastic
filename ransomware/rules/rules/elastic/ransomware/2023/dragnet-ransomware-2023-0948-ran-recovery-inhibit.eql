// Dragnet [Ransomware]: dragnet-ransomware-2023-0948 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 217ec395-6a71-529f-8c86-afd0ad8ae819

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
