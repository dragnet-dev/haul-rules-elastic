// Dragnet [Ransomware]: dragnet-ransomware-2023-2584 — Recovery Inhibition (siegedsec)
// Status: experimental | Level: high | ID: fe6693f1-f65e-5db6-87cb-5f89fa05c2d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
