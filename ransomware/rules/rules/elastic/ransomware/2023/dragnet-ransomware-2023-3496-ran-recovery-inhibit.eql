// Dragnet [Ransomware]: dragnet-ransomware-2023-3496 — Recovery Inhibition (darkrace)
// Status: experimental | Level: high | ID: 3b453ed6-f4d6-584d-a7f0-0a7b6c5c0287

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
