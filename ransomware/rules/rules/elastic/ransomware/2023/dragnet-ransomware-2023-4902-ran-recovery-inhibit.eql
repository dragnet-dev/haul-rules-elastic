// Dragnet [Ransomware]: dragnet-ransomware-2023-4902 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 902bfb06-d4ac-5fa0-abcb-617a90666f52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
