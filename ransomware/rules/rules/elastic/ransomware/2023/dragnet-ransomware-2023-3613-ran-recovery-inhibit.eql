// Dragnet [Ransomware]: dragnet-ransomware-2023-3613 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 515450d5-bf1b-524d-b01c-4764488a6093

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
