// Dragnet [Ransomware]: dragnet-ransomware-2023-4743 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 669f017c-c355-56aa-9646-24cb3d365669

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
