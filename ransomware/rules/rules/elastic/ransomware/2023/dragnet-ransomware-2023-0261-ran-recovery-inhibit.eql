// Dragnet [Ransomware]: dragnet-ransomware-2023-0261 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 10018332-86d1-511a-8a60-f7508311e3eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
