// Dragnet [Ransomware]: dragnet-ransomware-2023-2350 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 35658963-8ca4-5858-985b-b578bc115988

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
