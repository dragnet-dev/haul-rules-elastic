// Dragnet [Ransomware]: dragnet-ransomware-2023-4508 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: a73060b2-52ca-5638-b411-502fa7a8fcec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
