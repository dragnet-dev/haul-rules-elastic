// Dragnet [Ransomware]: dragnet-ransomware-2023-4283 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f2cbdb21-6a76-572f-9467-4e0960e1561b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
