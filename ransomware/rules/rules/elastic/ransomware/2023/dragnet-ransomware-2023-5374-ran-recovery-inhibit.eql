// Dragnet [Ransomware]: dragnet-ransomware-2023-5374 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: f065bdd1-80f7-539b-b905-4b90356d1687

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
