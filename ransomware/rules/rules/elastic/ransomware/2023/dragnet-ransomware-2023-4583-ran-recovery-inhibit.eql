// Dragnet [Ransomware]: dragnet-ransomware-2023-4583 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 43b53722-0104-5cd7-be5f-333de14bc015

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
