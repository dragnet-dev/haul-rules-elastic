// Dragnet [Ransomware]: dragnet-ransomware-2023-1893 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3fbbe62c-a38f-597c-b2e3-a59086329192

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
