// Dragnet [Ransomware]: dragnet-ransomware-2023-2745 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 9388f33d-52c1-5ed5-9d7a-831a053a0617

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
