// Dragnet [Ransomware]: dragnet-ransomware-2023-3112 — Recovery Inhibition (moneymessage)
// Status: deprecated | Level: high | ID: af6872d4-bd7f-5916-80c8-cb5b79c77941

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
