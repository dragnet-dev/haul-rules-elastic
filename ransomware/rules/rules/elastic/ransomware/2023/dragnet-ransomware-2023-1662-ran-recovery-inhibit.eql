// Dragnet [Ransomware]: dragnet-ransomware-2023-1662 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 6471dde6-0be2-5503-99aa-331b0b9d6d19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
