// Dragnet [Ransomware]: dragnet-ransomware-2023-0820 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 27789b8d-a0c6-5d6f-89bb-ba61abb1bf6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
