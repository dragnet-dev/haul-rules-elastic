// Dragnet [Ransomware]: dragnet-ransomware-2023-1514 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: c279b5f2-494a-5e88-be5f-3d9cafe21988

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
