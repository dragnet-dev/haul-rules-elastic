// Dragnet [Ransomware]: dragnet-ransomware-2023-2583 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c978f566-13c4-51fe-bdb5-1ff2defb7e4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
