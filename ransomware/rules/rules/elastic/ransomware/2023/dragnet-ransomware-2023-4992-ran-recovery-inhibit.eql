// Dragnet [Ransomware]: dragnet-ransomware-2023-4992 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 5a8883da-2268-5ce1-bccf-7022161e4135

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
