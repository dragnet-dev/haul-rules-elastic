// Dragnet [Ransomware]: dragnet-ransomware-2023-3395 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 744514fc-bafd-5e45-ac01-7f3b2ad81316

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
