// Dragnet [Ransomware]: dragnet-ransomware-2023-0285 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: f5cd9458-39a4-5305-8a7c-511aafa82437

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
