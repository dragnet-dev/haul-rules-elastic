// Dragnet [Ransomware]: dragnet-ransomware-2023-2968 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 4dadcb42-5560-5a06-a1f5-9f68612faea3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
