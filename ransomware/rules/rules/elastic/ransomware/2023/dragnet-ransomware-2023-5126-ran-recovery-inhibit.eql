// Dragnet [Ransomware]: dragnet-ransomware-2023-5126 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 1cbd6d99-f15c-5dc9-8654-476eee9849e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
