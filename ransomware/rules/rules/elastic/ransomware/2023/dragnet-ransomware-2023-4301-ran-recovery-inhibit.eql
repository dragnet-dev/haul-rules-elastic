// Dragnet [Ransomware]: dragnet-ransomware-2023-4301 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: 4b7fd790-0177-5113-ae5e-3a47f7ca0a1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
