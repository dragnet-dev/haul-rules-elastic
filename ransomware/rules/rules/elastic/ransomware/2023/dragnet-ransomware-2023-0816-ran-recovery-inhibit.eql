// Dragnet [Ransomware]: dragnet-ransomware-2023-0816 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 980d766b-e245-599d-8f11-efb0a844ded8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
