// Dragnet [Ransomware]: dragnet-ransomware-2023-1801 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 45d38f7f-846a-5b55-ace6-537eee23e5b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
