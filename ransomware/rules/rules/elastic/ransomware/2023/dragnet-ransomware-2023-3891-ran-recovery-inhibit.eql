// Dragnet [Ransomware]: dragnet-ransomware-2023-3891 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: b7111fdb-2ea7-54e9-a704-084a6574db79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
