// Dragnet [Ransomware]: dragnet-ransomware-2023-1977 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: cebbe717-8f5e-537b-860d-6dfe79ba86c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
