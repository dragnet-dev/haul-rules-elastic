// Dragnet [Ransomware]: dragnet-ransomware-2023-4905 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5a1026fa-350e-53b9-b3c6-af6642d8ecf4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
