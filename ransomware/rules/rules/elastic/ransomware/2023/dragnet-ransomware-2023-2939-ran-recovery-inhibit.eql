// Dragnet [Ransomware]: dragnet-ransomware-2023-2939 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: bb657118-5e38-56dc-a8f2-856091a81825

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
