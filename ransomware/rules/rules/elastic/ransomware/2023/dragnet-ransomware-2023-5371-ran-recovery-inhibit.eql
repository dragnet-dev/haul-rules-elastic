// Dragnet [Ransomware]: dragnet-ransomware-2023-5371 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: 47fd808f-5754-5d6e-bea0-83b3de9ecce9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
