// Dragnet [Ransomware]: dragnet-ransomware-2023-0808 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: e3e4ee7b-9d54-545d-bc2b-485a5f937c9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
