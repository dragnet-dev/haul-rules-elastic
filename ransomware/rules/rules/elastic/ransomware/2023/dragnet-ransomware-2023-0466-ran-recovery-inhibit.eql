// Dragnet [Ransomware]: dragnet-ransomware-2023-0466 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: c61a8e3b-ce40-5150-b618-4e8d378759e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
