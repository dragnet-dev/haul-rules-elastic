// Dragnet [Ransomware]: dragnet-ransomware-2023-3495 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 575268d6-ad04-5878-9bfe-9fdc618da2fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
