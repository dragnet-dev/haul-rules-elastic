// Dragnet [Ransomware]: dragnet-ransomware-2023-4524 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 4902255f-257f-56f7-afc4-601290e07854

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
