// Dragnet [Ransomware]: dragnet-ransomware-2023-0404 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: d588ebdb-1bb8-5267-8459-7a2c962f90dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
