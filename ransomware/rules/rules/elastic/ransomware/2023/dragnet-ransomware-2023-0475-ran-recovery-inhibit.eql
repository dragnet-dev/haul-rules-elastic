// Dragnet [Ransomware]: dragnet-ransomware-2023-0475 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: c1b76fce-e1d9-50d7-877a-2d153e031a71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
