// Dragnet [Ransomware]: dragnet-ransomware-2023-3013 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ff69b7ea-dfa0-5007-af72-68084e781fbd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
