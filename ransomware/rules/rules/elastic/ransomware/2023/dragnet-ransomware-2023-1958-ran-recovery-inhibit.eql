// Dragnet [Ransomware]: dragnet-ransomware-2023-1958 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 60b768b5-b3c8-5510-ade3-03db52a34846

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
