// Dragnet [Ransomware]: dragnet-ransomware-2023-2657 — Recovery Inhibition (mallox)
// Status: experimental | Level: high | ID: dcb1adf3-af8a-5c63-8174-ed0e91940e7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
