// Dragnet [Ransomware]: dragnet-ransomware-2023-1454 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 4886e7d0-d985-592d-9ae4-6e48c5dc7e86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
