// Dragnet [Ransomware]: dragnet-ransomware-2023-2091 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: c5d96ceb-8d45-53e9-9990-d2407e30f65f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
