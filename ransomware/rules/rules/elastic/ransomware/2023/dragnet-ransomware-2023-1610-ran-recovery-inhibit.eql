// Dragnet [Ransomware]: dragnet-ransomware-2023-1610 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 65816b5d-294b-597b-9a93-d3451169d72c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
