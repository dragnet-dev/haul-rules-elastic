// Dragnet [Ransomware]: dragnet-ransomware-2023-0270 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d79596f0-7123-5f4f-a3b0-1ca93dda2a3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
