// Dragnet [Ransomware]: dragnet-ransomware-2023-0767 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: fc82d19d-3c35-551f-bc92-920569623c95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
