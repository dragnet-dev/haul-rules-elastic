// Dragnet [Ransomware]: dragnet-ransomware-2023-5204 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: b8668799-ab04-5371-ab11-2f57bc512e20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
