// Dragnet [Ransomware]: dragnet-ransomware-2023-0029 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 61f17d68-e35e-5668-a53b-33a66c0e14d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
