// Dragnet [Ransomware]: dragnet-ransomware-2023-3060 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 1912ec86-b018-50b2-b053-655070091a98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
