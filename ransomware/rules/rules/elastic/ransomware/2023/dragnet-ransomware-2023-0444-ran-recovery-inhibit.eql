// Dragnet [Ransomware]: dragnet-ransomware-2023-0444 — Recovery Inhibition (ElDorado)
// Status: experimental | Level: high | ID: 675d2095-717a-5a40-9194-0c7661b39957

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
