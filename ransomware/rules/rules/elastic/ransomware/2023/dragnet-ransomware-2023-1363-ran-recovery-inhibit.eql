// Dragnet [Ransomware]: dragnet-ransomware-2023-1363 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: 67874c21-9026-52da-9ead-f4ff48d9c08c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
