// Dragnet [Ransomware]: dragnet-ransomware-2023-1190 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 9289badf-291a-507c-91a7-beb700cfa295

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
