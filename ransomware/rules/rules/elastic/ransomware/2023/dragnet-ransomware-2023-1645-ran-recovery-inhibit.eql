// Dragnet [Ransomware]: dragnet-ransomware-2023-1645 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b2816b86-e51d-52fe-996d-2adc66611923

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
