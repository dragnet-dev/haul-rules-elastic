// Dragnet [Ransomware]: dragnet-ransomware-2023-2243 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: 05b43027-6051-5425-89d7-5277378c9ee1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
