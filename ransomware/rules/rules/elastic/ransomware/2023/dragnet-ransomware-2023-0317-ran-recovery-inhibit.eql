// Dragnet [Ransomware]: dragnet-ransomware-2023-0317 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: eacc01de-9f8a-52e5-ad28-f2e49ad92810

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
