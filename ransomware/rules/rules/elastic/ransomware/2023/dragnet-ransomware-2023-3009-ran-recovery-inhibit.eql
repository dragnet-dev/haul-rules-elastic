// Dragnet [Ransomware]: dragnet-ransomware-2023-3009 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 952d1704-1f75-5e74-90b5-bf8cd77811c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
