// Dragnet [Ransomware]: dragnet-ransomware-2023-0615 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 0cd4f579-0d56-5513-a055-c91a61bf8313

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
