// Dragnet [Ransomware]: dragnet-ransomware-2023-4170 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: d43ebbb2-6760-5b0b-953c-b2c98c3a3aa2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
