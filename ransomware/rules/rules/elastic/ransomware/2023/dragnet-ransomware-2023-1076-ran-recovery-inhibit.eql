// Dragnet [Ransomware]: dragnet-ransomware-2023-1076 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: bd3dca92-9195-5e73-a9db-44392dd4522a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
