// Dragnet [Ransomware]: dragnet-ransomware-2023-2206 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 7b9f6ef4-ca68-5f98-869b-d25914374549

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
