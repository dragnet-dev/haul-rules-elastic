// Dragnet [Ransomware]: dragnet-ransomware-2023-4459 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: d349732e-7a74-54da-b6a5-301927b3290b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
