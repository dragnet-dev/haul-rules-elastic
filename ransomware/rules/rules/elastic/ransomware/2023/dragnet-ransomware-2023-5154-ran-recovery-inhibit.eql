// Dragnet [Ransomware]: dragnet-ransomware-2023-5154 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5f435106-3653-5d58-9e42-da946be792ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
