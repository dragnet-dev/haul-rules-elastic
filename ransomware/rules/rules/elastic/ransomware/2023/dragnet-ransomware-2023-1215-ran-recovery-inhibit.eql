// Dragnet [Ransomware]: dragnet-ransomware-2023-1215 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 0091496c-5671-5055-9219-5018742755ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
