// Dragnet [Ransomware]: dragnet-ransomware-2023-5088 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: dabad903-8300-5dd1-a504-11250032e717

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
