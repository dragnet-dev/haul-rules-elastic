// Dragnet [Ransomware]: dragnet-ransomware-2023-5202 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 61b63cf3-ccc5-536c-b66a-9a6b6b4f4241

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
