// Dragnet [Ransomware]: dragnet-ransomware-2023-5358 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f0978856-4df1-5c3e-95e8-96d93ed4c432

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
