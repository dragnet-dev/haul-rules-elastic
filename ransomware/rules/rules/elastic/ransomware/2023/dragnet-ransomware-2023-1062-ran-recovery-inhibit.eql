// Dragnet [Ransomware]: dragnet-ransomware-2023-1062 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: fb723c9c-bf3d-522c-9064-3085a2c892d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
