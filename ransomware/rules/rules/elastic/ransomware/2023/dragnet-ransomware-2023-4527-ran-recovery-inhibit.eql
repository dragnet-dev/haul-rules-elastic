// Dragnet [Ransomware]: dragnet-ransomware-2023-4527 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: 7707d979-f219-5d78-87c6-865ab3e1825a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
