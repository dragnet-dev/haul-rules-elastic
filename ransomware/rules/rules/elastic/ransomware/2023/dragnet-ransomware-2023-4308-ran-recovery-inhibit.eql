// Dragnet [Ransomware]: dragnet-ransomware-2023-4308 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ba2de9b8-3993-51ab-a336-178408418210

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
