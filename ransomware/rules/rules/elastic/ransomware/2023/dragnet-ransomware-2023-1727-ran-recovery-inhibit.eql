// Dragnet [Ransomware]: dragnet-ransomware-2023-1727 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 3dd1c743-213f-5bf4-88d5-eedd8843a2fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
