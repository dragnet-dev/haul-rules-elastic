// Dragnet [Ransomware]: dragnet-ransomware-2023-2366 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d0a909e2-1115-5c75-9854-3be6c90d32b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
