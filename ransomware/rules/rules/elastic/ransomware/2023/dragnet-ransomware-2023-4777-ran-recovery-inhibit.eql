// Dragnet [Ransomware]: dragnet-ransomware-2023-4777 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f295c74d-7514-56fe-89d7-f952ceedb921

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
