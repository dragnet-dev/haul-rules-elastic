// Dragnet [Ransomware]: dragnet-ransomware-2023-4648 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f0211525-7349-528f-acfb-79526566fb0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
