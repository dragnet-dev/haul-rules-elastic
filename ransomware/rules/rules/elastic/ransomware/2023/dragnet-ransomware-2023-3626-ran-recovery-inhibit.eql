// Dragnet [Ransomware]: dragnet-ransomware-2023-3626 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 35762937-a503-5928-a82f-3b4818e9dcbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
