// Dragnet [Ransomware]: dragnet-ransomware-2023-1336 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 8b8083b3-5b5c-5278-8a6d-f08cbf7fd22a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
