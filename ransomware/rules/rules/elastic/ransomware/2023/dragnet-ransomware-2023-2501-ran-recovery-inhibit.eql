// Dragnet [Ransomware]: dragnet-ransomware-2023-2501 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6b480923-279d-5237-b3ba-5d938303f192

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
