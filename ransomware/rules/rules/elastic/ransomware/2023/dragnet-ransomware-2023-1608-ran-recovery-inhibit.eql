// Dragnet [Ransomware]: dragnet-ransomware-2023-1608 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 945ae568-50e2-5afb-8467-2a6016a78889

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
