// Dragnet [Ransomware]: dragnet-ransomware-2023-4627 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7e04389f-0762-5e7b-bb01-d1f9d8cafb55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
