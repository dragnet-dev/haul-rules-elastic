// Dragnet [Ransomware]: dragnet-ransomware-2023-2539 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: de1abfd7-db3c-5247-ac4d-4895fdcac564

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
