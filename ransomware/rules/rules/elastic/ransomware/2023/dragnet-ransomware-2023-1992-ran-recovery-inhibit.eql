// Dragnet [Ransomware]: dragnet-ransomware-2023-1992 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7637cfb3-b33e-5c86-962e-b07c90bede57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
