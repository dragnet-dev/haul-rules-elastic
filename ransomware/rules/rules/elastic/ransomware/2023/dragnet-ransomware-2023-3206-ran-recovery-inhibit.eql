// Dragnet [Ransomware]: dragnet-ransomware-2023-3206 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 6834ccf4-b608-539b-858f-2dbb41dced43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
