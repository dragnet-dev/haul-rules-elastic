// Dragnet [Ransomware]: dragnet-ransomware-2023-3550 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 52de055e-a700-555f-9592-56d33e84afac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
