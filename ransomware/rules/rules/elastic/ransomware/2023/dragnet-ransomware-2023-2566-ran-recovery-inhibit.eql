// Dragnet [Ransomware]: dragnet-ransomware-2023-2566 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: e8f19d56-59d3-517a-b860-876e464ee42a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
