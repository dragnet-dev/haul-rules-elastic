// Dragnet [Ransomware]: dragnet-ransomware-2023-0367 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 587b3f6c-e749-5b9f-8f9c-900401555f97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
