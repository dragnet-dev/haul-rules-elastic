// Dragnet [Ransomware]: dragnet-ransomware-2023-0758 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: df2b1a68-49bb-5ed1-ae60-a8dec6eb7a23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
