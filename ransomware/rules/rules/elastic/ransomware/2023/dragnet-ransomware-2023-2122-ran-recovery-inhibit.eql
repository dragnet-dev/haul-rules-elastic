// Dragnet [Ransomware]: dragnet-ransomware-2023-2122 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e606fdce-fe86-505b-b3c5-cf68e4414f57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
