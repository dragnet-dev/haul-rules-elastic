// Dragnet [Ransomware]: dragnet-ransomware-2023-0442 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8951705f-8100-5efb-9268-c3cf599c2377

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
