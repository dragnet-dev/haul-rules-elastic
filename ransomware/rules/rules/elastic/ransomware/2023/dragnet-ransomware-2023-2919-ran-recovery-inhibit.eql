// Dragnet [Ransomware]: dragnet-ransomware-2023-2919 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: b30e24a9-e600-52d5-b59b-4fd15b857c67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
