// Dragnet [Ransomware]: dragnet-ransomware-2023-3269 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 19d3216d-52a9-51f8-bb26-51f075ca9e2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
