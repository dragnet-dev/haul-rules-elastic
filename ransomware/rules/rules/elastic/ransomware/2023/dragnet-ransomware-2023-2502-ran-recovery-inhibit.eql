// Dragnet [Ransomware]: dragnet-ransomware-2023-2502 — Recovery Inhibition (werewolves)
// Status: experimental | Level: high | ID: 8b2404f6-5032-5e7a-890f-c936dad04d27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
