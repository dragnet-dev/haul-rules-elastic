// Dragnet [Ransomware]: dragnet-ransomware-2023-3285 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 830ccb8c-62c1-5f8c-b71a-a655d890cdd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
