// Dragnet [Ransomware]: dragnet-ransomware-2023-3312 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: 907c0a46-acef-56ab-ab84-afc9e667e8ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
