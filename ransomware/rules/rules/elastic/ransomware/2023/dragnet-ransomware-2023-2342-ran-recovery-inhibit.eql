// Dragnet [Ransomware]: dragnet-ransomware-2023-2342 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: ddaaaf4a-72a5-568c-a68c-597cccf47176

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
