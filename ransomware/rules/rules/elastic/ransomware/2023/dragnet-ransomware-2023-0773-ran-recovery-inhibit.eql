// Dragnet [Ransomware]: dragnet-ransomware-2023-0773 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 125d2887-51ca-5540-b3ab-222dc426a33f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
