// Dragnet [Ransomware]: dragnet-ransomware-2023-0213 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 86d180e7-6b15-5a01-8ab1-5ca61cdbdb83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
