// Dragnet [Ransomware]: dragnet-ransomware-2023-5170 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: f6203e12-44f0-5750-9195-1a21b1e45e39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
