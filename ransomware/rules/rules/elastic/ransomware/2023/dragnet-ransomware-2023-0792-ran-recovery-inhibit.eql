// Dragnet [Ransomware]: dragnet-ransomware-2023-0792 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4f6a265c-4f8f-53ad-b70b-aecd9a619a0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
