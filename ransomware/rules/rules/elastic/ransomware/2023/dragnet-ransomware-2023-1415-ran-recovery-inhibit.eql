// Dragnet [Ransomware]: dragnet-ransomware-2023-1415 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 066ef809-b0a0-5cea-81f2-1e277fbb57be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
