// Dragnet [Ransomware]: dragnet-ransomware-2023-3294 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 45613ce3-f06e-558c-8e26-8f8dd264067b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
