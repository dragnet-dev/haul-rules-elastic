// Dragnet [Ransomware]: dragnet-ransomware-2023-4714 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: da7b6e74-cd06-54bc-bc7c-95ba41b1fa5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
