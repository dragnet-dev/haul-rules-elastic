// Dragnet [Ransomware]: dragnet-ransomware-2023-1179 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 79f53beb-f160-56d1-9681-64ff81f80a37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
