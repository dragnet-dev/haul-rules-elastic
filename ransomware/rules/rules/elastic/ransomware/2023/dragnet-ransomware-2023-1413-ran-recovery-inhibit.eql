// Dragnet [Ransomware]: dragnet-ransomware-2023-1413 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: eb5ae2f0-a8bc-5e21-bbc8-a585c60efecf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
