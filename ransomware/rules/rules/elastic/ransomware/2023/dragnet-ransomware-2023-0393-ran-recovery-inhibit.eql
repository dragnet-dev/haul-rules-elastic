// Dragnet [Ransomware]: dragnet-ransomware-2023-0393 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 3cc09895-cd65-56af-b4c1-cd2d7fecba6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
