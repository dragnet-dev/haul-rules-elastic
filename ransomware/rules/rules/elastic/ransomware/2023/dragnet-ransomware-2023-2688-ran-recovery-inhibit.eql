// Dragnet [Ransomware]: dragnet-ransomware-2023-2688 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ad65de17-a57f-5cca-88af-3284e6267935

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
