// Dragnet [Ransomware]: dragnet-ransomware-2023-4738 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8fc2dc80-690a-50cc-a870-d7bf0830c20b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
