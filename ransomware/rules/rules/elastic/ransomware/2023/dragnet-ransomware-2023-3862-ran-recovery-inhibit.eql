// Dragnet [Ransomware]: dragnet-ransomware-2023-3862 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: 49f264c0-ffe2-5771-94c9-c05c75b50731

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
