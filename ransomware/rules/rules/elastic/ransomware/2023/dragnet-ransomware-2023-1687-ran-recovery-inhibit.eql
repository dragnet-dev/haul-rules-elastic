// Dragnet [Ransomware]: dragnet-ransomware-2023-1687 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 64ed8406-5c51-54cd-a111-26fc77212de8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
