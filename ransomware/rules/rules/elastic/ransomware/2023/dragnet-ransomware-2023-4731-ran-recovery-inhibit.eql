// Dragnet [Ransomware]: dragnet-ransomware-2023-4731 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 874bd82e-fc0e-5f46-8e45-e15e3e24f61f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
