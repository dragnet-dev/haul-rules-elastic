// Dragnet [Ransomware]: dragnet-ransomware-2023-3622 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f5d073ce-27e5-5838-bf4a-6584ef626477

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
