// Dragnet [Ransomware]: dragnet-ransomware-2023-0968 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d7b73038-40c0-5939-a15b-b5e45bfed002

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
