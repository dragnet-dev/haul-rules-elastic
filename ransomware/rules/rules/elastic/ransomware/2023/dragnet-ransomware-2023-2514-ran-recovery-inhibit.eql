// Dragnet [Ransomware]: dragnet-ransomware-2023-2514 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 75d923aa-36af-5216-8aa4-fbeffb0c9133

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
