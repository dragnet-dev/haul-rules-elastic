// Dragnet [Ransomware]: dragnet-ransomware-2023-4364 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: b3e55614-f570-58d8-836e-da0ac403b5f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
