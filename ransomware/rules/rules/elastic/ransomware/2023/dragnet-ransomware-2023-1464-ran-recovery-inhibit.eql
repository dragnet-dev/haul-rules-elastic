// Dragnet [Ransomware]: dragnet-ransomware-2023-1464 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a59071b0-ac1b-592f-b077-7ff5bf1c4cca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
