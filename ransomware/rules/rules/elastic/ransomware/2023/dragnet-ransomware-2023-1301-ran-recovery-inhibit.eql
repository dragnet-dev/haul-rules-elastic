// Dragnet [Ransomware]: dragnet-ransomware-2023-1301 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 3ef9248b-70f4-52c1-a083-a1b793715d47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
