// Dragnet [Ransomware]: dragnet-ransomware-2023-1405 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 4cd70fd4-e109-516e-8815-40215009294f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
