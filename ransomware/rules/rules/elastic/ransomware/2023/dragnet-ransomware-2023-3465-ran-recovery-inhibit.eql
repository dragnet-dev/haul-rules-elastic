// Dragnet [Ransomware]: dragnet-ransomware-2023-3465 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: f1a4cdf3-3c7f-5fc2-b2c0-7493ee32296e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
