// Dragnet [Ransomware]: dragnet-ransomware-2023-4179 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: ea4bfc69-de4d-5385-86c2-b63930408fbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
