// Dragnet [Ransomware]: dragnet-ransomware-2023-0114 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 1fc8401b-6271-57fa-a43b-9cde2df9408c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
