// Dragnet [Ransomware]: dragnet-ransomware-2023-3960 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 0de4bab8-2958-5213-9a9c-6adb4a4198c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
