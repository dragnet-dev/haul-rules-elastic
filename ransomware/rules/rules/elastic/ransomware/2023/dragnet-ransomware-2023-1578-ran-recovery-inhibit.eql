// Dragnet [Ransomware]: dragnet-ransomware-2023-1578 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 852b39e4-8d0b-54db-8cfa-b9ee5a31aeae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
