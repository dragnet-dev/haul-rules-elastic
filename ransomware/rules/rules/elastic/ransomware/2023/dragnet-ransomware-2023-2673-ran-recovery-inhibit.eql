// Dragnet [Ransomware]: dragnet-ransomware-2023-2673 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 78b7a96a-cfe2-57d0-be51-d1f918461fb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
