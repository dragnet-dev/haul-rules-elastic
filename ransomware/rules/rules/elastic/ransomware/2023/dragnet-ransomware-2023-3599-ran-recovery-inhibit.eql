// Dragnet [Ransomware]: dragnet-ransomware-2023-3599 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: a5b3f6e0-9163-580b-a959-d92259bdf6e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
