// Dragnet [Ransomware]: dragnet-ransomware-2023-2005 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a0ea0f07-bfda-5600-aa95-0398a18ca53a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
