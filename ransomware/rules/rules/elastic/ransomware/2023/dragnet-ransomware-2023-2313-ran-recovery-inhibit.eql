// Dragnet [Ransomware]: dragnet-ransomware-2023-2313 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: acbcb112-7789-508b-a37a-ddaa7cddebf4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
