// Dragnet [Ransomware]: dragnet-ransomware-2023-3710 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 2aa8a53e-229f-5bed-a6df-c278827856e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
