// Dragnet [Ransomware]: dragnet-ransomware-2023-3076 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 79da2bbd-41ed-558c-a733-0747d8421513

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
