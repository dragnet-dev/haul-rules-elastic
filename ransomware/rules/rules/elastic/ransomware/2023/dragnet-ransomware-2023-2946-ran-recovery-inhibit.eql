// Dragnet [Ransomware]: dragnet-ransomware-2023-2946 — Recovery Inhibition (siegedsec)
// Status: deprecated | Level: high | ID: cd4dfc0d-de2e-519f-8180-f00fb664c60c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
