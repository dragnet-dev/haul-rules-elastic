// Dragnet [Ransomware]: dragnet-ransomware-2023-1154 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: b4659d4f-eb4b-5869-b691-b637a9b8755e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
