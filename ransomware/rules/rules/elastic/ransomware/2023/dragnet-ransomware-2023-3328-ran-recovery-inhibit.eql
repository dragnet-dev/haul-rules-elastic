// Dragnet [Ransomware]: dragnet-ransomware-2023-3328 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: bdd56c05-edb0-5806-aa1f-15c1c94d7e16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
