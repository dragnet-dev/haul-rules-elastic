// Dragnet [Ransomware]: dragnet-ransomware-2023-2916 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e48dcdac-c3fe-5094-bb35-5b6a97ef0b3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
