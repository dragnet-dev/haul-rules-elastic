// Dragnet [Ransomware]: dragnet-ransomware-2023-4942 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 78465b95-cfb0-5558-bda9-5b794c87d805

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
