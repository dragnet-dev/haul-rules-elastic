// Dragnet [Ransomware]: dragnet-ransomware-2023-3352 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 4b530bc0-c4cb-5c0e-995a-adeb58e36bcf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
