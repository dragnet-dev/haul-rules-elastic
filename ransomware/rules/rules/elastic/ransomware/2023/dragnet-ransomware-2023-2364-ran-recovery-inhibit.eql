// Dragnet [Ransomware]: dragnet-ransomware-2023-2364 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: bbc76414-fee7-5305-aec8-bff80943c68b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
