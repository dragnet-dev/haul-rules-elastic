// Dragnet [Ransomware]: dragnet-ransomware-2023-3478 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 3c25c077-a9f5-547c-9433-1a96d221b628

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
