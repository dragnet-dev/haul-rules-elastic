// Dragnet [Ransomware]: dragnet-ransomware-2023-1916 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a0b889bc-b43f-55f5-a16e-9bf7948127ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
