// Dragnet [Ransomware]: dragnet-ransomware-2023-4444 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: d0f3194c-9dde-5712-9b05-ad52e30cc4c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
