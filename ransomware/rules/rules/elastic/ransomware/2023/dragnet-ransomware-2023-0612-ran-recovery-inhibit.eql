// Dragnet [Ransomware]: dragnet-ransomware-2023-0612 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 91906441-63bb-5219-aa4b-1ff0c96ada42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
