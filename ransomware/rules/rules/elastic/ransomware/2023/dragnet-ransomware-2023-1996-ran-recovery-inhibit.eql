// Dragnet [Ransomware]: dragnet-ransomware-2023-1996 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: 934e8f0d-77e8-5dc9-8906-e1e85bb687ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
