// Dragnet [Ransomware]: dragnet-ransomware-2023-2412 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ccf284e4-c02e-588a-851c-dee414b3db44

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
