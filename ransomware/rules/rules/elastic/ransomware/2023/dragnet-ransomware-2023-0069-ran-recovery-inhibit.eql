// Dragnet [Ransomware]: dragnet-ransomware-2023-0069 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: 1fa2b395-bc5b-5dd2-b5ce-0ccf4cefcc5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
