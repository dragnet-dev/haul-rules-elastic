// Dragnet [Ransomware]: dragnet-ransomware-2023-1187 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3dd38e99-5cbc-515d-9704-d015cd682c1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
