// Dragnet [Ransomware]: dragnet-ransomware-2023-2983 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: eec8c74d-a104-52c8-ac9c-490c7ec10d0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
