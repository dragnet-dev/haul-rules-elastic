// Dragnet [Ransomware]: dragnet-ransomware-2023-2171 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: bf482379-c1fa-52a0-8685-b8c4068f85d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
