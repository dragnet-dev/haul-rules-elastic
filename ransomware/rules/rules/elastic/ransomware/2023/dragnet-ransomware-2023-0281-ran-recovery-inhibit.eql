// Dragnet [Ransomware]: dragnet-ransomware-2023-0281 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9aa249b1-111a-5227-8bb2-4d9b4f01ed5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
