// Dragnet [Ransomware]: dragnet-ransomware-2023-0462 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 63e2d6e0-9eb8-5166-a8b4-914f10c30644

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
