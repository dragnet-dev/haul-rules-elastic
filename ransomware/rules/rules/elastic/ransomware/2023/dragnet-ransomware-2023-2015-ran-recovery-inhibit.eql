// Dragnet [Ransomware]: dragnet-ransomware-2023-2015 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: 6e01ccf5-fc2a-5875-839a-e0e3ab43ddff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
