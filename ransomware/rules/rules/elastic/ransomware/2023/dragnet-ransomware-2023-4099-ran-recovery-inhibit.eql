// Dragnet [Ransomware]: dragnet-ransomware-2023-4099 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c4b02fda-bf84-5036-b185-45419cb505a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
