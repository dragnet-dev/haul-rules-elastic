// Dragnet [Ransomware]: dragnet-ransomware-2023-2390 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: c3c01ee8-48b2-5ea7-8600-2301f27e7754

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
