// Dragnet [Ransomware]: dragnet-ransomware-2023-3397 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 93d1d625-8acd-5918-9f6e-10653f602378

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
