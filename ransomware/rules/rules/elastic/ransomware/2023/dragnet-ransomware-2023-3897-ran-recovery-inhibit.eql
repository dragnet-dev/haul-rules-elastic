// Dragnet [Ransomware]: dragnet-ransomware-2023-3897 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 4a62d90b-1068-5ea9-937e-344611f6efb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
