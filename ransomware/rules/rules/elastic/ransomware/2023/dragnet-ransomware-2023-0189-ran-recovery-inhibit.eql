// Dragnet [Ransomware]: dragnet-ransomware-2023-0189 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 0f4b697d-d873-5188-953b-ecc2aa7c6374

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
