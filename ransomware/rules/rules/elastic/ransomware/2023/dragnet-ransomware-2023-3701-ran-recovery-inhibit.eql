// Dragnet [Ransomware]: dragnet-ransomware-2023-3701 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 698e1e40-3cfd-5b50-997c-01658eaece7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
