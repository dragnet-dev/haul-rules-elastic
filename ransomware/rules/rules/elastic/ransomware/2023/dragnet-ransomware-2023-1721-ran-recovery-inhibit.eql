// Dragnet [Ransomware]: dragnet-ransomware-2023-1721 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: f3f2ef77-4642-5239-b232-dfea17a6c12d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
