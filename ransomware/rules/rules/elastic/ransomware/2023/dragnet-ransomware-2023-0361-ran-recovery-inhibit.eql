// Dragnet [Ransomware]: dragnet-ransomware-2023-0361 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 2a2605a3-1617-59f6-9c87-5398da82bb94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
