// Dragnet [Ransomware]: dragnet-ransomware-2023-1818 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 41a43a87-275f-5239-b6ad-17686776b39d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
