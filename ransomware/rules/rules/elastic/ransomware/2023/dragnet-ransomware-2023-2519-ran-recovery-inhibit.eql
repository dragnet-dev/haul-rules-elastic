// Dragnet [Ransomware]: dragnet-ransomware-2023-2519 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c4805da8-a06c-5b2b-9a11-3eaa6b45eb2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
