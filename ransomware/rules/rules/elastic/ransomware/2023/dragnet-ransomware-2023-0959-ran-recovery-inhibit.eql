// Dragnet [Ransomware]: dragnet-ransomware-2023-0959 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: a0c39ff2-0e13-5f2f-b9bc-7d81e79a3af3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
