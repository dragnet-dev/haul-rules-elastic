// Dragnet [Ransomware]: dragnet-ransomware-2023-3463 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 97cd0f83-64bd-56c9-8f52-50fef6a5b5a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
