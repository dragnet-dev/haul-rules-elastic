// Dragnet [Ransomware]: dragnet-ransomware-2023-4562 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 6f4ba8ef-4bf4-5c98-99f9-4446cd509972

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
