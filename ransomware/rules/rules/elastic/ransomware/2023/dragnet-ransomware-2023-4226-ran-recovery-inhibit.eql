// Dragnet [Ransomware]: dragnet-ransomware-2023-4226 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 57c76533-c95e-5553-84a6-223f28266d54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
