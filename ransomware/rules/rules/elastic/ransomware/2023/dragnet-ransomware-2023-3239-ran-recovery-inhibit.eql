// Dragnet [Ransomware]: dragnet-ransomware-2023-3239 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 890acf94-5123-5544-83cf-2d85ddfe754e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
