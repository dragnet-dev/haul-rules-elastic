// Dragnet [Ransomware]: dragnet-ransomware-2023-0351 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0d19a062-5402-520c-a952-6f119c92c1a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
