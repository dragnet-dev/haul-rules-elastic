// Dragnet [Ransomware]: dragnet-ransomware-2023-4982 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 64780722-d5cb-53d3-b821-db9d5af36710

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
