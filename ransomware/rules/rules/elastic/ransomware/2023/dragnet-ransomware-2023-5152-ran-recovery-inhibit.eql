// Dragnet [Ransomware]: dragnet-ransomware-2023-5152 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 13b505d7-c72d-5ed3-9f4d-8eb6a04c4536

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
