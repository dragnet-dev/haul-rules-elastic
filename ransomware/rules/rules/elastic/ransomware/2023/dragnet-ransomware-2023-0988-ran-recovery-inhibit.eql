// Dragnet [Ransomware]: dragnet-ransomware-2023-0988 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 794cff3e-3377-564a-9a04-4777f50e874b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
