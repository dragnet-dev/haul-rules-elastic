// Dragnet [Ransomware]: dragnet-ransomware-2023-0984 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7ed0a727-d194-5170-96ea-58988dff63d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
