// Dragnet [Ransomware]: dragnet-ransomware-2023-3414 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 68b81ffe-bb8c-5dd7-b8e9-65d7dccb4d90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
