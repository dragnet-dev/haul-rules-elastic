// Dragnet [Ransomware]: dragnet-ransomware-2023-1621 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: defe898d-4d44-55f8-abf1-6772d0153757

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
