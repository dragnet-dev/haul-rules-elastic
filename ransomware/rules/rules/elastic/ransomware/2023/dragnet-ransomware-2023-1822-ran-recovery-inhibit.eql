// Dragnet [Ransomware]: dragnet-ransomware-2023-1822 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 421b8907-d859-58b3-9e17-20cb61ef8915

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
