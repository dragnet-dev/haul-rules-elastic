// Dragnet [Ransomware]: dragnet-ransomware-2023-3004 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: c69ed5ca-5239-590a-b529-f10389f87df4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
