// Dragnet [Ransomware]: dragnet-ransomware-2023-3786 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: d6baca01-2272-569b-8165-f93a7dc5e5b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
