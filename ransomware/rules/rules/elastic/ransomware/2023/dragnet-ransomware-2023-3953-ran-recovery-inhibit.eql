// Dragnet [Ransomware]: dragnet-ransomware-2023-3953 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f8eca2b7-5960-56d8-8265-bdbfb0b01a3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
