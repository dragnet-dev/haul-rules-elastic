// Dragnet [Ransomware]: dragnet-ransomware-2023-3335 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 435ee02f-66b1-56e3-bae1-eff25a3519dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
