// Dragnet [Ransomware]: dragnet-ransomware-2023-0827 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a337a644-b88d-53ca-a06d-9703e4857d98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
