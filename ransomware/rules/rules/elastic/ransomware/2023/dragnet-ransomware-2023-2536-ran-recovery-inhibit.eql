// Dragnet [Ransomware]: dragnet-ransomware-2023-2536 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 30f4956e-a31f-524d-b44a-932dad499eeb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
