// Dragnet [Ransomware]: dragnet-ransomware-2023-2628 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 13478333-476c-53da-890f-74adbb88a5fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
