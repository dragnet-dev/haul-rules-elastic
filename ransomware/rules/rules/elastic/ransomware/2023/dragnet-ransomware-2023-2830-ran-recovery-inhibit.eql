// Dragnet [Ransomware]: dragnet-ransomware-2023-2830 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 03d7b6eb-0470-52d2-994a-3423aba4ac78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
