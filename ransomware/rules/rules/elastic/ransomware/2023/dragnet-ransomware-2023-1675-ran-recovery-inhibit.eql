// Dragnet [Ransomware]: dragnet-ransomware-2023-1675 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 7a77230f-d192-51aa-b63d-f177c2c72e67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
