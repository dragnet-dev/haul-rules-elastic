// Dragnet [Ransomware]: dragnet-ransomware-2023-5022 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: c2aefabd-8232-5964-b80a-41822d0b5e52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
