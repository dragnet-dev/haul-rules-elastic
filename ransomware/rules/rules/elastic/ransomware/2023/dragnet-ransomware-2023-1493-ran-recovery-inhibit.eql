// Dragnet [Ransomware]: dragnet-ransomware-2023-1493 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 823ce2fd-1190-5201-9813-8e74440075ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
