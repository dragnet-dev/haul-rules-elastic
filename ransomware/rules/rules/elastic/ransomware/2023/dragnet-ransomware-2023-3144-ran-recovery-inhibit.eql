// Dragnet [Ransomware]: dragnet-ransomware-2023-3144 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 03e37057-1ec6-5c4f-b71d-4124934281f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
