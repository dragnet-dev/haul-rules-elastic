// Dragnet [Ransomware]: dragnet-ransomware-2023-4186 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 22fba2ec-b315-5dce-a713-679b2160fe96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
