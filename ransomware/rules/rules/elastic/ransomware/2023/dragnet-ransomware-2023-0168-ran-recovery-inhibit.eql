// Dragnet [Ransomware]: dragnet-ransomware-2023-0168 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 2e7dd98f-2cec-5420-8052-283edbc2ae10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
