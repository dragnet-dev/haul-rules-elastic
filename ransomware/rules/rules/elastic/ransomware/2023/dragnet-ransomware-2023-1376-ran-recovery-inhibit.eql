// Dragnet [Ransomware]: dragnet-ransomware-2023-1376 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 17832d15-7de3-5eba-92c0-bbdc2237931b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
