// Dragnet [Ransomware]: dragnet-ransomware-2023-4736 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: 000986fe-7f70-5ba2-9ec5-2463c6d99285

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
