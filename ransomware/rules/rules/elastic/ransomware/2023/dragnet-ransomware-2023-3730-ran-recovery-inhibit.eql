// Dragnet [Ransomware]: dragnet-ransomware-2023-3730 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 536743bc-6feb-5ec8-98ea-605722ea31af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
