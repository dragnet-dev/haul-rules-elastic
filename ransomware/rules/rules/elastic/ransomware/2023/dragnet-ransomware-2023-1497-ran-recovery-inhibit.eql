// Dragnet [Ransomware]: dragnet-ransomware-2023-1497 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 7fedba18-9267-52ba-8a73-50b558ff33a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
