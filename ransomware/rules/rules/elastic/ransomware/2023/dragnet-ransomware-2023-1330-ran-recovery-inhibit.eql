// Dragnet [Ransomware]: dragnet-ransomware-2023-1330 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: 1df65abc-72c9-5c13-a404-23031c2b6200

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
