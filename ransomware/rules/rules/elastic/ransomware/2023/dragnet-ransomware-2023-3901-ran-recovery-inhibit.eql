// Dragnet [Ransomware]: dragnet-ransomware-2023-3901 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 7173fa51-80fb-534b-9e7f-9620bef0a9fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
