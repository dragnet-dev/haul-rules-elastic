// Dragnet [Ransomware]: dragnet-ransomware-2023-3306 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: bb48086a-5f01-5aab-b6be-d09d5a46b247

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
