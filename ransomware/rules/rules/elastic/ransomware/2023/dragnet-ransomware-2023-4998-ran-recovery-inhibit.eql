// Dragnet [Ransomware]: dragnet-ransomware-2023-4998 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c185cc72-9c89-5b25-a81e-49fdfa7bfe4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
