// Dragnet [Ransomware]: dragnet-ransomware-2023-0812 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 15700a85-b049-5d8a-baee-9d5661028968

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
