// Dragnet [Ransomware]: dragnet-ransomware-2023-3338 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: dfb0d877-c9a6-53fe-ae1b-62d0df96b3a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
