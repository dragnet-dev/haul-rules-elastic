// Dragnet [Ransomware]: dragnet-ransomware-2023-2294 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: abe97002-6676-5648-b443-c91de1f339c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
