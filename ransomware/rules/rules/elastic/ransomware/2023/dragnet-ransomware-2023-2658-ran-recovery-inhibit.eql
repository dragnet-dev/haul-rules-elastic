// Dragnet [Ransomware]: dragnet-ransomware-2023-2658 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: 2f0eb341-0270-5c42-8720-2ccce4d36002

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
