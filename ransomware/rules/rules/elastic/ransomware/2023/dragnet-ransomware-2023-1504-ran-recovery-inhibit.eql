// Dragnet [Ransomware]: dragnet-ransomware-2023-1504 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 1c678d7c-d4a2-5e74-915b-c384f51b67dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
