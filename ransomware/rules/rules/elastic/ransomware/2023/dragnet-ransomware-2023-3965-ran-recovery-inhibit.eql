// Dragnet [Ransomware]: dragnet-ransomware-2023-3965 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 54dda77a-f2bc-5d08-bb98-378cdafa4201

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
