// Dragnet [Ransomware]: dragnet-ransomware-2023-3512 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 0618a76b-803d-51f9-8783-fcefc336ff38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
