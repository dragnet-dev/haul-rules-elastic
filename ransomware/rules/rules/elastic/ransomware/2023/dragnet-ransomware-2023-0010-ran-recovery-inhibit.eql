// Dragnet [Ransomware]: dragnet-ransomware-2023-0010 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 981ff5a5-47b6-50ab-8974-fe20585a0e3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
