// Dragnet [Ransomware]: dragnet-ransomware-2023-2608 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 6b27ae39-f68f-5132-9f85-0f42900433fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
