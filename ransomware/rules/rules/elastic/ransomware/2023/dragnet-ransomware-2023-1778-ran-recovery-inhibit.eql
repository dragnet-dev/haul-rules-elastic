// Dragnet [Ransomware]: dragnet-ransomware-2023-1778 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 40d04119-e494-5330-81a6-a20d5bdc5755

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
