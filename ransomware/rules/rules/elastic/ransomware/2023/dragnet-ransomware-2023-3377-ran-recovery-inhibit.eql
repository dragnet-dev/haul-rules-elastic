// Dragnet [Ransomware]: dragnet-ransomware-2023-3377 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 8f4a4911-c617-57e4-a601-0648cae0ecb3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
