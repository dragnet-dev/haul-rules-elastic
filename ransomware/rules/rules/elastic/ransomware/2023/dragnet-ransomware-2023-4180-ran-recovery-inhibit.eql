// Dragnet [Ransomware]: dragnet-ransomware-2023-4180 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 2f1ee25f-d8b5-55d0-89c3-f93debf5dd68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
