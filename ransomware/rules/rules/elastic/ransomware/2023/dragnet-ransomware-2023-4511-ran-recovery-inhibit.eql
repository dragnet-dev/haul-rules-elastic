// Dragnet [Ransomware]: dragnet-ransomware-2023-4511 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 5068471f-1274-5153-a4ac-fd30986f356a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
