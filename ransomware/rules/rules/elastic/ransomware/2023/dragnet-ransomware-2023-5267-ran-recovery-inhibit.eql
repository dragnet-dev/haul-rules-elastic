// Dragnet [Ransomware]: dragnet-ransomware-2023-5267 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 87879318-0562-5ed7-a005-2d0250904ae5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
