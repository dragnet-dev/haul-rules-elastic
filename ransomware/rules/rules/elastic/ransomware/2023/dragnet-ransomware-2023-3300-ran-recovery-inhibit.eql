// Dragnet [Ransomware]: dragnet-ransomware-2023-3300 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: bd1a0d1f-d8d5-5076-a1d7-ebf60501e8f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
