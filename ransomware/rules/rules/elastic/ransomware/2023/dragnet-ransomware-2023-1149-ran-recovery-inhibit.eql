// Dragnet [Ransomware]: dragnet-ransomware-2023-1149 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: e6eccb37-e418-5784-826b-18d6b5b44a53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
