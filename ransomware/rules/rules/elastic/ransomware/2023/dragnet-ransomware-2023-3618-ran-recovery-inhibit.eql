// Dragnet [Ransomware]: dragnet-ransomware-2023-3618 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 6a470d22-a0ec-565c-9758-a41a27db29c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
