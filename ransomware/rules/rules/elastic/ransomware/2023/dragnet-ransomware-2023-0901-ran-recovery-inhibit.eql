// Dragnet [Ransomware]: dragnet-ransomware-2023-0901 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: c9586f73-7826-5f91-af8b-156369a14369

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
