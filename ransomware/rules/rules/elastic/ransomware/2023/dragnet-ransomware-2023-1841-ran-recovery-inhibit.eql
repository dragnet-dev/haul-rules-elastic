// Dragnet [Ransomware]: dragnet-ransomware-2023-1841 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 16589548-0bf9-5f1a-96a3-c3e83901f379

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
