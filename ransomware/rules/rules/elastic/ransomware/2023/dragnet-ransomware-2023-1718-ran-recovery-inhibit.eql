// Dragnet [Ransomware]: dragnet-ransomware-2023-1718 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 7114b50e-f6b7-5ca9-a9c0-3bd7fb668533

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
