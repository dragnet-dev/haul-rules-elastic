// Dragnet [Ransomware]: dragnet-ransomware-2023-5223 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 2353262d-8601-521d-8028-797e4e53ef92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
