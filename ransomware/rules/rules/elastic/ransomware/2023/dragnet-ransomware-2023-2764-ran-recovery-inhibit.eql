// Dragnet [Ransomware]: dragnet-ransomware-2023-2764 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 8423934a-3c4c-5784-b4b7-1362c0c8cce8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
