// Dragnet [Ransomware]: dragnet-ransomware-2023-0670 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 92eacc9c-f79d-538a-a260-f352ddf8ed6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
