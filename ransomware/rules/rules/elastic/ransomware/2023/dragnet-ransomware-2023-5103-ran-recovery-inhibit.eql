// Dragnet [Ransomware]: dragnet-ransomware-2023-5103 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: c027875a-f78d-5b64-8a75-162eb65151b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
