// Dragnet [Ransomware]: dragnet-ransomware-2023-0550 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 271911d6-ac4f-5a57-be21-f592398f49b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
