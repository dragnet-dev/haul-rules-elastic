// Dragnet [Ransomware]: dragnet-ransomware-2023-1813 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 725bfd6c-8959-5e0b-8937-7d170631e196

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
