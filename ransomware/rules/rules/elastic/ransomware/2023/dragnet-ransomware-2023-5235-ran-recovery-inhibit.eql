// Dragnet [Ransomware]: dragnet-ransomware-2023-5235 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: c3080dbc-bb01-5803-a463-b0911c5ebd6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
