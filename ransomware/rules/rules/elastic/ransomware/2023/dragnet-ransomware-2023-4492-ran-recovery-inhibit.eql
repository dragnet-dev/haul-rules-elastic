// Dragnet [Ransomware]: dragnet-ransomware-2023-4492 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 9b5e7ebf-249d-53af-aa45-d81c1142bc27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
