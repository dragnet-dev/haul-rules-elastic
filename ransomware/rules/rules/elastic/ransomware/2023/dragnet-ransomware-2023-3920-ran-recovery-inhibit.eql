// Dragnet [Ransomware]: dragnet-ransomware-2023-3920 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 45dc0f3c-cb93-5858-8fdd-4936a7f32751

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
