// Dragnet [Ransomware]: dragnet-ransomware-2023-4139 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 86678b40-b4d5-5e59-86cc-696f10f9cac4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
