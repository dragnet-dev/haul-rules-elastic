// Dragnet [Ransomware]: dragnet-ransomware-2023-5023 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 4ed179dc-64c5-5773-966a-fd1825231b82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
