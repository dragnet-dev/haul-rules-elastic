// Dragnet [Ransomware]: dragnet-ransomware-2023-1849 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 15b064ea-04ea-5836-8289-fe66ba1087cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
