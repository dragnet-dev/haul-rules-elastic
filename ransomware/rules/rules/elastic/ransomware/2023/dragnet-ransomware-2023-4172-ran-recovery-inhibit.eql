// Dragnet [Ransomware]: dragnet-ransomware-2023-4172 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: cb3da4f1-4355-56f5-9340-96bf430f9974

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
