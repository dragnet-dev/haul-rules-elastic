// Dragnet [Ransomware]: dragnet-ransomware-2023-3959 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 27dedfdd-57ac-50ac-bf8d-8d06536d7b4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
