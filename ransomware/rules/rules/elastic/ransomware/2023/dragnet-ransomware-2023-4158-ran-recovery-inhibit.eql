// Dragnet [Ransomware]: dragnet-ransomware-2023-4158 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e98182d0-0292-5dab-84c2-b4d6dd32cdf8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
