// Dragnet [Ransomware]: dragnet-ransomware-2023-4127 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e1b3bc58-dd06-579b-8b9e-b9dfcde1b140

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
