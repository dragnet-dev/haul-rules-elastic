// Dragnet [Ransomware]: dragnet-ransomware-2023-2069 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: a2c3c374-680c-5eb5-a138-69a8c154fbe9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
