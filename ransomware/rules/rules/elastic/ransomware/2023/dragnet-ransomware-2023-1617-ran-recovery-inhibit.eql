// Dragnet [Ransomware]: dragnet-ransomware-2023-1617 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 202807e8-8fe1-56ab-acc9-379d7be4e3b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
