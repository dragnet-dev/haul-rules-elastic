// Dragnet [Ransomware]: dragnet-ransomware-2023-4063 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: 0810f839-5863-59f7-bd30-4d133878f42f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
