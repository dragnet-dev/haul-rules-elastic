// Dragnet [Ransomware]: dragnet-ransomware-2023-0123 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6454b9e3-c971-54ac-8aee-7bcfd1a694db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
