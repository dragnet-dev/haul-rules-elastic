// Dragnet [Ransomware]: dragnet-ransomware-2023-2434 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: 9b67c97a-c1fe-5f03-baa1-2a65d3d67575

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
