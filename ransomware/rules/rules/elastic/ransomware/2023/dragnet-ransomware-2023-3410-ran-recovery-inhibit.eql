// Dragnet [Ransomware]: dragnet-ransomware-2023-3410 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 2fd50b85-2c32-5ac3-a873-e84d5c30d01f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
