// Dragnet [Ransomware]: dragnet-ransomware-2023-0852 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 69acc78a-978b-5176-8284-90c5af5f648d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
