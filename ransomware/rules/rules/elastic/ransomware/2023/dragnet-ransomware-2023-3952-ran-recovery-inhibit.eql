// Dragnet [Ransomware]: dragnet-ransomware-2023-3952 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: 32ed40a5-c138-5792-b407-fccfe1afb577

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
