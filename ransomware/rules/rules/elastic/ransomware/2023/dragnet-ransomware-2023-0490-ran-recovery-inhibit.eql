// Dragnet [Ransomware]: dragnet-ransomware-2023-0490 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 09d82f96-6828-5e7c-a537-91efea1a0b18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
