// Dragnet [Ransomware]: dragnet-ransomware-2023-1918 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3a15f6e1-2785-5768-81a7-5c8e9a3e9cd3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
