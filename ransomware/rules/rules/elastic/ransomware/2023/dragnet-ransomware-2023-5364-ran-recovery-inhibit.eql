// Dragnet [Ransomware]: dragnet-ransomware-2023-5364 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: e63850a7-8a71-50b6-b26d-fef912d29e80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
