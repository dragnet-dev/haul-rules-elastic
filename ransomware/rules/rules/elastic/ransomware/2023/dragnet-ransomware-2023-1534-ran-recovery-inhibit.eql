// Dragnet [Ransomware]: dragnet-ransomware-2023-1534 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: aab25fd6-40b2-5bec-875a-4a8cf830ae2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
