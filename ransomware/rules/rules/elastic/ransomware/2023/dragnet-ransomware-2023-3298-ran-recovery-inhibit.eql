// Dragnet [Ransomware]: dragnet-ransomware-2023-3298 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 4d84d586-1e44-5c60-ae1b-a9f137835471

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
