// Dragnet [Ransomware]: dragnet-ransomware-2023-4277 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 70b05ce9-e615-578a-a692-2c60a931bdb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
