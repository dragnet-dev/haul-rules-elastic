// Dragnet [Ransomware]: dragnet-ransomware-2023-0754 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2c6dcb35-fdb0-5dce-ad4c-aaa1fa121b88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
