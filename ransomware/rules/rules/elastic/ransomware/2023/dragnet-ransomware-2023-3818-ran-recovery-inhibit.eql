// Dragnet [Ransomware]: dragnet-ransomware-2023-3818 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 967644ff-5a4e-52dc-94a8-7c541702d7a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
