// Dragnet [Ransomware]: dragnet-ransomware-2023-5290 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 26ae3ca8-e97f-5315-8d8b-b14f1a4caa0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
