// Dragnet [Ransomware]: dragnet-ransomware-2023-5156 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: cb333935-4c8e-5a05-aeee-fb7873c00a85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
