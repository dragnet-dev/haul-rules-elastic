// Dragnet [Ransomware]: dragnet-ransomware-2023-2526 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a5779e63-648b-535e-beab-053351ecd5a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
