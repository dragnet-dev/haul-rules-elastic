// Dragnet [Ransomware]: dragnet-ransomware-2023-4066 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 8baad889-6a3f-5d3f-b059-f21f09134793

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
