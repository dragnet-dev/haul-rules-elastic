// Dragnet [Ransomware]: dragnet-ransomware-2023-3113 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: bcd20049-bd09-5610-beb9-436b77605f43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
