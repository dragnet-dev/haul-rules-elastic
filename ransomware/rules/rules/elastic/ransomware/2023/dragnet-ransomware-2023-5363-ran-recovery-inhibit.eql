// Dragnet [Ransomware]: dragnet-ransomware-2023-5363 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 0e498b6f-4bef-5e70-98f8-8bbc2d8e1491

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
