// Dragnet [Ransomware]: dragnet-ransomware-2023-3943 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 51f40ad9-17e5-5996-9a02-6a66e474e581

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
