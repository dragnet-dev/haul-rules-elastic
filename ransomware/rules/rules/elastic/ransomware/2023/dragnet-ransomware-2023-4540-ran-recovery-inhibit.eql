// Dragnet [Ransomware]: dragnet-ransomware-2023-4540 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: a343c236-e1c8-5bb5-b725-caf8530fd180

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
