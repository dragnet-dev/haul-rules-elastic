// Dragnet [Ransomware]: dragnet-ransomware-2023-4584 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 00ae3b13-0b99-5664-918b-f4d24beffb7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
