// Dragnet [Ransomware]: dragnet-ransomware-2023-4167 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 763b400b-22c2-5237-8621-75453dcf47c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
