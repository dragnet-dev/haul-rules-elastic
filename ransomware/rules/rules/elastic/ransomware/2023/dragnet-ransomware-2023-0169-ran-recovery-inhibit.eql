// Dragnet [Ransomware]: dragnet-ransomware-2023-0169 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 93becd56-062b-559d-ba22-4de2503ed298

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
