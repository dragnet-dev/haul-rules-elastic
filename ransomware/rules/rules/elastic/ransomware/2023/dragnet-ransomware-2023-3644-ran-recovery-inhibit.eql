// Dragnet [Ransomware]: dragnet-ransomware-2023-3644 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 58c38b84-56d3-568d-97e1-8c39baa291b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
