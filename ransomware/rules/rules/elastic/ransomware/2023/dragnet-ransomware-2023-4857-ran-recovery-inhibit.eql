// Dragnet [Ransomware]: dragnet-ransomware-2023-4857 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5d20ff5f-d986-5dbf-91b7-103e169dc47a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
