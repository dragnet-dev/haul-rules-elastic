// Dragnet [Ransomware]: dragnet-ransomware-2023-4197 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 1dfa4eda-dcdf-5138-afbd-114fa070e2dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
