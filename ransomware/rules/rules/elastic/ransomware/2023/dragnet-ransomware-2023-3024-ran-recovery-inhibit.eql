// Dragnet [Ransomware]: dragnet-ransomware-2023-3024 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: aa18ba7c-9ea0-5838-80a6-e775b494df7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
