// Dragnet [Ransomware]: dragnet-ransomware-2023-3028 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: b998a465-536f-5f87-8208-1f7bc1d9f538

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
