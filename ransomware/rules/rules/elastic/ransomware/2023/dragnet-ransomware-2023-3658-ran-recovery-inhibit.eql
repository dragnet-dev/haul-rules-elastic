// Dragnet [Ransomware]: dragnet-ransomware-2023-3658 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: c2f49aca-2186-54c1-8af9-2899870d6c0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
