// Dragnet [Ransomware]: dragnet-ransomware-2023-4059 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 2acdf5b6-8f51-506c-9e54-9e611162764b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
