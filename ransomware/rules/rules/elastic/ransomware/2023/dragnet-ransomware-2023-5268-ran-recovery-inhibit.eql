// Dragnet [Ransomware]: dragnet-ransomware-2023-5268 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 5381848b-6ca4-57e6-bae2-5130c34086ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
