// Dragnet [Ransomware]: dragnet-ransomware-2023-0717 — Recovery Inhibition (0mega)
// Status: deprecated | Level: high | ID: 5146a3f6-71c0-5267-90ee-1495d7783f83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
