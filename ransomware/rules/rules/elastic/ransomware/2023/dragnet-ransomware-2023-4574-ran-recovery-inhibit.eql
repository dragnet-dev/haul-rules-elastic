// Dragnet [Ransomware]: dragnet-ransomware-2023-4574 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: fd375fa1-e5e5-5917-b846-3ca3cc5bac4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
