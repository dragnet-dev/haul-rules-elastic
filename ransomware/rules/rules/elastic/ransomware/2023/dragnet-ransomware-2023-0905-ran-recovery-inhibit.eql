// Dragnet [Ransomware]: dragnet-ransomware-2023-0905 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 46524547-f812-5d71-9489-a08555def31f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
