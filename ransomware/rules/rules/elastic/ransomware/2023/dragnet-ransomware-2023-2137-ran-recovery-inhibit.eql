// Dragnet [Ransomware]: dragnet-ransomware-2023-2137 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 39ce2319-6483-5be6-8e95-0065cc4e7edc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
