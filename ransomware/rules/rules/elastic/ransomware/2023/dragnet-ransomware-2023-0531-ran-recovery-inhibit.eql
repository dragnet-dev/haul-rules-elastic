// Dragnet [Ransomware]: dragnet-ransomware-2023-0531 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e23cebb0-e51f-5b7b-b989-a2ee90400d24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
