// Dragnet [Ransomware]: dragnet-ransomware-2023-1242 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 3bd27a2d-e6d9-501f-9a65-c055b8596ea1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
