// Dragnet [Ransomware]: dragnet-ransomware-2023-3671 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5a348452-671c-5b94-a7e7-9888bf1cf6b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
