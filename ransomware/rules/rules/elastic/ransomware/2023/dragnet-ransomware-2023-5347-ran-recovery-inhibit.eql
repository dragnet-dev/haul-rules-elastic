// Dragnet [Ransomware]: dragnet-ransomware-2023-5347 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: cd375992-9247-569f-bb7e-7d396c1b4234

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
