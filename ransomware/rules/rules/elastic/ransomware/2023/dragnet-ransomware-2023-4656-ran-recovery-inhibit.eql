// Dragnet [Ransomware]: dragnet-ransomware-2023-4656 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a38d0c18-ae64-538d-9596-ce058b519a0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
