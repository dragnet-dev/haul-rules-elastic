// Dragnet [Ransomware]: dragnet-ransomware-2023-0013 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 949d3f22-67fe-5b81-a2ac-dd13de68fbb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
