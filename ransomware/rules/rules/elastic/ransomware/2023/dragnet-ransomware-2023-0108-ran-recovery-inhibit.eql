// Dragnet [Ransomware]: dragnet-ransomware-2023-0108 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6e5bf689-8dfc-56a3-b68b-e1c438ed816b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
