// Dragnet [Ransomware]: dragnet-ransomware-2023-0753 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 03aa08cc-b1e7-5b6b-a837-9c997524fe45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
