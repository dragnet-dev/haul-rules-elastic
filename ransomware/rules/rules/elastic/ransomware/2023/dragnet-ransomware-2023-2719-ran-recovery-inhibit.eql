// Dragnet [Ransomware]: dragnet-ransomware-2023-2719 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: f3c3f598-fd24-55a1-9832-b74473aed3e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
