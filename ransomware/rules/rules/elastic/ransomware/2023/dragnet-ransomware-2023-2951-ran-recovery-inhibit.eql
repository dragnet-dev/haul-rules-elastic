// Dragnet [Ransomware]: dragnet-ransomware-2023-2951 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: d399f03c-6c38-50c5-98c2-1ef159226055

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
