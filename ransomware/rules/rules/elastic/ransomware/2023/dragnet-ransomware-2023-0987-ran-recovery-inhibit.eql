// Dragnet [Ransomware]: dragnet-ransomware-2023-0987 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: 8afa70f2-acc7-5bf6-abea-e1ae5ed0fc7c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
