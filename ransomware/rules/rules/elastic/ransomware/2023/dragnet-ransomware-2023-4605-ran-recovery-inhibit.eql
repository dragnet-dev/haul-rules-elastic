// Dragnet [Ransomware]: dragnet-ransomware-2023-4605 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 8659a53c-72f6-5334-ad13-99e86d090113

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
