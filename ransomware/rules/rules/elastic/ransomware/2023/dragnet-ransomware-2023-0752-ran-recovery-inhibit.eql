// Dragnet [Ransomware]: dragnet-ransomware-2023-0752 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 7c90cdca-1e3d-55bd-86e6-d30306bfe8b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
