// Dragnet [Ransomware]: dragnet-ransomware-2023-0437 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ea192e08-156a-5527-a109-8ccb0b0ee4c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
