// Dragnet [Ransomware]: dragnet-ransomware-2023-1502 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 11e03a8f-0939-535a-acd7-dde59f3a12cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
