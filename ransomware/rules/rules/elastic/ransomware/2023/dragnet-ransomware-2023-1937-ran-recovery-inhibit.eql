// Dragnet [Ransomware]: dragnet-ransomware-2023-1937 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: e23580ec-2808-508a-b7e8-1b45e13a7733

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
