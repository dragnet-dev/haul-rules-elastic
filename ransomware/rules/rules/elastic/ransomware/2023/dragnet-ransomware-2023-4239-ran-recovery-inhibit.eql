// Dragnet [Ransomware]: dragnet-ransomware-2023-4239 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: eb162723-3293-5b4c-b29e-387574dd1a23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
