// Dragnet [Ransomware]: dragnet-ransomware-2023-1440 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 43de1fd2-ad96-589b-8909-f56186fefcbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
