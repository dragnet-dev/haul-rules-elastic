// Dragnet [Ransomware]: dragnet-ransomware-2023-1635 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: bf57135c-56fe-5421-986b-c2c14604da08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
