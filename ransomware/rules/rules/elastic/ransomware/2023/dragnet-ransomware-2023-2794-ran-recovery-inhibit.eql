// Dragnet [Ransomware]: dragnet-ransomware-2023-2794 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: aae3c602-bb1f-573e-b86d-39f2ccce0952

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
