// Dragnet [Ransomware]: dragnet-ransomware-2023-0510 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: efc285cb-37e9-5241-90a9-ecdfa4097716

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
