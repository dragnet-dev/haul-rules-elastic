// Dragnet [Ransomware]: dragnet-ransomware-2023-1740 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 03521ff8-c74d-5a9d-a3dc-c8f23512061c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
