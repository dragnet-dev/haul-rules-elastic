// Dragnet [Ransomware]: dragnet-ransomware-2023-4713 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f037513a-8e6e-558d-8141-51e9b70862f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
