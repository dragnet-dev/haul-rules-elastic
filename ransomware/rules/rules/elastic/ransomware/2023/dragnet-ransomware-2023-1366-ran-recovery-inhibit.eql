// Dragnet [Ransomware]: dragnet-ransomware-2023-1366 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 646a164c-7a72-5d6b-8db7-78cf8bf73b81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
