// Dragnet [Ransomware]: dragnet-ransomware-2023-0138 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: b3bafd1f-c380-5de8-adf5-bf8a2d641bab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
