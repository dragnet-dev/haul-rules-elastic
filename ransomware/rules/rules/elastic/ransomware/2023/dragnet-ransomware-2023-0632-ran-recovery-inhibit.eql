// Dragnet [Ransomware]: dragnet-ransomware-2023-0632 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 0995e802-318d-5474-9aff-e3e52d65d6a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
