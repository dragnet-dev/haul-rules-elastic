// Dragnet [Ransomware]: dragnet-ransomware-2023-5174 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 49384ac7-67f7-572e-8619-b61b85d3388f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
