// Dragnet [Ransomware]: dragnet-ransomware-2023-2681 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: 72916d5a-4947-5ab2-b42f-065642fa38e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
