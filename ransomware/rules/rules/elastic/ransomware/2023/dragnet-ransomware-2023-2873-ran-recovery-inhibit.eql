// Dragnet [Ransomware]: dragnet-ransomware-2023-2873 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 53c47879-83b8-5110-9b38-2f388192279b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
