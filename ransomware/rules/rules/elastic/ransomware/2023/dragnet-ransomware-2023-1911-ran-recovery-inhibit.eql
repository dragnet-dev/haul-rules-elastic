// Dragnet [Ransomware]: dragnet-ransomware-2023-1911 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 13134ed4-3f53-546b-ac18-40ba681c4333

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
