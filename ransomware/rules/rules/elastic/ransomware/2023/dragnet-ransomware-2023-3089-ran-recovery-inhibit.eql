// Dragnet [Ransomware]: dragnet-ransomware-2023-3089 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 26d04914-6648-557b-b124-1e4a11223e76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
