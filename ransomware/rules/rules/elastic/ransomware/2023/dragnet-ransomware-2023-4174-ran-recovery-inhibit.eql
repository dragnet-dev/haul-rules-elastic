// Dragnet [Ransomware]: dragnet-ransomware-2023-4174 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: f31dd213-0b5a-57c8-9534-966760724374

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
