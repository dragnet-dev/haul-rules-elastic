// Dragnet [Ransomware]: dragnet-ransomware-2023-3757 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: 5bc1ca3c-656d-50cb-937c-804bc50c5744

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
