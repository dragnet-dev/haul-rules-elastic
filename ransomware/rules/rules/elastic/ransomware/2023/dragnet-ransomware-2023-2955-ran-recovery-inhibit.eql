// Dragnet [Ransomware]: dragnet-ransomware-2023-2955 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a6935e6f-23b0-5aa0-844e-836914f47d31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
