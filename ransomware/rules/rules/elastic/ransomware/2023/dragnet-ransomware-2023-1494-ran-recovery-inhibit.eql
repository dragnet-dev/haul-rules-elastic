// Dragnet [Ransomware]: dragnet-ransomware-2023-1494 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: 0b80fb63-15fe-5cfd-b68d-cb6cc61d5a4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
