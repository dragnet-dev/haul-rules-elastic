// Dragnet [Ransomware]: dragnet-ransomware-2023-4305 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 14e43b52-357f-5d6b-8aee-8f1fbce7d1bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
