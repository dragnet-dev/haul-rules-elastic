// Dragnet [Ransomware]: dragnet-ransomware-2023-2716 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 387e41d6-97b8-56b3-97e0-409bc93d91a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
