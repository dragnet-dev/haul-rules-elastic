// Dragnet [Ransomware]: dragnet-ransomware-2023-0690 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 7d77c1ea-846b-514d-910a-5c07029ee2a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
