// Dragnet [Ransomware]: dragnet-ransomware-2023-0785 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c8f9dbfe-eceb-509c-b7a5-98a3bc4f0938

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
