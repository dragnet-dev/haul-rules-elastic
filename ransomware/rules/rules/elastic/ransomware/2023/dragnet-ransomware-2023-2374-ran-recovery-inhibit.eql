// Dragnet [Ransomware]: dragnet-ransomware-2023-2374 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 53ced610-c122-5038-8612-69531e3aaa67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
