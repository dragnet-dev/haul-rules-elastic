// Dragnet [Ransomware]: dragnet-ransomware-2023-2128 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d893df56-8a3f-5f2f-bd22-4c8aab988d48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
