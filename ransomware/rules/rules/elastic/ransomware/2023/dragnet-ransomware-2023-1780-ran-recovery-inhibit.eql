// Dragnet [Ransomware]: dragnet-ransomware-2023-1780 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 5799336c-a9b2-5a24-bee9-b5bd8b3d83bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
