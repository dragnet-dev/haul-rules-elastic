// Dragnet [Ransomware]: dragnet-ransomware-2023-1766 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: cd9faa88-7d72-57f1-8b89-fe0a7a1d00fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
