// Dragnet [Ransomware]: dragnet-ransomware-2023-3366 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 5ae73e6a-e627-5c7d-b6f2-00c484394385

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
