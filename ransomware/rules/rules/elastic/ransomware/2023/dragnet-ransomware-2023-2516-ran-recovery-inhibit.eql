// Dragnet [Ransomware]: dragnet-ransomware-2023-2516 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e362fd41-b3d3-5bf1-837c-c1b4c723e58b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
