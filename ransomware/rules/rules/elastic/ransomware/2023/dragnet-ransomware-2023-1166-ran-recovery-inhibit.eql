// Dragnet [Ransomware]: dragnet-ransomware-2023-1166 — Recovery Inhibition (medusa)
// Status: deprecated | Level: high | ID: 7d8abb00-1a42-55ff-ab82-496d84d9fe87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
