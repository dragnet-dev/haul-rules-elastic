// Dragnet [Ransomware]: dragnet-ransomware-2023-3125 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f8e79347-c739-5a4d-af02-0c19457173cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
