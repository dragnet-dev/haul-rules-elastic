// Dragnet [Ransomware]: dragnet-ransomware-2023-1252 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 037e03ab-2ad3-53d5-b9a5-a5432bff4dd4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
