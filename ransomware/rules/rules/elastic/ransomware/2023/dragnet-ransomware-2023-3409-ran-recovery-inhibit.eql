// Dragnet [Ransomware]: dragnet-ransomware-2023-3409 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 34061f56-beab-5e97-ac1a-59f5c94f6d0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
