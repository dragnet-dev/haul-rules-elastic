// Dragnet [Ransomware]: dragnet-ransomware-2023-4298 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: b94670d0-2a02-5a78-a8fd-15c70282535d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
