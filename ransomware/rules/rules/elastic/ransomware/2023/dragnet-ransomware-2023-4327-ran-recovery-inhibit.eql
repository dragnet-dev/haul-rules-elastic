// Dragnet [Ransomware]: dragnet-ransomware-2023-4327 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 06f25f9e-92c7-57e3-9dd7-e09e747d7fd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
