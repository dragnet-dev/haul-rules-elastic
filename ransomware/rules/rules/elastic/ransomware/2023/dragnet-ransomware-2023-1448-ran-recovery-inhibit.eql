// Dragnet [Ransomware]: dragnet-ransomware-2023-1448 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 784078f7-da19-51a1-aeaf-32b7a4efe631

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
