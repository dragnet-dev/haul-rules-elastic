// Dragnet [Ransomware]: dragnet-ransomware-2023-0024 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: eb8fe01f-28c7-5539-ac51-ccbb7b7c5692

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
