// Dragnet [Ransomware]: dragnet-ransomware-2023-5256 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 016214c2-a823-561c-80fd-e24ddcbfb360

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
