// Dragnet [Ransomware]: dragnet-ransomware-2023-2532 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 703d27d4-3054-5432-bb9a-0a825161af7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
