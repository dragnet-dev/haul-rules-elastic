// Dragnet [Ransomware]: dragnet-ransomware-2023-0184 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: fc90a898-b823-57be-837b-08848728df74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
