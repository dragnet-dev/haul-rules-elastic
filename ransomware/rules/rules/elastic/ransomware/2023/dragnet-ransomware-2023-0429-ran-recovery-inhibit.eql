// Dragnet [Ransomware]: dragnet-ransomware-2023-0429 — Recovery Inhibition (darkpower)
// Status: experimental | Level: high | ID: 015afcbc-c9a9-5f99-bb79-f2e6f4fcb22d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
