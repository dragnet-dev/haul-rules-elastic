// Dragnet [Ransomware]: dragnet-ransomware-2023-1902 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f3fb5f64-7b7e-5a40-b6cf-77147e143fdd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
