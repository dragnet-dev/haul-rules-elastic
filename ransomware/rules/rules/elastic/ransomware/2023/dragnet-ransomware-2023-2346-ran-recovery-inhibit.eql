// Dragnet [Ransomware]: dragnet-ransomware-2023-2346 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 5a05b206-8ad4-5027-ac2a-5226bf20ec5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
