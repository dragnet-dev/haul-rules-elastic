// Dragnet [Ransomware]: dragnet-ransomware-2023-5326 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f9a2d199-e565-5f3c-8c59-b32c1c931954

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
