// Dragnet [Ransomware]: dragnet-ransomware-2023-0686 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 161bcafd-2caf-543f-81b6-d5edceb0b23c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
