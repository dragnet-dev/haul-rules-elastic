// Dragnet [Ransomware]: dragnet-ransomware-2023-3837 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 974ced67-3bd5-5ed6-b221-ab66097e21ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
