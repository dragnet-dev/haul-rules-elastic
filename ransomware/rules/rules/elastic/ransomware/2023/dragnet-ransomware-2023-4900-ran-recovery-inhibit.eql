// Dragnet [Ransomware]: dragnet-ransomware-2023-4900 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 25ef1041-950f-5e7d-a240-538d98436fb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
