// Dragnet [Ransomware]: dragnet-ransomware-2023-0562 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5cfe22fc-c940-5ab7-944c-978e15e9d659

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
