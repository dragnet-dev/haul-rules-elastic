// Dragnet [Ransomware]: dragnet-ransomware-2023-1397 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ee7ded95-a04d-5d39-8ea9-6f2e822d5f72

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
