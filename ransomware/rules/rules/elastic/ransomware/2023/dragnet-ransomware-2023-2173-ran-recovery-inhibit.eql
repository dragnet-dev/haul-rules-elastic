// Dragnet [Ransomware]: dragnet-ransomware-2023-2173 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 59dbacb5-4ea7-59e3-85b6-6dee9e8a3b14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
