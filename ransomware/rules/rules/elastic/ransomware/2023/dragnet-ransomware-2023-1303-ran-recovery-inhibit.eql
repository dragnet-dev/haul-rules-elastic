// Dragnet [Ransomware]: dragnet-ransomware-2023-1303 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 06676117-92ed-513f-91bb-9918536110ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
