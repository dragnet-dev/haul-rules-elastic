// Dragnet [Ransomware]: dragnet-ransomware-2023-4137 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 45dbe67f-fb4c-5fd2-bde7-7275203766cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
