// Dragnet [Ransomware]: dragnet-ransomware-2023-3458 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b28b6ddc-f305-557e-b09e-8397cb6a11bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
