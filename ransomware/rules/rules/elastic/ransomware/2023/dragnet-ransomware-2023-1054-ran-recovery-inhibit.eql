// Dragnet [Ransomware]: dragnet-ransomware-2023-1054 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: ac042665-b6d9-571a-9be3-de7cb7656996

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
