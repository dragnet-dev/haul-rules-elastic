// Dragnet [Ransomware]: dragnet-ransomware-2023-4361 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c0bae5c3-f24b-5dff-a9e2-e649fd4e7a25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
