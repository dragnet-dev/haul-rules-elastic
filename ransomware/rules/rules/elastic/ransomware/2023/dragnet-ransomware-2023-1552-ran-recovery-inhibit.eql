// Dragnet [Ransomware]: dragnet-ransomware-2023-1552 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: aa730ef8-e39d-5419-99b4-8aed4d8d8f3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
