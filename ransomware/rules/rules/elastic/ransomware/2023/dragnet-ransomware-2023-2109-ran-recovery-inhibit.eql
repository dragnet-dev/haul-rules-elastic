// Dragnet [Ransomware]: dragnet-ransomware-2023-2109 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: cc96c844-0722-5bdc-b467-65219db23102

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
