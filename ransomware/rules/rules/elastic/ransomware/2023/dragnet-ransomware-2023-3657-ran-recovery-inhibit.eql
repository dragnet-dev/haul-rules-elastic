// Dragnet [Ransomware]: dragnet-ransomware-2023-3657 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ff4b108d-fc69-5b0e-804d-d232b154c919

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
