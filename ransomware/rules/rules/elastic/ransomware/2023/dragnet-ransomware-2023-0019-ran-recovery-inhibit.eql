// Dragnet [Ransomware]: dragnet-ransomware-2023-0019 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f802dd2d-ae55-58e9-b419-c05f4da9f48a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
