// Dragnet [Ransomware]: dragnet-ransomware-2023-4154 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 35682072-fa94-521c-8762-cc7fdf5b33c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
