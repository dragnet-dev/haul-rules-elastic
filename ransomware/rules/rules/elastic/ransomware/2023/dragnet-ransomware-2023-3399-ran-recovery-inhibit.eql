// Dragnet [Ransomware]: dragnet-ransomware-2023-3399 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 42ba9b88-48c6-5e2c-9924-5ddeb4b3386f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
