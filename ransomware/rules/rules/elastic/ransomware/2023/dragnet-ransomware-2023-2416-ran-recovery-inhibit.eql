// Dragnet [Ransomware]: dragnet-ransomware-2023-2416 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: f463e652-8cb3-53cd-a902-23676a6c704a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
