// Dragnet [Ransomware]: dragnet-ransomware-2023-4041 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 6684bcbd-8f95-5e91-8457-cb5686b6e199

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
