// Dragnet [Ransomware]: dragnet-ransomware-2023-3091 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: a77ce485-d07d-5429-a901-0c6ecc135100

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
