// Dragnet [Ransomware]: dragnet-ransomware-2023-3127 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 20abc215-a28c-5a7b-94ed-099eebe75ded

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
