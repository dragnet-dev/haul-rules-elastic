// Dragnet [Ransomware]: dragnet-ransomware-2023-5059 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 2d156cae-2150-597f-b437-f9a076a9dd5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
