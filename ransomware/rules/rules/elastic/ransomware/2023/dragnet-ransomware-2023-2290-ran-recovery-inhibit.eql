// Dragnet [Ransomware]: dragnet-ransomware-2023-2290 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: f4c8abab-c4a7-5b10-a965-b62dd0951a3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
