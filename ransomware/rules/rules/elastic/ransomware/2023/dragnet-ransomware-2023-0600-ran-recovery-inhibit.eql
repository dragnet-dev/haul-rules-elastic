// Dragnet [Ransomware]: dragnet-ransomware-2023-0600 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: cf26aee2-4f10-562b-b353-766318d4c12c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
