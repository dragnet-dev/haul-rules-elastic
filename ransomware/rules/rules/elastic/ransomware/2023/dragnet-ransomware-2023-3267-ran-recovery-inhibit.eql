// Dragnet [Ransomware]: dragnet-ransomware-2023-3267 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2113b4b4-ca0a-53b3-8326-f739fcbdc598

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
