// Dragnet [Ransomware]: dragnet-ransomware-2023-2483 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: a2055a36-fb42-5bb8-b79b-4e60c3975a87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
