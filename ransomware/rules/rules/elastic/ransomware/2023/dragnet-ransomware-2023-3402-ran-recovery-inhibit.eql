// Dragnet [Ransomware]: dragnet-ransomware-2023-3402 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 913e4647-5ed2-5bc4-9d06-0ca15237d090

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
