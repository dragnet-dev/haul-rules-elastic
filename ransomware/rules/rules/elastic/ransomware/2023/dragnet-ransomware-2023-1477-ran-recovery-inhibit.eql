// Dragnet [Ransomware]: dragnet-ransomware-2023-1477 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 9deff5e6-f6bc-5f44-bc2c-a11835058b5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
