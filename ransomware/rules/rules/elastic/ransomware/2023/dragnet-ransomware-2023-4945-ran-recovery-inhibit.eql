// Dragnet [Ransomware]: dragnet-ransomware-2023-4945 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 000fcef7-761f-5683-ad8b-083729df55b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
