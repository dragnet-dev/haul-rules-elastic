// Dragnet [Ransomware]: dragnet-ransomware-2023-4112 — Recovery Inhibition (medusa)
// Status: deprecated | Level: high | ID: 5dd2b34f-a727-53ad-a11c-2226b68cd461

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
