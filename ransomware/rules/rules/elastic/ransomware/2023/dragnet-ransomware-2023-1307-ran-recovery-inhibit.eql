// Dragnet [Ransomware]: dragnet-ransomware-2023-1307 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: acfec670-460b-5f5e-98e5-91cf0f678dea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
