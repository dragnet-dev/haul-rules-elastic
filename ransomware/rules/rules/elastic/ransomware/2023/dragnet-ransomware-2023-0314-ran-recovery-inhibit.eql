// Dragnet [Ransomware]: dragnet-ransomware-2023-0314 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 75022282-758f-5042-86d4-a6700c77ebe4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
