// Dragnet [Ransomware]: dragnet-ransomware-2023-3900 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 76d9558b-9a87-50fc-809f-cde2e8074e44

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
