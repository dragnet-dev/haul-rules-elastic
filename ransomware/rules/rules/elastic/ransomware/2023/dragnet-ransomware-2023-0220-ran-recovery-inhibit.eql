// Dragnet [Ransomware]: dragnet-ransomware-2023-0220 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 9aa7100c-ab43-5545-98d6-ba1ca119942d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
