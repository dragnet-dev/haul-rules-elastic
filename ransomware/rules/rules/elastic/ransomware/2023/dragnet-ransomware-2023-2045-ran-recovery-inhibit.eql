// Dragnet [Ransomware]: dragnet-ransomware-2023-2045 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 9bbaef5d-2dc6-537e-b5bb-b21b114cd7b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
