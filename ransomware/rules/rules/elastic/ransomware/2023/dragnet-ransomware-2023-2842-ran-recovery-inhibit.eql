// Dragnet [Ransomware]: dragnet-ransomware-2023-2842 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: f44176f2-f33f-5cb6-899e-a42905d41425

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
