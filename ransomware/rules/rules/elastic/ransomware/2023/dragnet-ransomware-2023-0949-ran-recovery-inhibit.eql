// Dragnet [Ransomware]: dragnet-ransomware-2023-0949 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 4506f7b4-9e6c-5ceb-9094-e305e377125a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
