// Dragnet [Ransomware]: dragnet-ransomware-2023-0142 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 12276464-dee7-5594-af99-c0adf2bc99c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
