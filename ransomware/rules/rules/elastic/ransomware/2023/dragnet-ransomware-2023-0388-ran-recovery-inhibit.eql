// Dragnet [Ransomware]: dragnet-ransomware-2023-0388 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 67dce33c-02da-55f6-9e60-a7e1b2259923

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
