// Dragnet [Ransomware]: dragnet-ransomware-2023-1163 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: fb2df4c4-157f-532f-85dc-4ffdec1ab1f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
