// Dragnet [Ransomware]: dragnet-ransomware-2023-5344 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 5f8d1a1d-811a-58d0-813a-fcd1943043ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
