// Dragnet [Ransomware]: dragnet-ransomware-2023-3583 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a2fbd073-5432-5ac4-aef4-56a72e6e9690

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
