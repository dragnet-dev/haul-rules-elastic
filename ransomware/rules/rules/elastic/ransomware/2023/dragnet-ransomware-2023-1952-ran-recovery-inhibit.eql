// Dragnet [Ransomware]: dragnet-ransomware-2023-1952 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: c7ab6401-2b5f-554d-be48-418f69a32894

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
