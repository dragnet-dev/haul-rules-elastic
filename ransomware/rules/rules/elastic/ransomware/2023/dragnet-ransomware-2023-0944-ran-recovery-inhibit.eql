// Dragnet [Ransomware]: dragnet-ransomware-2023-0944 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 5325160d-4df7-5389-b73d-1b17e7f429a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
