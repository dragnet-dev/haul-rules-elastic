// Dragnet [Ransomware]: dragnet-ransomware-2023-3548 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 973ee994-702c-51c9-825c-1e43f53e5a08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
