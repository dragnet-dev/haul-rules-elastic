// Dragnet [Ransomware]: dragnet-ransomware-2023-1386 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 4d4c38ba-24f6-5da7-b426-1f29ccf08ba9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
