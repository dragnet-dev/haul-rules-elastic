// Dragnet [Ransomware]: dragnet-ransomware-2023-1267 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 117ed2d1-76b7-5c9b-855c-36e4b0387e90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
