// Dragnet [Ransomware]: dragnet-ransomware-2023-5312 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: df052a43-58de-5f65-855a-ce92823a59e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
