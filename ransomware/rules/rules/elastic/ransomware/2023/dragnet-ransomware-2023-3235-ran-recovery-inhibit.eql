// Dragnet [Ransomware]: dragnet-ransomware-2023-3235 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 07e38656-a938-54fb-9fd5-29b967424767

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
