// Dragnet [Ransomware]: dragnet-ransomware-2023-0385 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: ff5bcf57-00c8-5f34-96ae-3ee17b0ed080

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
