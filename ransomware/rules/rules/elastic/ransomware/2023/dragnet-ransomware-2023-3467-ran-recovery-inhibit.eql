// Dragnet [Ransomware]: dragnet-ransomware-2023-3467 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: fd1aba6f-fc1a-5b72-957c-f9f734ab9a0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
