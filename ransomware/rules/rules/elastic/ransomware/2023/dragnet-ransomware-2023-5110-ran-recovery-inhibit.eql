// Dragnet [Ransomware]: dragnet-ransomware-2023-5110 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 00ce5fc5-dd07-5bc2-902d-0a3702bdb37d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
