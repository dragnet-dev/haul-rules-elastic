// Dragnet [Ransomware]: dragnet-ransomware-2023-0074 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: a32b85fb-b393-5d4a-b28e-6630d21178c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
