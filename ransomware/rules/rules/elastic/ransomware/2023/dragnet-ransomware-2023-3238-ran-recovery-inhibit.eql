// Dragnet [Ransomware]: dragnet-ransomware-2023-3238 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d63c38e7-5c69-5224-b1dd-65ea45f7e7d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
