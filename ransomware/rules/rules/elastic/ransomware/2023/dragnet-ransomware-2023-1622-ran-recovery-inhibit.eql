// Dragnet [Ransomware]: dragnet-ransomware-2023-1622 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: c879019f-8ec5-5dcb-9437-46d86a526aa8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
