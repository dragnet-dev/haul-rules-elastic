// Dragnet [Ransomware]: dragnet-ransomware-2023-2191 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f4f74a1b-17db-51c1-aea7-3547691fa804

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
