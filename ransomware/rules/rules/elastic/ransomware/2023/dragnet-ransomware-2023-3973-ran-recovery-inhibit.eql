// Dragnet [Ransomware]: dragnet-ransomware-2023-3973 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 4772637d-6ae4-553e-a029-b7225cb5dc6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
