// Dragnet [Ransomware]: dragnet-ransomware-2023-1846 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: ab4d75ac-5d91-57d8-99b1-7fabc19620fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
