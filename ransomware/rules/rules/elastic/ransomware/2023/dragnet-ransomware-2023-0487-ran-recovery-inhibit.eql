// Dragnet [Ransomware]: dragnet-ransomware-2023-0487 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: a8f23a59-1885-5222-9739-e03ae4ca49d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
