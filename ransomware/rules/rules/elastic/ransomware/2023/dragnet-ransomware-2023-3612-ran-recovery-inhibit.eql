// Dragnet [Ransomware]: dragnet-ransomware-2023-3612 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 63da2344-68bd-570c-afae-5a2f3dcb17d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
