// Dragnet [Ransomware]: dragnet-ransomware-2023-1936 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 05b742b1-d415-5b06-952e-4c91e199bac7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
