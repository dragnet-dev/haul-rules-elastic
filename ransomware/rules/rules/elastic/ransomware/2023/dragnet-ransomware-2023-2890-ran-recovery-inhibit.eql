// Dragnet [Ransomware]: dragnet-ransomware-2023-2890 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: af34d480-9509-5ba2-a450-996e065846b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
