// Dragnet [Ransomware]: dragnet-ransomware-2023-0122 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6dfd553c-64bf-5fde-acab-3f67de73d9c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
