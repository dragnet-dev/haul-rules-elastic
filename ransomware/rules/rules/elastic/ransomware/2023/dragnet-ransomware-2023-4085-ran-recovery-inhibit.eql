// Dragnet [Ransomware]: dragnet-ransomware-2023-4085 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: e07f29dd-0ac3-57bb-b8cd-c0a2c9636f99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
