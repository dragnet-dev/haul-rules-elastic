// Dragnet [Ransomware]: dragnet-ransomware-2023-3014 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: be333272-1a1a-5f71-af91-c84983791923

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
