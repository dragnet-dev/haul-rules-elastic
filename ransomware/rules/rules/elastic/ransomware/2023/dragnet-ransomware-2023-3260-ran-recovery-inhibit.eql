// Dragnet [Ransomware]: dragnet-ransomware-2023-3260 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 52996713-6224-532d-b42f-9a5b6a33a64c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
