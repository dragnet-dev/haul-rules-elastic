// Dragnet [Ransomware]: dragnet-ransomware-2023-0947 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5886cc82-1c92-5f71-83a7-5c0b735dfc73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
