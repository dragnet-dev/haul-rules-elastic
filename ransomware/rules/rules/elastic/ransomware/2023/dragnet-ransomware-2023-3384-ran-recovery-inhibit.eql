// Dragnet [Ransomware]: dragnet-ransomware-2023-3384 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 3ea5164b-3cca-53b9-ad13-be4b9b13f425

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
