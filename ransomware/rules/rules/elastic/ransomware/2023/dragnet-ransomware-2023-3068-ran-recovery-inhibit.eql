// Dragnet [Ransomware]: dragnet-ransomware-2023-3068 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 80e49061-fbcf-5726-b23e-7a78e832a543

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
