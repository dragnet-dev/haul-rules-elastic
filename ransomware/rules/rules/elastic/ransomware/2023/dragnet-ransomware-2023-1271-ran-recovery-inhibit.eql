// Dragnet [Ransomware]: dragnet-ransomware-2023-1271 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d0f0f7bc-1f84-5b38-8510-138c60152a7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
