// Dragnet [Ransomware]: dragnet-ransomware-2023-5318 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 0ab522fc-f30e-5a5c-993f-df58244d819a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
