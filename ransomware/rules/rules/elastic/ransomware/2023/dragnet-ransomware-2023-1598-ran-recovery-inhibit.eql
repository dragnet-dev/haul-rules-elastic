// Dragnet [Ransomware]: dragnet-ransomware-2023-1598 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7df5aec9-ab4a-5110-ad2d-2cfcc5cc12ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
