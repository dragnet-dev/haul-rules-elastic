// Dragnet [Ransomware]: dragnet-ransomware-2023-0825 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: b5adad00-8b65-5efc-bf5c-6f4d59d52052

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
