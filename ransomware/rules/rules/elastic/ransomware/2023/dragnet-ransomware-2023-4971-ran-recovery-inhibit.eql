// Dragnet [Ransomware]: dragnet-ransomware-2023-4971 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ae2d02a0-c3fc-5327-bf82-50109bf0d33d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
