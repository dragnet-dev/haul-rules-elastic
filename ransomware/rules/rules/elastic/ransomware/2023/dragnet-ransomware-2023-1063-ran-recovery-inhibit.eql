// Dragnet [Ransomware]: dragnet-ransomware-2023-1063 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: fc1cef86-a5df-5d9e-9a99-bd424fad65ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
