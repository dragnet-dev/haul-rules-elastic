// Dragnet [Ransomware]: dragnet-ransomware-2023-2853 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: ebea8591-9acd-5108-a3be-d94650faf7ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
