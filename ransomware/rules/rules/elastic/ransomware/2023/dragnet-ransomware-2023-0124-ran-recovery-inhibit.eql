// Dragnet [Ransomware]: dragnet-ransomware-2023-0124 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: d4b7be26-81c9-5769-970e-5a93a66300d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
