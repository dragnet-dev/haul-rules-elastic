// Dragnet [Ransomware]: dragnet-ransomware-2023-4224 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: 4f74ca79-956e-5a25-8670-e74334722e1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
