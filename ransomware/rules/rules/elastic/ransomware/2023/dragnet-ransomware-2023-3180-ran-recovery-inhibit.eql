// Dragnet [Ransomware]: dragnet-ransomware-2023-3180 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 793f5ac8-39b7-5668-9788-e54be980c6e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
