// Dragnet [Ransomware]: dragnet-ransomware-2023-3261 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 6e6fc1dc-b66f-5f2b-80d2-08a91d7f0f85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
