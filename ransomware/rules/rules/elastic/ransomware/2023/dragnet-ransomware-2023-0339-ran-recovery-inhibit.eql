// Dragnet [Ransomware]: dragnet-ransomware-2023-0339 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: afe15bbd-d977-53d3-bede-a425e4a107ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
