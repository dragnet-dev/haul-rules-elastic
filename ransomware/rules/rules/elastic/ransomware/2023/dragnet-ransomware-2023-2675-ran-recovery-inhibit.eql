// Dragnet [Ransomware]: dragnet-ransomware-2023-2675 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 62ab942d-6c8f-51ba-9345-8e7d7ae39ceb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
