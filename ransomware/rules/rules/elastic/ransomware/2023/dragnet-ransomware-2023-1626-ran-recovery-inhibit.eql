// Dragnet [Ransomware]: dragnet-ransomware-2023-1626 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5b07106b-b5cc-540f-bf23-27e7664ee52b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
