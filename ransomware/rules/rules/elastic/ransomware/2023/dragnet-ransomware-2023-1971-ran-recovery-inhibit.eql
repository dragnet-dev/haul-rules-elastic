// Dragnet [Ransomware]: dragnet-ransomware-2023-1971 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: b67b12e8-1c54-5a82-93ad-e2a199b280e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
