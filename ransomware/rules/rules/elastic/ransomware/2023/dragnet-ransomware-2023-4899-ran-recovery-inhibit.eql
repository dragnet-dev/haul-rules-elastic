// Dragnet [Ransomware]: dragnet-ransomware-2023-4899 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 14f1bb81-f633-5230-a738-0590b0d7fbb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
