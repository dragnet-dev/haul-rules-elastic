// Dragnet [Ransomware]: dragnet-ransomware-2023-4249 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 29e620e5-9340-513a-8ae5-4474cca44c20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
