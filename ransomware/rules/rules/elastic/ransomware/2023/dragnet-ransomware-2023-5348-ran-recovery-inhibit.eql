// Dragnet [Ransomware]: dragnet-ransomware-2023-5348 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 7c63852a-8592-5e5b-b51a-d7f41ddb15d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
