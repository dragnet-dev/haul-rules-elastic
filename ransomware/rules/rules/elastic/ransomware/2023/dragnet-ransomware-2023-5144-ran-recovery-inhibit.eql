// Dragnet [Ransomware]: dragnet-ransomware-2023-5144 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ec585838-87fa-5a04-b566-738188d8e047

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
