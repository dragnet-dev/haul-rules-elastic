// Dragnet [Ransomware]: dragnet-ransomware-2023-0039 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 3118ac79-a102-5860-881c-7d98a607b067

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
