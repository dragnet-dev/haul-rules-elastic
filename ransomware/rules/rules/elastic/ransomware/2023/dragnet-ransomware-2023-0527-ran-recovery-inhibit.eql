// Dragnet [Ransomware]: dragnet-ransomware-2023-0527 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 98ec1b8c-d690-5428-acc4-4a5be8dc9734

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
