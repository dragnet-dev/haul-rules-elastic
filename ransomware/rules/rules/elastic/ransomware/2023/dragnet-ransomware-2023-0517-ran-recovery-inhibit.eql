// Dragnet [Ransomware]: dragnet-ransomware-2023-0517 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ef535444-ee7f-5b1b-86a7-754472cf3caf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
