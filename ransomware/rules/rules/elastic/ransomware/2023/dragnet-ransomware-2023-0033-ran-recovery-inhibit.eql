// Dragnet [Ransomware]: dragnet-ransomware-2023-0033 — Recovery Inhibition (cloak)
// Status: experimental | Level: high | ID: 0cef59cc-cf94-540c-8ef8-262e9739e0e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
