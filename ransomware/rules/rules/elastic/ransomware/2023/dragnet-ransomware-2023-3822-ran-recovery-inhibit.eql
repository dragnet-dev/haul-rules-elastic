// Dragnet [Ransomware]: dragnet-ransomware-2023-3822 — Recovery Inhibition (ElDorado)
// Status: experimental | Level: high | ID: 23e45178-d868-50ec-a1c4-f1273e2adae9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
