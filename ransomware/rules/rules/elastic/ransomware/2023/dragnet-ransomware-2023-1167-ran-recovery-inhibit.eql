// Dragnet [Ransomware]: dragnet-ransomware-2023-1167 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 020b1138-7198-5da2-8fe3-765c2f777ec5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
