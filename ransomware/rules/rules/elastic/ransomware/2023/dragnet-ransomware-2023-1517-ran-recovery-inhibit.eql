// Dragnet [Ransomware]: dragnet-ransomware-2023-1517 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 094b6fe5-6e9d-5a68-bf1b-671e037aa85f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
