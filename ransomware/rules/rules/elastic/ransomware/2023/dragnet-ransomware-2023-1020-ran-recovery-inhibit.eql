// Dragnet [Ransomware]: dragnet-ransomware-2023-1020 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 66ac2a5f-388b-5894-ac31-468c8fdcc07d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
