// Dragnet [Ransomware]: dragnet-ransomware-2023-3323 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f6c756f7-4235-5049-8db2-fc98939f7cf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
