// Dragnet [Ransomware]: dragnet-ransomware-2023-1332 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0edd2cf3-217f-5ef8-ad6f-753151f2626a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
