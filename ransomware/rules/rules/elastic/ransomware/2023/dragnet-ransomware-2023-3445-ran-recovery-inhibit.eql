// Dragnet [Ransomware]: dragnet-ransomware-2023-3445 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: 8212e9d8-3a52-53e9-b0dc-ae1f6cf30bbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
