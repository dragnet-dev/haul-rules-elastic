// Dragnet [Ransomware]: dragnet-ransomware-2023-0526 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 61b8c590-682b-57a7-813b-3c61a9a2d7b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
