// Dragnet [Ransomware]: dragnet-ransomware-2023-4119 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 3a44cf4f-c54b-56d4-b310-735e0c847245

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
