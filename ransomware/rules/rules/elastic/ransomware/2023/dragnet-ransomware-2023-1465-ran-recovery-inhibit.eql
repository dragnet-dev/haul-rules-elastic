// Dragnet [Ransomware]: dragnet-ransomware-2023-1465 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f869f4e2-ab6e-532b-98fc-aad15c6ecbc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
