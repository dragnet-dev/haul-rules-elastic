// Dragnet [Ransomware]: dragnet-ransomware-2023-4235 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 3c9374c6-3e86-595c-8f7b-6203b5d1d9cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
