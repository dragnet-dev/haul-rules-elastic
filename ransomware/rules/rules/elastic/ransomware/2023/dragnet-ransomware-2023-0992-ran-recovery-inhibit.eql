// Dragnet [Ransomware]: dragnet-ransomware-2023-0992 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: ada7bf74-7654-53e5-9ed7-6add2b43f425

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
