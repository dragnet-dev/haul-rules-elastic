// Dragnet [Ransomware]: dragnet-ransomware-2023-2768 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 6ff10341-cc2c-529e-91a2-9f65be5e5d92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
