// Dragnet [Ransomware]: dragnet-ransomware-2023-3455 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4c396fce-317f-55b6-8da9-2ce3d8bb1452

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
