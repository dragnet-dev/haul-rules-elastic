// Dragnet [Ransomware]: dragnet-ransomware-2023-1679 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: 43471a2c-f99d-59b2-8798-f670c07cbe5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
