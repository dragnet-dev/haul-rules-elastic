// Dragnet [Ransomware]: dragnet-ransomware-2023-1487 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 03d39cbb-7172-52e2-bffa-b401504b911e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
