// Dragnet [Ransomware]: dragnet-ransomware-2023-4930 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2c40f8ae-79eb-5b1a-9efc-584e67e5f091

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
