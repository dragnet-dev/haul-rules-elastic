// Dragnet [Ransomware]: dragnet-ransomware-2023-4570 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e352676c-ebeb-5277-a766-f5e16499f8ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
