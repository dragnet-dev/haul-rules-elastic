// Dragnet [Ransomware]: dragnet-ransomware-2023-5249 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 74090a70-bbf7-5791-9680-8792d0ca385d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
