// Dragnet [Ransomware]: dragnet-ransomware-2023-1128 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 25e691cc-42ee-5d10-8545-1b85cbbc3a9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
