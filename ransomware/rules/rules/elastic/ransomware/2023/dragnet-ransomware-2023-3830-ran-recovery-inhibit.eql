// Dragnet [Ransomware]: dragnet-ransomware-2023-3830 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7559ed3b-6df3-5cd7-8a88-4ee70c89c162

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
