// Dragnet [Ransomware]: dragnet-ransomware-2023-0930 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 8fd374fb-c43c-5d2c-a43e-82a6d6c2ced4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
