// Dragnet [Ransomware]: dragnet-ransomware-2023-0647 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e0b852fa-9239-50b4-9611-8d11aadc0659

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
