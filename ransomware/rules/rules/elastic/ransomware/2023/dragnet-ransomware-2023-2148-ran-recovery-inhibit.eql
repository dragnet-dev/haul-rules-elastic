// Dragnet [Ransomware]: dragnet-ransomware-2023-2148 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0a291605-4b34-5b17-b3b4-22100f146563

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
