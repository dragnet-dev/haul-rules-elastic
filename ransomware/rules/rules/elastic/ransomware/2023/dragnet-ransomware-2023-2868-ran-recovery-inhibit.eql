// Dragnet [Ransomware]: dragnet-ransomware-2023-2868 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 7c64ae33-b0b0-5521-b9c2-cc4afc01b989

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
