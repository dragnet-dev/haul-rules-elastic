// Dragnet [Ransomware]: dragnet-ransomware-2023-4449 — Recovery Inhibition (darkrace)
// Status: experimental | Level: high | ID: 73a5b255-8cca-573b-89da-1169ca9e8d0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
