// Dragnet [Ransomware]: dragnet-ransomware-2023-1310 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 9a12cfab-ffc2-57d3-86e2-4aaf0c0d1f8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
