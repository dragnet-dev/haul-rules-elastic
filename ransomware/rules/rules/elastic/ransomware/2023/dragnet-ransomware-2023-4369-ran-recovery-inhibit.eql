// Dragnet [Ransomware]: dragnet-ransomware-2023-4369 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: d54a8520-18b9-51ec-a461-0269f6644170

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
