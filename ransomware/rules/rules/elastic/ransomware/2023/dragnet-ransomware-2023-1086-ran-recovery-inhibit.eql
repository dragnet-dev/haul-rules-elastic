// Dragnet [Ransomware]: dragnet-ransomware-2023-1086 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: af3e3d9d-7dfa-5249-8214-fd065cae97cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
