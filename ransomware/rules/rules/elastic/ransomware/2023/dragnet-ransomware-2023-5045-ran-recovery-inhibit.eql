// Dragnet [Ransomware]: dragnet-ransomware-2023-5045 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f5b73b48-2072-5226-a08f-fcae0167be04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
