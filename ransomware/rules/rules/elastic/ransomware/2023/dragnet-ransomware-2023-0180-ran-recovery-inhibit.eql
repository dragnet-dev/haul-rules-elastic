// Dragnet [Ransomware]: dragnet-ransomware-2023-0180 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 2dfd917e-9f79-5be6-9ae5-21b003a2ae10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
