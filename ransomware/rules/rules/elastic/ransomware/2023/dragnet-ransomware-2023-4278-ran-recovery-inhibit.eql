// Dragnet [Ransomware]: dragnet-ransomware-2023-4278 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: cfae57c0-8038-5907-81ab-77b45b94fddb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
