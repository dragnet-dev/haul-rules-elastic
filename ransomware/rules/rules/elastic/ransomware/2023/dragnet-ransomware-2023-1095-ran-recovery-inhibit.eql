// Dragnet [Ransomware]: dragnet-ransomware-2023-1095 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 41e39766-1b21-52f7-851f-733425c4978a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
