// Dragnet [Ransomware]: dragnet-ransomware-2023-5013 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 412fe539-8fb0-51fc-a379-639dca1215d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
