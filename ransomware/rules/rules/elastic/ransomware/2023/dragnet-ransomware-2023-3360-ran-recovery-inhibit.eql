// Dragnet [Ransomware]: dragnet-ransomware-2023-3360 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 93f5e330-5848-5d64-a3f3-ca81f7203f1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
