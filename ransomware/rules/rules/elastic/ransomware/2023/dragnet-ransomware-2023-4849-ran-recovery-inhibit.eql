// Dragnet [Ransomware]: dragnet-ransomware-2023-4849 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 51c2bee6-a17b-59e5-bb66-437e24f5ce8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
