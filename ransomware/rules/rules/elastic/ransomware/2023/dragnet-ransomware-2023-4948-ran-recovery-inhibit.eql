// Dragnet [Ransomware]: dragnet-ransomware-2023-4948 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 589bcbfc-9f5e-5089-a64d-efe294d680a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
