// Dragnet [Ransomware]: dragnet-ransomware-2023-0817 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 094a6db6-81cf-51cf-93b5-3f924570febd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
