// Dragnet [Ransomware]: dragnet-ransomware-2023-3945 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 24ecbb48-f1f6-5f43-ae80-16ae386feeb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
