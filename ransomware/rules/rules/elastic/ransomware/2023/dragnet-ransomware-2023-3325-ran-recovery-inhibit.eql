// Dragnet [Ransomware]: dragnet-ransomware-2023-3325 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 7c35bc8f-f09d-538d-be25-19b6e3cbd37f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
