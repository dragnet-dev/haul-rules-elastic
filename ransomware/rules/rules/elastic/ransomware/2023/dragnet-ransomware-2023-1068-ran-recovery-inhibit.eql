// Dragnet [Ransomware]: dragnet-ransomware-2023-1068 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: ed487ebe-e203-5021-9abf-e875ed0c6c99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
