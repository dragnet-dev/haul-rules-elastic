// Dragnet [Ransomware]: dragnet-ransomware-2023-1848 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5fb16303-e283-5421-9a86-f8a5db87dab5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
