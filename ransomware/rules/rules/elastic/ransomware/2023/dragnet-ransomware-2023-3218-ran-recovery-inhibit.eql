// Dragnet [Ransomware]: dragnet-ransomware-2023-3218 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b4a20a22-672a-52dc-8dba-9bd53240793f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
