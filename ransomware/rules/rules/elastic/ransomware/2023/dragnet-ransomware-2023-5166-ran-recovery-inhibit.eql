// Dragnet [Ransomware]: dragnet-ransomware-2023-5166 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: bacd3609-6512-5abe-8b21-9b02790ea146

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
