// Dragnet [Ransomware]: dragnet-ransomware-2023-2623 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 10fc2ef4-23e4-5387-8542-4000cc0e8777

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
