// Dragnet [Ransomware]: dragnet-ransomware-2023-1979 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4b6221e1-8a5e-5448-956c-345f18e94864

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
