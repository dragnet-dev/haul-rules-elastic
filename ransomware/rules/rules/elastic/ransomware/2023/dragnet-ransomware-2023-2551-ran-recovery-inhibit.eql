// Dragnet [Ransomware]: dragnet-ransomware-2023-2551 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 1dfb19f3-75a7-50be-a9c5-79494b539182

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
