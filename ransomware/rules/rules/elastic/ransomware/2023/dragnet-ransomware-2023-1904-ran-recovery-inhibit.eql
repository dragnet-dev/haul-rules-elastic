// Dragnet [Ransomware]: dragnet-ransomware-2023-1904 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: e5c0c05e-ffe0-5483-97ba-1b0a3794294a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
