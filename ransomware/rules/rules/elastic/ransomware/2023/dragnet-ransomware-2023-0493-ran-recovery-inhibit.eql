// Dragnet [Ransomware]: dragnet-ransomware-2023-0493 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ef889229-db86-5f0a-8590-5b514f2fb1e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
