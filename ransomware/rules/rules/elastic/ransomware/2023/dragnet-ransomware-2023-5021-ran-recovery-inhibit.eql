// Dragnet [Ransomware]: dragnet-ransomware-2023-5021 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 9fa43006-4245-5748-aada-94d2ed55c285

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
