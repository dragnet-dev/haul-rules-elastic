// Dragnet [Ransomware]: dragnet-ransomware-2023-1761 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: 48b90b25-a022-59f0-9cfa-f4852dfa523d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
