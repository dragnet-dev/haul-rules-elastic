// Dragnet [Ransomware]: dragnet-ransomware-2023-5089 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 69d9548f-1cbe-54b4-ae10-326c69e1a23a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
