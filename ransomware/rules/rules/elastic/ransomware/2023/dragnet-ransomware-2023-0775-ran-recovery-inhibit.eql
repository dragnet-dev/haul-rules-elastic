// Dragnet [Ransomware]: dragnet-ransomware-2023-0775 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 96dbdacc-25c9-58e4-87f4-9053a528cfa4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
