// Dragnet [Ransomware]: dragnet-ransomware-2023-3145 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e3293b99-5872-556b-8146-0916525d6fdc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
