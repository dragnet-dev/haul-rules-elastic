// Dragnet [Ransomware]: dragnet-ransomware-2023-0088 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bd5e03db-2508-5368-a59c-a39e42ed9b46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
