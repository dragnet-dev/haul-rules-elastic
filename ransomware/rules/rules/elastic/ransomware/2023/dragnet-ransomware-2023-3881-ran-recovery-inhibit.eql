// Dragnet [Ransomware]: dragnet-ransomware-2023-3881 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: bd007553-81a6-5ac8-9a3c-be78c6c7790c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
