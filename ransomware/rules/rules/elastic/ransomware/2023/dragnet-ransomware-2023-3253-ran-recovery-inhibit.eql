// Dragnet [Ransomware]: dragnet-ransomware-2023-3253 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: eb6cf26d-0c63-59e1-b9d7-0b09f4540c8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
