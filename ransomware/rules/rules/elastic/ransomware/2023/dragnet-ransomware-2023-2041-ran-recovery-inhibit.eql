// Dragnet [Ransomware]: dragnet-ransomware-2023-2041 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6bd92b67-00ce-564e-9090-3600843d9d20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
