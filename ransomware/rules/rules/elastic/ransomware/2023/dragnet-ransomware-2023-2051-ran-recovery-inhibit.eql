// Dragnet [Ransomware]: dragnet-ransomware-2023-2051 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 575aafe1-e744-51e0-8074-e4e77b24139c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
