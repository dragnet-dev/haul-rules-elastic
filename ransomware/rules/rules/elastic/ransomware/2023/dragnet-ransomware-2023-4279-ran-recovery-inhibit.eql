// Dragnet [Ransomware]: dragnet-ransomware-2023-4279 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 948f3d1b-19cc-5db8-ae85-7e7544e31e4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
