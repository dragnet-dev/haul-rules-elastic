// Dragnet [Ransomware]: dragnet-ransomware-2023-2068 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 66b365a8-d80b-547f-b493-4eb16ee06a19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
