// Dragnet [Ransomware]: dragnet-ransomware-2023-0532 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: e1ae10f7-c719-530b-b297-cca3c4be88b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
