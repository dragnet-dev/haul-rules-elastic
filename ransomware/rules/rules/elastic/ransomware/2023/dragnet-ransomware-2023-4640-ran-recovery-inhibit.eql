// Dragnet [Ransomware]: dragnet-ransomware-2023-4640 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 15f4d6d7-5f91-5191-82b0-b024c3e8e895

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
