// Dragnet [Ransomware]: dragnet-ransomware-2023-5206 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a44353a1-f641-5daa-8d67-5175bac4c820

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
