// Dragnet [Ransomware]: dragnet-ransomware-2023-2335 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: fc57e799-b8fc-50ee-84f3-59a59f266e41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
