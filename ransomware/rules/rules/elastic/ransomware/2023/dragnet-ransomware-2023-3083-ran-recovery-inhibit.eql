// Dragnet [Ransomware]: dragnet-ransomware-2023-3083 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 2db2ca17-8ea8-5a19-b876-c221968df3b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
