// Dragnet [Ransomware]: dragnet-ransomware-2023-1313 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: fea7a53d-c2ae-5362-91b8-215e3acbfa90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
