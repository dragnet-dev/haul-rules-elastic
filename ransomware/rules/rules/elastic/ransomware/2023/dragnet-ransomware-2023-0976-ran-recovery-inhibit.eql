// Dragnet [Ransomware]: dragnet-ransomware-2023-0976 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 91e815fa-df09-5913-b465-1da389804baf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
