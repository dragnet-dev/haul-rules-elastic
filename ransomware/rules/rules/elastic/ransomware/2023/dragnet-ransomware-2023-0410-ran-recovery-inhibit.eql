// Dragnet [Ransomware]: dragnet-ransomware-2023-0410 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 0c6e2973-a056-5fcc-a6b4-3b1267234625

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
