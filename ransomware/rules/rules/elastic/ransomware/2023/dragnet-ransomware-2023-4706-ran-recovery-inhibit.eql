// Dragnet [Ransomware]: dragnet-ransomware-2023-4706 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 6e46137d-0eab-5e9d-8384-4510ba2be2bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
