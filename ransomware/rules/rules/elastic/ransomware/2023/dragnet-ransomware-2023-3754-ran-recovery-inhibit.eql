// Dragnet [Ransomware]: dragnet-ransomware-2023-3754 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 883ec16f-7aa8-564a-b18d-7b659682e9c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
