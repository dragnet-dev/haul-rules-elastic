// Dragnet [Ransomware]: dragnet-ransomware-2023-3718 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 82dec101-b070-5f14-b6e9-95372feb598d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
