// Dragnet [Ransomware]: dragnet-ransomware-2023-2542 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: a47d134d-1fd1-5618-9402-5a05b060a013

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
