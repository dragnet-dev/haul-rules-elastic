// Dragnet [Ransomware]: dragnet-ransomware-2023-2304 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3fc41c09-9d37-57cd-881e-bcfd98a6a9f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
