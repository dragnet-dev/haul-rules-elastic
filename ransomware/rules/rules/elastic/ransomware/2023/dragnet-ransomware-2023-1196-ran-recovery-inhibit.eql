// Dragnet [Ransomware]: dragnet-ransomware-2023-1196 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 675d26cc-90d6-55b9-ab25-d3ad387af909

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
