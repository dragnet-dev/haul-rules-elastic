// Dragnet [Ransomware]: dragnet-ransomware-2023-2923 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 7f306f47-6c02-578d-b456-86eef1644d6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
