// Dragnet [Ransomware]: dragnet-ransomware-2023-2445 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f9988f0d-c8cf-55dd-8f8e-3481e38bb2a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
