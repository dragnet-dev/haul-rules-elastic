// Dragnet [Ransomware]: dragnet-ransomware-2023-1855 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: 9d0327f7-7242-5b9f-82df-b2a2eec4084a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
