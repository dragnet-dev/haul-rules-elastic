// Dragnet [Ransomware]: dragnet-ransomware-2023-0749 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 05489b39-4a8e-5688-a159-f08882fbdbca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
