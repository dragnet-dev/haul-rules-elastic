// Dragnet [Ransomware]: dragnet-ransomware-2023-2849 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: d0a056d5-8bf0-54db-bd93-f986d7174b97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
