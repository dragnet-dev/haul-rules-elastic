// Dragnet [Ransomware]: dragnet-ransomware-2023-3150 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 59551490-0e11-539f-b9e6-beedaf54bacc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
