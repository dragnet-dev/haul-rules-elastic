// Dragnet [Ransomware]: dragnet-ransomware-2023-2203 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 6fc601f9-3bb7-55ea-ba3c-b27588384053

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
