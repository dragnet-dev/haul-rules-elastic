// Dragnet [Ransomware]: dragnet-ransomware-2023-1829 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 851d13e8-f0fd-5415-9c35-7a6f016aa9b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
