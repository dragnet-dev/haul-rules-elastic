// Dragnet [Ransomware]: dragnet-ransomware-2023-2980 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: c354278b-8ada-572c-b828-4a1df4d50ce1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
