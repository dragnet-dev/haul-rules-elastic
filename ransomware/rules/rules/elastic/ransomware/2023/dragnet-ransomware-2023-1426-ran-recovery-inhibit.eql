// Dragnet [Ransomware]: dragnet-ransomware-2023-1426 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: 8209aa8e-7ce0-5f46-907d-2b4d313a4d6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
