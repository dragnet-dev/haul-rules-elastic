// Dragnet [Ransomware]: dragnet-ransomware-2023-0918 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1aa076f2-68a9-542e-829f-837c83396578

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
