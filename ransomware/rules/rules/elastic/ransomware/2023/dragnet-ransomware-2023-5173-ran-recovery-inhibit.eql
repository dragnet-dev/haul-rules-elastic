// Dragnet [Ransomware]: dragnet-ransomware-2023-5173 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 34a18fb4-fa28-5ed8-93a4-2848d28455ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
