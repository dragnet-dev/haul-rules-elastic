// Dragnet [Ransomware]: dragnet-ransomware-2023-5285 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 14f6eaa5-c7c3-5fd8-9db8-03c26d5e13c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
