// Dragnet [Ransomware]: dragnet-ransomware-2023-5306 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 09471306-591d-55e9-ad9f-3cef1feba863

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
