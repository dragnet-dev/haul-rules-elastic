// Dragnet [Ransomware]: dragnet-ransomware-2023-5337 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 1e0c100c-e304-527f-ab42-a5fd361d4c3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
