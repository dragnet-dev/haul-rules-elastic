// Dragnet [Ransomware]: dragnet-ransomware-2023-5075 — Recovery Inhibition (rancoz)
// Status: experimental | Level: high | ID: e5ff7f14-6d82-5ddf-bf7d-cbfdbfb75bc6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
