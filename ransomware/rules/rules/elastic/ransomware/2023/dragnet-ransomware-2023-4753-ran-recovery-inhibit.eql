// Dragnet [Ransomware]: dragnet-ransomware-2023-4753 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: d2b58a7b-0e2d-59b8-8b3c-ab775f83968a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
