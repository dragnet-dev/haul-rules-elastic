// Dragnet [Ransomware]: dragnet-ransomware-2023-0243 — Recovery Inhibition (mallox)
// Status: experimental | Level: high | ID: a01cbb11-df6f-5470-844f-05da5c1d8edc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
