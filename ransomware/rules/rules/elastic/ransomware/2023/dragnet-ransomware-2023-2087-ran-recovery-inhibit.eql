// Dragnet [Ransomware]: dragnet-ransomware-2023-2087 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 64eda03c-2602-5a33-a569-41f60cd05347

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
