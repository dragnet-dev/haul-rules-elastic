// Dragnet [Ransomware]: dragnet-ransomware-2023-2926 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 20150e53-785e-5797-9f3f-be342c129706

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
