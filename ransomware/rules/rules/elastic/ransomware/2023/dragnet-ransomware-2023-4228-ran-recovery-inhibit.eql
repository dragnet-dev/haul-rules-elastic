// Dragnet [Ransomware]: dragnet-ransomware-2023-4228 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ec1de71b-c1ff-5936-bdea-959e8b319fbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
