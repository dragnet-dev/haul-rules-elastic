// Dragnet [Ransomware]: dragnet-ransomware-2023-1333 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: f9716ac1-e178-528e-8053-dcda60d4e898

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
