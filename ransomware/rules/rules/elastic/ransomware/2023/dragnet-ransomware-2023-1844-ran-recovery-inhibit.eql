// Dragnet [Ransomware]: dragnet-ransomware-2023-1844 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 723f456e-2c50-56e6-9f2b-77838e051f6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
