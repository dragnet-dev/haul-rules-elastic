// Dragnet [Ransomware]: dragnet-ransomware-2023-2284 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: bb7854c1-d980-51eb-acd0-c6346b4e1c27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
