// Dragnet [Ransomware]: dragnet-ransomware-2023-1865 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 198aacc6-f081-57a1-814e-ac1ded757b5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
