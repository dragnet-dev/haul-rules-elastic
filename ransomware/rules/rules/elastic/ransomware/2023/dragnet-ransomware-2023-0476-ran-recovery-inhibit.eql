// Dragnet [Ransomware]: dragnet-ransomware-2023-0476 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c4eb3e9c-6c24-5dbd-89cb-af2e153dbda1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
