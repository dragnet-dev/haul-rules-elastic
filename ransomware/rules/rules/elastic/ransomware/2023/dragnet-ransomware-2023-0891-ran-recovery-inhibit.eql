// Dragnet [Ransomware]: dragnet-ransomware-2023-0891 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 4225d4ae-c83b-5d69-93da-5380e8aaced3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
