// Dragnet [Ransomware]: dragnet-ransomware-2023-1042 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 50a5863f-d005-5164-a4b4-0ed8b9eba14b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
