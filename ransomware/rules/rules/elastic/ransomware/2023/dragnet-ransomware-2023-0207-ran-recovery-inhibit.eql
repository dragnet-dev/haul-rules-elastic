// Dragnet [Ransomware]: dragnet-ransomware-2023-0207 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 0ac5e88e-bb7f-5671-b7bf-35a3836dad3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
