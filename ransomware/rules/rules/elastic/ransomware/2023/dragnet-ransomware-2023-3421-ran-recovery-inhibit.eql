// Dragnet [Ransomware]: dragnet-ransomware-2023-3421 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 601037ba-e6b5-5c33-ab70-2a0f02592a4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
