// Dragnet [Ransomware]: dragnet-ransomware-2023-2357 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 1eae94c6-92a1-5088-9647-72e704659f10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
