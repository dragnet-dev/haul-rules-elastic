// Dragnet [Ransomware]: dragnet-ransomware-2023-1435 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: c9494782-0c6a-5772-a35a-e6bcade4c65c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
