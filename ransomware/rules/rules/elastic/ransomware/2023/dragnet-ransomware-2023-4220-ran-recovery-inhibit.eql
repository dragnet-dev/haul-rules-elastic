// Dragnet [Ransomware]: dragnet-ransomware-2023-4220 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 0e15d8f0-f997-5222-a5cc-26d1149ea1d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
