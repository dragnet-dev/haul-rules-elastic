// Dragnet [Ransomware]: dragnet-ransomware-2023-2708 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 569f838c-f7e2-542f-b3e2-3ef772cb078c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
