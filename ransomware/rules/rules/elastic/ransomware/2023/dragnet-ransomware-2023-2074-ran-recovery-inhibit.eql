// Dragnet [Ransomware]: dragnet-ransomware-2023-2074 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 09d82c8f-1ccc-5eca-b77c-90e52460d51c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
