// Dragnet [Ransomware]: dragnet-ransomware-2023-0175 — Recovery Inhibition (noname)
// Status: experimental | Level: high | ID: 0099097b-7630-5e41-be60-db2fcf1ee139

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
