// Dragnet [Ransomware]: dragnet-ransomware-2023-1827 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 4fc146c6-7e1f-5a77-ab55-db0fbdca0b83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
