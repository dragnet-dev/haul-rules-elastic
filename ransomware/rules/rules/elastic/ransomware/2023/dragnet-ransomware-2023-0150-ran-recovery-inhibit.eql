// Dragnet [Ransomware]: dragnet-ransomware-2023-0150 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 8822aa54-b632-5079-bccc-3e19b05bb539

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
