// Dragnet [Ransomware]: dragnet-ransomware-2023-4768 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 62d37649-98e2-5fd9-8c29-3e8a304dba29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
