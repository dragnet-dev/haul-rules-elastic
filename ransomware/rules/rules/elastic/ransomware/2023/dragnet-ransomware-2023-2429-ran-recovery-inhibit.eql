// Dragnet [Ransomware]: dragnet-ransomware-2023-2429 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5512652d-6964-56c3-9c44-e55150b1a7cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
