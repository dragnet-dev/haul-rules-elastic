// Dragnet [Ransomware]: dragnet-ransomware-2023-0502 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 392ea84f-278c-531d-b116-af015a1ac7e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
