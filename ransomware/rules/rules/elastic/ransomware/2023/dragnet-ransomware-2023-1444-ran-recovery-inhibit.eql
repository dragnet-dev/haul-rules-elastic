// Dragnet [Ransomware]: dragnet-ransomware-2023-1444 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: bb37a5e7-66ca-5c12-8606-949c09b06255

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
