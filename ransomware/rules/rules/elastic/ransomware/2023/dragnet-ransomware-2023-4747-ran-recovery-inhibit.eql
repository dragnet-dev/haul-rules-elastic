// Dragnet [Ransomware]: dragnet-ransomware-2023-4747 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: b6afa549-972c-5cbf-b51d-d9aa494a5380

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
