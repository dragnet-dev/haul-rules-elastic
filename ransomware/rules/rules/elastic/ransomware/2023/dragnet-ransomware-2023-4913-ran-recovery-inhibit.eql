// Dragnet [Ransomware]: dragnet-ransomware-2023-4913 — Recovery Inhibition (medusa)
// Status: deprecated | Level: high | ID: 745dace5-5183-5c8e-a43b-a09351ed6634

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
