// Dragnet [Ransomware]: dragnet-ransomware-2023-4091 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 64fd32ec-3ecb-5b38-9cab-e3d1b9c54434

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
