// Dragnet [Ransomware]: dragnet-ransomware-2023-3052 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 5d16fabe-6d54-5729-9704-1563030b88a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
