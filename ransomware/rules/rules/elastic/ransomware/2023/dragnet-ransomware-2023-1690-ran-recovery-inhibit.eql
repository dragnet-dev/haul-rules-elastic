// Dragnet [Ransomware]: dragnet-ransomware-2023-1690 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 2f93b3d8-e03c-5f8a-b7bd-1b64019c7132

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
