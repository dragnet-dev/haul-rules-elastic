// Dragnet [Ransomware]: dragnet-ransomware-2023-4679 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: d65c1244-29bc-5a59-93b4-8ddd2c9fe7fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
