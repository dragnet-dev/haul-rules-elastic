// Dragnet [Ransomware]: dragnet-ransomware-2023-2769 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 2a12bfa0-87f3-5684-96b8-fc0f84b8f89a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
