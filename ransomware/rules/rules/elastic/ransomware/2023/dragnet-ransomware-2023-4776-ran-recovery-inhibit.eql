// Dragnet [Ransomware]: dragnet-ransomware-2023-4776 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 524540ff-c522-558e-bae2-6e7f1bcbca82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
