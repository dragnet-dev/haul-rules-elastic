// Dragnet [Ransomware]: dragnet-ransomware-2023-4895 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: f70a3f69-f5c3-5435-a34f-b7fcbe518075

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
