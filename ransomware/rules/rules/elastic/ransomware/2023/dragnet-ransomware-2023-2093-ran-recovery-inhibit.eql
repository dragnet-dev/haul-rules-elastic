// Dragnet [Ransomware]: dragnet-ransomware-2023-2093 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 680d0a56-6a3c-5ae0-bf31-be5736c6116e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
