// Dragnet [Ransomware]: dragnet-ransomware-2023-1614 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 73fc3491-b145-5929-8f43-6a0fea0053dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
