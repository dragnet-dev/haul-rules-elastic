// Dragnet [Ransomware]: dragnet-ransomware-2023-3896 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: eb3831dd-5927-5979-89fc-4af0c4ed069d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
