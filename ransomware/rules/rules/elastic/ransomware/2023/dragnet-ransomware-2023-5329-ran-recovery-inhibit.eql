// Dragnet [Ransomware]: dragnet-ransomware-2023-5329 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: a8cf73d2-08d0-59f1-8c7e-570879b8354f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
