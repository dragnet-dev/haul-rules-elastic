// Dragnet [Ransomware]: dragnet-ransomware-2023-1186 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 76313c86-964a-54d1-b1fb-563710e0c9cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
