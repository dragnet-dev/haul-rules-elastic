// Dragnet [Ransomware]: dragnet-ransomware-2023-3532 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 9d64a310-947f-58d7-9331-3e9696880cde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
