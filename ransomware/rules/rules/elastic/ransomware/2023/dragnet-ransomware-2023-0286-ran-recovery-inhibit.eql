// Dragnet [Ransomware]: dragnet-ransomware-2023-0286 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: b2019f9b-52f7-5dae-b4a2-fec4c5fc3565

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
