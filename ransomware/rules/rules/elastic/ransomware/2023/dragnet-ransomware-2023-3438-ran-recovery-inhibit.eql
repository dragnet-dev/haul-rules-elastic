// Dragnet [Ransomware]: dragnet-ransomware-2023-3438 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a8864b27-7d66-5de0-91c0-d27214e53bf9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
