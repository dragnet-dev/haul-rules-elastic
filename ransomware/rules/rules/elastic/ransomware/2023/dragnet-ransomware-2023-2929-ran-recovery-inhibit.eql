// Dragnet [Ransomware]: dragnet-ransomware-2023-2929 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 3672af58-ca4c-56e8-ba27-fedac3554683

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
