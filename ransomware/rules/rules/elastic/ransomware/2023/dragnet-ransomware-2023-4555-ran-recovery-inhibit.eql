// Dragnet [Ransomware]: dragnet-ransomware-2023-4555 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f4869cd7-4351-5cd9-9483-9722114cd99e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
