// Dragnet [Ransomware]: dragnet-ransomware-2023-1337 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b3d592a2-b56f-57d1-a53c-2d7530f1648e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
