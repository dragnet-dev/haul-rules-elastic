// Dragnet [Ransomware]: dragnet-ransomware-2023-4370 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 6af978f5-544f-57a1-91f6-493d062f3883

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
