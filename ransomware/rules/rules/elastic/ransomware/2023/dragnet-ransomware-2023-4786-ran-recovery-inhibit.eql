// Dragnet [Ransomware]: dragnet-ransomware-2023-4786 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 7a561c81-3e63-5d8c-bf4e-5765e698beb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
