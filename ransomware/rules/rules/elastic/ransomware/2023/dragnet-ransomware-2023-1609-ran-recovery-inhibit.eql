// Dragnet [Ransomware]: dragnet-ransomware-2023-1609 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4333a44d-1379-5a14-9a08-e3c4a438b66d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
