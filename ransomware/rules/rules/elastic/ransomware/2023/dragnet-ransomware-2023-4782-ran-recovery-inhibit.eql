// Dragnet [Ransomware]: dragnet-ransomware-2023-4782 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5e4a0fdb-34fc-50fe-af52-43ae741571a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
