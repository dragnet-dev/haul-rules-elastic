// Dragnet [Ransomware]: dragnet-ransomware-2023-1041 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ae24b46f-9cda-53ab-9fd4-1fc0e9de17df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
