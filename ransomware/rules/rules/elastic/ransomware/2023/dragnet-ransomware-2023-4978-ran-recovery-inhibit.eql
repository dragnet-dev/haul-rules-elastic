// Dragnet [Ransomware]: dragnet-ransomware-2023-4978 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 34711f0f-2ea4-51fb-af3c-17996cf20952

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
