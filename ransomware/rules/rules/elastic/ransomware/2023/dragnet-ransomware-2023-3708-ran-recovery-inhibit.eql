// Dragnet [Ransomware]: dragnet-ransomware-2023-3708 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 406b39bd-91eb-5976-bc86-ee75d54c955e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
