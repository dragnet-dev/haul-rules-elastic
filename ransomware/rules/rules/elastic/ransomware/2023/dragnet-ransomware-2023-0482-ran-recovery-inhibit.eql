// Dragnet [Ransomware]: dragnet-ransomware-2023-0482 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 1d4d9771-5afa-57fc-8f32-bcc4b3f5d408

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
