// Dragnet [Ransomware]: dragnet-ransomware-2023-2381 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 6a0f1b53-0fa2-5a28-92fa-5867226eaa57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
