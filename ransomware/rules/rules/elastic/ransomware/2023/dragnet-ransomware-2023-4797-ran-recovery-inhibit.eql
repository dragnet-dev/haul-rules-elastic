// Dragnet [Ransomware]: dragnet-ransomware-2023-4797 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 8756ec77-3b93-5ab9-86f3-cdd32282e49e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
