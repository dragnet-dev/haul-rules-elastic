// Dragnet [Ransomware]: dragnet-ransomware-2023-2865 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 547b560c-59f2-5819-b718-142eef11dc70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
