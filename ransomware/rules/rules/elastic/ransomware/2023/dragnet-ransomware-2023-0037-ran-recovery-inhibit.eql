// Dragnet [Ransomware]: dragnet-ransomware-2023-0037 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 90da2686-230e-5056-9726-e18196b94395

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
