// Dragnet [Ransomware]: dragnet-ransomware-2023-2418 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 0a111029-6ffa-53d8-916a-15b21c9e17bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
