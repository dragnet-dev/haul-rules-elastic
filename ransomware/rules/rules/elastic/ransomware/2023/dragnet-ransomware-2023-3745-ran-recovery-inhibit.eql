// Dragnet [Ransomware]: dragnet-ransomware-2023-3745 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 2ede2313-e15e-57d2-8452-f1b2668bbee4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
