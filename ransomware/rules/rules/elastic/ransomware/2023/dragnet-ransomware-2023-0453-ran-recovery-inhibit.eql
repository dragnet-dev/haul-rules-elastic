// Dragnet [Ransomware]: dragnet-ransomware-2023-0453 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 1622d265-bd60-5e8e-93ec-ac6154f3d142

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
