// Dragnet [Ransomware]: dragnet-ransomware-2023-1886 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 60ecaea4-4918-5e84-8711-16d7f0e98157

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
