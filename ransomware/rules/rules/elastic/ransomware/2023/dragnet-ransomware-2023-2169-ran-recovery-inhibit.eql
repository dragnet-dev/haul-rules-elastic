// Dragnet [Ransomware]: dragnet-ransomware-2023-2169 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 7503b8cb-34bc-5817-8a26-7b3a606a42b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
