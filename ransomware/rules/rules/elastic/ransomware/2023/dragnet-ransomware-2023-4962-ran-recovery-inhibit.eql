// Dragnet [Ransomware]: dragnet-ransomware-2023-4962 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 406a3e05-7dba-5e67-9c62-3b234d22ca26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
