// Dragnet [Ransomware]: dragnet-ransomware-2023-3762 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 1ea234e7-5de6-5dda-a8c0-861e318633c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
