// Dragnet [Ransomware]: dragnet-ransomware-2023-1377 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 8ae7a3c3-831c-5ca8-9e92-f009e289454b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
