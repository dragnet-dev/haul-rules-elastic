// Dragnet [Ransomware]: dragnet-ransomware-2023-4525 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 43879fe4-b31c-5a12-8ae0-6d6bc6d0dd75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
