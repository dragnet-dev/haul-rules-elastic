// Dragnet [Ransomware]: dragnet-ransomware-2023-2697 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 52000b3c-ea10-5bb3-8ffc-0950aff068d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
