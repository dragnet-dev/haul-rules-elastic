// Dragnet [Ransomware]: dragnet-ransomware-2023-4696 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 89ca6254-936c-5183-9d47-8a23cce57195

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
