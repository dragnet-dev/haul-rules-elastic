// Dragnet [Ransomware]: dragnet-ransomware-2023-0859 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 8377090b-db1f-5a6a-b617-00afedb6466e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
