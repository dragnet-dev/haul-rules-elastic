// Dragnet [Ransomware]: dragnet-ransomware-2023-1806 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 68aa0675-f0c3-57cf-bd1b-2f756510a6b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
