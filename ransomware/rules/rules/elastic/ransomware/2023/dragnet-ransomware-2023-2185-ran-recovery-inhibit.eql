// Dragnet [Ransomware]: dragnet-ransomware-2023-2185 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 855d2925-f891-5854-bdea-e97a2402c0a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
