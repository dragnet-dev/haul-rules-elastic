// Dragnet [Ransomware]: dragnet-ransomware-2023-2476 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: d1538c51-8897-5311-a4c6-ba70f75dd7f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
