// Dragnet [Ransomware]: dragnet-ransomware-2023-1218 — Recovery Inhibition (rancoz)
// Status: experimental | Level: high | ID: c6f0bba5-8ac3-59f8-9cb6-1c16fe25c356

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
