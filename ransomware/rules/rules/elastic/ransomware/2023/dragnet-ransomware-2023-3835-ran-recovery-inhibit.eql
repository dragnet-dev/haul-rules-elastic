// Dragnet [Ransomware]: dragnet-ransomware-2023-3835 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: e5f13852-1189-5a48-a9c5-e9b87b49c419

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
