// Dragnet [Ransomware]: dragnet-ransomware-2023-3214 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 3eea7db6-4775-5316-8e08-506e4eb0fc6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
