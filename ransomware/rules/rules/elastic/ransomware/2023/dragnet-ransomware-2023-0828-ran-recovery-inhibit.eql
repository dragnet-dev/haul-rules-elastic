// Dragnet [Ransomware]: dragnet-ransomware-2023-0828 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 0eda8974-e65d-588e-bffd-df2bf90e46c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
