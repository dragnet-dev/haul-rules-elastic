// Dragnet [Ransomware]: dragnet-ransomware-2023-2408 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 463ba3ee-ae93-5dd6-a0c2-4dce9bb99080

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
