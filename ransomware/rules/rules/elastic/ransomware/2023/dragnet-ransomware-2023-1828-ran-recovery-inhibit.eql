// Dragnet [Ransomware]: dragnet-ransomware-2023-1828 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: cbd604ab-52f6-5478-961b-a328e3ca5967

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
