// Dragnet [Ransomware]: dragnet-ransomware-2023-4667 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 396ae513-f065-5f5c-b3f0-d01a1133253f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
