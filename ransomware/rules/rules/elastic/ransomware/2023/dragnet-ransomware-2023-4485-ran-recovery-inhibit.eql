// Dragnet [Ransomware]: dragnet-ransomware-2023-4485 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: f5c307d4-643e-56c2-a313-04d96e654559

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
