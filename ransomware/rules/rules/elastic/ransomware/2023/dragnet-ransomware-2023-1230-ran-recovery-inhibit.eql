// Dragnet [Ransomware]: dragnet-ransomware-2023-1230 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 8185759a-e818-5fa3-a816-54569f766cfc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
