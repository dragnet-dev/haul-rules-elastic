// Dragnet [Ransomware]: dragnet-ransomware-2023-3094 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3fccdbc6-3509-512f-8889-0504930aa30b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
