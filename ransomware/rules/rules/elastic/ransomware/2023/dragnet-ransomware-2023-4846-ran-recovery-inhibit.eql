// Dragnet [Ransomware]: dragnet-ransomware-2023-4846 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 11df5fb1-812d-5a3b-ba29-ab2deeb0bbf6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
