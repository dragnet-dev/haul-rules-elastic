// Dragnet [Ransomware]: dragnet-ransomware-2023-1711 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 68aba204-ca27-54aa-92dd-67526772e71d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
