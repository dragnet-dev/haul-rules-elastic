// Dragnet [Ransomware]: dragnet-ransomware-2023-2763 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: aa7f121a-676d-50c1-92d2-a8260f46b8d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
