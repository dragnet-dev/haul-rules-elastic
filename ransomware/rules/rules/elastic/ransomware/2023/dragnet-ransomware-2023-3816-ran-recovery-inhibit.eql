// Dragnet [Ransomware]: dragnet-ransomware-2023-3816 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: c53d375d-cea2-54a7-ad6d-523d4ffe69fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
