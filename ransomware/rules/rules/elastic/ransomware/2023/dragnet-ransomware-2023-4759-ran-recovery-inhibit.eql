// Dragnet [Ransomware]: dragnet-ransomware-2023-4759 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 60f6fc17-3945-5b39-bd90-f96959b2baa1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
