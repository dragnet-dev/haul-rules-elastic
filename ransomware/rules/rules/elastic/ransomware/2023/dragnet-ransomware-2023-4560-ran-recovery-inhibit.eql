// Dragnet [Ransomware]: dragnet-ransomware-2023-4560 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: fd3ebf4b-dc67-50d6-933f-dc5ac3fb4065

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
