// Dragnet [Ransomware]: dragnet-ransomware-2023-0503 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: fa04a3e3-afd4-5d64-a4a2-5c84e199ba09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
