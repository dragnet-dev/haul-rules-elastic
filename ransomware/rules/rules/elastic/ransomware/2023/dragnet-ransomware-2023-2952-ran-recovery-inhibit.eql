// Dragnet [Ransomware]: dragnet-ransomware-2023-2952 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 59866c86-fe77-562e-b15c-ac90a56ad748

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
