// Dragnet [Ransomware]: dragnet-ransomware-2023-3462 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 6cf1d62b-7518-525b-812e-6fae6b207dd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
