// Dragnet [Ransomware]: dragnet-ransomware-2023-4918 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 18f93f1d-f6b6-50c2-adda-ad7e20bb4bb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
