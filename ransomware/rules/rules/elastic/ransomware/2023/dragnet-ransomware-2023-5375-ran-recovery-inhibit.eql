// Dragnet [Ransomware]: dragnet-ransomware-2023-5375 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 5f608441-ab11-5e57-91e9-9d5642c31f04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
