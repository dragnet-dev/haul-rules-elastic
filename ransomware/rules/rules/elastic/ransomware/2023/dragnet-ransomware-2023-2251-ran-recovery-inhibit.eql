// Dragnet [Ransomware]: dragnet-ransomware-2023-2251 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ce64c2c7-22f1-53e0-96e8-ad2df27e47cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
