// Dragnet [Ransomware]: dragnet-ransomware-2023-4660 — Recovery Inhibition (cuba)
// Status: experimental | Level: high | ID: 6f12fea5-5c78-545b-8c4f-9fddd1faedcc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
