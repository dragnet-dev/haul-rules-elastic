// Dragnet [Ransomware]: dragnet-ransomware-2023-4310 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 4833ef16-5943-53ac-9c27-622e251ff6ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
