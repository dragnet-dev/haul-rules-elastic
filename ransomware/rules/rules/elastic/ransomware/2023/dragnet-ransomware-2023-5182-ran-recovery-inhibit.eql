// Dragnet [Ransomware]: dragnet-ransomware-2023-5182 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 30887c62-8ecc-53fb-96fc-8d5928328a18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
