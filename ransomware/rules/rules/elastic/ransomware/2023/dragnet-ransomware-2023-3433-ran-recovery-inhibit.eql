// Dragnet [Ransomware]: dragnet-ransomware-2023-3433 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 137c343b-4a54-5479-a349-3bab10e06074

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
