// Dragnet [Ransomware]: dragnet-ransomware-2023-2336 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: b48613fc-0b7a-5d8b-b280-c4ff1eef19a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
