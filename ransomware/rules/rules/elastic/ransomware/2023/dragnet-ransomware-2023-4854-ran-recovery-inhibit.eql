// Dragnet [Ransomware]: dragnet-ransomware-2023-4854 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f8db2784-bae4-507a-844d-029ecdd62c9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
