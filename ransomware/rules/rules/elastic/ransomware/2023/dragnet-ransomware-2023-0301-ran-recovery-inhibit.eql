// Dragnet [Ransomware]: dragnet-ransomware-2023-0301 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2c76b8ad-7863-5c77-ae0b-5da653604957

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
