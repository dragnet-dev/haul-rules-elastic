// Dragnet [Ransomware]: dragnet-ransomware-2023-3649 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 38fb7945-ef7b-56e3-a099-628a652ac791

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
