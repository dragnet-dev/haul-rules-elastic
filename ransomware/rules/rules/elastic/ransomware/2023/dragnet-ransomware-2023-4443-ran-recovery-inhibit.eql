// Dragnet [Ransomware]: dragnet-ransomware-2023-4443 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 73876eb4-59af-5154-90f7-b97698c704a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
