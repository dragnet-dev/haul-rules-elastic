// Dragnet [Ransomware]: dragnet-ransomware-2023-3301 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6b176386-6109-54b3-ab99-929d772caea0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
