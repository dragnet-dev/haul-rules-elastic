// Dragnet [Ransomware]: dragnet-ransomware-2023-0818 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 3a86f8ab-2c59-5d2b-afdf-2e2b084abeb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
