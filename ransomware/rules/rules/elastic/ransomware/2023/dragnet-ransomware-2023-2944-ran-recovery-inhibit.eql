// Dragnet [Ransomware]: dragnet-ransomware-2023-2944 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: a53d51a7-c9a1-5233-b609-cb9c6701aee2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
