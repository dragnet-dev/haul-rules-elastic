// Dragnet [Ransomware]: dragnet-ransomware-2023-1599 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 82a6c8c8-7e84-55c9-9b05-4d29b6a62301

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
