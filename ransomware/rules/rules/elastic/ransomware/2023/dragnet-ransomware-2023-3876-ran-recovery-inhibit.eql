// Dragnet [Ransomware]: dragnet-ransomware-2023-3876 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: dcd4bf31-7b50-5038-b40d-8e2dc71a3f5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
