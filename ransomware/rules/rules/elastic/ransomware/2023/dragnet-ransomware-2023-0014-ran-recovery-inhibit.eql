// Dragnet [Ransomware]: dragnet-ransomware-2023-0014 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: ae032836-db66-5900-b101-c67044a840d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
