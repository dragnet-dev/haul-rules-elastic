// Dragnet [Ransomware]: dragnet-ransomware-2023-1324 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 358a7cbc-7ecc-5fe8-ab65-98afe0f1d087

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
