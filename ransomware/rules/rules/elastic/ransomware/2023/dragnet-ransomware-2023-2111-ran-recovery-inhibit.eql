// Dragnet [Ransomware]: dragnet-ransomware-2023-2111 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 1f634afa-8b93-5a62-a2ef-a8a1dc3ac968

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
