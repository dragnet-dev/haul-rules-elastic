// Dragnet [Ransomware]: dragnet-ransomware-2023-5043 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3da89146-9d16-543d-8111-b721b77b86c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
