// Dragnet [Ransomware]: dragnet-ransomware-2023-4606 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 87d9636d-c392-5ce7-8f10-6ce457cf3226

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
