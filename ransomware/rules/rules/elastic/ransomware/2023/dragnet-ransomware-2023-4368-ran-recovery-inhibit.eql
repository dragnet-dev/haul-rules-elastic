// Dragnet [Ransomware]: dragnet-ransomware-2023-4368 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e75db43e-653f-500a-bf8b-4fe6afe02886

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
