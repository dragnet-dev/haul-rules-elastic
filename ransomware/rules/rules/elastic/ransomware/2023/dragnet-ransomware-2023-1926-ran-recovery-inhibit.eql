// Dragnet [Ransomware]: dragnet-ransomware-2023-1926 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: db94ec59-f4c6-5387-8d04-06f66cbfe50a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
