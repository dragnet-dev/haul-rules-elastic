// Dragnet [Ransomware]: dragnet-ransomware-2023-3284 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 474b1074-11ff-5323-9559-96cb8d59d0eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
