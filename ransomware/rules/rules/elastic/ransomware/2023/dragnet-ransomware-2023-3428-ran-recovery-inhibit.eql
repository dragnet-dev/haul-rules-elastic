// Dragnet [Ransomware]: dragnet-ransomware-2023-3428 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ae6809c6-3091-54f1-b6ef-18aaa09a3f62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
