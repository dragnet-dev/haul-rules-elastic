// Dragnet [Ransomware]: dragnet-ransomware-2023-3286 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 53babea3-1896-551c-a540-c22f340ee26e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
