// Dragnet [Ransomware]: dragnet-ransomware-2023-1700 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: d9f693bb-5b32-54af-bc51-bf981dbb817c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
