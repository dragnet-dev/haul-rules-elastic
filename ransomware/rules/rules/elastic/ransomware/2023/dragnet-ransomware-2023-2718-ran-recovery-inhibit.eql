// Dragnet [Ransomware]: dragnet-ransomware-2023-2718 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0da2fcae-4a40-550a-b981-e3bd1cf5ee9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
