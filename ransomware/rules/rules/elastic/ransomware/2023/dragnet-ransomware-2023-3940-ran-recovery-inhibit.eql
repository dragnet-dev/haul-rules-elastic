// Dragnet [Ransomware]: dragnet-ransomware-2023-3940 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: cc7b0e4c-0860-5ef9-9404-d8e757a8c8d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
