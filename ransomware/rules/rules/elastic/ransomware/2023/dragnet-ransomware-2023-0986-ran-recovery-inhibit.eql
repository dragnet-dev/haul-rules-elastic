// Dragnet [Ransomware]: dragnet-ransomware-2023-0986 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7f9c21e2-5e82-5b43-a582-968461cc0db9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
