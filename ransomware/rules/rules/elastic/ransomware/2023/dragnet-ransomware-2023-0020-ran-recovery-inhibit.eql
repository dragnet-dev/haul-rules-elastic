// Dragnet [Ransomware]: dragnet-ransomware-2023-0020 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 04c81177-985a-55a3-bdcd-de025c303e75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
