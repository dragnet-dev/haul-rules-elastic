// Dragnet [Ransomware]: dragnet-ransomware-2023-1059 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: c30ff4b1-0d3e-5ba4-beea-71810932cc63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
