// Dragnet [Ransomware]: dragnet-ransomware-2023-1034 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 76023fce-4e63-553b-a5a3-b7f4699e421b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
