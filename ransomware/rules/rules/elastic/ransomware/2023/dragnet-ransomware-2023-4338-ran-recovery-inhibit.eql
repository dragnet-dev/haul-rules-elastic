// Dragnet [Ransomware]: dragnet-ransomware-2023-4338 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: be81652e-5dcc-5ee9-bdc2-d61e775618e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
