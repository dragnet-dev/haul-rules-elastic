// Dragnet [Ransomware]: dragnet-ransomware-2023-4940 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: faab2434-aa6b-5149-a980-cc08e2a27d59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
