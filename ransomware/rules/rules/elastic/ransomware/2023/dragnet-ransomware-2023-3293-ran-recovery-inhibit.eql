// Dragnet [Ransomware]: dragnet-ransomware-2023-3293 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: be943549-64fe-5636-9e34-628b6b644fe9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
