// Dragnet [Ransomware]: dragnet-ransomware-2023-2283 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 1d083c23-2dbb-5451-ad59-04e8f308ec5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
