// Dragnet [Ransomware]: dragnet-ransomware-2023-4395 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 1179b3ca-327c-5db9-9c33-2da69973ab71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
