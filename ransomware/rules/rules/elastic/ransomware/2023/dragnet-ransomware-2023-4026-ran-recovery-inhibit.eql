// Dragnet [Ransomware]: dragnet-ransomware-2023-4026 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5b74bee5-da15-5a3c-805b-ff1086b7b2c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
