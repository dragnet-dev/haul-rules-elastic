// Dragnet [Ransomware]: dragnet-ransomware-2023-0787 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 94b5b883-efb5-5b4d-a044-7d8b08167644

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
