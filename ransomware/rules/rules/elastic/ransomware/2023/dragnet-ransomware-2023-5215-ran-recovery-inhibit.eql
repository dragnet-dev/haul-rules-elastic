// Dragnet [Ransomware]: dragnet-ransomware-2023-5215 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 9ecf78f9-efb3-50cb-bd07-be596217940d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
