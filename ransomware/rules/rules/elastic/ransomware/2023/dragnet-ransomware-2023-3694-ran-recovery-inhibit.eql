// Dragnet [Ransomware]: dragnet-ransomware-2023-3694 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 92b3c000-b299-56d4-b741-e895bbb87e27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
