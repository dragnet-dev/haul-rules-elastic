// Dragnet [Ransomware]: dragnet-ransomware-2023-3865 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1c69b9a4-5bb7-529e-9875-a3709f78106f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
