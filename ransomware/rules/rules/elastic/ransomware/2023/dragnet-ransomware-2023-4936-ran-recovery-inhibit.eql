// Dragnet [Ransomware]: dragnet-ransomware-2023-4936 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 9d48ffc5-8844-5ecc-ba8d-bd8e9073d340

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
