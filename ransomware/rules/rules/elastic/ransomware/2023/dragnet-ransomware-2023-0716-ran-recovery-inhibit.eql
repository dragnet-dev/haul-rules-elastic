// Dragnet [Ransomware]: dragnet-ransomware-2023-0716 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 68e2e235-c5ee-5a19-a19a-de75f13b000c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
