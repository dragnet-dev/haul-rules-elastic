// Dragnet [Ransomware]: dragnet-ransomware-2023-3723 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c934fb01-7c05-513a-a0e8-0b4026d41e5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
