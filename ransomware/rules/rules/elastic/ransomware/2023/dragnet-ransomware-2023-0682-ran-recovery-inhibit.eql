// Dragnet [Ransomware]: dragnet-ransomware-2023-0682 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 9d309a81-fe36-5c1b-a712-925e64d0da54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
