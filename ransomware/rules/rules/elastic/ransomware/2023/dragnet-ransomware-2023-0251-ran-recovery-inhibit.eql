// Dragnet [Ransomware]: dragnet-ransomware-2023-0251 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 719df1e6-8e15-50bc-b344-53fc4701e3ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
