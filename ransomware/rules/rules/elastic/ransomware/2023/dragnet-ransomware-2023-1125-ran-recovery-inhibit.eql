// Dragnet [Ransomware]: dragnet-ransomware-2023-1125 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: eeea4122-02d8-5343-80ad-70c412b2fb6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
