// Dragnet [Ransomware]: dragnet-ransomware-2023-5096 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 412eb926-c06f-5c82-80ed-41d6af7aefc0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
