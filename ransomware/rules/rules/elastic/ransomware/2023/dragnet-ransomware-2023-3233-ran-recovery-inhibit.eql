// Dragnet [Ransomware]: dragnet-ransomware-2023-3233 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: 9678ea89-4e07-5ecd-9909-faa8ebfa05f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
