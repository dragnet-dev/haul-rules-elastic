// Dragnet [Ransomware]: dragnet-ransomware-2023-3216 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 6b9276d9-35b0-52af-88e7-c3c8897f8757

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
