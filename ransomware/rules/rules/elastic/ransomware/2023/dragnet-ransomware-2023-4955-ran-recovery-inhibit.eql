// Dragnet [Ransomware]: dragnet-ransomware-2023-4955 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bace4337-036a-5df7-a9bd-f268bc7ab4c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
