// Dragnet [Ransomware]: dragnet-ransomware-2023-1991 — Recovery Inhibition (siegedsec)
// Status: experimental | Level: high | ID: ce8dc714-db94-5a1f-92c5-10d6653c1af9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
