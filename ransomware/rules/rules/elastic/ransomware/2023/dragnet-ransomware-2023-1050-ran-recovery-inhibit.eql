// Dragnet [Ransomware]: dragnet-ransomware-2023-1050 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 4ecc5f01-3392-5b3c-9621-649bb489b148

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
