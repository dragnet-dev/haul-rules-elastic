// Dragnet [Ransomware]: dragnet-ransomware-2023-0640 — Recovery Inhibition (trigona)
// Status: deprecated | Level: high | ID: f1a85faa-1244-5847-888f-55a3be0af87b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
