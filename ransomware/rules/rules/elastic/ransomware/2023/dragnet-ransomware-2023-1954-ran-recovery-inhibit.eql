// Dragnet [Ransomware]: dragnet-ransomware-2023-1954 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 97cbd45d-e237-5088-b3f2-43415ec35aa6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
