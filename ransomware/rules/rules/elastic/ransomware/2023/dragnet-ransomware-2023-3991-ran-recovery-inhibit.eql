// Dragnet [Ransomware]: dragnet-ransomware-2023-3991 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: d832e0f6-93c7-5f61-b424-f1e9687f278f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
