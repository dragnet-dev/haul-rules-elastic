// Dragnet [Ransomware]: dragnet-ransomware-2023-3527 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 39be0b6f-5281-5c41-b476-d296549887de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
