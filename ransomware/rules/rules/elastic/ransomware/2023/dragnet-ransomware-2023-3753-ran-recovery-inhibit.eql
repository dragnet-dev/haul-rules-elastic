// Dragnet [Ransomware]: dragnet-ransomware-2023-3753 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 6c3680e5-1f3f-57b5-92d7-631579fc908d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
