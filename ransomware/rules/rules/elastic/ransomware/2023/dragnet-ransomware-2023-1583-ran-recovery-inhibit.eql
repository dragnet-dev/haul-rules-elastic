// Dragnet [Ransomware]: dragnet-ransomware-2023-1583 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 7f5d6b4d-84d7-5ee5-9784-f99e9f660fc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
