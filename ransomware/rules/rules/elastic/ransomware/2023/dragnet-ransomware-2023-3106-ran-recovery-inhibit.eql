// Dragnet [Ransomware]: dragnet-ransomware-2023-3106 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 429412c7-1876-53fa-afc7-ce28277e5278

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
