// Dragnet [Ransomware]: dragnet-ransomware-2023-4029 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 03afc3e9-ca8f-52cf-acbc-9f0db1e6fa1f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
