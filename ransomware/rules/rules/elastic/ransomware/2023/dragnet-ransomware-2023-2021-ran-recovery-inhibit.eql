// Dragnet [Ransomware]: dragnet-ransomware-2023-2021 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 14614104-a5b1-54df-a1ab-ee64977f7e7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
