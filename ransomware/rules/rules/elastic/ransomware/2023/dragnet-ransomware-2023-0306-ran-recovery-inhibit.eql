// Dragnet [Ransomware]: dragnet-ransomware-2023-0306 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: ec310dff-4851-54c4-9aa9-76da9f7db948

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
