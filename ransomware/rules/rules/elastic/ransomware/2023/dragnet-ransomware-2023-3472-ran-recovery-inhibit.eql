// Dragnet [Ransomware]: dragnet-ransomware-2023-3472 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ac42134e-1bc3-537f-b184-451570ad5cc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
