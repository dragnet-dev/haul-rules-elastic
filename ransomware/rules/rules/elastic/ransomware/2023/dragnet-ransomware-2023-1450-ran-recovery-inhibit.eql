// Dragnet [Ransomware]: dragnet-ransomware-2023-1450 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 22dccdcb-f344-57f9-bb56-083452d162c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
