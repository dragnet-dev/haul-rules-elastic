// Dragnet [Ransomware]: dragnet-ransomware-2023-3935 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6d76b19a-529d-58e8-93e7-95f801080570

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
