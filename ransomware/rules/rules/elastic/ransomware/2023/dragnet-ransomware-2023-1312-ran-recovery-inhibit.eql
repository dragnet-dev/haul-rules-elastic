// Dragnet [Ransomware]: dragnet-ransomware-2023-1312 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: fe348e41-955c-5dab-ae5d-27e19362937d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
