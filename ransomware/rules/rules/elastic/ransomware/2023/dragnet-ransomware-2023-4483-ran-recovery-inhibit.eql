// Dragnet [Ransomware]: dragnet-ransomware-2023-4483 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 1523d34a-14b2-5b35-af89-d5aab575b76a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
