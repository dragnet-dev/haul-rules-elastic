// Dragnet [Ransomware]: dragnet-ransomware-2023-2517 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 55d87687-dc4c-581e-abc2-a3890141d6f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
