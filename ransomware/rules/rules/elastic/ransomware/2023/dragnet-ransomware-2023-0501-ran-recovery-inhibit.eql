// Dragnet [Ransomware]: dragnet-ransomware-2023-0501 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 84ef1f30-1b30-55b0-bcc5-92e9c9f7950a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
