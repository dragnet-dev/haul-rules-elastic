// Dragnet [Ransomware]: dragnet-ransomware-2023-4917 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d3bcc14d-de4c-55cf-be02-b0cb11f742be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
