// Dragnet [Ransomware]: dragnet-ransomware-2023-5269 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7f7ce61b-c1ba-5893-b3a0-63b6af2c3328

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
