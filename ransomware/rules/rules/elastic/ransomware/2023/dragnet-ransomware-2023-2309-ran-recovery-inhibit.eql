// Dragnet [Ransomware]: dragnet-ransomware-2023-2309 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: ae1a30ea-2a93-57b2-8dd3-b28f4ccf2bb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
