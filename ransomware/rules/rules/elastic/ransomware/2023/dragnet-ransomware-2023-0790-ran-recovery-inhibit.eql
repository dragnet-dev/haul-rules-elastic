// Dragnet [Ransomware]: dragnet-ransomware-2023-0790 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 58267cd6-0e18-5fce-ac7e-22fc84d7f34e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
