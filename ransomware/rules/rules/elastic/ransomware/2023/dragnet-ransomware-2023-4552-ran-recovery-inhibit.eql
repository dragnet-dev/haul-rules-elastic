// Dragnet [Ransomware]: dragnet-ransomware-2023-4552 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 167f691f-3129-52ba-8b85-7f574b88e731

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
