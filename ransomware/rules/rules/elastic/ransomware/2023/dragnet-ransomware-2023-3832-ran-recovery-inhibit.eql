// Dragnet [Ransomware]: dragnet-ransomware-2023-3832 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 16773fbc-7263-50f7-b61a-330f09b02f41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
