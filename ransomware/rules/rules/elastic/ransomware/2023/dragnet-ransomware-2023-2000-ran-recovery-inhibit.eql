// Dragnet [Ransomware]: dragnet-ransomware-2023-2000 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 33c688b6-937b-5dd9-a46d-a315fd4e3091

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
