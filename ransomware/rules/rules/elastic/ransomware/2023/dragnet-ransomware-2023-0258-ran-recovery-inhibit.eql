// Dragnet [Ransomware]: dragnet-ransomware-2023-0258 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: baa5fe1a-9ab3-5f99-8e0c-a8040e80d4ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
