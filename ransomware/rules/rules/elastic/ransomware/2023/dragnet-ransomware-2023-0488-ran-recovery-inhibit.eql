// Dragnet [Ransomware]: dragnet-ransomware-2023-0488 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 083b0f41-cf60-587d-b596-96381bc966b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
