// Dragnet [Ransomware]: dragnet-ransomware-2023-3404 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 1e38c4bd-542a-5dbf-940c-abeac22f0794

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
