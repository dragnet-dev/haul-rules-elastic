// Dragnet [Ransomware]: dragnet-ransomware-2023-3571 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ccce38fc-ea35-572b-9a90-0d2f65454f97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
