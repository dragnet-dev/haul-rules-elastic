// Dragnet [Ransomware]: dragnet-ransomware-2023-0040 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 44ddd73e-94d0-546d-a44f-b7c4acd78321

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
