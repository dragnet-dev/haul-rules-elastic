// Dragnet [Ransomware]: dragnet-ransomware-2023-1273 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: bb623efa-4938-52b6-a82c-4db62124a8c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
