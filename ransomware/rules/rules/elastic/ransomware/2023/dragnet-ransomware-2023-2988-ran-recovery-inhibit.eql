// Dragnet [Ransomware]: dragnet-ransomware-2023-2988 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: f8259743-0693-5330-9cc3-ddbe85ca480a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
