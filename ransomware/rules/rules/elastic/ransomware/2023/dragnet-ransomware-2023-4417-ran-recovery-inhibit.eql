// Dragnet [Ransomware]: dragnet-ransomware-2023-4417 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 499970ad-9f14-55f0-a235-7faed1b03a1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
