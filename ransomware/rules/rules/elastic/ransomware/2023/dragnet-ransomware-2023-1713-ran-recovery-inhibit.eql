// Dragnet [Ransomware]: dragnet-ransomware-2023-1713 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 4fb15e90-f022-5fad-a147-f44654a54d4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
