// Dragnet [Ransomware]: dragnet-ransomware-2023-0214 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: be8cc0e8-489d-55c7-98e9-cc1798345355

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
