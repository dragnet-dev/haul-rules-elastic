// Dragnet [Ransomware]: dragnet-ransomware-2023-2095 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: e36c9408-e8af-5587-b96d-a0f947848875

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
