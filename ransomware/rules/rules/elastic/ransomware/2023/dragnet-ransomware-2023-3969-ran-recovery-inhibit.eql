// Dragnet [Ransomware]: dragnet-ransomware-2023-3969 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: ff7c7dd1-b3a7-53fe-9be5-a3eb262c26af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
