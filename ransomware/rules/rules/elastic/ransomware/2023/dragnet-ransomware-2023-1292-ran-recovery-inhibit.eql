// Dragnet [Ransomware]: dragnet-ransomware-2023-1292 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c0b20b16-5490-5542-8cec-cc72fbdb7864

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
