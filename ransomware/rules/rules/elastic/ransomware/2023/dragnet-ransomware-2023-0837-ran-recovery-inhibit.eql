// Dragnet [Ransomware]: dragnet-ransomware-2023-0837 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 07c755f1-520a-573f-bb2b-46adc373b916

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
