// Dragnet [Ransomware]: dragnet-ransomware-2023-4044 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 40956c60-a38c-5e43-9693-5db37e89759b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
