// Dragnet [Ransomware]: dragnet-ransomware-2023-4865 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 16479d8e-6ab2-59ba-8227-4cfc52ad9542

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
