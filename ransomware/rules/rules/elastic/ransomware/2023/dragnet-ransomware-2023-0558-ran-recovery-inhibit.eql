// Dragnet [Ransomware]: dragnet-ransomware-2023-0558 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: fe4fe860-81d4-5adc-a131-c93d9de56ec6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
