// Dragnet [Ransomware]: dragnet-ransomware-2023-2993 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 55d876cb-d8bf-5daa-b738-6ee0cc88d736

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
