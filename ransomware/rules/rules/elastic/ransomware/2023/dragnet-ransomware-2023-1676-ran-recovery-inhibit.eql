// Dragnet [Ransomware]: dragnet-ransomware-2023-1676 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: 13b232f5-2d04-5e5a-ac0f-f9b9dadb9e4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
