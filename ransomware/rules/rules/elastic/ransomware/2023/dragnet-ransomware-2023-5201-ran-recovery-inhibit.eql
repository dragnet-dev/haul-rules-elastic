// Dragnet [Ransomware]: dragnet-ransomware-2023-5201 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 6c222389-60dd-502b-a4f2-11ba51948253

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
