// Dragnet [Ransomware]: dragnet-ransomware-2023-4116 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 1f85f9a6-aea1-58e6-8792-cebc33c425b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
