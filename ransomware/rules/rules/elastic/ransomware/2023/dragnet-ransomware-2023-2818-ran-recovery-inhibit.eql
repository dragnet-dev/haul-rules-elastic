// Dragnet [Ransomware]: dragnet-ransomware-2023-2818 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 02f38a7c-61d4-5837-9893-1586994168c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
