// Dragnet [Ransomware]: dragnet-ransomware-2023-3849 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9301734f-f5bb-5c46-ad69-3a8ef74ef909

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
