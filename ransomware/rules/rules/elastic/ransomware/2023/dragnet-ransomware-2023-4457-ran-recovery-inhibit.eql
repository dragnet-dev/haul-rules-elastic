// Dragnet [Ransomware]: dragnet-ransomware-2023-4457 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2ee4a2eb-acbf-5290-a054-20516a3c00bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
