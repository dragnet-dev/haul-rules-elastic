// Dragnet [Ransomware]: dragnet-ransomware-2023-3551 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: cc84701a-d7f0-5cac-95fc-d9d0ce67310e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
