// Dragnet [Ransomware]: dragnet-ransomware-2023-5351 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 77cafee9-65c9-54eb-9010-67a2276436fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
