// Dragnet [Ransomware]: dragnet-ransomware-2023-1726 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 17534c27-6827-5189-be47-9c536f30b19b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
