// Dragnet [Ransomware]: dragnet-ransomware-2023-0665 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ad676d00-2265-5679-b8ca-4d8e3c78b904

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
