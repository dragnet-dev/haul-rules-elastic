// Dragnet [Ransomware]: dragnet-ransomware-2023-0601 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: a3fc3ecb-3e53-5e18-882b-341005568470

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
