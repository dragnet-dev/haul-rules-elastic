// Dragnet [Ransomware]: dragnet-ransomware-2023-4655 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 6944ab17-0422-598e-98bf-edcc9df703df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
