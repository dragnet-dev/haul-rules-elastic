// Dragnet [Ransomware]: dragnet-ransomware-2023-1900 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: a1f1e02f-3883-5541-89d3-6719406c0f5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
