// Dragnet [Ransomware]: dragnet-ransomware-2023-0625 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 53582555-1663-5931-8d89-5bfb0981afa1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
