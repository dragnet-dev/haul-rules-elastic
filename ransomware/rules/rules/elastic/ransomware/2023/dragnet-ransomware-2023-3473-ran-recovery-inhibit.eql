// Dragnet [Ransomware]: dragnet-ransomware-2023-3473 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 9dde37fb-4ada-5fb2-9f4e-1ccb683d9c85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
