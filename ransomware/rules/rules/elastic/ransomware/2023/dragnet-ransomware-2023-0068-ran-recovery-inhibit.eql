// Dragnet [Ransomware]: dragnet-ransomware-2023-0068 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: c7b59b8b-0a41-5760-b69f-a1a588280c56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
