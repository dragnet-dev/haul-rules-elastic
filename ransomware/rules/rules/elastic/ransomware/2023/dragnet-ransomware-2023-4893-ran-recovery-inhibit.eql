// Dragnet [Ransomware]: dragnet-ransomware-2023-4893 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0f2f789a-5f60-5cfe-a2cc-af556c186c0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
