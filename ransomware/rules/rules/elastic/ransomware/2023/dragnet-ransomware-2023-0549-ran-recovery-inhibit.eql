// Dragnet [Ransomware]: dragnet-ransomware-2023-0549 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 88f92c73-6c31-5541-aa89-bed4b3f8207a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
