// Dragnet [Ransomware]: dragnet-ransomware-2023-0958 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 7f393a9c-8497-5475-b93a-cb3d04dfb569

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
