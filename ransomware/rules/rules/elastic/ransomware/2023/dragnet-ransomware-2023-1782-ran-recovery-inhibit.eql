// Dragnet [Ransomware]: dragnet-ransomware-2023-1782 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 49e6ca79-24ae-5926-aacf-ed1022264887

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
