// Dragnet [Ransomware]: dragnet-ransomware-2023-2081 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a59e90a6-0f6f-59d2-a4e9-65f3d86c110a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
