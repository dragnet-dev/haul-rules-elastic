// Dragnet [Ransomware]: dragnet-ransomware-2023-5357 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 2733b3cc-5b83-58c8-a426-4aadd0f018d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
