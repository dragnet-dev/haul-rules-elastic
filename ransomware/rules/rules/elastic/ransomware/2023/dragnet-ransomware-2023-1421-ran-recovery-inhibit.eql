// Dragnet [Ransomware]: dragnet-ransomware-2023-1421 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 254ef9fc-0270-5fa6-9f7f-d501cb74b651

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
