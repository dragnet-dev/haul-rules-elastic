// Dragnet [Ransomware]: dragnet-ransomware-2023-0654 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 9c4c865c-3b7b-5e80-8a3c-e64eb414baee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
