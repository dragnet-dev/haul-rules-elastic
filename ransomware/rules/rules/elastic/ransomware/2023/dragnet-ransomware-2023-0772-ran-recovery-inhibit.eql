// Dragnet [Ransomware]: dragnet-ransomware-2023-0772 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: b86337b2-b429-5de0-bd90-562225df9daa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
