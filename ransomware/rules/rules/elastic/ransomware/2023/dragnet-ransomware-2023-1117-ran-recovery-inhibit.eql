// Dragnet [Ransomware]: dragnet-ransomware-2023-1117 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8903e891-b060-5eee-b938-1f1dfd5f6d55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
