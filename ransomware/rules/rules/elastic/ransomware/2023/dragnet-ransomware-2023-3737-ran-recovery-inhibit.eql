// Dragnet [Ransomware]: dragnet-ransomware-2023-3737 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 320ce67f-0bc2-59c5-8069-b8d2f0eb20f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
