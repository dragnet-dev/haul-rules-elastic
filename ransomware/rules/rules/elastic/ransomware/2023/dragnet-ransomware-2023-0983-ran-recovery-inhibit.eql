// Dragnet [Ransomware]: dragnet-ransomware-2023-0983 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 310f2e50-e968-564b-b398-b91206c12622

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
