// Dragnet [Ransomware]: dragnet-ransomware-2023-1722 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 57a578e0-d0f5-53be-b475-9072d01be273

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
