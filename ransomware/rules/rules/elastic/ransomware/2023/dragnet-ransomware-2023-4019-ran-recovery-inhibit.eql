// Dragnet [Ransomware]: dragnet-ransomware-2023-4019 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: 9a1ba85c-c67c-5248-928e-588c5685bb6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
