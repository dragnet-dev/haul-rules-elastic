// Dragnet [Ransomware]: dragnet-ransomware-2023-2616 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: acdcd0ea-f780-5112-b7d1-b36958cb38bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
