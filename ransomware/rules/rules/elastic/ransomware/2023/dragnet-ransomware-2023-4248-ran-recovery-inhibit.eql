// Dragnet [Ransomware]: dragnet-ransomware-2023-4248 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 06b1423c-1e35-53d1-9e0c-600c783822a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
