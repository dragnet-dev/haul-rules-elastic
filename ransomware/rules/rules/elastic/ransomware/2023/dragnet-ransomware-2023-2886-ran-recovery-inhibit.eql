// Dragnet [Ransomware]: dragnet-ransomware-2023-2886 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 1e1eaf8d-4ab4-5d2f-baa1-ee46c50bf20d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
