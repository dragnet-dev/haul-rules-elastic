// Dragnet [Ransomware]: dragnet-ransomware-2023-2232 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 638093c5-900b-5723-bd2d-d201661e6ff2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
