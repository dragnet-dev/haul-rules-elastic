// Dragnet [Ransomware]: dragnet-ransomware-2023-2105 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c78ea97b-5023-586a-93a1-fee21b129fe2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
