// Dragnet [Ransomware]: dragnet-ransomware-2023-1238 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bbc16963-163c-53dc-8623-7882e8b860f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
