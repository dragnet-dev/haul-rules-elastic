// Dragnet [Ransomware]: dragnet-ransomware-2023-1311 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 24fd1768-5f6f-552b-8de2-8339a1b3feb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
