// Dragnet [Ransomware]: dragnet-ransomware-2023-4381 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 0673272c-3733-51f1-9548-d82e1bcd01f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
