// Dragnet [Ransomware]: dragnet-ransomware-2023-0327 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 8f5b5768-006c-522a-bd00-54e9d3ebac22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
