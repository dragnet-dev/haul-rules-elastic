// Dragnet [Ransomware]: dragnet-ransomware-2023-0352 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8dce97aa-88d2-5566-a717-b10ff8008344

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
