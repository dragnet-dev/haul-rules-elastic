// Dragnet [Ransomware]: dragnet-ransomware-2023-1647 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fa60878b-d94c-585f-b0ef-7f3a2c4102e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
