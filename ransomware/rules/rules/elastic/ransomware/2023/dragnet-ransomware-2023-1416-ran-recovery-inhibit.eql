// Dragnet [Ransomware]: dragnet-ransomware-2023-1416 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 04b97b3c-a1ab-547e-9071-37498e57662f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
