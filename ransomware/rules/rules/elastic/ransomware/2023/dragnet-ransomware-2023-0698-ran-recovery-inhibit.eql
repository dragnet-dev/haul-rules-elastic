// Dragnet [Ransomware]: dragnet-ransomware-2023-0698 — Recovery Inhibition (daixin)
// Status: deprecated | Level: high | ID: 1c610d68-ca8a-5cc6-b357-59439bf2049c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
