// Dragnet [Ransomware]: dragnet-ransomware-2023-2298 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d51c8cd5-c3fe-56b6-b841-85982b713171

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
