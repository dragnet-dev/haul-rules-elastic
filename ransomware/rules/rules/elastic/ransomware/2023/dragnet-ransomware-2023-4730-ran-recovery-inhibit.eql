// Dragnet [Ransomware]: dragnet-ransomware-2023-4730 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: 837ff92f-1ccf-5e88-a78c-6d1553ba40d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
