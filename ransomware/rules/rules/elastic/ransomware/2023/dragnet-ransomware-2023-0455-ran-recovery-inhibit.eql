// Dragnet [Ransomware]: dragnet-ransomware-2023-0455 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: dd920ec9-9230-5643-9fb8-4e23cecbc9c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
