// Dragnet [Ransomware]: dragnet-ransomware-2023-0477 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 551e04f6-42b9-5eab-afdc-26f59e324938

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
