// Dragnet [Ransomware]: dragnet-ransomware-2023-3819 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 856eae60-89f3-5edb-84b6-6cd9b8409842

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
