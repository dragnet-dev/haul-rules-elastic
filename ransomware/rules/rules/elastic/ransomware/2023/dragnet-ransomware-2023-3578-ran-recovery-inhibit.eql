// Dragnet [Ransomware]: dragnet-ransomware-2023-3578 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: f63d03de-009f-56fe-b4f9-7b5af2ecef6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
