// Dragnet [Ransomware]: dragnet-ransomware-2023-1399 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 72d77a37-3617-5606-bc73-079ed0fde9a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
