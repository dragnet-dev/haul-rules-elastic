// Dragnet [Ransomware]: dragnet-ransomware-2023-0459 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 35e7d5db-70eb-5d55-bcb6-7c30167bd73f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
