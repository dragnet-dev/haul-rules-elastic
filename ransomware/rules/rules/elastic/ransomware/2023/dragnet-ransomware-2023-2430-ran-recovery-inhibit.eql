// Dragnet [Ransomware]: dragnet-ransomware-2023-2430 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 550ede48-17c8-5b02-a0a7-04bbba6f22c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
