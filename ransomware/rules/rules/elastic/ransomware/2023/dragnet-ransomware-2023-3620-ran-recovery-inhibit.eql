// Dragnet [Ransomware]: dragnet-ransomware-2023-3620 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: f82f72e6-057d-5700-a43c-d8d4b0ce6bcd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
