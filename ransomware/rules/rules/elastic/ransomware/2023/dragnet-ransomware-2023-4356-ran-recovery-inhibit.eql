// Dragnet [Ransomware]: dragnet-ransomware-2023-4356 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: cf4e9b83-de87-5fbe-98e6-409a84586b95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
