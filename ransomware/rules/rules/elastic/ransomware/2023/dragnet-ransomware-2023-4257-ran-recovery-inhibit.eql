// Dragnet [Ransomware]: dragnet-ransomware-2023-4257 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 14d9b0a6-d1d8-5dc2-b692-76a8b2bbe700

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
