// Dragnet [Ransomware]: dragnet-ransomware-2023-1802 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5ce2fb7f-54a4-5d8f-84bc-577b3854a8da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
