// Dragnet [Ransomware]: dragnet-ransomware-2023-2789 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 126a2728-419b-5805-ad84-180d584c1811

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
