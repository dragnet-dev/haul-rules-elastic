// Dragnet [Ransomware]: dragnet-ransomware-2023-2747 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 551131fb-5889-536c-8284-3bbf6b65c77b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
