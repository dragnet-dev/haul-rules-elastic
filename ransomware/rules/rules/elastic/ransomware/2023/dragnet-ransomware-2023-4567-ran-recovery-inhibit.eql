// Dragnet [Ransomware]: dragnet-ransomware-2023-4567 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: cc910c90-6de2-570c-8ddd-ad550aad82b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
