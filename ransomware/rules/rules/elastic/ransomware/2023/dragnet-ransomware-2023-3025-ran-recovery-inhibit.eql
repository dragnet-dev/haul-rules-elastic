// Dragnet [Ransomware]: dragnet-ransomware-2023-3025 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b26a2f3c-c1cc-5466-8f7a-b899d69529d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
