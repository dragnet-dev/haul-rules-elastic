// Dragnet [Ransomware]: dragnet-ransomware-2023-1010 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: 51d98309-5252-576b-8f87-71882a3eec60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
