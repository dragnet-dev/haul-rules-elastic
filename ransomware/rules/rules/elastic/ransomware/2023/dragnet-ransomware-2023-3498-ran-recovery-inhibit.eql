// Dragnet [Ransomware]: dragnet-ransomware-2023-3498 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3f26df0c-2373-5691-92dc-755ca4e54fa8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
