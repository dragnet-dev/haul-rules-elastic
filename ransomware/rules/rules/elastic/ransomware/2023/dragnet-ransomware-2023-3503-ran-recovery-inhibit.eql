// Dragnet [Ransomware]: dragnet-ransomware-2023-3503 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a5825daa-5cdf-5e63-be7f-99dcaceced62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
