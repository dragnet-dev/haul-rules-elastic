// Dragnet [Ransomware]: dragnet-ransomware-2023-3213 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 0f7ba65f-c46f-5c54-b0be-461385e064ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
