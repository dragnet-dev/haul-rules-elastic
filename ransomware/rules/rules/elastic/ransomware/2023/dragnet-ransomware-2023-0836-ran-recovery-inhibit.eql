// Dragnet [Ransomware]: dragnet-ransomware-2023-0836 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: c8de30c7-74c5-5f25-9b3e-9bbd1a5944fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
