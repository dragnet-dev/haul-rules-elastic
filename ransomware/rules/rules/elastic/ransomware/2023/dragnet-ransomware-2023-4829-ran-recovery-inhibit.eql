// Dragnet [Ransomware]: dragnet-ransomware-2023-4829 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0e091fad-efed-500c-bcba-cb2c3ef34a94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
