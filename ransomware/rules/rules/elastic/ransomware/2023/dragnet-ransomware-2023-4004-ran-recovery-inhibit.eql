// Dragnet [Ransomware]: dragnet-ransomware-2023-4004 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 842ff342-64c1-5b20-8840-e4014ba8a4ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
