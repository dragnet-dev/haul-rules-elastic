// Dragnet [Ransomware]: dragnet-ransomware-2023-0215 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 1ea0a386-cceb-5215-8fff-4ed49cb66277

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
