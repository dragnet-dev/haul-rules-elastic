// Dragnet [Ransomware]: dragnet-ransomware-2023-1938 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: 5a1a7906-c9bb-504e-b422-5b6652252e9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
