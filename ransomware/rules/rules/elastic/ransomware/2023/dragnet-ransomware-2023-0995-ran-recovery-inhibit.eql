// Dragnet [Ransomware]: dragnet-ransomware-2023-0995 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c89f408a-0ee4-5425-a413-c213d76a8b88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
