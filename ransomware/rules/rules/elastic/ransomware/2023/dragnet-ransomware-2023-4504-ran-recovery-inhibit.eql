// Dragnet [Ransomware]: dragnet-ransomware-2023-4504 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: cdea4840-4be6-53dd-b90e-1f2e8e8516e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
