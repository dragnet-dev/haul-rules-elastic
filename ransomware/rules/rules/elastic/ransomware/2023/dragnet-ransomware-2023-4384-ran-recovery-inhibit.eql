// Dragnet [Ransomware]: dragnet-ransomware-2023-4384 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 7b33e71c-8d2a-5c69-9521-dc865c2c64d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
