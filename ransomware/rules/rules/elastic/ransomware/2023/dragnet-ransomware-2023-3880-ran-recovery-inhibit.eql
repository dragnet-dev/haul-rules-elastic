// Dragnet [Ransomware]: dragnet-ransomware-2023-3880 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: e4567730-0384-53d9-8342-1464cee1fd14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
