// Dragnet [Ransomware]: dragnet-ransomware-2023-4800 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: aa8f3338-39ee-55a0-8668-640e0d21fc08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
