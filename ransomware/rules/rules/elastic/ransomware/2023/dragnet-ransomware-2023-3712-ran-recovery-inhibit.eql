// Dragnet [Ransomware]: dragnet-ransomware-2023-3712 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 558861c3-eeae-54b7-aa65-1754cad338d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
