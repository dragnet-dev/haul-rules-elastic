// Dragnet [Ransomware]: dragnet-ransomware-2023-3364 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: a5457584-e66f-570c-96a3-43c198557c02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
