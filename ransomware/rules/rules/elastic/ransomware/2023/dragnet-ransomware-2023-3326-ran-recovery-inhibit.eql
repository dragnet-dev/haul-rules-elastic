// Dragnet [Ransomware]: dragnet-ransomware-2023-3326 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 8a7b7052-7f07-5e09-acfc-e07bf9eff4cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
