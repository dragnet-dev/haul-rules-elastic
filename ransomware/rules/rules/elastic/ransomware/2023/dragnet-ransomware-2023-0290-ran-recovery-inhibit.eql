// Dragnet [Ransomware]: dragnet-ransomware-2023-0290 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 9e003a74-7eec-5380-bc9f-f70bc8ade33e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
