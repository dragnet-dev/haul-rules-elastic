// Dragnet [Ransomware]: dragnet-ransomware-2023-1632 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 211e311a-f554-5b68-a151-53dfb131ac1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
