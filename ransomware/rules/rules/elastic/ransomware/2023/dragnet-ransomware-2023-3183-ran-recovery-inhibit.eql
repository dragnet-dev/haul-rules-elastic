// Dragnet [Ransomware]: dragnet-ransomware-2023-3183 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b03900ac-32fc-5f6b-b5e6-8be0aa9b2ff1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
