// Dragnet [Ransomware]: dragnet-ransomware-2023-3276 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 356de26b-a010-5f09-8e63-54b445271c22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
