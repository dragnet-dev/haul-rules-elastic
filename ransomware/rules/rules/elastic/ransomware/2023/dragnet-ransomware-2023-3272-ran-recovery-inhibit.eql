// Dragnet [Ransomware]: dragnet-ransomware-2023-3272 — Recovery Inhibition (siegedsec)
// Status: deprecated | Level: high | ID: 4f00afb8-70d8-5909-807a-39371df77b99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
