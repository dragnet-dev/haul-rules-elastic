// Dragnet [Ransomware]: dragnet-ransomware-2023-2829 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 5d4c29ef-23ab-54ea-8e00-bf703fdb0604

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
