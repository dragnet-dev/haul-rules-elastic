// Dragnet [Ransomware]: dragnet-ransomware-2023-4056 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 6604dbad-0b06-508e-a3f6-c6e3a896faa3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
