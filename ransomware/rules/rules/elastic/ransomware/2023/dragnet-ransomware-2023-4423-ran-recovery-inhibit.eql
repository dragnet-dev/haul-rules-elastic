// Dragnet [Ransomware]: dragnet-ransomware-2023-4423 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 7c7ec740-bb76-574a-ad89-227951963b54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
