// Dragnet [Ransomware]: dragnet-ransomware-2023-5014 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 1f61e7e7-aab2-5481-ba99-ff0cfde5bc5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
