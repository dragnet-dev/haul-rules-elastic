// Dragnet [Ransomware]: dragnet-ransomware-2023-5165 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: f3743950-ec24-5053-af18-6c018b9efd74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
