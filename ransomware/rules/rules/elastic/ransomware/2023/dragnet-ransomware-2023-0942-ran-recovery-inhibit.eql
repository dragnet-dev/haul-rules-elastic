// Dragnet [Ransomware]: dragnet-ransomware-2023-0942 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 05299056-4708-58ee-95ac-322f5200012c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
