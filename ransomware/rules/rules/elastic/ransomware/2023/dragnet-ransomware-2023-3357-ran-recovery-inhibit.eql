// Dragnet [Ransomware]: dragnet-ransomware-2023-3357 — Recovery Inhibition (darkrace)
// Status: experimental | Level: high | ID: c54ae114-b968-5592-8411-a8a2f0b5cb2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
