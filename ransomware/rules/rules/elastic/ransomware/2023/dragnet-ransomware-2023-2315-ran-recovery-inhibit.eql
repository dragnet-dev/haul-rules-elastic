// Dragnet [Ransomware]: dragnet-ransomware-2023-2315 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: d38d2312-9aa5-5770-9314-e98321edcc1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
