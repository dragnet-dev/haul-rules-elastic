// Dragnet [Ransomware]: dragnet-ransomware-2023-0794 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: fb069d2f-0b66-5791-bd3d-462e664ad6e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
