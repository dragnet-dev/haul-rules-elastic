// Dragnet [Ransomware]: dragnet-ransomware-2023-0903 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3c01b129-c895-5846-b8ef-dac5912b03b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
