// Dragnet [Ransomware]: dragnet-ransomware-2023-4704 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 2e5419c9-aaf4-5701-b2c9-5377f68509dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
