// Dragnet [Ransomware]: dragnet-ransomware-2023-0115 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: b893d432-cb97-5023-9668-f04e9c35911f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
