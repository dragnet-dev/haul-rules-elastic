// Dragnet [Ransomware]: dragnet-ransomware-2023-3692 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 857df42f-cbb4-535f-a688-52f4bb2c1c9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
