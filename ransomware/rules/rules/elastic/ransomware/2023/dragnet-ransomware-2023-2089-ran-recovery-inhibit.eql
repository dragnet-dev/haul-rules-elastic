// Dragnet [Ransomware]: dragnet-ransomware-2023-2089 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 140481cb-9901-5ff8-9958-c39cd70720c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
