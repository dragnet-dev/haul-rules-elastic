// Dragnet [Ransomware]: dragnet-ransomware-2023-2216 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: da1163e1-2a2e-5f98-8ce6-66ecde98f98f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
