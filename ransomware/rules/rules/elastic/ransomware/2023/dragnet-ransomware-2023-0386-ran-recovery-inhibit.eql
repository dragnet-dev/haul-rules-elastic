// Dragnet [Ransomware]: dragnet-ransomware-2023-0386 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 8b0b52f0-4472-5d2c-8810-775555267f8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
