// Dragnet [Ransomware]: dragnet-ransomware-2023-1560 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 18c2a47b-98ff-5666-9762-491e7ab3f3a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
