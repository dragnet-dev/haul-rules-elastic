// Dragnet [Ransomware]: dragnet-ransomware-2023-0201 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 91674ebb-4087-5750-9526-4fc8638f642e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
