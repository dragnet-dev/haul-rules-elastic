// Dragnet [Ransomware]: dragnet-ransomware-2023-4002 — Recovery Inhibition (underground)
// Status: experimental | Level: high | ID: f5ac7fd3-b7a1-5eb4-98a5-fe32bb9087b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
