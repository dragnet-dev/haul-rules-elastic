// Dragnet [Ransomware]: dragnet-ransomware-2023-4380 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: ba076a8b-323a-5375-b202-37e4e4427900

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
