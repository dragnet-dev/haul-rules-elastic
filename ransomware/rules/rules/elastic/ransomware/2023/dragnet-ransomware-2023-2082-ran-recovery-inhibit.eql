// Dragnet [Ransomware]: dragnet-ransomware-2023-2082 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: fcff1fb9-6e7e-531b-ac1b-b3498802c784

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
