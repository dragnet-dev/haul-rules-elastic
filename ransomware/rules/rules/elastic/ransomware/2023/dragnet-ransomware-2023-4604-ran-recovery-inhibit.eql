// Dragnet [Ransomware]: dragnet-ransomware-2023-4604 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: ce55ffa0-8ae9-5526-9def-a51d46b06ec2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
