// Dragnet [Ransomware]: dragnet-ransomware-2023-3732 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: dae1ac72-c833-5f02-870e-611a187955d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
