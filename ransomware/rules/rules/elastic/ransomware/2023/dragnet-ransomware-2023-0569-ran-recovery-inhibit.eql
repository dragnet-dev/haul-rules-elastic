// Dragnet [Ransomware]: dragnet-ransomware-2023-0569 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 497c915e-612e-5c89-a343-6b219b9da594

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
