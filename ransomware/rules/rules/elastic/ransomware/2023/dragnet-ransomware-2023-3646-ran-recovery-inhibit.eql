// Dragnet [Ransomware]: dragnet-ransomware-2023-3646 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 66a7daeb-1f66-51ad-b5a4-b6d20d651c06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
