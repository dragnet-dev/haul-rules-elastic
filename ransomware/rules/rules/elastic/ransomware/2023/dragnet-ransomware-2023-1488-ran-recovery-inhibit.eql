// Dragnet [Ransomware]: dragnet-ransomware-2023-1488 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 48e9729a-6203-5d01-92f0-407795923465

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
