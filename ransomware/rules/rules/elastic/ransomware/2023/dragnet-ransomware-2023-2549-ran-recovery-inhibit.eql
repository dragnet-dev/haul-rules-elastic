// Dragnet [Ransomware]: dragnet-ransomware-2023-2549 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: e0e9d3ec-6ed9-5ffc-beb1-9be756504d2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
