// Dragnet [Ransomware]: dragnet-ransomware-2023-1258 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f670b6eb-dc7f-5e7e-bb8c-71a3e75ea73f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
