// Dragnet [Ransomware]: dragnet-ransomware-2023-2530 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 9b25783d-44c5-5df2-b03d-edcc4179eeee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
