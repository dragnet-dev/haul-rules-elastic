// Dragnet [Ransomware]: dragnet-ransomware-2023-3541 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9eeff6c5-6fd9-5c1d-ad5c-55e607de787d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
