// Dragnet [Ransomware]: dragnet-ransomware-2023-1576 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 59b0d286-29fd-5c4d-9ef0-06d08d235ce4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
