// Dragnet [Ransomware]: dragnet-ransomware-2023-1220 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 945157d4-198d-525b-a69e-9ccd02feeb83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
