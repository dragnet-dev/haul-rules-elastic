// Dragnet [Ransomware]: dragnet-ransomware-2023-1832 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: e8eed71d-ad32-57a4-9862-25125bc4d437

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
