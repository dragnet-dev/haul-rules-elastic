// Dragnet [Ransomware]: dragnet-ransomware-2023-1509 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 55749185-6e27-5c9c-9749-f7c566347ecf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
