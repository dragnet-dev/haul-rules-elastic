// Dragnet [Ransomware]: dragnet-ransomware-2023-2057 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 47fa25cf-1373-59ac-ba55-c0f6ba14c509

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
