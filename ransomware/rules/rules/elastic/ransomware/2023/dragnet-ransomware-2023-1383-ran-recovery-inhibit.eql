// Dragnet [Ransomware]: dragnet-ransomware-2023-1383 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 1919ff3c-ad5e-595e-a207-d1257bb21f09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
