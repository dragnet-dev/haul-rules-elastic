// Dragnet [Ransomware]: dragnet-ransomware-2023-4960 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: be75cb04-689d-5f11-8a77-b42cbdb86499

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
