// Dragnet [Ransomware]: dragnet-ransomware-2023-4246 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 4f39c2b7-4152-5f9d-9c7d-0b1a594cf31c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
