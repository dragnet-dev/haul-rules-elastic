// Dragnet [Ransomware]: dragnet-ransomware-2023-4670 — Recovery Inhibition (medusa)
// Status: deprecated | Level: high | ID: c9ac76ea-c3a6-5d53-84a1-93521cadb02f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
