// Dragnet [Ransomware]: dragnet-ransomware-2023-2632 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: bc4ea4f8-1d88-569c-928c-78ce303ef14d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
