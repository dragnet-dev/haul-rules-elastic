// Dragnet [Ransomware]: dragnet-ransomware-2023-4187 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: da60a6dd-3e00-54f3-abe9-561fe79b8bb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
