// Dragnet [Ransomware]: dragnet-ransomware-2023-3956 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b749b1c0-cb09-58e8-a3e8-1bb7f407bb63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
