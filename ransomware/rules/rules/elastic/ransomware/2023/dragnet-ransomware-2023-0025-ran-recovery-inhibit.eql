// Dragnet [Ransomware]: dragnet-ransomware-2023-0025 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: c4edb482-972b-50cf-994d-8ace147dfaf1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
