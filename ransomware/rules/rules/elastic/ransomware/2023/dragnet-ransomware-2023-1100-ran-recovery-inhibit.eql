// Dragnet [Ransomware]: dragnet-ransomware-2023-1100 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4b03b7cb-c937-50c7-8650-86a8f065c3cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
