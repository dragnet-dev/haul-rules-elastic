// Dragnet [Ransomware]: dragnet-ransomware-2023-3834 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 2774eca0-1c89-5faf-ac04-4fa63b7adb71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
