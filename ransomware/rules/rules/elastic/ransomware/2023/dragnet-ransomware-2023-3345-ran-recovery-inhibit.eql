// Dragnet [Ransomware]: dragnet-ransomware-2023-3345 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b537c227-8380-5aa3-98b3-69bac3f1b31e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
