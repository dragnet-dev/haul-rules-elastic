// Dragnet [Ransomware]: dragnet-ransomware-2023-2810 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 938a0903-b4fa-5113-9430-9c3f1bf0573e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
