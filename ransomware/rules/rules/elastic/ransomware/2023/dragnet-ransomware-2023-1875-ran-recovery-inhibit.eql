// Dragnet [Ransomware]: dragnet-ransomware-2023-1875 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 61101e72-9112-52fb-b71c-31bba91e92d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
