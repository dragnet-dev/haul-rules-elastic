// Dragnet [Ransomware]: dragnet-ransomware-2023-5009 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: dfd30c5d-c17a-5a00-8df2-191eff0dcafb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
