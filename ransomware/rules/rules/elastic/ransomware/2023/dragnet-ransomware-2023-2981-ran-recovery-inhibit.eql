// Dragnet [Ransomware]: dragnet-ransomware-2023-2981 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 261548df-289b-5027-89a1-160584e7ca47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
