// Dragnet [Ransomware]: dragnet-ransomware-2023-1418 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: fe09244a-7b3f-5464-b203-bd34ae3dcaa1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
