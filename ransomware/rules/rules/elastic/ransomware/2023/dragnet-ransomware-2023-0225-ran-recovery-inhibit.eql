// Dragnet [Ransomware]: dragnet-ransomware-2023-0225 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: facef82a-0d0b-561e-8c63-efd9da24b0e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
