// Dragnet [Ransomware]: dragnet-ransomware-2023-3699 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 571f677a-e1c5-5a4f-ba82-ceb9cada8093

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
