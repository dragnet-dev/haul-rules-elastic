// Dragnet [Ransomware]: dragnet-ransomware-2023-2643 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: e8171f90-0638-5b53-be17-8133f56e4a14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
