// Dragnet [Ransomware]: dragnet-ransomware-2023-5263 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 7e85c673-00a1-533f-adf7-223c42652793

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
