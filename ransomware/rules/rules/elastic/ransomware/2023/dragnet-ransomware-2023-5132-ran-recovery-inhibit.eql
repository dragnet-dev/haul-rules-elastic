// Dragnet [Ransomware]: dragnet-ransomware-2023-5132 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: cc77786e-645f-5db8-9fbe-a1e73dbe7f78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
