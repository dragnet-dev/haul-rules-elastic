// Dragnet [Ransomware]: dragnet-ransomware-2023-1572 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 5c83bd18-5fd2-5d50-97a3-ffb4db9c3f89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
