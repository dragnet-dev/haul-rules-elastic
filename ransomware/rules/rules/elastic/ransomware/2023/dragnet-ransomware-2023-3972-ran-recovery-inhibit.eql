// Dragnet [Ransomware]: dragnet-ransomware-2023-3972 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: b931ae61-3215-5e45-9069-76981a153bf9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
