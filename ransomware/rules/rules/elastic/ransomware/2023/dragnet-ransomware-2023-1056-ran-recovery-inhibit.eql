// Dragnet [Ransomware]: dragnet-ransomware-2023-1056 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 5cb2b12a-d7ed-5756-bdc8-db93ca80e5cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
