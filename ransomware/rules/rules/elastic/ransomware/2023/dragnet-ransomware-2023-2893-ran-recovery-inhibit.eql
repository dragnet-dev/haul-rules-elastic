// Dragnet [Ransomware]: dragnet-ransomware-2023-2893 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: fb54e323-9b11-533f-941e-69fbc8878a4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
