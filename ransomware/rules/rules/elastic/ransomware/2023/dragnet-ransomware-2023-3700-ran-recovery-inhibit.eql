// Dragnet [Ransomware]: dragnet-ransomware-2023-3700 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 7dcaa48e-18df-51f0-b557-12d7959e76db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
