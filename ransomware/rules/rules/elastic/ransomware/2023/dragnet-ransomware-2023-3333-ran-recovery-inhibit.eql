// Dragnet [Ransomware]: dragnet-ransomware-2023-3333 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 17504452-ea1a-5dad-bac6-79dc89574049

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
