// Dragnet [Ransomware]: dragnet-ransomware-2023-2915 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: e5405247-6ed1-58eb-8d76-0bf4d1836dfa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
