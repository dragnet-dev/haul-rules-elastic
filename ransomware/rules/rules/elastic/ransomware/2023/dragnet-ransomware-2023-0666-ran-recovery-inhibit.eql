// Dragnet [Ransomware]: dragnet-ransomware-2023-0666 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 375ae48e-9d37-550b-b1ca-0dc371351077

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
