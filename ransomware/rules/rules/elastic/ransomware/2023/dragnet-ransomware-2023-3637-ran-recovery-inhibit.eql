// Dragnet [Ransomware]: dragnet-ransomware-2023-3637 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7fb1cea5-a80b-5636-a43e-f14bf7b2a934

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
