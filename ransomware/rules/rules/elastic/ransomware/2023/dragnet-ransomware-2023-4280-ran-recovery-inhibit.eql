// Dragnet [Ransomware]: dragnet-ransomware-2023-4280 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d4e516f3-a684-5acc-aa29-3378d6c1ba40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
