// Dragnet [Ransomware]: dragnet-ransomware-2023-4737 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f59d5da1-6235-5fce-957f-073e126bd2ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
