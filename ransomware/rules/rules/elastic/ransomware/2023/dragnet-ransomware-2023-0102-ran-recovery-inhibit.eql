// Dragnet [Ransomware]: dragnet-ransomware-2023-0102 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 3d04d7c1-595a-54d0-b249-baf307b30f14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
