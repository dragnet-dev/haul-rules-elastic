// Dragnet [Ransomware]: dragnet-ransomware-2023-3002 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1b61e4a1-b676-556a-9a4b-7389288b2c57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
