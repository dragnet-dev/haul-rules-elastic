// Dragnet [Ransomware]: dragnet-ransomware-2023-2653 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 2285d73a-b97a-5a31-ac4f-7ae120219e7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
