// Dragnet [Ransomware]: dragnet-ransomware-2023-0633 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 793f6a42-6eca-5d35-94db-270333d364ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
