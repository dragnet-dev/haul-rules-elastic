// Dragnet [Ransomware]: dragnet-ransomware-2023-4015 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: fd27538c-7b5b-5d4d-87a3-8eea2c4c5d28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
