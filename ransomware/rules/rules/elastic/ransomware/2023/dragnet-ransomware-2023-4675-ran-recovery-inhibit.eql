// Dragnet [Ransomware]: dragnet-ransomware-2023-4675 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3e32b95e-4ad0-51e5-aa83-ebe84de3d12f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
