// Dragnet [Ransomware]: dragnet-ransomware-2023-2751 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: a8faebdc-bbf4-5117-956f-e41dd96a6282

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
