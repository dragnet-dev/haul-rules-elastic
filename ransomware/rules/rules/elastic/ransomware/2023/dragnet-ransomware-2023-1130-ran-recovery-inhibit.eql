// Dragnet [Ransomware]: dragnet-ransomware-2023-1130 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 61945d39-ee96-5aa9-b838-4b5eb5557abf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
