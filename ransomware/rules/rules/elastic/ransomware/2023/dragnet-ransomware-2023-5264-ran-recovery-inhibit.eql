// Dragnet [Ransomware]: dragnet-ransomware-2023-5264 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: a1b963b7-5cc0-51b3-be9c-7c5361983d3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
