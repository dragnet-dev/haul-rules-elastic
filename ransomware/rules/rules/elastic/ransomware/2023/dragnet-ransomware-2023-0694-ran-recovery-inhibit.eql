// Dragnet [Ransomware]: dragnet-ransomware-2023-0694 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 24685737-49af-589d-82ff-1ddba24be93f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
