// Dragnet [Ransomware]: dragnet-ransomware-2023-2558 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 379e894b-5c8f-5b79-b23e-d0f1c29a29eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
