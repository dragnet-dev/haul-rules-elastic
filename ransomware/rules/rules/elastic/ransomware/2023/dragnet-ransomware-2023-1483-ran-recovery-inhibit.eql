// Dragnet [Ransomware]: dragnet-ransomware-2023-1483 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d3da9271-9dce-5859-b194-d76009f92b58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
