// Dragnet [Ransomware]: dragnet-ransomware-2023-4994 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b66d3cd5-176a-5237-ab93-670faae35927

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
