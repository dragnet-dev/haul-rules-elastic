// Dragnet [Ransomware]: dragnet-ransomware-2023-4980 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 36cee208-f2a6-5e2c-a9eb-266bf4d6805f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
