// Dragnet [Ransomware]: dragnet-ransomware-2023-5024 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5cf469b0-2d94-5612-92cf-e7b7ef4ab46d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
