// Dragnet [Ransomware]: dragnet-ransomware-2023-0528 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 00fec892-97d7-5b97-99b1-6e1cca366c2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
