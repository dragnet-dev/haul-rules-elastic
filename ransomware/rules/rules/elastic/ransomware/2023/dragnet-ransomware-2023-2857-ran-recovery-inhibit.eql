// Dragnet [Ransomware]: dragnet-ransomware-2023-2857 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 2ea0261c-f1ac-5eac-bff7-85bd588d70a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
