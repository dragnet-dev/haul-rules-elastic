// Dragnet [Ransomware]: dragnet-ransomware-2023-4683 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7b923226-d389-5595-ad43-f6afa109516c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
