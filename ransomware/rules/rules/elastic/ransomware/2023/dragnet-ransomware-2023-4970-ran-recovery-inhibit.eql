// Dragnet [Ransomware]: dragnet-ransomware-2023-4970 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 61c3db3c-62d0-59ba-b0d1-4ef9ada552ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
