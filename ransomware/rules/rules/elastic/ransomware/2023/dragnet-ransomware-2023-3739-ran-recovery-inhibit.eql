// Dragnet [Ransomware]: dragnet-ransomware-2023-3739 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 6248163e-36a4-5781-9e44-73291dc0e5d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
