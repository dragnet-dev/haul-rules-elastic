// Dragnet [Ransomware]: dragnet-ransomware-2023-0445 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 56f49338-e6b6-5399-a1a0-d5451c360b34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
