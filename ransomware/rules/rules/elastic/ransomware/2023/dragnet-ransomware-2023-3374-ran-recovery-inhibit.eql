// Dragnet [Ransomware]: dragnet-ransomware-2023-3374 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8697f78f-1d42-5a62-94f4-9600f01128d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
