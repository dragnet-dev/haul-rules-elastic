// Dragnet [Ransomware]: dragnet-ransomware-2023-4841 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3bc37846-3472-532d-9e26-4c7f2c0bd16a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
