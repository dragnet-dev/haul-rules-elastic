// Dragnet [Ransomware]: dragnet-ransomware-2023-4360 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 04fc3f95-355a-5426-818b-2d99fea37c8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
