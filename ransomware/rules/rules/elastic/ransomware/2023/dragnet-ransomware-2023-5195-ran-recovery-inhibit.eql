// Dragnet [Ransomware]: dragnet-ransomware-2023-5195 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f6b271b4-786f-5fae-809b-268439e414bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
