// Dragnet [Ransomware]: dragnet-ransomware-2023-2591 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 8b364e29-68a8-5d06-af4d-d4384d8cddbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
