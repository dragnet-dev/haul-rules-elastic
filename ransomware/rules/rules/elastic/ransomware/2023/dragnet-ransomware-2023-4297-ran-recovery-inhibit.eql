// Dragnet [Ransomware]: dragnet-ransomware-2023-4297 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 41dc2862-37c8-5b1c-b7c6-65b282a55353

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
