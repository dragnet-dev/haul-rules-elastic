// Dragnet [Ransomware]: dragnet-ransomware-2023-4177 — Recovery Inhibition (mallox)
// Status: experimental | Level: high | ID: 35f0bc7e-cd73-514a-accc-d77989e8deb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
