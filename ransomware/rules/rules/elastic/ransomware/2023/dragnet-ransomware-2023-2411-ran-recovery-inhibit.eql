// Dragnet [Ransomware]: dragnet-ransomware-2023-2411 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8824464b-a494-5de5-8d10-cc8b3e963bd7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
