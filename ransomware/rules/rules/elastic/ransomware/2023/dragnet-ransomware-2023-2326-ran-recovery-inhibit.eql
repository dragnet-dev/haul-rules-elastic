// Dragnet [Ransomware]: dragnet-ransomware-2023-2326 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: a6665286-ad2e-51fd-bc26-69ff29358c0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
