// Dragnet [Ransomware]: dragnet-ransomware-2023-3788 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 353450d1-f006-5a90-b114-8adc5a550595

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
