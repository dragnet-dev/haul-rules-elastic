// Dragnet [Ransomware]: dragnet-ransomware-2023-4507 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 956bf667-f2be-593d-b665-3c920ad70f33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
