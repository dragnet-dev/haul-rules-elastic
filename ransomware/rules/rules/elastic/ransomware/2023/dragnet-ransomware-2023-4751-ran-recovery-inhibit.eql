// Dragnet [Ransomware]: dragnet-ransomware-2023-4751 — Recovery Inhibition (malekteam)
// Status: experimental | Level: high | ID: dccb174f-1d78-5109-9970-cd7c056a763f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
