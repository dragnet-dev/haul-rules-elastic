// Dragnet [Ransomware]: dragnet-ransomware-2023-4260 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f5b946fc-1493-5c93-a52c-144f043f71a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
