// Dragnet [Ransomware]: dragnet-ransomware-2023-1563 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 6a4f51a6-8372-5eec-a5d5-9088e477ab28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
