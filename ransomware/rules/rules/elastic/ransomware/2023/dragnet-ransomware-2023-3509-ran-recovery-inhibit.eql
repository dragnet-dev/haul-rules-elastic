// Dragnet [Ransomware]: dragnet-ransomware-2023-3509 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0fa91565-908c-5188-9c3e-23b7f6c4e6e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
