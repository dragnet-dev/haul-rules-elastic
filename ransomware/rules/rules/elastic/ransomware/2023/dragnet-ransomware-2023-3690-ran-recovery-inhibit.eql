// Dragnet [Ransomware]: dragnet-ransomware-2023-3690 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 5e1e5517-af10-551f-93a3-c460382899c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
