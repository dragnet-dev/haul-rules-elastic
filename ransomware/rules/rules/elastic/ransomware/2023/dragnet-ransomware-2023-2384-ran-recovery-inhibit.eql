// Dragnet [Ransomware]: dragnet-ransomware-2023-2384 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e2f20e3e-fe41-5b16-9727-0e7d4ba09976

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
