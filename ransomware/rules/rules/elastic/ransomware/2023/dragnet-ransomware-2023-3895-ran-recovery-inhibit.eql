// Dragnet [Ransomware]: dragnet-ransomware-2023-3895 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 5b99a122-b1c5-574a-8a0e-ed3d7d8b91f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
