// Dragnet [Ransomware]: dragnet-ransomware-2023-4334 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: dee6acbd-a1aa-552b-8967-42de4ec91080

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
