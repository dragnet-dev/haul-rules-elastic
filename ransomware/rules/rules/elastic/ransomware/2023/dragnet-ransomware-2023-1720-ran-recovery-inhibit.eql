// Dragnet [Ransomware]: dragnet-ransomware-2023-1720 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b7805a0d-c26f-57e0-88f3-115272c12594

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
