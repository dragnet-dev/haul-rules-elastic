// Dragnet [Ransomware]: dragnet-ransomware-2023-4291 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5637f0f4-aaeb-57da-b0a7-dc7b52d2e649

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
