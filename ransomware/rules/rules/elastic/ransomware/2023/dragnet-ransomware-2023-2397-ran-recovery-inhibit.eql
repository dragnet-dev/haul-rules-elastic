// Dragnet [Ransomware]: dragnet-ransomware-2023-2397 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 32113b00-78d5-55b6-ae39-8b1a2488e6a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
