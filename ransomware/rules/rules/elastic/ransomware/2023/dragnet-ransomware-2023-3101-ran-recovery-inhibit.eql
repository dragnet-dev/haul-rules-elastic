// Dragnet [Ransomware]: dragnet-ransomware-2023-3101 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: e7e520c8-851d-5329-81a8-5d5a8b7b05f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
