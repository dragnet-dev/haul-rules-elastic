// Dragnet [Ransomware]: dragnet-ransomware-2023-2752 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 746bc99b-d497-515f-be1d-45216d8eddcb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
