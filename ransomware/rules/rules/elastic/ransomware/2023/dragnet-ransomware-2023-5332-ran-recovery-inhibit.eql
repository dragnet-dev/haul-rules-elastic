// Dragnet [Ransomware]: dragnet-ransomware-2023-5332 — Recovery Inhibition (dunghill)
// Status: experimental | Level: high | ID: 4f4fb2e4-207b-52ac-9e3b-769b6c1c29a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
