// Dragnet [Ransomware]: dragnet-ransomware-2023-1619 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 33a22253-aef9-5dfb-ae8e-beb12c47256f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
