// Dragnet [Ransomware]: dragnet-ransomware-2023-0170 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1059b8b2-79fa-5366-a1db-d0d5980904a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
