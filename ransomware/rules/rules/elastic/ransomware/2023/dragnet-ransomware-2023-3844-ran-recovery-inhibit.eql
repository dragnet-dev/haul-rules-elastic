// Dragnet [Ransomware]: dragnet-ransomware-2023-3844 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 191bad8f-a251-54e3-865f-e13b3028ba1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
