// Dragnet [Ransomware]: dragnet-ransomware-2023-1638 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 12d8b9f7-6bca-561d-bc06-a83d96165907

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
