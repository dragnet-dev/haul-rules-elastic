// Dragnet [Ransomware]: dragnet-ransomware-2023-3000 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2aacdf09-c42a-5d32-8428-d2061cf2c2fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
