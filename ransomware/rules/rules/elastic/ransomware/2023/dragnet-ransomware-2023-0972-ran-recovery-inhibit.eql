// Dragnet [Ransomware]: dragnet-ransomware-2023-0972 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: dadaa87d-945d-5fa6-a36b-598273876839

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
