// Dragnet [Ransomware]: dragnet-ransomware-2023-3053 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 70dbf2f8-e360-5011-aa76-e8d0e471e208

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
