// Dragnet [Ransomware]: dragnet-ransomware-2023-2014 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: dbfedc4f-c693-5310-a91c-b0c4bfb37660

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
