// Dragnet [Ransomware]: dragnet-ransomware-2023-3356 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5955ab12-4d2a-54a5-98d0-6be6caad1089

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
