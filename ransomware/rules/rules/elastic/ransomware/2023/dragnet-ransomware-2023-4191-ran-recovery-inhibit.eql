// Dragnet [Ransomware]: dragnet-ransomware-2023-4191 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: ce609673-3174-5d17-b19c-72a83ca40e11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
