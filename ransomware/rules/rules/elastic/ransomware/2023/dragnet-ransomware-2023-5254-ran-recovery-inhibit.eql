// Dragnet [Ransomware]: dragnet-ransomware-2023-5254 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: fd08fe77-319c-52f1-9f41-8582ea3e02bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
