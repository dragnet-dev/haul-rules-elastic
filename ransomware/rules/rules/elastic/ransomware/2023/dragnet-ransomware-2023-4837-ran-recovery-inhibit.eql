// Dragnet [Ransomware]: dragnet-ransomware-2023-4837 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 75e5a73c-d807-536a-a25c-cf9d1acd7c1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
