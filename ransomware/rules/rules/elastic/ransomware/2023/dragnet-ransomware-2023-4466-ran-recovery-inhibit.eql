// Dragnet [Ransomware]: dragnet-ransomware-2023-4466 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: d817a277-e6f0-5115-a42b-1e1c550e83e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
