// Dragnet [Ransomware]: dragnet-ransomware-2023-0440 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: e0c002fb-0a8c-57da-a227-2af1921981d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
