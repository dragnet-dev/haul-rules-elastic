// Dragnet [Ransomware]: dragnet-ransomware-2023-2753 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: bbe0b917-2014-57d5-b19b-918efea9fdb2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
