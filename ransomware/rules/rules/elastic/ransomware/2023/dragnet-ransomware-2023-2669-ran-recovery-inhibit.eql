// Dragnet [Ransomware]: dragnet-ransomware-2023-2669 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a01bd658-b3c5-569d-8db1-d23d8289baf9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
