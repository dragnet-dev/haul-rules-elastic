// Dragnet [Ransomware]: dragnet-ransomware-2023-5136 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: d249ddf1-9378-5d07-8799-5133747a255d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
