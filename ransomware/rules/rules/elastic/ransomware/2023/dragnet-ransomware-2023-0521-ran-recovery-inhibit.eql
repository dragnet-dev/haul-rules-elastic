// Dragnet [Ransomware]: dragnet-ransomware-2023-0521 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: d0448910-ca90-5d61-a643-628761d6e934

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
