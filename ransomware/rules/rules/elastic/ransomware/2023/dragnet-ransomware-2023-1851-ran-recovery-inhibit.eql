// Dragnet [Ransomware]: dragnet-ransomware-2023-1851 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5686dc2d-5f79-5d4f-ac1f-fee8bb47d603

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
