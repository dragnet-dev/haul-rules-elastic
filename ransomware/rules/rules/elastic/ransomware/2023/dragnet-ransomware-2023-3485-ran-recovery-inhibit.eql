// Dragnet [Ransomware]: dragnet-ransomware-2023-3485 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: a41f3265-5a4f-5d54-882e-a152f0df1842

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
