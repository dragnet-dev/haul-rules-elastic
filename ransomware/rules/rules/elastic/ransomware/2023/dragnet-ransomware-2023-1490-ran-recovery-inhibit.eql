// Dragnet [Ransomware]: dragnet-ransomware-2023-1490 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7ce76a5f-2aa7-5fda-b2dc-f1d021823fc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
