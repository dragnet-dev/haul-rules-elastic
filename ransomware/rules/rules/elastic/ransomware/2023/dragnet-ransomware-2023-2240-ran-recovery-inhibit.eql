// Dragnet [Ransomware]: dragnet-ransomware-2023-2240 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 54a9971a-14a4-53e2-89d8-7d4681fa7b15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
