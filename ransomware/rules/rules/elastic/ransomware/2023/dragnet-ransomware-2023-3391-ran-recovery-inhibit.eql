// Dragnet [Ransomware]: dragnet-ransomware-2023-3391 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 375bafa0-36ce-5069-8866-da0fe60091d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
