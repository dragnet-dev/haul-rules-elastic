// Dragnet [Ransomware]: dragnet-ransomware-2023-1006 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 6e73c0c8-f48a-507b-9ec3-91cdfb54e39b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
