// Dragnet [Ransomware]: dragnet-ransomware-2023-3139 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 501c3a42-f58e-5582-a2e0-d53d0c1753e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
