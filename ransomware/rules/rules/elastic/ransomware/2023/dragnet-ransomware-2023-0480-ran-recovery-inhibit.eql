// Dragnet [Ransomware]: dragnet-ransomware-2023-0480 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 68428066-cf18-56dd-a268-90cd65417546

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
