// Dragnet [Ransomware]: dragnet-ransomware-2023-1239 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 80ecc418-2ccc-5d40-a0d9-731431cd38e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
