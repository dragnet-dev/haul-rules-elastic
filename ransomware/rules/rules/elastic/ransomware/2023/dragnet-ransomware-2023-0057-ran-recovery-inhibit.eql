// Dragnet [Ransomware]: dragnet-ransomware-2023-0057 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 65ac08d4-fca8-5158-8bc2-667a8d04cbde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
