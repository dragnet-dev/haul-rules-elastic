// Dragnet [Ransomware]: dragnet-ransomware-2023-2713 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: da2726c8-3e84-5b3c-92c1-a33134fa6845

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
