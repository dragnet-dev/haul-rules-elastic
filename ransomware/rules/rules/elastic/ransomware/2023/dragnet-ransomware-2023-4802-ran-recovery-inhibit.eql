// Dragnet [Ransomware]: dragnet-ransomware-2023-4802 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: bb10a1de-36be-568a-a533-97d56d68ebf2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
