// Dragnet [Ransomware]: dragnet-ransomware-2023-1372 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 05ad7b41-ede4-51b6-9fe9-c13819cc60b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
