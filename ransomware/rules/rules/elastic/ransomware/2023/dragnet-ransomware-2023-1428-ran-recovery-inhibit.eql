// Dragnet [Ransomware]: dragnet-ransomware-2023-1428 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2094400b-dbe9-58ee-aeda-3e40f94e0349

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
