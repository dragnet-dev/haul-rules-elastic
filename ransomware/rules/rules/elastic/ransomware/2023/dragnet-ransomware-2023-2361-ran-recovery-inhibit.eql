// Dragnet [Ransomware]: dragnet-ransomware-2023-2361 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 8ca012be-bbee-59e3-a261-a7e8f79a331f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
