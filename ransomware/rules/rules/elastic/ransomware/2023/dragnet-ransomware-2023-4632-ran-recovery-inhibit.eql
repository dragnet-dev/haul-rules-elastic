// Dragnet [Ransomware]: dragnet-ransomware-2023-4632 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 05283907-b9be-5937-9f05-65b4de593f29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
