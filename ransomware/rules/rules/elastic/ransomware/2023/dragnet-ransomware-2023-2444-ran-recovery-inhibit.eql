// Dragnet [Ransomware]: dragnet-ransomware-2023-2444 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 0e23559c-0a3c-5423-9ec3-b2b7e3391979

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
