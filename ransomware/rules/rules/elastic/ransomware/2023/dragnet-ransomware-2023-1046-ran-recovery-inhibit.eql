// Dragnet [Ransomware]: dragnet-ransomware-2023-1046 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 218d4aaa-4ffc-5c6b-aa0d-f4906ca8b369

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
