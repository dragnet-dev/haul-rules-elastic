// Dragnet [Ransomware]: dragnet-ransomware-2023-3431 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: a94ad2e1-0e8e-597c-86f2-af053a561d84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
