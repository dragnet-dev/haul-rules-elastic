// Dragnet [Ransomware]: dragnet-ransomware-2023-1978 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 90081bfe-6d9f-51bf-ba0f-5636648b77b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
