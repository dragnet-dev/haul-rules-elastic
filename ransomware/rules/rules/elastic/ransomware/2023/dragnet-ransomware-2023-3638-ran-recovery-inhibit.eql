// Dragnet [Ransomware]: dragnet-ransomware-2023-3638 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 633574bc-5933-5584-98f5-fe0e87719f99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
