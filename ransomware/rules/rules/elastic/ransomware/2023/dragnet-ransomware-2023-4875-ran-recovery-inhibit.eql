// Dragnet [Ransomware]: dragnet-ransomware-2023-4875 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f6af2bad-4722-598e-8e77-8b1d09090435

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
