// Dragnet [Ransomware]: dragnet-ransomware-2023-2773 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 30d54366-433b-5098-89a2-b2fff51cc640

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
