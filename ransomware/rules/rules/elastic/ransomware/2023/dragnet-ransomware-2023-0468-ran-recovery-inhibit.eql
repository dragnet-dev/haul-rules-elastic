// Dragnet [Ransomware]: dragnet-ransomware-2023-0468 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 84275c74-38a4-564d-88e1-334600241c2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
