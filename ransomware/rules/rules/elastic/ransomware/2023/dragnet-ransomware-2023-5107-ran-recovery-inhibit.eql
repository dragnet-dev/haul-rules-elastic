// Dragnet [Ransomware]: dragnet-ransomware-2023-5107 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: c0a39e40-a161-5da2-8db4-f7198f3b5cbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
