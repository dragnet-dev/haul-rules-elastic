// Dragnet [Ransomware]: dragnet-ransomware-2023-1447 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6649b346-e050-5a8d-a8f9-38e5861a15ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
