// Dragnet [Ransomware]: dragnet-ransomware-2023-2402 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: 4eef8341-82bc-5502-85c9-45f216489dda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
