// Dragnet [Ransomware]: dragnet-ransomware-2023-2815 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: e81a4ee7-1e07-5531-81c8-7f4145480734

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
