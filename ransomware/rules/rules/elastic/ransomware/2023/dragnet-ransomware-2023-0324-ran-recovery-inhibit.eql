// Dragnet [Ransomware]: dragnet-ransomware-2023-0324 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 9e0f6c07-c292-5bcd-81b4-f1c379e7da94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
