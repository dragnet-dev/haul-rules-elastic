// Dragnet [Ransomware]: dragnet-ransomware-2023-5287 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 85a0a13e-66ae-50d0-a8b9-979ed5f5aadf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
