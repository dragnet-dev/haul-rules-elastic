// Dragnet [Ransomware]: dragnet-ransomware-2023-3593 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 76408ecb-649d-5862-86c3-9564238755b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
