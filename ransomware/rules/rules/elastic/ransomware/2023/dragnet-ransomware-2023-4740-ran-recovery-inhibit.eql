// Dragnet [Ransomware]: dragnet-ransomware-2023-4740 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c9a8508d-aef8-5013-ab3e-77555a80ffca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
