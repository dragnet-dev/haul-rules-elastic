// Dragnet [Ransomware]: dragnet-ransomware-2023-4544 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 048b49c3-589b-556d-8563-c05134ddeb4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
