// Dragnet [Ransomware]: dragnet-ransomware-2023-3628 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 90207f2f-c429-517c-bb6b-9e0646f7dfeb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
