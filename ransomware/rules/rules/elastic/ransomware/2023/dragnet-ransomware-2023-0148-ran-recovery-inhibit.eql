// Dragnet [Ransomware]: dragnet-ransomware-2023-0148 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: a44ca793-8f4c-5a95-9afa-81c29e7ba3b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
