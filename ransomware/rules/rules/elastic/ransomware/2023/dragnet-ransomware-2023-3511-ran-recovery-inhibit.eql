// Dragnet [Ransomware]: dragnet-ransomware-2023-3511 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 1114dfe4-1bbb-515f-ba7d-90cb22e6a2d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
