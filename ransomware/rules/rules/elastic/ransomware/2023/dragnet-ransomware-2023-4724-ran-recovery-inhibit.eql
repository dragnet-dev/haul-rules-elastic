// Dragnet [Ransomware]: dragnet-ransomware-2023-4724 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: e588b9bc-a1cb-5679-a55b-c0caa88f786a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
