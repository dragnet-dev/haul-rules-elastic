// Dragnet [Ransomware]: dragnet-ransomware-2023-4096 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6fb472cf-b4f7-5598-844d-4c9c37240075

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
