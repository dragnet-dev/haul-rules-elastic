// Dragnet [Ransomware]: dragnet-ransomware-2023-3407 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6a2570be-5c2e-5158-80fa-88086fb14407

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
