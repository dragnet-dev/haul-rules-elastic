// Dragnet [Ransomware]: dragnet-ransomware-2023-5063 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ef2a2299-6c21-5b91-abd9-70f580d4f574

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
