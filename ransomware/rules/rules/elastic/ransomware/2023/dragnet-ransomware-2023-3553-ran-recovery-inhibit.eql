// Dragnet [Ransomware]: dragnet-ransomware-2023-3553 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 7a06b81f-1311-57e5-bbb6-abd1677dc9dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
