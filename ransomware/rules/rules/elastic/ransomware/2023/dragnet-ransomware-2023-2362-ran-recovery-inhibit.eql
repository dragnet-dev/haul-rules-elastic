// Dragnet [Ransomware]: dragnet-ransomware-2023-2362 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2ebb0ae7-d6e9-5157-804b-8db3ad2bc2ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
