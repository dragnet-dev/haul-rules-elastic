// Dragnet [Ransomware]: dragnet-ransomware-2023-2756 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 5c69bda6-23c6-5e27-a305-bb960780ad93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
