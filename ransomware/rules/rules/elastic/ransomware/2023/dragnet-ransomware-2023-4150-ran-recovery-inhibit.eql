// Dragnet [Ransomware]: dragnet-ransomware-2023-4150 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: c065f363-830d-5c9f-bd58-efefb554f5d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
