// Dragnet [Ransomware]: dragnet-ransomware-2023-1349 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: bad6796c-2c36-525a-9133-67684ea97ed0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
