// Dragnet [Ransomware]: dragnet-ransomware-2023-5362 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 5a8a71f4-9dbc-5b31-9d3c-a0e0eb4a0a4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
