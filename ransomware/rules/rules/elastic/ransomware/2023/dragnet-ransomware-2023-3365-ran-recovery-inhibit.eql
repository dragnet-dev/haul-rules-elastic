// Dragnet [Ransomware]: dragnet-ransomware-2023-3365 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: 8a390550-d28a-5ce4-9fdf-ec8c30aa1d4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
