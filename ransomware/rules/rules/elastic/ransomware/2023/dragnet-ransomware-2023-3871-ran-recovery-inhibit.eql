// Dragnet [Ransomware]: dragnet-ransomware-2023-3871 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: c20a6378-a29c-59f2-b77b-9d78d45cfb08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
