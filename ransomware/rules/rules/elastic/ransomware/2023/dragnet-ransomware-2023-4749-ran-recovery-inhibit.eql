// Dragnet [Ransomware]: dragnet-ransomware-2023-4749 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 56454e61-68f9-5642-b859-453d5636e411

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
