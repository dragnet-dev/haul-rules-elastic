// Dragnet [Ransomware]: dragnet-ransomware-2023-2932 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 63d8ebaa-717a-53f7-8f53-6375ec6d5353

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
