// Dragnet [Ransomware]: dragnet-ransomware-2023-1290 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 2903d339-0f3b-5918-a348-6e661255a319

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
