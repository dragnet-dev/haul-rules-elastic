// Dragnet [Ransomware]: dragnet-ransomware-2023-3010 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 908384a4-9e78-5da9-bb1f-bf6a201a41f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
