// Dragnet [Ransomware]: dragnet-ransomware-2023-0461 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 6319f467-907b-55f9-9791-88f9ce2f0794

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
