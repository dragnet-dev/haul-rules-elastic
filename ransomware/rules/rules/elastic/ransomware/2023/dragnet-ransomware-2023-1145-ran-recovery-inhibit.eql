// Dragnet [Ransomware]: dragnet-ransomware-2023-1145 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5d5b2c7b-e82c-55ce-a912-32990e79f1ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
