// Dragnet [Ransomware]: dragnet-ransomware-2023-4165 — Recovery Inhibition (moneymessage)
// Status: deprecated | Level: high | ID: d8f44e5c-df0b-51eb-aa14-21f2beba74ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
