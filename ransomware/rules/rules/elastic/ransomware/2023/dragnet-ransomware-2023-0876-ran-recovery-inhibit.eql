// Dragnet [Ransomware]: dragnet-ransomware-2023-0876 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 733900e4-30a7-5548-bb98-bfccda5b004d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
