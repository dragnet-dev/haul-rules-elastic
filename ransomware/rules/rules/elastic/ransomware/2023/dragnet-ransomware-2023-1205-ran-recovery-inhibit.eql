// Dragnet [Ransomware]: dragnet-ransomware-2023-1205 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 64bc7397-34e2-5eb3-b84e-8387af412f6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
