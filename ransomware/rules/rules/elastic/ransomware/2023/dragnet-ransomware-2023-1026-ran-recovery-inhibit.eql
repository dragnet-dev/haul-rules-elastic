// Dragnet [Ransomware]: dragnet-ransomware-2023-1026 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 9c8b5b56-8e9f-5c83-b824-423718c8956b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
