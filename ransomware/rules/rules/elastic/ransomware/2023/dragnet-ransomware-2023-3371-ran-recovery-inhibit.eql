// Dragnet [Ransomware]: dragnet-ransomware-2023-3371 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 5eca70a0-c54e-5d99-86f3-21b02fd6d3e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
