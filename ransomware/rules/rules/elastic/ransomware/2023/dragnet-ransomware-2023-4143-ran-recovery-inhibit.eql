// Dragnet [Ransomware]: dragnet-ransomware-2023-4143 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: f18f2748-00fb-5bb6-8b5a-c13e6f0c9f02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
