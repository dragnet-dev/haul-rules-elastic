// Dragnet [Ransomware]: dragnet-ransomware-2023-3733 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: df41aa49-c36f-5e38-b170-97aa48906f29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
