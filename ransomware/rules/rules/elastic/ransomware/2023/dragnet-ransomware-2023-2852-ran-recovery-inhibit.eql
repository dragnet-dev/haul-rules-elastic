// Dragnet [Ransomware]: dragnet-ransomware-2023-2852 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 1d8b366f-e293-53cd-b544-aa347abfbc89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
