// Dragnet [Ransomware]: dragnet-ransomware-2023-2817 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 99f8db1f-a06f-503e-9ea2-f56d7e8daa5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
