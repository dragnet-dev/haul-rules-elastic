// Dragnet [Ransomware]: dragnet-ransomware-2023-2553 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: fb6a70e1-7472-5d43-b5e1-64252a55f173

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
