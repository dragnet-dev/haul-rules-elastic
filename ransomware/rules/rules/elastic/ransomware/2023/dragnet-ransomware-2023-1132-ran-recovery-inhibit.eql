// Dragnet [Ransomware]: dragnet-ransomware-2023-1132 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: 2f2222c9-b935-5cab-93fd-5c0caf5902a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
