// Dragnet [Ransomware]: dragnet-ransomware-2023-0133 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: cb572a2b-51e6-5d22-8c38-e7ec0228d852

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
