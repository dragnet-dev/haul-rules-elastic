// Dragnet [Ransomware]: dragnet-ransomware-2023-2398 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ad5f42ed-015e-51ac-b466-6e1ce425e18f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
