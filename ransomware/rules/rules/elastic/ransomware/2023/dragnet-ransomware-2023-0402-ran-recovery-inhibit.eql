// Dragnet [Ransomware]: dragnet-ransomware-2023-0402 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 35e6ae3a-bf23-5909-8a29-98129754d378

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
