// Dragnet [Ransomware]: dragnet-ransomware-2023-5054 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 3969f371-2c66-55e4-85c7-8ea42856dda5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
