// Dragnet [Ransomware]: dragnet-ransomware-2023-2451 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 025a9739-d02c-52a4-99e9-54b0e23e4fba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
