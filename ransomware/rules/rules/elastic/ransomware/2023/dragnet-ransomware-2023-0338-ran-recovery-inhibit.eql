// Dragnet [Ransomware]: dragnet-ransomware-2023-0338 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1f19afed-b207-50f3-9964-a5332b3e10a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
