// Dragnet [Ransomware]: dragnet-ransomware-2023-4300 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6163427a-f487-5f52-a1f8-963bdc4ac425

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
