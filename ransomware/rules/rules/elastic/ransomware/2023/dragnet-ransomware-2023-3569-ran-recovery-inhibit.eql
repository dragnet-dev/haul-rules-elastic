// Dragnet [Ransomware]: dragnet-ransomware-2023-3569 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0ea48a0b-e8a1-5134-9a89-9cc57d0dfde2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
