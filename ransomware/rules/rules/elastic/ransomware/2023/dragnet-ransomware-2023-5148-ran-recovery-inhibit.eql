// Dragnet [Ransomware]: dragnet-ransomware-2023-5148 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: 4eadc84c-c384-589c-a13b-406d57d40a9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
