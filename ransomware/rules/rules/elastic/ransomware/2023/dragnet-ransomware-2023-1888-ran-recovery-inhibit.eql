// Dragnet [Ransomware]: dragnet-ransomware-2023-1888 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: aaff61c0-cff1-55e6-8409-03887aa7efe2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
