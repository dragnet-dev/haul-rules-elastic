// Dragnet [Ransomware]: dragnet-ransomware-2023-0287 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: a5d2d793-650e-55c5-9a3e-2ea88dddfd5e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
