// Dragnet [Ransomware]: dragnet-ransomware-2023-0077 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 863b0d0a-e3b3-570c-95c8-76c60f251b9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
