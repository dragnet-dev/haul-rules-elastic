// Dragnet [Ransomware]: dragnet-ransomware-2023-0830 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 63a292d6-168c-5cbd-94bd-55ae0bcba3b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
