// Dragnet [Ransomware]: dragnet-ransomware-2023-1648 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 949f22fa-9843-521c-b70e-cfbfbab792b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
