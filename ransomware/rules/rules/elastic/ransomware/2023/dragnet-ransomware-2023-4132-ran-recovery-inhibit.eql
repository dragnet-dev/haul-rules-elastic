// Dragnet [Ransomware]: dragnet-ransomware-2023-4132 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1585d154-c2cf-56d5-a1cb-5494a9a173bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
