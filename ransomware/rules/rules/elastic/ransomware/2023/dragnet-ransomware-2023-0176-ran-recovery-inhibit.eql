// Dragnet [Ransomware]: dragnet-ransomware-2023-0176 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5ffe2943-27e8-5296-a914-9d6edfc108c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
