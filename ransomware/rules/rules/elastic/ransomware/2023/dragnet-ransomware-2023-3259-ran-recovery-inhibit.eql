// Dragnet [Ransomware]: dragnet-ransomware-2023-3259 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 15bb3e58-a72e-57b8-a7e0-01d29b2e3e51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
