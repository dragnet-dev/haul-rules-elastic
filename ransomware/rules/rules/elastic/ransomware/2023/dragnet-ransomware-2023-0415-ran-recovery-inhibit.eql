// Dragnet [Ransomware]: dragnet-ransomware-2023-0415 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4475f2ff-9d13-5d99-978e-45cb25889353

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
