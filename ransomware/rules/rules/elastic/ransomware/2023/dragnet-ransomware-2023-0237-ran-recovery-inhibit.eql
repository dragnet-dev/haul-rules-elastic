// Dragnet [Ransomware]: dragnet-ransomware-2023-0237 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5a037cba-5f9d-58dd-8870-66efc6a35908

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
