// Dragnet [Ransomware]: dragnet-ransomware-2023-1008 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f1be4a7a-6980-5b7e-83fc-5de60bcef984

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
