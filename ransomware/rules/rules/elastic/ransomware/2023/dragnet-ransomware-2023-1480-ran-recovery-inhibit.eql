// Dragnet [Ransomware]: dragnet-ransomware-2023-1480 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5ddcef8f-aa05-546b-a54f-c1dae71e7e9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
