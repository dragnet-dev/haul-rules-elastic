// Dragnet [Ransomware]: dragnet-ransomware-2023-1800 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 6da3abc8-2e0c-5033-b8f5-155535045a61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
