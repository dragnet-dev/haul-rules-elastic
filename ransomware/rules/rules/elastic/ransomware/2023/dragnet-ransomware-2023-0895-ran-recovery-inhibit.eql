// Dragnet [Ransomware]: dragnet-ransomware-2023-0895 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 1f396d91-ada6-5f7f-b182-ed69e0b26df7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
