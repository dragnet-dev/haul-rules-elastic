// Dragnet [Ransomware]: dragnet-ransomware-2023-0684 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: f8726dc9-ad44-57ea-aa9f-a1d58e2bec90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
