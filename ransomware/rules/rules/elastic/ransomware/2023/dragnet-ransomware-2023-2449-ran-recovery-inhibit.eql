// Dragnet [Ransomware]: dragnet-ransomware-2023-2449 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: 9950eceb-8e67-5906-98a4-035db291759a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
