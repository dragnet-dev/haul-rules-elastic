// Dragnet [Ransomware]: dragnet-ransomware-2023-1729 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 09cdbcec-cc3c-5d3c-abd7-69a1b31dfc08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
