// Dragnet [Ransomware]: dragnet-ransomware-2023-2666 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: b552d7ab-bd55-5df7-8063-ffccc9479f0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
