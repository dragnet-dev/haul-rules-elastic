// Dragnet [Ransomware]: dragnet-ransomware-2023-2471 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f645e187-c0bc-5b1f-9437-f7991ba3dc0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
