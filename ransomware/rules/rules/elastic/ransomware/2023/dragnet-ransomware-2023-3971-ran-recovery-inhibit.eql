// Dragnet [Ransomware]: dragnet-ransomware-2023-3971 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 963582bc-579d-56df-915d-32102efc7627

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
