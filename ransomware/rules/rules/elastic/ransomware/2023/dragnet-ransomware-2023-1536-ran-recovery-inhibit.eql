// Dragnet [Ransomware]: dragnet-ransomware-2023-1536 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 279cde1d-3681-5e81-95ea-fb59083f035f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
