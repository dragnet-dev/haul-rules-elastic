// Dragnet [Ransomware]: dragnet-ransomware-2023-0224 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 113e3d1b-fc5f-5bb2-8f71-ca35279406a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
