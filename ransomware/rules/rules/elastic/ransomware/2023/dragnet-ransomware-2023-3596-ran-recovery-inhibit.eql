// Dragnet [Ransomware]: dragnet-ransomware-2023-3596 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5911c5d3-c864-5d51-ae9c-56fadcafa696

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
