// Dragnet [Ransomware]: dragnet-ransomware-2023-5234 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2af76f2a-4c70-5cb2-80ce-5aecdac84d06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
