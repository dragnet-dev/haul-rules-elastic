// Dragnet [Ransomware]: dragnet-ransomware-2023-2931 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 00d81926-5652-56ef-8e7d-529aa6d37821

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
