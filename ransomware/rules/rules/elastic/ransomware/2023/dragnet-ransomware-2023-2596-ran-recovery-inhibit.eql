// Dragnet [Ransomware]: dragnet-ransomware-2023-2596 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 658eb323-c477-5a81-8151-307e12499777

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
