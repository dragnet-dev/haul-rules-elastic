// Dragnet [Ransomware]: dragnet-ransomware-2023-5203 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: 9b66156e-232b-5579-9636-daf582b20aef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
