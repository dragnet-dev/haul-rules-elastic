// Dragnet [Ransomware]: dragnet-ransomware-2023-1175 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 02e279ad-b0b5-59fa-80e4-421b3753ba72

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
