// Dragnet [Ransomware]: dragnet-ransomware-2023-3872 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: def25309-9dd3-5258-8492-7be9dc0095b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
