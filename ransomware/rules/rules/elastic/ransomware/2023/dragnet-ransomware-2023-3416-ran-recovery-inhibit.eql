// Dragnet [Ransomware]: dragnet-ransomware-2023-3416 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 33aeb4d7-009f-5f72-99e4-3b78e33a9e45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
