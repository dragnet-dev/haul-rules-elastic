// Dragnet [Ransomware]: dragnet-ransomware-2023-5135 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: a02bd565-e82c-57b6-a493-0d70cbb38e08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
