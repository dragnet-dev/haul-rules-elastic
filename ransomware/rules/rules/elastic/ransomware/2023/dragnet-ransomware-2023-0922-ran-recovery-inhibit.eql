// Dragnet [Ransomware]: dragnet-ransomware-2023-0922 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: da336361-b07c-5850-8ac3-ee5b42fc071e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
