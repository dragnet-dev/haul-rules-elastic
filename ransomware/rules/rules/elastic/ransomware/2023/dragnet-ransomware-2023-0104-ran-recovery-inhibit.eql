// Dragnet [Ransomware]: dragnet-ransomware-2023-0104 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 35b74184-44d0-55f3-a022-55237bc7097d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
