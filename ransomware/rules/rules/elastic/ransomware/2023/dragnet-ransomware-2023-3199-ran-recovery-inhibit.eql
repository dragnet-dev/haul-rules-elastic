// Dragnet [Ransomware]: dragnet-ransomware-2023-3199 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5854c219-1042-573e-badb-925d459a6262

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
