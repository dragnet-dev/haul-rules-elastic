// Dragnet [Ransomware]: dragnet-ransomware-2023-4084 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 32654d0b-0e7c-56f3-9d76-e46f20e6d077

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
