// Dragnet [Ransomware]: dragnet-ransomware-2023-3767 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 4e4b1b9b-a3ff-5479-9f22-07d844ff29db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
