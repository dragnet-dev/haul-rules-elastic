// Dragnet [Ransomware]: dragnet-ransomware-2023-1763 — Recovery Inhibition (darkrace)
// Status: experimental | Level: high | ID: 9b8d417c-0452-5ad8-b987-a54adc921fd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
