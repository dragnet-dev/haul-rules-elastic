// Dragnet [Ransomware]: dragnet-ransomware-2023-0099 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3b0a6681-5a6f-59d7-94cb-fb746346c142

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
