// Dragnet [Ransomware]: dragnet-ransomware-2023-2134 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 595b28a0-0162-55e2-b911-4b52d37163f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
