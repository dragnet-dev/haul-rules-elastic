// Dragnet [Ransomware]: dragnet-ransomware-2023-1057 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 64612d4a-b68b-5bd8-b0b9-5d63b979e6e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
