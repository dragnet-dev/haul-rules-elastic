// Dragnet [Ransomware]: dragnet-ransomware-2023-4953 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9d0203ef-7e12-58ba-95a5-39b3695ab3c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
