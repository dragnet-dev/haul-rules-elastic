// Dragnet [Ransomware]: dragnet-ransomware-2023-2612 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a0c34148-5a30-5fcf-968c-eb266687f9de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
