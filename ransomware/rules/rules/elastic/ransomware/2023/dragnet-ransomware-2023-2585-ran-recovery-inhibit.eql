// Dragnet [Ransomware]: dragnet-ransomware-2023-2585 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: c0b19311-2bcc-5b4c-8056-a9d1d75d525e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
