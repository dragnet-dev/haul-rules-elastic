// Dragnet [Ransomware]: dragnet-ransomware-2023-5376 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 85ff78b1-3bad-569b-a9a6-cf0e4d3a174a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
