// Dragnet [Ransomware]: dragnet-ransomware-2023-4991 — Recovery Inhibition (dunghill)
// Status: experimental | Level: high | ID: a442b2ae-daca-5172-96a7-d32db531df0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
