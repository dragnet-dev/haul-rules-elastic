// Dragnet [Ransomware]: dragnet-ransomware-2023-0149 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e8fd5c64-fac7-53a0-980e-8885acd5a327

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
