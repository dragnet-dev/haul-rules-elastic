// Dragnet [Ransomware]: dragnet-ransomware-2023-5040 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d92529a0-ae73-59e2-9316-5840804fed54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
