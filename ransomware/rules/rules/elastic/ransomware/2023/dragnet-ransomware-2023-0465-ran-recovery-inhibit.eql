// Dragnet [Ransomware]: dragnet-ransomware-2023-0465 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 381e0829-29c6-58c8-85b0-ffb65f39a6e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
