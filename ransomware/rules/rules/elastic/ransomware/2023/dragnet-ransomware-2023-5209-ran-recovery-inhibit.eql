// Dragnet [Ransomware]: dragnet-ransomware-2023-5209 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 21804fb8-5155-5866-bec2-67cc0eaf9268

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
