// Dragnet [Ransomware]: dragnet-ransomware-2023-1300 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5d761af0-efb3-5545-9a1a-9b77acb584e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
