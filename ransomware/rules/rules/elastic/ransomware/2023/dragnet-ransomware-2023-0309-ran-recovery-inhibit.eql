// Dragnet [Ransomware]: dragnet-ransomware-2023-0309 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 41edf5a1-0862-5f3a-a160-884a10d22b9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
