// Dragnet [Ransomware]: dragnet-ransomware-2023-0623 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 852d1bcf-f8cf-5f8c-8b4c-7cd636ebc1ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
