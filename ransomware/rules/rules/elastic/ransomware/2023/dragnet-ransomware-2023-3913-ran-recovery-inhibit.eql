// Dragnet [Ransomware]: dragnet-ransomware-2023-3913 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 353813cc-cbd3-5f6e-a71b-2e28c6be89d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
