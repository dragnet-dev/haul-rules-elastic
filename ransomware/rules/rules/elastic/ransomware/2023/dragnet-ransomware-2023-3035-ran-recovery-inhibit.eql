// Dragnet [Ransomware]: dragnet-ransomware-2023-3035 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: a1798b12-b027-5430-af0e-badac67f78f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
