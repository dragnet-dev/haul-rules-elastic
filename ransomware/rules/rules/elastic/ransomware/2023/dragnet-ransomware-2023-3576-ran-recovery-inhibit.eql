// Dragnet [Ransomware]: dragnet-ransomware-2023-3576 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4e97052b-a45f-5c6a-84ed-f91bfba489d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
