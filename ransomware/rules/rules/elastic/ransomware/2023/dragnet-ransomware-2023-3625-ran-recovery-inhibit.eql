// Dragnet [Ransomware]: dragnet-ransomware-2023-3625 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 43b402a6-b02d-5c12-a582-9dcd0ec7c13d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
