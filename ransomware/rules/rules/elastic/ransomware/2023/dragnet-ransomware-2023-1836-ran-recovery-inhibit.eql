// Dragnet [Ransomware]: dragnet-ransomware-2023-1836 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 44fcba14-226a-5546-aec2-fc950e44ab3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
