// Dragnet [Ransomware]: dragnet-ransomware-2023-4530 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 1c3070ed-0f3b-5289-a366-775717a50787

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
