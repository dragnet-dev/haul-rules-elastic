// Dragnet [Ransomware]: dragnet-ransomware-2023-0619 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: bb0f42b3-c3a9-5ede-be77-28f21afc1135

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
