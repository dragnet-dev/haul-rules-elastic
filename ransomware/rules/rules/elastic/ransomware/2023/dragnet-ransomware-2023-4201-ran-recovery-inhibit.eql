// Dragnet [Ransomware]: dragnet-ransomware-2023-4201 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 93b40632-2ee7-5381-972e-600189954cae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
