// Dragnet [Ransomware]: dragnet-ransomware-2023-4388 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 98736c16-7f77-559a-9fbe-32518b4425ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
