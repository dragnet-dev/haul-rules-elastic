// Dragnet [Ransomware]: dragnet-ransomware-2023-4855 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1e8aea5b-ce8e-5c49-81e4-9297563de482

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
