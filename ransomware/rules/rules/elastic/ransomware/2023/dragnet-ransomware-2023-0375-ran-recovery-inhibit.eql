// Dragnet [Ransomware]: dragnet-ransomware-2023-0375 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 11781855-359a-5df4-9351-e550b31135ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
