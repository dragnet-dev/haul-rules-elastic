// Dragnet [Ransomware]: dragnet-ransomware-2023-4987 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: ee946285-9a40-5b80-b538-b3a8129d5f48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
