// Dragnet [Ransomware]: dragnet-ransomware-2023-3045 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: c4cd6867-3ad6-5a98-a30f-a39c816a6390

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
