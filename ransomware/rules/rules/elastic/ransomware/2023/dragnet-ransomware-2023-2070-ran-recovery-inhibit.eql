// Dragnet [Ransomware]: dragnet-ransomware-2023-2070 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4e4db42c-f4b2-5c32-8789-015ecb1352a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
