// Dragnet [Ransomware]: dragnet-ransomware-2023-0514 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: 0e038046-acb6-5911-b212-1ee2d29d3e14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
