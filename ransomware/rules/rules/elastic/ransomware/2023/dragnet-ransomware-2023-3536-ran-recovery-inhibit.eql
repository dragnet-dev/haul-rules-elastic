// Dragnet [Ransomware]: dragnet-ransomware-2023-3536 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 38e7cfd0-bb84-5752-9d6b-35623bdcedb6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
