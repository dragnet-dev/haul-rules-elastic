// Dragnet [Ransomware]: dragnet-ransomware-2023-3648 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 38ffc96e-7251-52ec-91e6-7e65a9dba133

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
