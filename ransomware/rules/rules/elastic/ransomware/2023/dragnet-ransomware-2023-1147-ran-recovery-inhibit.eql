// Dragnet [Ransomware]: dragnet-ransomware-2023-1147 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 4fc7bc97-93d3-5b6c-8793-f5d020461259

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
