// Dragnet [Ransomware]: dragnet-ransomware-2023-3359 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a979a4a4-dbb4-5673-ba34-4ec22b9d526f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
