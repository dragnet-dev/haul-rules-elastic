// Dragnet [Ransomware]: dragnet-ransomware-2023-0218 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8b018f97-6332-5af9-a70d-2e462bbb4935

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
