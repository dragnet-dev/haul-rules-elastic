// Dragnet [Ransomware]: dragnet-ransomware-2023-1452 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 70f97a98-e1de-5ee9-9c90-41807390f394

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
