// Dragnet [Ransomware]: dragnet-ransomware-2023-4602 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 60556dbd-5f2b-5f66-a067-29348967f38c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
