// Dragnet [Ransomware]: dragnet-ransomware-2023-0864 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 4c3e3548-c5f3-57bd-87ea-6fffad4f3f07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
