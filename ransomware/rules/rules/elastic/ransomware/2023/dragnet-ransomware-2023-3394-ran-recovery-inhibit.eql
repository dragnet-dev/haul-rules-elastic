// Dragnet [Ransomware]: dragnet-ransomware-2023-3394 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0fee5ded-8711-592e-913f-04bea220dacb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
