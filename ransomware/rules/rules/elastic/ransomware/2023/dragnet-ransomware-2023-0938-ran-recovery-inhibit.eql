// Dragnet [Ransomware]: dragnet-ransomware-2023-0938 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 59e429b5-5ad4-56e1-a1f9-b013c936e2ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
