// Dragnet [Ransomware]: dragnet-ransomware-2023-2144 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a967017a-1e25-509d-8102-4abe1ed49b1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
