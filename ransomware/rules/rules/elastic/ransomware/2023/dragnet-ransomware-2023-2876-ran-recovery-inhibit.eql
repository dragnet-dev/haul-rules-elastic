// Dragnet [Ransomware]: dragnet-ransomware-2023-2876 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 0d883c17-5123-5506-9646-93cc7264637d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
