// Dragnet [Ransomware]: dragnet-ransomware-2023-2465 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: fd74d5fb-b481-5b03-8d38-6cef252648e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
