// Dragnet [Ransomware]: dragnet-ransomware-2023-0337 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 44ffed3d-1408-5ee6-83e8-0f293846d3dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
