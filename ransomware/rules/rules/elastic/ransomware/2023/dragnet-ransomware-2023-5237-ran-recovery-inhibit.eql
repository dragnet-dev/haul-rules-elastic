// Dragnet [Ransomware]: dragnet-ransomware-2023-5237 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: eaa2a005-ac4f-53c7-8c90-a92e2e6814f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
