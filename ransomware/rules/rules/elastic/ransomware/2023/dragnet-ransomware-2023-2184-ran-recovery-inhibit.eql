// Dragnet [Ransomware]: dragnet-ransomware-2023-2184 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 132d4e75-fc6f-53bf-8bfa-0041c06de59d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
