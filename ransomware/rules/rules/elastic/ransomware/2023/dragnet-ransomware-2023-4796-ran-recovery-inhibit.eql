// Dragnet [Ransomware]: dragnet-ransomware-2023-4796 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 17bdce9b-ddd9-53da-90ef-04d4d1a340f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
