// Dragnet [Ransomware]: dragnet-ransomware-2023-1289 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 3caea8ac-fa71-555d-ba79-8ecdbac6682e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
