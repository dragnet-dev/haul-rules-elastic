// Dragnet [Ransomware]: dragnet-ransomware-2023-1714 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f6f4dc38-8131-532f-a265-f8aa04e62f0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
