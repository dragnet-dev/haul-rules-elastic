// Dragnet [Ransomware]: dragnet-ransomware-2023-1728 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 6faa48b4-ad57-5463-a6c9-748575ade2ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
