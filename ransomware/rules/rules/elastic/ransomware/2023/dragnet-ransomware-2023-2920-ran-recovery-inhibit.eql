// Dragnet [Ransomware]: dragnet-ransomware-2023-2920 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 022aa11d-c073-52b0-b609-ea16222c974d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
