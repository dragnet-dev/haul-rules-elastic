// Dragnet [Ransomware]: dragnet-ransomware-2023-1498 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 008f2373-b0fc-5034-8acb-6967c5860a34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
