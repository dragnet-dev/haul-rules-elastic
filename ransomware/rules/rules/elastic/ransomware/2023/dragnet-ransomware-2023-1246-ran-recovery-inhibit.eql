// Dragnet [Ransomware]: dragnet-ransomware-2023-1246 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 773ba3cf-ffe9-56e4-b5ca-4fae3d7fd7e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
