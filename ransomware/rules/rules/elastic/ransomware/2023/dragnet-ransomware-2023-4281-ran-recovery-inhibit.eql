// Dragnet [Ransomware]: dragnet-ransomware-2023-4281 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 7a92687b-e13f-552c-829d-8acb4bc0546c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
