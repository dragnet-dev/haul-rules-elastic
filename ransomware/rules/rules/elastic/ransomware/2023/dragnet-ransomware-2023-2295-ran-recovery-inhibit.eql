// Dragnet [Ransomware]: dragnet-ransomware-2023-2295 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 526a24f0-e8ac-54a5-a41f-3a712577e459

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
