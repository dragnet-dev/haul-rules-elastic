// Dragnet [Ransomware]: dragnet-ransomware-2023-2535 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e78028ce-3f95-517f-8462-3d3b78c9d18e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
