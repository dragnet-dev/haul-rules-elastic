// Dragnet [Ransomware]: dragnet-ransomware-2023-4977 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 3aa11745-d40e-57fd-ae57-1f20490d1192

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
