// Dragnet [Ransomware]: dragnet-ransomware-2023-1541 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: f0848f81-3993-50dc-b3d4-73fc73fefe58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
