// Dragnet [Ransomware]: dragnet-ransomware-2023-1914 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 234eaf0d-7c6c-509d-9fd7-54d48b728c8f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
