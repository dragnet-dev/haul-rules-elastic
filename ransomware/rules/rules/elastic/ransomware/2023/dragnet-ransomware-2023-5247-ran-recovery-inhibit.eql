// Dragnet [Ransomware]: dragnet-ransomware-2023-5247 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 88c97f44-2a7e-5906-9478-7b32a4b255ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
