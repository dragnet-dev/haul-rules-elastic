// Dragnet [Ransomware]: dragnet-ransomware-2023-2837 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: bdb0e438-bf1d-5867-8f28-a34046cefa63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
