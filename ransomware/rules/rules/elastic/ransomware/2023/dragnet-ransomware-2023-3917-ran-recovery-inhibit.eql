// Dragnet [Ransomware]: dragnet-ransomware-2023-3917 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f9e7700c-2d6f-5669-abb8-a431e88d7531

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
