// Dragnet [Ransomware]: dragnet-ransomware-2023-0406 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: 9e8e8acd-1715-5ae0-90ab-9696076733d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
