// Dragnet [Ransomware]: dragnet-ransomware-2023-0644 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 799b2c5e-fec2-5c06-a58c-ee0f96e5a43a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
