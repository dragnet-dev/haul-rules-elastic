// Dragnet [Ransomware]: dragnet-ransomware-2023-1559 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 9f5240bd-64a7-5e6a-b58f-e141e6725ad3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
