// Dragnet [Ransomware]: dragnet-ransomware-2023-1535 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ec08b623-b5ce-5cbc-a46d-1da0ff2cfad4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
