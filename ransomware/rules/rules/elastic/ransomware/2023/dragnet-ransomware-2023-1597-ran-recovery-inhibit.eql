// Dragnet [Ransomware]: dragnet-ransomware-2023-1597 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: acb91abe-33a4-5d3a-97e0-c8aac86f42b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
