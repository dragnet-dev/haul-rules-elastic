// Dragnet [Ransomware]: dragnet-ransomware-2023-0718 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 556664a3-d33d-5337-be91-aae7f784abe3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
