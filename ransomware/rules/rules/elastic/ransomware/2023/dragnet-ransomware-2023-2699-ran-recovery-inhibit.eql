// Dragnet [Ransomware]: dragnet-ransomware-2023-2699 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 29e18b6f-f7be-511f-bec1-e035082ac646

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
