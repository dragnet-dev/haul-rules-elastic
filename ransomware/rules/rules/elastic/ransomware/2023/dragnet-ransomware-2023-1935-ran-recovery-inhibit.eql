// Dragnet [Ransomware]: dragnet-ransomware-2023-1935 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 59a2a683-095e-5ec5-a264-d4cbc9754b6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
