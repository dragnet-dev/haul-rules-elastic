// Dragnet [Ransomware]: dragnet-ransomware-2023-4514 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: e0c7d221-e911-522a-8f81-6c79e7edfaef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
