// Dragnet [Ransomware]: dragnet-ransomware-2023-2340 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 7f050358-7bd3-57d8-975d-142b91be2886

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
