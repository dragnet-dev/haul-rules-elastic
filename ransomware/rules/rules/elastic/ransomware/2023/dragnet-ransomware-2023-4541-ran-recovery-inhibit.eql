// Dragnet [Ransomware]: dragnet-ransomware-2023-4541 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: a7151a46-57ab-5524-90f3-40bfaca2300d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
