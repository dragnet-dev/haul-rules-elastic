// Dragnet [Ransomware]: dragnet-ransomware-2023-1411 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 66d4fbc0-f528-52f8-a18f-3cd018c2b9bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
