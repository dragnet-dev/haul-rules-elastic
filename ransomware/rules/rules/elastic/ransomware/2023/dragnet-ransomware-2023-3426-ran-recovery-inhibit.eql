// Dragnet [Ransomware]: dragnet-ransomware-2023-3426 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 12f06ea0-4ee9-5f30-970a-87c4909ad480

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
