// Dragnet [Ransomware]: dragnet-ransomware-2023-0606 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2314a79b-d670-5399-a80f-e96d7b19e870

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
