// Dragnet [Ransomware]: dragnet-ransomware-2023-5041 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 82dbf7e1-5b63-5280-bb93-e4bc9548a136

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
