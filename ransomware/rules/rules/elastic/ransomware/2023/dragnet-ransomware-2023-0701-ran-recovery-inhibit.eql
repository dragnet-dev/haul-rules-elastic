// Dragnet [Ransomware]: dragnet-ransomware-2023-0701 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8a5ebb33-8096-5f58-963f-ebd8f9c013ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
