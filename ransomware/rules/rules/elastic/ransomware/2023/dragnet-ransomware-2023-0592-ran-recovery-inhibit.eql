// Dragnet [Ransomware]: dragnet-ransomware-2023-0592 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: f4406f9b-61cc-52f1-91ae-80ce35e17249

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
