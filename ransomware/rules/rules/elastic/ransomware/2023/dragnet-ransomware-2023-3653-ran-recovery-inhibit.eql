// Dragnet [Ransomware]: dragnet-ransomware-2023-3653 — Recovery Inhibition (moneymessage)
// Status: experimental | Level: high | ID: 1b29965d-cb3d-5cb9-bd74-373adf220622

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
