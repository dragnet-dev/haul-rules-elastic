// Dragnet [Ransomware]: dragnet-ransomware-2023-1989 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 496f91a3-4609-5346-956b-ea0c2d524b32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
