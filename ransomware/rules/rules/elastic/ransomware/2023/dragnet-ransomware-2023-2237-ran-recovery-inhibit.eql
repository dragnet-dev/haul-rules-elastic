// Dragnet [Ransomware]: dragnet-ransomware-2023-2237 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 172199c8-71e2-50b6-ae45-44080d403dd6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
