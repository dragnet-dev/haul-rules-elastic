// Dragnet [Ransomware]: dragnet-ransomware-2023-2762 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 6cf3e226-0e02-5a52-9350-070de7f4c69b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
