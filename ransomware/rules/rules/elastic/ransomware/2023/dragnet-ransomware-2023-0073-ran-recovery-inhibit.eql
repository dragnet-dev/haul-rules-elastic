// Dragnet [Ransomware]: dragnet-ransomware-2023-0073 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 335741e0-5c0e-5f29-9b3a-c4467fb7c385

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
