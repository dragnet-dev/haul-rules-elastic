// Dragnet [Ransomware]: dragnet-ransomware-2023-0967 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 121fb0cf-455b-5e8c-b7bf-aa2bd5d5691c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
