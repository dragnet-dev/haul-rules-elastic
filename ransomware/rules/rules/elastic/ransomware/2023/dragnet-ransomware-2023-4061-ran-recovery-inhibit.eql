// Dragnet [Ransomware]: dragnet-ransomware-2023-4061 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: 17c91c27-616c-5b57-924b-1443d2bfe0bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
