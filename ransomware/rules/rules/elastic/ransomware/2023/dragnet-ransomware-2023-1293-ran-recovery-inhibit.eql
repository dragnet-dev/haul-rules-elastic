// Dragnet [Ransomware]: dragnet-ransomware-2023-1293 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: dd4b5bb4-d82d-5843-8ec5-2e0a0918ebb2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
