// Dragnet [Ransomware]: dragnet-ransomware-2023-0599 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 9b07f096-a27d-5925-909f-cd2fe882f8e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
