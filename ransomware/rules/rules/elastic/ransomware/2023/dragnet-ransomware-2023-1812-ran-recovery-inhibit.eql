// Dragnet [Ransomware]: dragnet-ransomware-2023-1812 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5b25cd38-2c7a-5f19-abf7-47c6faa06a12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
