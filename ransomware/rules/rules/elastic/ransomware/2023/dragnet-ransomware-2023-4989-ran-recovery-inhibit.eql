// Dragnet [Ransomware]: dragnet-ransomware-2023-4989 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1a746922-0520-5876-a807-e1702930ae3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
