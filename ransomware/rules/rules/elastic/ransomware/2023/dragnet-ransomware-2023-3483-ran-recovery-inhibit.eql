// Dragnet [Ransomware]: dragnet-ransomware-2023-3483 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 9742b4e8-a6db-51d5-a42d-22e46abc5700

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
