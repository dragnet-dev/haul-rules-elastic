// Dragnet [Ransomware]: dragnet-ransomware-2023-1157 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ffade420-49d0-5856-add7-07d594e6be14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
