// Dragnet [Ransomware]: dragnet-ransomware-2023-1748 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 50d71cd6-166b-5546-974e-35d77103cfda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
