// Dragnet [Ransomware]: dragnet-ransomware-2023-1984 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: edd993be-0520-539e-a004-a0a3a6673746

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
