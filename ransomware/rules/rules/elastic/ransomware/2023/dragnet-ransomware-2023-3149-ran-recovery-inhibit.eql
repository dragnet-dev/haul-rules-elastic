// Dragnet [Ransomware]: dragnet-ransomware-2023-3149 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d238a51e-467a-54b2-ac7f-7c6804f08518

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
