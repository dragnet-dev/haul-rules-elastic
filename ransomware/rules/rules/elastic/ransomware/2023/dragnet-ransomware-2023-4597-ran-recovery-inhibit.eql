// Dragnet [Ransomware]: dragnet-ransomware-2023-4597 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 505fd195-822a-5d01-ab35-eb28e06da298

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
