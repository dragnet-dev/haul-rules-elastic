// Dragnet [Ransomware]: dragnet-ransomware-2023-5091 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6d9ca0df-e1cf-53b3-b2bd-5278fbb4b6d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
