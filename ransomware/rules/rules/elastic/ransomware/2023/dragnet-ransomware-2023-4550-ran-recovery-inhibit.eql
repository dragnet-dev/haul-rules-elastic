// Dragnet [Ransomware]: dragnet-ransomware-2023-4550 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d46fc50b-3c0a-5556-be53-f2988e728217

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
