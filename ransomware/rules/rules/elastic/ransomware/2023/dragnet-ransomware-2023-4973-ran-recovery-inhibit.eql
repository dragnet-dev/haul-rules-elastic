// Dragnet [Ransomware]: dragnet-ransomware-2023-4973 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ff5e1571-fc63-58e0-8b79-f3085cd57367

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
