// Dragnet [Ransomware]: dragnet-ransomware-2023-4027 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5b8bc262-d327-5576-be7b-cc06d202789d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
