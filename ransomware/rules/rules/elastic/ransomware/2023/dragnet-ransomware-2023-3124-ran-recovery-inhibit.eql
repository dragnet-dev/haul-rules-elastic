// Dragnet [Ransomware]: dragnet-ransomware-2023-3124 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: bfa6def6-cfda-5f89-bb2e-a86d20fd346a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
