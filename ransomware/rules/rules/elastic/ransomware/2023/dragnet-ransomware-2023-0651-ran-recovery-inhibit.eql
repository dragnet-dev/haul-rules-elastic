// Dragnet [Ransomware]: dragnet-ransomware-2023-0651 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: d7be9049-6f29-5f9f-91bc-ac1c4454a618

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
