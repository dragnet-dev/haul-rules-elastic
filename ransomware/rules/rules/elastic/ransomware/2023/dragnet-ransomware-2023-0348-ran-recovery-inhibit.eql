// Dragnet [Ransomware]: dragnet-ransomware-2023-0348 — Recovery Inhibition (werewolves)
// Status: experimental | Level: high | ID: a4e94e50-25c9-5366-ad2e-4fff7025ab06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
