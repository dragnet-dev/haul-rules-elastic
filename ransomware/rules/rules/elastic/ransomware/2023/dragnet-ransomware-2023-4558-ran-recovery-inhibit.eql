// Dragnet [Ransomware]: dragnet-ransomware-2023-4558 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b1d60d20-3205-5a60-8e71-59bea79f3c38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
