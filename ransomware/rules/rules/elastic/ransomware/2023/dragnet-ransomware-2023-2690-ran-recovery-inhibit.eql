// Dragnet [Ransomware]: dragnet-ransomware-2023-2690 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: ada5611b-3290-5ae4-8e8e-e9cef6b593d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
