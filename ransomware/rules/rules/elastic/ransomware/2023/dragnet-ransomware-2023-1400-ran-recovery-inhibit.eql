// Dragnet [Ransomware]: dragnet-ransomware-2023-1400 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a3e0c1ad-b43d-54aa-94e7-c632f241bd5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
