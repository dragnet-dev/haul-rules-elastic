// Dragnet [Ransomware]: dragnet-ransomware-2023-1356 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: f21bb2df-239d-5495-9a70-f5500ad5c268

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
