// Dragnet [Ransomware]: dragnet-ransomware-2023-3778 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: cddbf150-514b-51a3-8ecd-a7f7d8c0f3c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
