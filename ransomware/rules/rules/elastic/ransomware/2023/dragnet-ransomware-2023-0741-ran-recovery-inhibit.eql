// Dragnet [Ransomware]: dragnet-ransomware-2023-0741 — Recovery Inhibition (siegedsec)
// Status: deprecated | Level: high | ID: c9f19f41-e01a-564a-82ff-44111577251d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
