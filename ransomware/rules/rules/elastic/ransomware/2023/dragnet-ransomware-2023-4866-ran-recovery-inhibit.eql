// Dragnet [Ransomware]: dragnet-ransomware-2023-4866 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 6bf76b61-7b7a-5fbf-9c80-338408d713e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
