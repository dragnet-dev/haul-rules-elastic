// Dragnet [Ransomware]: dragnet-ransomware-2023-3727 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 291dc7cb-ab98-5571-9643-8f487b8e3139

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
