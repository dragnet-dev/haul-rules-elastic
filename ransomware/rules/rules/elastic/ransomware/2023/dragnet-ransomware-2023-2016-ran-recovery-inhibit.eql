// Dragnet [Ransomware]: dragnet-ransomware-2023-2016 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 1fc2df5d-79de-5b88-850e-e6f54dace7bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
