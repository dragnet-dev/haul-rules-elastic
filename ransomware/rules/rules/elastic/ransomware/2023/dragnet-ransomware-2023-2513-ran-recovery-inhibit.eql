// Dragnet [Ransomware]: dragnet-ransomware-2023-2513 — Recovery Inhibition (0mega)
// Status: deprecated | Level: high | ID: c17ea51c-c6bf-50e0-ace1-e8b6afc2f1c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
