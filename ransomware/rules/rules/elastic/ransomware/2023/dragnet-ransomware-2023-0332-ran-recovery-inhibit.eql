// Dragnet [Ransomware]: dragnet-ransomware-2023-0332 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f986d2a1-2ae1-532d-8ee7-60a999e5b9a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
