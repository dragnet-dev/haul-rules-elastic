// Dragnet [Ransomware]: dragnet-ransomware-2023-1158 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: 58276bcc-ee58-5fff-b8d2-e19fd5e661f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
