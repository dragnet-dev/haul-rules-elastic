// Dragnet [Ransomware]: dragnet-ransomware-2023-2778 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: af67094d-55f7-5fa1-82ce-3b070ec0191b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
