// Dragnet [Ransomware]: dragnet-ransomware-2023-3114 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 0b2a69e7-54ea-524a-a096-3c7c867b88a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
