// Dragnet [Ransomware]: dragnet-ransomware-2023-4438 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: e823db75-1048-58f9-bf75-e66a9303d135

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
