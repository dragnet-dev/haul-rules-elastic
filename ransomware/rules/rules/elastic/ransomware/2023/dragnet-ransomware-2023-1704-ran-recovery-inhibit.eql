// Dragnet [Ransomware]: dragnet-ransomware-2023-1704 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 2a319a78-3528-5861-95d6-4f26cae2301b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
