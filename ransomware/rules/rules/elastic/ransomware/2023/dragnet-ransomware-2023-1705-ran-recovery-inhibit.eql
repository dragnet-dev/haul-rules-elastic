// Dragnet [Ransomware]: dragnet-ransomware-2023-1705 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 461039d6-b201-5144-bf59-be0edfee5052

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
