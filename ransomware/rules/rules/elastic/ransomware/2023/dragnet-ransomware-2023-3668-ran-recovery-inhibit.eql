// Dragnet [Ransomware]: dragnet-ransomware-2023-3668 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 277db43c-87d0-54f3-87cb-1e112ed23542

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
