// Dragnet [Ransomware]: dragnet-ransomware-2023-1353 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ecef8dba-3252-5299-92fe-ff6be2d98024

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
