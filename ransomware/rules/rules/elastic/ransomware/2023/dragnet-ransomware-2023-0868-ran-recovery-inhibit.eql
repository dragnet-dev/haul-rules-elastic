// Dragnet [Ransomware]: dragnet-ransomware-2023-0868 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: da865ffa-40ed-5549-993c-36eee6208501

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
