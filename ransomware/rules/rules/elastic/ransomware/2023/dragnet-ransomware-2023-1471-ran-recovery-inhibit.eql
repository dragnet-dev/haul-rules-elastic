// Dragnet [Ransomware]: dragnet-ransomware-2023-1471 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 64a6a7b9-3a9b-52bb-a495-c82037005155

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
