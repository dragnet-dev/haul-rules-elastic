// Dragnet [Ransomware]: dragnet-ransomware-2023-2651 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 1fc2bf0c-2362-58ee-bfe3-273638bfb94f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
