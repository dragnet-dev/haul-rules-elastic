// Dragnet [Ransomware]: dragnet-ransomware-2023-1527 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: b9178ba8-ce49-5778-a9a5-4e98dd2b09d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
