// Dragnet [Ransomware]: dragnet-ransomware-2023-2473 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 642946e4-de79-59ef-a1b3-9b4221958a71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
