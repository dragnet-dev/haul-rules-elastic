// Dragnet [Ransomware]: dragnet-ransomware-2023-1917 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 3813c0ec-c728-58f8-b2f4-7ea86c938595

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
