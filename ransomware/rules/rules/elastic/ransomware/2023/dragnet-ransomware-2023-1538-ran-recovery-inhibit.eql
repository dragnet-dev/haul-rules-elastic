// Dragnet [Ransomware]: dragnet-ransomware-2023-1538 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 25db012a-de0a-592c-9878-46966a86a2b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
