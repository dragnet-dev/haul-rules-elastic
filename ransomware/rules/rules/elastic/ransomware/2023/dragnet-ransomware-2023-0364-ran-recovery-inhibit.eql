// Dragnet [Ransomware]: dragnet-ransomware-2023-0364 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: e1304cf9-e63e-5179-aa8f-f3bae743e643

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
