// Dragnet [Ransomware]: dragnet-ransomware-2023-4488 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ab0a391e-65fb-55ef-a02c-a2c6ff1edb77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
