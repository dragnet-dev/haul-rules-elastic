// Dragnet [Ransomware]: dragnet-ransomware-2023-2902 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 799632e8-5b8d-554b-b054-7f7298e62bc6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
