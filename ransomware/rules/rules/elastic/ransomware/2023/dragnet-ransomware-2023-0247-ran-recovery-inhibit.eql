// Dragnet [Ransomware]: dragnet-ransomware-2023-0247 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fc85a999-b373-598d-87c3-7b694dd0c65a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
