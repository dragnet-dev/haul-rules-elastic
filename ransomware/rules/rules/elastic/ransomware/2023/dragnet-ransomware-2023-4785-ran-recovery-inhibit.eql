// Dragnet [Ransomware]: dragnet-ransomware-2023-4785 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3e06192b-5965-55c8-bf28-b6408906e919

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
