// Dragnet [Ransomware]: dragnet-ransomware-2023-2742 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 1222f214-9cf0-5439-9567-c46c7fdf6fce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
