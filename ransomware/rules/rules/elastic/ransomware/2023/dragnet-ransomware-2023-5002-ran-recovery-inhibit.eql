// Dragnet [Ransomware]: dragnet-ransomware-2023-5002 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c41c85dd-fd23-5af3-9279-6e12d89403ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
