// Dragnet [Ransomware]: dragnet-ransomware-2023-3201 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a23feca9-f38d-57c4-9340-2e4c369901fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
