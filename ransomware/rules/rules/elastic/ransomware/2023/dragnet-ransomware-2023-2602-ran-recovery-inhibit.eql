// Dragnet [Ransomware]: dragnet-ransomware-2023-2602 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 9710e502-1cf5-5ac5-af5a-3ede008cebb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
