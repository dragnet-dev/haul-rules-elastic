// Dragnet [Ransomware]: dragnet-ransomware-2023-1216 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: a95343d3-8b6d-5a03-83e6-ed5df82b673c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
