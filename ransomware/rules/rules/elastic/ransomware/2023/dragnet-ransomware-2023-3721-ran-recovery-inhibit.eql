// Dragnet [Ransomware]: dragnet-ransomware-2023-3721 — Recovery Inhibition (mallox)
// Status: experimental | Level: high | ID: d6787680-4165-527f-909f-79352ac2076a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
