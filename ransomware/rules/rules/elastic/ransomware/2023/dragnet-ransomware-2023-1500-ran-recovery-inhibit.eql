// Dragnet [Ransomware]: dragnet-ransomware-2023-1500 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: 2c593cd2-0359-5917-b201-b2281fbbc44d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
