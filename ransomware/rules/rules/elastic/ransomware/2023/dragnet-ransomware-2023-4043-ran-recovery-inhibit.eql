// Dragnet [Ransomware]: dragnet-ransomware-2023-4043 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 791cd2a6-4286-5bd5-ac97-825b89da6d95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
