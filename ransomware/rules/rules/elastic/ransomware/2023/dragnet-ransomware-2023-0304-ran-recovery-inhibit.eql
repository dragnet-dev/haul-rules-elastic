// Dragnet [Ransomware]: dragnet-ransomware-2023-0304 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 605d32fb-13ee-5aa2-b75e-0f1da04caa41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
