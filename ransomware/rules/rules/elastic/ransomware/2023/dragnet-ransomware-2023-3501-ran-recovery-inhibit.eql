// Dragnet [Ransomware]: dragnet-ransomware-2023-3501 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 13fa2877-f45c-5791-b1c4-4bccd08d684f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
