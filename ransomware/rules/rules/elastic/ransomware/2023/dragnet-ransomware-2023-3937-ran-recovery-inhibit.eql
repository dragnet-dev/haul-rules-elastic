// Dragnet [Ransomware]: dragnet-ransomware-2023-3937 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 0c92a6f6-c2c7-5ad7-b389-2d2a8922edcc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
