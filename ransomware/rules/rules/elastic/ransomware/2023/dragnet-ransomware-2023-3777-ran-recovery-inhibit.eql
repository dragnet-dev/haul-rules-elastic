// Dragnet [Ransomware]: dragnet-ransomware-2023-3777 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: f05c9c59-83ba-57f7-a44f-b63abb072f61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
