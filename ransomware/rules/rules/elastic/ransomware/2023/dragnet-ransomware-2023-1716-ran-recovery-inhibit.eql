// Dragnet [Ransomware]: dragnet-ransomware-2023-1716 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 4dc0c995-28e2-5449-9949-6d5433fc4588

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
