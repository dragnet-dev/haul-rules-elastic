// Dragnet [Ransomware]: dragnet-ransomware-2023-4149 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 158b4d58-bcfc-5daf-b920-0aeca7148c2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
