// Dragnet [Ransomware]: dragnet-ransomware-2023-2959 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 563fe2ba-0267-53d9-8330-44519012c7c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
