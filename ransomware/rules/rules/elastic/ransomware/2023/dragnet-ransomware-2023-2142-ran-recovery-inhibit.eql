// Dragnet [Ransomware]: dragnet-ransomware-2023-2142 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: 7fa3ccc3-e22e-554c-8537-af38ec9643c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
