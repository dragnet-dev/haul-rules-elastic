// Dragnet [Ransomware]: dragnet-ransomware-2023-0086 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 8291d788-6101-5b02-a8d7-bc65527a6fea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
