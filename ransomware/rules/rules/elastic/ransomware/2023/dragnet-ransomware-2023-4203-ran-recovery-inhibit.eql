// Dragnet [Ransomware]: dragnet-ransomware-2023-4203 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: b1c527f2-4bea-532c-a3b3-d7e8522e34a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
