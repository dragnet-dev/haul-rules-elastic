// Dragnet [Ransomware]: dragnet-ransomware-2023-3749 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a366995d-e4b6-55fb-8e2e-2f613aa19433

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
