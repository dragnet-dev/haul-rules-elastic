// Dragnet [Ransomware]: dragnet-ransomware-2023-2039 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2456ec25-4950-5f42-83a8-c376e9fb8aa4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
