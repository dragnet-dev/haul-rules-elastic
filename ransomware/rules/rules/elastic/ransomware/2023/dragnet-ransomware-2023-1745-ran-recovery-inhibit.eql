// Dragnet [Ransomware]: dragnet-ransomware-2023-1745 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 042ee942-1549-51ef-8a1e-929c5ece8fd0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
