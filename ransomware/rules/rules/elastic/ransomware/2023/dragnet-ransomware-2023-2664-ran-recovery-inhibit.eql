// Dragnet [Ransomware]: dragnet-ransomware-2023-2664 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3f52bce7-f389-5d95-bb52-f04f11d09f67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
