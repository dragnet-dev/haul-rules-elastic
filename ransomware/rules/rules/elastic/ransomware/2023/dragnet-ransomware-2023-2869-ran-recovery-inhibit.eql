// Dragnet [Ransomware]: dragnet-ransomware-2023-2869 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: dc68c6aa-18e5-5ad3-b954-8a1646a5aafd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
