// Dragnet [Ransomware]: dragnet-ransomware-2023-1824 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: ea59b5f6-5fa9-5184-8997-641528ca5e83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
