// Dragnet [Ransomware]: dragnet-ransomware-2023-2783 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 5b65e4b4-efa1-5512-9483-2f99cc4c0bfd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
