// Dragnet [Ransomware]: dragnet-ransomware-2023-3189 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 235ece5d-380d-516e-a1ac-7b9c25eaf371

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
