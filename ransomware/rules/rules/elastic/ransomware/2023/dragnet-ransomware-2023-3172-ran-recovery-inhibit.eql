// Dragnet [Ransomware]: dragnet-ransomware-2023-3172 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 15bb3e75-d944-5407-a4b7-1729e4380968

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
