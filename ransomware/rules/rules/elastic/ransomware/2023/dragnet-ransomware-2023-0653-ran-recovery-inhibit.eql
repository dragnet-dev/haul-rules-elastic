// Dragnet [Ransomware]: dragnet-ransomware-2023-0653 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 01871644-f0f1-5ace-8553-6f0788266c1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
