// Dragnet [Ransomware]: dragnet-ransomware-2023-5350 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 01594206-0991-5007-95ee-9fd1bf449a00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
