// Dragnet [Ransomware]: dragnet-ransomware-2023-3192 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: e9a283d0-0179-5ea4-94ec-a6d9f07f16a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
