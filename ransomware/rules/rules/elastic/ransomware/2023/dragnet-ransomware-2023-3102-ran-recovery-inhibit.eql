// Dragnet [Ransomware]: dragnet-ransomware-2023-3102 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ae0dac73-710c-5559-ba3c-64ad09ecb45c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
