// Dragnet [Ransomware]: dragnet-ransomware-2023-2820 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 4d5a4438-28ad-59e4-9b55-eb332442f871

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
