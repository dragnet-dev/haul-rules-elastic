// Dragnet [Ransomware]: dragnet-ransomware-2023-2986 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 90b9f33a-13d8-5920-b01c-9526cb35a120

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
