// Dragnet [Ransomware]: dragnet-ransomware-2023-2407 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: 7944905a-43d6-5978-b4df-bb91dc143b6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
