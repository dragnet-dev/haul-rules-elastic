// Dragnet [Ransomware]: dragnet-ransomware-2023-5008 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 096acac3-c8dd-5eb1-830b-929c1a704bef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
