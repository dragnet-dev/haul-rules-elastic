// Dragnet [Ransomware]: dragnet-ransomware-2023-3134 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b73e5b54-1e85-51f7-83a0-0130f082b4ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
