// Dragnet [Ransomware]: dragnet-ransomware-2023-4536 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 65fe91dd-5f81-5a55-b040-cf5888c2a76f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
