// Dragnet [Ransomware]: dragnet-ransomware-2023-4882 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: c550a1c9-3709-5e49-a7b6-89c0fdd62c98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
