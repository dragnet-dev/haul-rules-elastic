// Dragnet [Ransomware]: dragnet-ransomware-2023-2046 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 3745e0dd-0df9-5c7b-8523-c275a8de64ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
