// Dragnet [Ransomware]: dragnet-ransomware-2023-5158 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: bc4f528b-a2a4-59ca-a1e8-f7d07fd95e75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
