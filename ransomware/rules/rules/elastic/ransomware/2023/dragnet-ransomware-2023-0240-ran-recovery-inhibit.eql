// Dragnet [Ransomware]: dragnet-ransomware-2023-0240 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: f86e152d-7f3a-5964-84ec-9cb2fe33954a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
