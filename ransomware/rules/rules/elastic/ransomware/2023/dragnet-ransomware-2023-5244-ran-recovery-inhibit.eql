// Dragnet [Ransomware]: dragnet-ransomware-2023-5244 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e36f3877-2522-5695-8c97-237fb55b418b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
