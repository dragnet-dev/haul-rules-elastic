// Dragnet [Ransomware]: dragnet-ransomware-2023-3146 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: d96bb7d4-f471-50cb-8c19-4419053a170f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
