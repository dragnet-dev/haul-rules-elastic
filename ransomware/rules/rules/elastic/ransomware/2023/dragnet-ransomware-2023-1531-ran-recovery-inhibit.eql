// Dragnet [Ransomware]: dragnet-ransomware-2023-1531 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: 9260f9ba-6d86-5df3-a404-d638e25e9f9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
