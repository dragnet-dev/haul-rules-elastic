// Dragnet [Ransomware]: dragnet-ransomware-2023-0256 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 6708849d-1469-5d83-ae37-eaa9508d3abf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
