// Dragnet [Ransomware]: dragnet-ransomware-2023-4285 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: d076c6fa-8fc8-561e-aede-92e2becd6151

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
