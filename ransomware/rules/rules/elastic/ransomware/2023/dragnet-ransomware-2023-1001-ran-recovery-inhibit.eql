// Dragnet [Ransomware]: dragnet-ransomware-2023-1001 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 22e140b9-80b3-5ba3-af08-662bc06a1fa4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
