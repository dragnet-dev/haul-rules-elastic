// Dragnet [Ransomware]: dragnet-ransomware-2023-0048 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 045f5da2-85d8-587b-a722-05cd3354c3ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
