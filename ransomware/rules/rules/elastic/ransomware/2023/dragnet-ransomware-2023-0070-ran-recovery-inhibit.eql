// Dragnet [Ransomware]: dragnet-ransomware-2023-0070 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5e3836f8-05c6-5284-b112-647f047a0dae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
