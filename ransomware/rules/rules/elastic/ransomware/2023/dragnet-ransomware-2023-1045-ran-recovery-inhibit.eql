// Dragnet [Ransomware]: dragnet-ransomware-2023-1045 — Recovery Inhibition (monti)
// Status: deprecated | Level: high | ID: 43e3b84b-5a7d-5366-b3b5-dd810b20a232

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
