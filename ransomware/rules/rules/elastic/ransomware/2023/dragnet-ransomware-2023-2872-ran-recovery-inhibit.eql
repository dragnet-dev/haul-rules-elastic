// Dragnet [Ransomware]: dragnet-ransomware-2023-2872 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 3683524f-fa04-561f-8350-cc97babf0ed3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
