// Dragnet [Ransomware]: dragnet-ransomware-2023-2694 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: b521270a-dc4b-5e71-b5ca-9aaab10d796f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
