// Dragnet [Ransomware]: dragnet-ransomware-2023-4868 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a5dd888b-5190-59b9-8885-6132fb922edc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
