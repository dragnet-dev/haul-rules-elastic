// Dragnet [Ransomware]: dragnet-ransomware-2023-4839 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e6e11923-ba1d-5f4e-af71-7f3767ad78c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
