// Dragnet [Ransomware]: dragnet-ransomware-2023-3033 — Recovery Inhibition (medusa)
// Status: deprecated | Level: high | ID: 37bdca44-4b08-5a6d-a8d8-0f9f5f2ff340

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
