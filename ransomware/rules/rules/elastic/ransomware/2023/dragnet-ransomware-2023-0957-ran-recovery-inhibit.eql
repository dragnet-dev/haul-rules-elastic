// Dragnet [Ransomware]: dragnet-ransomware-2023-0957 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 0ae59503-5142-52b9-8c33-753512121695

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
