// Dragnet [Ransomware]: dragnet-ransomware-2023-1226 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 30d72acd-866d-5ca1-a467-9de23c52d2cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
