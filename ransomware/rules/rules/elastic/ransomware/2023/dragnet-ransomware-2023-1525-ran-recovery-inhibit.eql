// Dragnet [Ransomware]: dragnet-ransomware-2023-1525 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: c2c5440a-13ba-5db2-a757-83d937d5e9e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
