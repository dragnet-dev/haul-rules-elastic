// Dragnet [Ransomware]: dragnet-ransomware-2023-3652 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 612b6fd3-a125-57c9-b434-d3633070c3d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
