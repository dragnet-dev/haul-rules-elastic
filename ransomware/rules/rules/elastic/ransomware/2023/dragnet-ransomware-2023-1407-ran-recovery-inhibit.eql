// Dragnet [Ransomware]: dragnet-ransomware-2023-1407 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f4f5c379-c705-5bbf-a425-d27ec7798655

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
