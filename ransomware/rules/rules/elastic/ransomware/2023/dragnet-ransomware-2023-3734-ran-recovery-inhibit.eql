// Dragnet [Ransomware]: dragnet-ransomware-2023-3734 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 01db7d86-d6a1-5d73-be11-076063cc8252

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
