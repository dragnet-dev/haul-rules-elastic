// Dragnet [Ransomware]: dragnet-ransomware-2023-2674 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ee63cd65-7727-5477-bf6d-1a5e782471e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
