// Dragnet [Ransomware]: dragnet-ransomware-2023-3128 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 35911884-ba8d-5a4a-9012-cf2fe4350d41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
