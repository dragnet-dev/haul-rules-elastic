// Dragnet [Ransomware]: dragnet-ransomware-2023-4545 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: e65e0119-7d8e-5f16-8688-72778682f05f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
