// Dragnet [Ransomware]: dragnet-ransomware-2023-5200 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 1b8dc9ab-e93c-584f-80cd-a32bfdda0371

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
