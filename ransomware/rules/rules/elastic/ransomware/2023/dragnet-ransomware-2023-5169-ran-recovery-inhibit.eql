// Dragnet [Ransomware]: dragnet-ransomware-2023-5169 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: b3289e37-7433-5df2-89f5-4b26be7b524c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
