// Dragnet [Ransomware]: dragnet-ransomware-2023-1744 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: ada531b9-6bc9-54ec-8026-aecaef37451a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
