// Dragnet [Ransomware]: dragnet-ransomware-2023-0103 — Recovery Inhibition (siegedsec)
// Status: experimental | Level: high | ID: b9e20678-d5b1-5dbe-a02e-964d4937a6ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
