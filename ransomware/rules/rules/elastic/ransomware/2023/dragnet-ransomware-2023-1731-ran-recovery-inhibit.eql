// Dragnet [Ransomware]: dragnet-ransomware-2023-1731 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 72ea328a-7a85-598e-b45b-4ddadbe9539a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
