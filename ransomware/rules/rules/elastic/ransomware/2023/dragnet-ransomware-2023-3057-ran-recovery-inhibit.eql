// Dragnet [Ransomware]: dragnet-ransomware-2023-3057 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 41995190-c297-57bd-96bd-225c874037a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
