// Dragnet [Ransomware]: dragnet-ransomware-2023-1194 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f08e6766-ecb8-537a-825f-85f2d550fc95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
