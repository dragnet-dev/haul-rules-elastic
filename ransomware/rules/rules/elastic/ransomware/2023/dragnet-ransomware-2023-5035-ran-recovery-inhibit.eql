// Dragnet [Ransomware]: dragnet-ransomware-2023-5035 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7c64bf4f-d48b-558c-9397-2ee652d881d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
