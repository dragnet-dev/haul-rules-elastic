// Dragnet [Ransomware]: dragnet-ransomware-2023-0354 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: bc7a8bf2-0610-51e9-83d7-7fd7152dcfdf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
