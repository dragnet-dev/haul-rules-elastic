// Dragnet [Ransomware]: dragnet-ransomware-2023-0113 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 7ed7bf88-6949-5e81-aadf-d6ca5c9ebe57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
