// Dragnet [Ransomware]: dragnet-ransomware-2023-1075 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 57ad786f-6ef2-5942-8079-83f8e78f413c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
