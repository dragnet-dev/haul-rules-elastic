// Dragnet [Ransomware]: dragnet-ransomware-2023-2504 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f97b0509-b67a-5d4a-9d0c-be3d0f7f679f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
