// Dragnet [Ransomware]: dragnet-ransomware-2023-4789 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: c0d3a5d1-7e20-579e-a805-1a72ba32b5f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
