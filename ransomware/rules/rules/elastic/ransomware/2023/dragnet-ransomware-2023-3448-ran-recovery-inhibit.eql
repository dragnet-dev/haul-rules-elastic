// Dragnet [Ransomware]: dragnet-ransomware-2023-3448 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 73d341a3-86ac-52ca-bc7b-ff455a5616ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
