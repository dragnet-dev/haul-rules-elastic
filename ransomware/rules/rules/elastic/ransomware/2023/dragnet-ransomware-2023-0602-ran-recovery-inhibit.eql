// Dragnet [Ransomware]: dragnet-ransomware-2023-0602 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d69008cb-c0d0-5e8f-b786-5727b0dbb360

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
