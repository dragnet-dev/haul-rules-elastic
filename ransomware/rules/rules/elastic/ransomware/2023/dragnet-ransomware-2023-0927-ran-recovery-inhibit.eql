// Dragnet [Ransomware]: dragnet-ransomware-2023-0927 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: bd5df940-053a-5342-af5c-991ad5a0dc32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
