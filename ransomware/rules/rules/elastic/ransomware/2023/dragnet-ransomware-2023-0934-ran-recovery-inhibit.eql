// Dragnet [Ransomware]: dragnet-ransomware-2023-0934 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: db91e51a-9c40-5df2-90d8-1e0e1a794ce8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
