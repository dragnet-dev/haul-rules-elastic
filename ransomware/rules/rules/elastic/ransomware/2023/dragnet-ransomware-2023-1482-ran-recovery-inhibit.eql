// Dragnet [Ransomware]: dragnet-ransomware-2023-1482 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 3010b8bd-3789-5a39-b524-b1ae0396e085

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
