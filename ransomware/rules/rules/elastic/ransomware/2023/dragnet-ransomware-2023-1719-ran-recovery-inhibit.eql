// Dragnet [Ransomware]: dragnet-ransomware-2023-1719 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 207fe493-f3c4-5e38-b12a-3b8cc200a25f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
