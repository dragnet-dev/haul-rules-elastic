// Dragnet [Ransomware]: dragnet-ransomware-2023-2136 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5fd0855c-4641-53b5-bebe-5a4f60c173fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
