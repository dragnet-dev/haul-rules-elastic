// Dragnet [Ransomware]: dragnet-ransomware-2023-4590 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 538ee581-ecbf-51b4-93d3-c7243c580a45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
