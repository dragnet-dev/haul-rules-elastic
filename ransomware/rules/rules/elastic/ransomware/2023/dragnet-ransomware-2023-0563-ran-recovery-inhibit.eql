// Dragnet [Ransomware]: dragnet-ransomware-2023-0563 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 0c2ff79f-cf50-523d-89a1-8faf6a89d514

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
