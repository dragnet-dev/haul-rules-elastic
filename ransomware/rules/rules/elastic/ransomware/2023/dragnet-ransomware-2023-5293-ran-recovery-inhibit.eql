// Dragnet [Ransomware]: dragnet-ransomware-2023-5293 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3819a2aa-7732-58b8-bfb9-0719bb067a3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
