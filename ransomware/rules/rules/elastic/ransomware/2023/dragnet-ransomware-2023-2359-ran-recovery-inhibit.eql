// Dragnet [Ransomware]: dragnet-ransomware-2023-2359 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: dbed5748-ce29-5800-9436-4cddd5ecd9bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
