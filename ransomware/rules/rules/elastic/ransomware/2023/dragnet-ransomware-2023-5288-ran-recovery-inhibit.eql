// Dragnet [Ransomware]: dragnet-ransomware-2023-5288 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: b4833d95-8d2f-53ee-8473-ec9f7bfde822

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
