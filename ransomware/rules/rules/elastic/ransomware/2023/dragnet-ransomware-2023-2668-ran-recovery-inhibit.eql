// Dragnet [Ransomware]: dragnet-ransomware-2023-2668 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 20f78d99-736d-59ba-885a-5599cf380bcc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
