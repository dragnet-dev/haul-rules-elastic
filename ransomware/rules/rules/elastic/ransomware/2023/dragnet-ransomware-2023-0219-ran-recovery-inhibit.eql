// Dragnet [Ransomware]: dragnet-ransomware-2023-0219 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 8bf54795-4bca-5930-afc7-d01134cb3f26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
