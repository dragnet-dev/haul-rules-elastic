// Dragnet [Ransomware]: dragnet-ransomware-2023-0167 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 9b1ed7f3-ff93-5744-9015-a1a9968a4617

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
