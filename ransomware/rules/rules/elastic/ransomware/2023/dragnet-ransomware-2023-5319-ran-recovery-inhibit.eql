// Dragnet [Ransomware]: dragnet-ransomware-2023-5319 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: b776d21e-67b6-5f7b-857a-d7fa4ae55370

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
