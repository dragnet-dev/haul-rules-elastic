// Dragnet [Ransomware]: dragnet-ransomware-2023-3580 — Recovery Inhibition (0mega)
// Status: deprecated | Level: high | ID: 73737bdc-6807-580a-8998-665503e2f319

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
