// Dragnet [Ransomware]: dragnet-ransomware-2023-4935 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3a75022a-6312-5e18-a1c9-02854ff4eb1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
