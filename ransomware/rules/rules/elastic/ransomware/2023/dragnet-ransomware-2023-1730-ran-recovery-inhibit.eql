// Dragnet [Ransomware]: dragnet-ransomware-2023-1730 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: 75546867-0755-52d4-913d-6aea403bb047

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
