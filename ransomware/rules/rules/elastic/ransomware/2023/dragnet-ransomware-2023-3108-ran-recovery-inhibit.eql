// Dragnet [Ransomware]: dragnet-ransomware-2023-3108 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: da417836-5036-5826-8863-6928af55641b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
