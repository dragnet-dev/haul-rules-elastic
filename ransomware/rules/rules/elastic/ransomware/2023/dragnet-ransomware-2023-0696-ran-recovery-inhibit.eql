// Dragnet [Ransomware]: dragnet-ransomware-2023-0696 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: abd958a3-2d7c-5ebe-bbbc-c9749aef1884

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
