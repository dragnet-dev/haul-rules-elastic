// Dragnet [Ransomware]: dragnet-ransomware-2023-1015 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 49410e5c-7cde-5709-b4a4-280aac7cf732

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
