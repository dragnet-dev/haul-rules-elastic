// Dragnet [Ransomware]: dragnet-ransomware-2023-1592 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3ed4b252-ff79-57f2-9a34-2519e541bd04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
