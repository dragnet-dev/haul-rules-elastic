// Dragnet [Ransomware]: dragnet-ransomware-2023-5199 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4c2d36ab-8914-5cb2-83f8-a8faac5bdb91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
