// Dragnet [Ransomware]: dragnet-ransomware-2023-1633 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 48c51d69-bd87-5afc-be84-293a5931fcb9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
