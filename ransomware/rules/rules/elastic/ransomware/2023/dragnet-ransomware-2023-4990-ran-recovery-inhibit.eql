// Dragnet [Ransomware]: dragnet-ransomware-2023-4990 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 0b375860-084c-5ce6-be8d-e38fd9521b5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
