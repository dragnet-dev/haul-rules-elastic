// Dragnet [Ransomware]: dragnet-ransomware-2023-3437 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: fa397a67-3fc3-56dc-8f1f-cd1b351fd993

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
