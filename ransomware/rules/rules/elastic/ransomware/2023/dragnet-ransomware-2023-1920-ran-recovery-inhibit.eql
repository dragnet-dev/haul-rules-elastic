// Dragnet [Ransomware]: dragnet-ransomware-2023-1920 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: b690aaef-f6cd-50d3-9f3c-7f9772984fcc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
