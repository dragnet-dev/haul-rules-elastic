// Dragnet [Ransomware]: dragnet-ransomware-2023-4031 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 77c13673-0ee1-5979-bafd-45d72d6789c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
