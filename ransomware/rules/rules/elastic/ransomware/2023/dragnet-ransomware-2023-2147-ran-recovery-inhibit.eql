// Dragnet [Ransomware]: dragnet-ransomware-2023-2147 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: 5b6b5692-d3b6-59bf-a2f0-e2c5692fdca5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
