// Dragnet [Ransomware]: dragnet-ransomware-2023-1666 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 7e60c6b5-b1d5-52d7-82a1-666046cbfde2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
