// Dragnet [Ransomware]: dragnet-ransomware-2023-2261 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 35b22bd8-2f6d-59ae-aadd-91c8ca62abd6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
