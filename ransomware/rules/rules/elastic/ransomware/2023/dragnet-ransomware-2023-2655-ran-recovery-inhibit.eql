// Dragnet [Ransomware]: dragnet-ransomware-2023-2655 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 3e143110-b70e-5343-a722-1fad27b3940f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
