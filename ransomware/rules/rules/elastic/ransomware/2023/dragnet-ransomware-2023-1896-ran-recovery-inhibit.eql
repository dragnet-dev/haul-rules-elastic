// Dragnet [Ransomware]: dragnet-ransomware-2023-1896 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: 720368b3-e157-56cf-9ccc-0e570336ae0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
