// Dragnet [Ransomware]: dragnet-ransomware-2023-4793 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d76631ba-8806-53c4-aaf8-cc12f4124bbd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
