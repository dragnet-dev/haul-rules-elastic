// Dragnet [Ransomware]: dragnet-ransomware-2023-2662 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 4105bcf6-253d-5dc4-95b2-f0ba35a9c62d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
