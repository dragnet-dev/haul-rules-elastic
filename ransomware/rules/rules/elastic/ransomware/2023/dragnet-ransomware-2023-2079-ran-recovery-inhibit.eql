// Dragnet [Ransomware]: dragnet-ransomware-2023-2079 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4bf3e606-68fd-5f0e-b382-dea00f8e56d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
