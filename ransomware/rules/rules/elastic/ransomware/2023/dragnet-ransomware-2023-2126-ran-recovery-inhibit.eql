// Dragnet [Ransomware]: dragnet-ransomware-2023-2126 — Recovery Inhibition (siegedsec)
// Status: deprecated | Level: high | ID: fc584e9d-666b-54d5-9ddd-603ed5421e69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
