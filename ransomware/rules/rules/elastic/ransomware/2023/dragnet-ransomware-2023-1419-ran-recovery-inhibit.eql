// Dragnet [Ransomware]: dragnet-ransomware-2023-1419 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: f84750b2-9835-581f-af57-d015238c3286

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
