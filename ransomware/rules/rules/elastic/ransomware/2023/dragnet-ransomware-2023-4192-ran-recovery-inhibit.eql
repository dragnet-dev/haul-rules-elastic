// Dragnet [Ransomware]: dragnet-ransomware-2023-4192 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 5709c77a-01a2-5324-94e6-ce662373f053

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
