// Dragnet [Ransomware]: dragnet-ransomware-2023-3197 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c5d6ee06-f795-5651-940a-19d47c9d76c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
