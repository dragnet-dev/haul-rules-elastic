// Dragnet [Ransomware]: dragnet-ransomware-2023-2360 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 29c82100-cbec-5794-a352-661ad7fd349e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
