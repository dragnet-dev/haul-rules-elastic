// Dragnet [Ransomware]: dragnet-ransomware-2023-3978 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7f0fb2af-d7c2-5955-860d-f3d89d35e6c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
