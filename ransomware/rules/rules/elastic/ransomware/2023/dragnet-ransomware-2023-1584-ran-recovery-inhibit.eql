// Dragnet [Ransomware]: dragnet-ransomware-2023-1584 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: bf0f75a4-17f2-5c5a-ae21-6f2c404825c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
