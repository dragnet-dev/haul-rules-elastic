// Dragnet [Ransomware]: dragnet-ransomware-2023-2824 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 19e74d6d-e91e-5618-8cb6-10e1a0f2a720

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
