// Dragnet [Ransomware]: dragnet-ransomware-2023-3741 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 024fda28-649b-57d3-8453-f3d9484cce88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
