// Dragnet [Ransomware]: dragnet-ransomware-2023-3168 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 1410b56e-f5ea-57fb-ba2d-01d9ee3784f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
