// Dragnet [Ransomware]: dragnet-ransomware-2023-0889 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: c8ab1d87-5fa9-5f8f-aa9e-7ae7625b12ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
