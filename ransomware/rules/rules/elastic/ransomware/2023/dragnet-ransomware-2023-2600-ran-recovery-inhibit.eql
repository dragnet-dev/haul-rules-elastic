// Dragnet [Ransomware]: dragnet-ransomware-2023-2600 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 0c350013-9a28-507a-9db7-35c37e9a4573

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
