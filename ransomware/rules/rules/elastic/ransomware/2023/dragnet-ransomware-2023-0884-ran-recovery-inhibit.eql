// Dragnet [Ransomware]: dragnet-ransomware-2023-0884 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 4f799d6a-06fd-5cfc-8c27-0ef5250842f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
