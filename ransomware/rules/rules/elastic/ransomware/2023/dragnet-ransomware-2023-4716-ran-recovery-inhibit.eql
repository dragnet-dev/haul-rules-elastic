// Dragnet [Ransomware]: dragnet-ransomware-2023-4716 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ff0c5a0f-757a-5a27-a292-8af4c45180e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
