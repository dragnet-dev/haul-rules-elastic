// Dragnet [Ransomware]: dragnet-ransomware-2023-3885 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: bdd54e69-6d48-5131-b273-e3e14c40c24d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
