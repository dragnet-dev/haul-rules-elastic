// Dragnet [Ransomware]: dragnet-ransomware-2023-4754 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: e0201518-204a-5e48-94a1-53c188f3bd95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
