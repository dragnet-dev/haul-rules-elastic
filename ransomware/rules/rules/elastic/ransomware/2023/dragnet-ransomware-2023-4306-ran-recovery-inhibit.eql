// Dragnet [Ransomware]: dragnet-ransomware-2023-4306 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ca12eae2-9de4-56be-853e-7977767b96ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
