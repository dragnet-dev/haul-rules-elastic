// Dragnet [Ransomware]: dragnet-ransomware-2023-4647 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: d0b2ce81-1939-5a92-ad76-b3e8d5f96b4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
