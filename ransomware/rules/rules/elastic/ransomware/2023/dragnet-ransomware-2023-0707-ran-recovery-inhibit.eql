// Dragnet [Ransomware]: dragnet-ransomware-2023-0707 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: 1c72629f-9d20-5bae-814f-d8349a5e490b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
