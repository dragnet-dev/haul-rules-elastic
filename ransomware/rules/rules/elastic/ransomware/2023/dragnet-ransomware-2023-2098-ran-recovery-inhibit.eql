// Dragnet [Ransomware]: dragnet-ransomware-2023-2098 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0ebf181e-1bb0-52d5-bab6-70e0c33e776f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
