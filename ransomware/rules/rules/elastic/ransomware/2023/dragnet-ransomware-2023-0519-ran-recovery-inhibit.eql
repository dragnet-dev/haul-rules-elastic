// Dragnet [Ransomware]: dragnet-ransomware-2023-0519 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ed67dd39-07d1-5ac3-b1ad-aac86c994169

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
