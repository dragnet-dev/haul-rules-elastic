// Dragnet [Ransomware]: dragnet-ransomware-2023-3303 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 6a71b91a-1376-5be0-8444-77409688f603

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
