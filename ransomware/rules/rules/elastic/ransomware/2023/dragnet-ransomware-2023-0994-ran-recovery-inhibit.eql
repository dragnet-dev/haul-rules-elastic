// Dragnet [Ransomware]: dragnet-ransomware-2023-0994 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5bf64f59-b009-587a-8d9e-9c444360421e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
