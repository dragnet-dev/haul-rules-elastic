// Dragnet [Ransomware]: dragnet-ransomware-2023-5046 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3102ca8a-59b8-5e14-b08c-9dc30b7aba6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
