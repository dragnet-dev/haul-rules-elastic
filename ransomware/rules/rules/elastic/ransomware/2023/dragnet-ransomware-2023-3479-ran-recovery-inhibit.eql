// Dragnet [Ransomware]: dragnet-ransomware-2023-3479 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d599afa1-3104-58d1-8225-dbb6c17d1f7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
