// Dragnet [Ransomware]: dragnet-ransomware-2023-3784 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: 99023242-979d-5821-8027-f2f35415a907

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
