// Dragnet [Ransomware]: dragnet-ransomware-2023-0962 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 4d548bb0-d512-5630-984b-25f5f1abd97c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
