// Dragnet [Ransomware]: dragnet-ransomware-2023-1346 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 76e6059e-a531-5e25-8e4b-a3567a745b06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
