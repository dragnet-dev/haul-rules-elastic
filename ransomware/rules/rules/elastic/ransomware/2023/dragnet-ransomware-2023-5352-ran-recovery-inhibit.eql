// Dragnet [Ransomware]: dragnet-ransomware-2023-5352 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f567c792-b177-5161-a114-fb0846c5ab01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
