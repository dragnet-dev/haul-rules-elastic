// Dragnet [Ransomware]: dragnet-ransomware-2023-4057 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7be11e51-5d62-5fa9-9f15-92c90a8f143f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
