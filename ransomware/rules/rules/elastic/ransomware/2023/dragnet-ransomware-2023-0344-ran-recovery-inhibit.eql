// Dragnet [Ransomware]: dragnet-ransomware-2023-0344 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 5588b542-52e0-5f90-b254-0863060d42a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
