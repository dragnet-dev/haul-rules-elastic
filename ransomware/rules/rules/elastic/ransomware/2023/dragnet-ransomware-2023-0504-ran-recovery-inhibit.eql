// Dragnet [Ransomware]: dragnet-ransomware-2023-0504 — Recovery Inhibition (cyclops)
// Status: deprecated | Level: high | ID: 862e196b-ee35-5c74-8b18-b11e66866c11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
