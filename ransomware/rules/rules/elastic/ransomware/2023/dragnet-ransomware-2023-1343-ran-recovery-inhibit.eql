// Dragnet [Ransomware]: dragnet-ransomware-2023-1343 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: a87f46c9-f475-5fad-9655-fc24fd2437e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
