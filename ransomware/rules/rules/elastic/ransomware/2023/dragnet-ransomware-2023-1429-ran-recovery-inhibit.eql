// Dragnet [Ransomware]: dragnet-ransomware-2023-1429 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: 1ccba186-ab39-50c8-ba86-ea554ff4dc12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
