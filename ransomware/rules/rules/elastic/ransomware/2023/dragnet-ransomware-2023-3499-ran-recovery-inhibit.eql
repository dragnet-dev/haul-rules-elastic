// Dragnet [Ransomware]: dragnet-ransomware-2023-3499 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 77526779-7cf6-5dad-9440-290c2172298e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
