// Dragnet [Ransomware]: dragnet-ransomware-2023-4484 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 6e7fa978-aedd-5c60-94b9-913b497a30f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
