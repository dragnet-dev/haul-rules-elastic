// Dragnet [Ransomware]: dragnet-ransomware-2023-1151 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 74fba8c4-8b78-5c78-8fa7-7f042afbc700

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
