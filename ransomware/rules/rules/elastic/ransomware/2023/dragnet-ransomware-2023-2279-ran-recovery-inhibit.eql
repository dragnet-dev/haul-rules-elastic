// Dragnet [Ransomware]: dragnet-ransomware-2023-2279 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 8dcecd2b-78c8-507d-af62-cd2af314ba5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
