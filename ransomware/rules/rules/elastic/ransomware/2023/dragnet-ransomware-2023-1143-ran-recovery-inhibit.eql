// Dragnet [Ransomware]: dragnet-ransomware-2023-1143 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: e5773a7a-15b4-51a8-bfec-0c59e1b3c9b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
