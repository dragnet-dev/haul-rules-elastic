// Dragnet [Ransomware]: dragnet-ransomware-2023-4513 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: d0419f46-abdc-5256-8ce4-8311245b3cbd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
