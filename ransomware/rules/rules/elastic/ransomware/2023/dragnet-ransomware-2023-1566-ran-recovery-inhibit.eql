// Dragnet [Ransomware]: dragnet-ransomware-2023-1566 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7e87530d-aae1-52c4-ad82-e4eb7a3853a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
