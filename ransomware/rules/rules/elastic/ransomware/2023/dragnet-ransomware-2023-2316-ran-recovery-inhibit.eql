// Dragnet [Ransomware]: dragnet-ransomware-2023-2316 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 7fce9242-8b6f-5fc8-ae9b-7ea372a4ee96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
