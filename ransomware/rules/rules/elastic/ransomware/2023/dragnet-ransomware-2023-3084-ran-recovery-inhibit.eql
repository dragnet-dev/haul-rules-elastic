// Dragnet [Ransomware]: dragnet-ransomware-2023-3084 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: d0305cca-4835-5d19-94cf-364ef953dc9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
