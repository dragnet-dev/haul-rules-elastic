// Dragnet [Ransomware]: dragnet-ransomware-2023-0614 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 7ae9b74e-47c6-548d-a0a4-2c298fd0cff5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
