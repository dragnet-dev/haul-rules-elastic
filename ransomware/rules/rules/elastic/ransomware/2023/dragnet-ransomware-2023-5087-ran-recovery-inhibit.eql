// Dragnet [Ransomware]: dragnet-ransomware-2023-5087 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 418d64b9-1527-513f-95ac-8532996c33a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
