// Dragnet [Ransomware]: dragnet-ransomware-2023-4479 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: e785528b-2193-58b5-8f81-4c8cdceb617f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
