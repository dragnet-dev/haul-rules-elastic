// Dragnet [Ransomware]: dragnet-ransomware-2023-2303 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 50f58ddc-c8d7-550d-938d-ca37e4e1b446

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
