// Dragnet [Ransomware]: dragnet-ransomware-2023-2466 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: fb9dc21b-2146-517d-b55e-1d0725cc4251

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
