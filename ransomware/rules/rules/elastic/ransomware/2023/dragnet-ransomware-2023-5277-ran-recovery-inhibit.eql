// Dragnet [Ransomware]: dragnet-ransomware-2023-5277 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 15d58fb7-ceac-5b0b-9649-abac12cc9341

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
