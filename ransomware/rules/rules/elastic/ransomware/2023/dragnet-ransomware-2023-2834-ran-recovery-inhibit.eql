// Dragnet [Ransomware]: dragnet-ransomware-2023-2834 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: d5065325-ad42-5925-a509-cb87b8466136

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
