// Dragnet [Ransomware]: dragnet-ransomware-2023-3161 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e2b63a7a-34c5-5710-8f56-03f29b384474

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
