// Dragnet [Ransomware]: dragnet-ransomware-2023-2415 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 93f0580b-78d6-5921-be9e-a07bb5290b97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
