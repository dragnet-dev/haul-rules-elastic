// Dragnet [Ransomware]: dragnet-ransomware-2023-4067 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 179b67d8-7f59-5565-afb4-757825553511

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
