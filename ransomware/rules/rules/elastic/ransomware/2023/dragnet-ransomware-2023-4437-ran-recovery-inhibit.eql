// Dragnet [Ransomware]: dragnet-ransomware-2023-4437 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 35e0cdd3-d03b-5bea-8ca4-f07e5f703116

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
