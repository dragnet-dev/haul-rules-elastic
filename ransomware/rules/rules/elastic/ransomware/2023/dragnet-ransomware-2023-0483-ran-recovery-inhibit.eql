// Dragnet [Ransomware]: dragnet-ransomware-2023-0483 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 1353aa1e-ac7c-5bdc-8d18-4aeb3e27319a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
