// Dragnet [Ransomware]: dragnet-ransomware-2023-2024 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: a70a3b6f-f6ef-5c4b-894b-1d36f9588eac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
