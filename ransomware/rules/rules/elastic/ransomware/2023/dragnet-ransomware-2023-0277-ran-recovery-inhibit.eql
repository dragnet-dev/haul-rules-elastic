// Dragnet [Ransomware]: dragnet-ransomware-2023-0277 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3d334d5a-ea7f-5e5a-b765-50272d3afefd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
