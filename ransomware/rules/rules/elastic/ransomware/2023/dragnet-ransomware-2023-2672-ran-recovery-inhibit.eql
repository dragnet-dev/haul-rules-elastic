// Dragnet [Ransomware]: dragnet-ransomware-2023-2672 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 17159d0c-17bc-5737-9fb7-06d5aca1b8e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
