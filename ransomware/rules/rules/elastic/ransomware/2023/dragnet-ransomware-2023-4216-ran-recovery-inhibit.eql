// Dragnet [Ransomware]: dragnet-ransomware-2023-4216 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 73f9f8d6-f39c-5bf7-9560-a0a4fb038561

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
