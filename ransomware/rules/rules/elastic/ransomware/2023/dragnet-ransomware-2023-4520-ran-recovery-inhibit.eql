// Dragnet [Ransomware]: dragnet-ransomware-2023-4520 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 4c982061-9879-5707-9830-a7a05f43b0ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
