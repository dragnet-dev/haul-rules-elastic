// Dragnet [Ransomware]: dragnet-ransomware-2023-0353 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8a20c2d3-a548-5831-8534-97c9175ef227

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
