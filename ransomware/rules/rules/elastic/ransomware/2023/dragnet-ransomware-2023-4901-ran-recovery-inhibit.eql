// Dragnet [Ransomware]: dragnet-ransomware-2023-4901 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 38b70e55-5ab0-5671-9570-909440d19e76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
