// Dragnet [Ransomware]: dragnet-ransomware-2023-4581 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 4d9f09b1-90f2-58c0-8f1a-406ebf9445cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
