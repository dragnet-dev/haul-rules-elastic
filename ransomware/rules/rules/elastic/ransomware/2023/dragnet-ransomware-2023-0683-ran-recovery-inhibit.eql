// Dragnet [Ransomware]: dragnet-ransomware-2023-0683 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: ba81dccb-590a-52bc-91bc-b84e6be67637

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
