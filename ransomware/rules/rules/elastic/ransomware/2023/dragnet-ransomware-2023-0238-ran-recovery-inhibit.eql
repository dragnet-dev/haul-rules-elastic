// Dragnet [Ransomware]: dragnet-ransomware-2023-0238 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: 374ab5c4-a182-588c-88c2-acb6d2604484

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
