// Dragnet [Ransomware]: dragnet-ransomware-2023-2292 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e9e4e157-a8da-5e29-9afe-88f869cdd9e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
