// Dragnet [Ransomware]: dragnet-ransomware-2023-2734 — Recovery Inhibition (mallox)
// Status: experimental | Level: high | ID: c2253074-038e-56b2-b7cc-c032f3ca3e75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
