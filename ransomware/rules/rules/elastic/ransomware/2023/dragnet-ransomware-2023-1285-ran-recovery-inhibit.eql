// Dragnet [Ransomware]: dragnet-ransomware-2023-1285 — Recovery Inhibition (cryptnet)
// Status: experimental | Level: high | ID: f3a948ed-f9e7-5ef5-b34e-c2e9d4539a31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
