// Dragnet [Ransomware]: dragnet-ransomware-2023-0919 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: b9996ca2-ea10-548c-8bcb-c82cc5043d6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
