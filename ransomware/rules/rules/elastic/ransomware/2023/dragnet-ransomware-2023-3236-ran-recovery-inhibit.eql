// Dragnet [Ransomware]: dragnet-ransomware-2023-3236 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: 3d5f99df-b48c-5d60-8880-c755eb3fee6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
