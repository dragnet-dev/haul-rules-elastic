// Dragnet [Ransomware]: dragnet-ransomware-2023-0578 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: 040a8244-e104-5b35-a4c5-59a6f55d9e5e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
