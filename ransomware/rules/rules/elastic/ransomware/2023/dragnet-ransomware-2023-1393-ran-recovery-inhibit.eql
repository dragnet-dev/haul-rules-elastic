// Dragnet [Ransomware]: dragnet-ransomware-2023-1393 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 75def205-54c4-5280-b709-f9de313e1fdf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
