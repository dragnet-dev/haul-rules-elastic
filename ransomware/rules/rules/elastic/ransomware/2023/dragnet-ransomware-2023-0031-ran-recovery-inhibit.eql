// Dragnet [Ransomware]: dragnet-ransomware-2023-0031 — Recovery Inhibition (werewolves)
// Status: experimental | Level: high | ID: 3b9a417b-3d89-5c7b-89e8-2aaf610df9b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
