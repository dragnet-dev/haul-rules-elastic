// Dragnet [Ransomware]: dragnet-ransomware-2023-3756 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 75363a11-d82c-5179-853a-de8c60eae7d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
