// Dragnet [Ransomware]: dragnet-ransomware-2023-1115 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 387a0578-40d6-51c0-bdfa-d9daa0b2669e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
