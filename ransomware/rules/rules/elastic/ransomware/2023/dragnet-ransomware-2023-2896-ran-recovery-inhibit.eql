// Dragnet [Ransomware]: dragnet-ransomware-2023-2896 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 13d45a33-405b-5cfe-9048-804f677dda74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
