// Dragnet [Ransomware]: dragnet-ransomware-2023-1997 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 996d3841-1f1d-5fe3-a4be-3424d10b20fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
