// Dragnet [Ransomware]: dragnet-ransomware-2023-3641 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: bd546e99-298d-56da-9d88-4f7957df262b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
