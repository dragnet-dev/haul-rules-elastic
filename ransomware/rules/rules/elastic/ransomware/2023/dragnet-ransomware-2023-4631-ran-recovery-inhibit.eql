// Dragnet [Ransomware]: dragnet-ransomware-2023-4631 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 9581dfec-d4c7-578e-bb7d-8e7ae5e91cec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
