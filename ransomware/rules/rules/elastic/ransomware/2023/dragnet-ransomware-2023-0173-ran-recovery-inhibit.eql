// Dragnet [Ransomware]: dragnet-ransomware-2023-0173 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: ebc88c7b-1413-5290-95b7-bf9d8d932aa4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
