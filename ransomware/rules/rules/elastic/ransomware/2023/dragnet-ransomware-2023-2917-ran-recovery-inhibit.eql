// Dragnet [Ransomware]: dragnet-ransomware-2023-2917 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: cbc483eb-159b-5ca5-afad-a51ae242acc3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
