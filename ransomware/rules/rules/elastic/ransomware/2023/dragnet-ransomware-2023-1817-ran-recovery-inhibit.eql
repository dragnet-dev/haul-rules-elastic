// Dragnet [Ransomware]: dragnet-ransomware-2023-1817 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: af10d1cf-9a93-5598-9d96-0ea25fd7a49c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
