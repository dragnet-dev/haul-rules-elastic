// Dragnet [Ransomware]: dragnet-ransomware-2023-4890 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 8d63afe3-7088-5cf1-aa1b-2443d199edfc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
