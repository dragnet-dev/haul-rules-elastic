// Dragnet [Ransomware]: dragnet-ransomware-2023-4481 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: b096eaad-b0f0-5a27-b9c5-9022e569c41b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
