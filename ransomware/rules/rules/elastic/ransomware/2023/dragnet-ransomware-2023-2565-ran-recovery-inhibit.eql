// Dragnet [Ransomware]: dragnet-ransomware-2023-2565 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 0cf66699-d6b0-5866-98a3-dddb94ec070c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
