// Dragnet [Ransomware]: dragnet-ransomware-2023-2667 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: e8fbc0e3-1ddc-56d3-90d4-a0af7d9c4458

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
