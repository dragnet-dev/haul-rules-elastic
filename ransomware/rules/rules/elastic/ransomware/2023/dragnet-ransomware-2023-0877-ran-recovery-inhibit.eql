// Dragnet [Ransomware]: dragnet-ransomware-2023-0877 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0c3e5e57-686f-5894-94de-0e5b1a16b343

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
