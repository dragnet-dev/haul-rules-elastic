// Dragnet [Ransomware]: dragnet-ransomware-2023-2874 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: cfd23144-f191-5e39-9d15-8d4750a85ea4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
