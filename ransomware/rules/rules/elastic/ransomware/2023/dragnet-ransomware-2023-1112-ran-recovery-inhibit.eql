// Dragnet [Ransomware]: dragnet-ransomware-2023-1112 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: df9e336c-0682-569b-91cd-0a92b195cf5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
