// Dragnet [Ransomware]: dragnet-ransomware-2023-1394 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 93f73099-2228-5437-98b5-a503dbd9296b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
