// Dragnet [Ransomware]: dragnet-ransomware-2023-1284 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 96e1c0ab-d5bb-5987-bafe-c96d29dd2d43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
