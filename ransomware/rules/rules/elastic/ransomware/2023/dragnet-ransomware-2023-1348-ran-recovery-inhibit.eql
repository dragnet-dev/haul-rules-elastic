// Dragnet [Ransomware]: dragnet-ransomware-2023-1348 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c2f3f792-ea36-5756-91ea-308d117d19b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
