// Dragnet [Ransomware]: dragnet-ransomware-2023-0297 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 27dcb9d2-da97-550c-8fea-9cd7aab3c7cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
