// Dragnet [Ransomware]: dragnet-ransomware-2023-1396 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: becf512b-8b1a-537c-b46a-a4ccf87773b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
