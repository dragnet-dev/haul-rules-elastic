// Dragnet [Ransomware]: dragnet-ransomware-2023-1747 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 459bdd74-792c-562a-b1d0-3c08500a7594

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
