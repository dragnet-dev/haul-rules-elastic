// Dragnet [Ransomware]: dragnet-ransomware-2023-0009 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 833f1bd2-964b-5a63-849e-2e077299f5e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
