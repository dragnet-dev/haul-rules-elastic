// Dragnet [Ransomware]: dragnet-ransomware-2023-4081 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1f9ecf33-2955-553a-84c6-58fc475358d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
