// Dragnet [Ransomware]: dragnet-ransomware-2023-3715 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 3613a8f7-a068-54fc-b8fb-d5f01610498b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
