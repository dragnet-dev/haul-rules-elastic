// Dragnet [Ransomware]: dragnet-ransomware-2023-4600 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 5fd65aff-99fd-5f15-abe4-96e24c8e0636

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
