// Dragnet [Ransomware]: dragnet-ransomware-2023-1510 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f0da1cba-cba3-5278-a50c-e9df8bd9986d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
