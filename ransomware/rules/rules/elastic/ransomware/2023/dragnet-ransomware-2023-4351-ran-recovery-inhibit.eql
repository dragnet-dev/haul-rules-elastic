// Dragnet [Ransomware]: dragnet-ransomware-2023-4351 — Recovery Inhibition (nokoyawa)
// Status: experimental | Level: high | ID: 22a708e1-8951-5640-981b-40cd47cc4558

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
