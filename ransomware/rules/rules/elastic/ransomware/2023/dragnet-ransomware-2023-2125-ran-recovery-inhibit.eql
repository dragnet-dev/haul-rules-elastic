// Dragnet [Ransomware]: dragnet-ransomware-2023-2125 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c0b26a51-6c30-556e-9620-dccf6a7535f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
