// Dragnet [Ransomware]: dragnet-ransomware-2023-2163 — Recovery Inhibition (ElDorado)
// Status: experimental | Level: high | ID: afc44601-c8ac-59b3-bc11-f6d2fe139585

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
