// Dragnet [Ransomware]: dragnet-ransomware-2023-4130 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e579f0b1-e464-5b68-8fe0-e3af78135e5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
