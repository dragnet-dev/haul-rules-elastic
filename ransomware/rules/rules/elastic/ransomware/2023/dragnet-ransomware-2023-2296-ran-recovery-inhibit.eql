// Dragnet [Ransomware]: dragnet-ransomware-2023-2296 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: bf029a15-9f10-549f-8ed5-d046ddd4b071

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
