// Dragnet [Ransomware]: dragnet-ransomware-2023-4666 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 038ed934-4a5e-543d-9720-3c748f16ff65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
