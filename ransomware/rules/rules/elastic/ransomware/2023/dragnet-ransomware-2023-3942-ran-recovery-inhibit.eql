// Dragnet [Ransomware]: dragnet-ransomware-2023-3942 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: fd623e34-11cf-51fb-81c3-47cfec1e74d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
