// Dragnet [Ransomware]: dragnet-ransomware-2023-1414 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 7d73f2d4-c5f4-5893-bfb0-e1dd7bef3834

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
