// Dragnet [Ransomware]: dragnet-ransomware-2023-3877 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9386e875-add8-5f2c-a780-f517e30299bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
