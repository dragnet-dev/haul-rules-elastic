// Dragnet [Ransomware]: dragnet-ransomware-2023-0127 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 672fe293-3ec1-5b6c-8123-11e8c033f371

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
