// Dragnet [Ransomware]: dragnet-ransomware-2023-0799 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8949704e-372b-524b-91cb-e2f57e8950d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
