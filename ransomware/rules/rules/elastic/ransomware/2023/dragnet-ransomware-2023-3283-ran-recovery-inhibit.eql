// Dragnet [Ransomware]: dragnet-ransomware-2023-3283 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: cde844ce-1031-5ac2-81b3-2f3edec85b52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
