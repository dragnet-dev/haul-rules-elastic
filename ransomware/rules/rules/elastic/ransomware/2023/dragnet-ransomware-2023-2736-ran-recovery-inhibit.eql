// Dragnet [Ransomware]: dragnet-ransomware-2023-2736 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 09702af2-3e94-53b6-bcc9-f3fc292c15e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
