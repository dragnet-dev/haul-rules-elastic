// Dragnet [Ransomware]: dragnet-ransomware-2023-2559 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 550f0bd3-4cf2-5350-95b3-ed4a0076b73d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
