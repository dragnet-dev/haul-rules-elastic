// Dragnet [Ransomware]: dragnet-ransomware-2023-1035 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c7d41ec6-9695-5544-8d35-8e7ee46c04bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
