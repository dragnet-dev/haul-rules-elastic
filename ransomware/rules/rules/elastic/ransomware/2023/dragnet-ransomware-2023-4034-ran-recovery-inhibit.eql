// Dragnet [Ransomware]: dragnet-ransomware-2023-4034 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: d4e8afad-0fd6-5998-b49b-ddec550b07a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
