// Dragnet [Ransomware]: dragnet-ransomware-2023-3392 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a27e5ecd-fab4-56bf-b04f-e9e5d28464c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
