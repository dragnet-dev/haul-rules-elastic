// Dragnet [Ransomware]: dragnet-ransomware-2023-0869 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: bb7f371b-5f58-535d-9c2a-4f2c13275438

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
