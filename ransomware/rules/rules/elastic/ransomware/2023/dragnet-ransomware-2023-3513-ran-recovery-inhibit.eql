// Dragnet [Ransomware]: dragnet-ransomware-2023-3513 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: f4433572-6aba-5b58-a21b-cb003a852f67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
