// Dragnet [Ransomware]: dragnet-ransomware-2023-1319 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: d6109894-d69a-5c67-8b6f-fe3eeb721e0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
