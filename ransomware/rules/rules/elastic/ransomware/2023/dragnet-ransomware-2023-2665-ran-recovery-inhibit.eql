// Dragnet [Ransomware]: dragnet-ransomware-2023-2665 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f174b5ec-4029-534d-abf2-f547079c4fd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
