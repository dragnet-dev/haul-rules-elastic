// Dragnet [Ransomware]: dragnet-ransomware-2023-3588 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 47bb5cc4-c3d5-5b51-bbd6-a45cc649a3da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
