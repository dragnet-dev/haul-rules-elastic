// Dragnet [Ransomware]: dragnet-ransomware-2023-5226 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 9e103660-968e-593c-903a-1677837ebddb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
