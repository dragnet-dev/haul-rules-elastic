// Dragnet [Ransomware]: dragnet-ransomware-2023-3243 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b523536a-694f-508e-9c76-b10d7c9fbd1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
