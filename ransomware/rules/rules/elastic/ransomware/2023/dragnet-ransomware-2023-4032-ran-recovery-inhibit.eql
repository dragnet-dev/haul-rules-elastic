// Dragnet [Ransomware]: dragnet-ransomware-2023-4032 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: aaead8ff-c089-51bc-9513-5864d48c73c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
