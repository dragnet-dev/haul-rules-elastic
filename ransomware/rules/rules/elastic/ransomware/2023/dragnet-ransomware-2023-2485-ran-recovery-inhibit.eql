// Dragnet [Ransomware]: dragnet-ransomware-2023-2485 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: 675de163-c582-5609-b3d5-5f7fbcf209df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
