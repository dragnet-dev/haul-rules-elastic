// Dragnet [Ransomware]: dragnet-ransomware-2023-1899 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: d77ae01e-b764-5e8a-b631-973ccbc7f0c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
