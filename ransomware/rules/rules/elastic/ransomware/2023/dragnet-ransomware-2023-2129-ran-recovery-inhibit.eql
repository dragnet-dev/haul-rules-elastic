// Dragnet [Ransomware]: dragnet-ransomware-2023-2129 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: f74dd127-4412-568b-9552-0311ce295a26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
