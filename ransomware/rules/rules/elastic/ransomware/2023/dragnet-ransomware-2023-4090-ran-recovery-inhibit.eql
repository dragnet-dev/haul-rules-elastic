// Dragnet [Ransomware]: dragnet-ransomware-2023-4090 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 4a2a79f6-bc2d-5b4b-a873-fafb6f8adc02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
