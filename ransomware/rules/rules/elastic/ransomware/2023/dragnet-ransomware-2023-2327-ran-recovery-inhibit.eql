// Dragnet [Ransomware]: dragnet-ransomware-2023-2327 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 18132829-87ea-59bc-96e9-b26c11a3a83f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
