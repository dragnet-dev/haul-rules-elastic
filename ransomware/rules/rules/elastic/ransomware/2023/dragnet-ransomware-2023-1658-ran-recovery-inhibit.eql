// Dragnet [Ransomware]: dragnet-ransomware-2023-1658 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: e66bbe4e-67f4-5cd7-8bf8-87bf0cb102d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
