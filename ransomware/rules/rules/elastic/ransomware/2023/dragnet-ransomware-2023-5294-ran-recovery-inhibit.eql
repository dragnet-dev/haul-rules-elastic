// Dragnet [Ransomware]: dragnet-ransomware-2023-5294 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: f6fcaf0a-bada-5e4a-b548-a18ee3d0f180

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
