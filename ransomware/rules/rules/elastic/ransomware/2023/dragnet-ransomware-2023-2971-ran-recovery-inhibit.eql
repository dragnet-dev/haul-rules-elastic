// Dragnet [Ransomware]: dragnet-ransomware-2023-2971 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 6c4d8cb2-3905-599a-b179-62c983015a1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
