// Dragnet [Ransomware]: dragnet-ransomware-2023-1228 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3d241535-1d4e-572b-9c56-0254d105fd3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
