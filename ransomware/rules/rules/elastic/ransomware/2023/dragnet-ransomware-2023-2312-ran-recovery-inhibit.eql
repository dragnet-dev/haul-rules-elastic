// Dragnet [Ransomware]: dragnet-ransomware-2023-2312 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 060e636c-7109-5ff7-9dab-b973d671d3c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
