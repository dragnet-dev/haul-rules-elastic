// Dragnet [Ransomware]: dragnet-ransomware-2023-0673 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b7232502-0e71-5a32-9377-ad7998f4ada0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
