// Dragnet [Ransomware]: dragnet-ransomware-2023-4873 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 76ea0ba5-c9e0-51c0-a28c-f881b5472a96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
