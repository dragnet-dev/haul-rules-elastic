// Dragnet [Ransomware]: dragnet-ransomware-2023-0065 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: c6a22765-6bbe-5bdd-b115-3ec5bfc1c4e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
