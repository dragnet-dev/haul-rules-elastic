// Dragnet [Ransomware]: dragnet-ransomware-2023-3411 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 12b3e5cc-4c63-5880-89d4-f2dc62ffc496

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
