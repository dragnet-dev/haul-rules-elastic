// Dragnet [Ransomware]: dragnet-ransomware-2023-3064 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: baea7f19-d12e-5852-9b29-96c330e15aff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
