// Dragnet [Ransomware]: dragnet-ransomware-2023-2831 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 51bbd930-6340-5fec-bb8d-4f32f55b5ca7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
