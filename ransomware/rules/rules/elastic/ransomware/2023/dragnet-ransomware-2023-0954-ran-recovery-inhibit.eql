// Dragnet [Ransomware]: dragnet-ransomware-2023-0954 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: b07c3f31-b34f-5365-83db-43ebd9c412ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
