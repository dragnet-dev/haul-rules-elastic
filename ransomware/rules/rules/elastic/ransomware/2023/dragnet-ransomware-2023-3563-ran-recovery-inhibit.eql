// Dragnet [Ransomware]: dragnet-ransomware-2023-3563 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 3a2603ab-6aeb-5891-8f14-6c58610ad660

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
