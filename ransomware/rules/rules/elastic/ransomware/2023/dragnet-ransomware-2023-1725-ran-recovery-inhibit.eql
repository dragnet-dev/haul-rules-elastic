// Dragnet [Ransomware]: dragnet-ransomware-2023-1725 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 9c128557-0d2a-55da-ae29-0dda7b52b497

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
