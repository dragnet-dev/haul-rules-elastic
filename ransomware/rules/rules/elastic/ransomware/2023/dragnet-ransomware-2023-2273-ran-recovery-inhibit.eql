// Dragnet [Ransomware]: dragnet-ransomware-2023-2273 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: a159b445-f45f-57d5-b2b4-e2a5a24b5172

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
