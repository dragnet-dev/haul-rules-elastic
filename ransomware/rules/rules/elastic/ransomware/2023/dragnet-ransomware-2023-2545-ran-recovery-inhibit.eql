// Dragnet [Ransomware]: dragnet-ransomware-2023-2545 — Recovery Inhibition (ransomed)
// Status: experimental | Level: high | ID: 70b21bc6-09d0-5a38-984c-ca44faa11c3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
