// Dragnet [Ransomware]: dragnet-ransomware-2023-3729 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 874fbba3-3674-5f22-b476-708f9e678a96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
