// Dragnet [Ransomware]: dragnet-ransomware-2023-0195 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 2170f2ff-df22-59a8-9df1-305a6a1bc20e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
