// Dragnet [Ransomware]: dragnet-ransomware-2023-5377 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 6a0bb8b7-fe5c-5773-9636-bc927b37a9e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
