// Dragnet [Ransomware]: dragnet-ransomware-2023-2379 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 790c1576-c7fa-5ffe-a56f-862c56ca300f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
