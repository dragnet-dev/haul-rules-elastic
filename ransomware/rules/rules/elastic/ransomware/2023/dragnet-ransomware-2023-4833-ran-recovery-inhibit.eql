// Dragnet [Ransomware]: dragnet-ransomware-2023-4833 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 7f63513f-0395-53d6-abfd-792c08d812f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
