// Dragnet [Ransomware]: dragnet-ransomware-2023-0239 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a91df014-1430-57ab-b594-cef31b26aa64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
