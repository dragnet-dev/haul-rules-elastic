// Dragnet [Ransomware]: dragnet-ransomware-2023-0439 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cb947690-e39e-5fc3-a161-b466b469533e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
