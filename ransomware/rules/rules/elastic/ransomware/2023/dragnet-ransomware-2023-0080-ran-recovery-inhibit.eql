// Dragnet [Ransomware]: dragnet-ransomware-2023-0080 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: e6541309-825b-5508-8f83-8c65c778af88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
