// Dragnet [Ransomware]: dragnet-ransomware-2023-3617 — Recovery Inhibition (toufan)
// Status: deprecated | Level: high | ID: 9ea8ec6b-8a62-5f7b-94a4-8ff0b6d8ce25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
