// Dragnet [Ransomware]: dragnet-ransomware-2023-2765 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 9dc099ca-d97c-5141-9ecf-a935ac3bd30e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
