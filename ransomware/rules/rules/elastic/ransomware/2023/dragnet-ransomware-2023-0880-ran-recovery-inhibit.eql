// Dragnet [Ransomware]: dragnet-ransomware-2023-0880 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ba294a28-2191-58e4-8118-792d677a1a83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
