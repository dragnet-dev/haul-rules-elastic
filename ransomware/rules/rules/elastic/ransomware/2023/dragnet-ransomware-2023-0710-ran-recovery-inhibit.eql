// Dragnet [Ransomware]: dragnet-ransomware-2023-0710 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: b8e009d0-5d71-5967-a48b-51321642282e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
