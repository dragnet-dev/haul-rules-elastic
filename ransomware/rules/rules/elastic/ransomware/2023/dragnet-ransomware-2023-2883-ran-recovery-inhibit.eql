// Dragnet [Ransomware]: dragnet-ransomware-2023-2883 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: d452cf7a-7e03-51cd-b6af-54bd7e2de4e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
