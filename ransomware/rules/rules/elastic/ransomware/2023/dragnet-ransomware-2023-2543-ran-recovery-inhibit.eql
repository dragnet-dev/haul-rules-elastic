// Dragnet [Ransomware]: dragnet-ransomware-2023-2543 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7a90e92c-422d-54f3-bac9-0eef7002272e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
