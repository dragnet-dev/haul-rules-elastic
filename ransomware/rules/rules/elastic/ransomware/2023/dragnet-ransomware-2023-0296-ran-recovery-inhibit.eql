// Dragnet [Ransomware]: dragnet-ransomware-2023-0296 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: e848f983-f32c-59f2-8b65-7ffad39026ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
