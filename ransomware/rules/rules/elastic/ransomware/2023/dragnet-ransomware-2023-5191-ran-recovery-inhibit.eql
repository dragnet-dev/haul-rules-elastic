// Dragnet [Ransomware]: dragnet-ransomware-2023-5191 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: a7359160-4f71-5780-90d3-2086e1079fab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
