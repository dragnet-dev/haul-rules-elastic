// Dragnet [Ransomware]: dragnet-ransomware-2023-2499 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 14922712-2a25-538e-8e21-0c44bb963b6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
