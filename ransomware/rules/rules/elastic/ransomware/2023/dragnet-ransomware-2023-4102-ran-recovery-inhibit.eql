// Dragnet [Ransomware]: dragnet-ransomware-2023-4102 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2f35599d-aa17-520d-b931-83559156b758

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
