// Dragnet [Ransomware]: dragnet-ransomware-2023-4103 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 07c63e22-15f7-521b-a762-2c480e4ddf42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
