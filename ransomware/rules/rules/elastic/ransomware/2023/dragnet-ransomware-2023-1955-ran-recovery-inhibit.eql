// Dragnet [Ransomware]: dragnet-ransomware-2023-1955 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: a8c7f641-13b6-59cc-9b14-a585537d3227

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
