// Dragnet [Ransomware]: dragnet-ransomware-2023-2181 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ef0b94ea-e849-53f6-8d21-12b902fbf438

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
