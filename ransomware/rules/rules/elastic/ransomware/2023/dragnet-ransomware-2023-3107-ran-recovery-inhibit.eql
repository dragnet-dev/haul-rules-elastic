// Dragnet [Ransomware]: dragnet-ransomware-2023-3107 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: c9092cba-c515-54b8-959e-0ecf3d348e20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
