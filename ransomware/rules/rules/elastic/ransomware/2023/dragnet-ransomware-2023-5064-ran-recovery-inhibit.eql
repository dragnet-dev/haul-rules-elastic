// Dragnet [Ransomware]: dragnet-ransomware-2023-5064 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 40247e6c-2502-543c-816b-735905f18a7c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
