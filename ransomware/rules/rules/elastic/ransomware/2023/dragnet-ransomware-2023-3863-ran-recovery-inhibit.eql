// Dragnet [Ransomware]: dragnet-ransomware-2023-3863 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: c1395ab2-37b3-519c-ace7-adb728914997

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
