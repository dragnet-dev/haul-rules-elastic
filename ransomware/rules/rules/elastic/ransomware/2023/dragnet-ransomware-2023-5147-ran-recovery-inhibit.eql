// Dragnet [Ransomware]: dragnet-ransomware-2023-5147 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 94edd3e7-1448-5921-b288-5bc87cdf7d73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
