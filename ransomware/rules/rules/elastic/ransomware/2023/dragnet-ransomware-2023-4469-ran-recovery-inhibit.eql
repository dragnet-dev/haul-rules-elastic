// Dragnet [Ransomware]: dragnet-ransomware-2023-4469 — Recovery Inhibition (trigona)
// Status: deprecated | Level: high | ID: 0f454f41-edc6-5aa0-9ddb-0a3ef5e876b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
