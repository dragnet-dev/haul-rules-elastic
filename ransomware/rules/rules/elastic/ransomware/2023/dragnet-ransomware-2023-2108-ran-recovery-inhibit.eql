// Dragnet [Ransomware]: dragnet-ransomware-2023-2108 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: cdf4f30f-4c72-54a5-a88a-0d022f4cead5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
