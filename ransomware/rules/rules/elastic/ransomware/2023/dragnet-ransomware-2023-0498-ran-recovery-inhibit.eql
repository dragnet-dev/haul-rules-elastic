// Dragnet [Ransomware]: dragnet-ransomware-2023-0498 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 55587b8b-c7f7-5f6d-a43b-f6f995e3c96e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
