// Dragnet [Ransomware]: dragnet-ransomware-2023-2365 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 770cf294-ea73-5782-ad50-15aab3a89531

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
