// Dragnet [Ransomware]: dragnet-ransomware-2023-1489 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 313767f8-3431-58f2-9928-4f8ae4c04535

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
