// Dragnet [Ransomware]: dragnet-ransomware-2023-1170 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: cf0bb028-9bb5-524d-a43e-2693c9704fbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
