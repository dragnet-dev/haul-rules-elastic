// Dragnet [Ransomware]: dragnet-ransomware-2023-1732 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 33295823-00c9-5f8e-a9a2-486704a7e6ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
