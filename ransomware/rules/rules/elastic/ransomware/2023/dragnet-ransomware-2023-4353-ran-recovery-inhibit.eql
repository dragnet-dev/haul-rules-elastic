// Dragnet [Ransomware]: dragnet-ransomware-2023-4353 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3edb03d3-4bda-5143-b6cc-c53a285ac3df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
