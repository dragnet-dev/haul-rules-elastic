// Dragnet [Ransomware]: dragnet-ransomware-2023-4442 — Recovery Inhibition (unsafe)
// Status: deprecated | Level: high | ID: bb8efefc-6dbe-5bfa-a4b1-b7b396a07f31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
