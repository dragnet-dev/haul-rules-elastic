// Dragnet [Ransomware]: dragnet-ransomware-2023-0328 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: 2b7fcec0-b2a6-5fcd-b2ca-dae3b4dd46db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
