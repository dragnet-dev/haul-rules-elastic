// Dragnet [Ransomware]: dragnet-ransomware-2023-2061 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: bf371258-1002-5a9d-94ba-61dbdc5a9777

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
