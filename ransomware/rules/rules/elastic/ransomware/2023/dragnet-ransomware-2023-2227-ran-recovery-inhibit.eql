// Dragnet [Ransomware]: dragnet-ransomware-2023-2227 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8560a6b1-e6d7-548d-9815-54bab55bfdce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
