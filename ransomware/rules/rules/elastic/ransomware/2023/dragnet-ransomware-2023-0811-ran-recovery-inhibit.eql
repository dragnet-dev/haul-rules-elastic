// Dragnet [Ransomware]: dragnet-ransomware-2023-0811 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 7eccea48-4d6d-50be-a849-8713ea753a03

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
