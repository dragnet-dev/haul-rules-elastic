// Dragnet [Ransomware]: dragnet-ransomware-2023-3223 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: f2d0e2c0-799a-58c8-93ff-157617332a67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
