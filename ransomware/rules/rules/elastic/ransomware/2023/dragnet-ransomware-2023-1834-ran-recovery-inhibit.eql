// Dragnet [Ransomware]: dragnet-ransomware-2023-1834 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4934acbb-212e-58aa-a80e-f135ec844806

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
