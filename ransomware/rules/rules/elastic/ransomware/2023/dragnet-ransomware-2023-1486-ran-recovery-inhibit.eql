// Dragnet [Ransomware]: dragnet-ransomware-2023-1486 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b9ad3f0b-65b5-5ffd-bde0-20352207637b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
