// Dragnet [Ransomware]: dragnet-ransomware-2023-1668 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 511741cd-20c7-5bd4-a1c6-297f7ede1f90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
