// Dragnet [Ransomware]: dragnet-ransomware-2023-1657 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 4b076807-7376-5350-a7bf-91fb3cdafcae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
