// Dragnet [Ransomware]: dragnet-ransomware-2023-0586 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 805d60fb-9695-5104-a9ca-f652ec7310df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
