// Dragnet [Ransomware]: dragnet-ransomware-2023-1012 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: e553e5bf-06d0-5f11-a6a2-91966160447b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
