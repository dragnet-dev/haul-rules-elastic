// Dragnet [Ransomware]: dragnet-ransomware-2023-4317 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0258a551-31e7-5962-a605-199009d2aa7c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
