// Dragnet [Ransomware]: dragnet-ransomware-2023-1173 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: bad6452d-4dd0-50ab-825c-be4343101ad6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
