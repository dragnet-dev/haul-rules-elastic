// Dragnet [Ransomware]: dragnet-ransomware-2023-1508 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 065901ee-2c75-5654-a21b-da6c190535fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
