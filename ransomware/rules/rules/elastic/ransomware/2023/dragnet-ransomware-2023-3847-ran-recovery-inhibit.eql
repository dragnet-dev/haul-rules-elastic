// Dragnet [Ransomware]: dragnet-ransomware-2023-3847 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 4cc57924-c58e-551e-af59-054474121680

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
