// Dragnet [Ransomware]: dragnet-ransomware-2023-2077 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: a765ad85-6ebb-5079-9a6f-626486ae6aad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
