// Dragnet [Ransomware]: dragnet-ransomware-2023-1930 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: e9112d99-df91-5804-bac0-68b27c6b90e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
