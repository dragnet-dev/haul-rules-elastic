// Dragnet [Ransomware]: dragnet-ransomware-2023-0810 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: add21aa9-8ef4-543d-ba62-423fe1f8e145

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
