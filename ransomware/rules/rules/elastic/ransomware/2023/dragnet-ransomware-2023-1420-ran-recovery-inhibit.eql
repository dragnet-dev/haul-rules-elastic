// Dragnet [Ransomware]: dragnet-ransomware-2023-1420 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: 318e9ea6-5ef3-56ba-ac63-bf29e644eab7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
