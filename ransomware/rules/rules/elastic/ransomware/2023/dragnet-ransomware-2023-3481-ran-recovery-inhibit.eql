// Dragnet [Ransomware]: dragnet-ransomware-2023-3481 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 794270e3-820b-572f-b300-650fc819a1fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
