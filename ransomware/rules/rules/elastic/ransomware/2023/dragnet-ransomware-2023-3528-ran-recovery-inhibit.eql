// Dragnet [Ransomware]: dragnet-ransomware-2023-3528 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: f8dae197-9380-5f67-9a51-67bc1ef05131

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
