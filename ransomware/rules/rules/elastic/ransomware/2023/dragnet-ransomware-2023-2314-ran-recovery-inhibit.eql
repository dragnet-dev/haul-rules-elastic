// Dragnet [Ransomware]: dragnet-ransomware-2023-2314 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 6cd2e009-0506-5f76-ab8d-80cddcfeeb51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
