// Dragnet [Ransomware]: dragnet-ransomware-2023-1987 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a72e2dde-0b7c-5d28-8e51-68b17fa89e9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
