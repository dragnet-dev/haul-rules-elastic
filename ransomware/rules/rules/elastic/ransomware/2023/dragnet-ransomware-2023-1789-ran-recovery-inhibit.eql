// Dragnet [Ransomware]: dragnet-ransomware-2023-1789 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: d261d679-bd7f-560e-9b01-67e66856fc6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
