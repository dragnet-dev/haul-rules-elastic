// Dragnet [Ransomware]: dragnet-ransomware-2023-4169 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: f191ceff-ec18-53a1-b344-2882b70924c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
