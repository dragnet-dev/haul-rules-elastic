// Dragnet [Ransomware]: dragnet-ransomware-2023-0053 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 75662e87-ecec-5c37-9406-261ac2d7dab9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
