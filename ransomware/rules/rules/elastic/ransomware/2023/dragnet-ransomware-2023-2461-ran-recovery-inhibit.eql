// Dragnet [Ransomware]: dragnet-ransomware-2023-2461 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: d76cca63-53fd-52dc-9b02-60a0da91c7d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
