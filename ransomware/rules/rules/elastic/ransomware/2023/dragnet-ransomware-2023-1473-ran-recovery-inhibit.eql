// Dragnet [Ransomware]: dragnet-ransomware-2023-1473 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f91b2c8c-a739-55d1-86e6-2d634ad35049

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
