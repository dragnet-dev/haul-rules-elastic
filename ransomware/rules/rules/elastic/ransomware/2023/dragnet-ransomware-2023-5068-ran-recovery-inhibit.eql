// Dragnet [Ransomware]: dragnet-ransomware-2023-5068 — Recovery Inhibition (noescape)
// Status: experimental | Level: high | ID: 9c585084-62f5-5f62-a7b6-8539b87be885

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
