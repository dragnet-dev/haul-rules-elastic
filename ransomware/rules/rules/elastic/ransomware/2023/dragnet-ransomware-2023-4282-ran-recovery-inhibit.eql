// Dragnet [Ransomware]: dragnet-ransomware-2023-4282 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: fbd97cff-4e8b-5652-82a8-074b0b707dec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
