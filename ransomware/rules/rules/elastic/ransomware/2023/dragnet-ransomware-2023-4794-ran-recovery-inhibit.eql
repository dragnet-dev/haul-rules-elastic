// Dragnet [Ransomware]: dragnet-ransomware-2023-4794 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 9b4da08b-7123-575a-95ee-6906a0133e47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
