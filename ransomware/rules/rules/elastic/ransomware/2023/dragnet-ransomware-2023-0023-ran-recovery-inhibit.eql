// Dragnet [Ransomware]: dragnet-ransomware-2023-0023 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: dc6eed2e-5a67-530e-a38e-fff73c904449

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
