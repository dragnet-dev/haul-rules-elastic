// Dragnet [Ransomware]: dragnet-ransomware-2023-2268 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 6fd68b5f-e3e5-51cc-a06b-04b7fd26c1d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
