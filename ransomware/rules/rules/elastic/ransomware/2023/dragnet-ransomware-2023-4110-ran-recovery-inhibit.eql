// Dragnet [Ransomware]: dragnet-ransomware-2023-4110 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 77010fc3-b811-55ac-beaa-9664fa97a48a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
