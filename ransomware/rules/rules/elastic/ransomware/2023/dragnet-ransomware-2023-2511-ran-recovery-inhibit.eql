// Dragnet [Ransomware]: dragnet-ransomware-2023-2511 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0c77c2f6-c4d7-5998-95fa-5bf52c33db2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
