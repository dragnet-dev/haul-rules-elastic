// Dragnet [Ransomware]: dragnet-ransomware-2023-4889 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 098a5617-8d9f-53c2-abed-03e6e5ca77bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
