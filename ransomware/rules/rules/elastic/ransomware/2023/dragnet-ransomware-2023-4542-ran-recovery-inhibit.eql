// Dragnet [Ransomware]: dragnet-ransomware-2023-4542 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 987b048f-4d4c-51e2-8aff-d24de0b8fa86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
