// Dragnet [Ransomware]: dragnet-ransomware-2023-4411 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: aea51faf-cc54-5b2c-8cf7-bf623d3e980f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
