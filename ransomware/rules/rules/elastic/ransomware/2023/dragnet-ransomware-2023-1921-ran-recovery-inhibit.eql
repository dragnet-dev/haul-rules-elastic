// Dragnet [Ransomware]: dragnet-ransomware-2023-1921 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0a3074bd-75ff-5a2e-a1fc-847e53bf36ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
