// Dragnet [Ransomware]: dragnet-ransomware-2023-5282 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 68c182e0-4eb6-541f-9c46-85f963800176

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
