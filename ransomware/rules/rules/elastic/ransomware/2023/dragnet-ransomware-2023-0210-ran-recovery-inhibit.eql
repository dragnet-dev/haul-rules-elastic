// Dragnet [Ransomware]: dragnet-ransomware-2023-0210 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 41c069c9-f261-546d-89e9-5619b37af399

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
