// Dragnet [Ransomware]: dragnet-ransomware-2023-2190 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f0407d69-f86c-5e64-b937-611f062b19fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
