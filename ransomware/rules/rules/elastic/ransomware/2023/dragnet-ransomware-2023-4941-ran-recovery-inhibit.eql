// Dragnet [Ransomware]: dragnet-ransomware-2023-4941 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c92fe3c6-8eff-5820-9cd2-b8f4218f726b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
