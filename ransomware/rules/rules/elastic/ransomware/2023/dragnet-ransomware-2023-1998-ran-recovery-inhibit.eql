// Dragnet [Ransomware]: dragnet-ransomware-2023-1998 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: f1071a92-f839-58a4-a2aa-7b86d3e4dfd7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
