// Dragnet [Ransomware]: dragnet-ransomware-2023-0766 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: f704878e-0780-54fe-8d1f-9a95761c7827

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
