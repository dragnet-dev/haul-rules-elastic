// Dragnet [Ransomware]: dragnet-ransomware-2023-2626 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: db320020-d163-5814-974a-3a69daa2761b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
