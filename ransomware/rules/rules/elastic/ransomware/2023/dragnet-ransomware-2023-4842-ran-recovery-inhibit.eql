// Dragnet [Ransomware]: dragnet-ransomware-2023-4842 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 9684965b-987b-5335-9009-080764dbc05b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
