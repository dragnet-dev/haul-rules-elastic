// Dragnet [Ransomware]: dragnet-ransomware-2023-2965 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: fa2dae9b-6071-56f0-8364-d6ca73c8c516

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
