// Dragnet [Ransomware]: dragnet-ransomware-2023-4916 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 37b18413-40ae-56e5-a2ac-78874b07313f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
