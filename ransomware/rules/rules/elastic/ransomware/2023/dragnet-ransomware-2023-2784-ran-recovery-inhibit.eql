// Dragnet [Ransomware]: dragnet-ransomware-2023-2784 — Recovery Inhibition (malas)
// Status: experimental | Level: high | ID: 0fe77856-eb39-51b7-9f5d-427fa5ff2509

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
