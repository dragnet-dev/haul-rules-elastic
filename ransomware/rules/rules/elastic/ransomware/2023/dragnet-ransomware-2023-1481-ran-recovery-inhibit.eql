// Dragnet [Ransomware]: dragnet-ransomware-2023-1481 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: eabfff64-746d-5042-8e79-2cb62c26be16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
