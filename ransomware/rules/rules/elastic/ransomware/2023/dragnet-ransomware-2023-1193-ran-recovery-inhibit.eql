// Dragnet [Ransomware]: dragnet-ransomware-2023-1193 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: aa9dd7c2-4fa1-5a16-890b-8a1440e5b4d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
