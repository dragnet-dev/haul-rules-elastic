// Dragnet [Ransomware]: dragnet-ransomware-2023-5214 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 461ba162-f8cf-5136-8d09-356dfbe05613

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
