// Dragnet [Ransomware]: dragnet-ransomware-2023-4107 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 4bb93f21-7e26-567c-97ee-8fd5f8ff61de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
