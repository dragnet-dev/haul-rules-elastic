// Dragnet [Ransomware]: dragnet-ransomware-2023-4134 — Recovery Inhibition (ransomed)
// Status: deprecated | Level: high | ID: ed1bd14e-501a-54cb-b6d1-3cc350035a59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
