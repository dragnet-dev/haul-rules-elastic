// Dragnet [Ransomware]: dragnet-ransomware-2023-4509 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: be01d204-02a3-5d13-a8e4-84b902ffa798

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
