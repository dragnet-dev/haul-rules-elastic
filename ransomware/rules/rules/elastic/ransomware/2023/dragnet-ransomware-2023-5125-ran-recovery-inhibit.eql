// Dragnet [Ransomware]: dragnet-ransomware-2023-5125 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 983b685e-4193-5d5e-8ca1-fb20e3fd4f2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
