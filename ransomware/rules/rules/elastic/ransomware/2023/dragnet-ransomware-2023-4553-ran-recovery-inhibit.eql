// Dragnet [Ransomware]: dragnet-ransomware-2023-4553 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 146bdb8f-da32-5273-874e-e5ce3f60db1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
