// Dragnet [Ransomware]: dragnet-ransomware-2023-3354 — Recovery Inhibition (darkpower)
// Status: experimental | Level: high | ID: d1ffa92b-8524-5841-b79c-ce9941f40239

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
