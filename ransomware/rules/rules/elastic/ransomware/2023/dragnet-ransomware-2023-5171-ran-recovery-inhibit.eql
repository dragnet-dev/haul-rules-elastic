// Dragnet [Ransomware]: dragnet-ransomware-2023-5171 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: 7d0a80bc-6992-58a1-a5d3-f0cd3fdc173e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
