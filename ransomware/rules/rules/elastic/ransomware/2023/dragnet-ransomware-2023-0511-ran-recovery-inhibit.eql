// Dragnet [Ransomware]: dragnet-ransomware-2023-0511 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 2ddcc941-5655-5e36-a837-0c38f72e77b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
