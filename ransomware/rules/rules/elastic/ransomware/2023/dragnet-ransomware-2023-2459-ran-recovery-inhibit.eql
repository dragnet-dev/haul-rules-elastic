// Dragnet [Ransomware]: dragnet-ransomware-2023-2459 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: f4bbc864-256a-58ec-83e1-b19419ebcf00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
