// Dragnet [Ransomware]: dragnet-ransomware-2023-4486 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 758a4a14-1eb1-5066-8234-85ba8f9d5785

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
