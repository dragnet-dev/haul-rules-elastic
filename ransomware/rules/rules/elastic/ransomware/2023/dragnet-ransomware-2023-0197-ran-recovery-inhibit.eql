// Dragnet [Ransomware]: dragnet-ransomware-2023-0197 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 17e31d9f-0d31-52ab-9f01-15e70b957b3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
