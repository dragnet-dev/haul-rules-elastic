// Dragnet [Ransomware]: dragnet-ransomware-2023-3268 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: d75cf4fc-e1a9-512c-ab81-0c2e3b2c1c69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
