// Dragnet [Ransomware]: dragnet-ransomware-2023-1582 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: e1a955b9-b66f-53b4-abdb-557d72355fd2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
