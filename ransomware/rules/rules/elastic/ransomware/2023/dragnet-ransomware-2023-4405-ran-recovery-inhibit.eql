// Dragnet [Ransomware]: dragnet-ransomware-2023-4405 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 154f8afa-24fe-57a8-af0e-9a6fed4d8710

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
