// Dragnet [Ransomware]: dragnet-ransomware-2023-4957 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e482c7b2-5c73-5c38-952c-44bbc2e67e5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
