// Dragnet [Ransomware]: dragnet-ransomware-2023-2603 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1080d841-4439-5680-a04c-ad20661d2cfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
