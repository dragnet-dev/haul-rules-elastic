// Dragnet [Ransomware]: dragnet-ransomware-2023-0313 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c6d41797-cbc2-5e3d-a9e5-17088e2697eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
