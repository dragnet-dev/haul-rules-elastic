// Dragnet [Ransomware]: dragnet-ransomware-2023-1206 — Recovery Inhibition (medusa)
// Status: deprecated | Level: high | ID: 8eb74bcc-c953-5718-b651-e247d5d61075

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
