// Dragnet [Ransomware]: dragnet-ransomware-2023-1081 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 4c15dbdc-e5de-5d47-bafd-03f7f5fb8ad7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
