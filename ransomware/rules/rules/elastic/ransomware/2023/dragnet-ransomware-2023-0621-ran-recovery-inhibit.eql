// Dragnet [Ransomware]: dragnet-ransomware-2023-0621 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: d4270baf-d18a-56ff-94fd-c2baeb2da7d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
