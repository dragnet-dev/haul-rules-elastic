// Dragnet [Ransomware]: dragnet-ransomware-2023-5142 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: a2da14c4-44ff-58b1-904a-c3e2a65f166b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
