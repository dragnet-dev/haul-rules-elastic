// Dragnet [Ransomware]: dragnet-ransomware-2023-4430 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: fab9b8bd-6672-5a0d-8504-bcb8b0586c43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
