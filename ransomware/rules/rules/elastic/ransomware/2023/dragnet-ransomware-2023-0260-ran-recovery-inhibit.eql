// Dragnet [Ransomware]: dragnet-ransomware-2023-0260 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f969b287-022c-50e6-981a-57d075851b30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
