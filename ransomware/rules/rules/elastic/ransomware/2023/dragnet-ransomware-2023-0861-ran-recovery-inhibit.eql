// Dragnet [Ransomware]: dragnet-ransomware-2023-0861 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 38abf51c-0d23-5e4d-8c68-c51bc284d253

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
