// Dragnet [Ransomware]: dragnet-ransomware-2023-3683 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: bfab966e-9d4b-5500-8f01-9c294500c905

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
