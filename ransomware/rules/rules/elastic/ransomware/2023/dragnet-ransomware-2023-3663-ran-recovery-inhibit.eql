// Dragnet [Ransomware]: dragnet-ransomware-2023-3663 — Recovery Inhibition (werewolves)
// Status: experimental | Level: high | ID: d60d6a3d-b0b1-55c8-a816-a6c7f3bc7633

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
