// Dragnet [Ransomware]: dragnet-ransomware-2023-1522 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 9fb03d3a-7fc0-5f92-be36-79e0dc2d75d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
