// Dragnet [Ransomware]: dragnet-ransomware-2023-4324 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 841954fb-fead-52ca-99c5-59c95cb00e12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
