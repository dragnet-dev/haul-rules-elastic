// Dragnet [Ransomware]: dragnet-ransomware-2023-4058 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: aafc917f-4c72-5045-a358-4b3696aaad9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
