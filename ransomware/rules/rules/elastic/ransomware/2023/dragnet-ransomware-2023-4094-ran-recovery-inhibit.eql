// Dragnet [Ransomware]: dragnet-ransomware-2023-4094 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 3952cd81-fd4f-5c67-aa37-7cce45bead2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
