// Dragnet [Ransomware]: dragnet-ransomware-2023-1351 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: f97d814d-6e0e-5c16-a5d9-329d4e3d938c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
