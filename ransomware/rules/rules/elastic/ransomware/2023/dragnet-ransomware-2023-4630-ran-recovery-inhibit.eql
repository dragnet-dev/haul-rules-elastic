// Dragnet [Ransomware]: dragnet-ransomware-2023-4630 — Recovery Inhibition (werewolves)
// Status: experimental | Level: high | ID: 7fb49d7c-20a0-583f-be12-fe61c7f14027

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
