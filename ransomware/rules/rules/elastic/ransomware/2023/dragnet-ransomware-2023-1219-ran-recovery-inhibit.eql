// Dragnet [Ransomware]: dragnet-ransomware-2023-1219 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: db470c1e-5bbb-5b55-b815-365478dc6c83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
