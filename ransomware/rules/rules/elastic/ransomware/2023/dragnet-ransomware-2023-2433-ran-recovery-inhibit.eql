// Dragnet [Ransomware]: dragnet-ransomware-2023-2433 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8ad27b51-454d-59e2-be5a-9c9f8fd74eb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
