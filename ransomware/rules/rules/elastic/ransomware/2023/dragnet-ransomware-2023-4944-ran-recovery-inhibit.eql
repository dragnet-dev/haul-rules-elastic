// Dragnet [Ransomware]: dragnet-ransomware-2023-4944 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 87527777-4360-582d-a28d-58fbabee1c0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
