// Dragnet [Ransomware]: dragnet-ransomware-2023-1667 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: ee3a8716-e838-50b2-843f-8ef8ce355fe2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
