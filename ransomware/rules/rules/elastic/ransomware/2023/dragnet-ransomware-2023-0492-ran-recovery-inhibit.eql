// Dragnet [Ransomware]: dragnet-ransomware-2023-0492 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3f37a320-e171-5039-89c9-ca21f5461382

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
