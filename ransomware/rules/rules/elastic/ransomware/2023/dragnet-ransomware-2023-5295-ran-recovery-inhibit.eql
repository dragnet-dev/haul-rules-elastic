// Dragnet [Ransomware]: dragnet-ransomware-2023-5295 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 858f6391-5adf-57e4-a14b-270fc639c295

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
