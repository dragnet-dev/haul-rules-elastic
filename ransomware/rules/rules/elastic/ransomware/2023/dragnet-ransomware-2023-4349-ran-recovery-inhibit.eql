// Dragnet [Ransomware]: dragnet-ransomware-2023-4349 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b5d7080d-a8e7-5342-9ea7-66e9768e975f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
