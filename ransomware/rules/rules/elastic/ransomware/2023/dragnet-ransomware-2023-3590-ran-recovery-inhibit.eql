// Dragnet [Ransomware]: dragnet-ransomware-2023-3590 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 86c0f3dc-304a-5c76-9681-c0d3f4cfcd9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
