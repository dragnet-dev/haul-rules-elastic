// Dragnet [Ransomware]: dragnet-ransomware-2023-2733 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 12380c60-456a-5880-afa5-759549ceada1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
