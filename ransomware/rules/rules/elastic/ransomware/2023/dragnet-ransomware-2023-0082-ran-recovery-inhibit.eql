// Dragnet [Ransomware]: dragnet-ransomware-2023-0082 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e90808a4-33ba-5428-9ce1-93e22f8cef40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
