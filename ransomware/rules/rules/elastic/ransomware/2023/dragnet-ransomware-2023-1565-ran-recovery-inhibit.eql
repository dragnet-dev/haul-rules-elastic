// Dragnet [Ransomware]: dragnet-ransomware-2023-1565 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b262bc1e-fe9d-5c26-bac8-5c0230961feb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
