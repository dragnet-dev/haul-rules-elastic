// Dragnet [Ransomware]: dragnet-ransomware-2023-4539 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e171a803-6d83-5d1f-a918-2f23f27ba51d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
