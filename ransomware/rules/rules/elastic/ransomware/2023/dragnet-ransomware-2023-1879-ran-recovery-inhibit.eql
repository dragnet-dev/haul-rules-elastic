// Dragnet [Ransomware]: dragnet-ransomware-2023-1879 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 385f2e3d-b333-5c7a-9852-1ca43eeffa92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
