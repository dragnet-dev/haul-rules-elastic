// Dragnet [Ransomware]: dragnet-ransomware-2023-1256 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 977b5dd1-91dd-5a7c-9a68-edda72728c8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
