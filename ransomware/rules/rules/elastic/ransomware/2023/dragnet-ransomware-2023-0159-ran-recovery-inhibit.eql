// Dragnet [Ransomware]: dragnet-ransomware-2023-0159 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: 530413a2-cb37-5106-8151-477a25097688

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
