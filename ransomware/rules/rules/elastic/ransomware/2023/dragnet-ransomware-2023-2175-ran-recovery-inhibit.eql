// Dragnet [Ransomware]: dragnet-ransomware-2023-2175 — Recovery Inhibition (losttrust)
// Status: deprecated | Level: high | ID: 89e877a5-0f01-599c-8f7d-70442ced9905

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
