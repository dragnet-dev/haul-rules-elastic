// Dragnet [Ransomware]: dragnet-ransomware-2023-3575 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 8d47c950-8500-5e58-8a6d-327d737ef4a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
