// Dragnet [Ransomware]: dragnet-ransomware-2023-0135 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 295c356f-bacf-5c53-90b0-64da1298ab4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
