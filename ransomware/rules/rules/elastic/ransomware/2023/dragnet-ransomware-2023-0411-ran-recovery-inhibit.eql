// Dragnet [Ransomware]: dragnet-ransomware-2023-0411 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: cc90c7c8-c63c-5dba-bfee-263bcc92dd45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
