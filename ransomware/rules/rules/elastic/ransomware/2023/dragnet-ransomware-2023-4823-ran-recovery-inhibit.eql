// Dragnet [Ransomware]: dragnet-ransomware-2023-4823 — Recovery Inhibition (royal)
// Status: experimental | Level: high | ID: 3d822c90-253a-57ca-a072-110f31fc88cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
