// Dragnet [Ransomware]: dragnet-ransomware-2023-3643 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 7983509a-c51e-54b6-b912-a8823b4a49bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
