// Dragnet [Ransomware]: dragnet-ransomware-2023-1601 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 13369ad4-2d50-58a1-aae3-abaa3ab297df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
