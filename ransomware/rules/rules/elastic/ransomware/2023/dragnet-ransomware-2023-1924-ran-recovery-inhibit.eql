// Dragnet [Ransomware]: dragnet-ransomware-2023-1924 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 4dabaced-dfbf-5cd3-8fac-e2db20d66ee7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
