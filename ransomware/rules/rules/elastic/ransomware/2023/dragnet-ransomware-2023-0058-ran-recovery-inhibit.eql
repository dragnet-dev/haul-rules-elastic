// Dragnet [Ransomware]: dragnet-ransomware-2023-0058 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0698a30e-a9dc-556a-b276-1b60df8929e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
