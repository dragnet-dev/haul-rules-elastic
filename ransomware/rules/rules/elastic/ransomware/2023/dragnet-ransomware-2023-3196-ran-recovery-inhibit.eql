// Dragnet [Ransomware]: dragnet-ransomware-2023-3196 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: dca8b350-0b57-5199-a0f1-377f4d4e4277

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
