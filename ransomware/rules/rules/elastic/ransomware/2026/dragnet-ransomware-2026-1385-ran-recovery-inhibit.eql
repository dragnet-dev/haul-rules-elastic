// Dragnet [Ransomware]: dragnet-ransomware-2026-1385 — Recovery Inhibition (beast)
// Status: stable | Level: high | ID: 5e99d3e1-41d4-5b45-a8e2-ded660b054b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
