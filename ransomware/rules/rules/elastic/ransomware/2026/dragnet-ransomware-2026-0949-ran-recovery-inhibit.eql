// Dragnet [Ransomware]: dragnet-ransomware-2026-0949 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: fdb1f387-8ea6-512f-a05d-69a9fcc61fdc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
