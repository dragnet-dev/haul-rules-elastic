// Dragnet [Ransomware]: dragnet-ransomware-2026-3184 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 82c1cde1-92c4-5e43-ab16-d5c7d6fd3a69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
