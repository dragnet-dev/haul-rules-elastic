// Dragnet [Ransomware]: dragnet-ransomware-2026-0291 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 4164abd7-3906-578e-a6b8-0dc1d29f3e8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
