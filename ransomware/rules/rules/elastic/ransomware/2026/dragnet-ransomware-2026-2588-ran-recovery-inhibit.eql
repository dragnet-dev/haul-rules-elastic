// Dragnet [Ransomware]: dragnet-ransomware-2026-2588 — Recovery Inhibition (linkc)
// Status: test | Level: high | ID: 174dca70-96b0-5071-a5fe-7ce10411d41f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
