// Dragnet [Ransomware]: dragnet-ransomware-2026-0737 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 5e8c4f2c-68a6-59bb-a177-d0e8af20bca8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
