// Dragnet [Ransomware]: dragnet-ransomware-2026-2243 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 9f3e8c8c-b12f-55d6-9976-95992d109353

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
