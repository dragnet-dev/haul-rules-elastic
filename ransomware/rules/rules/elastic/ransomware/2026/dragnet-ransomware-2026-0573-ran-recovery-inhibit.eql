// Dragnet [Ransomware]: dragnet-ransomware-2026-0573 — Recovery Inhibition (pear)
// Status: stable | Level: high | ID: 180cd1e3-597a-59e1-84ef-d78069ee324d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
