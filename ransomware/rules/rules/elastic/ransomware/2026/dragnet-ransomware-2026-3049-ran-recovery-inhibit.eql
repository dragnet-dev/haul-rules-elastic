// Dragnet [Ransomware]: dragnet-ransomware-2026-3049 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 9ac9bae9-344f-57cb-a9bf-5feddcc9efd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
