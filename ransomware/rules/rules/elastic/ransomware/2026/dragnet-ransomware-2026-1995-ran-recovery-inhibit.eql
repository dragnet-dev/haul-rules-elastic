// Dragnet [Ransomware]: dragnet-ransomware-2026-1995 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: d1c09595-92ef-59fe-a783-5dbbb6b54933

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
