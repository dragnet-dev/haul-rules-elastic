// Dragnet [Ransomware]: dragnet-ransomware-2026-1564 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 15eefb26-6015-5666-88fa-25ac75cb3083

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
