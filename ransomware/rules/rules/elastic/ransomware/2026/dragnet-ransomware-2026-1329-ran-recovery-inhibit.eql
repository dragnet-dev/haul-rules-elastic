// Dragnet [Ransomware]: dragnet-ransomware-2026-1329 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 65483ccd-0813-5f25-87f1-01ca25fa08d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
