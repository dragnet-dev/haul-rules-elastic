// Dragnet [Ransomware]: dragnet-ransomware-2026-3024 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: e3b81d2b-9050-5646-ac73-fffa7852a10c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
