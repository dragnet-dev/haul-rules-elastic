// Dragnet [Ransomware]: dragnet-ransomware-2026-1203 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 8a5c5eba-3e65-5083-9979-6830fe574044

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
