// Dragnet [Ransomware]: dragnet-ransomware-2026-3200 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: c694cfed-aa14-5bd4-80b1-726daccdbeb9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
