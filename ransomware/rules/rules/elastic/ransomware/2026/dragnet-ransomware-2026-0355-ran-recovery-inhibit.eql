// Dragnet [Ransomware]: dragnet-ransomware-2026-0355 — Recovery Inhibition (direwolf)
// Status: test | Level: high | ID: 41b7d642-67fa-565c-90c6-9087255b0452

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
