// Dragnet [Ransomware]: dragnet-ransomware-2026-2803 — Recovery Inhibition (medusalocker)
// Status: stable | Level: high | ID: 02182d6c-1c19-5bc9-a073-1bdf8f7e8955

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
