// Dragnet [Ransomware]: dragnet-ransomware-2026-3111 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: 918527ef-4d11-5f06-bbd2-f7874d97e825

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
