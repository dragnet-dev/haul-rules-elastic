// Dragnet [Ransomware]: dragnet-ransomware-2026-1475 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 40a7fad1-33bd-54f9-b217-4e1d45c947bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
