// Dragnet [Ransomware]: dragnet-ransomware-2026-1301 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 85991e29-e7ce-5609-a725-ef16682c52c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
