// Dragnet [Ransomware]: dragnet-ransomware-2026-0080 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 2d1aac91-5191-5169-8a85-44f233253e24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
