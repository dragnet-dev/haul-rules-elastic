// Dragnet [Ransomware]: dragnet-ransomware-2026-2734 — Recovery Inhibition (lynx)
// Status: stable | Level: high | ID: 8947550b-b178-56c0-a5ed-a92d67ff1185

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
