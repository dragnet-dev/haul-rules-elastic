// Dragnet [Ransomware]: dragnet-ransomware-2026-1635 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cbfc34e1-f261-504b-bdf2-750fbcb4f115

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
