// Dragnet [Ransomware]: dragnet-ransomware-2026-2244 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 08324b5e-1595-5100-b5ab-6840919365c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
