// Dragnet [Ransomware]: dragnet-ransomware-2026-1436 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ac2660da-af23-5870-95f1-d75da62da797

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
