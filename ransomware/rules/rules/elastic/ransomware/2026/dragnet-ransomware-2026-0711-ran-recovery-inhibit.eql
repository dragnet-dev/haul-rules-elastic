// Dragnet [Ransomware]: dragnet-ransomware-2026-0711 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: b16a06a6-9771-5b20-87a5-a64718a0907e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
