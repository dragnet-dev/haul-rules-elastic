// Dragnet [Ransomware]: dragnet-ransomware-2026-0092 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bd70b18e-0335-5df4-964c-4df510bb1cb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
