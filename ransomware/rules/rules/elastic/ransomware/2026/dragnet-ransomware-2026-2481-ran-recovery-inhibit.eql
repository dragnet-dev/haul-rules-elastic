// Dragnet [Ransomware]: dragnet-ransomware-2026-2481 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: b2fa23f0-07ca-5ea1-8c5e-16170b917361

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
