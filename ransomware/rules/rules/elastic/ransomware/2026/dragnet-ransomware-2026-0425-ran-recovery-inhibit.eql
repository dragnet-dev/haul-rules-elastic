// Dragnet [Ransomware]: dragnet-ransomware-2026-0425 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: b968d1f6-e740-5a2f-8721-44be6ac08aa7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
