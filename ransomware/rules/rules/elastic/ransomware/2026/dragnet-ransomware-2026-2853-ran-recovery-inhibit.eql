// Dragnet [Ransomware]: dragnet-ransomware-2026-2853 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: e770e378-0556-5295-b896-ec548d9f9028

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
