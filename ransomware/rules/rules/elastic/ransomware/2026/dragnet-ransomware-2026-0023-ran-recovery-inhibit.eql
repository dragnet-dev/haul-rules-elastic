// Dragnet [Ransomware]: dragnet-ransomware-2026-0023 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 2c856c64-3b73-5d68-b11f-e7eaf0535723

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
