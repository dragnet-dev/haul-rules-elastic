// Dragnet [Ransomware]: dragnet-ransomware-2026-2224 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: 4cfb4e67-2188-57f2-8a67-5bf7f21eac05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
