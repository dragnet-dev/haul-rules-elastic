// Dragnet [Ransomware]: dragnet-ransomware-2026-3234 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: acb8ef6c-7d81-5a18-b008-bef0b026ff65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
