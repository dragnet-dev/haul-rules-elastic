// Dragnet [Ransomware]: dragnet-ransomware-2026-0315 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: dce22e59-cb80-59f7-8c24-31e71b5aefcd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
