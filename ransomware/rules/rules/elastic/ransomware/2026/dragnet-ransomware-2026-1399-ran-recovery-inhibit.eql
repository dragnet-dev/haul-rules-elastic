// Dragnet [Ransomware]: dragnet-ransomware-2026-1399 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5ba69eee-7306-54d0-a38e-d99f8356de2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
