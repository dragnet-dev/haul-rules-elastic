// Dragnet [Ransomware]: dragnet-ransomware-2026-1767 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: b9de3e8e-1d2f-518a-a752-67c7f9b32af3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
