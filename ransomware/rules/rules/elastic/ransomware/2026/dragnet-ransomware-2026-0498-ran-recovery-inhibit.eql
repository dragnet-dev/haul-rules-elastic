// Dragnet [Ransomware]: dragnet-ransomware-2026-0498 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 86667340-0b4a-5a54-88a6-a13f5e6798fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
