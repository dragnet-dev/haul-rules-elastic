// Dragnet [Ransomware]: dragnet-ransomware-2026-1151 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: b8e8b426-6407-5c11-a0ec-e9aad74590d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
