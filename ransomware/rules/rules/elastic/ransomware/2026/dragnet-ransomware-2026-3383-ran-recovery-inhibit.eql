// Dragnet [Ransomware]: dragnet-ransomware-2026-3383 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: fba382cd-3899-527a-9927-b8167c578797

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
