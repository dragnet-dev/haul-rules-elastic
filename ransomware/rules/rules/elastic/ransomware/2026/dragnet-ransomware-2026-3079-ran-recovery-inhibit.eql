// Dragnet [Ransomware]: dragnet-ransomware-2026-3079 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: e579296d-18a3-5359-ac6c-5f1487bb26d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
