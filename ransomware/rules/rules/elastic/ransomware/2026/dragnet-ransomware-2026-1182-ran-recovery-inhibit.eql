// Dragnet [Ransomware]: dragnet-ransomware-2026-1182 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 298249f4-4594-5b26-8d05-78d403ce09ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
