// Dragnet [Ransomware]: dragnet-ransomware-2026-2956 — Recovery Inhibition (payoutsking)
// Status: stable | Level: high | ID: 22fa8c6c-45ee-5fc7-a164-cdae742a3575

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
