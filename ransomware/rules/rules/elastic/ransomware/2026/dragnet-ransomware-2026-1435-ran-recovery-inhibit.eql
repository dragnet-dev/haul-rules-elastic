// Dragnet [Ransomware]: dragnet-ransomware-2026-1435 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: d19cc916-5e66-536c-ae3b-1fa70046b3bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
