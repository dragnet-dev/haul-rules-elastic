// Dragnet [Ransomware]: dragnet-ransomware-2026-2831 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 1263ee64-a616-54b3-9e5d-80cf2a7dc773

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
