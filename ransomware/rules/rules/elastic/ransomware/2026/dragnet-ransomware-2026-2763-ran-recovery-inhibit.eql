// Dragnet [Ransomware]: dragnet-ransomware-2026-2763 — Recovery Inhibition (aurora)
// Status: stable | Level: high | ID: d900bb6c-b218-55cc-9ae4-db8ca129c972

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
