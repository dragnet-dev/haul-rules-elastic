// Dragnet [Ransomware]: dragnet-ransomware-2026-3238 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: ec4c8c6e-de69-5c6c-8f43-36972bb74fe1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
