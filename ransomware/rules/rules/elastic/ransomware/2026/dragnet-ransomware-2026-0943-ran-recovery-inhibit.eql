// Dragnet [Ransomware]: dragnet-ransomware-2026-0943 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4e52af0d-6f9b-56a5-9d94-a8bfe793c69d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
