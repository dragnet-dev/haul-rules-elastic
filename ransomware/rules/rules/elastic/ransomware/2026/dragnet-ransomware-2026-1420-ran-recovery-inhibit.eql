// Dragnet [Ransomware]: dragnet-ransomware-2026-1420 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: eb87f3d8-3e98-5f19-a883-155325c070bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
