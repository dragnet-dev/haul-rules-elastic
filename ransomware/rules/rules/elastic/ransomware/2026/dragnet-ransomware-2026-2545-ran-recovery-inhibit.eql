// Dragnet [Ransomware]: dragnet-ransomware-2026-2545 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: a015f64d-dc5f-57dc-8dfd-78dc5cc6db34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
