// Dragnet [Ransomware]: dragnet-ransomware-2026-2913 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 87aef3a1-6f13-5c09-a2b8-9dd84d5901e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
