// Dragnet [Ransomware]: dragnet-ransomware-2026-0827 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 37376fee-5f7c-510c-bc67-eec960f3d158

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
