// Dragnet [Ransomware]: dragnet-ransomware-2026-1166 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 6d7b2db1-67a8-59b4-b0db-ab3c9ce19e4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
