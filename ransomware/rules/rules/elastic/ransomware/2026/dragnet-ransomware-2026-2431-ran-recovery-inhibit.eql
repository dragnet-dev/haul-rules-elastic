// Dragnet [Ransomware]: dragnet-ransomware-2026-2431 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 6d345b81-2fc6-55e5-88e6-675caff3517e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
