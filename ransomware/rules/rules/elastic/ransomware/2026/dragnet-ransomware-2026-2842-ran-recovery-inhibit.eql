// Dragnet [Ransomware]: dragnet-ransomware-2026-2842 — Recovery Inhibition (worldleaks)
// Status: stable | Level: high | ID: 868e4d35-854a-5770-8931-d9a41d24118c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
