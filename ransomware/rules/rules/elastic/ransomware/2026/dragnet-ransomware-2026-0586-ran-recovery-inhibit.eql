// Dragnet [Ransomware]: dragnet-ransomware-2026-0586 — Recovery Inhibition (ransomhouse)
// Status: test | Level: high | ID: a34b33f8-a9ab-5215-a88b-c20915ab885d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
