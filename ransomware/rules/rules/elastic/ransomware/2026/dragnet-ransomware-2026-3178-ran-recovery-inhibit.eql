// Dragnet [Ransomware]: dragnet-ransomware-2026-3178 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 37465af1-6418-5f74-81f3-570cb65ec917

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
