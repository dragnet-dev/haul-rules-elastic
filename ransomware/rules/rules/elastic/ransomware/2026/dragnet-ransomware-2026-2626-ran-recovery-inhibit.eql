// Dragnet [Ransomware]: dragnet-ransomware-2026-2626 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1d85ba07-9e6c-5971-86d7-6926052f3988

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
