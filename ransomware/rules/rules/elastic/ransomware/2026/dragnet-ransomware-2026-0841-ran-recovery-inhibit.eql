// Dragnet [Ransomware]: dragnet-ransomware-2026-0841 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 1e96ec60-8c52-5a22-a153-9a754e6fcc65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
