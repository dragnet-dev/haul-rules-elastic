// Dragnet [Ransomware]: dragnet-ransomware-2026-3524 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 9f3e76fb-56c1-58a6-aab0-879d1b6334a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
