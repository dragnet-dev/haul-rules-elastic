// Dragnet [Ransomware]: dragnet-ransomware-2026-1650 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 9c40e26c-a511-526c-bc8d-cc56914ddfde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
