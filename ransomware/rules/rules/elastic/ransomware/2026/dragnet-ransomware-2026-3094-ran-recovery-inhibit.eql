// Dragnet [Ransomware]: dragnet-ransomware-2026-3094 — Recovery Inhibition (securotrop)
// Status: test | Level: high | ID: cf6b82a0-afe9-57f8-b060-56f7e3ec40f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
