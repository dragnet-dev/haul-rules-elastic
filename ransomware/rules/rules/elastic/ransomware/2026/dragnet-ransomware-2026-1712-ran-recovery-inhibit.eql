// Dragnet [Ransomware]: dragnet-ransomware-2026-1712 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 8ecac1de-3bb6-562f-842a-d90034f0e681

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
