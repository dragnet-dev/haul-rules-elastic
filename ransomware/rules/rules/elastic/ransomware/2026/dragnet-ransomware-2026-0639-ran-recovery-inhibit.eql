// Dragnet [Ransomware]: dragnet-ransomware-2026-0639 — Recovery Inhibition (interlock)
// Status: test | Level: high | ID: 7371c1dd-986b-5bb5-a93f-28f781bf9458

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
