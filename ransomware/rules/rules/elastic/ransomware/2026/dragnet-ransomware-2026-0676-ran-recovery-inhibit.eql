// Dragnet [Ransomware]: dragnet-ransomware-2026-0676 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 92645e36-dcec-5df9-b728-60503daf7e0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
