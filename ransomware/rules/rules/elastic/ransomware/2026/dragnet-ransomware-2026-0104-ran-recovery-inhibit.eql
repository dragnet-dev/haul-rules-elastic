// Dragnet [Ransomware]: dragnet-ransomware-2026-0104 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: d0044fa9-1238-5f80-8029-ebbf57175107

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
