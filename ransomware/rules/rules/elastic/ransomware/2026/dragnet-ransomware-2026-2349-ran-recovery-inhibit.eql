// Dragnet [Ransomware]: dragnet-ransomware-2026-2349 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 832f44ae-2891-5d91-858e-400ad88a3829

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
