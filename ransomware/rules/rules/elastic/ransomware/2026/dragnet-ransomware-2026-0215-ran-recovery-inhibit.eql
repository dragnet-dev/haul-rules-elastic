// Dragnet [Ransomware]: dragnet-ransomware-2026-0215 — Recovery Inhibition (ransomhouse)
// Status: stable | Level: high | ID: c5367982-3dfa-527e-bcf0-2ae81f430ac7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
