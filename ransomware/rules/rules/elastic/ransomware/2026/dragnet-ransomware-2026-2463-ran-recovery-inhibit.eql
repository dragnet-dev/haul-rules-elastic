// Dragnet [Ransomware]: dragnet-ransomware-2026-2463 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 04e99ce3-1bc4-5f04-9ff6-300fda453e96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
