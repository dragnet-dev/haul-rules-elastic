// Dragnet [Ransomware]: dragnet-ransomware-2026-0066 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 6a0e6f03-03df-5d4d-b297-69cc1bb48115

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
