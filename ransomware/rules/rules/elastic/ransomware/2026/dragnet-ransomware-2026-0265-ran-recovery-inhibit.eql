// Dragnet [Ransomware]: dragnet-ransomware-2026-0265 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 60073940-91a6-51cb-ac77-ef4dc5d9eadb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
