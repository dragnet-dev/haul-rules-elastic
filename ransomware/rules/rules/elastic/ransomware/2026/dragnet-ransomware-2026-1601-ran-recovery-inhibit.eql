// Dragnet [Ransomware]: dragnet-ransomware-2026-1601 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 45c5486c-f327-5f24-9813-b52cb813fd80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
