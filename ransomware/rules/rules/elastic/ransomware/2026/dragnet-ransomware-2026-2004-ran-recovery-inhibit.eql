// Dragnet [Ransomware]: dragnet-ransomware-2026-2004 — Recovery Inhibition (spacebears)
// Status: stable | Level: high | ID: b0cfab1d-b134-590e-9152-4e2ad11fbf44

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
