// Dragnet [Ransomware]: dragnet-ransomware-2026-0682 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: 048e3533-de4f-5464-a510-78c145f24a0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
