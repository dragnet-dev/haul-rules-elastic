// Dragnet [Ransomware]: dragnet-ransomware-2026-0890 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: ef29d643-6cd4-5582-b558-2d1065a39eaa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
