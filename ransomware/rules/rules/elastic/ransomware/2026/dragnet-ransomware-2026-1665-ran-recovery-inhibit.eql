// Dragnet [Ransomware]: dragnet-ransomware-2026-1665 — Recovery Inhibition (cipherforce)
// Status: stable | Level: high | ID: 2df80a07-d72f-59b6-a113-7d59beb02532

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
