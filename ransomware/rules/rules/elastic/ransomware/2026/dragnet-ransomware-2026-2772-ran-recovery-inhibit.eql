// Dragnet [Ransomware]: dragnet-ransomware-2026-2772 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 3538a65c-fa9f-50dd-b697-4fc748ac3744

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
