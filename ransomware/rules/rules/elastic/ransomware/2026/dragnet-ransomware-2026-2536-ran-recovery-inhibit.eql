// Dragnet [Ransomware]: dragnet-ransomware-2026-2536 — Recovery Inhibition (krybit)
// Status: stable | Level: high | ID: 1e60a2d0-7f0a-5a86-9d51-f24e15903323

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
