// Dragnet [Ransomware]: dragnet-ransomware-2026-3299 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 5ff07595-8935-5a24-ad40-c8ea6992210e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
