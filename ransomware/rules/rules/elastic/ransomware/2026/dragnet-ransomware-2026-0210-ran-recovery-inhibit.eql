// Dragnet [Ransomware]: dragnet-ransomware-2026-0210 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 93d093c6-ada4-5c97-8a44-92574db965da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
