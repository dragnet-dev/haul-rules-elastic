// Dragnet [Ransomware]: dragnet-ransomware-2026-1969 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: f1a43faf-eea4-51bc-9961-86a315428e2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
