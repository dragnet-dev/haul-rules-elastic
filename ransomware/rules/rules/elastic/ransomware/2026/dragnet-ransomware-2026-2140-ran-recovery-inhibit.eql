// Dragnet [Ransomware]: dragnet-ransomware-2026-2140 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: 27890eb9-600d-5a98-afd1-81fd5bbbe460

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
