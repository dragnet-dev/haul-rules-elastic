// Dragnet [Ransomware]: dragnet-ransomware-2026-1020 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: a7fe2625-c5d4-54d5-b4a8-de49f0f0190e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
