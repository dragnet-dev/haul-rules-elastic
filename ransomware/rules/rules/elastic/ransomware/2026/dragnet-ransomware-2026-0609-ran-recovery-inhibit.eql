// Dragnet [Ransomware]: dragnet-ransomware-2026-0609 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 5c04c2f2-e63a-52b2-83bc-085f547a847b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
