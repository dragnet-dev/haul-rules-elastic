// Dragnet [Ransomware]: dragnet-ransomware-2026-3132 — Recovery Inhibition (handala)
// Status: test | Level: high | ID: 1062596f-1599-5628-8fc9-3f177dc47843

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
