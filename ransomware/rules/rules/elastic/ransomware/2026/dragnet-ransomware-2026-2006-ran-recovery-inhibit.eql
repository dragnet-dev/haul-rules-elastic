// Dragnet [Ransomware]: dragnet-ransomware-2026-2006 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 84aed429-9c74-5a99-bc97-17df09816fe6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
