// Dragnet [Ransomware]: dragnet-ransomware-2026-2623 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 887ed335-d730-5f46-b70d-db566bb9866a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
