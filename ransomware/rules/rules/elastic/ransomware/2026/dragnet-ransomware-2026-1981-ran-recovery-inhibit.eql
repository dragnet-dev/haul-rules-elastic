// Dragnet [Ransomware]: dragnet-ransomware-2026-1981 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: aeef355d-22ce-551d-9efb-7d3192cb1ff0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
