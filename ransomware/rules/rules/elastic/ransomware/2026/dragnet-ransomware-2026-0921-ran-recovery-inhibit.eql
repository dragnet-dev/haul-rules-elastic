// Dragnet [Ransomware]: dragnet-ransomware-2026-0921 — Recovery Inhibition (medusa)
// Status: test | Level: high | ID: 31b87042-0c7d-52dd-96b5-505a7d02a4ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
