// Dragnet [Ransomware]: dragnet-ransomware-2026-2327 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: f8b5d3e1-0a12-5f1b-8b58-c4acfc603fa5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
