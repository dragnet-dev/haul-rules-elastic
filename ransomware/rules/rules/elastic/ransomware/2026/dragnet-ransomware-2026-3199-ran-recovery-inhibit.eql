// Dragnet [Ransomware]: dragnet-ransomware-2026-3199 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: e95c1503-45ba-539c-9005-6c7284d8fcd2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
