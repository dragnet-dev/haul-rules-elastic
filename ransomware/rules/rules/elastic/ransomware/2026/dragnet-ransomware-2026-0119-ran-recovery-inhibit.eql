// Dragnet [Ransomware]: dragnet-ransomware-2026-0119 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 8f3a755e-3a2a-5303-a3bc-d8ed4df468e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
