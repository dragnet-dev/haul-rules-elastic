// Dragnet [Ransomware]: dragnet-ransomware-2026-2868 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: b2f36312-6c5b-58f8-a1a4-ae602fb4102e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
