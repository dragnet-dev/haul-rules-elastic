// Dragnet [Ransomware]: dragnet-ransomware-2026-0817 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 9c3fe680-573e-5418-876b-930f2bd3b704

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
