// Dragnet [Ransomware]: dragnet-ransomware-2026-1053 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: af9d3fbd-91fd-59df-91ba-0b5b86d039bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
