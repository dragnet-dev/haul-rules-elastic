// Dragnet [Ransomware]: dragnet-ransomware-2026-3239 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: 4fc7c97c-0e03-50dc-928b-209a22ca5d77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
