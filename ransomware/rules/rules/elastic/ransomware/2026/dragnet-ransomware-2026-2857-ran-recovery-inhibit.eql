// Dragnet [Ransomware]: dragnet-ransomware-2026-2857 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: db8e2b99-89d9-5dba-94f4-63c7e90207f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
