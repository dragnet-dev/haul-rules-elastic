// Dragnet [Ransomware]: dragnet-ransomware-2026-1111 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: bd108593-3e86-5774-bf3d-a340eca0c463

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
