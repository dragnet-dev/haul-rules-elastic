// Dragnet [Ransomware]: dragnet-ransomware-2026-1742 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 6c5bc435-e4d8-5ee8-ab7a-f509addd3061

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
