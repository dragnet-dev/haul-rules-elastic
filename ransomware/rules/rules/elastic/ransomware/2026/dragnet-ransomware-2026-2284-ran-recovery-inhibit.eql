// Dragnet [Ransomware]: dragnet-ransomware-2026-2284 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3b2e3519-c7fd-5c62-8df5-c59091baed41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
