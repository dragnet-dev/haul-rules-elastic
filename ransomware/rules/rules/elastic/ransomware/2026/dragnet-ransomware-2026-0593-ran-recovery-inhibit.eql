// Dragnet [Ransomware]: dragnet-ransomware-2026-0593 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8d07fd3b-94c7-53d5-9aa3-02fd85f80691

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
