// Dragnet [Ransomware]: dragnet-ransomware-2026-3394 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 270c4954-5566-5235-a136-12c209a45cb2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
