// Dragnet [Ransomware]: dragnet-ransomware-2026-2647 — Recovery Inhibition (m3rx)
// Status: stable | Level: high | ID: f7aeeaae-cfa1-56e0-a6d7-07559e273549

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
