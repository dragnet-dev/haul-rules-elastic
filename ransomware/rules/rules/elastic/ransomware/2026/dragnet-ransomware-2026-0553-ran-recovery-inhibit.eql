// Dragnet [Ransomware]: dragnet-ransomware-2026-0553 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 9381a035-7dbf-50ff-845b-d2060d7d7c27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
