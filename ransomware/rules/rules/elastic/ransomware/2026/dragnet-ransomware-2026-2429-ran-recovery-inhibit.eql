// Dragnet [Ransomware]: dragnet-ransomware-2026-2429 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d10c751b-3495-5579-9ae4-131d647f63fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
