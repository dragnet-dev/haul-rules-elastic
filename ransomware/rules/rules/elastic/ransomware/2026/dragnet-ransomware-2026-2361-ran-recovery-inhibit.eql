// Dragnet [Ransomware]: dragnet-ransomware-2026-2361 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: be3fd687-1411-5bdd-a255-335a08fdfa27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
