// Dragnet [Ransomware]: dragnet-ransomware-2026-2293 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b613334e-8f1a-58e1-9e1b-621bb0384246

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
