// Dragnet [Ransomware]: dragnet-ransomware-2026-3351 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: e36ffed5-43a4-5bd6-bd47-e635dd1c0dba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
