// Dragnet [Ransomware]: dragnet-ransomware-2026-1983 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 252cce1b-925b-5d1a-b23d-0e000dfcd167

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
