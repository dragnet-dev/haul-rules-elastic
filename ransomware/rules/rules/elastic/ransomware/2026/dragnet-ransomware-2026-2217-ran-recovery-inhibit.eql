// Dragnet [Ransomware]: dragnet-ransomware-2026-2217 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 1c70b3b5-42e4-5a68-b52a-040f11515bee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
