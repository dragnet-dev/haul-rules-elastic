// Dragnet [Ransomware]: dragnet-ransomware-2026-2042 — Recovery Inhibition (blackwater)
// Status: stable | Level: high | ID: b8f05522-7b86-54dc-a869-979d9ea2bcf7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
