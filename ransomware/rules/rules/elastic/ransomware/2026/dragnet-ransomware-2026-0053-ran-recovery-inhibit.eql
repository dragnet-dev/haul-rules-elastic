// Dragnet [Ransomware]: dragnet-ransomware-2026-0053 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: 50e08790-d4e6-572a-9c89-c5772261523b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
