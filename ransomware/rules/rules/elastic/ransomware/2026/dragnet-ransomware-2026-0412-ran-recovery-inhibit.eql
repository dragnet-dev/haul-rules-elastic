// Dragnet [Ransomware]: dragnet-ransomware-2026-0412 — Recovery Inhibition (krybit)
// Status: stable | Level: high | ID: ff305d16-d742-52d3-9589-f5a285097769

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
