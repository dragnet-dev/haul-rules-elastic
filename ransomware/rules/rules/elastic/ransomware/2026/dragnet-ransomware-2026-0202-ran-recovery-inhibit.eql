// Dragnet [Ransomware]: dragnet-ransomware-2026-0202 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 301de47d-8b08-5c6f-a038-64f05401fac2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
