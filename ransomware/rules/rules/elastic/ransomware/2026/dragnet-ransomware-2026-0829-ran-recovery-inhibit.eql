// Dragnet [Ransomware]: dragnet-ransomware-2026-0829 — Recovery Inhibition (interlock)
// Status: test | Level: high | ID: 1e967cab-3671-5dda-847a-0493b7ca61e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
