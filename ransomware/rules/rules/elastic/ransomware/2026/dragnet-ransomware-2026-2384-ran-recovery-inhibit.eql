// Dragnet [Ransomware]: dragnet-ransomware-2026-2384 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: 61d7dfdb-d8aa-59e3-8ec9-816d25632313

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
