// Dragnet [Ransomware]: dragnet-ransomware-2026-2328 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: ac7822f7-1a56-53ba-b46e-6a92157d0af5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
