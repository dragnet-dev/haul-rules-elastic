// Dragnet [Ransomware]: dragnet-ransomware-2026-1588 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: f269f7fc-eca4-57a5-b4ec-8d6d596ca064

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
