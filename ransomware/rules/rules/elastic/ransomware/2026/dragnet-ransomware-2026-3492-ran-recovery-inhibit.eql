// Dragnet [Ransomware]: dragnet-ransomware-2026-3492 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 87ca44aa-26b5-570c-b4a2-18130a51a74d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
