// Dragnet [Ransomware]: dragnet-ransomware-2026-2143 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 0107be02-f50c-59f3-ae12-712f2690a46d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
