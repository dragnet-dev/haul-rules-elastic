// Dragnet [Ransomware]: dragnet-ransomware-2026-1366 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: be612fd3-5a53-5637-ba74-250ef53df27a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
