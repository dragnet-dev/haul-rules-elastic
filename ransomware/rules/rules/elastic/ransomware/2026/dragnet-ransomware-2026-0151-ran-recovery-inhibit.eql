// Dragnet [Ransomware]: dragnet-ransomware-2026-0151 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 6bd9efe6-60f4-5258-9694-7931fb17bb06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
