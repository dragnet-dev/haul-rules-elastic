// Dragnet [Ransomware]: dragnet-ransomware-2026-3004 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 50254050-31e9-5a37-981d-93c41ad05298

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
