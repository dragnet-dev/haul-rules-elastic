// Dragnet [Ransomware]: dragnet-ransomware-2026-0401 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: abf53c7e-a9a6-5342-b968-d046b9cc9c4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
