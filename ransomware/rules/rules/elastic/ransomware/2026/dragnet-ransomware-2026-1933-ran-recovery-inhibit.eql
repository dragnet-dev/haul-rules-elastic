// Dragnet [Ransomware]: dragnet-ransomware-2026-1933 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4255483c-81ec-5d8c-a524-4dba3ffc3a90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
