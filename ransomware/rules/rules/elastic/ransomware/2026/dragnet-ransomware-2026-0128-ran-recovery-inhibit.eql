// Dragnet [Ransomware]: dragnet-ransomware-2026-0128 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: ab97551e-6a09-5ae6-ba41-f29958386882

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
