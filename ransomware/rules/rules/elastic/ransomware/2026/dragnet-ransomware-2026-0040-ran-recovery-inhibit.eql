// Dragnet [Ransomware]: dragnet-ransomware-2026-0040 — Recovery Inhibition (aurora)
// Status: stable | Level: high | ID: 2d1a0692-d58b-5235-a028-05bd52fa9429

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
