// Dragnet [Ransomware]: dragnet-ransomware-2026-3497 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 36241144-7da4-5d5b-abcb-89f125bbb6e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
