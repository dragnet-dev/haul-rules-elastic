// Dragnet [Ransomware]: dragnet-ransomware-2026-1524 — Recovery Inhibition (ShadowByt3$)
// Status: deprecated | Level: high | ID: 0aefc34c-7f9a-55e4-9b58-cb11f7ee131b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
