// Dragnet [Ransomware]: dragnet-ransomware-2026-2351 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: eadd8743-eca8-5462-9e0d-de004d167dec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
