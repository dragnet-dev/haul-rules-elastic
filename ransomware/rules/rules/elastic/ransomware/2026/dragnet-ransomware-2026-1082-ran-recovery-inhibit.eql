// Dragnet [Ransomware]: dragnet-ransomware-2026-1082 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 591337a9-5022-507b-8966-3917ea72d884

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
