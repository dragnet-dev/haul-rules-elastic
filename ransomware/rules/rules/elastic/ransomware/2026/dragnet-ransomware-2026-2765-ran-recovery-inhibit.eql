// Dragnet [Ransomware]: dragnet-ransomware-2026-2765 — Recovery Inhibition (beast)
// Status: test | Level: high | ID: 9a0b8a09-b62f-52c1-9a7d-f76cccf2742a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
