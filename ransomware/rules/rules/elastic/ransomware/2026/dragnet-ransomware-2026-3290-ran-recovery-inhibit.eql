// Dragnet [Ransomware]: dragnet-ransomware-2026-3290 — Recovery Inhibition (lynx)
// Status: stable | Level: high | ID: 8a1d8c10-de47-5bf1-b9de-946e03623a67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
