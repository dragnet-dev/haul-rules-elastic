// Dragnet [Ransomware]: dragnet-ransomware-2026-0022 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b25c0dae-5f64-5507-8082-d60ff5ffa20e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
