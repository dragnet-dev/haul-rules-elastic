// Dragnet [Ransomware]: dragnet-ransomware-2026-2401 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: ba9a9540-ecb8-5310-8b7a-4564437a3cfa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
