// Dragnet [Ransomware]: dragnet-ransomware-2026-0930 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: a671c7f2-eb09-5d6d-bfc2-e230e7278e7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
