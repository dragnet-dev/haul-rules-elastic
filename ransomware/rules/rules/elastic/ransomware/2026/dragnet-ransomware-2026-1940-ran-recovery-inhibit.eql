// Dragnet [Ransomware]: dragnet-ransomware-2026-1940 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 063bf391-daad-50dc-a3e5-65293828f34d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
