// Dragnet [Ransomware]: dragnet-ransomware-2026-0892 — Recovery Inhibition (termite)
// Status: stable | Level: high | ID: a424d32f-afa5-509b-bea7-7aeac83fa439

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
