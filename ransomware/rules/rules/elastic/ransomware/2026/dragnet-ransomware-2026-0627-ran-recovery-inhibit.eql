// Dragnet [Ransomware]: dragnet-ransomware-2026-0627 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: cdca02bc-cd05-5c19-830f-bdc175bc1551

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
