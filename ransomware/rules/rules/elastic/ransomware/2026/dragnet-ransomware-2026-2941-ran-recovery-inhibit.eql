// Dragnet [Ransomware]: dragnet-ransomware-2026-2941 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 4e302b93-f786-5830-91a0-ab028eb47665

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
