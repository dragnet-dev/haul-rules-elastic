// Dragnet [Ransomware]: dragnet-ransomware-2026-3260 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 0262df72-7b75-5d4b-b575-c6c3561bd6de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
