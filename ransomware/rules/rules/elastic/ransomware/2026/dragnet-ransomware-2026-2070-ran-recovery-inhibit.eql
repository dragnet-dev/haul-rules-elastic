// Dragnet [Ransomware]: dragnet-ransomware-2026-2070 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 922c9c73-a1fd-5373-9629-b5bc69f052ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
