// Dragnet [Ransomware]: dragnet-ransomware-2026-1057 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: c6b6b7ac-8f47-51a8-8872-e48b2e77598c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
