// Dragnet [Ransomware]: dragnet-ransomware-2026-2915 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 25b0f5bd-bf71-5d47-bcfc-33945834ab0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
