// Dragnet [Ransomware]: dragnet-ransomware-2026-2116 — Recovery Inhibition (termite)
// Status: test | Level: high | ID: 1a12ed81-4ec8-5828-b196-743332839f4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
