// Dragnet [Ransomware]: dragnet-ransomware-2026-0941 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 53c0850c-db80-59cc-abbf-32340570d298

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
