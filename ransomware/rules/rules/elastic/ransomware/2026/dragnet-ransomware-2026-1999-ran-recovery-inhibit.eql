// Dragnet [Ransomware]: dragnet-ransomware-2026-1999 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0eac8827-c0f9-5ae1-bfcb-d0ae4d34e0d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
