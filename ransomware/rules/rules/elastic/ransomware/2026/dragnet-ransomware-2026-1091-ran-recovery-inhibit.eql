// Dragnet [Ransomware]: dragnet-ransomware-2026-1091 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 0d8807b8-7601-591f-97a9-44e9ec68ce50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
