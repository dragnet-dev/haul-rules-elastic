// Dragnet [Ransomware]: dragnet-ransomware-2026-2379 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 0f6abefa-ef05-55f6-965d-94c6a7119eaa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
