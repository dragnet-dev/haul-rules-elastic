// Dragnet [Ransomware]: dragnet-ransomware-2026-2538 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 305c40ac-4048-511e-bb23-751b2ff72285

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
