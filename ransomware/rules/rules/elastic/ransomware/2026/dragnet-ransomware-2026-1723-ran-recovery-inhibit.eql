// Dragnet [Ransomware]: dragnet-ransomware-2026-1723 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5e06a095-f5c1-5cfc-867d-d72ad8d1d4a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
