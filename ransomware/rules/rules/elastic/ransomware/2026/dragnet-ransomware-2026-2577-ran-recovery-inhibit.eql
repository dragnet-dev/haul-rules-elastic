// Dragnet [Ransomware]: dragnet-ransomware-2026-2577 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: cafe76f0-a07f-5148-bb43-758fad9ca0a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
