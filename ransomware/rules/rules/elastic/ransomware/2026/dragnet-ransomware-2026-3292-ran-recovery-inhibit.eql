// Dragnet [Ransomware]: dragnet-ransomware-2026-3292 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4fd9a0f2-633f-53b6-b6f4-89faf571469c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
