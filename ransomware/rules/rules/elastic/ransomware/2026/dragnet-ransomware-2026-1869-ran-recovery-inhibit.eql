// Dragnet [Ransomware]: dragnet-ransomware-2026-1869 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: a7ca662c-b718-5098-a710-d4368d4a7565

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
