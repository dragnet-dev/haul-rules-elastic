// Dragnet [Ransomware]: dragnet-ransomware-2026-1534 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 298ab9cb-4b80-5195-8807-24fb5cbc99e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
