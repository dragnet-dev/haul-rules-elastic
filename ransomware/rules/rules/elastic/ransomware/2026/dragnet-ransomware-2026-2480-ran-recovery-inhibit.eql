// Dragnet [Ransomware]: dragnet-ransomware-2026-2480 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 039f8458-6ea5-5cca-98c8-6e9f62f7bf77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
