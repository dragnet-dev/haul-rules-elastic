// Dragnet [Ransomware]: dragnet-ransomware-2026-2241 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 1e62400d-0b21-5758-ae5f-b97307a5d248

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
