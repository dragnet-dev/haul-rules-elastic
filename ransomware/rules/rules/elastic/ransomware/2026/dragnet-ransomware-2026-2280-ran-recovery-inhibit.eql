// Dragnet [Ransomware]: dragnet-ransomware-2026-2280 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a96ea14a-8fa1-57cc-b2d7-e3c840aed895

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
