// Dragnet [Ransomware]: dragnet-ransomware-2026-3189 — Recovery Inhibition (rhysida)
// Status: test | Level: high | ID: 98d15c65-2d32-50b4-a587-75394172b86a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
