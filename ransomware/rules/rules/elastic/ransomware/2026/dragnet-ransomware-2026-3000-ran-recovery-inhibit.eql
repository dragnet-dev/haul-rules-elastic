// Dragnet [Ransomware]: dragnet-ransomware-2026-3000 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 93670c5e-6f53-5d1a-be5c-f755e79d81db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
