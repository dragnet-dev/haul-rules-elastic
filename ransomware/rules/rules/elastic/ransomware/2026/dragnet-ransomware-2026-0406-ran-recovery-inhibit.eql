// Dragnet [Ransomware]: dragnet-ransomware-2026-0406 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 994e20fb-9579-5600-8d1b-eb8b6ea1c2a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
