// Dragnet [Ransomware]: dragnet-ransomware-2026-2058 — Recovery Inhibition (vect)
// Status: deprecated | Level: high | ID: 3e60afab-7f0e-5a26-9f7f-b4d30398dd25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
