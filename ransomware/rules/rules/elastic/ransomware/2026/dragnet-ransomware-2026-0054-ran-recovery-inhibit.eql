// Dragnet [Ransomware]: dragnet-ransomware-2026-0054 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 3bd28943-9813-5c41-984c-910db724eb3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
