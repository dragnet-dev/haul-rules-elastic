// Dragnet [Ransomware]: dragnet-ransomware-2026-2898 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 0bf35ef5-5c6b-5b82-be0b-fb7cb3aa7cda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
