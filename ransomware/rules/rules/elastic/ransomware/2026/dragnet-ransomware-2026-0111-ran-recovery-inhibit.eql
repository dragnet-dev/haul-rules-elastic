// Dragnet [Ransomware]: dragnet-ransomware-2026-0111 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 6c113c67-03b6-5a4f-93d6-fd118288bc52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
