// Dragnet [Ransomware]: dragnet-ransomware-2026-3166 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 635a33b8-5a1d-5f16-8fed-d7679eec388e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
