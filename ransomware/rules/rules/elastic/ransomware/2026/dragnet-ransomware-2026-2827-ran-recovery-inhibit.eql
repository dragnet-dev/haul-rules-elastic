// Dragnet [Ransomware]: dragnet-ransomware-2026-2827 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: ba242b32-995d-558d-ae73-fb894d8cdbaf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
