// Dragnet [Ransomware]: dragnet-ransomware-2026-0631 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: 88fda6f3-3c40-58a6-99a4-c2a425d9a83c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
