// Dragnet [Ransomware]: dragnet-ransomware-2026-0554 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 58acdd41-3da9-50e4-bacb-4404975be836

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
