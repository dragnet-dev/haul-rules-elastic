// Dragnet [Ransomware]: dragnet-ransomware-2026-2200 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 5ae1a308-3ac8-59e9-a0b7-d6a3bf68f351

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
