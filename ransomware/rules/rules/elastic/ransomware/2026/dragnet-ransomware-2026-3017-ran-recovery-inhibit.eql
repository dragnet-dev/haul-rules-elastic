// Dragnet [Ransomware]: dragnet-ransomware-2026-3017 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 946bccb0-15ad-50fd-a062-2c54f56bb147

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
