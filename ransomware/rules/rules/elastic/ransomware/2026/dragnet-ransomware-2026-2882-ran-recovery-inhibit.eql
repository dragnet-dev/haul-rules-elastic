// Dragnet [Ransomware]: dragnet-ransomware-2026-2882 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 109fcd3c-e264-5c0f-ac18-380c62d67b04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
