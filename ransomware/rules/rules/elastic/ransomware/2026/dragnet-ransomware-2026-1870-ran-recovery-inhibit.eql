// Dragnet [Ransomware]: dragnet-ransomware-2026-1870 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: bb0ad25c-d446-58b6-973f-bcd1e66cd0ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
