// Dragnet [Ransomware]: dragnet-ransomware-2026-1791 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: cdf2e4b1-f8b7-56cb-b60a-efd378ffd2d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
