// Dragnet [Ransomware]: dragnet-ransomware-2026-0068 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: d20dcf99-cd8b-5519-89a7-ce9bcef19816

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
