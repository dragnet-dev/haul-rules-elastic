// Dragnet [Ransomware]: dragnet-ransomware-2026-0566 — Recovery Inhibition (fulcrumsec)
// Status: stable | Level: high | ID: 6ec79c62-dedb-5cec-9a35-aa367b30f113

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
