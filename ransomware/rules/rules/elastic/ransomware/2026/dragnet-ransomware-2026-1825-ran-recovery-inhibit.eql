// Dragnet [Ransomware]: dragnet-ransomware-2026-1825 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: dc6d7051-5185-56e8-9eb6-50e3ae0169f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
