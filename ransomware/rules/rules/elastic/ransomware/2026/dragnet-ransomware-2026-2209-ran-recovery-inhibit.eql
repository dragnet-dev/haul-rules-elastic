// Dragnet [Ransomware]: dragnet-ransomware-2026-2209 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 6b11b381-32cc-5bcd-9657-e9674d73cbdd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
