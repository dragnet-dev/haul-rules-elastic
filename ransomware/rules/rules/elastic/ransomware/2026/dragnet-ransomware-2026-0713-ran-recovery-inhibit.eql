// Dragnet [Ransomware]: dragnet-ransomware-2026-0713 — Recovery Inhibition (pear)
// Status: stable | Level: high | ID: 4d7a02e5-f8ad-5267-af9e-8333aec6536f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
