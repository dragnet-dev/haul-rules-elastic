// Dragnet [Ransomware]: dragnet-ransomware-2026-1833 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 0bca283d-4568-58b1-a10a-861036951e48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
