// Dragnet [Ransomware]: dragnet-ransomware-2026-0742 — Recovery Inhibition (BrainCipher)
// Status: stable | Level: high | ID: 30e4aacb-73ea-5db2-99e4-fce843000412

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
