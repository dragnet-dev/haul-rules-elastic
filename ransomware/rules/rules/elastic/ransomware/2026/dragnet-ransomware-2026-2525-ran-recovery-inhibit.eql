// Dragnet [Ransomware]: dragnet-ransomware-2026-2525 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 27d3e84a-4966-5e75-addc-49e1c3d5e60d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
