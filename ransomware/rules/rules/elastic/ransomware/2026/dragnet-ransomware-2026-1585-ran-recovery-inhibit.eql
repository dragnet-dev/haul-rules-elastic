// Dragnet [Ransomware]: dragnet-ransomware-2026-1585 — Recovery Inhibition (aurora)
// Status: stable | Level: high | ID: 83f07466-1b28-5d08-a5c8-12846427c9ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
