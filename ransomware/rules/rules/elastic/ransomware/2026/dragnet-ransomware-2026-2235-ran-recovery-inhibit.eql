// Dragnet [Ransomware]: dragnet-ransomware-2026-2235 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: ee84171e-6956-544c-9965-4d70e254c523

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
