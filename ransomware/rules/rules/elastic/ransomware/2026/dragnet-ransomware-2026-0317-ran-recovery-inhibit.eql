// Dragnet [Ransomware]: dragnet-ransomware-2026-0317 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 4a3e5a29-6569-5c6b-8c21-3185e4c38e3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
