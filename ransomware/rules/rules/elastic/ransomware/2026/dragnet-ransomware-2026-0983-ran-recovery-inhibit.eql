// Dragnet [Ransomware]: dragnet-ransomware-2026-0983 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 2bf1a8a1-de75-5063-85e9-a060b3e3f00d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
