// Dragnet [Ransomware]: dragnet-ransomware-2026-1636 — Recovery Inhibition (titan)
// Status: stable | Level: high | ID: a70a5ff0-b52a-55cd-808f-a007e75b79f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
