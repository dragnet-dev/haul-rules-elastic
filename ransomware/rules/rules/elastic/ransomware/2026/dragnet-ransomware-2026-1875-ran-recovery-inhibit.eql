// Dragnet [Ransomware]: dragnet-ransomware-2026-1875 — Recovery Inhibition (bravox)
// Status: stable | Level: high | ID: bf9d129f-4d32-5fa2-8f80-5e4be74cb6f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
