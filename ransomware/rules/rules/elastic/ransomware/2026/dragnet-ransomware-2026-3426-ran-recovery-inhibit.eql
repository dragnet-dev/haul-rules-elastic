// Dragnet [Ransomware]: dragnet-ransomware-2026-3426 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 2eb61264-b647-59f0-840a-f37b5fcacf86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
