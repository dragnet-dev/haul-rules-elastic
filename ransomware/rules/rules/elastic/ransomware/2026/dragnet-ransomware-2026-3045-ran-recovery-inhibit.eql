// Dragnet [Ransomware]: dragnet-ransomware-2026-3045 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 911ff7a2-5eeb-5f58-96b1-28700eaf2b0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
