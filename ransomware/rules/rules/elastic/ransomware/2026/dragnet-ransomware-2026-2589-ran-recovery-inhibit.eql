// Dragnet [Ransomware]: dragnet-ransomware-2026-2589 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: c9f1e978-f4e9-55cf-a441-72129c494786

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
