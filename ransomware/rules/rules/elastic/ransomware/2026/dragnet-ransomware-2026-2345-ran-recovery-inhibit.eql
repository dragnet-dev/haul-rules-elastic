// Dragnet [Ransomware]: dragnet-ransomware-2026-2345 — Recovery Inhibition (pear)
// Status: stable | Level: high | ID: 7431f07e-bbca-508b-bf12-8827ca174c03

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
