// Dragnet [Ransomware]: dragnet-ransomware-2026-3336 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: f3ad505b-00e2-508e-964f-cb4209a5e324

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
