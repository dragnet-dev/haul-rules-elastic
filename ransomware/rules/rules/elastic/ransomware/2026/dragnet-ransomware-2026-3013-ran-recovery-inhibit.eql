// Dragnet [Ransomware]: dragnet-ransomware-2026-3013 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: f1394532-95f7-5f8b-9bc0-ad13907f8a63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
