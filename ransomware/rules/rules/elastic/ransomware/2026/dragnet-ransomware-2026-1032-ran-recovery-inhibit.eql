// Dragnet [Ransomware]: dragnet-ransomware-2026-1032 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 02cb6e22-631a-5605-84b7-81a40f5cce0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
