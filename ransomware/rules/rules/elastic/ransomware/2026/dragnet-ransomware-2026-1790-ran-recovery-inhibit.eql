// Dragnet [Ransomware]: dragnet-ransomware-2026-1790 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: 5ac80685-9751-58f2-8689-542ac1b254a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
