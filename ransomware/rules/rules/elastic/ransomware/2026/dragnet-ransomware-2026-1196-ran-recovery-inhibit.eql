// Dragnet [Ransomware]: dragnet-ransomware-2026-1196 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: d744b56a-db20-5b54-be3f-7ad69e7bc3f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
