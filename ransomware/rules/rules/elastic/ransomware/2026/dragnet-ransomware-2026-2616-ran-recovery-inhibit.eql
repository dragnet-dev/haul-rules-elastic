// Dragnet [Ransomware]: dragnet-ransomware-2026-2616 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: f0129354-ba6d-5417-9e06-cb4ad5c3acbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
