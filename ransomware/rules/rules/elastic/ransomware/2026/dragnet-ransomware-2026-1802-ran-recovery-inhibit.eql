// Dragnet [Ransomware]: dragnet-ransomware-2026-1802 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: dd2a9fa7-4110-5e17-ab59-885123c64aff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
