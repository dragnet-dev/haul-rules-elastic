// Dragnet [Ransomware]: dragnet-ransomware-2026-2202 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 92d7e3e0-57b4-5c66-bb7c-a121e086eed6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
