// Dragnet [Ransomware]: dragnet-ransomware-2026-3175 — Recovery Inhibition (fulcrumsec)
// Status: stable | Level: high | ID: e6d57061-6885-5745-85b7-cdb3b8596ba0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
