// Dragnet [Ransomware]: dragnet-ransomware-2026-0781 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 40a6dd87-55da-5b3c-a24b-606a98819b92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
