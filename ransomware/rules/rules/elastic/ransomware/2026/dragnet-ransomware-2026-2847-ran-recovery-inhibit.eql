// Dragnet [Ransomware]: dragnet-ransomware-2026-2847 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 1a8e6f54-4378-5edb-887c-5a51495101c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
