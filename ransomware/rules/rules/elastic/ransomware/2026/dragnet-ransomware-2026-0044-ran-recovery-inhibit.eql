// Dragnet [Ransomware]: dragnet-ransomware-2026-0044 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 3cd74a8a-23d4-533c-a3f1-9f701024d269

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
