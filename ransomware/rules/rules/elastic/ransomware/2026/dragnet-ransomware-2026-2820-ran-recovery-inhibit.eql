// Dragnet [Ransomware]: dragnet-ransomware-2026-2820 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 4fc9089b-453d-52f1-86d8-145b8b7d83e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
