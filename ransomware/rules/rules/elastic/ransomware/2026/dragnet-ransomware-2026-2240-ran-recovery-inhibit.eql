// Dragnet [Ransomware]: dragnet-ransomware-2026-2240 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 7de5668b-882a-5c55-b03f-ca7bc6412553

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
