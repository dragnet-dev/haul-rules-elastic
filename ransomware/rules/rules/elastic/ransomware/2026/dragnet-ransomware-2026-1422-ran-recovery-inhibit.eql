// Dragnet [Ransomware]: dragnet-ransomware-2026-1422 — Recovery Inhibition (gunra)
// Status: deprecated | Level: high | ID: 4e984fb6-e988-5594-9a48-c1a1d7e78f22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
