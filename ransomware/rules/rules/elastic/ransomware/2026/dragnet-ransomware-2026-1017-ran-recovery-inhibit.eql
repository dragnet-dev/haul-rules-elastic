// Dragnet [Ransomware]: dragnet-ransomware-2026-1017 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 237cb281-c817-5510-98ff-d664984622d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
