// Dragnet [Ransomware]: dragnet-ransomware-2026-2477 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 5a07d188-11e6-58b9-beaf-406a18acd4a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
