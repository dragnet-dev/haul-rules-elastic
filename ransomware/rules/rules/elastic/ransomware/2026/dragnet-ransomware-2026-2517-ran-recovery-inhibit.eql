// Dragnet [Ransomware]: dragnet-ransomware-2026-2517 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 8097cfb8-aaf4-5f81-90d5-8f6ce63b89c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
