// Dragnet [Ransomware]: dragnet-ransomware-2026-2885 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 21a849e0-ca7d-511f-85bb-1e4a6f909c75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
