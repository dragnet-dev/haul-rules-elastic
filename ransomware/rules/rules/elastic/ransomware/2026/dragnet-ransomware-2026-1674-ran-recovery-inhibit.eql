// Dragnet [Ransomware]: dragnet-ransomware-2026-1674 — Recovery Inhibition (payoutsking)
// Status: stable | Level: high | ID: e29d934d-00da-5271-a284-52afe70dafeb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
