// Dragnet [Ransomware]: dragnet-ransomware-2026-1262 — Recovery Inhibition (krybit)
// Status: stable | Level: high | ID: fa4e0a10-3379-56c4-a94f-d803eb94364f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
