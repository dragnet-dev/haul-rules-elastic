// Dragnet [Ransomware]: dragnet-ransomware-2026-0697 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 3f3a7640-32b1-5f7c-9788-1035b8a6ed0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
