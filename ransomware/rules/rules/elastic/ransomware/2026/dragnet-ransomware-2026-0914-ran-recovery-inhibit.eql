// Dragnet [Ransomware]: dragnet-ransomware-2026-0914 — Recovery Inhibition (AuditTeam)
// Status: stable | Level: high | ID: d78753e7-314c-557b-8dcb-2be8eb819417

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
