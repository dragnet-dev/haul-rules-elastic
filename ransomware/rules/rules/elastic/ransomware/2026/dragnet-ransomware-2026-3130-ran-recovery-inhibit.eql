// Dragnet [Ransomware]: dragnet-ransomware-2026-3130 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 7746684c-e937-5c4a-9fa6-f77519618ae3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
