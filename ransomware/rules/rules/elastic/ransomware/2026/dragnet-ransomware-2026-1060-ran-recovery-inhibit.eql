// Dragnet [Ransomware]: dragnet-ransomware-2026-1060 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: be0042e4-2fbb-5457-84ea-2c8fa44bff48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
