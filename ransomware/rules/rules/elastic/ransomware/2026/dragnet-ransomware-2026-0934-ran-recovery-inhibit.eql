// Dragnet [Ransomware]: dragnet-ransomware-2026-0934 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: ca1a1fc7-ecd8-5197-83dd-de4c7a3e5bbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
