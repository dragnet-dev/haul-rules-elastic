// Dragnet [Ransomware]: dragnet-ransomware-2026-2008 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: dee240b6-430e-59b3-a539-20bf70190455

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
