// Dragnet [Ransomware]: dragnet-ransomware-2026-1099 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 193d8092-d38f-5dbe-8ac4-8b7e514dad4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
