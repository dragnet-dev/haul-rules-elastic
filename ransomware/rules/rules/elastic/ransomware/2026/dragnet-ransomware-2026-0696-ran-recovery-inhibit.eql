// Dragnet [Ransomware]: dragnet-ransomware-2026-0696 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: d8b05f24-5680-52c4-a234-5dffce4fa97e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
