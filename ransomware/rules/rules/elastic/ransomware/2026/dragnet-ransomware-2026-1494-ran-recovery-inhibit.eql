// Dragnet [Ransomware]: dragnet-ransomware-2026-1494 — Recovery Inhibition (anubis)
// Status: stable | Level: high | ID: f2392cd5-5d4a-59a8-8896-75c633baed38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
