// Dragnet [Ransomware]: dragnet-ransomware-2026-2520 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 9b757224-4e53-5c6b-82c9-27fb4755a85b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
