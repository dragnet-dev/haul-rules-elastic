// Dragnet [Ransomware]: dragnet-ransomware-2026-0014 — Recovery Inhibition (tengu)
// Status: stable | Level: high | ID: 443e07da-6e9e-5b3f-9886-07c4ec5123c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
