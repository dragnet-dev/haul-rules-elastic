// Dragnet [Ransomware]: dragnet-ransomware-2026-2046 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: aed13281-baba-58f0-a679-f20fa3f7abe0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
