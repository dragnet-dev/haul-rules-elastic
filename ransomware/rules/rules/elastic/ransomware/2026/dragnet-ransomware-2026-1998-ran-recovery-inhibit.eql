// Dragnet [Ransomware]: dragnet-ransomware-2026-1998 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 6e544610-5095-5543-ac47-4dfad3f05816

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
