// Dragnet [Ransomware]: dragnet-ransomware-2026-1709 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: b6d5cdf5-441f-51fb-9383-ad9ecac5f7fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
