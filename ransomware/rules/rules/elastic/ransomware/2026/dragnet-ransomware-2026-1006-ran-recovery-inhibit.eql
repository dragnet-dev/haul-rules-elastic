// Dragnet [Ransomware]: dragnet-ransomware-2026-1006 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 6af5ce0c-387f-5e72-aedf-a5d3e303abbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
