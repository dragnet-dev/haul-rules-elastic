// Dragnet [Ransomware]: dragnet-ransomware-2026-0581 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 21be3451-d45a-5349-81fc-fa673075e737

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
