// Dragnet [Ransomware]: dragnet-ransomware-2026-3044 — Recovery Inhibition (mnt6)
// Status: stable | Level: high | ID: ab085cad-60af-5f7a-9abb-68def659fbbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
