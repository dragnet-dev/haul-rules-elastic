// Dragnet [Ransomware]: dragnet-ransomware-2026-0472 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 8d8d8d4b-d1dc-56af-bd0e-94c78c233eae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
