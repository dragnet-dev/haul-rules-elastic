// Dragnet [Ransomware]: dragnet-ransomware-2026-1700 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 81ea90ab-668b-5dd1-b278-7a0448864781

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
