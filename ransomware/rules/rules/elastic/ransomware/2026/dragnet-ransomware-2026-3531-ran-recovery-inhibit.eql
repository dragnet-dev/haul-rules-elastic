// Dragnet [Ransomware]: dragnet-ransomware-2026-3531 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: d3a066da-d46b-5a01-b40f-6760eda0cf96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
