// Dragnet [Ransomware]: dragnet-ransomware-2026-0019 — Recovery Inhibition (lynx)
// Status: stable | Level: high | ID: 76c50c1c-379d-574a-ab80-74f7db20cd64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
