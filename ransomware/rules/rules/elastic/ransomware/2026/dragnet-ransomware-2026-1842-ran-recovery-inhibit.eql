// Dragnet [Ransomware]: dragnet-ransomware-2026-1842 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: af0b09f5-9ed6-5ac9-b5a3-f2efb1bb5504

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
