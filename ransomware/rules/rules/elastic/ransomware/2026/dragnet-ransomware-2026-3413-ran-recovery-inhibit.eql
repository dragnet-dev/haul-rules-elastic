// Dragnet [Ransomware]: dragnet-ransomware-2026-3413 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 61c46636-651c-5d69-98ee-53ab5e7aed8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
