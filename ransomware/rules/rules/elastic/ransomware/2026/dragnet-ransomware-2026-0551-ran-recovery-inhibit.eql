// Dragnet [Ransomware]: dragnet-ransomware-2026-0551 — Recovery Inhibition (worldleaks)
// Status: stable | Level: high | ID: 4815b789-f4b1-5426-bf41-de6bd00e8caa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
