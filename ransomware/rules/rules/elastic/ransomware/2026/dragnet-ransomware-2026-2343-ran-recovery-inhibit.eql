// Dragnet [Ransomware]: dragnet-ransomware-2026-2343 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 0a201909-f4d8-5ea2-9879-91053c2728a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
