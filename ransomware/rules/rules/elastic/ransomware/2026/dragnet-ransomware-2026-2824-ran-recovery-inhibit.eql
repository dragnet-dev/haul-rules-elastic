// Dragnet [Ransomware]: dragnet-ransomware-2026-2824 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 8d423967-52bd-5679-957b-eae8fd818124

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
