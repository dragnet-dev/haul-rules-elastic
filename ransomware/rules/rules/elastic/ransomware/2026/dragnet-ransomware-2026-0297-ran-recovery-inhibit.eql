// Dragnet [Ransomware]: dragnet-ransomware-2026-0297 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 1eb7e10a-fe42-5e83-9e2d-3fc95c36da6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
