// Dragnet [Ransomware]: dragnet-ransomware-2026-2210 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 36b209ae-33c8-5ed4-811a-02c9404029f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
