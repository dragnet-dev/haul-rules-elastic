// Dragnet [Ransomware]: dragnet-ransomware-2026-1469 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 0227b91f-d1d2-5489-9604-aa3faf47bb9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
