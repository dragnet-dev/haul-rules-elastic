// Dragnet [Ransomware]: dragnet-ransomware-2026-0578 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 83a5bd72-b492-5614-aaaf-7604294b3579

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
