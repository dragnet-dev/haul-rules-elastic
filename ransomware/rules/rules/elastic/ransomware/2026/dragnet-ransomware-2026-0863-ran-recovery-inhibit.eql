// Dragnet [Ransomware]: dragnet-ransomware-2026-0863 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 1c585770-2741-50ad-9c1e-43a9e82c2460

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
