// Dragnet [Ransomware]: dragnet-ransomware-2026-1108 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 6811def3-2c87-5b77-9637-51882ea6dd83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
