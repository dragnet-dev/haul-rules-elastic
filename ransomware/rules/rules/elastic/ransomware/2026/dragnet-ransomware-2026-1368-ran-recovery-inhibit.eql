// Dragnet [Ransomware]: dragnet-ransomware-2026-1368 — Recovery Inhibition (krybit)
// Status: stable | Level: high | ID: 036ec3e8-efac-5bff-9838-efaecf361832

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
