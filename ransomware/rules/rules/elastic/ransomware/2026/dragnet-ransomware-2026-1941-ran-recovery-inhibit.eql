// Dragnet [Ransomware]: dragnet-ransomware-2026-1941 — Recovery Inhibition (obscura)
// Status: deprecated | Level: high | ID: d956cacd-e1e3-53b5-bb3d-ff0a8eab039b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
