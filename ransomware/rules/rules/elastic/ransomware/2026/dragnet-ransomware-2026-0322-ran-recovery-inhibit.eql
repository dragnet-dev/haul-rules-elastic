// Dragnet [Ransomware]: dragnet-ransomware-2026-0322 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: cb331ccd-f665-5e8b-863c-cb37a08df94d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
