// Dragnet [Ransomware]: dragnet-ransomware-2026-2148 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: a25a00c9-e308-51ab-a9eb-4ca6a8d58b72

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
