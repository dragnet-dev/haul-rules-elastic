// Dragnet [Ransomware]: dragnet-ransomware-2026-1272 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 0fe6971b-f8ec-5a51-8ffb-a22d1c849bf7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
