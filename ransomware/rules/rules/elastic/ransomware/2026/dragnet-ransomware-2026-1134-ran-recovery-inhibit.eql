// Dragnet [Ransomware]: dragnet-ransomware-2026-1134 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 82ac114c-6c36-5a6d-a156-2e4de7a58df2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
