// Dragnet [Ransomware]: dragnet-ransomware-2026-1608 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e4d50e5c-2814-5f3c-a7e2-6c8d80c5fb68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
