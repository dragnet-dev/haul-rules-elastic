// Dragnet [Ransomware]: dragnet-ransomware-2026-0931 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: a9e4635a-a508-5c00-a2ff-28c1e4bf33c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
