// Dragnet [Ransomware]: dragnet-ransomware-2026-2973 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 8bd7916f-0aa9-524e-8484-9d67863ca955

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
