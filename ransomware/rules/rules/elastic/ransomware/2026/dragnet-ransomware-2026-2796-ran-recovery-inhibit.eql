// Dragnet [Ransomware]: dragnet-ransomware-2026-2796 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: f0e7b0de-d4fc-59eb-adca-bc339c9396a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
