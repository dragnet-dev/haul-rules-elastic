// Dragnet [Ransomware]: dragnet-ransomware-2026-2844 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bbbac330-5742-5c47-b191-58936b5329ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
