// Dragnet [Ransomware]: dragnet-ransomware-2026-1267 — Recovery Inhibition (netrunner)
// Status: stable | Level: high | ID: dad1ae08-d362-5052-a41a-297cfe522ce7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
