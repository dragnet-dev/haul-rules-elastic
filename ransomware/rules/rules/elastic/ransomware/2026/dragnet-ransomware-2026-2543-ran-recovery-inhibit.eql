// Dragnet [Ransomware]: dragnet-ransomware-2026-2543 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: aa6d4b4d-0a70-56af-86e7-1458e13209d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
