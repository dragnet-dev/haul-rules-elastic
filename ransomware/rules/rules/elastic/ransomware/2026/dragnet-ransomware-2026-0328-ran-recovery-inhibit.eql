// Dragnet [Ransomware]: dragnet-ransomware-2026-0328 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: 6bef7882-f677-52f9-8450-34f37164fbaa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
