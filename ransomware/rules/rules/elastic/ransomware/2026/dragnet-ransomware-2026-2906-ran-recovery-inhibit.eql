// Dragnet [Ransomware]: dragnet-ransomware-2026-2906 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: cd88daf6-d0ec-58ea-aea0-0cc5b471a54f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
