// Dragnet [Ransomware]: dragnet-ransomware-2026-3397 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: f9d95681-e745-51f7-89c6-f7e8155f7101

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
