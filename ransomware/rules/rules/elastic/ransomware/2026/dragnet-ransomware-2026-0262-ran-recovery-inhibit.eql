// Dragnet [Ransomware]: dragnet-ransomware-2026-0262 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 8ff79045-637e-5c0d-a4da-4a34398705d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
