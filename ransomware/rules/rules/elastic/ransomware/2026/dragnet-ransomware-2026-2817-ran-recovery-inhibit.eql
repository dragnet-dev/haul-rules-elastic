// Dragnet [Ransomware]: dragnet-ransomware-2026-2817 — Recovery Inhibition (ALP-001)
// Status: stable | Level: high | ID: 7b8bc365-1722-5d5f-8ac0-7886ca99d967

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
