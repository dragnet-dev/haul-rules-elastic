// Dragnet [Ransomware]: dragnet-ransomware-2026-0986 — Recovery Inhibition (lynx)
// Status: stable | Level: high | ID: bd86197d-9013-5580-9b80-b4dcf572267f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
