// Dragnet [Ransomware]: dragnet-ransomware-2026-2648 — Recovery Inhibition (m3rx)
// Status: stable | Level: high | ID: f0677427-ce32-5286-8d88-890d487ce128

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
