// Dragnet [Ransomware]: dragnet-ransomware-2026-0170 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 761bb56f-5686-5354-a467-071216cfebf3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
