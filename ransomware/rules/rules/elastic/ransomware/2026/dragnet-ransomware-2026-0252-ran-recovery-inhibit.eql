// Dragnet [Ransomware]: dragnet-ransomware-2026-0252 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: b98ccb9f-1752-531f-a05a-e07ef70f9a6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
