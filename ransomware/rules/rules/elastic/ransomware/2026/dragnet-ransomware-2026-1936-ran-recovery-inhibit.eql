// Dragnet [Ransomware]: dragnet-ransomware-2026-1936 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: bee2d72e-ac66-5d10-b08d-bd5e7872cf33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
