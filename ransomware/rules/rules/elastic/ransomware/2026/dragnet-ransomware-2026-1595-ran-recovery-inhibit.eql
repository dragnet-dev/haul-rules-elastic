// Dragnet [Ransomware]: dragnet-ransomware-2026-1595 — Recovery Inhibition (bravox)
// Status: test | Level: high | ID: ca08af04-7722-5a7f-9217-5f5235764405

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
