// Dragnet [Ransomware]: dragnet-ransomware-2026-0094 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 32cf4647-2e1a-51c6-8d68-fea6643750e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
