// Dragnet [Ransomware]: dragnet-ransomware-2026-1606 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: b4dc4de9-d7be-5a02-82ce-ca35ce9bdac0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
