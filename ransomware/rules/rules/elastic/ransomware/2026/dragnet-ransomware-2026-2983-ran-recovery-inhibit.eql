// Dragnet [Ransomware]: dragnet-ransomware-2026-2983 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 4abb14cb-63e9-58d2-a42f-9147715535a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
