// Dragnet [Ransomware]: dragnet-ransomware-2026-2447 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 5adadbbd-1dc3-5f70-8b9c-35a553a81ad8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
