// Dragnet [Ransomware]: dragnet-ransomware-2026-2638 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cc20c4ee-310b-5731-a336-baa75335913a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
