// Dragnet [Ransomware]: dragnet-ransomware-2026-2291 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 063750f3-57dd-51eb-867b-52a48728a344

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
