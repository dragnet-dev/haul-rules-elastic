// Dragnet [Ransomware]: dragnet-ransomware-2026-1206 — Recovery Inhibition (insomnia)
// Status: test | Level: high | ID: 156e2a90-8243-51c6-81a1-63b7a6e8f782

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
