// Dragnet [Ransomware]: dragnet-ransomware-2026-0652 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b4dbfeb3-ee76-54c1-b878-c3506d02e465

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
