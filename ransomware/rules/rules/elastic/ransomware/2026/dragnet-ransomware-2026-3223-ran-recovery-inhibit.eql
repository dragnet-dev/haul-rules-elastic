// Dragnet [Ransomware]: dragnet-ransomware-2026-3223 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 86b5062b-861c-5b55-860a-bb498ad0a96b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
