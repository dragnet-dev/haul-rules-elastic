// Dragnet [Ransomware]: dragnet-ransomware-2026-1852 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 073e8289-9b5a-5f8f-b367-aba52b3dcbab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
