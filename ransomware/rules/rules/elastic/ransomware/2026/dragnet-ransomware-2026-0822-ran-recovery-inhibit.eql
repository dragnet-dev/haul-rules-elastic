// Dragnet [Ransomware]: dragnet-ransomware-2026-0822 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: fdd48b60-f63d-58fc-b90f-29ebfda68c3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
