// Dragnet [Ransomware]: dragnet-ransomware-2026-0952 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: bd84316d-cfee-5b68-9574-f296d74ec0c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
