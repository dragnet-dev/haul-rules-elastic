// Dragnet [Ransomware]: dragnet-ransomware-2026-3440 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: e7fdadb4-5225-5b86-bd3e-05457f2a8ee5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
