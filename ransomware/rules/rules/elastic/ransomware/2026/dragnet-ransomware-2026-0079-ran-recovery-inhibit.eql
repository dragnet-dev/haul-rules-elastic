// Dragnet [Ransomware]: dragnet-ransomware-2026-0079 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: f40a0ac5-d491-5ade-865f-673791a86900

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
