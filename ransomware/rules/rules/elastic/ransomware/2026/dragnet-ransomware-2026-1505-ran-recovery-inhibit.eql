// Dragnet [Ransomware]: dragnet-ransomware-2026-1505 — Recovery Inhibition (genesis)
// Status: stable | Level: high | ID: 6bd25122-815c-5b98-a1a9-26fff54989da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
