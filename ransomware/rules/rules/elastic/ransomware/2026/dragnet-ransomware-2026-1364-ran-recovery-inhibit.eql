// Dragnet [Ransomware]: dragnet-ransomware-2026-1364 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: 51412685-3514-531c-9131-fd1bbdb9151b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
