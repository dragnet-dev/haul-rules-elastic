// Dragnet [Ransomware]: dragnet-ransomware-2026-1296 — Recovery Inhibition (anubis)
// Status: stable | Level: high | ID: 399ac663-cacc-5e4b-9950-a05bd53f43e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
