// Dragnet [Ransomware]: dragnet-ransomware-2026-2718 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 3a92117b-a30a-5d34-a417-4b9b55a49694

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
