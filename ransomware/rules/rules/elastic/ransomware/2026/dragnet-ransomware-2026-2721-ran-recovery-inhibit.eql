// Dragnet [Ransomware]: dragnet-ransomware-2026-2721 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 2379cfd0-bd7e-5a9d-bd1c-d528bdcd8a2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
