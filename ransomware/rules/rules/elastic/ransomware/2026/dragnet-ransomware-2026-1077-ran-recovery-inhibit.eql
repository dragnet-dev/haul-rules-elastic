// Dragnet [Ransomware]: dragnet-ransomware-2026-1077 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: b694075f-588b-5098-a177-e9697b3438be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
