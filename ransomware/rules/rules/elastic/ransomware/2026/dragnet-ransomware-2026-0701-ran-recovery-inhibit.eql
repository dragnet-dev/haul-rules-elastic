// Dragnet [Ransomware]: dragnet-ransomware-2026-0701 — Recovery Inhibition (vect)
// Status: deprecated | Level: high | ID: f52e804a-8c98-58e3-ad49-187e91b20da7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
