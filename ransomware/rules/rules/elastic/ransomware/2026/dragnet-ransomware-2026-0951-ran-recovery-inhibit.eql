// Dragnet [Ransomware]: dragnet-ransomware-2026-0951 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 14468f8f-9f63-5ec2-9948-9d4d9244b7b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
