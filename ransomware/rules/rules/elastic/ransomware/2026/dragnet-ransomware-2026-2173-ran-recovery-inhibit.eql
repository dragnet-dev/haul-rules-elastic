// Dragnet [Ransomware]: dragnet-ransomware-2026-2173 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: c95c6680-aef9-5409-828c-5304d8319db4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
