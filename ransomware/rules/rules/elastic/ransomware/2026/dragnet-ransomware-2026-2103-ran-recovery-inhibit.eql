// Dragnet [Ransomware]: dragnet-ransomware-2026-2103 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 645b2bad-ab0d-57f5-b78e-9e84ee8cf4c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
