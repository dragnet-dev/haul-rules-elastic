// Dragnet [Ransomware]: dragnet-ransomware-2026-3009 — Recovery Inhibition (pear)
// Status: stable | Level: high | ID: e93189da-1251-536e-b1c7-14bcedb8602a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
