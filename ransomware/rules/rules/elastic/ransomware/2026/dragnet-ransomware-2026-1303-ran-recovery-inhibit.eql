// Dragnet [Ransomware]: dragnet-ransomware-2026-1303 — Recovery Inhibition (bravox)
// Status: stable | Level: high | ID: 66ebe6e8-4814-51e8-9350-69bbad4946c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
