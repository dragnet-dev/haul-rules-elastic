// Dragnet [Ransomware]: dragnet-ransomware-2026-2534 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: f098d055-4347-5e3f-9982-7ea888ff85ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
