// Dragnet [Ransomware]: dragnet-ransomware-2026-2030 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 120758d0-474b-5569-9bed-4f9f47f5b1bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
