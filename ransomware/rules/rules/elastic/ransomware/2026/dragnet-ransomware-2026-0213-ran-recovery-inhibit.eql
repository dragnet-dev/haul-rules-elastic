// Dragnet [Ransomware]: dragnet-ransomware-2026-0213 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: ebe88288-25fe-51a0-bee9-d317a366c16c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
