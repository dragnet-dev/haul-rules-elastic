// Dragnet [Ransomware]: dragnet-ransomware-2026-2954 — Recovery Inhibition (sinobi)
// Status: stable | Level: high | ID: bac0f017-1f4d-560c-bc9c-de9891a1618d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
