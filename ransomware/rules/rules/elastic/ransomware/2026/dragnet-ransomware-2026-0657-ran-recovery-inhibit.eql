// Dragnet [Ransomware]: dragnet-ransomware-2026-0657 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: c5d5b284-2652-5305-aa5f-071de40c7836

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
