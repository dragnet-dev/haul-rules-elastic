// Dragnet [Ransomware]: dragnet-ransomware-2026-2314 — Recovery Inhibition (worldleaks)
// Status: test | Level: high | ID: 0a11d3cd-7b84-5ef9-bbbe-8318548578ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
