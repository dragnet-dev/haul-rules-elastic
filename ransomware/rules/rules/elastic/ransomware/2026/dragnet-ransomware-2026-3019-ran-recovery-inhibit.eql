// Dragnet [Ransomware]: dragnet-ransomware-2026-3019 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: cd33b16c-d015-57a0-b0b9-295fcd617ec7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
