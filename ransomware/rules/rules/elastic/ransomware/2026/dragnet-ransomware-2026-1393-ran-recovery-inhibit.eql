// Dragnet [Ransomware]: dragnet-ransomware-2026-1393 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: a42edfb8-69c3-57bd-ae1d-e0809cb87111

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
