// Dragnet [Ransomware]: dragnet-ransomware-2026-0179 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 35d53490-25cf-5a3c-a89a-c7f58e2916ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
