// Dragnet [Ransomware]: dragnet-ransomware-2026-2104 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: fb96a0be-2fd6-56f8-87e8-6c4b15537f69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
