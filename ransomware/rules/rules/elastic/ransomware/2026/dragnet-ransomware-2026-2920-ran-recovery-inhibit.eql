// Dragnet [Ransomware]: dragnet-ransomware-2026-2920 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 578fa5ea-1bcc-58f8-bfe1-e61cc6cb8da1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
