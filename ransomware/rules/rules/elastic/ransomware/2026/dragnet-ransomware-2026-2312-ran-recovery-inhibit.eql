// Dragnet [Ransomware]: dragnet-ransomware-2026-2312 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: c359a0c6-8da6-5801-95f6-b968619037f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
