// Dragnet [Ransomware]: dragnet-ransomware-2026-3390 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: b4c97c76-0e4c-5219-a83e-a7441b41a115

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
