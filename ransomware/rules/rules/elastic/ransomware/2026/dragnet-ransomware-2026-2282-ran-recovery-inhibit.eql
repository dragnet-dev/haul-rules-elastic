// Dragnet [Ransomware]: dragnet-ransomware-2026-2282 — Recovery Inhibition (krybit)
// Status: stable | Level: high | ID: a920b1b6-b3b1-50c4-91e4-57f72d9b0312

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
