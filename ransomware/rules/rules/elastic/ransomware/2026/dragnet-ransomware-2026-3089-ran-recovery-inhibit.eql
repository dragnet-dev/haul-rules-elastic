// Dragnet [Ransomware]: dragnet-ransomware-2026-3089 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 209254dd-ea7b-5ccd-b043-3dafe9e2de63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
