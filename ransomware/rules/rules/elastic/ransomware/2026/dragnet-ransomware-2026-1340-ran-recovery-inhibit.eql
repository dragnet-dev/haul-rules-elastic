// Dragnet [Ransomware]: dragnet-ransomware-2026-1340 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 8807fcd0-7287-5ecc-a403-0defad1b3fe7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
