// Dragnet [Ransomware]: dragnet-ransomware-2026-0323 — Recovery Inhibition (genesis)
// Status: stable | Level: high | ID: dc0df384-7423-566f-b932-2da2512b4efc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
