// Dragnet [Ransomware]: dragnet-ransomware-2026-0505 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 69d725c3-8b16-5088-9f51-5309fc9d4975

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
