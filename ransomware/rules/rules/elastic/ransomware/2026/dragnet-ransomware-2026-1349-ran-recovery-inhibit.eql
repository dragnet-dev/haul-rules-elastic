// Dragnet [Ransomware]: dragnet-ransomware-2026-1349 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: 4cb3ab2f-e2ca-5676-a627-9784fa5c9964

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
