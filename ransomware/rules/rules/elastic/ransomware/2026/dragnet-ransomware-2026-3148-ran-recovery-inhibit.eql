// Dragnet [Ransomware]: dragnet-ransomware-2026-3148 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: e492efef-f334-5ce1-8935-746a086affa6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
