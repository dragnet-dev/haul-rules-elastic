// Dragnet [Ransomware]: dragnet-ransomware-2026-2675 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 1dae733e-91ef-51b2-b769-ffa794dbb771

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
