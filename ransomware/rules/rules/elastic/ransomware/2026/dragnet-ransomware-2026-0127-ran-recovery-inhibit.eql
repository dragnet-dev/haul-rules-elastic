// Dragnet [Ransomware]: dragnet-ransomware-2026-0127 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a8a3803a-af91-50c0-b36b-54fc50936b71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
