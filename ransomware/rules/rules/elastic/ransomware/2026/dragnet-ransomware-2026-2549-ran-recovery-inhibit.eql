// Dragnet [Ransomware]: dragnet-ransomware-2026-2549 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 2786a308-60b8-55b3-addc-c7c752495076

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
