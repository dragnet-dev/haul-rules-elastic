// Dragnet [Ransomware]: dragnet-ransomware-2026-0894 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 2bf27339-65f1-56b9-a8f0-30d9cb9aa801

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
