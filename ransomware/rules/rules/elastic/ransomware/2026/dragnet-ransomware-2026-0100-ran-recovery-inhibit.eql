// Dragnet [Ransomware]: dragnet-ransomware-2026-0100 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 6f39e95a-e8a6-59f9-9229-41c1218a6207

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
