// Dragnet [Ransomware]: dragnet-ransomware-2026-2488 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 52db77cc-c8de-5550-b8d9-ee485f773ec8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
