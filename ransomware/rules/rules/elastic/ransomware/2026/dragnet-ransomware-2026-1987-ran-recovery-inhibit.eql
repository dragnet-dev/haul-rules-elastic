// Dragnet [Ransomware]: dragnet-ransomware-2026-1987 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 090c45de-184d-5335-a6fd-d5ed96f94b51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
