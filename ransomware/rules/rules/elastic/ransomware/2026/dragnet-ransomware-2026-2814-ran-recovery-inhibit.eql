// Dragnet [Ransomware]: dragnet-ransomware-2026-2814 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f868415c-ba9b-5ca7-838c-887dd5e8a516

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
