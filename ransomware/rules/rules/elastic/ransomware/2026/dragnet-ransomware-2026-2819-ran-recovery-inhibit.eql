// Dragnet [Ransomware]: dragnet-ransomware-2026-2819 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 5ab28a2b-5606-5fb1-9680-7b0a18daefa0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
