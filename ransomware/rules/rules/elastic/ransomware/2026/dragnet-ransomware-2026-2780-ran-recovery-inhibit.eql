// Dragnet [Ransomware]: dragnet-ransomware-2026-2780 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 47aa141f-c6ac-5f1b-ae22-1c0f10740efb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
