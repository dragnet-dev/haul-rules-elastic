// Dragnet [Ransomware]: dragnet-ransomware-2026-2556 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 4c02e51c-1d63-559b-bb77-536ec9bfc8e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
