// Dragnet [Ransomware]: dragnet-ransomware-2026-1023 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 75ee53cb-85a1-55d3-96d2-3685b2c94822

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
