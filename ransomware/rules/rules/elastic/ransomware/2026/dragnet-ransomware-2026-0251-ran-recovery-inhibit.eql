// Dragnet [Ransomware]: dragnet-ransomware-2026-0251 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 19835af6-61fc-583a-a233-8075130a2e6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
