// Dragnet [Ransomware]: dragnet-ransomware-2026-2261 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: d7fedff4-cb67-5df8-9cec-7d45a9b773f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
