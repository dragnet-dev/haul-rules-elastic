// Dragnet [Ransomware]: dragnet-ransomware-2026-2092 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: 968d2c6c-89ce-5385-bc3c-2e6ec899c2dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
