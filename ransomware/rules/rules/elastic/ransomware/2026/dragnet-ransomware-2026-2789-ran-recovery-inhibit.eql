// Dragnet [Ransomware]: dragnet-ransomware-2026-2789 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: d7dfb27c-25a7-5bd9-ae32-7fdfd58ae2b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
