// Dragnet [Ransomware]: dragnet-ransomware-2026-2566 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 8779e4db-6888-5047-b83c-a46e3583ffc0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
