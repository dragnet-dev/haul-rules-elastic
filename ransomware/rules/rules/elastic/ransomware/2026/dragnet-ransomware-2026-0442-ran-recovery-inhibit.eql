// Dragnet [Ransomware]: dragnet-ransomware-2026-0442 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: e87004be-8080-5c94-8cfe-f3b0981ba54a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
