// Dragnet [Ransomware]: dragnet-ransomware-2026-0029 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 1f1de430-1d21-5c78-a2a0-db140ba065f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
