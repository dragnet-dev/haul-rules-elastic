// Dragnet [Ransomware]: dragnet-ransomware-2026-2657 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: bd6e6c96-ea6b-5751-816d-8dd29d1c7f9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
