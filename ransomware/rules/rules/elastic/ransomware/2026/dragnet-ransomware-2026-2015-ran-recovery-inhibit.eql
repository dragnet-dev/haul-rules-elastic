// Dragnet [Ransomware]: dragnet-ransomware-2026-2015 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: d33ee1aa-7a5a-5043-b346-35688100a761

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
