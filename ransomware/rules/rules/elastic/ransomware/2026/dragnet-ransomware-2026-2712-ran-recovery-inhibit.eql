// Dragnet [Ransomware]: dragnet-ransomware-2026-2712 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: b13aa479-58aa-5646-b6b5-172a9a70f422

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
