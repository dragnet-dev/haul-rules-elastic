// Dragnet [Ransomware]: dragnet-ransomware-2026-0335 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 9e61222c-2f99-5ed4-b309-ad270d215b54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
