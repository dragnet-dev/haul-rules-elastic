// Dragnet [Ransomware]: dragnet-ransomware-2026-2745 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: e54413d1-0be5-520b-ae6f-23eae5e4956f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
