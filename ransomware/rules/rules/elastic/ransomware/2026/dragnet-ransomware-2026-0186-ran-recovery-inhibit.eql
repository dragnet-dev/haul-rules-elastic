// Dragnet [Ransomware]: dragnet-ransomware-2026-0186 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 752f0205-181a-5ef8-8204-aa91190f953b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
