// Dragnet [Ransomware]: dragnet-ransomware-2026-3174 — Recovery Inhibition (cmdorganization)
// Status: deprecated | Level: high | ID: cea2f0c1-74aa-5193-97bd-9e23dc01d6b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
