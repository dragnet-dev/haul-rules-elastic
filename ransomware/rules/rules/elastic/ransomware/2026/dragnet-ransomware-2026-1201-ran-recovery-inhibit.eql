// Dragnet [Ransomware]: dragnet-ransomware-2026-1201 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 139faf14-f0c2-56c5-9926-21cc2764bd2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
