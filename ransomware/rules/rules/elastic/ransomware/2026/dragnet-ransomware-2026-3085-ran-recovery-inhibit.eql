// Dragnet [Ransomware]: dragnet-ransomware-2026-3085 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 72678e61-db4b-5e06-8e9e-9660f5d03fff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
