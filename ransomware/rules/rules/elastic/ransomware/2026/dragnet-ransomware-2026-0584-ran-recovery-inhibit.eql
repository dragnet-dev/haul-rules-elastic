// Dragnet [Ransomware]: dragnet-ransomware-2026-0584 — Recovery Inhibition (beast)
// Status: test | Level: high | ID: 293d90dc-875a-59e0-a8ad-e59f00bfd044

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
