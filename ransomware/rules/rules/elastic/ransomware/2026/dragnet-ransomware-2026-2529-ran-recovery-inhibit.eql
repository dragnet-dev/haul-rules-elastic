// Dragnet [Ransomware]: dragnet-ransomware-2026-2529 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 5e60b6a7-be79-5aa9-8472-b7e85a00bd04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
