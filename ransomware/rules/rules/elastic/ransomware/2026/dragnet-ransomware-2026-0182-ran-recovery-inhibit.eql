// Dragnet [Ransomware]: dragnet-ransomware-2026-0182 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: ba9e46ef-6d43-5adf-b627-a4a9237edb03

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
