// Dragnet [Ransomware]: dragnet-ransomware-2026-1661 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 25b0d720-aa78-5d80-b414-336f1f2b9550

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
