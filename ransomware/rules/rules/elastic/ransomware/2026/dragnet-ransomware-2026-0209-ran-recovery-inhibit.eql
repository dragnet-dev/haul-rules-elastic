// Dragnet [Ransomware]: dragnet-ransomware-2026-0209 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 59796420-2678-5989-8b74-f554407544bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
