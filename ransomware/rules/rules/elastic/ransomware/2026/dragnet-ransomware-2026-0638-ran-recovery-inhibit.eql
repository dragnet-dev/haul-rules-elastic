// Dragnet [Ransomware]: dragnet-ransomware-2026-0638 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 44c05171-bc7b-5ca7-800a-1d9fe304a607

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
