// Dragnet [Ransomware]: dragnet-ransomware-2026-3311 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 5ec4d90b-fc1b-57b0-978a-a95d0a88ff85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
