// Dragnet [Ransomware]: dragnet-ransomware-2026-1819 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: f4f7c28d-b332-599c-9626-5bce66e988cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
