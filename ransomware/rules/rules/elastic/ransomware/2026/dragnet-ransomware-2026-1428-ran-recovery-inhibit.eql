// Dragnet [Ransomware]: dragnet-ransomware-2026-1428 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 7bd06d07-4b00-5236-b9e2-fd1468d8915b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
