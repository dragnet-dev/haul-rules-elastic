// Dragnet [Ransomware]: dragnet-ransomware-2026-1807 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0ccb6a34-4a58-585b-bfd0-7cac5deccc0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
