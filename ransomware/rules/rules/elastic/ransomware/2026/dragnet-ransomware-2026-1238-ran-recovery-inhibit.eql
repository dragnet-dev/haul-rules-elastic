// Dragnet [Ransomware]: dragnet-ransomware-2026-1238 — Recovery Inhibition (chaos)
// Status: stable | Level: high | ID: dcca1020-85de-5e0d-8eec-d3f7b097f52e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
