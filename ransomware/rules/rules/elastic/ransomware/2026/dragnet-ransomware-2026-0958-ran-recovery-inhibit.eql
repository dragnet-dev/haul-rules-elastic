// Dragnet [Ransomware]: dragnet-ransomware-2026-0958 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: ce06e6d4-7384-5da6-a6c5-04241c0fe600

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
