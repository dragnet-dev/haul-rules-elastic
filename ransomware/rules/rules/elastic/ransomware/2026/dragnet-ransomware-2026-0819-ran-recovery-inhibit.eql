// Dragnet [Ransomware]: dragnet-ransomware-2026-0819 — Recovery Inhibition (pear)
// Status: stable | Level: high | ID: 36a8252c-40de-56a8-bab3-2c03a102b095

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
