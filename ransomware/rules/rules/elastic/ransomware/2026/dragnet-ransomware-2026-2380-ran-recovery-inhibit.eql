// Dragnet [Ransomware]: dragnet-ransomware-2026-2380 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: ef47747f-d1c1-5721-90a7-46fd86d8ce83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
