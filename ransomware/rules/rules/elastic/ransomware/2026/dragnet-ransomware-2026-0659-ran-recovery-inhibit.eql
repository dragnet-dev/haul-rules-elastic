// Dragnet [Ransomware]: dragnet-ransomware-2026-0659 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0a1c951b-b7b0-5e06-aab3-03ec84eef5e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
