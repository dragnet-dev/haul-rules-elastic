// Dragnet [Ransomware]: dragnet-ransomware-2026-0964 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 6ed4d8a9-adef-5d07-8611-8e448cf6e1a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
