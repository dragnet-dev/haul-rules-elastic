// Dragnet [Ransomware]: dragnet-ransomware-2026-1622 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: ad36f8bb-0dfa-567a-b763-655db93fcc29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
