// Dragnet [Ransomware]: dragnet-ransomware-2026-0463 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 28d77f4a-bedd-5dd5-a0e4-61bf4499824c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
