// Dragnet [Ransomware]: dragnet-ransomware-2026-1427 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 04df2e83-47b5-54ee-8dbb-7b388408af91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
