// Dragnet [Ransomware]: dragnet-ransomware-2026-1010 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 1c6a34f9-a5f4-50ac-aed7-3646c32dc8b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
