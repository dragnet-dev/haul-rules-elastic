// Dragnet [Ransomware]: dragnet-ransomware-2026-1861 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 03b2a19d-a277-5921-b1ec-8f1a88a2bd4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
