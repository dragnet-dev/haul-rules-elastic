// Dragnet [Ransomware]: dragnet-ransomware-2026-1064 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 356e24f2-38af-5a0c-822d-a8b5059b1fe4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
