// Dragnet [Ransomware]: dragnet-ransomware-2026-3331 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 714dd1bb-ee42-574c-8182-21359d2ad188

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
