// Dragnet [Ransomware]: dragnet-ransomware-2026-3048 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 8afd58f4-8d51-5aad-8206-b2f57c0b85cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
