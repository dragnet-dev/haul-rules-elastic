// Dragnet [Ransomware]: dragnet-ransomware-2026-3222 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: d4b450d1-6a81-546c-8da3-ef3730848a32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
