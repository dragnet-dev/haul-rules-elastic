// Dragnet [Ransomware]: dragnet-ransomware-2026-0198 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 809d4168-f308-5eb8-a99d-eb19df672478

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
