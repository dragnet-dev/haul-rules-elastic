// Dragnet [Ransomware]: dragnet-ransomware-2026-1220 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 42921ce2-1b4d-5963-8a86-cc887ed42142

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
