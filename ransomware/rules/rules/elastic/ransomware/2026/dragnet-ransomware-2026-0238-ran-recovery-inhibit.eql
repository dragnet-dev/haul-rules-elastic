// Dragnet [Ransomware]: dragnet-ransomware-2026-0238 — Recovery Inhibition (insomnia)
// Status: stable | Level: high | ID: 96430597-8935-5a10-aaa5-f600c1835420

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
