// Dragnet [Ransomware]: dragnet-ransomware-2026-2950 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5fe48fed-4b3b-56ad-aacd-d33dc94ba8be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
