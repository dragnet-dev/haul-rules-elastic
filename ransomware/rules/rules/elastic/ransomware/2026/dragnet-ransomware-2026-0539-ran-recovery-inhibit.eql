// Dragnet [Ransomware]: dragnet-ransomware-2026-0539 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0766955e-f366-5c41-9aa9-cbe8eaadb632

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
