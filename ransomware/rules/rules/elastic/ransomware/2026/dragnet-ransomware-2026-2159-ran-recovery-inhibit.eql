// Dragnet [Ransomware]: dragnet-ransomware-2026-2159 — Recovery Inhibition (anubis)
// Status: stable | Level: high | ID: f2903ac0-5501-5049-bf50-e75944722234

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
