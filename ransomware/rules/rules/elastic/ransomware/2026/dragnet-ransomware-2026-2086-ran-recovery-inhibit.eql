// Dragnet [Ransomware]: dragnet-ransomware-2026-2086 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 602f3474-51c6-5412-b873-4de0be7af8e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
