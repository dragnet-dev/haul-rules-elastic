// Dragnet [Ransomware]: dragnet-ransomware-2026-2559 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 4d72eac8-277f-575d-b70f-4c6c0d61a39a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
