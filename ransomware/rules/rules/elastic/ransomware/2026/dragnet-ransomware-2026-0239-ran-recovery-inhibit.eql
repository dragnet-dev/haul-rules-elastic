// Dragnet [Ransomware]: dragnet-ransomware-2026-0239 — Recovery Inhibition (aurora)
// Status: stable | Level: high | ID: 2b487d80-cdf4-50fe-83f5-ca9bfbece589

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
