// Dragnet [Ransomware]: dragnet-ransomware-2026-2848 — Recovery Inhibition (genesis)
// Status: stable | Level: high | ID: be332899-7f83-5875-a727-88659a88cb2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
