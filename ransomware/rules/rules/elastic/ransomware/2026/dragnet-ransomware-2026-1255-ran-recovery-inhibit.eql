// Dragnet [Ransomware]: dragnet-ransomware-2026-1255 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 80ac6cca-58eb-56e1-94b4-f541f42280e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
