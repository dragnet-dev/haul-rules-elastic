// Dragnet [Ransomware]: dragnet-ransomware-2026-2948 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 84c8da68-7f9a-51e4-8bf0-e521105adcb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
