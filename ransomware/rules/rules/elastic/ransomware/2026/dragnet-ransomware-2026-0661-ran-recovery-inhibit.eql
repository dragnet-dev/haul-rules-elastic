// Dragnet [Ransomware]: dragnet-ransomware-2026-0661 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 0b12d03c-d3fa-52cb-a81f-9b7994eaa6b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
