// Dragnet [Ransomware]: dragnet-ransomware-2026-2891 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: db1a6ef5-daf4-5b2e-a01a-e9fc69bf0a66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
