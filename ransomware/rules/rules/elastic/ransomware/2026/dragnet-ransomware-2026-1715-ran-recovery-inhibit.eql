// Dragnet [Ransomware]: dragnet-ransomware-2026-1715 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: ccbfa475-fdf4-5978-803d-6f91cbbd2cd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
