// Dragnet [Ransomware]: dragnet-ransomware-2026-2542 — Recovery Inhibition (vect)
// Status: deprecated | Level: high | ID: 8783431f-f3a5-5cd8-970b-275050fb51a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
