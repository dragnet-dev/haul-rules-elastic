// Dragnet [Ransomware]: dragnet-ransomware-2026-0532 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 7e310a69-7250-5e80-a94e-127afa4eed79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
