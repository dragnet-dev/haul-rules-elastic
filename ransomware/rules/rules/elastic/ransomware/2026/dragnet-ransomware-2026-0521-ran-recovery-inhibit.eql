// Dragnet [Ransomware]: dragnet-ransomware-2026-0521 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 066e0a63-cb64-57f0-aab4-004179e20808

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
