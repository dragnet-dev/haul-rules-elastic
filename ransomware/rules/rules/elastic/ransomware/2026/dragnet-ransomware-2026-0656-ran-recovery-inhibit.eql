// Dragnet [Ransomware]: dragnet-ransomware-2026-0656 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 614955e8-b952-57e9-aea1-2b13a47e2100

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
