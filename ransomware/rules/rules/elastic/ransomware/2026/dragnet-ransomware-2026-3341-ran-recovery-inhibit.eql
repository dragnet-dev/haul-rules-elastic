// Dragnet [Ransomware]: dragnet-ransomware-2026-3341 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 729dc302-3888-57f9-9446-21551e07f069

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
