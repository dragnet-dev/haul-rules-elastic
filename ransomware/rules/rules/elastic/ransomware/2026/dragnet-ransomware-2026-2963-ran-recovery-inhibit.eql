// Dragnet [Ransomware]: dragnet-ransomware-2026-2963 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 069d36f3-74fc-56e7-8a50-efcfcf6af489

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
