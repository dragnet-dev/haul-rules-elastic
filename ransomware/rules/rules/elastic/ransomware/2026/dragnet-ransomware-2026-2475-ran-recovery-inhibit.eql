// Dragnet [Ransomware]: dragnet-ransomware-2026-2475 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 00f7ec74-649d-59e1-89e7-604feaa67a29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
