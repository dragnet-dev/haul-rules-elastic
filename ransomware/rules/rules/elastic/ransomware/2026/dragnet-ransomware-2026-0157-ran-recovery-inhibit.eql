// Dragnet [Ransomware]: dragnet-ransomware-2026-0157 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: edfffbb9-f17f-5a4a-b082-2e82af79d583

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
