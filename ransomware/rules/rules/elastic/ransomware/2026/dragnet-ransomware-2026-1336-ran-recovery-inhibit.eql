// Dragnet [Ransomware]: dragnet-ransomware-2026-1336 — Recovery Inhibition (nova)
// Status: stable | Level: high | ID: 811723d6-e123-5994-8371-b7d350f6225d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
