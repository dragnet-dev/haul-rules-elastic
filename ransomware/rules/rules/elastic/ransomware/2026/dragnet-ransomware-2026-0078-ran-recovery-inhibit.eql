// Dragnet [Ransomware]: dragnet-ransomware-2026-0078 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: b864489e-7069-5b8d-a636-e521118eb571

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
