// Dragnet [Ransomware]: dragnet-ransomware-2026-0043 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 1ee7624a-9447-545d-8023-980209eda5d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
