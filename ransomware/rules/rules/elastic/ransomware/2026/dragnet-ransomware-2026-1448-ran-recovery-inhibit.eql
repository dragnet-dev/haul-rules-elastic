// Dragnet [Ransomware]: dragnet-ransomware-2026-1448 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: 7ebe8d83-cb25-5e9b-a131-0263f38d733e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
