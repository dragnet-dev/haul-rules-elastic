// Dragnet [Ransomware]: dragnet-ransomware-2026-2416 — Recovery Inhibition (exitium)
// Status: stable | Level: high | ID: 7eb30dd5-831a-582c-afed-eccc57712ace

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
