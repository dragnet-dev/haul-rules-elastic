// Dragnet [Ransomware]: dragnet-ransomware-2026-1431 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 562e75f7-acf8-51bd-8a8e-3d5cec6df297

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
