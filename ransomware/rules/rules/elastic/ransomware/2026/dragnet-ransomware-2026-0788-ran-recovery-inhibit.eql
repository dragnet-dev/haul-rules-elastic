// Dragnet [Ransomware]: dragnet-ransomware-2026-0788 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: cd948e4e-9c64-5a87-9a6c-5af0923b5c0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
