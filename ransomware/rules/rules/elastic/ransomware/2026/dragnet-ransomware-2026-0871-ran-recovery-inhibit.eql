// Dragnet [Ransomware]: dragnet-ransomware-2026-0871 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: e4a86003-4137-5b79-896c-35b4d107b050

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
