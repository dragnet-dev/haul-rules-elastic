// Dragnet [Ransomware]: dragnet-ransomware-2026-3229 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: a6e27743-a933-5eb3-ac51-d8795f134fd0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
