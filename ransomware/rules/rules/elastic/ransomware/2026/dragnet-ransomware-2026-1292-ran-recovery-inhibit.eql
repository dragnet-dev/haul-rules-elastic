// Dragnet [Ransomware]: dragnet-ransomware-2026-1292 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: af2fad53-f7ee-5eff-b00e-deb9d3419dcd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
