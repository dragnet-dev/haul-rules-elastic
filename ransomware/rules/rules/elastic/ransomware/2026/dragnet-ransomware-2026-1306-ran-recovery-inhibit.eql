// Dragnet [Ransomware]: dragnet-ransomware-2026-1306 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 83e3bc3a-3c2b-55d0-8f6a-e9e91c76a1bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
