// Dragnet [Ransomware]: dragnet-ransomware-2026-2435 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: be707963-485a-5960-b47b-77797df4159b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
