// Dragnet [Ransomware]: dragnet-ransomware-2026-1841 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: c4457652-4971-5a56-92e1-0c1fcec65535

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
