// Dragnet [Ransomware]: dragnet-ransomware-2026-1451 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 2d5b4f31-0aab-5031-95d8-c683c79ec44b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
