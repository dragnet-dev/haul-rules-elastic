// Dragnet [Ransomware]: dragnet-ransomware-2026-2830 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 20adb88c-9ffc-5119-8c20-1c37ac3799ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
