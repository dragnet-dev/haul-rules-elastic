// Dragnet [Ransomware]: dragnet-ransomware-2026-0948 — Recovery Inhibition (ALP-001)
// Status: stable | Level: high | ID: 33d22d55-bc3e-545e-a96c-4a18d857ed6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
