// Dragnet [Ransomware]: dragnet-ransomware-2026-1590 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 381d1739-aac9-575f-84e6-abdf491f4f22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
