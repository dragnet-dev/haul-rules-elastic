// Dragnet [Ransomware]: dragnet-ransomware-2026-1930 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: fca32b56-8667-5013-b26c-9965ae988633

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
