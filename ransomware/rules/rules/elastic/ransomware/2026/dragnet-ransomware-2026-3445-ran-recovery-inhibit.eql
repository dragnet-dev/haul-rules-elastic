// Dragnet [Ransomware]: dragnet-ransomware-2026-3445 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 12923133-c5d6-5c6c-8a7d-4f22b56199e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
