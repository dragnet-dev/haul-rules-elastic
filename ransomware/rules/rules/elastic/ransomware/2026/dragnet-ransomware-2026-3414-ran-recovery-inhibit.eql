// Dragnet [Ransomware]: dragnet-ransomware-2026-3414 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 04450e35-621e-54b5-b108-b08d5ddd94a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
