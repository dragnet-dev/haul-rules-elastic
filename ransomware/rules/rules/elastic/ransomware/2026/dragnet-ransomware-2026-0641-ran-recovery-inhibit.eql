// Dragnet [Ransomware]: dragnet-ransomware-2026-0641 — Recovery Inhibition (genesis)
// Status: stable | Level: high | ID: 5012cf42-b828-512f-8425-d4affda873a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
