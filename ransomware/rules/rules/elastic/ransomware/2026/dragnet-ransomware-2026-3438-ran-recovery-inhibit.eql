// Dragnet [Ransomware]: dragnet-ransomware-2026-3438 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: cfee0096-59e9-5201-9083-667968ae05df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
