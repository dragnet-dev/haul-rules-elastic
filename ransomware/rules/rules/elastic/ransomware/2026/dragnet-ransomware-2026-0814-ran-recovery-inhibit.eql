// Dragnet [Ransomware]: dragnet-ransomware-2026-0814 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: a2135569-6ceb-5ab0-932c-11ed07eb6c16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
