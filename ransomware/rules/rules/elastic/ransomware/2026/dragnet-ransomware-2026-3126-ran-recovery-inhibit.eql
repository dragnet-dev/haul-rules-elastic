// Dragnet [Ransomware]: dragnet-ransomware-2026-3126 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 74686c16-5d80-5b0d-b70d-cad4b4226bec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
