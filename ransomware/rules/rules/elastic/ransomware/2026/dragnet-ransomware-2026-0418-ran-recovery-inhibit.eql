// Dragnet [Ransomware]: dragnet-ransomware-2026-0418 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 84b0d22b-1a89-5258-b290-448803fc1c75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
