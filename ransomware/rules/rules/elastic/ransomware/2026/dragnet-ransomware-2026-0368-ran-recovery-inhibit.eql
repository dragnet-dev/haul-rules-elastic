// Dragnet [Ransomware]: dragnet-ransomware-2026-0368 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: c86145c3-3f7e-5d9e-8a3b-7b16bc299e63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
