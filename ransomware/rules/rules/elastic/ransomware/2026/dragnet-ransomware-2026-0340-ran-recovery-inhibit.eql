// Dragnet [Ransomware]: dragnet-ransomware-2026-0340 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: b0ce6314-09a9-542b-b3b4-b3e21cbf40ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
