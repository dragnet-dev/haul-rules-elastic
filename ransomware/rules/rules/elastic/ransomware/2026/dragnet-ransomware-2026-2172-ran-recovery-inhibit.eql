// Dragnet [Ransomware]: dragnet-ransomware-2026-2172 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 355ed200-b7b6-5e9b-8339-1fddd3a7f43c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
