// Dragnet [Ransomware]: dragnet-ransomware-2026-1489 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 59fb096b-3bb1-5df1-94bc-0cbd45a8078d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
