// Dragnet [Ransomware]: dragnet-ransomware-2026-3233 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: dd66d02f-25ef-5c6a-b135-31f24cdb5b63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
