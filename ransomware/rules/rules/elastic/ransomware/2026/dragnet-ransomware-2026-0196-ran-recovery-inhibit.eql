// Dragnet [Ransomware]: dragnet-ransomware-2026-0196 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: df2df272-4a2e-51d4-a103-39795baf7d59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
