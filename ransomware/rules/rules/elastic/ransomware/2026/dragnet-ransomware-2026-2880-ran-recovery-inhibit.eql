// Dragnet [Ransomware]: dragnet-ransomware-2026-2880 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 634d8c24-555a-521a-ba7a-612d846a9c55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
