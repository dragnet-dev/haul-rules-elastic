// Dragnet [Ransomware]: dragnet-ransomware-2026-3382 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: a6bb1cb4-f3a7-5776-ac3d-734fe92bb5de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
