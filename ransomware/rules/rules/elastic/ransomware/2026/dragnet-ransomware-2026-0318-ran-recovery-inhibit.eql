// Dragnet [Ransomware]: dragnet-ransomware-2026-0318 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 82467b0f-7180-5d5f-ae20-901b944ed4fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
