// Dragnet [Ransomware]: dragnet-ransomware-2026-0860 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 172c1fba-c9d9-5723-b916-e97ae1a6a084

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
