// Dragnet [Ransomware]: dragnet-ransomware-2026-3008 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: f0980760-8861-5ada-903c-15f24781c45c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
