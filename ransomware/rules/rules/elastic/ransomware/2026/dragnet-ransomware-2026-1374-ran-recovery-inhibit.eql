// Dragnet [Ransomware]: dragnet-ransomware-2026-1374 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 21af2b12-ba1e-5288-b96c-1bb314713e48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
