// Dragnet [Ransomware]: dragnet-ransomware-2026-2134 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 408e130c-1b80-5d77-97c9-a9a24bf48697

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
