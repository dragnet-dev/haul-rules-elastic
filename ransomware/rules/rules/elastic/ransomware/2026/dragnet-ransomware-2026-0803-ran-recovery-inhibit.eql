// Dragnet [Ransomware]: dragnet-ransomware-2026-0803 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 0fc4e81d-4c9b-58fa-bf9e-415dafcdce80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
