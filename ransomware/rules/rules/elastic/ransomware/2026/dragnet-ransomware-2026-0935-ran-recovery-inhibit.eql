// Dragnet [Ransomware]: dragnet-ransomware-2026-0935 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 8e5b57ec-1f68-5312-a619-85daf62ea51b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
