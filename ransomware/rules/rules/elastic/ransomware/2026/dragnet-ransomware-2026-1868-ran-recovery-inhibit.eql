// Dragnet [Ransomware]: dragnet-ransomware-2026-1868 — Recovery Inhibition (nova)
// Status: stable | Level: high | ID: 579e5409-88af-596b-aa5f-43a08b732115

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
