// Dragnet [Ransomware]: dragnet-ransomware-2026-0445 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 4390c757-a446-5b61-a1f1-88df8958b919

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
