// Dragnet [Ransomware]: dragnet-ransomware-2026-0272 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: b57ada10-5c67-5914-81db-191fd41df266

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
