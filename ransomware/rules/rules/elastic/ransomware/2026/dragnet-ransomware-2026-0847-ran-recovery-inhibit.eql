// Dragnet [Ransomware]: dragnet-ransomware-2026-0847 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: e4c130fc-2fa6-5c9d-a4e7-d7528068509e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
