// Dragnet [Ransomware]: dragnet-ransomware-2026-1523 — Recovery Inhibition (threeam)
// Status: stable | Level: high | ID: 45b77bae-eec9-556b-a574-7c032c506ae6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
