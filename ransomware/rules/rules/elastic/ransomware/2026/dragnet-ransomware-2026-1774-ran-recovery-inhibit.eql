// Dragnet [Ransomware]: dragnet-ransomware-2026-1774 — Recovery Inhibition (medusalocker)
// Status: stable | Level: high | ID: 7496cff8-cea6-544c-ae8d-795e3adf0858

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
