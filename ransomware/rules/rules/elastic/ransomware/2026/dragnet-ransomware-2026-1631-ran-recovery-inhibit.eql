// Dragnet [Ransomware]: dragnet-ransomware-2026-1631 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: 14a73b29-62b1-5d85-813a-1e0ef319843e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
