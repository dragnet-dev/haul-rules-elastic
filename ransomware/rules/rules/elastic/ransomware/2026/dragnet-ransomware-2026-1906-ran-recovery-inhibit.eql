// Dragnet [Ransomware]: dragnet-ransomware-2026-1906 — Recovery Inhibition (AuditTeam)
// Status: stable | Level: high | ID: 8d1cd300-e84c-5762-abf9-6c37f9a4b42d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
