// Dragnet [Ransomware]: dragnet-ransomware-2026-3337 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b59941bb-8b0c-5bbe-b7cf-9dc0194064f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
