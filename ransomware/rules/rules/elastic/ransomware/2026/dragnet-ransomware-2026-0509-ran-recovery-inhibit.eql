// Dragnet [Ransomware]: dragnet-ransomware-2026-0509 — Recovery Inhibition (fulcrumsec)
// Status: stable | Level: high | ID: 5144068d-b9d8-53b7-91b0-64ee18a28c4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
