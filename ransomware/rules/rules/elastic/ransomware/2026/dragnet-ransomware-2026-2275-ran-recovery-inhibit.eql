// Dragnet [Ransomware]: dragnet-ransomware-2026-2275 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 57e9acb2-c7fb-5e4c-9255-a2b9340057d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
