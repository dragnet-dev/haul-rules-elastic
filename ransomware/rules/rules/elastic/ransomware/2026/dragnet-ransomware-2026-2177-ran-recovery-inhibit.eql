// Dragnet [Ransomware]: dragnet-ransomware-2026-2177 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 1dbdcaa9-ae20-5572-a635-5f85ddeb3b3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
