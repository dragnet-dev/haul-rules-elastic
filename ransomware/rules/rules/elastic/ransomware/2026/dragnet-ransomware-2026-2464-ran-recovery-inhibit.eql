// Dragnet [Ransomware]: dragnet-ransomware-2026-2464 — Recovery Inhibition (kazu)
// Status: deprecated | Level: high | ID: bf20c102-4958-5b1f-8f37-e73e249d23c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
