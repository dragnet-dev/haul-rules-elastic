// Dragnet [Ransomware]: dragnet-ransomware-2026-3072 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: f7911c0a-9a6d-50b6-8e76-17e45a3b1a4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
