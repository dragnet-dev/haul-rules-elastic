// Dragnet [Ransomware]: dragnet-ransomware-2026-2584 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: c4226d8c-ed2b-555b-b09f-ce92eb6832f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
