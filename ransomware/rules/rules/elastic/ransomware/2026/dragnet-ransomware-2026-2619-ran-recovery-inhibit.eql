// Dragnet [Ransomware]: dragnet-ransomware-2026-2619 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: b034b078-4244-5019-8be3-b888c07b435b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
