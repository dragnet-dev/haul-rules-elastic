// Dragnet [Ransomware]: dragnet-ransomware-2026-3520 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: a0a777e6-4bb1-5a24-9a00-6e12b30aaedf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
