// Dragnet [Ransomware]: dragnet-ransomware-2026-0302 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: 9e9a2ada-0558-51b2-8b48-c8dbe9a79b76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
