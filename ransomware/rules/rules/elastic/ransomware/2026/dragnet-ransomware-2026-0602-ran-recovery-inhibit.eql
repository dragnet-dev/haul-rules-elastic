// Dragnet [Ransomware]: dragnet-ransomware-2026-0602 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: dd706aa6-ba29-51ad-a22a-70eb25a464d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
