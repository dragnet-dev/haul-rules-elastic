// Dragnet [Ransomware]: dragnet-ransomware-2026-1988 — Recovery Inhibition (threeam)
// Status: stable | Level: high | ID: 4b71aba0-8451-5fc3-95d2-a44c4e76ae34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
