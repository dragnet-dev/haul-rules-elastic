// Dragnet [Ransomware]: dragnet-ransomware-2026-1197 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: e2cfa785-63b0-5b47-978a-ce2fd334bbaf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
