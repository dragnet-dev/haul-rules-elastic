// Dragnet [Ransomware]: dragnet-ransomware-2026-1425 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 82f351fd-0e21-537f-9355-59c9283a4ada

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
