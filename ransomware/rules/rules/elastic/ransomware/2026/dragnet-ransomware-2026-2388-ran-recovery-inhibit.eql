// Dragnet [Ransomware]: dragnet-ransomware-2026-2388 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 3ef65ec7-33d0-5dac-bdbe-de97f805b95e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
