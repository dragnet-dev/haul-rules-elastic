// Dragnet [Ransomware]: dragnet-ransomware-2026-1318 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 8bd84852-e465-52f0-a4c1-0df10c24b7cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
