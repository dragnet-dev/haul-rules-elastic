// Dragnet [Ransomware]: dragnet-ransomware-2026-1290 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: 7e1c6e7c-8a2c-5e89-b5b5-2026db13566c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
