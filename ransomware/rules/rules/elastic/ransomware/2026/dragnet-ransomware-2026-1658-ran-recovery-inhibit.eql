// Dragnet [Ransomware]: dragnet-ransomware-2026-1658 — Recovery Inhibition (radar)
// Status: deprecated | Level: high | ID: d47a2236-6a7d-5adb-98f4-53527a81c9a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
