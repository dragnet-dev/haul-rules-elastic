// Dragnet [Ransomware]: dragnet-ransomware-2026-0275 — Recovery Inhibition (gunra)
// Status: stable | Level: high | ID: 8646b354-089a-5e33-b1aa-296540f9304b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
