// Dragnet [Ransomware]: dragnet-ransomware-2026-3036 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 808bf54c-f084-5761-a438-cda3402c982c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
