// Dragnet [Ransomware]: dragnet-ransomware-2026-3197 — Recovery Inhibition (pear)
// Status: stable | Level: high | ID: a729aa95-7be4-5604-992d-b1c9fbce9865

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
