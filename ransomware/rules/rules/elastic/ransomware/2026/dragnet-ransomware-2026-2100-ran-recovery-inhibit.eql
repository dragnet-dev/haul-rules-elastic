// Dragnet [Ransomware]: dragnet-ransomware-2026-2100 — Recovery Inhibition (anubis)
// Status: stable | Level: high | ID: dddb278d-1dd5-5e7b-a203-97b70bf56831

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
