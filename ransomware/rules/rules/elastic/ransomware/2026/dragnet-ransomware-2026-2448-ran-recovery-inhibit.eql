// Dragnet [Ransomware]: dragnet-ransomware-2026-2448 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 2f9c9e7e-d67f-56c0-b541-2764457c544c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
