// Dragnet [Ransomware]: dragnet-ransomware-2026-2575 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: e7798044-7739-51d3-87f0-93714a247682

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
