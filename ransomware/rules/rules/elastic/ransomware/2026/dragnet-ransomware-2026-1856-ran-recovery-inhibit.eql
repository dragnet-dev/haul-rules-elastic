// Dragnet [Ransomware]: dragnet-ransomware-2026-1856 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: d2f7132c-8221-5523-80e7-1a33f35f756e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
