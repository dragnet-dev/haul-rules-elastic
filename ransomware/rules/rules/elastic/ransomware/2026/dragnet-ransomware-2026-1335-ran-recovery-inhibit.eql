// Dragnet [Ransomware]: dragnet-ransomware-2026-1335 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: d6fb3154-cce3-5961-bef2-75e8822dd283

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
