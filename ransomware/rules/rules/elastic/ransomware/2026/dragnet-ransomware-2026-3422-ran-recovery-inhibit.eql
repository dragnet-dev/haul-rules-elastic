// Dragnet [Ransomware]: dragnet-ransomware-2026-3422 — Recovery Inhibition (spacebears)
// Status: test | Level: high | ID: c0da729c-d509-5e8f-a20a-cac7837f2077

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
