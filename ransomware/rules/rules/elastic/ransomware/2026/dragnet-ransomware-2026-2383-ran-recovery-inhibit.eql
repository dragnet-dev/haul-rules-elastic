// Dragnet [Ransomware]: dragnet-ransomware-2026-2383 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: ad49e05a-6c2f-5816-ab9c-f6f4978a1683

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
