// Dragnet [Ransomware]: dragnet-ransomware-2026-0662 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 708419e2-d506-568f-9a21-3f73ff726919

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
