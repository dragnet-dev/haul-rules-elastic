// Dragnet [Ransomware]: dragnet-ransomware-2026-2386 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 059e46bd-8f98-56bb-8318-5a7f00be65a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
