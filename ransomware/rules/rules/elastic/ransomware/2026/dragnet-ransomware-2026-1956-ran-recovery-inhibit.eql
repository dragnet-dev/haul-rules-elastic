// Dragnet [Ransomware]: dragnet-ransomware-2026-1956 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: e1a417c4-bd45-5bb2-b988-96f8227888e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
