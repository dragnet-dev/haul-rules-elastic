// Dragnet [Ransomware]: dragnet-ransomware-2026-1351 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: f0f16af9-a559-57ae-a019-92dff7c49017

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
