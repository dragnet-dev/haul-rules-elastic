// Dragnet [Ransomware]: dragnet-ransomware-2026-0158 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: 66143ce9-0f53-520f-bc86-98feed5fdf10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
