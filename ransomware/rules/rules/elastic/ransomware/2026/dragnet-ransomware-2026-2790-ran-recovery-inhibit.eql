// Dragnet [Ransomware]: dragnet-ransomware-2026-2790 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 93918d6e-11fb-590e-9b3e-ad9c9699846f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
