// Dragnet [Ransomware]: dragnet-ransomware-2026-0164 — Recovery Inhibition (insomnia)
// Status: stable | Level: high | ID: 3e2404d7-9fda-519f-9d12-fb4ef8a2aa67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
