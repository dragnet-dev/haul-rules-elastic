// Dragnet [Ransomware]: dragnet-ransomware-2026-3137 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: c5fe73fb-25fd-5abe-9df5-66fa86e50b36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
