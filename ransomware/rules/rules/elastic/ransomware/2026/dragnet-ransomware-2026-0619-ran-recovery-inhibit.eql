// Dragnet [Ransomware]: dragnet-ransomware-2026-0619 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: eff60087-8f06-5bde-8367-7c123f021d80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
