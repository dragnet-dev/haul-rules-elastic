// Dragnet [Ransomware]: dragnet-ransomware-2026-1678 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 76ac9d83-a581-595d-9a73-d4fc8b33ea07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
