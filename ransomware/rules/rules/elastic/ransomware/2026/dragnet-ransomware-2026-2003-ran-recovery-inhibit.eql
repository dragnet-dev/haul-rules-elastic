// Dragnet [Ransomware]: dragnet-ransomware-2026-2003 — Recovery Inhibition (lynx)
// Status: stable | Level: high | ID: 22aec960-0c18-5963-8ed6-25d79221105a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
