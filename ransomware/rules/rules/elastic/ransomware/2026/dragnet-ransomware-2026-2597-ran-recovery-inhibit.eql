// Dragnet [Ransomware]: dragnet-ransomware-2026-2597 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 67886d90-dc2b-5539-95a8-ce3f061acc63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
