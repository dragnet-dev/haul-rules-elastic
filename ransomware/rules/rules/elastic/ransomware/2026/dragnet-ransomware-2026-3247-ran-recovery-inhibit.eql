// Dragnet [Ransomware]: dragnet-ransomware-2026-3247 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: f2381177-cabd-5b46-8314-d6de723a1607

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
