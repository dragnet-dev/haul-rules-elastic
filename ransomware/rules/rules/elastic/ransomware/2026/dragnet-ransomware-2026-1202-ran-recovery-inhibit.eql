// Dragnet [Ransomware]: dragnet-ransomware-2026-1202 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: c85df91f-24a6-507b-ae3a-8d9c94e9f204

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
