// Dragnet [Ransomware]: dragnet-ransomware-2026-2029 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 97839fac-e9c1-546c-937d-c789df77e06e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
