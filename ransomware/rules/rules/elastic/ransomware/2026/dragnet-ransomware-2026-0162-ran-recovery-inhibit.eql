// Dragnet [Ransomware]: dragnet-ransomware-2026-0162 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: da48b610-ab9b-5ec1-8b78-2f1c4434a497

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
