// Dragnet [Ransomware]: dragnet-ransomware-2026-2178 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: cf28edff-e923-5ea2-972b-2aff1f520be8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
