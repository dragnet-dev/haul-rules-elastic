// Dragnet [Ransomware]: dragnet-ransomware-2026-2245 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d4488374-afda-5be5-be87-2b4668a6e885

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
