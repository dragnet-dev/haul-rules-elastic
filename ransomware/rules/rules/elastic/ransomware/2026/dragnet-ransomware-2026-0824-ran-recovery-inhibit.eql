// Dragnet [Ransomware]: dragnet-ransomware-2026-0824 — Recovery Inhibition (spacebears)
// Status: stable | Level: high | ID: dd8c1f48-d9f3-5152-9160-f8f186b07465

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
