// Dragnet [Ransomware]: dragnet-ransomware-2026-1921 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: bdf76a5e-e620-53e0-b03e-ae0aa7f2ac48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
