// Dragnet [Ransomware]: dragnet-ransomware-2026-1947 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: a3e44b5f-b685-5b2e-ae25-903f428bb2dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
