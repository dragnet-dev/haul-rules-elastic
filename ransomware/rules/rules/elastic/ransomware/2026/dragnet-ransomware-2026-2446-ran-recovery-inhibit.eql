// Dragnet [Ransomware]: dragnet-ransomware-2026-2446 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 692c1702-06f8-58ab-a387-939e73eb7bdf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
