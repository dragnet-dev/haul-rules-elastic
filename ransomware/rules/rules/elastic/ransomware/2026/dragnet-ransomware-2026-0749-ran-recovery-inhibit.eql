// Dragnet [Ransomware]: dragnet-ransomware-2026-0749 — Recovery Inhibition (alphalocker)
// Status: stable | Level: high | ID: 58445450-9252-5333-9d6d-5da8767c983e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
