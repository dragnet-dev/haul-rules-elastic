// Dragnet [Ransomware]: dragnet-ransomware-2026-1615 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 96336762-55b8-5948-a449-fb09a7a7d9e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
