// Dragnet [Ransomware]: dragnet-ransomware-2026-0139 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 022b3048-6d31-58eb-9525-92aa5539c1e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
