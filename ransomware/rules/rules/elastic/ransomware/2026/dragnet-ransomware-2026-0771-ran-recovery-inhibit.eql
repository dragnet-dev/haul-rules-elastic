// Dragnet [Ransomware]: dragnet-ransomware-2026-0771 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 03b50c34-27d3-59bb-89b7-a24096674058

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
