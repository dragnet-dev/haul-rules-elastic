// Dragnet [Ransomware]: dragnet-ransomware-2026-1278 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 8824b5dd-e3fe-5caa-9f2f-900507487947

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
