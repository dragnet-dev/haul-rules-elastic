// Dragnet [Ransomware]: dragnet-ransomware-2026-1953 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 17fd9b3d-71fa-5ccf-9678-e59faec13eeb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
