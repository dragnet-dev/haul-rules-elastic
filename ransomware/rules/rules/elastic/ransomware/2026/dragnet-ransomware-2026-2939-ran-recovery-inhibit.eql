// Dragnet [Ransomware]: dragnet-ransomware-2026-2939 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: cd48071f-63b0-5499-82cb-1abe8e35db03

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
