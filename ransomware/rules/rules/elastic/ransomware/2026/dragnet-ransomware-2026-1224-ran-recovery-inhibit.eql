// Dragnet [Ransomware]: dragnet-ransomware-2026-1224 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: f8471b97-88ba-59b8-a2b7-ce7c1bbaaf6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
