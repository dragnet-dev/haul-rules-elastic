// Dragnet [Ransomware]: dragnet-ransomware-2026-3387 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: f1d41bb8-356c-5dd0-9bed-3edb4ddd4314

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
