// Dragnet [Ransomware]: dragnet-ransomware-2026-1212 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 01f4ae52-bf0e-5590-a718-580b599ff726

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
