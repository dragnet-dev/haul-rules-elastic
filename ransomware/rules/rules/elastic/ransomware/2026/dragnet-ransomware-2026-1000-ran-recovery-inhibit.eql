// Dragnet [Ransomware]: dragnet-ransomware-2026-1000 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 9482c547-339a-5471-974c-2ebd3c128060

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
