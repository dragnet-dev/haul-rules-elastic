// Dragnet [Ransomware]: dragnet-ransomware-2026-0733 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 36ae63fe-4ba5-57c5-97ae-9222afe0fe15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
