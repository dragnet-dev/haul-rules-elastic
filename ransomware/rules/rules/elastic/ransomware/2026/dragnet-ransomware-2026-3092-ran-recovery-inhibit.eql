// Dragnet [Ransomware]: dragnet-ransomware-2026-3092 — Recovery Inhibition (securotrop)
// Status: test | Level: high | ID: 1ab80296-a01f-531d-9322-357012ba262e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
