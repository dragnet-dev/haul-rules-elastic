// Dragnet [Ransomware]: dragnet-ransomware-2026-3077 — Recovery Inhibition (beast)
// Status: test | Level: high | ID: e7e03a28-6160-5468-951a-a8e265a47549

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
