// Dragnet [Ransomware]: dragnet-ransomware-2026-1126 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: ca2f5fc6-14b5-5972-a92b-0c3276f88302

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
