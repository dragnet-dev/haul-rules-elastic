// Dragnet [Ransomware]: dragnet-ransomware-2026-0458 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 3c7d249e-64f6-5234-8ab7-dabe4a4be142

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
