// Dragnet [Ransomware]: dragnet-ransomware-2026-3362 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 7afcb5bd-46d3-5e10-aeca-a8f9393ba47f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
