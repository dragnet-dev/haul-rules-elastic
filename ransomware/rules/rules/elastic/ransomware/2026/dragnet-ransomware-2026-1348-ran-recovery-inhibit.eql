// Dragnet [Ransomware]: dragnet-ransomware-2026-1348 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: ea81cb7b-40ff-561d-b5f4-b47359147712

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
