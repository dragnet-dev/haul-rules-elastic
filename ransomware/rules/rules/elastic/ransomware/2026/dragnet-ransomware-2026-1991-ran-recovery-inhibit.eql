// Dragnet [Ransomware]: dragnet-ransomware-2026-1991 — Recovery Inhibition (nova)
// Status: stable | Level: high | ID: b65855f6-5899-5889-b913-892b563c3552

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
