// Dragnet [Ransomware]: dragnet-ransomware-2026-3370 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 0c9b7f7f-ecbf-5c4a-a8d5-d9d31c3d7d4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
