// Dragnet [Ransomware]: dragnet-ransomware-2026-2834 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 6fd71ea3-4ad2-5fef-8eca-3e05f759c8f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
