// Dragnet [Ransomware]: dragnet-ransomware-2026-2510 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 8fba0921-4cb8-533d-aa4e-ccc76a403f39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
