// Dragnet [Ransomware]: dragnet-ransomware-2026-1892 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: bdeb5e3e-1438-56e1-8fc7-c929b5c57209

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
