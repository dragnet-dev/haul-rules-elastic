// Dragnet [Ransomware]: dragnet-ransomware-2026-0579 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: 77f44e7a-12ef-5258-8c3a-4c3ed5fef59b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
