// Dragnet [Ransomware]: dragnet-ransomware-2026-1720 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 53f64bbe-4afa-53ef-8293-f133a795dd1f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
