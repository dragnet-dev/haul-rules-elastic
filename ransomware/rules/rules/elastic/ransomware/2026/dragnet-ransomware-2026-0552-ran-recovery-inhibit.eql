// Dragnet [Ransomware]: dragnet-ransomware-2026-0552 — Recovery Inhibition (lapsus$)
// Status: deprecated | Level: high | ID: 528c76eb-8e78-5523-ad4b-a0290310b2da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
