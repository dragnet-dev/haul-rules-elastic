// Dragnet [Ransomware]: dragnet-ransomware-2026-2438 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 2e506247-8fb7-564a-bed2-ff9dfec2bd3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
