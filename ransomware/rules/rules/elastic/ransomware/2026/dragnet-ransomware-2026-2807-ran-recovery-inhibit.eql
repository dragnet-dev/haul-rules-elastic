// Dragnet [Ransomware]: dragnet-ransomware-2026-2807 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: abff4f60-f20d-50fe-bc0f-499fc560d3f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
