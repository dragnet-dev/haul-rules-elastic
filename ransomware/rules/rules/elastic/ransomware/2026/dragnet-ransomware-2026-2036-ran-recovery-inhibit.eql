// Dragnet [Ransomware]: dragnet-ransomware-2026-2036 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: bd0c85a6-9df7-59d2-a9d7-0cba4a43c829

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
