// Dragnet [Ransomware]: dragnet-ransomware-2026-0083 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 351ef908-300c-5495-a31f-9ad21b363990

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
