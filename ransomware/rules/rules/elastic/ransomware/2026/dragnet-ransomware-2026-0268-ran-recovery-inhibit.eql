// Dragnet [Ransomware]: dragnet-ransomware-2026-0268 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 7e212ed1-072d-58eb-9561-855c64aa7465

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
