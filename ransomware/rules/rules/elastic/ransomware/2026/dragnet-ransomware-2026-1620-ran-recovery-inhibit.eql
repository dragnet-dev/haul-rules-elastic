// Dragnet [Ransomware]: dragnet-ransomware-2026-1620 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 7ba5adf9-f2b7-51e8-b30d-9853387bfd72

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
