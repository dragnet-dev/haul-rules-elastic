// Dragnet [Ransomware]: dragnet-ransomware-2026-3100 — Recovery Inhibition (shadowbyt3$)
// Status: deprecated | Level: high | ID: 17348cbd-2d06-59b0-98ea-d6729995c99f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
