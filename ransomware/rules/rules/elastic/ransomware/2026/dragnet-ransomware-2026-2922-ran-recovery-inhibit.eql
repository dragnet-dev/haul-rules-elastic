// Dragnet [Ransomware]: dragnet-ransomware-2026-2922 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: cf5e4192-c8e4-544e-89e3-7487b59a7bd1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
