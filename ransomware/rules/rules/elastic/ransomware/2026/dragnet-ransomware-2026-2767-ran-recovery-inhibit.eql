// Dragnet [Ransomware]: dragnet-ransomware-2026-2767 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e201980e-9838-57f8-accc-1383871d7611

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
