// Dragnet [Ransomware]: dragnet-ransomware-2026-2324 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: a49357e3-8227-5ed0-ab97-067b5220b51c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
