// Dragnet [Ransomware]: dragnet-ransomware-2026-3425 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 7c4dbf15-b53b-5e7d-ae5a-6b65064d2f00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
