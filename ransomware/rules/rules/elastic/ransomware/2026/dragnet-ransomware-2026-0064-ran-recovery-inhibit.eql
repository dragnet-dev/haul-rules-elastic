// Dragnet [Ransomware]: dragnet-ransomware-2026-0064 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: e4613922-2a4d-5396-99c9-959484951855

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
