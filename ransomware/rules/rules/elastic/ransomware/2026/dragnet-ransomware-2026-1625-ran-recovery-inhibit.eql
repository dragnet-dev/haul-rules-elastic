// Dragnet [Ransomware]: dragnet-ransomware-2026-1625 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: 5cc9ecb6-5dfc-5a4e-b9e0-401a12ac00c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
