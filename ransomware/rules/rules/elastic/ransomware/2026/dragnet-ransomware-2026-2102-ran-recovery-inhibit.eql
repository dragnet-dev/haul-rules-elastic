// Dragnet [Ransomware]: dragnet-ransomware-2026-2102 — Recovery Inhibition (chaos)
// Status: stable | Level: high | ID: 6df0bc2b-cb77-5594-9e10-bcde09cb897a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
