// Dragnet [Ransomware]: dragnet-ransomware-2026-3306 — Recovery Inhibition (worldleaks)
// Status: test | Level: high | ID: f407db0b-09c3-5103-88ea-0f1ad649c648

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
