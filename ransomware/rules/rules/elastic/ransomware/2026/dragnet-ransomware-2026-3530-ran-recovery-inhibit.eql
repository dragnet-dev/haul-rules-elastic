// Dragnet [Ransomware]: dragnet-ransomware-2026-3530 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: c112531e-afb6-51de-b3ce-c9387f2ce99e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
