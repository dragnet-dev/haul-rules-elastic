// Dragnet [Ransomware]: dragnet-ransomware-2026-2841 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: c6f13bcb-8a22-5eb9-9f49-520a783f0b0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
