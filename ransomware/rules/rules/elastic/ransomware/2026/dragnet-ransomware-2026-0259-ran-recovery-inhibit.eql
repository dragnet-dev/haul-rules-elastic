// Dragnet [Ransomware]: dragnet-ransomware-2026-0259 — Recovery Inhibition (insomnia)
// Status: stable | Level: high | ID: 7db18991-ce01-5fbb-8286-b34285ccc1c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
