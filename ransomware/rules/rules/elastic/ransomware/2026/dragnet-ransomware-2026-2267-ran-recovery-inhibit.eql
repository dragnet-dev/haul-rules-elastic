// Dragnet [Ransomware]: dragnet-ransomware-2026-2267 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 8859fec1-ed1a-50a0-9d06-b9639a0a9667

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
