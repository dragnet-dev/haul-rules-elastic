// Dragnet [Ransomware]: dragnet-ransomware-2026-1346 — Recovery Inhibition (genesis)
// Status: stable | Level: high | ID: 40c2c3c2-6c3f-5f3e-b1eb-fca51159fe67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
