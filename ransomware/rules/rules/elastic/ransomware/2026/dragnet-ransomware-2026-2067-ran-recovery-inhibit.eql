// Dragnet [Ransomware]: dragnet-ransomware-2026-2067 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 3a80e4b1-db7d-526c-a4d4-f539ca4ccaa9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
