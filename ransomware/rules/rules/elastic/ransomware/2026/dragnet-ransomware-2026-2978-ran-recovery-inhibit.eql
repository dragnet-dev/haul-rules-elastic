// Dragnet [Ransomware]: dragnet-ransomware-2026-2978 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: f1829914-d28d-54fa-996f-ee1e9a79d22d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
