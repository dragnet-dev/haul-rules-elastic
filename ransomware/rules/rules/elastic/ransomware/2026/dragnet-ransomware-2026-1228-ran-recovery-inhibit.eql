// Dragnet [Ransomware]: dragnet-ransomware-2026-1228 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: f8ad25de-8aa9-5d41-aa68-1e438f934fb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
