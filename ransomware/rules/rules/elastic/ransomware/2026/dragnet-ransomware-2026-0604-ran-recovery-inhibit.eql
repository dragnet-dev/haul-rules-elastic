// Dragnet [Ransomware]: dragnet-ransomware-2026-0604 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 46c29ed0-3f24-5c13-a914-620c9286fec0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
