// Dragnet [Ransomware]: dragnet-ransomware-2026-0359 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: be681aa8-1f11-504c-9ca4-c5808b2f3621

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
