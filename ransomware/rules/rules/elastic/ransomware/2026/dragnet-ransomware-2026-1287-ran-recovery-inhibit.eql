// Dragnet [Ransomware]: dragnet-ransomware-2026-1287 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0e8bdae0-b611-5615-b40a-f4dfad4a6f14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
