// Dragnet [Ransomware]: dragnet-ransomware-2026-0372 — Recovery Inhibition (kittykatkrew)
// Status: stable | Level: high | ID: 4ecddb81-9f04-55f8-aa29-cd10fbf62968

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
