// Dragnet [Ransomware]: dragnet-ransomware-2026-3043 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: dfb40eff-bd4a-51f8-b536-68e076ea78d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
