// Dragnet [Ransomware]: dragnet-ransomware-2026-1703 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 06d2ce94-fe58-5402-9dc4-5cda306c0de3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
