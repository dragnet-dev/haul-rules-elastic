// Dragnet [Ransomware]: dragnet-ransomware-2026-3430 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: 82e62c39-4771-5cbb-9b0c-03352251338c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
