// Dragnet [Ransomware]: dragnet-ransomware-2026-1770 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 5bdb04bc-803f-5725-a079-ef4f1761400d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
