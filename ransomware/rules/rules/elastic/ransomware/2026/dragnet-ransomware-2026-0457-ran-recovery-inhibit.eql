// Dragnet [Ransomware]: dragnet-ransomware-2026-0457 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 4bfeff2b-ebbf-58cb-bc83-3c72e9b458b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
