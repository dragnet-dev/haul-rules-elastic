// Dragnet [Ransomware]: dragnet-ransomware-2026-0189 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 6e4ee08d-d2dd-5b8f-8a39-8d6bc75d8575

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
