// Dragnet [Ransomware]: dragnet-ransomware-2026-1298 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: bf216b2d-0c04-599c-807a-5706daa5d059

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
