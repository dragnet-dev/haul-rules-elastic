// Dragnet [Ransomware]: dragnet-ransomware-2026-2430 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: b03f5d28-89f9-536c-919a-09b2e242ff67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
