// Dragnet [Ransomware]: dragnet-ransomware-2026-2971 — Recovery Inhibition (spacebears)
// Status: test | Level: high | ID: 79bb974e-cd85-5757-8864-903ec72790d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
