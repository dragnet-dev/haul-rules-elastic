// Dragnet [Ransomware]: dragnet-ransomware-2026-3226 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: e3db8487-d9c0-5964-9987-d9c13193e601

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
