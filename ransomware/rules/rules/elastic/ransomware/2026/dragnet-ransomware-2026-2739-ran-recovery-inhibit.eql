// Dragnet [Ransomware]: dragnet-ransomware-2026-2739 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: bba78fdc-725b-5ff6-b798-37462f5be441

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
