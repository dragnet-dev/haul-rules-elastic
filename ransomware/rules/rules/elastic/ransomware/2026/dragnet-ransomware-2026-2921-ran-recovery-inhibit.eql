// Dragnet [Ransomware]: dragnet-ransomware-2026-2921 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 67a370e6-6919-50ce-b786-b29d7c0c360a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
