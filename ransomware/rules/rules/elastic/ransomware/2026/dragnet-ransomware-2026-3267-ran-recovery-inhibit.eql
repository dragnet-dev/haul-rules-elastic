// Dragnet [Ransomware]: dragnet-ransomware-2026-3267 — Recovery Inhibition (ransomhouse)
// Status: stable | Level: high | ID: e3f0d6d4-be47-52fb-aac5-cf289c7b4134

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
