// Dragnet [Ransomware]: dragnet-ransomware-2026-0897 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: e0756f0b-da8e-5c6f-ba40-85cdb0560f20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
