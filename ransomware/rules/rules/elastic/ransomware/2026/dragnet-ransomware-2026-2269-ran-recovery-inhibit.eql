// Dragnet [Ransomware]: dragnet-ransomware-2026-2269 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 3571d93a-352d-5996-b9b9-c354eca87152

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
