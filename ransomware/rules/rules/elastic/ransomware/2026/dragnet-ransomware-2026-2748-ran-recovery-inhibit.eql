// Dragnet [Ransomware]: dragnet-ransomware-2026-2748 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: afa6adbc-b8ea-5808-9f6b-8a26bda416cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
