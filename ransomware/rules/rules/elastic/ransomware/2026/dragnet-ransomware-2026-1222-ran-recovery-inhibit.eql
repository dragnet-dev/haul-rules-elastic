// Dragnet [Ransomware]: dragnet-ransomware-2026-1222 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: ed97a1c1-5823-5899-b35f-57437c8dd16c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
