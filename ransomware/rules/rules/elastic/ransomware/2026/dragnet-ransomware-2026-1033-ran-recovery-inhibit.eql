// Dragnet [Ransomware]: dragnet-ransomware-2026-1033 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 89111c0f-5ca7-5f08-a787-881e6fc74d46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
