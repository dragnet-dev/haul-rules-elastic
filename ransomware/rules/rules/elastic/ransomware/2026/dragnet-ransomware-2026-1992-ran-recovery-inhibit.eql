// Dragnet [Ransomware]: dragnet-ransomware-2026-1992 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: d6a5c9c0-17cb-5b8c-a7d8-a864d35b0cf4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
