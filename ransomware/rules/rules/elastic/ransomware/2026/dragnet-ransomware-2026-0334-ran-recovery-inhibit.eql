// Dragnet [Ransomware]: dragnet-ransomware-2026-0334 — Recovery Inhibition (genesis)
// Status: stable | Level: high | ID: cdd3ec47-f5f4-59ee-a570-eb3b4e63a503

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
