// Dragnet [Ransomware]: dragnet-ransomware-2026-1319 — Recovery Inhibition (worldleaks)
// Status: stable | Level: high | ID: 91db5924-61f0-5f62-8822-ff200b7c5de8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
