// Dragnet [Ransomware]: dragnet-ransomware-2026-1669 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: a6d60c36-ce53-5d17-82ab-b5e8cb28d3d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
