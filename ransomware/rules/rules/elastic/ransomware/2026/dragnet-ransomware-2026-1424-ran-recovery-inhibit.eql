// Dragnet [Ransomware]: dragnet-ransomware-2026-1424 — Recovery Inhibition (embargo)
// Status: stable | Level: high | ID: b2557502-f202-544d-9524-f7a525092071

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
