// Dragnet [Ransomware]: dragnet-ransomware-2026-0683 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 6ad857f0-8423-528e-8cea-379382e364e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
