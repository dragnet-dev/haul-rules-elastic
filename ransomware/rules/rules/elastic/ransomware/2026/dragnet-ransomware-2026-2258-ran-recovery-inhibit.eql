// Dragnet [Ransomware]: dragnet-ransomware-2026-2258 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 567acc46-d47e-5ff4-9b36-c030b72004db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
