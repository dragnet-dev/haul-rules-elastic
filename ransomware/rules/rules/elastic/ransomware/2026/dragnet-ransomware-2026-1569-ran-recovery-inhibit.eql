// Dragnet [Ransomware]: dragnet-ransomware-2026-1569 — Recovery Inhibition (lynx)
// Status: stable | Level: high | ID: b6458a2a-cdf7-56b1-ad84-4933c6103765

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
