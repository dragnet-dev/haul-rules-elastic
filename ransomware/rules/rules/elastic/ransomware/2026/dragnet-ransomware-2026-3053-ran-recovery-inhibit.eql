// Dragnet [Ransomware]: dragnet-ransomware-2026-3053 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: f8d36f8c-dffe-5235-b37c-62fd6af4b902

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
