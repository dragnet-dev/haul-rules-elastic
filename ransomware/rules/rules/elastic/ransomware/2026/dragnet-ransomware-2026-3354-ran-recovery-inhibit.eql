// Dragnet [Ransomware]: dragnet-ransomware-2026-3354 — Recovery Inhibition (anubis)
// Status: stable | Level: high | ID: aa151eb1-65d4-5dee-b545-2be19caeaa54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
