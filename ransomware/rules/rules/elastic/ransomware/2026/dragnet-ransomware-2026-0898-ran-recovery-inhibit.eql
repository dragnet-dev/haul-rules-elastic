// Dragnet [Ransomware]: dragnet-ransomware-2026-0898 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: a28ef8f2-8d75-5f75-a995-cce5ce768d34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
