// Dragnet [Ransomware]: dragnet-ransomware-2026-3350 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: a5e1f8d8-9498-57b5-bb00-8cb2c100ecae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
