// Dragnet [Ransomware]: dragnet-ransomware-2026-2962 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: c2f160b7-3e5d-5e24-874b-f59bb2617af4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
