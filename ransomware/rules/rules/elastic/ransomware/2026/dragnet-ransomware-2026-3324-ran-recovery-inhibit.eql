// Dragnet [Ransomware]: dragnet-ransomware-2026-3324 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 59767a72-67f0-5c03-9349-d27acfa8ebaf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
