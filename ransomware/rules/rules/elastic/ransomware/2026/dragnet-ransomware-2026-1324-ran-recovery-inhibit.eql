// Dragnet [Ransomware]: dragnet-ransomware-2026-1324 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 49e22db1-71c9-530f-b1b1-5c415db23e7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
