// Dragnet [Ransomware]: dragnet-ransomware-2026-0633 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: ea25167a-3d7c-561a-bd04-1183f7918edb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
