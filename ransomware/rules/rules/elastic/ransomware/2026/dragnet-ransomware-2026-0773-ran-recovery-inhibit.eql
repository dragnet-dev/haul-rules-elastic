// Dragnet [Ransomware]: dragnet-ransomware-2026-0773 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 4f4b8159-5fc6-5721-a283-e993807478f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
