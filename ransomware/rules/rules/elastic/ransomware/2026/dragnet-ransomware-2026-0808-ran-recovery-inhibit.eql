// Dragnet [Ransomware]: dragnet-ransomware-2026-0808 — Recovery Inhibition (nova)
// Status: stable | Level: high | ID: a933f047-db46-5f77-8d0e-0020b6b59704

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
