// Dragnet [Ransomware]: dragnet-ransomware-2026-1860 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: e6a20e3d-cce8-537a-b819-7298d00aa83d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
