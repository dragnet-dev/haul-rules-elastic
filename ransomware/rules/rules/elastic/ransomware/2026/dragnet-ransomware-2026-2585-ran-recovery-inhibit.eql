// Dragnet [Ransomware]: dragnet-ransomware-2026-2585 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 0a1acf41-5bf2-561b-b1b4-9d25943d6069

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
