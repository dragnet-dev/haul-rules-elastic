// Dragnet [Ransomware]: dragnet-ransomware-2026-2440 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 7215b153-b90a-5a12-a861-447be11b8d2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
