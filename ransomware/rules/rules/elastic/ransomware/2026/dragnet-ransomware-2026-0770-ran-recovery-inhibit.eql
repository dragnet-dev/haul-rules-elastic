// Dragnet [Ransomware]: dragnet-ransomware-2026-0770 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: fb6fdfab-dd90-529f-bf36-7416670a33bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
