// Dragnet [Ransomware]: dragnet-ransomware-2026-1251 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 32208323-c315-5ce1-9d66-d0318209f27e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
