// Dragnet [Ransomware]: dragnet-ransomware-2026-0016 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: df88679d-8dd7-5ce3-862b-2acdd113b3f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
