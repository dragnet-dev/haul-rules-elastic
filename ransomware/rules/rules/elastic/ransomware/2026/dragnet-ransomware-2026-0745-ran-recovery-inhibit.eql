// Dragnet [Ransomware]: dragnet-ransomware-2026-0745 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: e454eaa7-5614-554c-a7ec-3e5644161306

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
