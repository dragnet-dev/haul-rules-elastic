// Dragnet [Ransomware]: dragnet-ransomware-2026-2156 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 7e4be2c7-b999-5547-a3a9-f25fc4a580c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
