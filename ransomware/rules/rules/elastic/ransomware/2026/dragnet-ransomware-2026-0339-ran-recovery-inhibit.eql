// Dragnet [Ransomware]: dragnet-ransomware-2026-0339 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 1f6129ce-34f5-5a4f-9d7c-843dd20719e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
