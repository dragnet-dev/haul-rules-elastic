// Dragnet [Ransomware]: dragnet-ransomware-2026-3151 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: c6f37ac2-1794-593c-8729-df016d5813df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
