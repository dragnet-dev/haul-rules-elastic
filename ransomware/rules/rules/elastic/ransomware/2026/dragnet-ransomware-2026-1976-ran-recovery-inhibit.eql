// Dragnet [Ransomware]: dragnet-ransomware-2026-1976 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: 8e40a7ac-0f52-5135-b716-2ed03eb985e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
