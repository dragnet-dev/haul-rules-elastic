// Dragnet [Ransomware]: dragnet-ransomware-2026-2012 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: b73eea56-b2e4-5341-8c0c-b7de29fe2159

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
