// Dragnet [Ransomware]: dragnet-ransomware-2026-2145 — Recovery Inhibition (anubis)
// Status: stable | Level: high | ID: b39020a0-14c1-5180-a6be-f1ee14d1599b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
