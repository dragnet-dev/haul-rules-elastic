// Dragnet [Ransomware]: dragnet-ransomware-2026-0020 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 2e20edd4-15fd-5002-bdbf-e0ddcb6a9728

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
