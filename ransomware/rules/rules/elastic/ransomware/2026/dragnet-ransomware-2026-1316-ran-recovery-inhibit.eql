// Dragnet [Ransomware]: dragnet-ransomware-2026-1316 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8dd3fbc7-f632-5f2b-8b36-b37b587426b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
