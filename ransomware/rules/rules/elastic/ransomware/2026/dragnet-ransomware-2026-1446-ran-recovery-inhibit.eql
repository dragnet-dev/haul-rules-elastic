// Dragnet [Ransomware]: dragnet-ransomware-2026-1446 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 0d47164d-0a57-5bc1-bf65-9bb64c5ad35b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
