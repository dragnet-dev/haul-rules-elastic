// Dragnet [Ransomware]: dragnet-ransomware-2026-2226 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 30d01e0d-9f5e-526e-a56e-4f2c42dda215

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
