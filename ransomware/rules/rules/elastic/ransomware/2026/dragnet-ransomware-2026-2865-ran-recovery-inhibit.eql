// Dragnet [Ransomware]: dragnet-ransomware-2026-2865 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 99fcded3-9f49-595f-b35d-d9d4ff69d6fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
