// Dragnet [Ransomware]: dragnet-ransomware-2026-0718 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 31063548-b8c6-5ddf-9b1f-61d137785d9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
