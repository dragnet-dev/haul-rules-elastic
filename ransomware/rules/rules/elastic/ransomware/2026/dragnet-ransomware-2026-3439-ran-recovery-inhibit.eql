// Dragnet [Ransomware]: dragnet-ransomware-2026-3439 — Recovery Inhibition (ransomhouse)
// Status: stable | Level: high | ID: 39daef60-72d4-5a4f-8f42-9faf9b6980c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
