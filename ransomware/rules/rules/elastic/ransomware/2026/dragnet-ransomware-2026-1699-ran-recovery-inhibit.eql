// Dragnet [Ransomware]: dragnet-ransomware-2026-1699 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: b966ca3a-c896-5654-a2ae-218950f03211

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
