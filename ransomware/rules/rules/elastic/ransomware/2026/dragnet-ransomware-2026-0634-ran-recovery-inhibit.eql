// Dragnet [Ransomware]: dragnet-ransomware-2026-0634 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: c3dcf97c-effb-51ba-830d-831ee64ebc9c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
