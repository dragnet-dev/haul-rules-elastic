// Dragnet [Ransomware]: dragnet-ransomware-2026-2061 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 665e7636-4584-5ebb-b37b-430ecbb3c013

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
