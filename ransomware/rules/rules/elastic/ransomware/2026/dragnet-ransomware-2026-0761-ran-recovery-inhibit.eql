// Dragnet [Ransomware]: dragnet-ransomware-2026-0761 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: e467447d-d488-5b7e-a39b-55bda618f029

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
