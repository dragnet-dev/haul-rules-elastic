// Dragnet [Ransomware]: dragnet-ransomware-2026-0183 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: da132e84-f2ec-5490-abae-dbefb292139b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
