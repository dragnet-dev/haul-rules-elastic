// Dragnet [Ransomware]: dragnet-ransomware-2026-0496 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 38cab3db-0afd-5a35-a898-6d196c243977

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
