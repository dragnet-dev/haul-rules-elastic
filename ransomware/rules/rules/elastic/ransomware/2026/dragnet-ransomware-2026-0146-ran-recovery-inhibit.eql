// Dragnet [Ransomware]: dragnet-ransomware-2026-0146 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 009c1ab3-85da-51c5-93fa-8c474a4498e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
