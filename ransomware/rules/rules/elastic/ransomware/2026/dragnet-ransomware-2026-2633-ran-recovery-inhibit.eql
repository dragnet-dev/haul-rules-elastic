// Dragnet [Ransomware]: dragnet-ransomware-2026-2633 — Recovery Inhibition (secpo)
// Status: stable | Level: high | ID: 32bd64ce-32c5-5231-8953-13e45b45bd10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
