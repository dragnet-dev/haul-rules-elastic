// Dragnet [Ransomware]: dragnet-ransomware-2026-0907 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: a32bada2-b11b-5618-999f-f0c8f7b3e134

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
