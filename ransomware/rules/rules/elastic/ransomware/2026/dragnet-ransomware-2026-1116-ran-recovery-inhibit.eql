// Dragnet [Ransomware]: dragnet-ransomware-2026-1116 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 9f1b7eca-f250-56e6-8710-0d1ee9089eef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
