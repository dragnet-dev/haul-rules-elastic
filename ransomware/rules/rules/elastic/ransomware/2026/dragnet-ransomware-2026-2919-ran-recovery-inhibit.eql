// Dragnet [Ransomware]: dragnet-ransomware-2026-2919 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 45204ed6-64ad-52cf-9e41-4842fea488c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
