// Dragnet [Ransomware]: dragnet-ransomware-2026-0874 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: 7ac9b361-e2e4-56ce-ac83-c90963242923

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
