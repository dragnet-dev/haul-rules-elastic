// Dragnet [Ransomware]: dragnet-ransomware-2026-0753 — Recovery Inhibition (insomnia)
// Status: stable | Level: high | ID: df0b2f5a-0ccb-598a-b9cc-e605984b5c4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
