// Dragnet [Ransomware]: dragnet-ransomware-2026-2256 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: b0c3c554-8b54-569c-8a69-1793f22ef3c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
