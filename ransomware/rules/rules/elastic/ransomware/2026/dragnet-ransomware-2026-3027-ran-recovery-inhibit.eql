// Dragnet [Ransomware]: dragnet-ransomware-2026-3027 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 7f7f366b-317a-5039-8015-626e7dcd5ba9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
