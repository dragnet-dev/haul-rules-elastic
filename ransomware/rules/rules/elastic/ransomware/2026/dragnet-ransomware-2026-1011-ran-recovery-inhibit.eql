// Dragnet [Ransomware]: dragnet-ransomware-2026-1011 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: b14643a1-9768-5962-8f4c-9411262affb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
