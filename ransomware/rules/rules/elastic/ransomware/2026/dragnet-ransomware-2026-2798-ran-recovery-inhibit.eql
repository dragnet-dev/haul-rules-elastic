// Dragnet [Ransomware]: dragnet-ransomware-2026-2798 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: ea0f2914-e895-584a-80fe-97732206e202

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
