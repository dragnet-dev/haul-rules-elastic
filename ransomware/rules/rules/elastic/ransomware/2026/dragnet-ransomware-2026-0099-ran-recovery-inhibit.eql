// Dragnet [Ransomware]: dragnet-ransomware-2026-0099 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: e1f56715-e04e-5e0b-94d0-4b2f4f92271f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
