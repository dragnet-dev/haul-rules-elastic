// Dragnet [Ransomware]: dragnet-ransomware-2026-2781 — Recovery Inhibition (bravox)
// Status: test | Level: high | ID: bf6bfe3b-5190-55d9-962c-6a723dfe40fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
