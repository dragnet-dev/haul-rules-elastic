// Dragnet [Ransomware]: dragnet-ransomware-2026-0517 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 8934304d-4654-5e15-9ead-f1a719c33a54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
