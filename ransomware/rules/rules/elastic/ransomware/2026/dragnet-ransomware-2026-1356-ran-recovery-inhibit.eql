// Dragnet [Ransomware]: dragnet-ransomware-2026-1356 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: df91778b-2ee0-5b89-8f68-c4e569f68012

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
