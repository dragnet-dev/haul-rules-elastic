// Dragnet [Ransomware]: dragnet-ransomware-2026-0325 — Recovery Inhibition (payoutsking)
// Status: test | Level: high | ID: c02bb804-2d9c-504a-9416-16b80e1bc772

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
