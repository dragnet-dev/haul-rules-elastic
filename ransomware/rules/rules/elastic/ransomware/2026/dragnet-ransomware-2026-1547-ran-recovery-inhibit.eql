// Dragnet [Ransomware]: dragnet-ransomware-2026-1547 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 57e5e060-8536-55c6-bc11-f8937bbba064

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
