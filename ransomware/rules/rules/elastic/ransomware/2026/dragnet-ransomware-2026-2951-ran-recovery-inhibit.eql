// Dragnet [Ransomware]: dragnet-ransomware-2026-2951 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 12859aeb-2d6b-5b68-b818-b3905cc48a24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
