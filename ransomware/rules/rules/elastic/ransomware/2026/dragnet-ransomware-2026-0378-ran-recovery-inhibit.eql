// Dragnet [Ransomware]: dragnet-ransomware-2026-0378 — Recovery Inhibition (krybit)
// Status: stable | Level: high | ID: 189066d4-83bf-50d5-b9f1-d829f9d7de47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
