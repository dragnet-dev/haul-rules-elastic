// Dragnet [Ransomware]: dragnet-ransomware-2026-0332 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 4f5ad493-6169-55e4-8c49-626deb475f5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
