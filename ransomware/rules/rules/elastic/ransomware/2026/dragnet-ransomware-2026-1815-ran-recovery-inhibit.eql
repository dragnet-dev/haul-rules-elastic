// Dragnet [Ransomware]: dragnet-ransomware-2026-1815 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 137b3c70-9086-5149-b57e-ba12e4379660

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
