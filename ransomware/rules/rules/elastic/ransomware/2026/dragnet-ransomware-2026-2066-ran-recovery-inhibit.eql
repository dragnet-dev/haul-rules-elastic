// Dragnet [Ransomware]: dragnet-ransomware-2026-2066 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 33ecbd6d-a14e-5ae1-953b-5c72046c8b20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
