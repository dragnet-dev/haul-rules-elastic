// Dragnet [Ransomware]: dragnet-ransomware-2026-0989 — Recovery Inhibition (m3rx)
// Status: stable | Level: high | ID: 737829e8-a0fc-56ee-a4c1-a1c55e7e9e5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
