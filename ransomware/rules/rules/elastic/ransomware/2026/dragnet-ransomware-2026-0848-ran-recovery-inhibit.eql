// Dragnet [Ransomware]: dragnet-ransomware-2026-0848 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 89cf53af-008e-5fc3-bfe2-25e966850c50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
