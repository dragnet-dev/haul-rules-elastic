// Dragnet [Ransomware]: dragnet-ransomware-2026-2661 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 1515397b-908c-5c36-909a-23bf97a89c0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
