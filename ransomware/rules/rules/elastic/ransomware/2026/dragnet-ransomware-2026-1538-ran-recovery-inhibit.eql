// Dragnet [Ransomware]: dragnet-ransomware-2026-1538 — Recovery Inhibition (worldleaks)
// Status: test | Level: high | ID: 0c514481-b7fc-5707-a360-26bb7ecabac4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
