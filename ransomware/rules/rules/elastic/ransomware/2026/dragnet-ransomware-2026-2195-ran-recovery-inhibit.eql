// Dragnet [Ransomware]: dragnet-ransomware-2026-2195 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: dd976e39-0281-50b3-9ef1-c5b92b9f7b3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
