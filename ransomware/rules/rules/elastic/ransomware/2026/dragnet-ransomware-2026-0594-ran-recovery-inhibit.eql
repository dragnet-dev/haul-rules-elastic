// Dragnet [Ransomware]: dragnet-ransomware-2026-0594 — Recovery Inhibition (brotherhood)
// Status: deprecated | Level: high | ID: 33343a22-704c-54ae-bd64-d1ef934bd090

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
