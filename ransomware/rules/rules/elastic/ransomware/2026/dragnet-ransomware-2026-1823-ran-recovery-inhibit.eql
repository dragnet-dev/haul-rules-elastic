// Dragnet [Ransomware]: dragnet-ransomware-2026-1823 — Recovery Inhibition (m3rx)
// Status: stable | Level: high | ID: 3ee26a9a-c958-5bbd-87e4-c41a89ea2eee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
