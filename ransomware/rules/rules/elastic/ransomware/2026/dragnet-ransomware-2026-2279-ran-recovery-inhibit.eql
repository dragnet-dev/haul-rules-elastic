// Dragnet [Ransomware]: dragnet-ransomware-2026-2279 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 106682cc-2ff7-5f39-a78d-a5d99d255068

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
