// Dragnet [Ransomware]: dragnet-ransomware-2026-3005 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 134cc8eb-983c-5348-bdc8-06837164b432

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
