// Dragnet [Ransomware]: dragnet-ransomware-2026-2957 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 0d1c79d7-4f0e-5271-b674-550c74c72c54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
