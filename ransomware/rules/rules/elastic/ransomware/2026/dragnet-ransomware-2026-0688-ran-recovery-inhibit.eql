// Dragnet [Ransomware]: dragnet-ransomware-2026-0688 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: c92e2f76-4cbf-55b9-93c1-9e30c4300130

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
