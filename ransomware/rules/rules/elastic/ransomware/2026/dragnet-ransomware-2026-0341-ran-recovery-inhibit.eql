// Dragnet [Ransomware]: dragnet-ransomware-2026-0341 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: d7934a69-0d4f-5196-a972-5cf7fbe156c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
