// Dragnet [Ransomware]: dragnet-ransomware-2026-2073 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 293a817e-5c6f-564f-acd8-60b819b2ad5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
