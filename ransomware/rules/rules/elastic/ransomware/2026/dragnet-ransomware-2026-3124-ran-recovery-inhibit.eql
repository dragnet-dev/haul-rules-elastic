// Dragnet [Ransomware]: dragnet-ransomware-2026-3124 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: e35b28ce-2b85-591a-b6f7-0bbfac0cd400

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
