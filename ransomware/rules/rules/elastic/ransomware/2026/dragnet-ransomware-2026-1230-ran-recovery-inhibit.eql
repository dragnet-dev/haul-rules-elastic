// Dragnet [Ransomware]: dragnet-ransomware-2026-1230 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5ee41ac4-a133-503b-a337-1456afb1574b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
