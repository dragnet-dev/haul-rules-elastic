// Dragnet [Ransomware]: dragnet-ransomware-2026-3046 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 413134dc-fcf9-55e8-bc5f-e20ce6819087

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
