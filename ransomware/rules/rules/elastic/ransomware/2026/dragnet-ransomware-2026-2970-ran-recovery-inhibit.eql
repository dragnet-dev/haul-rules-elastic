// Dragnet [Ransomware]: dragnet-ransomware-2026-2970 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: 04a10b95-8856-5750-b2cb-b9648ad7723f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
