// Dragnet [Ransomware]: dragnet-ransomware-2026-0416 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: db513b95-31d6-5e26-868c-aea85e478f93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
