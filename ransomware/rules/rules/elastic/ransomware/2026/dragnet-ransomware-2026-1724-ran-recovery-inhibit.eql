// Dragnet [Ransomware]: dragnet-ransomware-2026-1724 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a8b2affa-467e-5d26-bd9c-c19a5ca82863

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
