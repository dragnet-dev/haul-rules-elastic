// Dragnet [Ransomware]: dragnet-ransomware-2026-0512 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 40e81a16-2511-57a0-b426-5872cea7c82c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
