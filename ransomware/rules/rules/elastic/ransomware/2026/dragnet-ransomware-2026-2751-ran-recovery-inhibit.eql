// Dragnet [Ransomware]: dragnet-ransomware-2026-2751 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 803ba0ed-d74e-5fa6-a114-b9ec288e8f43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
