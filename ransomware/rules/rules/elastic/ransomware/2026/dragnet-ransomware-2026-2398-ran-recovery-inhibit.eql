// Dragnet [Ransomware]: dragnet-ransomware-2026-2398 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 67e3fbfe-6204-54fd-a3af-2726c7139bc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
