// Dragnet [Ransomware]: dragnet-ransomware-2026-2019 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: c58163ed-8d93-5ab1-b291-45f49d9ef58d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
