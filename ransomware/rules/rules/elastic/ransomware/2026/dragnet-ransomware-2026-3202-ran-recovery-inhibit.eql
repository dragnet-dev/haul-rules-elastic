// Dragnet [Ransomware]: dragnet-ransomware-2026-3202 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: 45d92dce-8c6e-5185-92b3-902b0736942c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
