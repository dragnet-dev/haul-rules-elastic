// Dragnet [Ransomware]: dragnet-ransomware-2026-0845 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d6e9b379-2640-52dd-9c48-8d37395ffe7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
