// Dragnet [Ransomware]: dragnet-ransomware-2026-0258 — Recovery Inhibition (insomnia)
// Status: stable | Level: high | ID: fd63fffd-27a6-50c3-b0bc-7ed391cde700

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
