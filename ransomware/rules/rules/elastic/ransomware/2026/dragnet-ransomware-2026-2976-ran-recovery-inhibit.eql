// Dragnet [Ransomware]: dragnet-ransomware-2026-2976 — Recovery Inhibition (lynx)
// Status: stable | Level: high | ID: cb0088ae-11c6-594a-8afc-69f992a9fda8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
