// Dragnet [Ransomware]: dragnet-ransomware-2026-1447 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 07d2b3b3-ea8b-5b41-ac39-1db6115f5c30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
