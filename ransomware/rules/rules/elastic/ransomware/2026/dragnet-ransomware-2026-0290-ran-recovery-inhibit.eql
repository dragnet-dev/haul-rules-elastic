// Dragnet [Ransomware]: dragnet-ransomware-2026-0290 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 94d891ea-e9ca-50f1-a06f-32a0f74a1d87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
