// Dragnet [Ransomware]: dragnet-ransomware-2026-2972 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: e533e173-b0b6-5fe7-bcbf-61bc229a091d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
