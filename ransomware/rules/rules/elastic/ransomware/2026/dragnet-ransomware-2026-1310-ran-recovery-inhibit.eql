// Dragnet [Ransomware]: dragnet-ransomware-2026-1310 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 92e5f409-40ab-58a4-b91b-ea0b6e867982

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
