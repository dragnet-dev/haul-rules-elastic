// Dragnet [Ransomware]: dragnet-ransomware-2026-3478 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 5092d6a3-1ca2-5202-8350-97755941a7b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
