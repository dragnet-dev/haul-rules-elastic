// Dragnet [Ransomware]: dragnet-ransomware-2026-2122 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 7f58e512-3bab-5c1a-aa4c-c33d187a55b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
