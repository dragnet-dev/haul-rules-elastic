// Dragnet [Ransomware]: dragnet-ransomware-2026-0535 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6e4f16cd-8de6-5f72-b980-92a208f26eaa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
