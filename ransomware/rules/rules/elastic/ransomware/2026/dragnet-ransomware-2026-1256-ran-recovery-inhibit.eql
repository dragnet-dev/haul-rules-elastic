// Dragnet [Ransomware]: dragnet-ransomware-2026-1256 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 868bcfe5-c773-5d22-99b5-0897488318a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
