// Dragnet [Ransomware]: dragnet-ransomware-2026-0704 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 98679b47-64df-51fe-bd41-96e863a7b67a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
