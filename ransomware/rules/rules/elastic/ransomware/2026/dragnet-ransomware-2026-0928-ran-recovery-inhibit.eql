// Dragnet [Ransomware]: dragnet-ransomware-2026-0928 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 8aade0bf-c233-5202-9306-29b887ec90c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
