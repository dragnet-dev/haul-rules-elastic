// Dragnet [Ransomware]: dragnet-ransomware-2026-1144 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: ace9d976-40ac-594e-898b-29117e7da3a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
