// Dragnet [Ransomware]: dragnet-ransomware-2026-2456 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 43d2c6c3-6db3-58aa-a850-685a9e6a3d2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
