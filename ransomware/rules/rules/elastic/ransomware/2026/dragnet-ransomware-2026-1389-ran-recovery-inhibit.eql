// Dragnet [Ransomware]: dragnet-ransomware-2026-1389 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 5c713cce-dafb-5712-8212-1c4e9be79e49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
