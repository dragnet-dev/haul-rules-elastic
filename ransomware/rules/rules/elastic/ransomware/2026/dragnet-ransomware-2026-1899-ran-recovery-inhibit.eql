// Dragnet [Ransomware]: dragnet-ransomware-2026-1899 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 339e6566-bd88-5caa-bed4-5b5c8943a2e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
