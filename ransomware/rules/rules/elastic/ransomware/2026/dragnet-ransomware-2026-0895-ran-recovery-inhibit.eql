// Dragnet [Ransomware]: dragnet-ransomware-2026-0895 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: 1ee24072-b913-58f5-9401-1157396a0888

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
