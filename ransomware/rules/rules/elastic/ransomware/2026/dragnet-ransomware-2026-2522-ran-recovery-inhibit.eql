// Dragnet [Ransomware]: dragnet-ransomware-2026-2522 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 4ec3b372-280d-5a74-a5aa-22f3cff6bba6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
