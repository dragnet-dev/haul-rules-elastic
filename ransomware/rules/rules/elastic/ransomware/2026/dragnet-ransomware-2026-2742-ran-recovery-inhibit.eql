// Dragnet [Ransomware]: dragnet-ransomware-2026-2742 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 5aa46baa-f322-5f93-94da-c67bad35da7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
