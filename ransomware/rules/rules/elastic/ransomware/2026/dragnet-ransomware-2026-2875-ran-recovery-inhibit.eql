// Dragnet [Ransomware]: dragnet-ransomware-2026-2875 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: b4a83378-4593-5b5b-9ee8-1d74f84ce60f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
