// Dragnet [Ransomware]: dragnet-ransomware-2026-2220 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 80ee17bc-5148-53bb-8125-4d4fd683a724

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
