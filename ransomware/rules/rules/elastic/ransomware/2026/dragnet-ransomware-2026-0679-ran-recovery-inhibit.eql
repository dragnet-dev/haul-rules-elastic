// Dragnet [Ransomware]: dragnet-ransomware-2026-0679 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 84bd918a-ed66-51a9-a87e-4f5b3c1a6069

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
