// Dragnet [Ransomware]: dragnet-ransomware-2026-2129 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: b9f00d21-19d5-5052-a1b5-d2e7bf8cbd61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
