// Dragnet [Ransomware]: dragnet-ransomware-2026-1025 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 8e1335d0-557a-501d-894e-98d2cfe54716

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
