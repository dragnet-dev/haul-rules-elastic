// Dragnet [Ransomware]: dragnet-ransomware-2026-2076 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 6adc0913-117c-54fe-afa7-e32b2c1e5e13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
