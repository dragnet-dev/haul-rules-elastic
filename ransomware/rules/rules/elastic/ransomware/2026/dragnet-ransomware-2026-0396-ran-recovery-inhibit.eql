// Dragnet [Ransomware]: dragnet-ransomware-2026-0396 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 16981f3b-20ca-5403-94f4-4db784685a08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
