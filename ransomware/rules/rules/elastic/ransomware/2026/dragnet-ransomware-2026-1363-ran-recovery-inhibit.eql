// Dragnet [Ransomware]: dragnet-ransomware-2026-1363 — Recovery Inhibition (anubis)
// Status: stable | Level: high | ID: 1ebbe1ff-e971-583e-b5f8-17e4d242988e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
