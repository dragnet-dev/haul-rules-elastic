// Dragnet [Ransomware]: dragnet-ransomware-2026-3161 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 7459c064-0a43-549c-9f28-2febbb9011dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
