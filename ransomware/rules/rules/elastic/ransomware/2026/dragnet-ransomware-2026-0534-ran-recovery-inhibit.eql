// Dragnet [Ransomware]: dragnet-ransomware-2026-0534 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 06262893-49a4-5ddb-8d2d-fa0cd550ef0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
