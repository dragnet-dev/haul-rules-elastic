// Dragnet [Ransomware]: dragnet-ransomware-2026-2551 — Recovery Inhibition (worldleaks)
// Status: stable | Level: high | ID: 68a1e481-33fc-5e58-a09e-b9bd5533ae5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
