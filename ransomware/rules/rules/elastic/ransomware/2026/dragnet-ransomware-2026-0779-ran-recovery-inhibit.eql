// Dragnet [Ransomware]: dragnet-ransomware-2026-0779 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: ef071a80-9f52-553c-a07e-9101318a158e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
