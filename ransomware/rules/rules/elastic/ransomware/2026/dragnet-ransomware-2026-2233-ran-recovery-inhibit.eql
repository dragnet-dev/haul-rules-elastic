// Dragnet [Ransomware]: dragnet-ransomware-2026-2233 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: 76a6b03b-85ab-582c-849a-dd7046b114bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
