// Dragnet [Ransomware]: dragnet-ransomware-2026-0392 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 95fd0496-e1f7-54b4-92d1-497c7e758f4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
