// Dragnet [Ransomware]: dragnet-ransomware-2026-0813 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 4fde4769-527b-579c-ae7d-c51e5ee61d39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
