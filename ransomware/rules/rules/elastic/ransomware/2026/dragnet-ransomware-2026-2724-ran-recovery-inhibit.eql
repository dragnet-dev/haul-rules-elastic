// Dragnet [Ransomware]: dragnet-ransomware-2026-2724 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: c52f7664-d7cd-5824-b9f4-fd0fb01d47fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
