// Dragnet [Ransomware]: dragnet-ransomware-2026-0365 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: 71abce98-95d3-564f-b048-12ac9b30abb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
