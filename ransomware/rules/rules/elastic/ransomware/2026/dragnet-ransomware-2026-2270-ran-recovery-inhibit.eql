// Dragnet [Ransomware]: dragnet-ransomware-2026-2270 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: e7a5790b-b0b2-59e7-a0ab-347db7f8bf1f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
