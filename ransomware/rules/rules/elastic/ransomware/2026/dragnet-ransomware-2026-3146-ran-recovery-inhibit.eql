// Dragnet [Ransomware]: dragnet-ransomware-2026-3146 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 1c9afc22-0e79-5db9-9951-3fadba12a5c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
