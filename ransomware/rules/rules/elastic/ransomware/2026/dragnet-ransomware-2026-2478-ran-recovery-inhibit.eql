// Dragnet [Ransomware]: dragnet-ransomware-2026-2478 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 87ba7e82-8668-5723-97f2-f4728780ebf1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
