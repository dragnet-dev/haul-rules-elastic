// Dragnet [Ransomware]: dragnet-ransomware-2026-1161 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 4045a7a2-3a65-5ff5-9a5a-71069ffaad19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
