// Dragnet [Ransomware]: dragnet-ransomware-2026-0344 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: d70a7660-738a-5839-9fa4-4e0ead6fb554

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
