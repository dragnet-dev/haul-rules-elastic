// Dragnet [Ransomware]: dragnet-ransomware-2026-1180 — Recovery Inhibition (insomnia)
// Status: test | Level: high | ID: 097c60e4-9e87-5823-8757-4774fa2fd6b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
