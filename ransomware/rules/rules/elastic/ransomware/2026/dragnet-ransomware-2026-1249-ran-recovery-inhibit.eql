// Dragnet [Ransomware]: dragnet-ransomware-2026-1249 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: e706aa4c-0413-5d2b-9912-c1c3d8310dd4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
