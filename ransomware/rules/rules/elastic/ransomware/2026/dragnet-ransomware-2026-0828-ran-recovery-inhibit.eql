// Dragnet [Ransomware]: dragnet-ransomware-2026-0828 — Recovery Inhibition (lynx)
// Status: stable | Level: high | ID: 973cdb74-a9ce-554b-8d05-ff10f34b7c16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
