// Dragnet [Ransomware]: dragnet-ransomware-2026-2020 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 6ab3128d-f8e9-50f4-a29d-21792820829c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
