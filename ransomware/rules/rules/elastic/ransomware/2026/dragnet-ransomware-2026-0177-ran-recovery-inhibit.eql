// Dragnet [Ransomware]: dragnet-ransomware-2026-0177 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 5f4df026-7748-5220-a22c-42b857c0e80b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
