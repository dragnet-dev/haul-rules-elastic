// Dragnet [Ransomware]: dragnet-ransomware-2026-2174 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 34047d17-e47b-54a4-9709-8ccda07ff2ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
