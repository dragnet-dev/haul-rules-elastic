// Dragnet [Ransomware]: dragnet-ransomware-2026-0058 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 862fbfef-28c4-58f8-bab8-785589eedca1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
