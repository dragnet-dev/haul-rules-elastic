// Dragnet [Ransomware]: dragnet-ransomware-2026-0916 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 201d2e76-2665-511e-9bc0-68b94966511c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
