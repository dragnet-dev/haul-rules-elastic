// Dragnet [Ransomware]: dragnet-ransomware-2026-3075 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 113f7926-372d-5811-b38d-284b5a0c46b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
