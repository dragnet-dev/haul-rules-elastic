// Dragnet [Ransomware]: dragnet-ransomware-2026-2489 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: f259fce5-22d7-5dbe-8728-f27d34a0cfd3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
