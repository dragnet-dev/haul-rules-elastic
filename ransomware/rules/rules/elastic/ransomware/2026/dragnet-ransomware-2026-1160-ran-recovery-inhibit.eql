// Dragnet [Ransomware]: dragnet-ransomware-2026-1160 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: ed3629de-234e-5a7f-85e8-8a6864280172

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
