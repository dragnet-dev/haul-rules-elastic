// Dragnet [Ransomware]: dragnet-ransomware-2026-1240 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 13429183-b18b-5bcf-a12a-254eb9a67edb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
