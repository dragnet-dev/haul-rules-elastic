// Dragnet [Ransomware]: dragnet-ransomware-2026-2141 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: 61552305-aca5-53d0-bd84-a74d62f1c48c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
