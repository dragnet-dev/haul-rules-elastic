// Dragnet [Ransomware]: dragnet-ransomware-2026-2443 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: e56b67e3-0434-5abc-9eb9-904d5e9089e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
