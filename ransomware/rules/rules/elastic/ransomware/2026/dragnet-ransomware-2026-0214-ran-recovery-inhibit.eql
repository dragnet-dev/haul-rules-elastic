// Dragnet [Ransomware]: dragnet-ransomware-2026-0214 — Recovery Inhibition (anubis)
// Status: deprecated | Level: high | ID: d4a0204a-5587-5844-9267-2c728a74d087

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
