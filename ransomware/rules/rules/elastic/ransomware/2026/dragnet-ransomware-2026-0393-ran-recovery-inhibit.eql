// Dragnet [Ransomware]: dragnet-ransomware-2026-0393 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 39753d25-9eb1-56a6-b578-1d46b82856eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
