// Dragnet [Ransomware]: dragnet-ransomware-2026-2377 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 7a54b59e-45e2-5c42-8420-f96965d861ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
