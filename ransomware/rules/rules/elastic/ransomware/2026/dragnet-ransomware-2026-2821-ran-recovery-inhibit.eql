// Dragnet [Ransomware]: dragnet-ransomware-2026-2821 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: c2c9407c-baa8-52e6-8497-61cad0491aa9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
