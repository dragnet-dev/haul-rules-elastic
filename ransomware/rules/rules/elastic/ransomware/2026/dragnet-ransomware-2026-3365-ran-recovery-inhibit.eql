// Dragnet [Ransomware]: dragnet-ransomware-2026-3365 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: e52a4037-de32-526d-8198-e3e40f81e0b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
