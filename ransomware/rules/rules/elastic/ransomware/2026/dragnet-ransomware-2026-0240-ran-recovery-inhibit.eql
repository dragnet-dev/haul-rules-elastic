// Dragnet [Ransomware]: dragnet-ransomware-2026-0240 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 3f1e041d-bfef-5df8-9855-f9ae3b53a950

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
