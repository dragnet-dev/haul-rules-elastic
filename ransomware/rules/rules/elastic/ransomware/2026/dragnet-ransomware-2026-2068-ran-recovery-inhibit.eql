// Dragnet [Ransomware]: dragnet-ransomware-2026-2068 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 52474415-48ba-5910-8d33-043e75fc9c30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
