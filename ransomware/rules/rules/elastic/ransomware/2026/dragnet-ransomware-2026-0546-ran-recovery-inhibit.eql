// Dragnet [Ransomware]: dragnet-ransomware-2026-0546 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: afe8e985-fbc9-5cbb-be34-2b940edbcc6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
