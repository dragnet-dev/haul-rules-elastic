// Dragnet [Ransomware]: dragnet-ransomware-2026-2205 — Recovery Inhibition (nova)
// Status: stable | Level: high | ID: f9233474-9368-5fc8-9822-4fec851bdeff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
