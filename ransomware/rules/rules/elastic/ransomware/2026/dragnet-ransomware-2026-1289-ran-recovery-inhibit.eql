// Dragnet [Ransomware]: dragnet-ransomware-2026-1289 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 82dcdb1a-b615-5d3c-a66e-6e63cb5db079

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
