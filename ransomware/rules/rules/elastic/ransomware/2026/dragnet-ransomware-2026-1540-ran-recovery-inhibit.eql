// Dragnet [Ransomware]: dragnet-ransomware-2026-1540 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 1f35a83e-9212-5232-a819-6afcb9faf902

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
