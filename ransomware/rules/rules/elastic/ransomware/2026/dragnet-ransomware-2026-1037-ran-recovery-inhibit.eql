// Dragnet [Ransomware]: dragnet-ransomware-2026-1037 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 1595278a-641e-5795-b651-8589448c062c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
