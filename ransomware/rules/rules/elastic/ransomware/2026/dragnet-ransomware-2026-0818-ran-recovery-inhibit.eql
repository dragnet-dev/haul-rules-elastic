// Dragnet [Ransomware]: dragnet-ransomware-2026-0818 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 327904b7-91dd-5a65-acf5-fa848b6338c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
