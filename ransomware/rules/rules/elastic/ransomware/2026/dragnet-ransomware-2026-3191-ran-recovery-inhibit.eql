// Dragnet [Ransomware]: dragnet-ransomware-2026-3191 — Recovery Inhibition (osiris)
// Status: deprecated | Level: high | ID: a53fefa8-0cc0-521a-82ac-6747d1aad13d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
