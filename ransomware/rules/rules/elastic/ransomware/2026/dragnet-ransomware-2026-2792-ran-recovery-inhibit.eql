// Dragnet [Ransomware]: dragnet-ransomware-2026-2792 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: f0c337e0-47fe-52c2-a9be-57435113a4e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
