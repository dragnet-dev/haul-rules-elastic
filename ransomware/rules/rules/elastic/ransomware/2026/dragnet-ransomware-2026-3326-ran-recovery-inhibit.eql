// Dragnet [Ransomware]: dragnet-ransomware-2026-3326 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 6327c36e-c50e-57ee-a315-3e4d7b418628

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
