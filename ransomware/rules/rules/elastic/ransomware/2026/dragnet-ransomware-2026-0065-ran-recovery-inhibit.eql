// Dragnet [Ransomware]: dragnet-ransomware-2026-0065 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 4d27d026-e0c6-53e9-9c3e-4ff686c07da8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
