// Dragnet [Ransomware]: dragnet-ransomware-2026-1997 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2f9be2b8-7ef4-5a39-821e-3c273a4abef8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
