// Dragnet [Ransomware]: dragnet-ransomware-2026-3540 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 0341b56c-13e3-5c34-a4db-d9629a1ffabc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
