// Dragnet [Ransomware]: dragnet-ransomware-2026-3241 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: c52ab1b7-883e-5407-9e6c-8671f11cefda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
