// Dragnet [Ransomware]: dragnet-ransomware-2026-1508 — Recovery Inhibition (titan)
// Status: stable | Level: high | ID: da7f337d-9676-5794-98e3-d2f65199a119

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
