// Dragnet [Ransomware]: dragnet-ransomware-2026-1397 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 80044a5c-3f03-59ca-ae89-cc76c02a1901

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
