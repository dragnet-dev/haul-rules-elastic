// Dragnet [Ransomware]: dragnet-ransomware-2026-1405 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 28a84c63-59b8-5815-b589-e7d515a06760

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
