// Dragnet [Ransomware]: dragnet-ransomware-2026-2336 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 857b1eb9-e0f6-5669-9a9e-9b490246544c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
