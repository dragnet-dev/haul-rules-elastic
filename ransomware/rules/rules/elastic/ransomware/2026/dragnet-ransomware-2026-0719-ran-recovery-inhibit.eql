// Dragnet [Ransomware]: dragnet-ransomware-2026-0719 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9921833d-9ac1-56c8-9368-e8137687c5fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
