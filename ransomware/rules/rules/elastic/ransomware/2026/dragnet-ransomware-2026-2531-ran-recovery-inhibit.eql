// Dragnet [Ransomware]: dragnet-ransomware-2026-2531 — Recovery Inhibition (morpheus)
// Status: deprecated | Level: high | ID: 65679369-7ccf-5cb6-817e-67432d10e17c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
