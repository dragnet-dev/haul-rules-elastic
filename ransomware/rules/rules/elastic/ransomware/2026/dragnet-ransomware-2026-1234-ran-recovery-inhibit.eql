// Dragnet [Ransomware]: dragnet-ransomware-2026-1234 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: c81140b7-06ee-53eb-8fa9-4bb9f5e628f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
