// Dragnet [Ransomware]: dragnet-ransomware-2026-2334 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 008833a2-6d97-5ff5-b676-b049c4847bae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
