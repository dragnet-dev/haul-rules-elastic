// Dragnet [Ransomware]: dragnet-ransomware-2026-0783 — Recovery Inhibition (pear)
// Status: stable | Level: high | ID: f17f6000-c787-5bae-b35c-0264eadbade0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
