// Dragnet [Ransomware]: dragnet-ransomware-2026-1705 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 1a578c26-4807-5c01-ab3b-acc8d7edd3fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
