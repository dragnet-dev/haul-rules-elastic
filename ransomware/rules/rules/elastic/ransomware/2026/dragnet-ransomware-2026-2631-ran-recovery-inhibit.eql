// Dragnet [Ransomware]: dragnet-ransomware-2026-2631 — Recovery Inhibition (exitium)
// Status: stable | Level: high | ID: f0824076-cba4-599f-a96b-af43de70310d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
