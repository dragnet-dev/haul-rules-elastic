// Dragnet [Ransomware]: dragnet-ransomware-2026-1136 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: c3be47ee-1412-57f8-a85d-0a012afc8fdf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
