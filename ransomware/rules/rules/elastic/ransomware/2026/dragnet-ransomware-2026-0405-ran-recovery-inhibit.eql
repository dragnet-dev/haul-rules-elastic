// Dragnet [Ransomware]: dragnet-ransomware-2026-0405 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 9e6cf1f3-aeb6-5936-ac83-fb031846221d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
