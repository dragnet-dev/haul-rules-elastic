// Dragnet [Ransomware]: dragnet-ransomware-2026-3447 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: 65849d5e-6df6-5380-a899-b1e4f4379fd4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
