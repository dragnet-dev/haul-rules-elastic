// Dragnet [Ransomware]: dragnet-ransomware-2026-1865 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 8693e526-4ea8-5331-b665-6413b547f3b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
