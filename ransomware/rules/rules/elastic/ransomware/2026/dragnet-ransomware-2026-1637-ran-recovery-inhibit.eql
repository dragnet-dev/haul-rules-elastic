// Dragnet [Ransomware]: dragnet-ransomware-2026-1637 — Recovery Inhibition (LeakBazaar)
// Status: stable | Level: high | ID: 7e957a7d-60cc-5965-9fb5-10f554dabe11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
