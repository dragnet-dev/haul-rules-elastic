// Dragnet [Ransomware]: dragnet-ransomware-2026-2196 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 4089f0be-33d1-553d-8eb9-452fea49f8ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
