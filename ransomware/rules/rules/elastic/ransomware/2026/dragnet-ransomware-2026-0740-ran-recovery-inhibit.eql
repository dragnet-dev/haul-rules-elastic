// Dragnet [Ransomware]: dragnet-ransomware-2026-0740 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: f48d8a9c-a713-58d2-ac35-9269f8c9fe44

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
