// Dragnet [Ransomware]: dragnet-ransomware-2026-3209 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: c7a55376-410f-55fe-b59b-78f37ad7555b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
