// Dragnet [Ransomware]: dragnet-ransomware-2026-1813 — Recovery Inhibition (nightspire)
// Status: stable | Level: high | ID: f160e2a6-491f-537b-880c-af8a84e3f631

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
