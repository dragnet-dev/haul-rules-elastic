// Dragnet [Ransomware]: dragnet-ransomware-2026-3120 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 2d7a884c-9c9b-50b6-8758-e9aedce506c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
