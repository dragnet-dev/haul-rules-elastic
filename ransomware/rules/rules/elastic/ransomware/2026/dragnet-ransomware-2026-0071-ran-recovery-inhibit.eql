// Dragnet [Ransomware]: dragnet-ransomware-2026-0071 — Recovery Inhibition (titan)
// Status: stable | Level: high | ID: 5ca8b0d2-b841-57f4-8dc1-ce2197907caf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
