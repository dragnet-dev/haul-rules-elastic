// Dragnet [Ransomware]: dragnet-ransomware-2026-1341 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f6d57262-6749-52e5-afa3-40d3bd6e8467

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
