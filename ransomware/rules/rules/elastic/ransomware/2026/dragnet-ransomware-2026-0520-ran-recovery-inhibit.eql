// Dragnet [Ransomware]: dragnet-ransomware-2026-0520 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 1c0ba1f5-8bde-56c3-a983-52293f4c47c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
