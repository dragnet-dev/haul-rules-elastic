// Dragnet [Ransomware]: dragnet-ransomware-2026-2208 — Recovery Inhibition (sinobi)
// Status: stable | Level: high | ID: f5841f24-08e7-584d-a5e7-6da59278f1d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
