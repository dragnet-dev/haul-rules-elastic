// Dragnet [Ransomware]: dragnet-ransomware-2026-1432 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 846113ec-b8e6-5f60-bf61-0e695080aae1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
