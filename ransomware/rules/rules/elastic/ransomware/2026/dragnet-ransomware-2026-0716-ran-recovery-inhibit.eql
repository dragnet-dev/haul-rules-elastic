// Dragnet [Ransomware]: dragnet-ransomware-2026-0716 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: e28145f7-5ac8-5241-8851-9d49b0e0bade

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
