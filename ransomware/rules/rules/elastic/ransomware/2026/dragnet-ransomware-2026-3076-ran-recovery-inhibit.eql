// Dragnet [Ransomware]: dragnet-ransomware-2026-3076 — Recovery Inhibition (lapsus$)
// Status: deprecated | Level: high | ID: 90f836e4-9d41-5daa-9a39-bd2dabb64502

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
