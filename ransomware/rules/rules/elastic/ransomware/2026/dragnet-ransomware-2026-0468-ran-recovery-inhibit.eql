// Dragnet [Ransomware]: dragnet-ransomware-2026-0468 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 883536ca-fe31-5012-9da8-60299a4fb84f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
