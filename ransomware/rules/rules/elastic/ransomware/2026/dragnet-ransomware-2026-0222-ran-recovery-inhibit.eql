// Dragnet [Ransomware]: dragnet-ransomware-2026-0222 — Recovery Inhibition (ransomhouse)
// Status: test | Level: high | ID: c1f2f7ec-69dc-5cc1-8509-0a25ddfa037f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
