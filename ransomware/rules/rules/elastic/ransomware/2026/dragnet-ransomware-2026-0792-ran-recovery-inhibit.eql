// Dragnet [Ransomware]: dragnet-ransomware-2026-0792 — Recovery Inhibition (gunra)
// Status: stable | Level: high | ID: fc9feaa4-ab64-57ed-8cee-bae280ecfe2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
