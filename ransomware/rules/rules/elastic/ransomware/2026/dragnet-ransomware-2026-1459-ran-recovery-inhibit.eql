// Dragnet [Ransomware]: dragnet-ransomware-2026-1459 — Recovery Inhibition (nova)
// Status: stable | Level: high | ID: 5a6f39af-4e28-5da2-978a-ded810446047

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
