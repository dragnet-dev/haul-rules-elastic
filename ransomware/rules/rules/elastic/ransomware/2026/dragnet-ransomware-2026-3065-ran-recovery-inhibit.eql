// Dragnet [Ransomware]: dragnet-ransomware-2026-3065 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: ba956f81-9167-5091-9f78-2c2d6c813c59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
