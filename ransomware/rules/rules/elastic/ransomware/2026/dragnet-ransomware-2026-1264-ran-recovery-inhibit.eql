// Dragnet [Ransomware]: dragnet-ransomware-2026-1264 — Recovery Inhibition (nova)
// Status: stable | Level: high | ID: 193d4e57-95c2-5781-9090-990436691163

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
