// Dragnet [Ransomware]: dragnet-ransomware-2026-1702 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 958ad91e-04b3-5f91-b5df-9a41fa49b25b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
