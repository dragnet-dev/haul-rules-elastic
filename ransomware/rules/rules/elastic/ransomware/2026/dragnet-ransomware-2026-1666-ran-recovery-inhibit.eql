// Dragnet [Ransomware]: dragnet-ransomware-2026-1666 — Recovery Inhibition (worldleaks)
// Status: stable | Level: high | ID: f9037dd1-3836-5ed4-abfc-0d8a5c13e336

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
