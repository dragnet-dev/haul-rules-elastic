// Dragnet [Ransomware]: dragnet-ransomware-2026-2457 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: f1d593f6-43e0-5e32-b0f2-e01535d2bbf5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
