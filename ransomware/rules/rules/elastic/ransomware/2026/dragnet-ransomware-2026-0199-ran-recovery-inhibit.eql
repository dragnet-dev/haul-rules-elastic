// Dragnet [Ransomware]: dragnet-ransomware-2026-0199 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d2deb1b1-659d-5782-bd94-35a1eb1e651d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
