// Dragnet [Ransomware]: dragnet-ransomware-2026-1225 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 5cc9d8c0-be73-5e8a-b5fa-c17dd3c2f637

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
