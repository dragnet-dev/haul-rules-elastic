// Dragnet [Ransomware]: dragnet-ransomware-2026-0838 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 2f063609-b64e-5f24-a44d-99d66633ae6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
