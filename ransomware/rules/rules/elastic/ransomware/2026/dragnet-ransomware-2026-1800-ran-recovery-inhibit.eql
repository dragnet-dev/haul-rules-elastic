// Dragnet [Ransomware]: dragnet-ransomware-2026-1800 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: e8b6c227-e316-566b-ba7f-79ad64a3ac73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
