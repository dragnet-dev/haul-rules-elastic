// Dragnet [Ransomware]: dragnet-ransomware-2026-1496 — Recovery Inhibition (worldleaks)
// Status: stable | Level: high | ID: 27c5e3e5-3978-5a8e-9ad5-1cd10df17b42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
