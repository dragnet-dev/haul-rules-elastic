// Dragnet [Ransomware]: dragnet-ransomware-2026-2149 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 31862eb9-e409-5ca7-8375-568dcdd850a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
