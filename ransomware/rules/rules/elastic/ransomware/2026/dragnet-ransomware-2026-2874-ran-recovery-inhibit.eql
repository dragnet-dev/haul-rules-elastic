// Dragnet [Ransomware]: dragnet-ransomware-2026-2874 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 07c511a2-f965-546f-ab16-c65bc96f8c88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
