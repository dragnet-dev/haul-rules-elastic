// Dragnet [Ransomware]: dragnet-ransomware-2026-2421 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: da553d51-c535-5db8-840c-508aafcb70df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
