// Dragnet [Ransomware]: dragnet-ransomware-2026-2511 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 41638d19-1c3a-5d48-a616-adab1871ad9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
