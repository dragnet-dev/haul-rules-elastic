// Dragnet [Ransomware]: dragnet-ransomware-2026-0327 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 6b6d65a4-646d-5df9-be41-c2d4d95b8070

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
