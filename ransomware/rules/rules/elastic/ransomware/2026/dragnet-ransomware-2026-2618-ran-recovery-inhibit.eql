// Dragnet [Ransomware]: dragnet-ransomware-2026-2618 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 1ca035d5-bfa4-555b-bdbc-3cf3217e824a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
