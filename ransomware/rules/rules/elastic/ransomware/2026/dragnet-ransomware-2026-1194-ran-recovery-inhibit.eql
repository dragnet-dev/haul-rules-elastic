// Dragnet [Ransomware]: dragnet-ransomware-2026-1194 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: b29e6ea9-a75f-5842-9332-216e886f4780

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
