// Dragnet [Ransomware]: dragnet-ransomware-2026-2902 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 0de55c14-c2f0-5522-b991-6ba771e7de04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
