// Dragnet [Ransomware]: dragnet-ransomware-2026-1506 — Recovery Inhibition (interlock)
// Status: stable | Level: high | ID: 9dae32e1-bb5d-558b-ac3f-6af94ed1aa9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
