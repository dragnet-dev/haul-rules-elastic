// Dragnet [Ransomware]: dragnet-ransomware-2026-0940 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: e53b59fb-3447-5818-ae2b-e330b35c093a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
