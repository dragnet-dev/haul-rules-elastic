// Dragnet [Ransomware]: dragnet-ransomware-2026-1613 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 5905438c-2102-5a9e-afe4-bafe72bb25d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
