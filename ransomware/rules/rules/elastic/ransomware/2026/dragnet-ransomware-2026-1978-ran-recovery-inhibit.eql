// Dragnet [Ransomware]: dragnet-ransomware-2026-1978 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4eef4a8a-2f86-50b9-aad6-73a0e4bff063

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
