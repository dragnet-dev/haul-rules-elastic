// Dragnet [Ransomware]: dragnet-ransomware-2026-0715 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 01e2e5d3-b165-516e-b716-348c6860864e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
