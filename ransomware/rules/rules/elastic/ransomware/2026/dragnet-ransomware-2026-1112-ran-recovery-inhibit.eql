// Dragnet [Ransomware]: dragnet-ransomware-2026-1112 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 9ba09379-b538-5202-9233-a23a8d317e0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
