// Dragnet [Ransomware]: dragnet-ransomware-2026-1740 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: c2f50676-e6c5-5bd2-ba09-6dead12deb06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
