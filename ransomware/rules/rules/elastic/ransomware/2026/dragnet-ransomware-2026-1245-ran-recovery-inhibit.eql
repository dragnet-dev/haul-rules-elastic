// Dragnet [Ransomware]: dragnet-ransomware-2026-1245 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: ed64254f-9271-59eb-a9ed-a05a1a0b57ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
