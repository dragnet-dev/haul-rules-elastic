// Dragnet [Ransomware]: dragnet-ransomware-2026-3083 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 37eb704b-0d26-5358-b6d9-b6ae0fd0363b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
