// Dragnet [Ransomware]: dragnet-ransomware-2026-2864 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: f8ad7caa-3996-56f1-a006-304944b87f3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
