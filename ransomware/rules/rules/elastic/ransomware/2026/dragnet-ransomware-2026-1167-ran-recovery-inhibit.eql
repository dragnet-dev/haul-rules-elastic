// Dragnet [Ransomware]: dragnet-ransomware-2026-1167 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 01e00e4a-0b93-51b5-a22b-15433f9a8a56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
