// Dragnet [Ransomware]: dragnet-ransomware-2026-0938 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: f88b7071-f79e-51d2-8a24-119385a99508

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
