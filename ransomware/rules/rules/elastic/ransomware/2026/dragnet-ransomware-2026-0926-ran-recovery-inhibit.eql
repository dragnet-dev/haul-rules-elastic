// Dragnet [Ransomware]: dragnet-ransomware-2026-0926 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: fc1f4c70-71ec-5aaf-9788-a27366571bb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
