// Dragnet [Ransomware]: dragnet-ransomware-2026-3050 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1a804b22-4a45-565d-acbd-bc8f6e4d1fe0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
