// Dragnet [Ransomware]: dragnet-ransomware-2026-2294 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 9a146f5d-ac47-5316-a8d9-cb3b6460df61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
