// Dragnet [Ransomware]: dragnet-ransomware-2026-3309 — Recovery Inhibition (lynx)
// Status: stable | Level: high | ID: a9e1872b-70ec-5172-84c3-800ba1fd13d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
