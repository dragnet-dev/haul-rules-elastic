// Dragnet [Ransomware]: dragnet-ransomware-2026-0046 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: a2358960-c964-5533-8fe4-a440f913ec32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
