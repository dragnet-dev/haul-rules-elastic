// Dragnet [Ransomware]: dragnet-ransomware-2026-1121 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: ec098d77-a55d-5721-8f2b-c22c31d73e33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
