// Dragnet [Ransomware]: dragnet-ransomware-2026-0843 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 680f7640-806a-5f03-a638-08df7111639e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
