// Dragnet [Ransomware]: dragnet-ransomware-2026-0421 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 12b0ecbf-4599-55ae-af51-607b79b685b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
