// Dragnet [Ransomware]: dragnet-ransomware-2026-2166 — Recovery Inhibition (exitium)
// Status: stable | Level: high | ID: 325c5dba-3b2f-52e0-9593-6e81189ef4d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
