// Dragnet [Ransomware]: dragnet-ransomware-2026-0030 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 4ac1fc3d-4625-5cab-85c7-92fe09b1fac4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
