// Dragnet [Ransomware]: dragnet-ransomware-2026-0097 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 011a0743-bc47-53ee-bfe8-b7dc90938a95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
