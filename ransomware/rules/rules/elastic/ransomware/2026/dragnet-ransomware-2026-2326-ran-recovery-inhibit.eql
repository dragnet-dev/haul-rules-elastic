// Dragnet [Ransomware]: dragnet-ransomware-2026-2326 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 88856fb9-bae2-5c98-a280-08fdd6e0caab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
