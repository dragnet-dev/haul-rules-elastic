// Dragnet [Ransomware]: dragnet-ransomware-2026-1871 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 841fbce3-9abb-5e7c-af41-ee3c2ef0aa68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
