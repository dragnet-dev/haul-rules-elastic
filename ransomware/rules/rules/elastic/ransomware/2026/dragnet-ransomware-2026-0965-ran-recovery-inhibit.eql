// Dragnet [Ransomware]: dragnet-ransomware-2026-0965 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 404285cd-2ce3-5db2-8d01-e03564989154

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
