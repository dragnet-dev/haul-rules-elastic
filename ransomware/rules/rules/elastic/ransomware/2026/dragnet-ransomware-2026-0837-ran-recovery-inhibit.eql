// Dragnet [Ransomware]: dragnet-ransomware-2026-0837 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 8d8b0552-bd3c-5d17-ac26-69ae6f09b44f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
