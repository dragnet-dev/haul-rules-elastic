// Dragnet [Ransomware]: dragnet-ransomware-2026-2933 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d706eb7a-bf1d-5190-8f79-8b3499fb097a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
