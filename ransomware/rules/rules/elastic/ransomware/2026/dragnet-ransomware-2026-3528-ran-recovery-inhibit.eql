// Dragnet [Ransomware]: dragnet-ransomware-2026-3528 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 650a2a49-5ed0-5c0e-90d9-f55f5d0b1fd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
