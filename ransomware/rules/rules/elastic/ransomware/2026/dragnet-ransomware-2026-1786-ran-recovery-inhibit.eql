// Dragnet [Ransomware]: dragnet-ransomware-2026-1786 — Recovery Inhibition (BrainCipher)
// Status: stable | Level: high | ID: 9273aa75-2607-5498-b243-ae4e1642b0f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
