// Dragnet [Ransomware]: dragnet-ransomware-2026-2132 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 631124b3-d617-5c60-987f-95c747f1f2a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
