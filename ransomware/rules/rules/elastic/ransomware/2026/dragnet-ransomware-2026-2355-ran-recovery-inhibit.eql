// Dragnet [Ransomware]: dragnet-ransomware-2026-2355 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 2fdb1d8d-e5a4-5914-a437-7a409f0eb6db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
