// Dragnet [Ransomware]: dragnet-ransomware-2026-1213 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d26376ac-0961-54e3-84ab-8b7d76810fd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
