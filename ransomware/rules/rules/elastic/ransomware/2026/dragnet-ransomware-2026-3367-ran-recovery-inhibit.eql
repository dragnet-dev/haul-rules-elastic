// Dragnet [Ransomware]: dragnet-ransomware-2026-3367 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 956cdd29-3d55-5eb8-a209-fcb9aa610ce1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
