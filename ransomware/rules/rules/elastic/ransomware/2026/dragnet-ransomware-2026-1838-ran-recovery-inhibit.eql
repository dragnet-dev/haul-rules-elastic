// Dragnet [Ransomware]: dragnet-ransomware-2026-1838 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 92c9a52d-5e3e-55df-8646-3384951c849b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
