// Dragnet [Ransomware]: dragnet-ransomware-2026-2496 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 9f43bac7-c68d-550e-9232-c86d6bc5fb0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
