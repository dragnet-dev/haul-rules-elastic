// Dragnet [Ransomware]: dragnet-ransomware-2026-2854 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 34a966bb-bc63-56f0-ba29-b8cda596df24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
