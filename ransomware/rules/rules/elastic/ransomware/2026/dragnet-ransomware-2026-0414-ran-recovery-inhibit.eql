// Dragnet [Ransomware]: dragnet-ransomware-2026-0414 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 0f8b21f7-ac69-566f-a923-f7449cdb6bb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
