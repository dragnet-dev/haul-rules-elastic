// Dragnet [Ransomware]: dragnet-ransomware-2026-1817 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: b3710235-a718-5083-a5b3-f553c87a2488

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
