// Dragnet [Ransomware]: dragnet-ransomware-2026-1657 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: c818ccd9-9afe-5097-bfeb-044b3e29b859

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
