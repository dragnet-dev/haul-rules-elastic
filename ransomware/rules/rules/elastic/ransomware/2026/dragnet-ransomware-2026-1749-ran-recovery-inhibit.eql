// Dragnet [Ransomware]: dragnet-ransomware-2026-1749 — Recovery Inhibition (shadowbyt3$)
// Status: deprecated | Level: high | ID: 3de12a95-3a14-59ea-93ae-316ab6cfe73e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
