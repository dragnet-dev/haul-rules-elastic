// Dragnet [Ransomware]: dragnet-ransomware-2026-0063 — Recovery Inhibition (lapsus$)
// Status: deprecated | Level: high | ID: 16a64505-3547-5fec-8c3f-d86cc2dfd2cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
