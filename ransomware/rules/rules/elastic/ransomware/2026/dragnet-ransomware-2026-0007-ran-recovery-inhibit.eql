// Dragnet [Ransomware]: dragnet-ransomware-2026-0007 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: b131be23-75b4-5a51-80bb-5fcf6f254087

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
