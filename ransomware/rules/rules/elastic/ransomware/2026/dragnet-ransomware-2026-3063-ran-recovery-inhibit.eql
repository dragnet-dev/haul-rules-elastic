// Dragnet [Ransomware]: dragnet-ransomware-2026-3063 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 34e9f962-0f49-576f-8a71-b111849f8268

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
