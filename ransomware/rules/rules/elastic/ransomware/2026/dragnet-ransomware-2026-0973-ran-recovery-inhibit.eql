// Dragnet [Ransomware]: dragnet-ransomware-2026-0973 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: f983e358-7735-5f84-92d8-5d540a5db900

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
