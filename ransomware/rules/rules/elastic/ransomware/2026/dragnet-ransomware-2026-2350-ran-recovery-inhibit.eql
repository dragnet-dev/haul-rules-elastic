// Dragnet [Ransomware]: dragnet-ransomware-2026-2350 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 46711a83-122c-55f1-9a43-ce374d1c2b77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
