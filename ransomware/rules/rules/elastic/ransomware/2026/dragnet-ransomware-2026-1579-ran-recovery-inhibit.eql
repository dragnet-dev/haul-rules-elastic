// Dragnet [Ransomware]: dragnet-ransomware-2026-1579 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: c8f0b4ce-4f2c-53fe-9940-b281e417ded7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
