// Dragnet [Ransomware]: dragnet-ransomware-2026-0588 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: d4db8af3-1d70-5fe7-9e35-7ffc0be3c4aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
