// Dragnet [Ransomware]: dragnet-ransomware-2026-3106 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 7db21c56-9bbb-50bf-b8d9-eb7fcc933eb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
