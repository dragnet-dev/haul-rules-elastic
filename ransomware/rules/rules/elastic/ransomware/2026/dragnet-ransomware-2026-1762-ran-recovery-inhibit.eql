// Dragnet [Ransomware]: dragnet-ransomware-2026-1762 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: eca9ed3d-60f2-5d03-8331-680c04414697

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
