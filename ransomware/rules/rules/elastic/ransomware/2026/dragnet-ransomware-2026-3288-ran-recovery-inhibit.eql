// Dragnet [Ransomware]: dragnet-ransomware-2026-3288 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 68e516e4-a0f4-55a0-bc68-1b1212aad8a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
