// Dragnet [Ransomware]: dragnet-ransomware-2026-3514 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 02ba2390-279a-555d-9a3e-4775225f5a77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
