// Dragnet [Ransomware]: dragnet-ransomware-2026-0479 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 73b76b4d-f02e-5064-a5ae-55e90065bd52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
