// Dragnet [Ransomware]: dragnet-ransomware-2026-2640 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: e9f16129-747d-5ade-8183-8daab7ab68ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
