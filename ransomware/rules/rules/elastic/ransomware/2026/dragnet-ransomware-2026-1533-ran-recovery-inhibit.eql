// Dragnet [Ransomware]: dragnet-ransomware-2026-1533 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: a8786b84-ff0b-599d-a881-cda6bc87b39e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
