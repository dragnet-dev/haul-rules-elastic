// Dragnet [Ransomware]: dragnet-ransomware-2026-3461 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: f2bd5647-926e-5a93-ae1d-158bd5d2c9ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
