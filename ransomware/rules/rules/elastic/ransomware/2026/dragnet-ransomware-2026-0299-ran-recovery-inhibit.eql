// Dragnet [Ransomware]: dragnet-ransomware-2026-0299 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: e448d138-9b39-5a72-9b90-7dfc79a43566

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
