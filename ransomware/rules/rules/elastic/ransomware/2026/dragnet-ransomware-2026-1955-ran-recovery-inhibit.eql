// Dragnet [Ransomware]: dragnet-ransomware-2026-1955 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 67b8ee8b-d3df-5e28-9619-1bbc3fab5d1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
