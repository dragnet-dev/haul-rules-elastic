// Dragnet [Ransomware]: dragnet-ransomware-2026-1761 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 423799d5-0d0e-533d-a0f9-e23341d904f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
