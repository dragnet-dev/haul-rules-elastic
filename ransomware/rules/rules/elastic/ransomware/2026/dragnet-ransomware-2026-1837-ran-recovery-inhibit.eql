// Dragnet [Ransomware]: dragnet-ransomware-2026-1837 — Recovery Inhibition (moneymessage)
// Status: stable | Level: high | ID: 3b5dac9c-c1a7-541a-b5ab-ce1875a7e50e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
