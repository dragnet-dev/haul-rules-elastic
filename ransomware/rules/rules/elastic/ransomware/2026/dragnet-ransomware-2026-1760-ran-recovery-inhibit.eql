// Dragnet [Ransomware]: dragnet-ransomware-2026-1760 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: c01c1a64-5550-570d-968d-56102466ea34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
