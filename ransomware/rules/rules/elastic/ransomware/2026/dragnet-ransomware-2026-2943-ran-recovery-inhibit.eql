// Dragnet [Ransomware]: dragnet-ransomware-2026-2943 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 76874e96-1eda-58df-8278-26293994ac67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
