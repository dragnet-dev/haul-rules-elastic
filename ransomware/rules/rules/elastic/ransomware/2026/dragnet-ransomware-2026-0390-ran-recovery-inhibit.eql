// Dragnet [Ransomware]: dragnet-ransomware-2026-0390 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 5eea0624-22d6-5f23-94f5-0bc2eb677eed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
