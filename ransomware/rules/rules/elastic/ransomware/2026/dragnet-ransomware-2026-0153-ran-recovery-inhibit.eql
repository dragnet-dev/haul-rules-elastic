// Dragnet [Ransomware]: dragnet-ransomware-2026-0153 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 0317db16-c754-5a4e-8d99-8436cc326c86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
