// Dragnet [Ransomware]: dragnet-ransomware-2026-0474 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 0877375f-d0a7-5e93-be9a-d882e3961308

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
