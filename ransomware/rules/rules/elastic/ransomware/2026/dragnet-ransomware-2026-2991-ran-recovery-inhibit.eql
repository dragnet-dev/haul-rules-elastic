// Dragnet [Ransomware]: dragnet-ransomware-2026-2991 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 8a8db0c3-80b1-5593-b7cc-0424c161c50f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
