// Dragnet [Ransomware]: dragnet-ransomware-2026-2931 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: bb215592-ff1c-5db9-a22c-03d06476f656

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
