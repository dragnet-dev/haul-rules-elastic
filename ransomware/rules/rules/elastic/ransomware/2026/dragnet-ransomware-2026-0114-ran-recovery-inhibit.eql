// Dragnet [Ransomware]: dragnet-ransomware-2026-0114 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 0dab6325-f5c3-5577-b18a-07cf7f18f92d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
