// Dragnet [Ransomware]: dragnet-ransomware-2026-2879 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 03693470-1f63-50e3-9915-d7bc80a789b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
