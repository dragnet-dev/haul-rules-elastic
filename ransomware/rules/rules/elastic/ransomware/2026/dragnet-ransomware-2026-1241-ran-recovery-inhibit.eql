// Dragnet [Ransomware]: dragnet-ransomware-2026-1241 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 9d79d03f-9f72-55b7-95cb-0494693596d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
