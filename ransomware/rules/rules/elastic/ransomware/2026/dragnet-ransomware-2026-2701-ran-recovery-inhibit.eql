// Dragnet [Ransomware]: dragnet-ransomware-2026-2701 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 0a04c400-752f-594d-8208-9d7b61e3ecff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
