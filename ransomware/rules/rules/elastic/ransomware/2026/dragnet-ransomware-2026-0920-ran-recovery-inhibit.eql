// Dragnet [Ransomware]: dragnet-ransomware-2026-0920 — Recovery Inhibition (fulcrumsec)
// Status: stable | Level: high | ID: fb0b8ef2-f04b-56e2-a1f4-2a451033ec53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
