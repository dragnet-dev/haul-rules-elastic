// Dragnet [Ransomware]: dragnet-ransomware-2026-3318 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 0c513234-4a36-5ec8-95d3-cf8817dfc34d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
