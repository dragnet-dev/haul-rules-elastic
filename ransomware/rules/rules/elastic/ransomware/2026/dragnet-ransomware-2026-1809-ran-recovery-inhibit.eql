// Dragnet [Ransomware]: dragnet-ransomware-2026-1809 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: b6fa1214-b41b-5f3c-8d2a-0874c5737cc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
