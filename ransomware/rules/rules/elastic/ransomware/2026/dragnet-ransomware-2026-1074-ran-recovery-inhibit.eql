// Dragnet [Ransomware]: dragnet-ransomware-2026-1074 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: dfba6306-f092-504e-a83e-befddc93ff4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
