// Dragnet [Ransomware]: dragnet-ransomware-2026-1083 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 515ba9b2-b1ef-546d-a546-9c0bb025d6f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
