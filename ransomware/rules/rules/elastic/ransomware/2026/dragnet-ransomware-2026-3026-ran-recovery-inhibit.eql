// Dragnet [Ransomware]: dragnet-ransomware-2026-3026 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: d5942323-7a3c-519f-870b-42bc0b9e2255

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
