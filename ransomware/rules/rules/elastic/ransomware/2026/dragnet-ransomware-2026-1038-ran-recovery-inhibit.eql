// Dragnet [Ransomware]: dragnet-ransomware-2026-1038 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 8b18fa2e-3b6e-5443-b16e-4196414afed2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
