// Dragnet [Ransomware]: dragnet-ransomware-2026-2778 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 78ad62cc-3248-5e3f-b354-0353c6d55502

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
