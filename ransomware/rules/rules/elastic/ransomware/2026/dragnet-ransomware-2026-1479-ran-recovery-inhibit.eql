// Dragnet [Ransomware]: dragnet-ransomware-2026-1479 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: c36d1b95-5004-50ed-bfc8-e364276b5b52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
