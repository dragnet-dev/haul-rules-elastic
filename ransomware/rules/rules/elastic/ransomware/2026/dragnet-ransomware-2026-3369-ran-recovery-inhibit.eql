// Dragnet [Ransomware]: dragnet-ransomware-2026-3369 — Recovery Inhibition (aurora)
// Status: stable | Level: high | ID: 0af63774-eccd-5d68-a4d1-1ef76e440d83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
