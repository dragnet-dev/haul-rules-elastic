// Dragnet [Ransomware]: dragnet-ransomware-2026-1353 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: f50c6acd-0b67-576d-892a-e6a7ebb1c82b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
