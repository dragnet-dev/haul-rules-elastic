// Dragnet [Ransomware]: dragnet-ransomware-2026-2840 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 1f4e0212-4be4-5495-a7f0-a0c579bc00e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
