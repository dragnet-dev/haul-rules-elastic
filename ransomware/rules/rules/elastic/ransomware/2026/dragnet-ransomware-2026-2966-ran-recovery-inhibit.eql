// Dragnet [Ransomware]: dragnet-ransomware-2026-2966 — Recovery Inhibition (AuditTeam)
// Status: stable | Level: high | ID: 00677bff-244e-5ec8-a92b-8f40fa6bb47d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
