// Dragnet [Ransomware]: dragnet-ransomware-2026-1616 — Recovery Inhibition (beast)
// Status: test | Level: high | ID: 1213430b-404b-58db-9439-776623380147

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
