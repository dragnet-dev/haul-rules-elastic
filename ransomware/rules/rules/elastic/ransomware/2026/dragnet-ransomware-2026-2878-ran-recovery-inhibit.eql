// Dragnet [Ransomware]: dragnet-ransomware-2026-2878 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d7f38afe-e71a-59e3-b145-6b42b64765cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
