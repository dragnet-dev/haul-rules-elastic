// Dragnet [Ransomware]: dragnet-ransomware-2026-0399 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d0e150af-ff72-5b2f-96a2-6da19e7fb429

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
