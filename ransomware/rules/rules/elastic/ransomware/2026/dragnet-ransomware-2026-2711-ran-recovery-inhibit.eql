// Dragnet [Ransomware]: dragnet-ransomware-2026-2711 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 8654d47f-8255-55b4-8f60-9daae937167c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
