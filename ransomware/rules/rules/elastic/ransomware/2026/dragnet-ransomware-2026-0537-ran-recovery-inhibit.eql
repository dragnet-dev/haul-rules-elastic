// Dragnet [Ransomware]: dragnet-ransomware-2026-0537 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 430ec7af-482a-58b0-a128-9520c39ec7ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
