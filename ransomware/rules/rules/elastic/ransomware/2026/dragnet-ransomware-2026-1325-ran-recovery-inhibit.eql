// Dragnet [Ransomware]: dragnet-ransomware-2026-1325 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: bea5cf5a-2370-512c-991a-3812acb66dbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
