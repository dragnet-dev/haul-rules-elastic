// Dragnet [Ransomware]: dragnet-ransomware-2026-3078 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 0c0897f2-0512-548d-ad30-f26885e49af0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
