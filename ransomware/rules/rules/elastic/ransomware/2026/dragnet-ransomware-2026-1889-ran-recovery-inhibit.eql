// Dragnet [Ransomware]: dragnet-ransomware-2026-1889 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 128e96cb-b3b8-5794-b85b-504206296e10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
