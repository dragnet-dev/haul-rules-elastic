// Dragnet [Ransomware]: dragnet-ransomware-2026-1334 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: 296c16ea-0c6e-552c-8052-e5ebc6a3ebe0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
