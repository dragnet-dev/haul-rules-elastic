// Dragnet [Ransomware]: dragnet-ransomware-2026-2366 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: ed379f53-9f49-58b6-9625-0e3a74ff2116

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
