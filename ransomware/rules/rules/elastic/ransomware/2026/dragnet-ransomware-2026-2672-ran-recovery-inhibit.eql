// Dragnet [Ransomware]: dragnet-ransomware-2026-2672 — Recovery Inhibition (worldleaks)
// Status: test | Level: high | ID: eddc91cd-63c9-5082-83fa-9beb7e0d22b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
