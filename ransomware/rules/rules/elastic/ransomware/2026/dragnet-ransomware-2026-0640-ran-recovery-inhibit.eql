// Dragnet [Ransomware]: dragnet-ransomware-2026-0640 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: d9311ebc-12ce-570d-b7d5-bc2ce6b84b66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
