// Dragnet [Ransomware]: dragnet-ransomware-2026-1943 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: e7b5ebf4-80dd-5450-a2ff-78865e4f1a45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
