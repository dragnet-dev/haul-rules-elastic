// Dragnet [Ransomware]: dragnet-ransomware-2026-1367 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 010ee2ff-2a56-52ff-826b-54b0d6965732

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
