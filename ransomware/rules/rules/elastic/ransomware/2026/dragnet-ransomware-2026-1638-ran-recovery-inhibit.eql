// Dragnet [Ransomware]: dragnet-ransomware-2026-1638 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 82949cb4-b273-5c6d-af14-42e75be01fbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
