// Dragnet [Ransomware]: dragnet-ransomware-2026-0570 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 26785d6e-a4e9-537b-9fe9-1be872c43db2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
