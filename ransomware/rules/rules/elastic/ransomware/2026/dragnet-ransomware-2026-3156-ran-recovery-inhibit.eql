// Dragnet [Ransomware]: dragnet-ransomware-2026-3156 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: 28c7943f-5712-5d02-b5b0-9541ed1f7658

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
