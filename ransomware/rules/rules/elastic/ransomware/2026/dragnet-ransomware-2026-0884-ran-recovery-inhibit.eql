// Dragnet [Ransomware]: dragnet-ransomware-2026-0884 — Recovery Inhibition (apt73)
// Status: stable | Level: high | ID: f51bd85e-9aea-5be8-be15-3ba8411ec1ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
