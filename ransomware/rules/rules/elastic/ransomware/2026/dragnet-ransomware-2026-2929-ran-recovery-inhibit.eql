// Dragnet [Ransomware]: dragnet-ransomware-2026-2929 — Recovery Inhibition (genesis)
// Status: stable | Level: high | ID: 2ed3ba3d-1eda-5f42-ace2-e6f3b6d920bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
