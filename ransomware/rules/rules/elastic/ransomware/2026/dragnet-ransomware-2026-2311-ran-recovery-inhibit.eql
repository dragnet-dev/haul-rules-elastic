// Dragnet [Ransomware]: dragnet-ransomware-2026-2311 — Recovery Inhibition (m3rx)
// Status: stable | Level: high | ID: 905650ca-3c2f-5f60-95e1-0d121b4f9c96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
