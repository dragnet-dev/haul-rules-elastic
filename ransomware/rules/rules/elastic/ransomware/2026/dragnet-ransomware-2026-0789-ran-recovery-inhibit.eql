// Dragnet [Ransomware]: dragnet-ransomware-2026-0789 — Recovery Inhibition (safepay)
// Status: stable | Level: high | ID: 4e960a3a-b397-5805-a3ac-ce01c7df3048

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
