// Dragnet [Ransomware]: dragnet-ransomware-2026-2673 — Recovery Inhibition (medusalocker)
// Status: stable | Level: high | ID: b6ccfecc-b4db-58e6-a00f-2ea5f0234aee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
