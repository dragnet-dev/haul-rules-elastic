// Dragnet [Ransomware]: dragnet-ransomware-2026-2152 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 1c7d7f56-a4ce-57a6-b8da-16bc6611e13d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
