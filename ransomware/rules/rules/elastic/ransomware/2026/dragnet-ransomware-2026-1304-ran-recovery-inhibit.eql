// Dragnet [Ransomware]: dragnet-ransomware-2026-1304 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 932fa550-92b3-55c6-9b5c-6eb7ebf7cd2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
