// Dragnet [Ransomware]: dragnet-ransomware-2026-2881 — Recovery Inhibition (insomnia)
// Status: test | Level: high | ID: c1aee089-4205-514f-8e54-9d02bd3726e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
