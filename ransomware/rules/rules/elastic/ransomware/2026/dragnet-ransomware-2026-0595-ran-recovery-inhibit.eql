// Dragnet [Ransomware]: dragnet-ransomware-2026-0595 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 58521b07-319e-53b5-8a30-ae87201c6aa0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
