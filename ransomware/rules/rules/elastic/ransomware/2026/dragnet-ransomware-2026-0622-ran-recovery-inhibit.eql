// Dragnet [Ransomware]: dragnet-ransomware-2026-0622 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1f2c892f-193b-5105-a7f4-22d3acdadfc0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
