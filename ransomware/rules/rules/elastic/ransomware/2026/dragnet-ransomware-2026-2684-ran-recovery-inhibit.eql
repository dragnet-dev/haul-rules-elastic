// Dragnet [Ransomware]: dragnet-ransomware-2026-2684 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 0066be36-a347-5097-b10b-4cd28ac9c988

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
