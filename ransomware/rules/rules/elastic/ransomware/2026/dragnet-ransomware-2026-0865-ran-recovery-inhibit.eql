// Dragnet [Ransomware]: dragnet-ransomware-2026-0865 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: d2943cac-4ef9-5d1c-9570-473a2907b54c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
