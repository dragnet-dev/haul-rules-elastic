// Dragnet [Ransomware]: dragnet-ransomware-2026-0968 — Recovery Inhibition (nova)
// Status: stable | Level: high | ID: 55f6c496-211a-5752-a19c-28ec15956195

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
