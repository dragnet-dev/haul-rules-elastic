// Dragnet [Ransomware]: dragnet-ransomware-2026-2408 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: bec71772-412d-5fba-822b-fa0c37b7b50d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
