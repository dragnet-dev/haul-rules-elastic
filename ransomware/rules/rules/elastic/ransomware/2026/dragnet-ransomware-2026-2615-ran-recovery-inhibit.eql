// Dragnet [Ransomware]: dragnet-ransomware-2026-2615 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 0be5aae3-a734-5e28-9ff9-0687e6a104d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
