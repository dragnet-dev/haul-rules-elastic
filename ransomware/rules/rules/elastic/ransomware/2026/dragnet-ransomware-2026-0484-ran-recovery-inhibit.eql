// Dragnet [Ransomware]: dragnet-ransomware-2026-0484 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: abe977da-7608-5c2f-a5e2-e03f3363776f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
