// Dragnet [Ransomware]: dragnet-ransomware-2026-2400 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: 64aceaee-b78c-5929-b194-225563781ed9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
