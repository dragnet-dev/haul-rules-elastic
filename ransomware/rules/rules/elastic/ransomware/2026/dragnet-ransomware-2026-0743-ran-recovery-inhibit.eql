// Dragnet [Ransomware]: dragnet-ransomware-2026-0743 — Recovery Inhibition (obscura)
// Status: deprecated | Level: high | ID: b51e864b-fdbb-5e97-875e-f416295307fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
