// Dragnet [Ransomware]: dragnet-ransomware-2026-2713 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 5bd2b62d-d1cb-50e8-bffc-057724355a79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
