// Dragnet [Ransomware]: dragnet-ransomware-2026-2198 — Recovery Inhibition (lynx)
// Status: stable | Level: high | ID: 4a4bae28-9878-5fc2-9367-eea24da65546

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
