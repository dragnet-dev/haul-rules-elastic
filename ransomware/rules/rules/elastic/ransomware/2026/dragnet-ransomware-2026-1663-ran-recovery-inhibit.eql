// Dragnet [Ransomware]: dragnet-ransomware-2026-1663 — Recovery Inhibition (tridentlocker)
// Status: test | Level: high | ID: 55558b84-86e6-55ea-a7b0-ff3f10e0497f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
