// Dragnet [Ransomware]: dragnet-ransomware-2026-2296 — Recovery Inhibition (medusalocker)
// Status: stable | Level: high | ID: 456552a4-abf5-5c35-b1ff-27dbaef05aa1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
