// Dragnet [Ransomware]: dragnet-ransomware-2026-0766 — Recovery Inhibition (chaos)
// Status: stable | Level: high | ID: 7bce30f6-a6ad-52ab-8b6f-85a93ab56518

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
