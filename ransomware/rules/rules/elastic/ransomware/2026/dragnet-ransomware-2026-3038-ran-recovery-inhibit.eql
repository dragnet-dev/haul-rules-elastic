// Dragnet [Ransomware]: dragnet-ransomware-2026-3038 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 11ea5c35-787d-5e98-aea2-3d1966996530

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
