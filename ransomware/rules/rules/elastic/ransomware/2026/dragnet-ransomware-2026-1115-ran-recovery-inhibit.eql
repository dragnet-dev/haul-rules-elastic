// Dragnet [Ransomware]: dragnet-ransomware-2026-1115 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: fda6e080-ce7c-5867-8dc9-181d90a42319

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
