// Dragnet [Ransomware]: dragnet-ransomware-2026-2805 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: fc896775-776a-5dc1-9ad8-86164233336d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
