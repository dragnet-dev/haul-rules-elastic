// Dragnet [Ransomware]: dragnet-ransomware-2026-3070 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: c92134d6-4bcf-5ff4-92f6-7abaf78aadb3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
