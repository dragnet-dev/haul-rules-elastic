// Dragnet [Ransomware]: dragnet-ransomware-2026-2419 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 1bf0ace0-bc4c-55af-a21b-e888f93ce7a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
