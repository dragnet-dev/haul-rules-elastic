// Dragnet [Ransomware]: dragnet-ransomware-2026-2735 — Recovery Inhibition (pear)
// Status: stable | Level: high | ID: fa409689-bd8d-5346-99a8-b1d03083c26f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
