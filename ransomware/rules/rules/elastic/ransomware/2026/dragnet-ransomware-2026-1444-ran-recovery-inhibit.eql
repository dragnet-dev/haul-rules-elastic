// Dragnet [Ransomware]: dragnet-ransomware-2026-1444 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 04722f08-aa12-511d-921a-f4f97580296a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
