// Dragnet [Ransomware]: dragnet-ransomware-2026-2340 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: c63cf765-987e-55af-8dcd-ccc41e9f5460

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
