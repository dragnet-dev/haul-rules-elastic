// Dragnet [Ransomware]: dragnet-ransomware-2026-2944 — Recovery Inhibition (payload)
// Status: stable | Level: high | ID: 2df1a358-af9a-5fd1-9779-a487e962f660

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
