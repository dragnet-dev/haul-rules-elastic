// Dragnet [Ransomware]: dragnet-ransomware-2026-0878 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: d5d35018-c33b-51cd-b53e-d3ae3a4ed762

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
