// Dragnet [Ransomware]: dragnet-ransomware-2026-0353 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: f88bfae9-86d5-56a3-9da4-990aded08f99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
