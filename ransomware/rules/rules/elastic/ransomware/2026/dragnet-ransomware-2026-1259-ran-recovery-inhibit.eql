// Dragnet [Ransomware]: dragnet-ransomware-2026-1259 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: 6da77d06-9286-5e1d-8485-bee14b66aeda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
