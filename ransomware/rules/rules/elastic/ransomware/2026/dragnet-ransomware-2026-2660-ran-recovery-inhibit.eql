// Dragnet [Ransomware]: dragnet-ransomware-2026-2660 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: b8143e0e-71d6-51e6-b75c-b041ac82b20e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
