// Dragnet [Ransomware]: dragnet-ransomware-2026-2726 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 9b8781ce-49cf-50f3-87fe-8139ebd74649

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
