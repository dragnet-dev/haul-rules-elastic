// Dragnet [Ransomware]: dragnet-ransomware-2026-3434 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 7e7eadcc-3d93-500d-9ada-5487bbe2aae9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
