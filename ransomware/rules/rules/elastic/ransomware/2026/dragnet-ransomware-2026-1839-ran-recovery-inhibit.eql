// Dragnet [Ransomware]: dragnet-ransomware-2026-1839 — Recovery Inhibition (play)
// Status: stable | Level: high | ID: 66a50ebe-f4a1-5187-af7f-6d55b33b7303

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
