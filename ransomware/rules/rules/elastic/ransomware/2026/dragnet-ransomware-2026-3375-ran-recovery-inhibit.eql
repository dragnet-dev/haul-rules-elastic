// Dragnet [Ransomware]: dragnet-ransomware-2026-3375 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: de22843d-ce85-5041-9a86-47641cf64771

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
