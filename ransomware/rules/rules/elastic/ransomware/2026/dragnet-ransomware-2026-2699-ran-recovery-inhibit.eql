// Dragnet [Ransomware]: dragnet-ransomware-2026-2699 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: ef84c7b6-bafa-5b59-8577-2c1deed675b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
