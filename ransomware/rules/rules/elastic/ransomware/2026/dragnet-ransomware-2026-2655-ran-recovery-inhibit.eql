// Dragnet [Ransomware]: dragnet-ransomware-2026-2655 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: a2f2c763-2503-5789-9940-4ff1fc1856fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
