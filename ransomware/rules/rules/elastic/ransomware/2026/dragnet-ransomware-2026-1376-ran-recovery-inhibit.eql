// Dragnet [Ransomware]: dragnet-ransomware-2026-1376 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: 2b209ecf-23ee-59e1-896f-b018ff910029

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
