// Dragnet [Ransomware]: dragnet-ransomware-2026-2098 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 288ba9ff-d210-5687-87b4-46e11fe34336

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
