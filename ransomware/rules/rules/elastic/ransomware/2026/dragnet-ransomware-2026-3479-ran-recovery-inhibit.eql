// Dragnet [Ransomware]: dragnet-ransomware-2026-3479 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: 05f945d3-110d-5bcd-a48b-944ec2b4943c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
