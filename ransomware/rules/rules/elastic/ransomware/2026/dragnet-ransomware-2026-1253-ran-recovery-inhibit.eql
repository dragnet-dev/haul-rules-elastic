// Dragnet [Ransomware]: dragnet-ransomware-2026-1253 — Recovery Inhibition (lapsus$)
// Status: deprecated | Level: high | ID: 2c2be47d-801e-5220-84ba-a2395aff5238

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
