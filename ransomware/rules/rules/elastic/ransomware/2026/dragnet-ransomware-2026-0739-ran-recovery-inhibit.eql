// Dragnet [Ransomware]: dragnet-ransomware-2026-0739 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: e795b370-4a2b-5fa2-b56e-debe3ed28431

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
