// Dragnet [Ransomware]: dragnet-ransomware-2026-1560 — Recovery Inhibition (nova)
// Status: stable | Level: high | ID: 84098ee2-63c5-510d-b71b-d18946456031

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
