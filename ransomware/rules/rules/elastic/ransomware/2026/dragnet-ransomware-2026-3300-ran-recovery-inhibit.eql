// Dragnet [Ransomware]: dragnet-ransomware-2026-3300 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 7455e1e5-ccbb-5dad-8dc0-1b5553c5ec80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
