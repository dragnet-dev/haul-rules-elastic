// Dragnet [Ransomware]: dragnet-ransomware-2026-1434 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7aca83b9-95c6-5841-ac86-a85eb242e891

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
