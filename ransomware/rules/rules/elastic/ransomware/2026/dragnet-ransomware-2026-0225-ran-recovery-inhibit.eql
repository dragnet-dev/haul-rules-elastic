// Dragnet [Ransomware]: dragnet-ransomware-2026-0225 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: 21b7d6f1-c248-50c8-b970-7a14f582f586

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
