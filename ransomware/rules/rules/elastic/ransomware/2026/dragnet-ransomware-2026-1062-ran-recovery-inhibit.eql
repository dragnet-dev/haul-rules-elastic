// Dragnet [Ransomware]: dragnet-ransomware-2026-1062 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: 3cc9718e-a866-5fe5-bd88-1f6394174d0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
