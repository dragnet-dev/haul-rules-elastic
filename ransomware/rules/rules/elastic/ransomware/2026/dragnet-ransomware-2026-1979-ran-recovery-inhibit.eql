// Dragnet [Ransomware]: dragnet-ransomware-2026-1979 — Recovery Inhibition (anubis)
// Status: stable | Level: high | ID: b27c60f9-cccf-55bc-b712-252c69a15422

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
