// Dragnet [Ransomware]: dragnet-ransomware-2026-0211 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: b621cf2b-cb83-541e-b769-051da91d0f67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
