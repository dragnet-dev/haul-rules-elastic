// Dragnet [Ransomware]: dragnet-ransomware-2026-1107 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 01a8012b-cbbc-5a4c-9625-d8a0cc6a36d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
