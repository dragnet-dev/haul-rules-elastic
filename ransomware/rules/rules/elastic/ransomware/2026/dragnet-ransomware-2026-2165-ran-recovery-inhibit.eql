// Dragnet [Ransomware]: dragnet-ransomware-2026-2165 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: 905c629f-0ad4-53d1-a065-c913c519a78d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
