// Dragnet [Ransomware]: dragnet-ransomware-2026-1917 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 99b81af8-0dc1-5344-8af8-592bb1359f95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
