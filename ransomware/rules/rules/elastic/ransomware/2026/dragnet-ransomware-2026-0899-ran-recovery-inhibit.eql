// Dragnet [Ransomware]: dragnet-ransomware-2026-0899 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: da4caa44-eb78-5b57-ad97-c7c3aa64d9b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
