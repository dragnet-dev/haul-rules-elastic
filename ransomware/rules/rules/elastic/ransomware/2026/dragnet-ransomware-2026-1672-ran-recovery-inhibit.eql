// Dragnet [Ransomware]: dragnet-ransomware-2026-1672 — Recovery Inhibition (krybit)
// Status: stable | Level: high | ID: b0ffd074-2349-5700-a8dd-4b30608e0660

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
