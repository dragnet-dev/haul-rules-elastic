// Dragnet [Ransomware]: dragnet-ransomware-2026-2147 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: abe87354-4451-56ac-979a-d9ff6c544422

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
