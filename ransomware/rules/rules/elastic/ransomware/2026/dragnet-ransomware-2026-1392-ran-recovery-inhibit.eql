// Dragnet [Ransomware]: dragnet-ransomware-2026-1392 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 14e77286-fd88-52f6-ad0e-035784341fe5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
