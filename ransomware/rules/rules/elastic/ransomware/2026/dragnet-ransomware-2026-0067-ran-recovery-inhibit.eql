// Dragnet [Ransomware]: dragnet-ransomware-2026-0067 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 7280b9ea-aa38-5cc7-93cf-97c858a8516e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
