// Dragnet [Ransomware]: dragnet-ransomware-2026-2422 — Recovery Inhibition (threeam)
// Status: stable | Level: high | ID: 74d0f9c3-39c5-540d-8cb4-ce171ad042f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
