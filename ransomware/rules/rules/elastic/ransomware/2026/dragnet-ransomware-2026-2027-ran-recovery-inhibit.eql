// Dragnet [Ransomware]: dragnet-ransomware-2026-2027 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 42f15167-0f9a-5337-86a5-9cb955d1a00d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
