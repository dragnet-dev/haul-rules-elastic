// Dragnet [Ransomware]: dragnet-ransomware-2026-2668 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 66d466e5-1a6b-5bc9-be56-3fa161466ac8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
