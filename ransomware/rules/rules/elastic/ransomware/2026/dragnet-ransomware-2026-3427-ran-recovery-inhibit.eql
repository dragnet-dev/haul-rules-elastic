// Dragnet [Ransomware]: dragnet-ransomware-2026-3427 — Recovery Inhibition (chaos)
// Status: stable | Level: high | ID: b6b60203-19e5-57ab-abde-401735f96f08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
