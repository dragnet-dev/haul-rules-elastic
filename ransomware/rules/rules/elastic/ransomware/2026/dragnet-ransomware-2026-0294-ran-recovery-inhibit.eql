// Dragnet [Ransomware]: dragnet-ransomware-2026-0294 — Recovery Inhibition (mnt6)
// Status: stable | Level: high | ID: 8ca57af9-84e3-50e5-9d38-c43d780052ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
