// Dragnet [Ransomware]: dragnet-ransomware-2026-3376 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 1051c211-a6f8-577c-a0b9-8324473d1397

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
