// Dragnet [Ransomware]: dragnet-ransomware-2026-2867 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 798e394a-e305-5cf7-91a2-8d847a15659f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
