// Dragnet [Ransomware]: dragnet-ransomware-2026-0494 — Recovery Inhibition (sinobi)
// Status: stable | Level: high | ID: 172d7e55-4755-50c0-969e-b7004f330865

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
