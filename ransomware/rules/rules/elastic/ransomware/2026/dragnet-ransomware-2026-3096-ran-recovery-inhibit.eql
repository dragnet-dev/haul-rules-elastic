// Dragnet [Ransomware]: dragnet-ransomware-2026-3096 — Recovery Inhibition (securotrop)
// Status: stable | Level: high | ID: 3f4d0323-55f8-5c5b-a040-e0251b7da177

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
