// Dragnet [Ransomware]: dragnet-ransomware-2026-1788 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: c15126f5-5f4a-58f5-aaa4-6c9d71b8e9b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
