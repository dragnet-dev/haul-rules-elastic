// Dragnet [Ransomware]: dragnet-ransomware-2026-1409 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: e4be3895-98b2-5089-a23f-ca51e3810993

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
