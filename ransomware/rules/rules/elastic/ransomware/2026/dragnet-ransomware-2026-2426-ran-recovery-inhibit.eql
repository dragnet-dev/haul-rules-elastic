// Dragnet [Ransomware]: dragnet-ransomware-2026-2426 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 837e5624-4ea9-513d-a92b-845dd1f80db3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
