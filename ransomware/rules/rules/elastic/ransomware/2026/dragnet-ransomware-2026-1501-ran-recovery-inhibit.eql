// Dragnet [Ransomware]: dragnet-ransomware-2026-1501 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: bbf4dfe1-9400-5107-b34e-45dedbbcb7cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
