// Dragnet [Ransomware]: dragnet-ransomware-2026-3235 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: b1e1f580-e039-5033-bb5f-46e0a350aee3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
