// Dragnet [Ransomware]: dragnet-ransomware-2026-3182 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 0846d587-a5c0-58b0-aad0-9edba3bc2a40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
