// Dragnet [Ransomware]: dragnet-ransomware-2026-0485 — Recovery Inhibition (BrainCipher)
// Status: stable | Level: high | ID: 14d3fe4d-58a3-5ea7-b09e-2d8029c770ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
