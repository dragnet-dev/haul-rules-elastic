// Dragnet [Ransomware]: dragnet-ransomware-2026-0444 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: e3b7a622-a548-52c0-bcaa-ad3771416e24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
