// Dragnet [Ransomware]: dragnet-ransomware-2026-3266 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 6692479e-f824-5187-87e7-299e7ef995fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
