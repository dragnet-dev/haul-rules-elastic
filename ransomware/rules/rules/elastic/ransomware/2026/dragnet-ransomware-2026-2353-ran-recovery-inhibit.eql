// Dragnet [Ransomware]: dragnet-ransomware-2026-2353 — Recovery Inhibition (ransomexx)
// Status: stable | Level: high | ID: 8ff1504f-d32a-5f56-9b4d-6ef61dd8dc68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
