// Dragnet [Ransomware]: dragnet-ransomware-2026-0314 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 027a2a16-8c55-5e65-b6b4-9e0ec60685b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
