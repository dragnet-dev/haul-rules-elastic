// Dragnet [Ransomware]: dragnet-ransomware-2026-2491 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 6e65b062-b987-5b69-b220-9aa58c67a5b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
