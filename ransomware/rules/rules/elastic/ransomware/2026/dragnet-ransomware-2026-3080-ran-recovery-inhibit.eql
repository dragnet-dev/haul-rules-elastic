// Dragnet [Ransomware]: dragnet-ransomware-2026-3080 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 2b9404a0-481f-5254-bee4-73a83c779d6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
