// Dragnet [Ransomware]: dragnet-ransomware-2026-1485 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: f3d39f69-37a6-5c70-b903-01e1345d0b5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
