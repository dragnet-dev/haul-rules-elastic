// Dragnet [Ransomware]: dragnet-ransomware-2026-2632 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 4068282e-63ae-5712-984a-4b00d9afe308

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
