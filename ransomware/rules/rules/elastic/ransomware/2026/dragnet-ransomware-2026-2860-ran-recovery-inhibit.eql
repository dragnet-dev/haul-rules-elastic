// Dragnet [Ransomware]: dragnet-ransomware-2026-2860 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 5e9dc86e-7cbd-586c-b089-6685601fc139

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
