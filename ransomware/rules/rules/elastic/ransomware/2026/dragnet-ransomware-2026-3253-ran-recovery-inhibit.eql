// Dragnet [Ransomware]: dragnet-ransomware-2026-3253 — Recovery Inhibition (dragonforce)
// Status: stable | Level: high | ID: 116db873-b740-59f0-960b-083eaeeb09f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
