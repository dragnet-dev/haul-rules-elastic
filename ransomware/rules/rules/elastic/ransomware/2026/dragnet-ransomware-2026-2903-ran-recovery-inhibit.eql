// Dragnet [Ransomware]: dragnet-ransomware-2026-2903 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 966d724f-18cc-5f0e-b7dd-2409d4a7e915

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
