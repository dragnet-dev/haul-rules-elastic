// Dragnet [Ransomware]: dragnet-ransomware-2026-1152 — Recovery Inhibition (thegentlemen)
// Status: stable | Level: high | ID: b7c1d05a-059a-5e12-8187-fb5e0c2e6d2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
