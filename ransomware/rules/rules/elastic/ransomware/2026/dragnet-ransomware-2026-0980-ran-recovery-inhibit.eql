// Dragnet [Ransomware]: dragnet-ransomware-2026-0980 — Recovery Inhibition (coinbasecartel)
// Status: stable | Level: high | ID: 44fc8da5-8504-5387-b814-ba4f6b4aa55e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
