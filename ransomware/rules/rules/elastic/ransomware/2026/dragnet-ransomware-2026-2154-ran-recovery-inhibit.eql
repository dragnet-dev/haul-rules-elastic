// Dragnet [Ransomware]: dragnet-ransomware-2026-2154 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 6dcf1b87-1414-5a90-9771-d537b4841d36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
