// Dragnet [Ransomware]: dragnet-ransomware-2026-2541 — Recovery Inhibition (lockbit5)
// Status: stable | Level: high | ID: 26a5a214-69ea-5e5b-852d-a20793427a61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
