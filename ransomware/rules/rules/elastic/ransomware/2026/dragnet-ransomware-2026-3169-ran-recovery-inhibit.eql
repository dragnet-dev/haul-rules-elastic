// Dragnet [Ransomware]: dragnet-ransomware-2026-3169 — Recovery Inhibition (lamashtu)
// Status: stable | Level: high | ID: fb1f2706-4a1a-5802-a941-a6a0aa381eb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
