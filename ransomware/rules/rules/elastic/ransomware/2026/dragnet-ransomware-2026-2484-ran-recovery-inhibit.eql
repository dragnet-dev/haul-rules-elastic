// Dragnet [Ransomware]: dragnet-ransomware-2026-2484 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e8b2684e-667c-52c6-a663-d4c22b006ebd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
