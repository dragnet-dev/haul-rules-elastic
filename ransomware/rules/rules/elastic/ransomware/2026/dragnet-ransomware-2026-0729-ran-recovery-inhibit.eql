// Dragnet [Ransomware]: dragnet-ransomware-2026-0729 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: b331172f-2ac4-5017-9680-4a5ae536750c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
