// Dragnet [Ransomware]: dragnet-ransomware-2026-2162 — Recovery Inhibition (incransom)
// Status: stable | Level: high | ID: ee85dcc1-3e6d-59d1-9d0e-b8ab9a2b821b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
