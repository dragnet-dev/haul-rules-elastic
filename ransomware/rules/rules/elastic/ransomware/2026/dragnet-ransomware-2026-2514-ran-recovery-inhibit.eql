// Dragnet [Ransomware]: dragnet-ransomware-2026-2514 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: d076243b-3f57-503d-b172-9bf3d7f60d74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
