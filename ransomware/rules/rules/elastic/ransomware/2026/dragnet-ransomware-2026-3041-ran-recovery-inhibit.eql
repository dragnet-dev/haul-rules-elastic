// Dragnet [Ransomware]: dragnet-ransomware-2026-3041 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: f22ea1ce-3e3d-55a2-8e0c-7242f551fc01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
