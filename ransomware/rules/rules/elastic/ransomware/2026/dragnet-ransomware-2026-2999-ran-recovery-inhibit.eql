// Dragnet [Ransomware]: dragnet-ransomware-2026-2999 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: c0f7918c-9bc8-51ee-8e4b-c26aface1192

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
