// Dragnet [Ransomware]: dragnet-ransomware-2026-2935 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: afda62e7-bd19-5e0c-94e4-3f0e5d9a5135

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
