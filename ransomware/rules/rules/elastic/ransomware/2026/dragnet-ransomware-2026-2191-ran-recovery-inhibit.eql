// Dragnet [Ransomware]: dragnet-ransomware-2026-2191 — Recovery Inhibition (handala)
// Status: stable | Level: high | ID: 94a97152-501a-54d2-a91d-9da79f3880bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
