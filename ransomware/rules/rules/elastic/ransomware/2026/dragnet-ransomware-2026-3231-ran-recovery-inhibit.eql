// Dragnet [Ransomware]: dragnet-ransomware-2026-3231 — Recovery Inhibition (anubis)
// Status: stable | Level: high | ID: 0e60cfd0-d9ff-5ba5-8e10-b5fed86171ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
