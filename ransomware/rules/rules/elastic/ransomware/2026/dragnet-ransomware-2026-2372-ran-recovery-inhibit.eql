// Dragnet [Ransomware]: dragnet-ransomware-2026-2372 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 8dff5f1c-5db3-5c2d-ab00-24f3b50964c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
