// Dragnet [Ransomware]: dragnet-ransomware-2026-1599 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: 16716c34-733e-560d-ab15-7234e13777f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
