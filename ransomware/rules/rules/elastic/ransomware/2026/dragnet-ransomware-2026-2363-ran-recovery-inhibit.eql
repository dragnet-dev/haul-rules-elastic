// Dragnet [Ransomware]: dragnet-ransomware-2026-2363 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 19e84ab2-50b4-5262-b120-91739195bfef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
