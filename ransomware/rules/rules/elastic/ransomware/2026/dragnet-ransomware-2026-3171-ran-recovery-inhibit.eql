// Dragnet [Ransomware]: dragnet-ransomware-2026-3171 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 97412b1b-bb18-5ee8-b152-16b738f65a3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
