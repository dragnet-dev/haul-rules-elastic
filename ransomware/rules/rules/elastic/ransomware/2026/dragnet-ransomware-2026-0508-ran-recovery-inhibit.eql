// Dragnet [Ransomware]: dragnet-ransomware-2026-0508 — Recovery Inhibition (everest)
// Status: stable | Level: high | ID: bf9ef4a6-a9fe-5849-8beb-b1773bebe3b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
