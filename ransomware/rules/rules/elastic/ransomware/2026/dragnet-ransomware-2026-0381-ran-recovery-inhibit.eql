// Dragnet [Ransomware]: dragnet-ransomware-2026-0381 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: c4f92bd5-f6b8-5714-8fa8-53fd02a5d1d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
