// Dragnet [Ransomware]: dragnet-ransomware-2026-1796 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: e684cf70-1304-513e-ba61-b02425588dc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
