// Dragnet [Ransomware]: dragnet-ransomware-2026-0649 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8808e322-36c5-522c-b2dc-813bcae68f05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
