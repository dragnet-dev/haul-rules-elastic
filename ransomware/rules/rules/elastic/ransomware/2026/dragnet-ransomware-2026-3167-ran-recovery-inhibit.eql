// Dragnet [Ransomware]: dragnet-ransomware-2026-3167 — Recovery Inhibition (bravox)
// Status: stable | Level: high | ID: b63d3816-f57a-5844-93e4-4d8d17f1d900

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
