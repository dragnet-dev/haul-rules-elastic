// Dragnet [Ransomware]: dragnet-ransomware-2026-2476 — Recovery Inhibition (qilin)
// Status: stable | Level: high | ID: 4fd1d35f-4b47-556e-b5e6-ff3b2d0ebea4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
