// Dragnet [Ransomware]: dragnet-ransomware-2026-2775 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: 8457ed42-09e4-5b82-8251-04cf1b432836

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
