// Dragnet [Ransomware]: dragnet-ransomware-2024-3276 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a47bf744-4ecc-51be-b4c3-a2d9674e69b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
