// Dragnet [Ransomware]: dragnet-ransomware-2024-3981 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 35e794fc-6fc6-59c1-86ae-df42a3d3325c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
