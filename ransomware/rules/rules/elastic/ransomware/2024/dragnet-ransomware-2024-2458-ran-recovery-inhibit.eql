// Dragnet [Ransomware]: dragnet-ransomware-2024-2458 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 577f7fe2-dfa3-5a79-952e-27eb3f8d7b48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
