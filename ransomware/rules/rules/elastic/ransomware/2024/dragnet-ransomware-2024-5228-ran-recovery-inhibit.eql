// Dragnet [Ransomware]: dragnet-ransomware-2024-5228 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: dce6d335-4e11-5276-9de9-1202e428f6ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
