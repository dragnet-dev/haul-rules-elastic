// Dragnet [Ransomware]: dragnet-ransomware-2024-5029 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: af2e9418-756d-5384-a9ab-ee0ba086a24d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
