// Dragnet [Ransomware]: dragnet-ransomware-2024-5279 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 739941f5-acbc-5c11-9b7f-fa32c07f6129

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
