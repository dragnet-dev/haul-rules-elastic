// Dragnet [Ransomware]: dragnet-ransomware-2024-0770 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 68adc8cb-6897-5cde-9f99-0c4ce5225860

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
