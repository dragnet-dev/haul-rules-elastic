// Dragnet [Ransomware]: dragnet-ransomware-2024-1907 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 3368851d-59e5-59dc-a849-0dcd3b589c65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
