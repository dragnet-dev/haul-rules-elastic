// Dragnet [Ransomware]: dragnet-ransomware-2024-5447 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: fa9bbc07-e433-57bf-b8cf-e8dc7e93ed45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
