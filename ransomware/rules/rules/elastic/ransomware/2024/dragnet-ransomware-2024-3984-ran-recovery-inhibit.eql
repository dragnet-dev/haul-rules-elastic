// Dragnet [Ransomware]: dragnet-ransomware-2024-3984 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: eb1e8ff6-8421-5c83-8304-76e86415a770

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
