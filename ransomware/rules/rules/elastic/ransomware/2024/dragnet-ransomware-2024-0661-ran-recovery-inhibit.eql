// Dragnet [Ransomware]: dragnet-ransomware-2024-0661 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 008580c0-4ebc-50e9-a384-95775e2598a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
