// Dragnet [Ransomware]: dragnet-ransomware-2024-4156 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 318cf110-da50-5f54-a732-e2da7868c646

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
