// Dragnet [Ransomware]: dragnet-ransomware-2024-1353 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 29b778bb-140f-5e8b-b7fa-edd2416e8be2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
