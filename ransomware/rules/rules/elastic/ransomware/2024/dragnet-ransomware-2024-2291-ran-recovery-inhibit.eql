// Dragnet [Ransomware]: dragnet-ransomware-2024-2291 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 65894c28-15f3-507d-b074-9539ab0215a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
