// Dragnet [Ransomware]: dragnet-ransomware-2024-1229 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 281eec7f-e6a0-54be-9110-34b093aacd2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
