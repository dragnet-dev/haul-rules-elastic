// Dragnet [Ransomware]: dragnet-ransomware-2024-5770 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 63984e45-63ff-5a70-b293-9b9a7213a6cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
