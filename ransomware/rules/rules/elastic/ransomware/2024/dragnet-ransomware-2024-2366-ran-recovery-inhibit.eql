// Dragnet [Ransomware]: dragnet-ransomware-2024-2366 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 78e6637c-0ca0-5317-bc42-37472f62c05d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
