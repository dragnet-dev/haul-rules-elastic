// Dragnet [Ransomware]: dragnet-ransomware-2024-0307 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 43424671-5fb2-56aa-b840-407b31b28e49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
