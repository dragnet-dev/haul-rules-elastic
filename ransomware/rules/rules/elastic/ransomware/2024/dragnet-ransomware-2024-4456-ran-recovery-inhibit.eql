// Dragnet [Ransomware]: dragnet-ransomware-2024-4456 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: ec4e6089-1638-5ac2-bf1f-65cffc559c42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
