// Dragnet [Ransomware]: dragnet-ransomware-2024-5413 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: a063583e-f1e7-5702-b609-51497df7957b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
