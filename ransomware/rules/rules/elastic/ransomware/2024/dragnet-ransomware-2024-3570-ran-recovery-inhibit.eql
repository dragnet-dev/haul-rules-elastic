// Dragnet [Ransomware]: dragnet-ransomware-2024-3570 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 0b85fff4-4dd7-574d-b0e7-0f24c10b48e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
