// Dragnet [Ransomware]: dragnet-ransomware-2024-2908 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: f42a6a54-808b-560e-a814-ce48daff17b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
