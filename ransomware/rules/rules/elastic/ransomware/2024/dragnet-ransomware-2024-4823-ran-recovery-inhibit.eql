// Dragnet [Ransomware]: dragnet-ransomware-2024-4823 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: a3d8fb75-3d56-5689-8ef1-73b8f2978532

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
