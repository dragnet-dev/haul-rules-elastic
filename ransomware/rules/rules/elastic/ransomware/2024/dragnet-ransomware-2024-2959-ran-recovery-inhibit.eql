// Dragnet [Ransomware]: dragnet-ransomware-2024-2959 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 8ac37d63-de09-57c7-8314-92633c8fd118

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
