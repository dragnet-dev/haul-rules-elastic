// Dragnet [Ransomware]: dragnet-ransomware-2024-2136 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: d9a538ad-54d5-5d3d-afdd-158c8bae6017

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
