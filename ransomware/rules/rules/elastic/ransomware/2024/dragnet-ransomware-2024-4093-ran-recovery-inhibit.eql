// Dragnet [Ransomware]: dragnet-ransomware-2024-4093 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 9b164ad7-708f-5a93-903a-f5f8bdf147f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
