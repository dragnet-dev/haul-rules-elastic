// Dragnet [Ransomware]: dragnet-ransomware-2024-2880 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 63425073-8a20-5782-9634-675ab1392c15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
