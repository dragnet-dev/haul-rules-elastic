// Dragnet [Ransomware]: dragnet-ransomware-2024-3151 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 56f03911-dc18-5fc3-bc95-f506001b2a63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
