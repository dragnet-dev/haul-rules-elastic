// Dragnet [Ransomware]: dragnet-ransomware-2024-1159 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 8a14a664-cb54-5d4d-860b-006f0eaabbad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
