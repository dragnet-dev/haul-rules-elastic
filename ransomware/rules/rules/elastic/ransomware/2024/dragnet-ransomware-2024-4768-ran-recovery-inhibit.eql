// Dragnet [Ransomware]: dragnet-ransomware-2024-4768 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0f446fed-2797-50f4-b5ad-593ebeed2850

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
