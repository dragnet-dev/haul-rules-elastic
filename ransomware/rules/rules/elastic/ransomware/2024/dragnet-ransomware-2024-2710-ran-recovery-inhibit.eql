// Dragnet [Ransomware]: dragnet-ransomware-2024-2710 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 1f88c410-4f84-5ea2-b99c-67c18cc18141

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
