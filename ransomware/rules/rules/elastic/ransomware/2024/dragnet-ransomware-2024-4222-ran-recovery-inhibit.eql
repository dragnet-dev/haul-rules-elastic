// Dragnet [Ransomware]: dragnet-ransomware-2024-4222 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2bb6560c-5e63-5203-8f9a-524d8aceff85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
