// Dragnet [Ransomware]: dragnet-ransomware-2024-5056 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 9fbe828c-8095-5acb-9079-780ea2069810

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
