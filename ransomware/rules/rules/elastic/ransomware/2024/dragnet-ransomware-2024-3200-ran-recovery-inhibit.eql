// Dragnet [Ransomware]: dragnet-ransomware-2024-3200 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 46e37ef5-150a-50f4-9637-7094b937a00f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
