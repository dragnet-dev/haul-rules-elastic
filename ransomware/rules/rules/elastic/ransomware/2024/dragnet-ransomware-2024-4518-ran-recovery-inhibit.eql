// Dragnet [Ransomware]: dragnet-ransomware-2024-4518 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 2aa7d64a-0330-551f-838d-67d19b724df9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
