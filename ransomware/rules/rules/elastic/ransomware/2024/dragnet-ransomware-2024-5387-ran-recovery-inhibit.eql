// Dragnet [Ransomware]: dragnet-ransomware-2024-5387 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 8d1af202-b5df-56c9-84f9-2cf542de16b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
