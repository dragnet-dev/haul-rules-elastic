// Dragnet [Ransomware]: dragnet-ransomware-2024-3998 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 8d0f28fc-b105-5e07-8545-e73e235aa643

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
