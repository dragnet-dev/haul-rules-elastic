// Dragnet [Ransomware]: dragnet-ransomware-2024-1611 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 9877660a-93e5-58d1-a62d-e752e366fc21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
