// Dragnet [Ransomware]: dragnet-ransomware-2024-2049 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 0a4a05f6-3ca0-575d-a562-d6d0d3f00941

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
