// Dragnet [Ransomware]: dragnet-ransomware-2024-5505 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 11250f55-aec1-5d3a-ada3-0346be467fcb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
