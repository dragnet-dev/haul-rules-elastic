// Dragnet [Ransomware]: dragnet-ransomware-2024-3098 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7ee75eac-df16-51fb-8800-5616bc9e7888

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
