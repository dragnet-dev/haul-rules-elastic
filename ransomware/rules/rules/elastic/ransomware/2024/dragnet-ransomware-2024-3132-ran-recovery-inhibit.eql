// Dragnet [Ransomware]: dragnet-ransomware-2024-3132 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 5d989d48-23a4-552f-a64b-fefdfa7918b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
