// Dragnet [Ransomware]: dragnet-ransomware-2024-4512 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 7baf81cf-4544-5cb7-a6c8-747ef02f9982

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
