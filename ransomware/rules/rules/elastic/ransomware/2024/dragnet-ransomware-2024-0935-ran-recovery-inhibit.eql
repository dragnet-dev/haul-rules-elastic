// Dragnet [Ransomware]: dragnet-ransomware-2024-0935 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 6ca15feb-e31a-5a4f-9339-c42e215551e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
