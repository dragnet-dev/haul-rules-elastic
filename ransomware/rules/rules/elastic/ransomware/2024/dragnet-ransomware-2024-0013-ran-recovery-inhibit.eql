// Dragnet [Ransomware]: dragnet-ransomware-2024-0013 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3a3288fd-0ed4-540a-b173-ba171bfa16ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
