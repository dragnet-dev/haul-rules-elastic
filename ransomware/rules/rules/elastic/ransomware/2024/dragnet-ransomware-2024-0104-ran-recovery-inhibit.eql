// Dragnet [Ransomware]: dragnet-ransomware-2024-0104 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 48bc8b84-3493-5046-94e8-46220fe1c884

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
