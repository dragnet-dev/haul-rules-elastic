// Dragnet [Ransomware]: dragnet-ransomware-2024-3262 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e14aa1cd-8eae-5f41-a311-11cd05b0fd10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
