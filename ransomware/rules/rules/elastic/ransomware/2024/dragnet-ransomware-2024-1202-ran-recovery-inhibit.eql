// Dragnet [Ransomware]: dragnet-ransomware-2024-1202 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7fa4b672-49d8-51cc-aa63-60965beda86a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
