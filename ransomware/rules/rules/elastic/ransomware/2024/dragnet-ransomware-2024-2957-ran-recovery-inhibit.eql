// Dragnet [Ransomware]: dragnet-ransomware-2024-2957 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a76ac746-9076-5d8a-b776-daaee2a32d17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
