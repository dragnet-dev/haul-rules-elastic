// Dragnet [Ransomware]: dragnet-ransomware-2024-3423 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 631a4fd5-f722-5698-80d5-ed4b09232523

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
