// Dragnet [Ransomware]: dragnet-ransomware-2024-2513 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 906a74f9-3449-507f-b089-6f4e01f0ffaa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
