// Dragnet [Ransomware]: dragnet-ransomware-2024-5269 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 2ce7a802-6f0b-5cdf-ad5f-820d1225277f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
