// Dragnet [Ransomware]: dragnet-ransomware-2024-5752 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: a00a4d68-1bc4-53a9-8091-1579564fbf42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
