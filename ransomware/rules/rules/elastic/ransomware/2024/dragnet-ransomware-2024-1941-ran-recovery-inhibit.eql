// Dragnet [Ransomware]: dragnet-ransomware-2024-1941 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: cb3cabaa-cf9c-5376-a2b4-5c92ad3871fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
