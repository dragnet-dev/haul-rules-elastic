// Dragnet [Ransomware]: dragnet-ransomware-2024-3471 — Recovery Inhibition (trisec)
// Status: experimental | Level: high | ID: 76b63e24-b392-5f7e-abce-1c314cffa7cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
