// Dragnet [Ransomware]: dragnet-ransomware-2024-1967 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7c7568b4-959d-539d-9a9a-83057816c271

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
