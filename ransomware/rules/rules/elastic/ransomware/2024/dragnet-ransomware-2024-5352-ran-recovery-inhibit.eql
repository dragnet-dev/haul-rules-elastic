// Dragnet [Ransomware]: dragnet-ransomware-2024-5352 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: e37be83d-b93c-5ab8-84bc-4da850e8d571

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
