// Dragnet [Ransomware]: dragnet-ransomware-2024-3523 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: b28435e5-cf57-5f2c-b02a-c9870458fa6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
