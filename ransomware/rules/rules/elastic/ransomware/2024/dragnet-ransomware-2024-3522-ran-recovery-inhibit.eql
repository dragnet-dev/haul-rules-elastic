// Dragnet [Ransomware]: dragnet-ransomware-2024-3522 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 93f8e9a6-b2bb-58ff-b5be-756d63614ac8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
