// Dragnet [Ransomware]: dragnet-ransomware-2024-2823 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 26dd1049-6b8a-5a6c-9a80-503015cf707d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
