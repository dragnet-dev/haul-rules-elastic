// Dragnet [Ransomware]: dragnet-ransomware-2024-5779 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 4c83f853-30c5-5a4a-a19b-15f61c53f62f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
