// Dragnet [Ransomware]: dragnet-ransomware-2024-1812 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d8c46fd7-bb2c-5393-80fa-a5219cb0a831

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
