// Dragnet [Ransomware]: dragnet-ransomware-2024-2831 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 24f607e2-3953-550f-bc8b-cf07e57cead6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
