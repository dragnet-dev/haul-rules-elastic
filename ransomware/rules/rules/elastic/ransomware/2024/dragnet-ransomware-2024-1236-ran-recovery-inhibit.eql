// Dragnet [Ransomware]: dragnet-ransomware-2024-1236 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: d4a76f37-175c-5a45-bcc6-24f877a157dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
