// Dragnet [Ransomware]: dragnet-ransomware-2024-5698 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 5d403d1b-603b-59c4-ab28-0b7032dd38ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
