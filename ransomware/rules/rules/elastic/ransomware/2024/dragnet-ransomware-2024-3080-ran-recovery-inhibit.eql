// Dragnet [Ransomware]: dragnet-ransomware-2024-3080 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e34ff01e-6394-5e20-9ac4-5f9913bcfeb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
