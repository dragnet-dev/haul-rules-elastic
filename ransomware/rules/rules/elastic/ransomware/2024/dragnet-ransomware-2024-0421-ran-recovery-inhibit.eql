// Dragnet [Ransomware]: dragnet-ransomware-2024-0421 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 151f2040-c7f8-5d96-bfe3-8552f6afd227

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
