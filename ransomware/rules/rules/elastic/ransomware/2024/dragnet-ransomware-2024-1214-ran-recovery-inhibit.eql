// Dragnet [Ransomware]: dragnet-ransomware-2024-1214 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: dacfd87c-e3d1-522f-8881-f35a68313da6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
