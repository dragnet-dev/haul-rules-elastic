// Dragnet [Ransomware]: dragnet-ransomware-2024-4786 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 158fbdc5-af60-5b41-83b9-5c3ecd1ad29c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
