// Dragnet [Ransomware]: dragnet-ransomware-2024-4230 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: d4baade2-4ac3-5634-8485-38a013028ce1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
