// Dragnet [Ransomware]: dragnet-ransomware-2024-5587 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 381a5099-e8be-5af8-adae-05a039afb32c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
