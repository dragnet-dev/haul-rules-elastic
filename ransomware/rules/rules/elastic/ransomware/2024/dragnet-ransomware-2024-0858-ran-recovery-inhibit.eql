// Dragnet [Ransomware]: dragnet-ransomware-2024-0858 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 19593016-2bd9-5731-a754-bf7c80bfd296

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
