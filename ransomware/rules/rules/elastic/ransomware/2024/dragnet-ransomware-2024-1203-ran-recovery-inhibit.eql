// Dragnet [Ransomware]: dragnet-ransomware-2024-1203 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 22283b25-d9ae-5255-a44d-02c059c841d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
