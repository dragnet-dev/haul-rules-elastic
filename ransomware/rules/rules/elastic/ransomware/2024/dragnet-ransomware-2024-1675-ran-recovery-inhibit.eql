// Dragnet [Ransomware]: dragnet-ransomware-2024-1675 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 66e0a200-e651-5c0a-b66c-64cfd64ac088

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
