// Dragnet [Ransomware]: dragnet-ransomware-2024-4141 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ff4981a2-3fab-5109-abf7-1c28f8d7056f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
