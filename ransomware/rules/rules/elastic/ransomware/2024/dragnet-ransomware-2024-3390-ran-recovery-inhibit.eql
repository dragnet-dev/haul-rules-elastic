// Dragnet [Ransomware]: dragnet-ransomware-2024-3390 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 45f2a110-2753-52a9-a80f-d8b9d8c4c15f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
