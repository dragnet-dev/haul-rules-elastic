// Dragnet [Ransomware]: dragnet-ransomware-2024-5292 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 2b0c5e52-8948-5f0e-b76b-b2c7428d91dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
