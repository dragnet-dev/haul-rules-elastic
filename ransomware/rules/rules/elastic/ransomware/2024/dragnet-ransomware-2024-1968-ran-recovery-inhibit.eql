// Dragnet [Ransomware]: dragnet-ransomware-2024-1968 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 956ef5b8-ef6e-5cad-8d40-9d55ef1379d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
