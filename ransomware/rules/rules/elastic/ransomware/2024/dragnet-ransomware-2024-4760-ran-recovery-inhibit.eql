// Dragnet [Ransomware]: dragnet-ransomware-2024-4760 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9302fa24-862d-59c1-944b-d65510e41bad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
