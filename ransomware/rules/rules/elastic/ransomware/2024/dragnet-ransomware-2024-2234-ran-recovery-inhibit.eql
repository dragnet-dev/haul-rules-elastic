// Dragnet [Ransomware]: dragnet-ransomware-2024-2234 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 67663d7e-5b06-55bc-a088-25749d3f7e90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
