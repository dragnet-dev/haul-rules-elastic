// Dragnet [Ransomware]: dragnet-ransomware-2024-4251 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 4f55e5a4-d7dd-5857-afb3-07ece79521ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
