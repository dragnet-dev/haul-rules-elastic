// Dragnet [Ransomware]: dragnet-ransomware-2024-3813 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 4c8d70f7-b092-58fe-bad2-81f68ada104b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
