// Dragnet [Ransomware]: dragnet-ransomware-2024-2360 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 1cb88601-a5f0-5d14-8991-bbe07a5a1353

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
