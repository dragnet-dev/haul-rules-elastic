// Dragnet [Ransomware]: dragnet-ransomware-2024-2796 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 91d32f1b-8b9f-5949-be19-6f6cf8af7799

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
