// Dragnet [Ransomware]: dragnet-ransomware-2024-3869 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 8c3956cf-0c4a-5f15-a4d7-5ab486d56a9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
