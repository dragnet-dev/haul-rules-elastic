// Dragnet [Ransomware]: dragnet-ransomware-2024-4569 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 869ef409-88e3-587e-9061-cfbf2fa6737e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
