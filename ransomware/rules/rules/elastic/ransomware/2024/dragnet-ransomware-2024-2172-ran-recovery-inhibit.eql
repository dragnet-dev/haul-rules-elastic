// Dragnet [Ransomware]: dragnet-ransomware-2024-2172 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: f1c2e68d-c4fe-5ae1-919e-4730853f4ab4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
