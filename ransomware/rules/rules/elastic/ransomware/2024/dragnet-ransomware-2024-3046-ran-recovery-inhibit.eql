// Dragnet [Ransomware]: dragnet-ransomware-2024-3046 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 69169605-eb36-5089-a354-16638e8e4bbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
