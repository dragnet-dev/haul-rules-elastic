// Dragnet [Ransomware]: dragnet-ransomware-2024-4158 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 369f7a3c-e51e-5f1c-971e-4a3620cd1d97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
