// Dragnet [Ransomware]: dragnet-ransomware-2024-1003 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 241c524a-ad2b-545f-a7d8-00b4038ee956

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
