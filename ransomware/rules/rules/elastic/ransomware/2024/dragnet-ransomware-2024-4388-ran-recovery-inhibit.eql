// Dragnet [Ransomware]: dragnet-ransomware-2024-4388 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 748822b3-edff-5b6d-98d7-c4faaf69d739

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
