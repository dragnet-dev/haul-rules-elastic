// Dragnet [Ransomware]: dragnet-ransomware-2024-1671 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 4399a961-e834-58ab-bbaa-7295c11ead76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
