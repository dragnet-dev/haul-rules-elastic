// Dragnet [Ransomware]: dragnet-ransomware-2024-1790 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: ff507942-147b-58a4-a672-14ee47aec070

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
