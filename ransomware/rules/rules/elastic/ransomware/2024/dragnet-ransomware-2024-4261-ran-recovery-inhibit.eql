// Dragnet [Ransomware]: dragnet-ransomware-2024-4261 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 81dab927-6d39-557b-a0b4-a99a6beb95c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
