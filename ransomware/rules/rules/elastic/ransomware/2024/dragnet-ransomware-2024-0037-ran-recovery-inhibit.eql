// Dragnet [Ransomware]: dragnet-ransomware-2024-0037 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: 18dfe768-9bab-5a48-8b1c-211e542de921

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
