// Dragnet [Ransomware]: dragnet-ransomware-2024-2756 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 6e371d8c-06e4-58d4-a967-3bfcb40bb031

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
