// Dragnet [Ransomware]: dragnet-ransomware-2024-0387 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: efb7849a-5244-5b78-b62f-c799730a0aa2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
