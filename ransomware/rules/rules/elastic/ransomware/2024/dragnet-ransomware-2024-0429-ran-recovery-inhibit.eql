// Dragnet [Ransomware]: dragnet-ransomware-2024-0429 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 75986397-80ed-5614-acb6-160e8704c0cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
