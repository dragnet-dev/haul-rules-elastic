// Dragnet [Ransomware]: dragnet-ransomware-2024-1068 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: b02a627e-8187-503e-b775-0801b4287b58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
