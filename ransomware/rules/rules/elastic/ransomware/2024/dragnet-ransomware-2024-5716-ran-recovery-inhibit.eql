// Dragnet [Ransomware]: dragnet-ransomware-2024-5716 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 3b098ef1-6234-5e60-8bd5-f44644ebb54e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
