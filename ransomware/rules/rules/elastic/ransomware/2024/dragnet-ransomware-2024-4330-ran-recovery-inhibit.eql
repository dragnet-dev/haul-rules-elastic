// Dragnet [Ransomware]: dragnet-ransomware-2024-4330 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: db30bef6-61e2-505f-a96f-bde9325789ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
