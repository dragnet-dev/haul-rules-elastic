// Dragnet [Ransomware]: dragnet-ransomware-2024-2034 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f872b0ab-a934-57d2-96aa-522932c8a541

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
