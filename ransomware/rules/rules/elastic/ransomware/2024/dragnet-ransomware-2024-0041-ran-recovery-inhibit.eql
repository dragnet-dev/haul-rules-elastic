// Dragnet [Ransomware]: dragnet-ransomware-2024-0041 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 97a0d2c0-521d-5b0c-9aff-4802c283bd59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
