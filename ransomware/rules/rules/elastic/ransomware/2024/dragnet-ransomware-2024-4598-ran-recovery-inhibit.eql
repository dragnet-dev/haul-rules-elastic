// Dragnet [Ransomware]: dragnet-ransomware-2024-4598 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 6681d021-6dbc-51c8-beae-dae79addc5b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
