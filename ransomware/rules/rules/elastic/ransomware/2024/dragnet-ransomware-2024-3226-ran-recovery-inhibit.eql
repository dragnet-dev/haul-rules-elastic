// Dragnet [Ransomware]: dragnet-ransomware-2024-3226 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 9816bb52-cfd1-5136-abc8-595dee2afc50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
