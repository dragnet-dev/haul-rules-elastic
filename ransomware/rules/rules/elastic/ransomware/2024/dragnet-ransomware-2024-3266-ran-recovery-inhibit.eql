// Dragnet [Ransomware]: dragnet-ransomware-2024-3266 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3034eb26-0bd1-54b5-9e17-daffbe21cbc3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
