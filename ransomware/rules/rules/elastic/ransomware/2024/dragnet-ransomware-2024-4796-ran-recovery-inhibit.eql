// Dragnet [Ransomware]: dragnet-ransomware-2024-4796 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: ee9a9e00-81d2-5d50-9479-79ffa8515004

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
