// Dragnet [Ransomware]: dragnet-ransomware-2024-2558 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: fe7e43c9-cdcf-5f30-9287-d99f855b77f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
