// Dragnet [Ransomware]: dragnet-ransomware-2024-0498 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 202dd5c6-6e37-5e8f-a4a5-7846a65707ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
