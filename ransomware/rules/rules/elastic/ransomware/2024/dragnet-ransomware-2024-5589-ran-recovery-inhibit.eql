// Dragnet [Ransomware]: dragnet-ransomware-2024-5589 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 33e7cc64-5e3b-5921-b72d-633863ab362f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
