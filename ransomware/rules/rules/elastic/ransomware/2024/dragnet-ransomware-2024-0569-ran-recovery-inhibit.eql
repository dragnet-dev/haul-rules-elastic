// Dragnet [Ransomware]: dragnet-ransomware-2024-0569 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 9a05e7a3-525f-57de-9bea-b0f88b19f609

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
