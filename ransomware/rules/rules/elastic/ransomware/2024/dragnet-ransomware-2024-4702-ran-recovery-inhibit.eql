// Dragnet [Ransomware]: dragnet-ransomware-2024-4702 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2f8e1591-e47a-502f-94cc-27576cf7a22f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
