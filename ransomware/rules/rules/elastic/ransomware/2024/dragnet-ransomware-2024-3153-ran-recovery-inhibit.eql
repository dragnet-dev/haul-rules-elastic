// Dragnet [Ransomware]: dragnet-ransomware-2024-3153 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: f56e230f-f8e7-5c5c-b90d-2cd0140137d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
