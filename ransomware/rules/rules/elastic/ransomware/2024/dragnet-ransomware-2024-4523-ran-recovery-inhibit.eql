// Dragnet [Ransomware]: dragnet-ransomware-2024-4523 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 9e49e6c5-6e51-5146-9f3f-03310931d619

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
