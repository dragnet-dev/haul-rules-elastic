// Dragnet [Ransomware]: dragnet-ransomware-2024-2148 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 4e52f466-3ad3-5ea1-b1c1-78bed4b7bab2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
