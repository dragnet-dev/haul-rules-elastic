// Dragnet [Ransomware]: dragnet-ransomware-2024-0370 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 7bdbbf3f-dab6-5aa7-81f6-f0844833ba5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
