// Dragnet [Ransomware]: dragnet-ransomware-2024-3354 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 9c790ff3-e98a-51c2-9d7c-7b775493780e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
