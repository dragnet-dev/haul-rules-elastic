// Dragnet [Ransomware]: dragnet-ransomware-2024-4054 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: c3708c30-9e64-55b8-a267-355537d43feb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
