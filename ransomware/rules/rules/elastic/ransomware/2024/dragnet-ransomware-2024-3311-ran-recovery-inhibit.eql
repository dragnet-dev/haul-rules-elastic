// Dragnet [Ransomware]: dragnet-ransomware-2024-3311 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: daa798f1-9393-557f-9166-7a13a28f8167

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
