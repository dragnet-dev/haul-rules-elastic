// Dragnet [Ransomware]: dragnet-ransomware-2024-1718 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 6a0f7089-54d2-5fc3-974f-a6fede8bc7dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
