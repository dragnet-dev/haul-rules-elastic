// Dragnet [Ransomware]: dragnet-ransomware-2024-3002 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 2a6b9c7d-9329-59a9-89bf-839946a0a1e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
