// Dragnet [Ransomware]: dragnet-ransomware-2024-1282 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 3f50d8fb-a0ed-5d83-a535-db97cdb962f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
