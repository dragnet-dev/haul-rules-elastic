// Dragnet [Ransomware]: dragnet-ransomware-2024-2752 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: 538e89f5-02e6-5440-bcc4-685f0f57ed15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
