// Dragnet [Ransomware]: dragnet-ransomware-2024-3808 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9a01d5df-af70-5c28-b883-1b38eea9b37b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
