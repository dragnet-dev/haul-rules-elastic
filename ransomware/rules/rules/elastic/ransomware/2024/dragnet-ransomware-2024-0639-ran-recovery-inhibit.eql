// Dragnet [Ransomware]: dragnet-ransomware-2024-0639 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: ea77eeec-8947-57f1-acdb-c77a0ca2201b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
