// Dragnet [Ransomware]: dragnet-ransomware-2024-5374 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: eb8e63a2-b134-5d98-abc5-dd91f2799fdd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
