// Dragnet [Ransomware]: dragnet-ransomware-2024-1505 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 1919c1f9-43a3-511d-91b8-3c95c89162a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
