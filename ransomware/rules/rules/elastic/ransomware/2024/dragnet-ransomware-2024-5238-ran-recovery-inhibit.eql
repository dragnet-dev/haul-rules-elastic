// Dragnet [Ransomware]: dragnet-ransomware-2024-5238 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 9b41bc58-6bf8-514c-823e-056fa14ba1ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
