// Dragnet [Ransomware]: dragnet-ransomware-2024-2188 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a92e1c26-2be5-5028-9bfb-4f5576e4729b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
