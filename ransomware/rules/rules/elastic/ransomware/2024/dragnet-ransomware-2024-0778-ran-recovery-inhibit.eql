// Dragnet [Ransomware]: dragnet-ransomware-2024-0778 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 2cc0ddea-c543-59cc-a1c5-c9c3ef3b22b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
