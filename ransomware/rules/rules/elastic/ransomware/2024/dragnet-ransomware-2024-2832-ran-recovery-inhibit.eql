// Dragnet [Ransomware]: dragnet-ransomware-2024-2832 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: b329614f-c730-52aa-b710-35074ab2ecb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
