// Dragnet [Ransomware]: dragnet-ransomware-2024-2582 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: a1a7e603-d059-5c8a-b6e9-5bbafbe6c22f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
