// Dragnet [Ransomware]: dragnet-ransomware-2024-2271 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 6b29eab2-12d9-513c-8881-678b1e0e2050

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
