// Dragnet [Ransomware]: dragnet-ransomware-2024-5229 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 6f41acaf-3a98-5ecc-ace8-279d6bec2149

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
