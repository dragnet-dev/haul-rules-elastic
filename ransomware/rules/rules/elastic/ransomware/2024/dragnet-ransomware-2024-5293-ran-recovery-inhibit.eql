// Dragnet [Ransomware]: dragnet-ransomware-2024-5293 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a3a7283e-3a46-520f-aed8-f8392294db60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
