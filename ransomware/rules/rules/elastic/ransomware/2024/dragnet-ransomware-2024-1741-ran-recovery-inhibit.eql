// Dragnet [Ransomware]: dragnet-ransomware-2024-1741 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 38f0db19-e72c-5607-8cd5-3c0b70c00533

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
