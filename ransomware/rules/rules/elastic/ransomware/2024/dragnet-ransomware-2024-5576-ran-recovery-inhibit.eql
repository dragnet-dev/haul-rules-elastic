// Dragnet [Ransomware]: dragnet-ransomware-2024-5576 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 371f1d61-e56a-5844-9182-6617bf69da6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
