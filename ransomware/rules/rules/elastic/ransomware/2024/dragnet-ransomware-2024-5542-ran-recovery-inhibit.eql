// Dragnet [Ransomware]: dragnet-ransomware-2024-5542 — Recovery Inhibition (frag)
// Status: deprecated | Level: high | ID: 2f194641-e07f-52ee-a43a-717941ba03a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
