// Dragnet [Ransomware]: dragnet-ransomware-2024-1196 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: ef46d0bb-394b-5c06-a4e2-8cc7d3a053a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
