// Dragnet [Ransomware]: dragnet-ransomware-2024-2754 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 1eeee7fd-1f5a-563b-807a-554268bdbb9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
