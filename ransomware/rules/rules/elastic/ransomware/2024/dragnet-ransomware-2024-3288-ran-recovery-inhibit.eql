// Dragnet [Ransomware]: dragnet-ransomware-2024-3288 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 9b38ceec-afb3-599d-873c-8bb7cfb472d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
