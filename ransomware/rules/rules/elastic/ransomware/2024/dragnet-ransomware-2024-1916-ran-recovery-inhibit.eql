// Dragnet [Ransomware]: dragnet-ransomware-2024-1916 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 6692a0de-a768-5467-a2af-f17743f67319

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
