// Dragnet [Ransomware]: dragnet-ransomware-2024-5548 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 297971fe-e8ea-5330-8c66-211ac99558e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
