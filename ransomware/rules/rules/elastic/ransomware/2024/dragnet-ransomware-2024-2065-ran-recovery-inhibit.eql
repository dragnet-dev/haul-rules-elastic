// Dragnet [Ransomware]: dragnet-ransomware-2024-2065 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b0feb8a1-9326-594f-a612-78b8520f0ffc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
