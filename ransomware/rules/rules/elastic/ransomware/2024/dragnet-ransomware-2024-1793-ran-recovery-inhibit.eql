// Dragnet [Ransomware]: dragnet-ransomware-2024-1793 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 008a1e2b-6d05-5e58-8501-7e1e7bd10dbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
