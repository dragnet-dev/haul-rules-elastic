// Dragnet [Ransomware]: dragnet-ransomware-2024-2983 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: cf7c78d2-9f8f-5ff1-80de-8ef00c14b2a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
