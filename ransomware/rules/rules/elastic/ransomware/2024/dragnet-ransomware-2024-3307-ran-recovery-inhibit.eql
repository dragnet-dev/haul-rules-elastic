// Dragnet [Ransomware]: dragnet-ransomware-2024-3307 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b28867d6-3db4-5a70-93cc-8b269cbf08de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
