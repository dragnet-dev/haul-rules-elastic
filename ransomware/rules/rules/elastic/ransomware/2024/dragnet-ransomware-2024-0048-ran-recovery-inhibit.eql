// Dragnet [Ransomware]: dragnet-ransomware-2024-0048 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 613309b4-b31c-57a9-83d3-531ec388cc33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
