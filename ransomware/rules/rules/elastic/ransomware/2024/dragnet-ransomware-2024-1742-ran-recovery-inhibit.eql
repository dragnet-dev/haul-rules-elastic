// Dragnet [Ransomware]: dragnet-ransomware-2024-1742 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8824b9db-2b16-55a5-b318-5d9a9389a26e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
