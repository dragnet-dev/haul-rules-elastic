// Dragnet [Ransomware]: dragnet-ransomware-2024-5969 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 7cfbf42f-50f9-5164-bf36-c78084fdd542

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
