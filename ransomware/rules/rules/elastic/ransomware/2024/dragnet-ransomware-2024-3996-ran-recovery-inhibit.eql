// Dragnet [Ransomware]: dragnet-ransomware-2024-3996 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: 8937ed02-2f03-56bd-826f-2aea4669303a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
