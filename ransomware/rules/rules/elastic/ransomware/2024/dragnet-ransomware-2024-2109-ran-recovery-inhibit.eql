// Dragnet [Ransomware]: dragnet-ransomware-2024-2109 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 10e72526-f0ac-5991-9223-9461a58c0da8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
