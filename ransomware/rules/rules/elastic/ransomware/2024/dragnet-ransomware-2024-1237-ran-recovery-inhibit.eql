// Dragnet [Ransomware]: dragnet-ransomware-2024-1237 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e8f4b5f5-c898-5282-87a9-fa8b48e749b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
