// Dragnet [Ransomware]: dragnet-ransomware-2024-3858 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: cfddb153-0df9-515b-988f-96315ff2e487

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
