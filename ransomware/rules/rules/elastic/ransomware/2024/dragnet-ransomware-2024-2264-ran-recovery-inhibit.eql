// Dragnet [Ransomware]: dragnet-ransomware-2024-2264 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 562b8fc1-95ff-51b0-8aa3-93fb0dcb053b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
