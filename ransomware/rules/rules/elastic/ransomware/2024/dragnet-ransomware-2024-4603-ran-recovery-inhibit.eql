// Dragnet [Ransomware]: dragnet-ransomware-2024-4603 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: a808565d-2810-55bf-a1ad-2f15a27364a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
