// Dragnet [Ransomware]: dragnet-ransomware-2024-2607 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 4d45d71a-7f01-5e87-b01f-4934e7541f48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
