// Dragnet [Ransomware]: dragnet-ransomware-2024-1531 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 1da96d4b-28de-5ba5-a52d-768a24454552

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
