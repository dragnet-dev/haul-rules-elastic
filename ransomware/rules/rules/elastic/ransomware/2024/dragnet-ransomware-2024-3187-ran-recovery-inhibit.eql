// Dragnet [Ransomware]: dragnet-ransomware-2024-3187 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: 2b353f2f-aa9f-5b58-a2a1-86ae316fd24a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
