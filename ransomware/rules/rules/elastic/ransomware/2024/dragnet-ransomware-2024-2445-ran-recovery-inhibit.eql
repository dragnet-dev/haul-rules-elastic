// Dragnet [Ransomware]: dragnet-ransomware-2024-2445 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: d8831682-8f48-5a5d-ac15-9bc404ebdffb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
