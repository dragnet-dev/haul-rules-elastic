// Dragnet [Ransomware]: dragnet-ransomware-2024-5026 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 081800c4-c4da-5c9f-8a45-4a48c1caffa6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
