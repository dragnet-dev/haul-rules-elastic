// Dragnet [Ransomware]: dragnet-ransomware-2024-5793 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 00b61427-ba14-53fd-b198-1974980b56c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
