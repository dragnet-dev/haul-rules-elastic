// Dragnet [Ransomware]: dragnet-ransomware-2024-4956 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 93fc1a2e-8d69-59f5-bc75-be356405b07e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
