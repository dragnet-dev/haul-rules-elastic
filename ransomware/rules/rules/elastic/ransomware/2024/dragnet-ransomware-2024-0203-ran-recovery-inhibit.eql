// Dragnet [Ransomware]: dragnet-ransomware-2024-0203 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: f45d2ad0-d023-52ca-9343-529772cd06d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
