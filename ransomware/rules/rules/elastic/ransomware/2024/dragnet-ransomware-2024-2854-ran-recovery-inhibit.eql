// Dragnet [Ransomware]: dragnet-ransomware-2024-2854 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 296ea329-d297-58f2-a8dc-44c5e8b652c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
