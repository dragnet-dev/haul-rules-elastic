// Dragnet [Ransomware]: dragnet-ransomware-2024-2398 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: abf5764e-f1d1-52db-a698-ff331d974937

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
