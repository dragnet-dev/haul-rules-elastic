// Dragnet [Ransomware]: dragnet-ransomware-2024-0695 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 73df6c31-595a-5d08-8b52-e59f8e3afbf5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
