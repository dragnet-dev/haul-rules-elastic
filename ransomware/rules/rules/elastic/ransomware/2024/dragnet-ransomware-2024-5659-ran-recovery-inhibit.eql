// Dragnet [Ransomware]: dragnet-ransomware-2024-5659 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 521c0f09-d219-5667-9a4f-1751d63cbc7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
