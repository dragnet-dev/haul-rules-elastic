// Dragnet [Ransomware]: dragnet-ransomware-2024-0341 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: fb6d1e36-68e1-5ec1-9c4a-fb9e5bfda3c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
