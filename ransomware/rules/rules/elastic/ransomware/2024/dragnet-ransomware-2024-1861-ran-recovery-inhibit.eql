// Dragnet [Ransomware]: dragnet-ransomware-2024-1861 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 8100b5eb-31b0-546a-adac-efb967122a58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
