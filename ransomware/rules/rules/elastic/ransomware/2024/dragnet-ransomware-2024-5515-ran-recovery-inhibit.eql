// Dragnet [Ransomware]: dragnet-ransomware-2024-5515 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: ef5ccfb6-b8ca-54b4-9cba-37680ad2422e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
