// Dragnet [Ransomware]: dragnet-ransomware-2024-2206 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 4a556590-e222-531c-b937-a95b4d0018a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
