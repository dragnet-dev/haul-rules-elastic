// Dragnet [Ransomware]: dragnet-ransomware-2024-4972 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 69f2c3c3-3d07-5bc3-9f60-c5ccbd148b98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
