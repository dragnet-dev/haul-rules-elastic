// Dragnet [Ransomware]: dragnet-ransomware-2024-3709 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 05a52965-a175-53fe-906a-ae95675f1766

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
