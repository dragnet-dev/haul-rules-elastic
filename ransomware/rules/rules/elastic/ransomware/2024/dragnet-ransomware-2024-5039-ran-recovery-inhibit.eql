// Dragnet [Ransomware]: dragnet-ransomware-2024-5039 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 803e52e0-ddd3-5de1-8bd4-e066c9b64040

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
