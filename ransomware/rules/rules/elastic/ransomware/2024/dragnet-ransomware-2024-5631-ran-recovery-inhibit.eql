// Dragnet [Ransomware]: dragnet-ransomware-2024-5631 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: b2172c88-ebdb-5e9c-ba66-92e53894dea2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
