// Dragnet [Ransomware]: dragnet-ransomware-2024-3328 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: b0995af0-b8ae-56c8-b6d3-10ea53ecdf4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
