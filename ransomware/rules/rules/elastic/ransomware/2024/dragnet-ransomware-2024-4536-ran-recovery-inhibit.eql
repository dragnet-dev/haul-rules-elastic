// Dragnet [Ransomware]: dragnet-ransomware-2024-4536 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: 0ab19b1c-88d8-5318-9447-150c0dddb85e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
