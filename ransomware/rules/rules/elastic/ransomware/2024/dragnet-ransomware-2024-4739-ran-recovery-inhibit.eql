// Dragnet [Ransomware]: dragnet-ransomware-2024-4739 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: aa35ec7d-fc7f-5b4e-b696-c8df66c8c297

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
