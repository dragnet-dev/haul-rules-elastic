// Dragnet [Ransomware]: dragnet-ransomware-2024-5467 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 85142f6c-e385-5256-b5d4-0a46008e26c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
