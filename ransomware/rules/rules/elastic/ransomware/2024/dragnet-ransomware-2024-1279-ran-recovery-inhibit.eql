// Dragnet [Ransomware]: dragnet-ransomware-2024-1279 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: beef1927-81e3-5247-84fb-e2fcadd9923d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
