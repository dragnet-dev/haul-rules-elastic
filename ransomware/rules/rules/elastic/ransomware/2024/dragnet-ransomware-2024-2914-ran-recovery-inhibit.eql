// Dragnet [Ransomware]: dragnet-ransomware-2024-2914 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7610e7bf-2937-59b0-b83b-7a36588da2ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
