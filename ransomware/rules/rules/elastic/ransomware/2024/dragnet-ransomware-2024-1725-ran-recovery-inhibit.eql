// Dragnet [Ransomware]: dragnet-ransomware-2024-1725 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 2627427a-80fc-5ec0-8ea4-675ece77bea5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
