// Dragnet [Ransomware]: dragnet-ransomware-2024-0497 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 9acb8f96-dcf6-5cdc-be79-75a515213baf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
