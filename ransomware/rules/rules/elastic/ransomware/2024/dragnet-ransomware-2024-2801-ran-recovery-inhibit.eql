// Dragnet [Ransomware]: dragnet-ransomware-2024-2801 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: d3093f1c-d559-59b7-bbec-011600b121d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
