// Dragnet [Ransomware]: dragnet-ransomware-2024-0885 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 5399a5a9-c27a-5d5c-a5f9-7ecc76f2e7d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
