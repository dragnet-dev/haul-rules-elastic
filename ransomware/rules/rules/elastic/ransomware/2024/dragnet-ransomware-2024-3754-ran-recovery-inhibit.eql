// Dragnet [Ransomware]: dragnet-ransomware-2024-3754 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8e9ba6d2-b6c3-5a5a-973c-29acab5e5ffc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
