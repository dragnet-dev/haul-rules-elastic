// Dragnet [Ransomware]: dragnet-ransomware-2024-1965 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 779aecf8-a9b5-504e-b5b0-f5564b6d2f74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
