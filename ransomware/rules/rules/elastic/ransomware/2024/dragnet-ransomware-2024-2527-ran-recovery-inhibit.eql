// Dragnet [Ransomware]: dragnet-ransomware-2024-2527 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 80ce7ed8-dc8d-52e5-a6fb-065a6bf0015a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
