// Dragnet [Ransomware]: dragnet-ransomware-2024-2674 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 596b6aa3-d7b3-5a57-92ac-c1ef38d011e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
