// Dragnet [Ransomware]: dragnet-ransomware-2024-2534 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 2c614cd3-8549-5d50-94e5-97bdf23359ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
