// Dragnet [Ransomware]: dragnet-ransomware-2024-2700 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 1296c6ab-0626-5c0e-a904-7d3ad8205259

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
