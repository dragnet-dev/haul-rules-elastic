// Dragnet [Ransomware]: dragnet-ransomware-2024-0681 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 4c341c4a-ef43-52f2-b437-998ce5780c21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
