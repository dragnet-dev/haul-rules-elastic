// Dragnet [Ransomware]: dragnet-ransomware-2024-2916 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 39fe06c7-7cd5-5e56-ac34-09f6c8f8722c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
