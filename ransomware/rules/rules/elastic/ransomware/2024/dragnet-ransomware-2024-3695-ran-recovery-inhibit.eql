// Dragnet [Ransomware]: dragnet-ransomware-2024-3695 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a189ab92-d200-5f1f-a213-b9cb0b66d8e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
