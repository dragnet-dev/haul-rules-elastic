// Dragnet [Ransomware]: dragnet-ransomware-2024-1342 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: ddc107c2-9205-5aba-9578-cbd3410f5dd4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
