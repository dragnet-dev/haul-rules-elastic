// Dragnet [Ransomware]: dragnet-ransomware-2024-2299 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: 43211bce-6f99-5834-b759-62a50963de5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
