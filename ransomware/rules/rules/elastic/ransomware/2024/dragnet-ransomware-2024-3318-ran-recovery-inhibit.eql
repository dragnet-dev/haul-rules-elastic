// Dragnet [Ransomware]: dragnet-ransomware-2024-3318 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2c6330bf-6706-51f2-8e86-cce34a82f368

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
