// Dragnet [Ransomware]: dragnet-ransomware-2024-2128 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 40c1f515-035e-54ac-9225-0cfb7b86a8d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
