// Dragnet [Ransomware]: dragnet-ransomware-2024-2917 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 46807467-db73-576b-a828-8d27f6bd09b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
