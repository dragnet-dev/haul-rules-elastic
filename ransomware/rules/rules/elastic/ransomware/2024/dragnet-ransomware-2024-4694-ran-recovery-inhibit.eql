// Dragnet [Ransomware]: dragnet-ransomware-2024-4694 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 5837c32b-5c06-5826-b640-af4ae8021fdb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
