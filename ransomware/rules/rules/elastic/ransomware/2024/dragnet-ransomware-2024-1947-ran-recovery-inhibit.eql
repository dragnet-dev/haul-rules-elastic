// Dragnet [Ransomware]: dragnet-ransomware-2024-1947 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: bbdfbc3e-5659-53d6-a7dd-d77bc15cda8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
