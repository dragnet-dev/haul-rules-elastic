// Dragnet [Ransomware]: dragnet-ransomware-2024-3156 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: e1ec4a7c-006f-5415-9ceb-b0d3ff16c9d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
