// Dragnet [Ransomware]: dragnet-ransomware-2024-4842 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a073a798-fe82-51de-956c-827212a21eab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
