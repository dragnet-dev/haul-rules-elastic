// Dragnet [Ransomware]: dragnet-ransomware-2024-2022 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 1e053dce-98cf-507e-9cf4-52b17dfe8ac3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
