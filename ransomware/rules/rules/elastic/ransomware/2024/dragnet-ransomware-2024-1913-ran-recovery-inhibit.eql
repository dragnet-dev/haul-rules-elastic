// Dragnet [Ransomware]: dragnet-ransomware-2024-1913 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: c40b435d-533b-5f6c-accc-6d8b2e429dce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
