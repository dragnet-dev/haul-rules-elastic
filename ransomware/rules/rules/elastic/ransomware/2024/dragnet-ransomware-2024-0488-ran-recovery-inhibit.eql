// Dragnet [Ransomware]: dragnet-ransomware-2024-0488 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 9ac22d08-a707-50cf-86ba-8fc1984f3665

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
