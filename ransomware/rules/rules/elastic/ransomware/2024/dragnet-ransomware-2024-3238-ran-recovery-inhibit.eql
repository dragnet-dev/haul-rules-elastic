// Dragnet [Ransomware]: dragnet-ransomware-2024-3238 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bf5a790b-0fef-5218-8702-3b8c2bc447c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
