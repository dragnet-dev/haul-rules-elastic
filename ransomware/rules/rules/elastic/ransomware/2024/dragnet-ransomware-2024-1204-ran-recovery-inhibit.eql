// Dragnet [Ransomware]: dragnet-ransomware-2024-1204 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8199cc40-0306-52fc-8d2b-0223d390470e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
