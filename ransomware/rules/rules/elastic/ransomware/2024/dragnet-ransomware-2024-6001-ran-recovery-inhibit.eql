// Dragnet [Ransomware]: dragnet-ransomware-2024-6001 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6b7d9a6d-324e-5b41-b0c9-9fc374988a0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
