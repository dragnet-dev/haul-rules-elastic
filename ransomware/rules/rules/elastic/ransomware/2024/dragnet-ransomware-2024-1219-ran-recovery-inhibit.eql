// Dragnet [Ransomware]: dragnet-ransomware-2024-1219 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 845898ad-c2e8-55da-b242-968e10820181

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
