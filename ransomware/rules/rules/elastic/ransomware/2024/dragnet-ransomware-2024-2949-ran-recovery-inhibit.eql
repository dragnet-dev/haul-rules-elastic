// Dragnet [Ransomware]: dragnet-ransomware-2024-2949 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 2322befe-50e2-5868-9588-f6c4c1df6963

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
