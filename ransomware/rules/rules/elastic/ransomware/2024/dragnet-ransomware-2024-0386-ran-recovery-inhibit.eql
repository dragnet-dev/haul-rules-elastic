// Dragnet [Ransomware]: dragnet-ransomware-2024-0386 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: 30e52609-1801-5413-bbd2-a2712b68dcd1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
