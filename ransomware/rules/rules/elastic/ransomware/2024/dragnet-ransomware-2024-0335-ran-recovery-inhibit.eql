// Dragnet [Ransomware]: dragnet-ransomware-2024-0335 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: f68dccc4-4efb-5beb-bd34-a5884ea8946e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
