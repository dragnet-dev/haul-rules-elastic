// Dragnet [Ransomware]: dragnet-ransomware-2024-2589 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 4cf312af-82c5-50bc-9e78-6ae65a512cd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
