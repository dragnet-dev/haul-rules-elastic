// Dragnet [Ransomware]: dragnet-ransomware-2024-2829 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 34a7c90a-86e1-5dcc-b12f-bf502223c2bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
