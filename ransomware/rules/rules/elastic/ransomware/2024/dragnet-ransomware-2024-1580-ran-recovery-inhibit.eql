// Dragnet [Ransomware]: dragnet-ransomware-2024-1580 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a578e62c-54c9-5a81-abcb-a62f68eaa255

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
