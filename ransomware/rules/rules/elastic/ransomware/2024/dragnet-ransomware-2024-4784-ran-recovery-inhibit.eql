// Dragnet [Ransomware]: dragnet-ransomware-2024-4784 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 9c1b565e-4b48-5d06-ad77-a0d049d0acd1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
