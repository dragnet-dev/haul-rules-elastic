// Dragnet [Ransomware]: dragnet-ransomware-2024-0352 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 746605ee-3e44-5fbb-9e07-1bcdea35222e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
