// Dragnet [Ransomware]: dragnet-ransomware-2024-3689 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 867b3769-a0c1-594a-a5f2-66461a1a1b4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
