// Dragnet [Ransomware]: dragnet-ransomware-2024-5756 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: d26a11f0-e5ff-5c90-8523-66ed06205d38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
