// Dragnet [Ransomware]: dragnet-ransomware-2024-4911 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 47de899e-35f4-5048-99c4-a3dff0fdd4e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
