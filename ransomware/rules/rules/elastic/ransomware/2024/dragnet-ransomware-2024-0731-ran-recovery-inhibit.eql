// Dragnet [Ransomware]: dragnet-ransomware-2024-0731 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e82f79da-247d-545d-9d58-ae34906c6fd6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
