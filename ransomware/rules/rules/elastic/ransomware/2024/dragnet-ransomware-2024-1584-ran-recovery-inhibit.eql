// Dragnet [Ransomware]: dragnet-ransomware-2024-1584 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 73e94c72-fe8a-5bfb-af2d-491186c032a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
