// Dragnet [Ransomware]: dragnet-ransomware-2024-1670 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 72b28dfb-7fe2-57aa-8ef7-b50e2642e9ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
