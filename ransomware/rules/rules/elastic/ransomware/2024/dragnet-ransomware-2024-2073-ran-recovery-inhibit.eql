// Dragnet [Ransomware]: dragnet-ransomware-2024-2073 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: dffeb173-ef3f-5133-9e98-34750405b1bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
