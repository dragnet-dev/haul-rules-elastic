// Dragnet [Ransomware]: dragnet-ransomware-2024-1681 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: b4a001b6-ebd8-595a-a838-9a4f9557bc34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
