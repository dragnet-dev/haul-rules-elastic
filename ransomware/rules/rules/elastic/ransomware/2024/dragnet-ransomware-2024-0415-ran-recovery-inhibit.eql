// Dragnet [Ransomware]: dragnet-ransomware-2024-0415 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7a01d434-d2ae-5d8f-9a26-8b9460b1add5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
