// Dragnet [Ransomware]: dragnet-ransomware-2024-1511 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 40c4bf63-60fd-5457-a793-5f94e9ee0d58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
