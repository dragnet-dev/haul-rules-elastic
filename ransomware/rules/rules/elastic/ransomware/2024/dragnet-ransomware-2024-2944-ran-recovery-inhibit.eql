// Dragnet [Ransomware]: dragnet-ransomware-2024-2944 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9cb7e265-be85-5274-aed7-63952f7e62d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
