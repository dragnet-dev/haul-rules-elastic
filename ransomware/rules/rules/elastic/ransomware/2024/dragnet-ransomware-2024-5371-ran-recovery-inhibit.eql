// Dragnet [Ransomware]: dragnet-ransomware-2024-5371 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 168a665c-8ca9-52e9-9f22-2ef6a8dd9ac4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
