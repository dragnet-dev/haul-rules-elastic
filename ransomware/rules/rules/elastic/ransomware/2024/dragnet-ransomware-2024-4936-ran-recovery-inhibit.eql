// Dragnet [Ransomware]: dragnet-ransomware-2024-4936 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 04f7aa9e-f876-5a49-9a21-61b21250e044

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
