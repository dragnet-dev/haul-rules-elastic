// Dragnet [Ransomware]: dragnet-ransomware-2024-4585 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f5a45e67-eb51-51cd-91e6-406bb524e58e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
