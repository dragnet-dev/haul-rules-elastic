// Dragnet [Ransomware]: dragnet-ransomware-2024-3137 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 35b71d8d-9bce-5f13-bdc7-dd576990d2e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
