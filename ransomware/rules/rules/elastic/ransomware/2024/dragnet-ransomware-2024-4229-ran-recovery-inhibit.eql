// Dragnet [Ransomware]: dragnet-ransomware-2024-4229 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: e8d2ec40-cfe3-5810-b4dc-56a73397ec90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
