// Dragnet [Ransomware]: dragnet-ransomware-2024-3541 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: cc8190d0-13aa-5b40-9f6e-e4004ae80e84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
