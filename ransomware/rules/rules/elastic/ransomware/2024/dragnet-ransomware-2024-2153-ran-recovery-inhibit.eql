// Dragnet [Ransomware]: dragnet-ransomware-2024-2153 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7f8ece74-6e4e-5619-90ff-6da2c28313e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
