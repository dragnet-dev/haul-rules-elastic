// Dragnet [Ransomware]: dragnet-ransomware-2024-4899 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 9fc903e8-b095-5a78-bfa3-83d1c2e91a3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
