// Dragnet [Ransomware]: dragnet-ransomware-2024-3845 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 558d5b92-a94f-5fce-9c3c-5e0b3450536b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
