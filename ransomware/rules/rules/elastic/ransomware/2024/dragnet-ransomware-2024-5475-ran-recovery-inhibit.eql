// Dragnet [Ransomware]: dragnet-ransomware-2024-5475 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 069308e0-b798-5155-badd-41435fea95dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
