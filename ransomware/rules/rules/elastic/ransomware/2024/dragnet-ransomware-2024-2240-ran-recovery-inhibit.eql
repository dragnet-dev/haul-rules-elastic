// Dragnet [Ransomware]: dragnet-ransomware-2024-2240 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a2b8721c-a518-5fa5-8be6-49d497729221

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
