// Dragnet [Ransomware]: dragnet-ransomware-2024-1429 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f39ebbab-f7fd-5179-bd9c-6c4fd314fcd4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
