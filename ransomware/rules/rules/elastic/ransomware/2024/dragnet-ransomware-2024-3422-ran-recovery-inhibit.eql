// Dragnet [Ransomware]: dragnet-ransomware-2024-3422 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f55d0049-66b0-5d4a-b831-cbf327cf6c78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
