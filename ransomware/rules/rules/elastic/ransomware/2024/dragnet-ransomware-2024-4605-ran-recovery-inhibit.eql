// Dragnet [Ransomware]: dragnet-ransomware-2024-4605 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 6493adad-1c87-510e-a794-d5b43723a3b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
