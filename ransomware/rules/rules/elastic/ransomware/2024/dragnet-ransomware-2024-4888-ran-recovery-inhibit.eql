// Dragnet [Ransomware]: dragnet-ransomware-2024-4888 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 36346b28-2dea-5a60-bc12-24800a3ba027

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
