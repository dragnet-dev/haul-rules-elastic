// Dragnet [Ransomware]: dragnet-ransomware-2024-3045 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: bb9fa4cc-840d-5401-9dc9-e99a27f80e1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
