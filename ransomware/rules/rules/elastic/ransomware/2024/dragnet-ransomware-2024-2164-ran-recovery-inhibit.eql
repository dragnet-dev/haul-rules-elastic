// Dragnet [Ransomware]: dragnet-ransomware-2024-2164 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 53065948-75f7-562b-a941-6310571d414e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
