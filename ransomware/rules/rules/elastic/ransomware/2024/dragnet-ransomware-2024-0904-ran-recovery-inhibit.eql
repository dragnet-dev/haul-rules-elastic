// Dragnet [Ransomware]: dragnet-ransomware-2024-0904 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: f6c225dc-721f-5b66-bea1-d990e3c4be68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
