// Dragnet [Ransomware]: dragnet-ransomware-2024-0223 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 3877330f-1e56-5fe0-a61f-2c9d75b0efe5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
