// Dragnet [Ransomware]: dragnet-ransomware-2024-4171 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: f6f202c3-0064-51f5-863b-bdbc1d7bc036

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
