// Dragnet [Ransomware]: dragnet-ransomware-2024-3696 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 90548fc3-41a6-5d6c-9cbe-3ee43e5c3b61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
