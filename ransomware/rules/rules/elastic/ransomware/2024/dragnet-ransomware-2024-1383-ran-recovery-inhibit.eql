// Dragnet [Ransomware]: dragnet-ransomware-2024-1383 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 581e524b-9b1a-5755-a513-6628e84dbbf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
