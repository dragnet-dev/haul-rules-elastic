// Dragnet [Ransomware]: dragnet-ransomware-2024-1295 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: cdaed928-14aa-5570-8729-497cce96b50f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
