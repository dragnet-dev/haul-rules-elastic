// Dragnet [Ransomware]: dragnet-ransomware-2024-3373 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: a35dfee3-a173-5ca7-85e1-58920dc35a05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
