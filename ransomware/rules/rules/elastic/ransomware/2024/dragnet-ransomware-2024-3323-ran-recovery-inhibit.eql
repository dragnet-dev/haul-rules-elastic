// Dragnet [Ransomware]: dragnet-ransomware-2024-3323 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: c784cf6d-3160-560b-84ee-7a0d9c3ca698

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
