// Dragnet [Ransomware]: dragnet-ransomware-2024-4482 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: 531068f8-7072-5635-9015-7b4467a103c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
