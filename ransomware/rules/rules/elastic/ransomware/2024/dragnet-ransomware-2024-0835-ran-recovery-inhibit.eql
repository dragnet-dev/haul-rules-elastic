// Dragnet [Ransomware]: dragnet-ransomware-2024-0835 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: b060da00-efbd-5bcb-8992-a88d163448a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
