// Dragnet [Ransomware]: dragnet-ransomware-2024-5563 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c746dafc-c6e1-54da-8d2c-7bd4443f3a78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
