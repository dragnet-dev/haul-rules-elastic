// Dragnet [Ransomware]: dragnet-ransomware-2024-5227 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3c95b194-3078-5061-a67d-84fe47100c4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
