// Dragnet [Ransomware]: dragnet-ransomware-2024-5531 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 06510f7f-a298-53c0-b0fe-2588a9bb1896

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
