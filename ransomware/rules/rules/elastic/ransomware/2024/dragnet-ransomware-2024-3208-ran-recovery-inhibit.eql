// Dragnet [Ransomware]: dragnet-ransomware-2024-3208 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: f2c1cb2b-22f6-582b-9d4d-1d3468fbd882

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
