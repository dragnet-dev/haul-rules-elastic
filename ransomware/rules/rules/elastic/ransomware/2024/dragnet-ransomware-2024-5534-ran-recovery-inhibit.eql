// Dragnet [Ransomware]: dragnet-ransomware-2024-5534 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 96e14bb3-89ea-5050-b380-1a742a612235

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
