// Dragnet [Ransomware]: dragnet-ransomware-2024-1579 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0c3a03a3-cad0-5d15-bfe4-d8fd4081cd9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
