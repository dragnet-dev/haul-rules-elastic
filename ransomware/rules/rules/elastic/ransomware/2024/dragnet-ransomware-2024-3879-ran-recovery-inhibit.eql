// Dragnet [Ransomware]: dragnet-ransomware-2024-3879 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: e3c0812e-8c4f-5f4b-8c80-716ed272dc21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
