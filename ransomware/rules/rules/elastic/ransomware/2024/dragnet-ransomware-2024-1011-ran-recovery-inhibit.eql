// Dragnet [Ransomware]: dragnet-ransomware-2024-1011 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 565a074d-1c27-5d3f-9800-811ec10e5a91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
