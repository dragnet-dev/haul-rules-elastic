// Dragnet [Ransomware]: dragnet-ransomware-2024-3658 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7f86017b-ec1d-57ff-af96-e01582699454

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
