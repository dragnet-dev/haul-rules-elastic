// Dragnet [Ransomware]: dragnet-ransomware-2024-2247 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 18d51d6f-ebcb-52d6-a86c-a6de6479e767

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
