// Dragnet [Ransomware]: dragnet-ransomware-2024-2900 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: c933487e-02e4-57ea-a599-b2e4478f2dd7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
