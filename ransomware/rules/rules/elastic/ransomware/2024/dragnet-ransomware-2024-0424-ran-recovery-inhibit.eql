// Dragnet [Ransomware]: dragnet-ransomware-2024-0424 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: bd8a7990-7110-59f0-a8c2-5a65912480cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
