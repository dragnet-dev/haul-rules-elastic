// Dragnet [Ransomware]: dragnet-ransomware-2024-2092 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7df5b30a-61eb-5eed-b751-b6164ab3a367

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
