// Dragnet [Ransomware]: dragnet-ransomware-2024-2000 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 6bb050d4-2c31-537c-95fd-0f87a01724d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
