// Dragnet [Ransomware]: dragnet-ransomware-2024-4150 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 60835bfd-b81b-58ce-9020-5794afb13de2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
