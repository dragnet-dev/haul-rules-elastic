// Dragnet [Ransomware]: dragnet-ransomware-2024-1804 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: 50e31f44-cf79-5d29-b7bd-61e0fad8c647

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
