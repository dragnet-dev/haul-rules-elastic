// Dragnet [Ransomware]: dragnet-ransomware-2024-1034 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3ba7f31c-70a4-5e5f-a651-183ab507e984

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
