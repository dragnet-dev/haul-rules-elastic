// Dragnet [Ransomware]: dragnet-ransomware-2024-2316 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 0aace59f-8b4d-5575-8163-7063406cf039

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
