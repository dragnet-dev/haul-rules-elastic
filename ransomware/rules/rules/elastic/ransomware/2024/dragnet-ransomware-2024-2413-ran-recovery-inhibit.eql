// Dragnet [Ransomware]: dragnet-ransomware-2024-2413 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6207284b-b068-5ab9-ad4f-b976be40a23d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
