// Dragnet [Ransomware]: dragnet-ransomware-2024-0071 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: dd4fe6a7-2328-5c89-a5c0-4f6be5b935d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
