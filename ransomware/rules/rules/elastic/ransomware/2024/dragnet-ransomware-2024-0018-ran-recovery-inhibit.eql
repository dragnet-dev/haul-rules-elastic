// Dragnet [Ransomware]: dragnet-ransomware-2024-0018 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f79921fd-fdf0-569a-bad4-4092d8380343

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
