// Dragnet [Ransomware]: dragnet-ransomware-2024-0804 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0e184840-8afa-5f4f-aa1c-9ba0086f15ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
