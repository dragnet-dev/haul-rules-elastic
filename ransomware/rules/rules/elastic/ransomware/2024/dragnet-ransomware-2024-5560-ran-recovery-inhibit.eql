// Dragnet [Ransomware]: dragnet-ransomware-2024-5560 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: e5dd4a73-0ad7-52d1-aabb-02f49e106cf1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
