// Dragnet [Ransomware]: dragnet-ransomware-2024-4059 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c75d4fea-10e6-579b-8cb9-c4c433fd410a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
