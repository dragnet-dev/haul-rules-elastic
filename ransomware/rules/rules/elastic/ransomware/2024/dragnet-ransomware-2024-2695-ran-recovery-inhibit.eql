// Dragnet [Ransomware]: dragnet-ransomware-2024-2695 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 8a4f3cfd-2851-551b-953e-23369bb1c685

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
