// Dragnet [Ransomware]: dragnet-ransomware-2024-0751 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ec66cd5c-0fcf-55a8-867f-c71974186e9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
