// Dragnet [Ransomware]: dragnet-ransomware-2024-3514 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 9c582215-f57a-5ddf-8021-ecbfaf63d1e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
