// Dragnet [Ransomware]: dragnet-ransomware-2024-2933 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 7af1b244-5852-5f11-99f1-e81288e5f813

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
