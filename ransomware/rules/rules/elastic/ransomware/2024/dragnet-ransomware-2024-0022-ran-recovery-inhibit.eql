// Dragnet [Ransomware]: dragnet-ransomware-2024-0022 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8ee55209-75ca-5d2d-a52c-8a8209ed3ac5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
