// Dragnet [Ransomware]: dragnet-ransomware-2024-6018 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 79eca5c8-fe49-55a2-ae46-2207f6002224

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
