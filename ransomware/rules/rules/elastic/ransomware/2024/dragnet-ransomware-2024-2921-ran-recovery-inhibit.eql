// Dragnet [Ransomware]: dragnet-ransomware-2024-2921 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 266b0d07-95df-5c1c-9c2d-53cccc1b10d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
