// Dragnet [Ransomware]: dragnet-ransomware-2024-4531 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: c60bf214-c396-5bf3-91fc-4a36bc09a817

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
