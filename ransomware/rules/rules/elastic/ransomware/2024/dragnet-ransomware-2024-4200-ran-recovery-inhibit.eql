// Dragnet [Ransomware]: dragnet-ransomware-2024-4200 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 21af78e7-0783-54dd-96a4-537b476048e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
