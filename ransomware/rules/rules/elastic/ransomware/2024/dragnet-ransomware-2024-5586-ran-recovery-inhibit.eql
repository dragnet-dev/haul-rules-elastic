// Dragnet [Ransomware]: dragnet-ransomware-2024-5586 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 70a6e253-f174-5b6b-a6e3-4b7e035e999a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
