// Dragnet [Ransomware]: dragnet-ransomware-2024-5769 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 2b421ffc-2955-5ef4-9995-5d306f32b06d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
