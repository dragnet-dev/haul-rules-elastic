// Dragnet [Ransomware]: dragnet-ransomware-2024-3630 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5a124360-e0fe-5503-b72f-b00bfe9cde02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
