// Dragnet [Ransomware]: dragnet-ransomware-2024-0536 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 7f062cca-82a8-5fae-b13b-004c5e0446cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
