// Dragnet [Ransomware]: dragnet-ransomware-2024-2218 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: cc25a5f1-21ed-5703-98b7-aac7b92f2510

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
