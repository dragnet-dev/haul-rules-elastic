// Dragnet [Ransomware]: dragnet-ransomware-2024-5997 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 722bd2e2-a293-5fd6-9e10-15256dc00d05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
