// Dragnet [Ransomware]: dragnet-ransomware-2024-4758 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: f049174b-3a28-5a80-9250-4ac88107a1d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
