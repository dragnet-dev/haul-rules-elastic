// Dragnet [Ransomware]: dragnet-ransomware-2024-4626 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 1a3c16f0-1771-5a8d-ab28-dd5875c6b76b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
