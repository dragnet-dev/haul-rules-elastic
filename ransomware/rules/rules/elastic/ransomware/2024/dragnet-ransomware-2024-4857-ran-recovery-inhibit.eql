// Dragnet [Ransomware]: dragnet-ransomware-2024-4857 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: c3bf8f89-70f7-55cc-97c0-ac7acf315d4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
