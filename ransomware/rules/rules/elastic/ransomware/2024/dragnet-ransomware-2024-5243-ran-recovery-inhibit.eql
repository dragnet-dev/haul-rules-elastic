// Dragnet [Ransomware]: dragnet-ransomware-2024-5243 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 047f35e1-d1a5-57cf-b8ee-da632e168cef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
