// Dragnet [Ransomware]: dragnet-ransomware-2024-2002 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 763a71a1-c0ec-569c-86d7-b59099d76deb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
