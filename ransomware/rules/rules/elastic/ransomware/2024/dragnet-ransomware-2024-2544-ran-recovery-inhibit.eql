// Dragnet [Ransomware]: dragnet-ransomware-2024-2544 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 4a9ed332-177a-5088-b765-cb3d8fdfa17f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
