// Dragnet [Ransomware]: dragnet-ransomware-2024-5070 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 10f8a820-7614-5152-ba9d-33b5fd7bc12b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
