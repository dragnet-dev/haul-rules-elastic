// Dragnet [Ransomware]: dragnet-ransomware-2024-0519 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0dcda1f0-6443-5d7f-b52d-548e8364bb3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
