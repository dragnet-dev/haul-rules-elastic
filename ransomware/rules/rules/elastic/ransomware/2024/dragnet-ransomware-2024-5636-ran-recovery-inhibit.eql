// Dragnet [Ransomware]: dragnet-ransomware-2024-5636 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7164f8e2-92d0-53b9-af70-2ef7090a9dd1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
