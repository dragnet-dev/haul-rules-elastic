// Dragnet [Ransomware]: dragnet-ransomware-2024-1609 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 3a5b973e-34e0-57b0-bff2-514c71fdfc19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
