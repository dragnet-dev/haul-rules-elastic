// Dragnet [Ransomware]: dragnet-ransomware-2024-5184 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 23f1f3cb-d591-5104-a573-9592f24a6240

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
