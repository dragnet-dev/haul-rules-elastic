// Dragnet [Ransomware]: dragnet-ransomware-2024-2978 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 435e83eb-c56f-5bdc-a8ea-df4fbae48a2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
