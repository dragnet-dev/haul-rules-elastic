// Dragnet [Ransomware]: dragnet-ransomware-2024-3252 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 08c8247b-619c-5883-8ea9-cc48f03e9e8f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
