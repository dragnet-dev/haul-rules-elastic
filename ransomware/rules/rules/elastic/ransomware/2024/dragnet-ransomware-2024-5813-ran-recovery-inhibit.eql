// Dragnet [Ransomware]: dragnet-ransomware-2024-5813 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 4fc7fe13-5aae-5cc7-abad-7640dbf9a3a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
