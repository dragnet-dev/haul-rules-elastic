// Dragnet [Ransomware]: dragnet-ransomware-2024-3280 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3ec777de-72d4-5929-a359-1a38d2b437bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
