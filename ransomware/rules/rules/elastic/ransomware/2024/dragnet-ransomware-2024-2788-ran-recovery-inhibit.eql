// Dragnet [Ransomware]: dragnet-ransomware-2024-2788 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 85886693-43ef-5d01-a74a-26a37328bacf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
