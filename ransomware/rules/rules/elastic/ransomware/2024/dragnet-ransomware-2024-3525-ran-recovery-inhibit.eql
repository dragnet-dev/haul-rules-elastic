// Dragnet [Ransomware]: dragnet-ransomware-2024-3525 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 7e5c23d4-eefb-564b-aa5b-539a5954ccf5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
