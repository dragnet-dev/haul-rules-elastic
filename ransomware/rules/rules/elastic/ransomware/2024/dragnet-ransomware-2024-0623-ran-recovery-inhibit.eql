// Dragnet [Ransomware]: dragnet-ransomware-2024-0623 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 20d9db36-64c6-5e36-83fd-a049a8041ff1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
