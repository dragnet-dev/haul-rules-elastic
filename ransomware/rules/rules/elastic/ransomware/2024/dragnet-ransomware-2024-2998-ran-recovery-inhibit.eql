// Dragnet [Ransomware]: dragnet-ransomware-2024-2998 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 4c97e8c5-2fba-556d-ae4b-6250c089ea65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
