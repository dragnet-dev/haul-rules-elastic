// Dragnet [Ransomware]: dragnet-ransomware-2024-5958 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 0470b5b0-847c-594d-95dd-87496c3ae1bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
