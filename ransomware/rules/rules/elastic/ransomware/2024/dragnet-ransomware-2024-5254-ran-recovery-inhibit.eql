// Dragnet [Ransomware]: dragnet-ransomware-2024-5254 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 87b91a1f-6ffa-58b6-ad12-56865fadcb82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
