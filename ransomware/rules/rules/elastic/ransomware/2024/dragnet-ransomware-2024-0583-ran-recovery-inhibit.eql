// Dragnet [Ransomware]: dragnet-ransomware-2024-0583 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 212c3dbe-0047-5ca7-ab10-f1a81cbc44fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
