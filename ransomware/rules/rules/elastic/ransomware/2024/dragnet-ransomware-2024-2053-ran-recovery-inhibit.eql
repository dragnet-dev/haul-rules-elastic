// Dragnet [Ransomware]: dragnet-ransomware-2024-2053 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 84e5df28-369a-5215-adee-1ea82319c165

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
