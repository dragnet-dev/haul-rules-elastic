// Dragnet [Ransomware]: dragnet-ransomware-2024-3713 — Recovery Inhibition (ransomcortex)
// Status: experimental | Level: high | ID: 3807d4d8-d3e5-5f87-87a6-603286c34a7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
