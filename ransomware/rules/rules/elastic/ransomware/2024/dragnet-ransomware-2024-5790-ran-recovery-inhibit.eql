// Dragnet [Ransomware]: dragnet-ransomware-2024-5790 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 8e454913-3a78-51bf-960d-859a69b71da0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
