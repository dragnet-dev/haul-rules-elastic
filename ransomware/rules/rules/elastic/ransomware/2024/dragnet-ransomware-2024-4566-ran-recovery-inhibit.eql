// Dragnet [Ransomware]: dragnet-ransomware-2024-4566 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 20f5c449-8dc8-5c9e-973f-8938aaf3d0b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
