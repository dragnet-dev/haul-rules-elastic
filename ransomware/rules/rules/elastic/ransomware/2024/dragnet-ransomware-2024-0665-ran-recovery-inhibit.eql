// Dragnet [Ransomware]: dragnet-ransomware-2024-0665 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 31525194-f539-531f-a349-2a92cee58548

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
