// Dragnet [Ransomware]: dragnet-ransomware-2024-2439 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: cbc58ca2-b90f-5da1-a591-cf751cb6d93d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
