// Dragnet [Ransomware]: dragnet-ransomware-2024-3627 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c181b6a4-c4f0-551c-b406-dd952aae4442

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
