// Dragnet [Ransomware]: dragnet-ransomware-2024-4179 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3d4c67e7-340b-5634-9191-06259390c51a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
