// Dragnet [Ransomware]: dragnet-ransomware-2024-1013 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 09c6afba-8ac2-5eda-8035-359796d75113

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
