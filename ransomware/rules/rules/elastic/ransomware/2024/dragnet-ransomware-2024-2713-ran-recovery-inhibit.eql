// Dragnet [Ransomware]: dragnet-ransomware-2024-2713 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: b2a798d1-a78a-5e5d-93c3-39492586549c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
