// Dragnet [Ransomware]: dragnet-ransomware-2024-5670 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: fa7911f4-3c54-5bef-b37d-5ac8c9aa08c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
