// Dragnet [Ransomware]: dragnet-ransomware-2024-2173 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 34b923f6-34fb-55cf-b6d2-c9db70b205b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
