// Dragnet [Ransomware]: dragnet-ransomware-2024-1327 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 31044462-36ae-5d02-8ad3-0c7431d74e0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
