// Dragnet [Ransomware]: dragnet-ransomware-2024-2611 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: dae5a519-d71b-5b61-83c1-ca0b35be7cc9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
