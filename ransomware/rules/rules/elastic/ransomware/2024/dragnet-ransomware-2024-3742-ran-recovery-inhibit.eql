// Dragnet [Ransomware]: dragnet-ransomware-2024-3742 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: 0570a061-2cfd-524d-bd70-249073f32992

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
