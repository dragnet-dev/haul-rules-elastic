// Dragnet [Ransomware]: dragnet-ransomware-2024-2575 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 2fd009d1-1382-5f8b-b32c-70d6288b3e01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
