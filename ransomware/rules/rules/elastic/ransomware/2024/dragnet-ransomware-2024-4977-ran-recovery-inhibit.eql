// Dragnet [Ransomware]: dragnet-ransomware-2024-4977 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 2facac20-8456-5424-9a17-1402249497c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
