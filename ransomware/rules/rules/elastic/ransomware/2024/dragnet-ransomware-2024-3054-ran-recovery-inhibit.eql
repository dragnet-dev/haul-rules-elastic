// Dragnet [Ransomware]: dragnet-ransomware-2024-3054 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: e2fd5610-d014-533e-a8f7-ec11f323fee9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
