// Dragnet [Ransomware]: dragnet-ransomware-2024-1930 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f9d5a8c9-c995-5d43-8063-683988de142e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
