// Dragnet [Ransomware]: dragnet-ransomware-2024-1936 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fecb12ff-2320-5342-8d26-65b63396111b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
