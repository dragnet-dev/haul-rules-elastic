// Dragnet [Ransomware]: dragnet-ransomware-2024-5473 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 9a1e06cd-a23c-5e7d-a784-79eb59e85bfb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
