// Dragnet [Ransomware]: dragnet-ransomware-2024-0243 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8e2bffb6-3dd0-5eaa-95b5-6e6cf50eb266

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
