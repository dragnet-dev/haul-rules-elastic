// Dragnet [Ransomware]: dragnet-ransomware-2024-0851 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 15871e0a-f99f-50ee-9ebd-92a8a804341f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
