// Dragnet [Ransomware]: dragnet-ransomware-2024-5591 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2d6c50fa-3cf0-5f5e-8235-8cc17a0a67bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
