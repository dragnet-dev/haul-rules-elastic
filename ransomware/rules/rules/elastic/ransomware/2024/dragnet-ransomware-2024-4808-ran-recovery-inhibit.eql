// Dragnet [Ransomware]: dragnet-ransomware-2024-4808 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2adb9639-b8ac-5e95-996c-f217525d7edf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
