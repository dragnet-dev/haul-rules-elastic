// Dragnet [Ransomware]: dragnet-ransomware-2024-0089 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 4276b26d-d6e0-5971-ab46-04509c717274

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
