// Dragnet [Ransomware]: dragnet-ransomware-2024-1940 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: c95ab761-576e-5318-a304-476d183aaebe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
