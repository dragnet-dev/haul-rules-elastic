// Dragnet [Ransomware]: dragnet-ransomware-2024-1923 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 8b7c5501-2bb1-579e-8e58-37254ee2d577

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
