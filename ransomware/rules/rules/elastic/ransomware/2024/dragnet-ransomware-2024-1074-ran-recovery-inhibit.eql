// Dragnet [Ransomware]: dragnet-ransomware-2024-1074 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 42fb0741-f414-51d9-a059-80ffb04fae54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
