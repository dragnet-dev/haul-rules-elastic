// Dragnet [Ransomware]: dragnet-ransomware-2024-4250 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: d8f800b4-04af-505d-b648-1a03468639d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
