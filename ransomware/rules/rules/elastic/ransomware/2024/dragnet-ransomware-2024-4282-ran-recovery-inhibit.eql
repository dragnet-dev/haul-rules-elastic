// Dragnet [Ransomware]: dragnet-ransomware-2024-4282 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: 06f08171-cd86-540e-bfa6-d9ecf6ad05ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
