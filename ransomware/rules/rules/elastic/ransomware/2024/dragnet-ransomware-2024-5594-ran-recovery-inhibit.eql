// Dragnet [Ransomware]: dragnet-ransomware-2024-5594 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 23ceed69-4781-5b5d-b82b-53ddfb31659a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
