// Dragnet [Ransomware]: dragnet-ransomware-2024-4984 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: c23f84b9-5dea-5fcf-b576-2701e16d24e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
