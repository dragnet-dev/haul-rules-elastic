// Dragnet [Ransomware]: dragnet-ransomware-2024-0025 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 65ed12ec-7c16-509c-aa5c-42d7b8481855

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
