// Dragnet [Ransomware]: dragnet-ransomware-2024-5010 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bfe6baae-13a2-5733-a445-232996074958

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
