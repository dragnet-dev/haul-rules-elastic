// Dragnet [Ransomware]: dragnet-ransomware-2024-4516 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 53d9e170-e42d-508c-ad67-13ff9e69598e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
