// Dragnet [Ransomware]: dragnet-ransomware-2024-1802 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: 7d07dded-ebc2-5d0e-bd29-f91101331828

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
