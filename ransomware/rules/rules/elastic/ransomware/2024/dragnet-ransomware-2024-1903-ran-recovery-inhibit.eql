// Dragnet [Ransomware]: dragnet-ransomware-2024-1903 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 1455a0fc-5d9c-5c4c-8f58-951d04f09b18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
