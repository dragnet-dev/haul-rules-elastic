// Dragnet [Ransomware]: dragnet-ransomware-2024-5260 — Recovery Inhibition (orca)
// Status: experimental | Level: high | ID: 68e7efd8-e516-59bd-88fa-06f68379b715

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
