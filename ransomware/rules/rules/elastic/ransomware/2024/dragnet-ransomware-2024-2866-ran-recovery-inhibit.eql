// Dragnet [Ransomware]: dragnet-ransomware-2024-2866 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a9636960-ec41-5e49-9eea-46ab1f89be0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
