// Dragnet [Ransomware]: dragnet-ransomware-2024-4375 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: fde1378e-ea1d-5256-b5be-ee53f88eb2c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
