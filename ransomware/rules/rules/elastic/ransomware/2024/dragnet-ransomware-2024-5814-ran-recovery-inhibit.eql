// Dragnet [Ransomware]: dragnet-ransomware-2024-5814 — Recovery Inhibition (radar)
// Status: deprecated | Level: high | ID: 66f05a41-bca0-578d-b4e6-5ea1827f27e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
