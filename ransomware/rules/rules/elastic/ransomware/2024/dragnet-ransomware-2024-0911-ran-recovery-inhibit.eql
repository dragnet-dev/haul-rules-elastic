// Dragnet [Ransomware]: dragnet-ransomware-2024-0911 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 7cc9dee3-7803-51ad-9e6a-6b8e0e25f62c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
