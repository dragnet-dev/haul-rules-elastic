// Dragnet [Ransomware]: dragnet-ransomware-2024-0884 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 911310a7-b958-5a38-bad1-2005bb648803

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
