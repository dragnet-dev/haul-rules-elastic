// Dragnet [Ransomware]: dragnet-ransomware-2024-5098 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 325fd053-8fb6-5fcf-9659-c83d698b56d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
