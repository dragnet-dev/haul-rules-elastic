// Dragnet [Ransomware]: dragnet-ransomware-2024-0813 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 842310b5-2578-578a-82b1-dc53958cab43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
