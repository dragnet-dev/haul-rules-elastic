// Dragnet [Ransomware]: dragnet-ransomware-2024-0861 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f7784228-3550-5cc1-918f-43a7ae1d1732

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
