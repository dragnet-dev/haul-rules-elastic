// Dragnet [Ransomware]: dragnet-ransomware-2024-0540 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 3c4caf48-d5a1-50f1-85ce-5fbe87569aa6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
