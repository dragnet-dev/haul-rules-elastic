// Dragnet [Ransomware]: dragnet-ransomware-2024-1470 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f4ddd9b5-653f-542c-88e0-3c3d1b739e44

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
