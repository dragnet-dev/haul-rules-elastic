// Dragnet [Ransomware]: dragnet-ransomware-2024-0787 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 5733dccd-2ab8-5e8b-b230-a0f423f66c8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
