// Dragnet [Ransomware]: dragnet-ransomware-2024-3911 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3112a4c5-e5d9-5093-92b9-35f2365e845e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
