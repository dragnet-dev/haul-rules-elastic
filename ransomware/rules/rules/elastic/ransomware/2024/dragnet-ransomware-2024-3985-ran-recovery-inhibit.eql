// Dragnet [Ransomware]: dragnet-ransomware-2024-3985 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b239e8f2-37da-5286-a4c6-a20a89ba3571

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
