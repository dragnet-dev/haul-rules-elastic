// Dragnet [Ransomware]: dragnet-ransomware-2024-5032 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: 5c98e501-6984-5a41-867a-793e32156f6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
