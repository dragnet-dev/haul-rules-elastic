// Dragnet [Ransomware]: dragnet-ransomware-2024-3474 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 46a60cda-b71f-5261-aef3-8807d74ca032

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
