// Dragnet [Ransomware]: dragnet-ransomware-2024-1606 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 7a7b3099-e507-5b33-a7a1-4cc10f5abfef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
