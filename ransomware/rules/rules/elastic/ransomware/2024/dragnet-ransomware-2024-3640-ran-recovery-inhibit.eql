// Dragnet [Ransomware]: dragnet-ransomware-2024-3640 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 46808a79-c189-5d69-8589-b6a391197bc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
