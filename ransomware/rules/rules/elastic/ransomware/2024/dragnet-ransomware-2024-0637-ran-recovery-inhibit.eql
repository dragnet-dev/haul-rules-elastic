// Dragnet [Ransomware]: dragnet-ransomware-2024-0637 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: da6cd6e9-f5fd-5abc-8838-d8906165c905

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
