// Dragnet [Ransomware]: dragnet-ransomware-2024-0147 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: 2b621a76-0cc6-5ef7-be34-2b22d49c870c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
