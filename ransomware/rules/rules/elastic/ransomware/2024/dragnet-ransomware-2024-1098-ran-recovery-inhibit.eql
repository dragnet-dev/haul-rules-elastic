// Dragnet [Ransomware]: dragnet-ransomware-2024-1098 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 487eb598-076b-5037-8f2a-ad3126dfd378

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
