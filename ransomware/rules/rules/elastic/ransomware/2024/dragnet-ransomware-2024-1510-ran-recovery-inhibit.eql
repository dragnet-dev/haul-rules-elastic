// Dragnet [Ransomware]: dragnet-ransomware-2024-1510 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 0b019357-26dc-559d-befa-24ca2231aef4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
