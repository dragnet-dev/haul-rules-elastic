// Dragnet [Ransomware]: dragnet-ransomware-2024-3784 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: dae67647-f156-5a02-b79c-01d83540f851

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
