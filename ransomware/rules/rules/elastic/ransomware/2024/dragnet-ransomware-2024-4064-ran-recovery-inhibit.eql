// Dragnet [Ransomware]: dragnet-ransomware-2024-4064 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: dfbbd78a-481a-5ffa-bcef-264071a2b58a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
