// Dragnet [Ransomware]: dragnet-ransomware-2024-2434 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a035be07-ad8f-55c1-8fde-76c61617a8fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
