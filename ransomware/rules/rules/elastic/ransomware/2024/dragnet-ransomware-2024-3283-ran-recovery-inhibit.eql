// Dragnet [Ransomware]: dragnet-ransomware-2024-3283 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: d3580b42-5cfb-5255-8a03-ecda94e123f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
