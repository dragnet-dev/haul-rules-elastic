// Dragnet [Ransomware]: dragnet-ransomware-2024-4511 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 2bcd7afb-c835-59fb-8e0a-a6d286a42017

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
