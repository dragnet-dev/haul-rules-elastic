// Dragnet [Ransomware]: dragnet-ransomware-2024-2882 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 8c08afa4-3562-5750-8718-da28faeb09df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
