// Dragnet [Ransomware]: dragnet-ransomware-2024-3400 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 13f541a8-47a8-5642-afd4-3ca7e7e785a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
