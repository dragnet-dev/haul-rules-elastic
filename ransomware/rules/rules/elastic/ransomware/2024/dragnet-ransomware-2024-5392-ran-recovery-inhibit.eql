// Dragnet [Ransomware]: dragnet-ransomware-2024-5392 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 62db8c7e-7184-58f1-aaa6-90be00e788a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
