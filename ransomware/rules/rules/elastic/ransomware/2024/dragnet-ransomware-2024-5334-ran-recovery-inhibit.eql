// Dragnet [Ransomware]: dragnet-ransomware-2024-5334 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: aa3a38d3-a434-5ae3-a624-dd31e274daf6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
