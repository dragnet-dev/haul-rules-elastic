// Dragnet [Ransomware]: dragnet-ransomware-2024-1212 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 63c8bc32-b7b0-5450-8cc1-c45acafa83c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
