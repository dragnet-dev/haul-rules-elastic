// Dragnet [Ransomware]: dragnet-ransomware-2024-1909 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 5a7e267f-f344-5350-a711-ecce5f606452

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
