// Dragnet [Ransomware]: dragnet-ransomware-2024-1504 — Recovery Inhibition (blackout)
// Status: experimental | Level: high | ID: 278fe066-99d4-5a82-aba9-9b33114db67d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
