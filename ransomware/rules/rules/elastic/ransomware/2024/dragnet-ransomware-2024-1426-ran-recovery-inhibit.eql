// Dragnet [Ransomware]: dragnet-ransomware-2024-1426 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: b1384e4b-6eef-5202-90f2-2c0f87ca176c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
