// Dragnet [Ransomware]: dragnet-ransomware-2024-3170 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: a560be93-2e0c-50b6-83bc-523ece88183a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
