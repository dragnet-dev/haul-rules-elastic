// Dragnet [Ransomware]: dragnet-ransomware-2024-3048 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4c785f29-8617-5646-8648-ea2f4df9d8bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
