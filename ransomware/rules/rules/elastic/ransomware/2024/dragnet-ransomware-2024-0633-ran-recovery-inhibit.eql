// Dragnet [Ransomware]: dragnet-ransomware-2024-0633 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: fd29bfa9-c8e8-581c-8c6f-dc824170b127

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
