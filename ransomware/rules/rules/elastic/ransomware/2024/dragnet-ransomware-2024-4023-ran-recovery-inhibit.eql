// Dragnet [Ransomware]: dragnet-ransomware-2024-4023 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 21ce962c-8779-54b1-b4df-b8645cbae2f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
