// Dragnet [Ransomware]: dragnet-ransomware-2024-4481 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 8ade2c5e-17c5-5c89-b199-db2a73eecb21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
