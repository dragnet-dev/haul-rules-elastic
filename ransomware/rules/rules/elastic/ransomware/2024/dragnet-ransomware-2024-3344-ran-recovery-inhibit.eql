// Dragnet [Ransomware]: dragnet-ransomware-2024-3344 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 2bc48a17-71ed-5351-a742-80afcd34bb63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
