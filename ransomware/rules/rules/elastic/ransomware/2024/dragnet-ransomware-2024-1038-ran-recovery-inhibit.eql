// Dragnet [Ransomware]: dragnet-ransomware-2024-1038 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: a4caddff-eb02-5848-8b69-de9efbc96a93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
