// Dragnet [Ransomware]: dragnet-ransomware-2024-5821 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 3daa54e9-a826-50c0-ad0f-77c9555fd147

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
