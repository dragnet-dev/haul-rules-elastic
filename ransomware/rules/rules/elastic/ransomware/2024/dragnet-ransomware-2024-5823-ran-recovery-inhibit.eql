// Dragnet [Ransomware]: dragnet-ransomware-2024-5823 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 507e5621-faa6-5037-a475-03c0138da096

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
