// Dragnet [Ransomware]: dragnet-ransomware-2024-0315 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ee8d6fe7-7e35-5f34-ba18-7c2cab173828

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
