// Dragnet [Ransomware]: dragnet-ransomware-2024-5867 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 63479d0c-49e3-5eff-8f0f-b9579d885fa6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
