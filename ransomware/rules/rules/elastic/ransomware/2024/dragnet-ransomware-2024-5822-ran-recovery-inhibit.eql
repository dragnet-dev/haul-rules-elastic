// Dragnet [Ransomware]: dragnet-ransomware-2024-5822 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 79037bb5-3f72-5609-8183-1357c622185f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
