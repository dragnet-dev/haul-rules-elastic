// Dragnet [Ransomware]: dragnet-ransomware-2024-3149 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 1dc38083-ade0-550a-85e9-bd6ab0f6d4c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
