// Dragnet [Ransomware]: dragnet-ransomware-2024-0263 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: afd42f32-fffc-5d21-9a83-558f6e560e65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
