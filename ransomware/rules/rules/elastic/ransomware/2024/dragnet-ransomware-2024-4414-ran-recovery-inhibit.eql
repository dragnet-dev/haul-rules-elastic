// Dragnet [Ransomware]: dragnet-ransomware-2024-4414 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 1b5ddf6e-3327-55ff-8394-3641d0df4e00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
