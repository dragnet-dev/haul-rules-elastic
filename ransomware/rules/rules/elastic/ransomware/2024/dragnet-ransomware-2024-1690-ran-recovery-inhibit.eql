// Dragnet [Ransomware]: dragnet-ransomware-2024-1690 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fb7f128c-0a3e-555c-9e7d-4ea28cd07154

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
