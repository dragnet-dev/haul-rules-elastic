// Dragnet [Ransomware]: dragnet-ransomware-2024-1596 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: fc0e6230-b37a-5b28-a867-db0d9285b79a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
