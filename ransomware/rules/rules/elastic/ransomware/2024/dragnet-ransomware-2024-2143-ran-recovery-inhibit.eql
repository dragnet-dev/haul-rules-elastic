// Dragnet [Ransomware]: dragnet-ransomware-2024-2143 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 91efb07e-3eb2-5b9d-a22e-f72361d615f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
