// Dragnet [Ransomware]: dragnet-ransomware-2024-5680 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 5a14999c-e8c1-5507-afd9-e4cffac7d3ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
