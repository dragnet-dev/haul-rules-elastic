// Dragnet [Ransomware]: dragnet-ransomware-2024-3557 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 18ce4181-0db3-5863-ac46-0524aa5ede58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
