// Dragnet [Ransomware]: dragnet-ransomware-2024-1307 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: b3bff3e6-eac7-50d2-951b-98c76ae726ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
