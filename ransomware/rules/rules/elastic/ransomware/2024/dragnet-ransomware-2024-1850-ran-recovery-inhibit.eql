// Dragnet [Ransomware]: dragnet-ransomware-2024-1850 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f2c2dbf7-8a5c-518e-af4d-b184836b7cbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
