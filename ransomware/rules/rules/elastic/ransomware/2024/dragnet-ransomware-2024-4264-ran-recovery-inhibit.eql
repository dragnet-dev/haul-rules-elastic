// Dragnet [Ransomware]: dragnet-ransomware-2024-4264 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: f8063af9-eed1-5a0f-8ef8-10267d0bfcfa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
