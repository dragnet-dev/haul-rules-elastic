// Dragnet [Ransomware]: dragnet-ransomware-2024-1745 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 8e19bfc9-fb46-5a62-8f49-f827ff74a8a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
