// Dragnet [Ransomware]: dragnet-ransomware-2024-3493 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 8e5527f3-00bd-551f-a52f-a64ef8b50a0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
