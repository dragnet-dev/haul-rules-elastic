// Dragnet [Ransomware]: dragnet-ransomware-2024-4019 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 9f34ec2b-e1de-5e47-af76-e993381bd1bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
