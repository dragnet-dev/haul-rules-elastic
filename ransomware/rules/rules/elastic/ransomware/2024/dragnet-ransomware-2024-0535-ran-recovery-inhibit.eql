// Dragnet [Ransomware]: dragnet-ransomware-2024-0535 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7cab03c9-8e7c-5c2a-91b0-c41848731dee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
