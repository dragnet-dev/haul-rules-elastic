// Dragnet [Ransomware]: dragnet-ransomware-2024-1019 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 74d0e927-e854-5c58-be5d-4d1c91570536

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
