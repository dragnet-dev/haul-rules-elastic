// Dragnet [Ransomware]: dragnet-ransomware-2024-1428 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 041b4578-256e-5da0-b9ec-357cc1b2071c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
