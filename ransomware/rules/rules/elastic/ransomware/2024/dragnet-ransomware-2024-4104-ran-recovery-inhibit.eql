// Dragnet [Ransomware]: dragnet-ransomware-2024-4104 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d0440f6e-3da6-5c9f-a7d2-956cae267955

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
