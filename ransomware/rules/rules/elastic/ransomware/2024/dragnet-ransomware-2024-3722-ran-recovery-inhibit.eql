// Dragnet [Ransomware]: dragnet-ransomware-2024-3722 — Recovery Inhibition (madliberator)
// Status: experimental | Level: high | ID: a54451ed-63d4-53fe-ae3e-3feabd5c0ce8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
