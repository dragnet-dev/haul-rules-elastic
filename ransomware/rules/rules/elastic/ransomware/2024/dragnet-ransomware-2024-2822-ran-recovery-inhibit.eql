// Dragnet [Ransomware]: dragnet-ransomware-2024-2822 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 979da6ea-ea67-5bb6-92cc-cb3932103aa0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
