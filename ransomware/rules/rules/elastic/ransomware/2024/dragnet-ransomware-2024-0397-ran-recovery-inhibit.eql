// Dragnet [Ransomware]: dragnet-ransomware-2024-0397 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 2d7c089b-221b-587e-a355-d11bb7cb678f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
