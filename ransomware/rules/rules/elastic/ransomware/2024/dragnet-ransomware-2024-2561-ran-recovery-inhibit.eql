// Dragnet [Ransomware]: dragnet-ransomware-2024-2561 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 211a6530-da7c-556c-b6b3-0ff4a98d69a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
