// Dragnet [Ransomware]: dragnet-ransomware-2024-5760 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8b478757-4954-50a3-b4ec-b1ae3a2f3507

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
