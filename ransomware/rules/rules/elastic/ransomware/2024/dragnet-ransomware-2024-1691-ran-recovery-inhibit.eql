// Dragnet [Ransomware]: dragnet-ransomware-2024-1691 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 29c54aac-9ede-5ae1-a872-485934bba7a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
