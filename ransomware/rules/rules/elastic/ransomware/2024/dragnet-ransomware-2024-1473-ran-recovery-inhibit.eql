// Dragnet [Ransomware]: dragnet-ransomware-2024-1473 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d3329631-0c6c-53d8-927a-2879e78d6bc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
