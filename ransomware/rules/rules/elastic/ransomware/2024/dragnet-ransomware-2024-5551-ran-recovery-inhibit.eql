// Dragnet [Ransomware]: dragnet-ransomware-2024-5551 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4a1a3175-c362-569f-b829-092d36974639

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
