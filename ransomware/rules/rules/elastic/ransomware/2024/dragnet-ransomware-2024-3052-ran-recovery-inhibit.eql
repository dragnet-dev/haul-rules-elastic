// Dragnet [Ransomware]: dragnet-ransomware-2024-3052 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 8a9d634a-6d9b-5898-8ebc-20bf593186c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
