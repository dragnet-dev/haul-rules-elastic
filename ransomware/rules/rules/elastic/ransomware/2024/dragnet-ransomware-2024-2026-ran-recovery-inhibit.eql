// Dragnet [Ransomware]: dragnet-ransomware-2024-2026 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: dcbffb46-9db7-523d-b815-327c95d222af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
