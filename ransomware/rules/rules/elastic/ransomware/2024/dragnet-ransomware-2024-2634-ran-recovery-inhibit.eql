// Dragnet [Ransomware]: dragnet-ransomware-2024-2634 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 1a1a2ca8-c522-5803-87e0-102d4058b18b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
