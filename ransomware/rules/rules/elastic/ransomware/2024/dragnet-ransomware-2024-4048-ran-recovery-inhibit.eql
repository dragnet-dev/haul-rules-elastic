// Dragnet [Ransomware]: dragnet-ransomware-2024-4048 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 291c033d-3a9e-57f3-b66a-3e9e0ccc4067

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
