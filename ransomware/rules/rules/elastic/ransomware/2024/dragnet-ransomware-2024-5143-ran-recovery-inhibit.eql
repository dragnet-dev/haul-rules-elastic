// Dragnet [Ransomware]: dragnet-ransomware-2024-5143 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 2516ce13-761b-57d9-b8e6-f7c2a63293dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
