// Dragnet [Ransomware]: dragnet-ransomware-2024-3101 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 853456ee-017b-5232-aa5c-af4e70ba8a81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
