// Dragnet [Ransomware]: dragnet-ransomware-2024-0306 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8aa6b0bd-919e-5ff9-8ccd-9f5efa938331

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
