// Dragnet [Ransomware]: dragnet-ransomware-2024-5397 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 650ac4d7-eba4-519f-9054-6736f7307b79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
