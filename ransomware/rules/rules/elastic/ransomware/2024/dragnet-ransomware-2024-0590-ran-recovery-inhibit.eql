// Dragnet [Ransomware]: dragnet-ransomware-2024-0590 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: c1ee8257-b63e-58fd-9576-cfe3517fd464

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
