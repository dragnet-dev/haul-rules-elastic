// Dragnet [Ransomware]: dragnet-ransomware-2024-4946 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: c50edff4-6a42-585c-b414-5a3f849d12b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
