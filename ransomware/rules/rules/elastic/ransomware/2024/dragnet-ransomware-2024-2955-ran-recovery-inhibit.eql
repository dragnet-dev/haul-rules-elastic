// Dragnet [Ransomware]: dragnet-ransomware-2024-2955 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: 7017ba24-64d0-5a1f-9787-311de1952d80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
