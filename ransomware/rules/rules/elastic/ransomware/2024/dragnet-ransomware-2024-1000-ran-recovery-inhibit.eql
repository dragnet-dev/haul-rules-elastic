// Dragnet [Ransomware]: dragnet-ransomware-2024-1000 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 46e1ff39-3a7d-5f78-ad90-707d85c57fa8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
