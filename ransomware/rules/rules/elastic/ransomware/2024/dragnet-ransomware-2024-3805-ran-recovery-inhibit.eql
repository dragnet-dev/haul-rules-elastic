// Dragnet [Ransomware]: dragnet-ransomware-2024-3805 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1be01e29-d460-5a18-8d1a-849b994f8612

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
