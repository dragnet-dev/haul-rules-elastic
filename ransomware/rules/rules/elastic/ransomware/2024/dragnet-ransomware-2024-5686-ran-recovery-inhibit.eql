// Dragnet [Ransomware]: dragnet-ransomware-2024-5686 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: fb76adf2-94dc-5501-9f5a-0e12f66f71f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
