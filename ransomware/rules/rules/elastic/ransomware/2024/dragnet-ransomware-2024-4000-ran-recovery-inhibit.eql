// Dragnet [Ransomware]: dragnet-ransomware-2024-4000 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 00f2a17d-8233-58c5-b423-192ec90aad56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
