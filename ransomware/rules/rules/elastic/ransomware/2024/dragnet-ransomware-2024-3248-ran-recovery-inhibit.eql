// Dragnet [Ransomware]: dragnet-ransomware-2024-3248 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 52379312-9418-578b-9322-ad3b4b653344

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
