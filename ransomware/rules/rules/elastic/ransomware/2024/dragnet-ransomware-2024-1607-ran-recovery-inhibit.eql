// Dragnet [Ransomware]: dragnet-ransomware-2024-1607 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: ebb6ba8f-bf02-595b-9c27-55c6e355e83e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
