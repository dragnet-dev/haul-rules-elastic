// Dragnet [Ransomware]: dragnet-ransomware-2024-1205 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 543b7ff0-3aa4-5528-9edb-1bd38ad37aea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
