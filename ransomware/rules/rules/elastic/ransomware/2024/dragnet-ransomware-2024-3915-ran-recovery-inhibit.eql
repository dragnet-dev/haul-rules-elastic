// Dragnet [Ransomware]: dragnet-ransomware-2024-3915 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: dc7fb9fc-d1b5-5c35-855d-02f9eb233948

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
