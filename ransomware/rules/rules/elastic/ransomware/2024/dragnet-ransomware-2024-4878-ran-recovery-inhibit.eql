// Dragnet [Ransomware]: dragnet-ransomware-2024-4878 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4c9f10a3-3e28-5313-ac8d-e1f0bea6f5c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
