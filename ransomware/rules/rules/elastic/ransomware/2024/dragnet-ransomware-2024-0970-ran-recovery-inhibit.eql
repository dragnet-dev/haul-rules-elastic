// Dragnet [Ransomware]: dragnet-ransomware-2024-0970 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 6b49fc89-1fb2-5c81-9e59-ae7cdf4fb768

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
