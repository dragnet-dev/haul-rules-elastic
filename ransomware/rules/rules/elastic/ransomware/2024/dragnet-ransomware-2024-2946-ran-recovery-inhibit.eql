// Dragnet [Ransomware]: dragnet-ransomware-2024-2946 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 10eefbf8-41d7-5ac9-9c21-cfe9128f9074

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
