// Dragnet [Ransomware]: dragnet-ransomware-2024-4189 — Recovery Inhibition (ValenciaLeaks)
// Status: experimental | Level: high | ID: 4f1fb2ca-a5ae-5c04-83f3-9c1ccd333a0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
