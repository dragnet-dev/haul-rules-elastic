// Dragnet [Ransomware]: dragnet-ransomware-2024-1747 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: f21b2fd5-9824-5b50-91db-51063202faa3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
