// Dragnet [Ransomware]: dragnet-ransomware-2024-3934 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 5140ec0d-8345-5cd5-90a0-25391c4f1f3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
