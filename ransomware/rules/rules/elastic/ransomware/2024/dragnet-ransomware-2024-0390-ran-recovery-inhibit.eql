// Dragnet [Ransomware]: dragnet-ransomware-2024-0390 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 263b9aca-f6af-54df-8e82-e1552e69616f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
