// Dragnet [Ransomware]: dragnet-ransomware-2024-2963 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 02437555-2fb9-5d0a-adb0-59501b43138c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
