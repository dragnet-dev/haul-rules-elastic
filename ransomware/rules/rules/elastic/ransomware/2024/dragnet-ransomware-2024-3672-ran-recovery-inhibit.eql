// Dragnet [Ransomware]: dragnet-ransomware-2024-3672 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 45d30c02-3286-583d-9caa-5d838c6c4ad0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
