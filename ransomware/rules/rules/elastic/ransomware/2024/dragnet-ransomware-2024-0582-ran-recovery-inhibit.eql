// Dragnet [Ransomware]: dragnet-ransomware-2024-0582 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 76472877-b367-5dbb-9b82-c15e375eb0ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
