// Dragnet [Ransomware]: dragnet-ransomware-2024-4406 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 29fecb5a-5727-51ba-a7a5-88a08888ea0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
