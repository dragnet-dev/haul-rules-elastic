// Dragnet [Ransomware]: dragnet-ransomware-2024-5101 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: ec2d49b0-5ee4-5f71-a266-86d9b38914d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
