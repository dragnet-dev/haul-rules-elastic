// Dragnet [Ransomware]: dragnet-ransomware-2024-4975 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 6321626d-10a4-5933-a858-194a01a465a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
