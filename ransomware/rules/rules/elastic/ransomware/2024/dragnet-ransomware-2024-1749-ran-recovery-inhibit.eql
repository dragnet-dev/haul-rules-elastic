// Dragnet [Ransomware]: dragnet-ransomware-2024-1749 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 59fc6ebb-bb3b-5255-9970-899e2df4a4bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
