// Dragnet [Ransomware]: dragnet-ransomware-2024-1292 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: aae974bc-f040-5964-b029-c90dd947311a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
