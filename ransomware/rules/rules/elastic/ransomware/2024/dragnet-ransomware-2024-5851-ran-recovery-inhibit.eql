// Dragnet [Ransomware]: dragnet-ransomware-2024-5851 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 51d60bbe-9ae4-5ab4-8bdc-2db0070403da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
