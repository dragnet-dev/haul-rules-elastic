// Dragnet [Ransomware]: dragnet-ransomware-2024-4379 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 15179f56-6813-5a2d-ac6b-a1cd940d7198

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
