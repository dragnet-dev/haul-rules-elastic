// Dragnet [Ransomware]: dragnet-ransomware-2024-1532 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 2ec15ed8-b189-53af-806e-0c2b19623c08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
