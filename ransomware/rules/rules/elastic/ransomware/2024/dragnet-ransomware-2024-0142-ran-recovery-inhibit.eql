// Dragnet [Ransomware]: dragnet-ransomware-2024-0142 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a68f111f-9164-523e-84d8-201ff7525c51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
