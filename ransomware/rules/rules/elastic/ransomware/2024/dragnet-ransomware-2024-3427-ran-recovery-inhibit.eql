// Dragnet [Ransomware]: dragnet-ransomware-2024-3427 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 1cf2218f-bc0d-53ea-a7ff-fbcec044a5f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
