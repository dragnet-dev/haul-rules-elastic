// Dragnet [Ransomware]: dragnet-ransomware-2024-2138 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 73c9c5ee-82e2-5803-a1fc-81b9300e5fa4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
