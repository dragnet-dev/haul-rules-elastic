// Dragnet [Ransomware]: dragnet-ransomware-2024-5172 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: cd729cfd-3c04-5224-968e-5b6c214d8d89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
