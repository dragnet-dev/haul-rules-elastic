// Dragnet [Ransomware]: dragnet-ransomware-2024-0543 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: df8e8789-1d7e-5741-8d87-3dd5247176b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
