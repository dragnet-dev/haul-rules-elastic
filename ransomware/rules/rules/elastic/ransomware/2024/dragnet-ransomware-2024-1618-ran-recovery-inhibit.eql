// Dragnet [Ransomware]: dragnet-ransomware-2024-1618 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 11c541bb-9a21-58de-b724-75a5b4b64c9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
