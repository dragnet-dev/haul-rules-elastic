// Dragnet [Ransomware]: dragnet-ransomware-2024-0252 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3d1b546a-9c74-54dc-9668-3bef9ae20fa8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
