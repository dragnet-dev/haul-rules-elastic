// Dragnet [Ransomware]: dragnet-ransomware-2024-0133 — Recovery Inhibition (cloak)
// Status: experimental | Level: high | ID: a67b22cb-87bb-54c6-9fb7-5a31c54828b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
