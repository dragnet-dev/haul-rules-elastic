// Dragnet [Ransomware]: dragnet-ransomware-2024-0903 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 6bef9eb3-adce-5d2f-be71-d847f258a5d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
