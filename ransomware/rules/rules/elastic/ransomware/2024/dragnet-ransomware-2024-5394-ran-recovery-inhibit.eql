// Dragnet [Ransomware]: dragnet-ransomware-2024-5394 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: d877d89c-9714-542e-8dad-297d765e02ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
