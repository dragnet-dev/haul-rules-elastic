// Dragnet [Ransomware]: dragnet-ransomware-2024-4066 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 205f63b5-b822-502f-91dc-31c669dd4785

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
