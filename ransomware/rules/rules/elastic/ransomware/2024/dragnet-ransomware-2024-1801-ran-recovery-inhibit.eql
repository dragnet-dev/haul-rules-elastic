// Dragnet [Ransomware]: dragnet-ransomware-2024-1801 — Recovery Inhibition (trinity)
// Status: experimental | Level: high | ID: 6af4dc2c-d670-5475-80bd-3291c1fbd4a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
