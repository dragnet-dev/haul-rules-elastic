// Dragnet [Ransomware]: dragnet-ransomware-2024-0149 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: f8b1eeea-cf54-52c2-9ff8-2f1c0db29346

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
