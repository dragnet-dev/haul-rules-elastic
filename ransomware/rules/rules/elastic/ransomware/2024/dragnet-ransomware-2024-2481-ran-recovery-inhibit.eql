// Dragnet [Ransomware]: dragnet-ransomware-2024-2481 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f5afc19b-4766-5e42-a9a8-8652fba608ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
