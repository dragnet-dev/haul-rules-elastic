// Dragnet [Ransomware]: dragnet-ransomware-2024-4483 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d5441b5a-d639-5926-b3c9-32b379610652

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
