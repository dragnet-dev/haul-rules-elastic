// Dragnet [Ransomware]: dragnet-ransomware-2024-3069 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 9654c119-9d3e-586c-bcf1-ddcb747b1096

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
