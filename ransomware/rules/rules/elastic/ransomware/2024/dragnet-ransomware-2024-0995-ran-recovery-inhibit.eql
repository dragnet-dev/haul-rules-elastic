// Dragnet [Ransomware]: dragnet-ransomware-2024-0995 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 8160e094-4f1a-5e1c-93bc-ea53a8b1b957

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
