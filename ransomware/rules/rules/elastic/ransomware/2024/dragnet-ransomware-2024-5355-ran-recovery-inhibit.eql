// Dragnet [Ransomware]: dragnet-ransomware-2024-5355 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: f843e907-4009-51ca-89ec-8aabede0dd98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
