// Dragnet [Ransomware]: dragnet-ransomware-2024-1770 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: a47e2c3c-2172-50c4-9324-13f84ee2798f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
