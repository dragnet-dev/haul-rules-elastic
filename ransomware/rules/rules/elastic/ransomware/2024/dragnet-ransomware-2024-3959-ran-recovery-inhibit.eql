// Dragnet [Ransomware]: dragnet-ransomware-2024-3959 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: fd8d0b09-9ffc-5177-b0c6-f0f95e1251f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
