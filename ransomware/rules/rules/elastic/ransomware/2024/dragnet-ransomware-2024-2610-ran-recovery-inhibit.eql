// Dragnet [Ransomware]: dragnet-ransomware-2024-2610 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: e7f9ec83-28d4-5e68-a1c9-071d57681957

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
