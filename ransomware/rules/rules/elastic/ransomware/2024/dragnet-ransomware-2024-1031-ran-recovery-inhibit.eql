// Dragnet [Ransomware]: dragnet-ransomware-2024-1031 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: e0b4720b-ce4c-5989-82d4-9dc90e7ca68e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
