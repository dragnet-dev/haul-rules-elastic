// Dragnet [Ransomware]: dragnet-ransomware-2024-0090 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 930c66cb-8b6f-5633-8353-fd10afae1bca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
