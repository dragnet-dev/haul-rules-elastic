// Dragnet [Ransomware]: dragnet-ransomware-2024-5904 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9cd1ad44-f002-5cbf-be57-fc0d53596f0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
