// Dragnet [Ransomware]: dragnet-ransomware-2024-4071 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 373e032d-783a-5d51-b449-ba3a2a733563

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
