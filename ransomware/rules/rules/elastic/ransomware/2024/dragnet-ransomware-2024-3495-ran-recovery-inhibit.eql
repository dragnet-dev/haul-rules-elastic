// Dragnet [Ransomware]: dragnet-ransomware-2024-3495 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: d1c35b78-78fd-53fa-8d6a-3e0111232103

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
