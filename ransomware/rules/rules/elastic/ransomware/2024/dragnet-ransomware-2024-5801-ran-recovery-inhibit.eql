// Dragnet [Ransomware]: dragnet-ransomware-2024-5801 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 96cf44bd-763f-58a8-a787-865fc9f85c67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
