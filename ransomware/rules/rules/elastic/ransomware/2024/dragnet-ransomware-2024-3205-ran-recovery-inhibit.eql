// Dragnet [Ransomware]: dragnet-ransomware-2024-3205 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 15d25443-7eda-5aee-a746-ee78f55d51c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
