// Dragnet [Ransomware]: dragnet-ransomware-2024-1722 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8f2984a8-fbb8-5cff-a98f-285614b1f764

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
