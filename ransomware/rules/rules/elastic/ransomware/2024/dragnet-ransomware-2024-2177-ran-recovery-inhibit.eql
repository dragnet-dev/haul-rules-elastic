// Dragnet [Ransomware]: dragnet-ransomware-2024-2177 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 10b9bfeb-5aac-526a-870f-05161f42e5ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
