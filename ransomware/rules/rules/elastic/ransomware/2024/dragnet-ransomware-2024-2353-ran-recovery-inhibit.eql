// Dragnet [Ransomware]: dragnet-ransomware-2024-2353 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 1a55d65e-74cb-56e5-a05c-93558cb3dc0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
