// Dragnet [Ransomware]: dragnet-ransomware-2024-4203 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 544c5173-6992-5148-971d-42d308b34b24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
