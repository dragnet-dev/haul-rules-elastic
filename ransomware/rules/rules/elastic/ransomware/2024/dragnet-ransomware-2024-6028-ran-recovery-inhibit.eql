// Dragnet [Ransomware]: dragnet-ransomware-2024-6028 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: 60a3c748-c84d-5e78-8771-47015b167b50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
