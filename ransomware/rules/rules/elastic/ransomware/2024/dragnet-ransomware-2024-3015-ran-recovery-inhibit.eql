// Dragnet [Ransomware]: dragnet-ransomware-2024-3015 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0f9cb9aa-70ef-5522-bd4a-b640abcd83e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
