// Dragnet [Ransomware]: dragnet-ransomware-2024-2252 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: dacbfa2e-47f6-5bd7-b3aa-e53e916d7fce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
