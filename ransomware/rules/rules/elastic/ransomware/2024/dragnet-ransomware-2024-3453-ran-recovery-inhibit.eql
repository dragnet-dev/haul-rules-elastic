// Dragnet [Ransomware]: dragnet-ransomware-2024-3453 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: b75d659b-c5f1-5e6f-aedb-e6af57032215

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
