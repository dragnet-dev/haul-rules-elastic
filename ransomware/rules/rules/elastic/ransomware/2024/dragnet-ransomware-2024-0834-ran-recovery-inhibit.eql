// Dragnet [Ransomware]: dragnet-ransomware-2024-0834 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: e37b4874-66e7-57c5-bc94-21b169925653

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
