// Dragnet [Ransomware]: dragnet-ransomware-2024-2694 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 7b58f867-94fa-5a96-9a6d-f7cf8bb14fbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
