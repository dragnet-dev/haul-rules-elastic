// Dragnet [Ransomware]: dragnet-ransomware-2024-5538 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 709e8a87-d022-5b79-94ea-3cc7e7961295

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
