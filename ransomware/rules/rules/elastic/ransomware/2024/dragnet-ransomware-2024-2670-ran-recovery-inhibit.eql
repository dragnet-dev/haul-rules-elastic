// Dragnet [Ransomware]: dragnet-ransomware-2024-2670 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: efc7361c-cafd-5aee-be0d-0ce54ddd9101

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
