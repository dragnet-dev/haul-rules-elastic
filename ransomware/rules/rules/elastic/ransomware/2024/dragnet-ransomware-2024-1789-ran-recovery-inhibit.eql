// Dragnet [Ransomware]: dragnet-ransomware-2024-1789 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: ca655fea-ab39-5306-a106-432bbdcb70e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
