// Dragnet [Ransomware]: dragnet-ransomware-2024-0445 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 6f9fa13a-a01c-51f4-b32c-413118f3977f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
