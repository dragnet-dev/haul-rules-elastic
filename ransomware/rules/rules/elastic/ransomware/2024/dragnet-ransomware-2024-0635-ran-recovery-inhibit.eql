// Dragnet [Ransomware]: dragnet-ransomware-2024-0635 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 50ca46bd-9b51-58ef-8f90-175120d3e3a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
