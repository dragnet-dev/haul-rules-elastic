// Dragnet [Ransomware]: dragnet-ransomware-2024-1094 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: 32f13f9b-79e7-5a30-a9d5-ee63ebd55b4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
