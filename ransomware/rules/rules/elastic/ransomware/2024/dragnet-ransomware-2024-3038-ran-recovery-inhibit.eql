// Dragnet [Ransomware]: dragnet-ransomware-2024-3038 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 6b91a750-7c0a-5cf6-9014-6ee8b26a9a00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
