// Dragnet [Ransomware]: dragnet-ransomware-2024-1250 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d4031d57-a451-5dbc-b072-5154d60875cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
