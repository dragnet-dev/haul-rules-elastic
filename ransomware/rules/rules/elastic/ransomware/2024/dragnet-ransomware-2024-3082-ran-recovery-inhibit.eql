// Dragnet [Ransomware]: dragnet-ransomware-2024-3082 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5da3b9cb-4a9f-5d6d-89cc-2993e0ce6343

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
