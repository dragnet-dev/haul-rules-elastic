// Dragnet [Ransomware]: dragnet-ransomware-2024-2996 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: cef7abe5-bf16-5d5d-aed6-a5fd36a3448a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
