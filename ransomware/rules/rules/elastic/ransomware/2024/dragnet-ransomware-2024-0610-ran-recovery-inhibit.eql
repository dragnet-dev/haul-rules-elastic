// Dragnet [Ransomware]: dragnet-ransomware-2024-0610 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: e40a6ff5-a779-5d4c-b079-9efad120c888

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
