// Dragnet [Ransomware]: dragnet-ransomware-2024-4387 — Recovery Inhibition (ransomcortex)
// Status: experimental | Level: high | ID: 20349f00-6450-5a8c-96f7-81ad4f2ced43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
