// Dragnet [Ransomware]: dragnet-ransomware-2024-5104 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1e674458-4b62-5065-8352-12141ba1d158

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
