// Dragnet [Ransomware]: dragnet-ransomware-2024-3932 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 288120ea-4a07-5a1e-8f08-e1f63c7568e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
