// Dragnet [Ransomware]: dragnet-ransomware-2024-0289 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 9525b741-4660-5db4-a7f4-50d39b4888b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
