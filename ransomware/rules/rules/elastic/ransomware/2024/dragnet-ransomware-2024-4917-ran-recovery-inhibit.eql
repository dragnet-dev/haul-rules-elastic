// Dragnet [Ransomware]: dragnet-ransomware-2024-4917 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 0d1cb957-e24a-5ce8-b907-860467e87489

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
