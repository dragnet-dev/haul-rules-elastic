// Dragnet [Ransomware]: dragnet-ransomware-2024-4672 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3bfe3edc-e853-56b9-b7ab-66e8149c9883

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
