// Dragnet [Ransomware]: dragnet-ransomware-2024-0799 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 06adeabc-d58b-5d19-b840-4fbf1ebbdf3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
