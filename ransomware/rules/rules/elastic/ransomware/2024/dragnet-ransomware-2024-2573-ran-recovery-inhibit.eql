// Dragnet [Ransomware]: dragnet-ransomware-2024-2573 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: f456f874-c779-57ad-92fd-1f8dd3889ccd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
