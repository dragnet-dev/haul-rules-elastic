// Dragnet [Ransomware]: dragnet-ransomware-2024-5049 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: ecf0207e-e315-5469-ae34-81aa5a88799c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
