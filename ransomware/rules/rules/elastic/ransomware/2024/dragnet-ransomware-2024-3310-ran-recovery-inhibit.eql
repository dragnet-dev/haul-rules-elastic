// Dragnet [Ransomware]: dragnet-ransomware-2024-3310 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: feaa85c5-6d8c-5b7b-a40a-38387cbae887

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
