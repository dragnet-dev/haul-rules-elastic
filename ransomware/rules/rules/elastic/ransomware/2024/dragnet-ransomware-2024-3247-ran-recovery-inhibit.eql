// Dragnet [Ransomware]: dragnet-ransomware-2024-3247 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ffe84608-bcc6-562b-a18b-21599d523f37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
