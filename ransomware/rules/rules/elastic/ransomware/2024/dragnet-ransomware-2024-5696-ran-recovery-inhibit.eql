// Dragnet [Ransomware]: dragnet-ransomware-2024-5696 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 20550410-9a6c-5947-8d77-5b4e426f01a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
