// Dragnet [Ransomware]: dragnet-ransomware-2024-3836 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f040e0e4-4650-5e1c-a217-933821bf7474

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
