// Dragnet [Ransomware]: dragnet-ransomware-2024-5253 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 3006954c-2696-5de5-b03b-3909ae4b8855

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
