// Dragnet [Ransomware]: dragnet-ransomware-2024-2624 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 514669db-945b-5b71-aa78-77d7c236ed80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
