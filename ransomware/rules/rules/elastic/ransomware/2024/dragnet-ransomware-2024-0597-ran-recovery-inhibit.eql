// Dragnet [Ransomware]: dragnet-ransomware-2024-0597 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 6ef55cd2-5b20-5b11-9f8b-f2f91a8f32a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
