// Dragnet [Ransomware]: dragnet-ransomware-2024-3762 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 512dd746-0e93-5648-9f8a-538331fa2dc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
