// Dragnet [Ransomware]: dragnet-ransomware-2024-2687 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 66e32805-015d-555e-bdc3-35d2874b0698

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
