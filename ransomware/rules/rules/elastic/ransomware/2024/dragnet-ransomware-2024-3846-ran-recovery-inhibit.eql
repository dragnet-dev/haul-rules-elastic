// Dragnet [Ransomware]: dragnet-ransomware-2024-3846 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: f43bb46f-9172-5518-8adb-847dd355144e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
