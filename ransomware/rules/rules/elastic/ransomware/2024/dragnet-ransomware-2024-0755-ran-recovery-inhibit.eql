// Dragnet [Ransomware]: dragnet-ransomware-2024-0755 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: a3eeb46b-136e-5942-8581-4ef02f31bc2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
