// Dragnet [Ransomware]: dragnet-ransomware-2024-4207 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 9d42242b-9b19-51ed-bd6c-54dd4fe57c8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
