// Dragnet [Ransomware]: dragnet-ransomware-2024-0178 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c4b37eea-151b-5e66-9b1f-8d2f148893d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
