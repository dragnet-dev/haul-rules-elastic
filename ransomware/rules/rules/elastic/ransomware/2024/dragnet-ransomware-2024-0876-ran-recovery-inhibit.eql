// Dragnet [Ransomware]: dragnet-ransomware-2024-0876 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: d0dda17c-4452-54c4-94cd-7cc9c4c962f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
