// Dragnet [Ransomware]: dragnet-ransomware-2024-3948 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: e07f7ebb-0fe5-5833-994d-c85c02caf2a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
