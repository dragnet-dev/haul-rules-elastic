// Dragnet [Ransomware]: dragnet-ransomware-2024-0030 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 8f439421-cf51-5255-a439-97b73502a579

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
