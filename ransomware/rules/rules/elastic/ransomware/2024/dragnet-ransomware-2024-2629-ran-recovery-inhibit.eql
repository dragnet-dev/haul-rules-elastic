// Dragnet [Ransomware]: dragnet-ransomware-2024-2629 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: de477e96-f887-5d07-ac1b-a106a1dcf67e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
