// Dragnet [Ransomware]: dragnet-ransomware-2024-3569 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b84dbc6a-ccfa-5299-b588-0add306fa2c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
