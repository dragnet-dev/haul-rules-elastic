// Dragnet [Ransomware]: dragnet-ransomware-2024-1485 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 38da295f-b41e-513b-ba57-90808a2fc064

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
