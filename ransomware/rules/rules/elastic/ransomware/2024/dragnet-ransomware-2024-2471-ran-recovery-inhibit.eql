// Dragnet [Ransomware]: dragnet-ransomware-2024-2471 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 57c2717c-8197-5792-8078-077cb72d245c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
