// Dragnet [Ransomware]: dragnet-ransomware-2024-5353 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 8919ac42-be64-5152-88c6-3a7cca975d73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
