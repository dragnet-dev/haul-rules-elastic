// Dragnet [Ransomware]: dragnet-ransomware-2024-1516 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 9594b4fc-f1d8-5a38-a090-438b98845c6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
