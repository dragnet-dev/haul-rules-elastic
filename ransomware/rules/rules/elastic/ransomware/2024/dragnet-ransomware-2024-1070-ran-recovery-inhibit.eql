// Dragnet [Ransomware]: dragnet-ransomware-2024-1070 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 336f75cf-acc4-59ac-bdb2-30ada6b4f510

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
