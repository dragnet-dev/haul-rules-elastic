// Dragnet [Ransomware]: dragnet-ransomware-2024-4680 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: e8ef5666-65c1-5112-ac8b-0bec6d8d40ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
