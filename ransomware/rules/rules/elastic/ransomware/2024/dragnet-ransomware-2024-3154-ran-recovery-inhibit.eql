// Dragnet [Ransomware]: dragnet-ransomware-2024-3154 — Recovery Inhibition (trinity)
// Status: experimental | Level: high | ID: 75980811-04cd-5f22-bd67-0807d0427029

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
