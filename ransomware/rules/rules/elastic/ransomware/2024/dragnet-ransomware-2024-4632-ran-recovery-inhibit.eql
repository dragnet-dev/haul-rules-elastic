// Dragnet [Ransomware]: dragnet-ransomware-2024-4632 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 5b09aaec-d853-5ce9-9e16-07a0fb14106e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
