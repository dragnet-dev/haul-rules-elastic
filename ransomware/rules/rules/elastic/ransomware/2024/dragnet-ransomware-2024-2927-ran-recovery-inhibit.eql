// Dragnet [Ransomware]: dragnet-ransomware-2024-2927 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 0d1d8a2e-dd00-5f05-abfe-cc205fe1dc6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
