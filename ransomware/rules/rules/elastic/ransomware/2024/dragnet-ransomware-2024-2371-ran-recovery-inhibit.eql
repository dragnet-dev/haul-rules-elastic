// Dragnet [Ransomware]: dragnet-ransomware-2024-2371 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 2decaf9c-accf-572d-ade3-989305a9bbe6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
