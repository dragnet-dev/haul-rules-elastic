// Dragnet [Ransomware]: dragnet-ransomware-2024-4545 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: a02fb4b7-f195-550c-bf02-5d74828db944

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
