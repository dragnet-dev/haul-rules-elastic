// Dragnet [Ransomware]: dragnet-ransomware-2024-0801 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: e802a119-318e-5f9b-8986-82084982202c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
