// Dragnet [Ransomware]: dragnet-ransomware-2024-0317 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e696f28d-debe-57a1-b449-204ddd80d8e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
