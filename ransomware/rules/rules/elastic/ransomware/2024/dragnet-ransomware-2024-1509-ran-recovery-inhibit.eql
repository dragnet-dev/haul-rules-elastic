// Dragnet [Ransomware]: dragnet-ransomware-2024-1509 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: 9fc912bf-f566-5760-807a-5c466c9d0548

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
