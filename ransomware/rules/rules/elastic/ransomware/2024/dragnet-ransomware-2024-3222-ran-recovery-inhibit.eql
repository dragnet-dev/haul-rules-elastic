// Dragnet [Ransomware]: dragnet-ransomware-2024-3222 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c7ea324b-cf93-5eae-9dd7-e5404f4801e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
