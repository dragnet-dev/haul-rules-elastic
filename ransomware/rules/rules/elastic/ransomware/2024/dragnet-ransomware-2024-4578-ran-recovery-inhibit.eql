// Dragnet [Ransomware]: dragnet-ransomware-2024-4578 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c2f5345b-79f4-5bc3-a662-c2df55b59ae1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
