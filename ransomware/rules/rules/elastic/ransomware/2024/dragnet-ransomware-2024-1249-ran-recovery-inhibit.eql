// Dragnet [Ransomware]: dragnet-ransomware-2024-1249 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 00985651-8695-5d52-896c-b9df8263a129

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
