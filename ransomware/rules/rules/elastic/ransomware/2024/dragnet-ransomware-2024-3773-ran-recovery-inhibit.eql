// Dragnet [Ransomware]: dragnet-ransomware-2024-3773 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: b8429b38-af6a-593e-8ac7-d2f481e796b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
