// Dragnet [Ransomware]: dragnet-ransomware-2024-3622 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1f7dae63-b555-543e-b5e1-cb83c36e7376

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
