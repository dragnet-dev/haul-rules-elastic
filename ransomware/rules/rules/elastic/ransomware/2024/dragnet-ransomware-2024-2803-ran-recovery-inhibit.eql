// Dragnet [Ransomware]: dragnet-ransomware-2024-2803 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6a17ce82-d230-5111-823b-2e75c0812efe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
