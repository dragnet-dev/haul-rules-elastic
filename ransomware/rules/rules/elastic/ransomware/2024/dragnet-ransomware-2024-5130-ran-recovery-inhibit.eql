// Dragnet [Ransomware]: dragnet-ransomware-2024-5130 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 0312dbb9-48a3-5c16-8963-abb9885b0230

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
