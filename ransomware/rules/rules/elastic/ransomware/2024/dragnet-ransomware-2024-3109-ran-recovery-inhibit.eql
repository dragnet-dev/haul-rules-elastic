// Dragnet [Ransomware]: dragnet-ransomware-2024-3109 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: a08c0f43-240a-56e5-8a19-df6b48f5da8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
