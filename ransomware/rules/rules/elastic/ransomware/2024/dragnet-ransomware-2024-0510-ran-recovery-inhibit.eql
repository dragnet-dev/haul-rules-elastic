// Dragnet [Ransomware]: dragnet-ransomware-2024-0510 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 7907a342-f782-54ff-8ef2-f6b1df75042f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
