// Dragnet [Ransomware]: dragnet-ransomware-2024-2842 — Recovery Inhibition (mallox)
// Status: experimental | Level: high | ID: f7cbb0cb-e971-590b-b3f6-252a98d651cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
