// Dragnet [Ransomware]: dragnet-ransomware-2024-3625 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: fd0c658e-abdc-59ac-b9bc-8e09ead725cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
