// Dragnet [Ransomware]: dragnet-ransomware-2024-1255 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: fe772c79-1e1f-5f94-bd07-daab64234555

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
