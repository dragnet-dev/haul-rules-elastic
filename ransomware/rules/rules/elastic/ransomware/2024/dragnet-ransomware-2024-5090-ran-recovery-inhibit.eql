// Dragnet [Ransomware]: dragnet-ransomware-2024-5090 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: bca4b1ce-2dc4-5da8-9785-ae1bbb5b053b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
