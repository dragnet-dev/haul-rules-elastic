// Dragnet [Ransomware]: dragnet-ransomware-2024-4957 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 334616d0-335e-575f-80dc-aab39f941aa1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
