// Dragnet [Ransomware]: dragnet-ransomware-2024-4787 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: cc2d1e9a-32a5-5a95-889e-160786ad9eff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
