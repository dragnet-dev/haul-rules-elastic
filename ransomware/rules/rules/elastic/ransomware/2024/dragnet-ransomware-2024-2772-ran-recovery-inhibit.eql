// Dragnet [Ransomware]: dragnet-ransomware-2024-2772 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 90a2a434-3f59-5e93-b23b-f7b64ed313e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
