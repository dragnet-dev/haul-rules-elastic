// Dragnet [Ransomware]: dragnet-ransomware-2024-4448 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: fed5a71c-ac1f-5696-89bc-e8b65dfa6413

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
