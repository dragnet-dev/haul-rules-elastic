// Dragnet [Ransomware]: dragnet-ransomware-2024-0676 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 4f80043f-6cc7-5c2b-a807-39d418ffd47f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
