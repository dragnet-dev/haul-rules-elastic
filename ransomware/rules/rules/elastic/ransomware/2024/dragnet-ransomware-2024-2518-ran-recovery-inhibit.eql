// Dragnet [Ransomware]: dragnet-ransomware-2024-2518 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 33598653-671b-538d-a535-fb3494ba944a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
