// Dragnet [Ransomware]: dragnet-ransomware-2024-5809 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 8706b998-4da6-57c6-a42a-e6c296cfc1ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
