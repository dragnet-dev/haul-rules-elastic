// Dragnet [Ransomware]: dragnet-ransomware-2024-0434 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 6d84edff-c2bc-5050-880c-857cf6ba086d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
