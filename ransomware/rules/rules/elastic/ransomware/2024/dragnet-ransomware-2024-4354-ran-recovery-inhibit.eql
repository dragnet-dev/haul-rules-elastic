// Dragnet [Ransomware]: dragnet-ransomware-2024-4354 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: 7c342800-ff8d-5f0e-bb7b-51002d95e119

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
