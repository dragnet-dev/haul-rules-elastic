// Dragnet [Ransomware]: dragnet-ransomware-2024-5297 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 02d8ea17-89b7-5144-bc25-ae4f2990aef9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
