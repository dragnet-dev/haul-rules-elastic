// Dragnet [Ransomware]: dragnet-ransomware-2024-0921 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 23097990-9d88-50e2-a054-2e27958308a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
