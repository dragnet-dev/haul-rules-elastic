// Dragnet [Ransomware]: dragnet-ransomware-2024-0136 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: dc50cdfb-c98d-55ff-9a6f-396846caa85b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
