// Dragnet [Ransomware]: dragnet-ransomware-2024-5705 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 0a04343e-aebe-5fbf-837a-2178cfacf1d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
