// Dragnet [Ransomware]: dragnet-ransomware-2024-1303 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 2291e12d-46a4-5763-b223-25956b5951c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
