// Dragnet [Ransomware]: dragnet-ransomware-2024-4394 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: fb3fe346-11e3-56cc-82b4-f598e63daf35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
