// Dragnet [Ransomware]: dragnet-ransomware-2024-5303 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 4497dc61-a2f6-5b30-8b24-193936f15296

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
