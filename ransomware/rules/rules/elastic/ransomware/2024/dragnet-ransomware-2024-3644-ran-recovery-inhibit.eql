// Dragnet [Ransomware]: dragnet-ransomware-2024-3644 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: ae6a3560-f595-5f4a-9d50-4fad70c55226

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
