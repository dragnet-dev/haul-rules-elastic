// Dragnet [Ransomware]: dragnet-ransomware-2024-2051 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 77eadf08-8562-532f-90d8-ab150b05b400

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
