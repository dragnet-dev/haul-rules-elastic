// Dragnet [Ransomware]: dragnet-ransomware-2024-3598 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: c105345b-ae10-5b77-b350-3e673f86faac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
