// Dragnet [Ransomware]: dragnet-ransomware-2024-5131 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8e4039ee-1ba2-5166-a940-96b5362f6c6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
