// Dragnet [Ransomware]: dragnet-ransomware-2024-1362 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 15851527-825c-5c70-bf9f-5d488e3d0574

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
