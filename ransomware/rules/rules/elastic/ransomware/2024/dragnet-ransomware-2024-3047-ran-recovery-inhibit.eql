// Dragnet [Ransomware]: dragnet-ransomware-2024-3047 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 418a3f91-75c8-5393-95d1-dfa370544c2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
