// Dragnet [Ransomware]: dragnet-ransomware-2024-3551 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 6406d777-bea9-5fda-b34f-e9a08dc395d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
