// Dragnet [Ransomware]: dragnet-ransomware-2024-2032 — Recovery Inhibition (hellcat)
// Status: deprecated | Level: high | ID: 49d3fb4a-5959-57f4-91fe-e1dc541cae99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
