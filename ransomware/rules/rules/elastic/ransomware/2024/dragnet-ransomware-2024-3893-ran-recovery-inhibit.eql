// Dragnet [Ransomware]: dragnet-ransomware-2024-3893 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d50ec636-c295-51da-bc11-e247d1fdf941

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
