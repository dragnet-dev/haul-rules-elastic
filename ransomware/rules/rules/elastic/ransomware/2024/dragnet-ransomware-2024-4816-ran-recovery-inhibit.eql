// Dragnet [Ransomware]: dragnet-ransomware-2024-4816 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8fccff9b-7c01-5217-bd26-803ffb0094d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
