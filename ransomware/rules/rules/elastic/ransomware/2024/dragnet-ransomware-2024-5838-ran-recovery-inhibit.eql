// Dragnet [Ransomware]: dragnet-ransomware-2024-5838 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 522687d8-c956-5478-8ba5-c894cfe5f005

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
