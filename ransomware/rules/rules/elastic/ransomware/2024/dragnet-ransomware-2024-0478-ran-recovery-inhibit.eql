// Dragnet [Ransomware]: dragnet-ransomware-2024-0478 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: ac47499f-1d4f-51c2-85d2-35ff2c660213

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
