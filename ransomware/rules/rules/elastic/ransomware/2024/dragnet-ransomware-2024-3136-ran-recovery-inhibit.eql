// Dragnet [Ransomware]: dragnet-ransomware-2024-3136 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8b08a194-a50d-5762-85b1-ed6513b6a504

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
