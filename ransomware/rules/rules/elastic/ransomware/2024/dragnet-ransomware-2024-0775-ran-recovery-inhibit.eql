// Dragnet [Ransomware]: dragnet-ransomware-2024-0775 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: c95ac9a0-00fc-55f3-8663-4ddc0e664731

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
