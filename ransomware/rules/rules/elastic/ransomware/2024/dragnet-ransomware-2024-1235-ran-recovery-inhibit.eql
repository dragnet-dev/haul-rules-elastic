// Dragnet [Ransomware]: dragnet-ransomware-2024-1235 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 9efb66f9-676b-568d-91d8-8ff20549fbae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
