// Dragnet [Ransomware]: dragnet-ransomware-2024-2780 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 066ea10e-8c5e-5c37-b055-6c7de9abecc9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
