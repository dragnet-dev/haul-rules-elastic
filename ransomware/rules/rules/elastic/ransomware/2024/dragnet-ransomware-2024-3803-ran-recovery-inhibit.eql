// Dragnet [Ransomware]: dragnet-ransomware-2024-3803 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 85746c44-efd7-5af7-90c2-271e8251b7e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
