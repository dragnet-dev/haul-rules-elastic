// Dragnet [Ransomware]: dragnet-ransomware-2024-1351 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: 68ed396c-df34-57d0-903e-e3167a471bd0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
