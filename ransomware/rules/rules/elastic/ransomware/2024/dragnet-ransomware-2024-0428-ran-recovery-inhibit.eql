// Dragnet [Ransomware]: dragnet-ransomware-2024-0428 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 1d8c94f1-5f06-5006-a1cb-62b571c8a632

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
