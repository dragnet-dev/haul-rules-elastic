// Dragnet [Ransomware]: dragnet-ransomware-2024-0218 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 14c19689-15a5-5e89-bdaa-a8802145c825

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
