// Dragnet [Ransomware]: dragnet-ransomware-2024-1276 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: abaf338d-24d4-50c4-a2b4-903dfddfbd6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
