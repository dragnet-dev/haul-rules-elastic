// Dragnet [Ransomware]: dragnet-ransomware-2024-3290 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5f668c67-dff4-5575-9d5c-ff4319f89fa1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
