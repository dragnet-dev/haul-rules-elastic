// Dragnet [Ransomware]: dragnet-ransomware-2024-5232 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 59024ceb-08c8-5385-a5b0-695d6b0b3aab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
