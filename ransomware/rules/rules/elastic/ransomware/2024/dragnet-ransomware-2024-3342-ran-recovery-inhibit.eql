// Dragnet [Ransomware]: dragnet-ransomware-2024-3342 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: 88a9e513-fab8-572b-b409-89c086166077

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
