// Dragnet [Ransomware]: dragnet-ransomware-2024-4770 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 19bec73f-55d9-52c6-84ff-6aff3abda49d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
