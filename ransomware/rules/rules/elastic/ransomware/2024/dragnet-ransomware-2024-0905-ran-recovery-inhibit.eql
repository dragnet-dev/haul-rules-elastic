// Dragnet [Ransomware]: dragnet-ransomware-2024-0905 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: dc985361-a4c6-5225-b02a-5f94391134cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
