// Dragnet [Ransomware]: dragnet-ransomware-2024-4745 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 764f779b-6118-56c9-81cb-1ca3a493ce5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
