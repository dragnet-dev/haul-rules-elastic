// Dragnet [Ransomware]: dragnet-ransomware-2024-2762 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c1958294-0b17-5fd0-8c7e-520e9eb1068e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
