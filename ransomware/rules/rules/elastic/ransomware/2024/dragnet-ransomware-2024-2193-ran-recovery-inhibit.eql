// Dragnet [Ransomware]: dragnet-ransomware-2024-2193 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7c073ba3-6ccc-5c24-8540-b4ce849245f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
