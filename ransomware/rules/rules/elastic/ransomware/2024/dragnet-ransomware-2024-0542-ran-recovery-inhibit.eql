// Dragnet [Ransomware]: dragnet-ransomware-2024-0542 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 7517c19d-0465-58d4-8d79-a82f04fb423f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
