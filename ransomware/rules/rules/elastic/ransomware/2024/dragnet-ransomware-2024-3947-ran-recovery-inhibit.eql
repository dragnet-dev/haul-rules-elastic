// Dragnet [Ransomware]: dragnet-ransomware-2024-3947 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: b843ef86-5d1e-53c9-895f-3320f994c4db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
