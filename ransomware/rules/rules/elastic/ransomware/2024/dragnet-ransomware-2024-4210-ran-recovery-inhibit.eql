// Dragnet [Ransomware]: dragnet-ransomware-2024-4210 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f39448c6-0c88-5731-b19e-97dd4d85c3d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
