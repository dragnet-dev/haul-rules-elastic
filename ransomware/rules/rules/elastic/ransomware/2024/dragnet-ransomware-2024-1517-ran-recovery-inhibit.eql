// Dragnet [Ransomware]: dragnet-ransomware-2024-1517 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1caa9472-fa6f-5e71-8762-7d52917fca9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
