// Dragnet [Ransomware]: dragnet-ransomware-2024-5959 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 46df677b-fc40-513b-afcc-2bfa4d63bec3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
