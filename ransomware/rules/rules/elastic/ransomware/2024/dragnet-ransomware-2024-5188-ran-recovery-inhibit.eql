// Dragnet [Ransomware]: dragnet-ransomware-2024-5188 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 39c2c40b-94cd-5063-9279-c216a6f85b6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
