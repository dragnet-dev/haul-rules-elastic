// Dragnet [Ransomware]: dragnet-ransomware-2024-4177 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: deece426-2747-57d2-b8ba-944e3e7a9f49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
