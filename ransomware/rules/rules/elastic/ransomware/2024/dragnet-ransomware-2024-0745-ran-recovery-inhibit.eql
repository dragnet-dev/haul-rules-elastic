// Dragnet [Ransomware]: dragnet-ransomware-2024-0745 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 26ec9e73-f0d1-56e9-b3c3-98d4f5096b90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
