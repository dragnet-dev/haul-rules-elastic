// Dragnet [Ransomware]: dragnet-ransomware-2024-2758 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: a42189bd-aba5-503f-a13f-20a01e3cba7c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
