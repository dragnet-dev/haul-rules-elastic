// Dragnet [Ransomware]: dragnet-ransomware-2024-4778 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 62831537-1da3-5ec4-aabb-ca8070aefa58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
