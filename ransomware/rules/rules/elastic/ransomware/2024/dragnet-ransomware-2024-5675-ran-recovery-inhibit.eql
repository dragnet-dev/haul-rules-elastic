// Dragnet [Ransomware]: dragnet-ransomware-2024-5675 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6113a16b-e790-5573-a15e-c286fbfd2af3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
