// Dragnet [Ransomware]: dragnet-ransomware-2024-3032 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 8f69e7e9-8cad-597a-8942-6c3737d20bd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
