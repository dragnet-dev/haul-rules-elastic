// Dragnet [Ransomware]: dragnet-ransomware-2024-0732 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 67d6c537-e1bb-5480-963b-d41b4109865e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
