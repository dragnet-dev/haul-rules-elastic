// Dragnet [Ransomware]: dragnet-ransomware-2024-1542 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 12f286b6-b670-5564-b3a7-8ad5b79513d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
