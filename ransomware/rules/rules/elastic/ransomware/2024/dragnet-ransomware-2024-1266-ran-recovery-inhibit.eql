// Dragnet [Ransomware]: dragnet-ransomware-2024-1266 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: dcdd86dc-d92a-5107-9e2f-109d3f5c496f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
