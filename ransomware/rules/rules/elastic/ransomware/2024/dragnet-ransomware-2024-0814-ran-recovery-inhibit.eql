// Dragnet [Ransomware]: dragnet-ransomware-2024-0814 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: b5ab4806-4d1f-53a0-9a50-f997297b2308

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
