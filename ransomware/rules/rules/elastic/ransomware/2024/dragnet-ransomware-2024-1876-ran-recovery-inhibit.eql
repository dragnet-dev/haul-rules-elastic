// Dragnet [Ransomware]: dragnet-ransomware-2024-1876 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 9f2e064c-796c-5564-bb50-629b4d0ecaba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
