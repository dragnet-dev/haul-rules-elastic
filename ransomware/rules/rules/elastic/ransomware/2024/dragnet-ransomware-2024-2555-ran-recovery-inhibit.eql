// Dragnet [Ransomware]: dragnet-ransomware-2024-2555 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 1e528d4f-134d-5aab-a22c-24f87413eb61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
