// Dragnet [Ransomware]: dragnet-ransomware-2024-1966 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d2135314-8ab7-55b5-a25e-6cd3c46fe9d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
