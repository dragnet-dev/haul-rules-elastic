// Dragnet [Ransomware]: dragnet-ransomware-2024-5912 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: d1753508-2e47-5b23-acd1-a22b5633189a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
