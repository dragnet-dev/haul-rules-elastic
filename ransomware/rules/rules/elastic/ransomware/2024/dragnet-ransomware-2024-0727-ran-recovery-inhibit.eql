// Dragnet [Ransomware]: dragnet-ransomware-2024-0727 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 58b1cd03-b197-51b0-a491-e6c58049a0ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
