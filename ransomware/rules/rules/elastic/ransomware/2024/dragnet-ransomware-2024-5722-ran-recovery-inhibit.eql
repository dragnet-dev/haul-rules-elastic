// Dragnet [Ransomware]: dragnet-ransomware-2024-5722 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 7d2421b4-4bfa-58f1-bde6-b2c793536fa8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
