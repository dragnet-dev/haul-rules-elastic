// Dragnet [Ransomware]: dragnet-ransomware-2024-1479 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3d716ce5-ed5c-56b3-b2ac-b46f4a155970

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
