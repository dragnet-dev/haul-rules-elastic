// Dragnet [Ransomware]: dragnet-ransomware-2024-5157 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 72af1248-b526-5696-8233-3029cb45a907

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
