// Dragnet [Ransomware]: dragnet-ransomware-2024-5218 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: d34d5178-c3d4-526c-88f6-272540577144

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
