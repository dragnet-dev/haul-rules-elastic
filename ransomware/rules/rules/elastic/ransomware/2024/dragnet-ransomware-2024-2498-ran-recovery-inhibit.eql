// Dragnet [Ransomware]: dragnet-ransomware-2024-2498 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 2331451c-8550-5b86-afb4-8ed6ab36297b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
