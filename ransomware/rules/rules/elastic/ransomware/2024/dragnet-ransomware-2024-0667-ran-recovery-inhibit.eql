// Dragnet [Ransomware]: dragnet-ransomware-2024-0667 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: 90d8a459-e8ff-5408-9d79-f43f11c13cf7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
