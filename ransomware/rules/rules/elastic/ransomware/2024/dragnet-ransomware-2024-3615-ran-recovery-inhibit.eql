// Dragnet [Ransomware]: dragnet-ransomware-2024-3615 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 366d2818-4d5b-5c03-952b-8f4d39b9711d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
