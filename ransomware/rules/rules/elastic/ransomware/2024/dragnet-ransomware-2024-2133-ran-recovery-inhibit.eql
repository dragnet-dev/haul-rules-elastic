// Dragnet [Ransomware]: dragnet-ransomware-2024-2133 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: acad0e0b-e475-51a6-8126-d1eee4f3d954

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
