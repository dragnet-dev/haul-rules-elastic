// Dragnet [Ransomware]: dragnet-ransomware-2024-2403 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 50150e5e-ef77-5478-8d8d-7614829fdfd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
