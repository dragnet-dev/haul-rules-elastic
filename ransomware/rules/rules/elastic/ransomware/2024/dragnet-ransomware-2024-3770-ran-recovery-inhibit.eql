// Dragnet [Ransomware]: dragnet-ransomware-2024-3770 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: fb94bf6a-03be-53f1-9fae-dd1938c4edae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
