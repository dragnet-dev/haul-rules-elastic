// Dragnet [Ransomware]: dragnet-ransomware-2024-0226 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 1bbbc011-e877-53dd-bed1-1b3aa506d1d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
