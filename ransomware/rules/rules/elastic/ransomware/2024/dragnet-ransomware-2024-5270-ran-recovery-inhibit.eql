// Dragnet [Ransomware]: dragnet-ransomware-2024-5270 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 88538a8d-2799-5299-af0b-cc6f13b3d213

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
