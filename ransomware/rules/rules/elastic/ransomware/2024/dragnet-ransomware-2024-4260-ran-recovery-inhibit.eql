// Dragnet [Ransomware]: dragnet-ransomware-2024-4260 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f19a4698-ceeb-5a5c-a1a7-d427dfa399f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
