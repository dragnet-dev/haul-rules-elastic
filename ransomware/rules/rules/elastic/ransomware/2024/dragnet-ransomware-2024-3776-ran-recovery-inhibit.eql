// Dragnet [Ransomware]: dragnet-ransomware-2024-3776 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 3e650b1f-8be8-5dc8-bebf-ba5effaed33d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
