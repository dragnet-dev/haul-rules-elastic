// Dragnet [Ransomware]: dragnet-ransomware-2024-2661 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b57416ab-60ab-5ae9-b499-dca30c4be62f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
