// Dragnet [Ransomware]: dragnet-ransomware-2024-1922 — Recovery Inhibition (frag)
// Status: deprecated | Level: high | ID: 0b75f7b4-df0d-59a4-8b42-ae024c3470b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
