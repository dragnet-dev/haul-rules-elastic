// Dragnet [Ransomware]: dragnet-ransomware-2024-3775 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: a286278b-5145-5098-88a9-d75f5d8dd46c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
