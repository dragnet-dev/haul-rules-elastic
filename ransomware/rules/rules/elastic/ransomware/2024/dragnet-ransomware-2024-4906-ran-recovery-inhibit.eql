// Dragnet [Ransomware]: dragnet-ransomware-2024-4906 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 94cabe77-da34-5224-a5f1-e33e199f28fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
