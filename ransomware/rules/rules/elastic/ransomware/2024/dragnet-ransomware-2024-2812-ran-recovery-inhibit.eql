// Dragnet [Ransomware]: dragnet-ransomware-2024-2812 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 2f27e6b7-8f4c-533d-8864-ace916ea1efb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
