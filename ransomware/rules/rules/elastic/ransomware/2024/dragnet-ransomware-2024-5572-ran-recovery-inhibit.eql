// Dragnet [Ransomware]: dragnet-ransomware-2024-5572 — Recovery Inhibition (ValenciaLeaks)
// Status: experimental | Level: high | ID: 14212918-8ac7-5cd8-80ed-efa21e259128

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
