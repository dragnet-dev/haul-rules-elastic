// Dragnet [Ransomware]: dragnet-ransomware-2024-1421 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 4527dad7-b86b-57ba-8716-4a5f9af0c5c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
