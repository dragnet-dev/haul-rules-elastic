// Dragnet [Ransomware]: dragnet-ransomware-2024-3444 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 160c59ec-2ea6-58c1-b4a3-7b2a511cb0db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
