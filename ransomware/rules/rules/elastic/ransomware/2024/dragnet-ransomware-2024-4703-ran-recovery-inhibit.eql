// Dragnet [Ransomware]: dragnet-ransomware-2024-4703 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 309c1d57-f094-5c7c-acc3-de0803b9dfda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
