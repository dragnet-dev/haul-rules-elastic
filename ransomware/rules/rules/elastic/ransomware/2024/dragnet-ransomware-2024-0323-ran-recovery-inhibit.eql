// Dragnet [Ransomware]: dragnet-ransomware-2024-0323 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 261fec46-91ef-5c92-9366-44b7046798f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
