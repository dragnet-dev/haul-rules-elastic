// Dragnet [Ransomware]: dragnet-ransomware-2024-2559 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 7a3c8a04-7d4c-5185-b76e-8c7c78e9a2a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
