// Dragnet [Ransomware]: dragnet-ransomware-2024-5682 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: c8fc4d61-be51-5b20-b03d-e366f0b3f3ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
