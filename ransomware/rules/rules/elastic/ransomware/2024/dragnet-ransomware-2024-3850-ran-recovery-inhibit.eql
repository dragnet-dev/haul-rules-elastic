// Dragnet [Ransomware]: dragnet-ransomware-2024-3850 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 689770c3-a9a5-55e1-830c-2759bc05e271

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
