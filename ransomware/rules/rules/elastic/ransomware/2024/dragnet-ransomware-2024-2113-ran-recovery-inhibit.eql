// Dragnet [Ransomware]: dragnet-ransomware-2024-2113 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f571d417-e108-5558-8001-85aab4705019

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
