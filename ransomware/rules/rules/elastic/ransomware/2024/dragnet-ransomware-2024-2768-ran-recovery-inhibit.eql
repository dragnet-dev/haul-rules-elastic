// Dragnet [Ransomware]: dragnet-ransomware-2024-2768 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 635168ba-5aa9-551b-8d7d-861185e46709

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
