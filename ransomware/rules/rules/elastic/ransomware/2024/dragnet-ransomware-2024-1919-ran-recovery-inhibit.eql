// Dragnet [Ransomware]: dragnet-ransomware-2024-1919 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 61bc7609-9483-564a-b595-017ee1556c38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
