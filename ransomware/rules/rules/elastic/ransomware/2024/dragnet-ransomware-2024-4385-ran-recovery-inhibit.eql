// Dragnet [Ransomware]: dragnet-ransomware-2024-4385 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5978d7f2-6890-593a-8c7e-69277de3c0ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
