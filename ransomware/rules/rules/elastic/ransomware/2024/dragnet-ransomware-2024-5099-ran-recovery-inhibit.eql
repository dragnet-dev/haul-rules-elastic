// Dragnet [Ransomware]: dragnet-ransomware-2024-5099 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: a47a77a8-bfbc-5180-ac82-70e9ef126624

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
