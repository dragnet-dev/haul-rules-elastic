// Dragnet [Ransomware]: dragnet-ransomware-2024-3403 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 91eb634a-0849-5b2a-a29c-cd08e46bea5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
