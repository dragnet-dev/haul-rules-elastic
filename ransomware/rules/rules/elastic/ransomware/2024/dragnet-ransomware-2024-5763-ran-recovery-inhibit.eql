// Dragnet [Ransomware]: dragnet-ransomware-2024-5763 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 7712646c-0565-5a11-b4a0-88f2b790c2d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
