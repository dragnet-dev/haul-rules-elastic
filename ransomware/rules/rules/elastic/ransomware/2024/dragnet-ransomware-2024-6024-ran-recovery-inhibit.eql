// Dragnet [Ransomware]: dragnet-ransomware-2024-6024 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: c75fd01e-2a41-50fa-9be3-1bcc8b49ed3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
