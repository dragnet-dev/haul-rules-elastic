// Dragnet [Ransomware]: dragnet-ransomware-2024-2853 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: fe91b891-6386-5e6d-ae01-0d1fa57a8929

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
