// Dragnet [Ransomware]: dragnet-ransomware-2024-2116 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 60c49ac8-29dc-54cf-b4cf-d4de6c339708

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
