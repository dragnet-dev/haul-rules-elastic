// Dragnet [Ransomware]: dragnet-ransomware-2024-1772 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 9ecb0628-1e44-5151-9677-1c85397811c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
