// Dragnet [Ransomware]: dragnet-ransomware-2024-4161 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5b90e519-e193-5523-b027-df74a156c531

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
