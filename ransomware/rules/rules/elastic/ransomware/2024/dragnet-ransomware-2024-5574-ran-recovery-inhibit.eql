// Dragnet [Ransomware]: dragnet-ransomware-2024-5574 — Recovery Inhibition (hellcat)
// Status: deprecated | Level: high | ID: c544e36f-208d-5a4f-b492-02f5cc8a3435

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
