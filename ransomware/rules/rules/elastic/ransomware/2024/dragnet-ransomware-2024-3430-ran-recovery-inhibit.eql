// Dragnet [Ransomware]: dragnet-ransomware-2024-3430 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 6e3c0430-41ea-5621-a5c0-49ef3e53deb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
