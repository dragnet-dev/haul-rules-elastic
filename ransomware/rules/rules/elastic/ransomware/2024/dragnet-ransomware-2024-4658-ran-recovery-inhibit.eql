// Dragnet [Ransomware]: dragnet-ransomware-2024-4658 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 0343f821-f808-5b83-b5fa-338f77437d5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
