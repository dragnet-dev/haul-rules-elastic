// Dragnet [Ransomware]: dragnet-ransomware-2024-5054 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: db7cf619-6831-54d0-9c70-feb2c011b133

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
