// Dragnet [Ransomware]: dragnet-ransomware-2024-4962 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 97796e60-2d2e-5b97-bee1-79eb62203e55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
