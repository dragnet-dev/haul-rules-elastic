// Dragnet [Ransomware]: dragnet-ransomware-2024-4123 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 5b2575e6-89a2-51dc-819e-1588f25b276a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
