// Dragnet [Ransomware]: dragnet-ransomware-2024-2438 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1ef3ab0a-d20a-547d-9867-a7b33addffb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
