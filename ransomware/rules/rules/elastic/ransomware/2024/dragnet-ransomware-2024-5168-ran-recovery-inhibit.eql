// Dragnet [Ransomware]: dragnet-ransomware-2024-5168 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c65d1783-44d5-5c10-8293-19b669be13f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
