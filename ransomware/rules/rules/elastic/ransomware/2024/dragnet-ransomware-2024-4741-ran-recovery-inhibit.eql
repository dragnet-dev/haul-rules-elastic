// Dragnet [Ransomware]: dragnet-ransomware-2024-4741 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: fe40f9fb-23e7-5d1a-8fd3-2540c2dabcbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
