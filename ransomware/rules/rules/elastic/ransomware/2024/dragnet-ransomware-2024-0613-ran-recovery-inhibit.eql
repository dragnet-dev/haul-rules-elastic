// Dragnet [Ransomware]: dragnet-ransomware-2024-0613 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: c8bd4b95-417e-580a-b8e8-795f92aeb751

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
