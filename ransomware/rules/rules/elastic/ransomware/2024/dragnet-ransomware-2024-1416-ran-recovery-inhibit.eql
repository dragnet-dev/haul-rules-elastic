// Dragnet [Ransomware]: dragnet-ransomware-2024-1416 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f748c552-877d-5ac8-b8e1-77896dac4f37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
