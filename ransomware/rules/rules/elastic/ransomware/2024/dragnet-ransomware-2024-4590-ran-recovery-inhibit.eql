// Dragnet [Ransomware]: dragnet-ransomware-2024-4590 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 8ea818f7-0c3f-5205-8e81-435d3a7cdcbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
