// Dragnet [Ransomware]: dragnet-ransomware-2024-3895 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0e44d623-eb52-5d1a-b445-46ad42f64a85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
