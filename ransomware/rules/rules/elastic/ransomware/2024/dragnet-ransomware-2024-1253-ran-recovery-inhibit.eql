// Dragnet [Ransomware]: dragnet-ransomware-2024-1253 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 4a42c22a-69ad-5996-8f65-72bf920d986d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
