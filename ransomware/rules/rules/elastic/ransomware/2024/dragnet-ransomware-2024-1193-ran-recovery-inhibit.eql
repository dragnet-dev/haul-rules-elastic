// Dragnet [Ransomware]: dragnet-ransomware-2024-1193 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: f3d39789-6978-559c-975a-6c2239d413d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
