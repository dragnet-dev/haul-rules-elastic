// Dragnet [Ransomware]: dragnet-ransomware-2024-1078 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a9f2f234-dfd0-5741-92eb-1fb510102873

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
