// Dragnet [Ransomware]: dragnet-ransomware-2024-0381 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 7a347660-bf23-58b6-b87b-f1d53aec0100

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
