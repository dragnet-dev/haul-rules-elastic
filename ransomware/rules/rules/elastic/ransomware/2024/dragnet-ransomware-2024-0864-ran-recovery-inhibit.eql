// Dragnet [Ransomware]: dragnet-ransomware-2024-0864 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 86fd4a7b-422b-5ddc-b7b4-4b3f768dc88c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
