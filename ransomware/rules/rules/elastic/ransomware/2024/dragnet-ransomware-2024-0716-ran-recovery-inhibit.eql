// Dragnet [Ransomware]: dragnet-ransomware-2024-0716 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 18939fc0-c335-5f19-a324-d4bd2fab41b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
