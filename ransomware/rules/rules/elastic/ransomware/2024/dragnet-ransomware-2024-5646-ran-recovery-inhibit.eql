// Dragnet [Ransomware]: dragnet-ransomware-2024-5646 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: c3a3ef56-58d8-50d5-9855-2a3503020c8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
