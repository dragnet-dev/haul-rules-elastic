// Dragnet [Ransomware]: dragnet-ransomware-2024-3752 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 9589cefb-d9fb-57dc-9621-a6a854797db2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
