// Dragnet [Ransomware]: dragnet-ransomware-2024-3516 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 14c7bf62-6597-5887-b291-3e5b44f1c424

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
