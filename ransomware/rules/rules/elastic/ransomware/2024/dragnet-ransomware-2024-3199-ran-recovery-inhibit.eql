// Dragnet [Ransomware]: dragnet-ransomware-2024-3199 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4e62ea02-73df-5484-b748-bb600712331d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
