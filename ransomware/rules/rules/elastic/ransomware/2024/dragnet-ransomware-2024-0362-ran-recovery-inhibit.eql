// Dragnet [Ransomware]: dragnet-ransomware-2024-0362 — Recovery Inhibition (ElDorado)
// Status: experimental | Level: high | ID: ccff87ae-d1c7-525b-a14c-2dfda3eb6642

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
