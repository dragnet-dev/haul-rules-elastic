// Dragnet [Ransomware]: dragnet-ransomware-2024-0156 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 7b88059a-a178-5369-8bbf-c71a45ce8162

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
