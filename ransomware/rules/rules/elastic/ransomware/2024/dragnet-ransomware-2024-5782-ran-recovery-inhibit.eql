// Dragnet [Ransomware]: dragnet-ransomware-2024-5782 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 59f0182a-ae0b-5281-af53-09be5e868766

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
