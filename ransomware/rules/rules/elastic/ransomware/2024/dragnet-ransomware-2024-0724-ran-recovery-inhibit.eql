// Dragnet [Ransomware]: dragnet-ransomware-2024-0724 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0e749352-44ae-576a-b80e-40eb040c23c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
