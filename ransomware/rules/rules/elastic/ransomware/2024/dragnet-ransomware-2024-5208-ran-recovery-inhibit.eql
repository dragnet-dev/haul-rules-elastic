// Dragnet [Ransomware]: dragnet-ransomware-2024-5208 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 700c1828-9a78-52e8-b754-5d6227e4fbff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
