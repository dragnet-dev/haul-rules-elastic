// Dragnet [Ransomware]: dragnet-ransomware-2024-0082 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 40cf93de-ce0e-560c-b44a-4f5c1876f7d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
