// Dragnet [Ransomware]: dragnet-ransomware-2024-3572 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 4fc2dd2d-9283-53fe-8c3d-f633007eb9e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
