// Dragnet [Ransomware]: dragnet-ransomware-2024-3602 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2c5b1000-550e-5ad3-a7bd-6c36d85a525e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
