// Dragnet [Ransomware]: dragnet-ransomware-2024-5844 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5fcd3cf5-f8d1-508c-aaf7-8db93ab6e875

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
