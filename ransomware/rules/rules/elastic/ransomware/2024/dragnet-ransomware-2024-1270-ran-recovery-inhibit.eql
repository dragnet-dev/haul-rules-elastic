// Dragnet [Ransomware]: dragnet-ransomware-2024-1270 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 3732ec47-23d6-5d4a-8a91-2bd4fd29898d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
