// Dragnet [Ransomware]: dragnet-ransomware-2024-3760 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 05f6124f-e506-599a-a551-4b7bf0d25d73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
