// Dragnet [Ransomware]: dragnet-ransomware-2024-0767 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 789c9f19-5a1d-52c0-af3c-8ce5b7c4bfe5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
