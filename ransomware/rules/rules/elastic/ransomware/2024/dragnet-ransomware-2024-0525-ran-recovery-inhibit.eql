// Dragnet [Ransomware]: dragnet-ransomware-2024-0525 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: fd2df835-dd5d-56fc-b3b9-3d6bc5fd5c82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
