// Dragnet [Ransomware]: dragnet-ransomware-2024-2598 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: fd4e9bcc-b724-5708-8b31-122b457ba670

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
