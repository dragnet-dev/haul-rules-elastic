// Dragnet [Ransomware]: dragnet-ransomware-2024-2837 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 9e74c8f7-6cd9-534d-a6dd-11404deca571

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
