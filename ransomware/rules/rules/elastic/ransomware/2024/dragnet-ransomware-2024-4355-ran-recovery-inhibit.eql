// Dragnet [Ransomware]: dragnet-ransomware-2024-4355 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 20fcf2d7-e1d2-5842-8c04-ced7204614f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
