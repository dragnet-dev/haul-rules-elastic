// Dragnet [Ransomware]: dragnet-ransomware-2024-0172 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: 213ec028-5fe9-5b02-b837-59e100316ed3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
