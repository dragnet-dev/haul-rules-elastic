// Dragnet [Ransomware]: dragnet-ransomware-2024-2151 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 7f2e0b21-f454-5c42-8eb7-db0c09e4ea62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
