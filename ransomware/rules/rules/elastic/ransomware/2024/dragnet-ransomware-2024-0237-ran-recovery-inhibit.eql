// Dragnet [Ransomware]: dragnet-ransomware-2024-0237 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: eb2879f7-3e22-569e-966e-afcf806a7bea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
