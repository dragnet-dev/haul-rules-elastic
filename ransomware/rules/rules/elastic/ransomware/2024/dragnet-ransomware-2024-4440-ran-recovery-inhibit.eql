// Dragnet [Ransomware]: dragnet-ransomware-2024-4440 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 00c133ab-bafa-5f4b-bc38-0ab72decc1c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
