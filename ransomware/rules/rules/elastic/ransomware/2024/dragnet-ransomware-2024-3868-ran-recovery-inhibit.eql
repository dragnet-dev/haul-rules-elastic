// Dragnet [Ransomware]: dragnet-ransomware-2024-3868 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 90a75729-df96-5400-813a-f1837ee51c6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
