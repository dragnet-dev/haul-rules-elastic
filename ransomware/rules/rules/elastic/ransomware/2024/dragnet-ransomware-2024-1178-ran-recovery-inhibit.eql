// Dragnet [Ransomware]: dragnet-ransomware-2024-1178 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: f656bea1-7e77-5abc-bb43-51be2abc4ce1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
