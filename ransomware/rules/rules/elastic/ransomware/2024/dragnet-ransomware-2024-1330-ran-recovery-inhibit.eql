// Dragnet [Ransomware]: dragnet-ransomware-2024-1330 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 4f9d8066-9e82-5968-b312-9a7284831ded

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
