// Dragnet [Ransomware]: dragnet-ransomware-2024-0389 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 54d5daa5-d0d2-5e68-9532-a42db9dadec7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
