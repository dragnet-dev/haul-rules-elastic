// Dragnet [Ransomware]: dragnet-ransomware-2024-3729 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 661f59a0-144a-52dd-a671-ec7fef2cb027

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
