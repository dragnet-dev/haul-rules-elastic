// Dragnet [Ransomware]: dragnet-ransomware-2024-1309 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: ba9f127f-99f1-5096-95c3-57be2c68c73e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
