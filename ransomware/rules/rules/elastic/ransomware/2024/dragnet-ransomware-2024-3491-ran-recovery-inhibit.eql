// Dragnet [Ransomware]: dragnet-ransomware-2024-3491 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 10a84bc8-b182-5efb-a036-26cd7ed2234a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
