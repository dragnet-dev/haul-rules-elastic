// Dragnet [Ransomware]: dragnet-ransomware-2024-5947 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 655fa7a4-5c54-5364-ad62-036242b42396

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
