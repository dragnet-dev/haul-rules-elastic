// Dragnet [Ransomware]: dragnet-ransomware-2024-4562 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: b8c9337e-dbb2-555c-b090-099189a31195

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
