// Dragnet [Ransomware]: dragnet-ransomware-2024-5055 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 72aea910-4faf-5a89-a86e-2cd72d2694ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
