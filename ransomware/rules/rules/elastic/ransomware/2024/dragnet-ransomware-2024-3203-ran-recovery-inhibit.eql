// Dragnet [Ransomware]: dragnet-ransomware-2024-3203 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 896e05ba-2b22-5ada-a26d-7a0cd8310719

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
