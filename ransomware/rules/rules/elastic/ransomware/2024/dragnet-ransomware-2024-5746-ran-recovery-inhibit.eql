// Dragnet [Ransomware]: dragnet-ransomware-2024-5746 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: bc49b7aa-946c-5b6d-935e-a0dc5810597b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
