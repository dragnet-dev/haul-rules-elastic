// Dragnet [Ransomware]: dragnet-ransomware-2024-3158 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9f2d84cb-71a4-5bc4-9e3c-546176989678

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
