// Dragnet [Ransomware]: dragnet-ransomware-2024-1859 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 7c6da01c-0d3c-535a-a899-541579a5120a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
