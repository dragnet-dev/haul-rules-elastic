// Dragnet [Ransomware]: dragnet-ransomware-2024-3777 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 7f2b7d7c-1f87-5812-8200-a3f2580555c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
