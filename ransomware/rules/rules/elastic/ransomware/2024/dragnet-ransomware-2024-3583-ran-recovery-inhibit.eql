// Dragnet [Ransomware]: dragnet-ransomware-2024-3583 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5006dbcd-6410-51b2-ae39-15b578160f2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
