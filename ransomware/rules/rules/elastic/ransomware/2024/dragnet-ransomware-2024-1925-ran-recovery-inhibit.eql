// Dragnet [Ransomware]: dragnet-ransomware-2024-1925 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 8da352a8-0867-5439-8417-dd5a7ae92b0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
