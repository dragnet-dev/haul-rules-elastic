// Dragnet [Ransomware]: dragnet-ransomware-2024-2574 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: c8295954-5a6e-5cda-8d47-84b8927b85d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
