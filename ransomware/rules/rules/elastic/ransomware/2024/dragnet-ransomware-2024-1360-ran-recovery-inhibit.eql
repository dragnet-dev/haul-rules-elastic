// Dragnet [Ransomware]: dragnet-ransomware-2024-1360 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: 886656ca-26c5-5915-8d08-044e8120bad0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
