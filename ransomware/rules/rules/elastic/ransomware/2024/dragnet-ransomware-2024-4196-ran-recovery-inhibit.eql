// Dragnet [Ransomware]: dragnet-ransomware-2024-4196 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: a30314f2-5839-57f5-aacb-56eff492dead

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
