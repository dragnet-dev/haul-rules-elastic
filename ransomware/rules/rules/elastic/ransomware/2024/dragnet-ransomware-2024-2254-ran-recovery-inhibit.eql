// Dragnet [Ransomware]: dragnet-ransomware-2024-2254 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c6a287b2-66e3-5cff-a6c3-0fd7c9539d56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
