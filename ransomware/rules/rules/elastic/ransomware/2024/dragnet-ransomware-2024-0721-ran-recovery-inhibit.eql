// Dragnet [Ransomware]: dragnet-ransomware-2024-0721 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 9d4261d2-6994-5b34-881e-0acd756415e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
