// Dragnet [Ransomware]: dragnet-ransomware-2024-2810 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 03c5a74c-1157-5172-92f8-5eddade20267

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
