// Dragnet [Ransomware]: dragnet-ransomware-2024-3449 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4d1bcfda-e5f7-5704-99a9-238aaba8b181

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
