// Dragnet [Ransomware]: dragnet-ransomware-2024-5181 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 0ee2a967-65b3-5982-adec-c0055379cd03

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
