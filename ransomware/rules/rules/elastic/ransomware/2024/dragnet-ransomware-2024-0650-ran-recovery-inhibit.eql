// Dragnet [Ransomware]: dragnet-ransomware-2024-0650 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c4f5f62d-ac14-517f-958d-e80c27af04df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
