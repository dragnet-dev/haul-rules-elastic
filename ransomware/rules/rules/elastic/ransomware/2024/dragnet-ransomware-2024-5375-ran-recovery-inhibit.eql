// Dragnet [Ransomware]: dragnet-ransomware-2024-5375 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b8647e97-6e6a-507f-9602-f87172ca7985

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
