// Dragnet [Ransomware]: dragnet-ransomware-2024-0393 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 9eb4ec1f-b518-5bf1-8de2-a54f8a95fd59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
