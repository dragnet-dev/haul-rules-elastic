// Dragnet [Ransomware]: dragnet-ransomware-2024-5033 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 885b330d-ed61-5517-8385-a842b999694f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
