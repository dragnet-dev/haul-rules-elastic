// Dragnet [Ransomware]: dragnet-ransomware-2024-0469 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 3d700968-feb1-5c9b-b416-dcc5b65bca5e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
