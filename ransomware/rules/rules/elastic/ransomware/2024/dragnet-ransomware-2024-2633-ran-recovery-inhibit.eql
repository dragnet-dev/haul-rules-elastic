// Dragnet [Ransomware]: dragnet-ransomware-2024-2633 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 90674fe9-b847-5f23-88e5-a4cb3e93958e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
