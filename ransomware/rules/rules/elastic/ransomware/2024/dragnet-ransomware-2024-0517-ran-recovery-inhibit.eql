// Dragnet [Ransomware]: dragnet-ransomware-2024-0517 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a359b4e8-ab8e-5c20-85c6-877c865a388e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
