// Dragnet [Ransomware]: dragnet-ransomware-2024-3887 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: de450a24-6b98-5684-952a-b990a95a0b19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
