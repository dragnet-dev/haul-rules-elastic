// Dragnet [Ransomware]: dragnet-ransomware-2024-5724 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: c39f6635-50e8-5dbe-b384-ce002682a3d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
