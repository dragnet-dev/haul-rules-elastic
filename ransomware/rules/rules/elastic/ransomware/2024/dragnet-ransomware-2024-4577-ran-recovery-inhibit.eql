// Dragnet [Ransomware]: dragnet-ransomware-2024-4577 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 6e27e493-e5c8-5ac5-bb10-093d188a0b0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
