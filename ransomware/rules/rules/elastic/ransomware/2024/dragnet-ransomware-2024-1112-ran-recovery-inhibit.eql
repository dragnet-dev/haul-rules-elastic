// Dragnet [Ransomware]: dragnet-ransomware-2024-1112 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4d951bb7-e893-5c22-993c-c91fd3851bb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
