// Dragnet [Ransomware]: dragnet-ransomware-2024-4522 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c93be492-f93e-5c69-a128-2318a8720a04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
