// Dragnet [Ransomware]: dragnet-ransomware-2024-3903 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ab36af13-fb21-5b1a-9676-6ae3059016ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
