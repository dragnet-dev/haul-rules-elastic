// Dragnet [Ransomware]: dragnet-ransomware-2024-1294 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 14764a0c-e41b-5e36-a85a-19f9db030327

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
