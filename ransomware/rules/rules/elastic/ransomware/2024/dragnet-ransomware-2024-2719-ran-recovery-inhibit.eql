// Dragnet [Ransomware]: dragnet-ransomware-2024-2719 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 8c0ff2ca-d177-51ef-8b29-79f86ef4bb7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
