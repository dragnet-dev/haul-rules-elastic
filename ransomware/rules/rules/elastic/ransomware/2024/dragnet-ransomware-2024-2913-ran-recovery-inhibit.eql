// Dragnet [Ransomware]: dragnet-ransomware-2024-2913 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: 2061b6ea-17b8-5ec8-9b9d-cdc81de7b511

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
