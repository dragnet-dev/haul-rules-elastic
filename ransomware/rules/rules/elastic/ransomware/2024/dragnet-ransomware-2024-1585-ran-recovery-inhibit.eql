// Dragnet [Ransomware]: dragnet-ransomware-2024-1585 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 4931ed80-f918-5b48-81a4-91a2476734ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
