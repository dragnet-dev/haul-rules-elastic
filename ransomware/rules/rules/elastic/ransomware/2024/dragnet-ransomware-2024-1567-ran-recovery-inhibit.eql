// Dragnet [Ransomware]: dragnet-ransomware-2024-1567 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 83704f06-f126-59a1-bbd4-03010271e7cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
