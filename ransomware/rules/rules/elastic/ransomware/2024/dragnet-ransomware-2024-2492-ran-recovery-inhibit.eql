// Dragnet [Ransomware]: dragnet-ransomware-2024-2492 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 7b6f8756-4506-5f3c-929f-162b33fb0436

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
