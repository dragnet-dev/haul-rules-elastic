// Dragnet [Ransomware]: dragnet-ransomware-2024-4779 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a80b23aa-9914-59cb-b6a0-b6560389d735

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
