// Dragnet [Ransomware]: dragnet-ransomware-2024-1288 — Recovery Inhibition (frag)
// Status: deprecated | Level: high | ID: 7bd55a15-1663-5ace-8cae-ee042033a9c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
