// Dragnet [Ransomware]: dragnet-ransomware-2024-4085 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: c24e47d2-e5fa-5e11-933b-13a6f7b9f398

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
