// Dragnet [Ransomware]: dragnet-ransomware-2024-1221 — Recovery Inhibition (donutleaks)
// Status: experimental | Level: high | ID: f8aab49b-7076-573b-b131-11e15c340810

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
