// Dragnet [Ransomware]: dragnet-ransomware-2024-4534 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 17ac492f-8db6-55db-966f-a6cce7739338

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
