// Dragnet [Ransomware]: dragnet-ransomware-2024-0768 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 601e3bf1-0f67-52be-aa63-7b406e10de4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
