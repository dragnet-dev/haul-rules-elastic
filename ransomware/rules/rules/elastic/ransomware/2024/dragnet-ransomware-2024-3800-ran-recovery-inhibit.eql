// Dragnet [Ransomware]: dragnet-ransomware-2024-3800 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: e64c9201-9e63-5645-aeb4-fefce75dcb23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
