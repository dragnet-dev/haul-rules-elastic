// Dragnet [Ransomware]: dragnet-ransomware-2024-1831 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 3ff7ee4f-3a39-546a-9db5-1bc875914ea2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
