// Dragnet [Ransomware]: dragnet-ransomware-2024-1573 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0db639db-a75a-533c-90b0-65d9d33e3d15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
