// Dragnet [Ransomware]: dragnet-ransomware-2024-5640 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 22c9d184-9d25-5c4b-afdb-cd5cefdc3249

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
