// Dragnet [Ransomware]: dragnet-ransomware-2024-2564 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 4a4afc45-24e3-5ae2-a171-81c35675b2d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
