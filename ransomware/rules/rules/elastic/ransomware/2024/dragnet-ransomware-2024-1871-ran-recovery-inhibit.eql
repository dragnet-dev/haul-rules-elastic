// Dragnet [Ransomware]: dragnet-ransomware-2024-1871 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 99f56adc-974e-5115-b5c9-e39114b57ca3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
