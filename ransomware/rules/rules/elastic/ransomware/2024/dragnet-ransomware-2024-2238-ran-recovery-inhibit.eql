// Dragnet [Ransomware]: dragnet-ransomware-2024-2238 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3e1d93bf-dd3b-58af-bf21-c3a667d19b64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
