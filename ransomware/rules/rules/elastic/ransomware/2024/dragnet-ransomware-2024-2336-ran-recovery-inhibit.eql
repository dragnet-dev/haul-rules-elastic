// Dragnet [Ransomware]: dragnet-ransomware-2024-2336 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 62f5a499-5210-5d6c-9dd2-2f24f19c54a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
