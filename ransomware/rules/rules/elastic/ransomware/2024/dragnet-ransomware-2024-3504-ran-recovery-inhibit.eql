// Dragnet [Ransomware]: dragnet-ransomware-2024-3504 — Recovery Inhibition (trinity)
// Status: experimental | Level: high | ID: 4fc91acf-2ebd-549c-b011-05ea6a66df35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
