// Dragnet [Ransomware]: dragnet-ransomware-2024-1608 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: d5481345-d6ab-55a4-867a-3d32feb34c86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
