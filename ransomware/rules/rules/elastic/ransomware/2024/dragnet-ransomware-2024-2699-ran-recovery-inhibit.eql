// Dragnet [Ransomware]: dragnet-ransomware-2024-2699 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: e46c0a8f-380d-52d2-b85b-b825fd0c96b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
