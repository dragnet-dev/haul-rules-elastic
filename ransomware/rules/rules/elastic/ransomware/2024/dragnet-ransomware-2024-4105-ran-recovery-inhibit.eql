// Dragnet [Ransomware]: dragnet-ransomware-2024-4105 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: acb9da03-b85c-5bf9-9a83-cab99a9076d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
