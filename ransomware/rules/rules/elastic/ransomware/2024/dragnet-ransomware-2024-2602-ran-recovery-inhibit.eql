// Dragnet [Ransomware]: dragnet-ransomware-2024-2602 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8b7b1261-1b89-5c35-869e-074026942a32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
