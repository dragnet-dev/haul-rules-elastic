// Dragnet [Ransomware]: dragnet-ransomware-2024-1988 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: af4ad5d9-6624-55b6-8ce1-559055d71a9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
