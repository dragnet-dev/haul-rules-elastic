// Dragnet [Ransomware]: dragnet-ransomware-2024-5981 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 742a67c9-ea10-5ef2-85d6-dac748230384

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
