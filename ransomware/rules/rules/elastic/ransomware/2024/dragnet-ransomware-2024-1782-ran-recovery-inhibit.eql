// Dragnet [Ransomware]: dragnet-ransomware-2024-1782 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 4f9e9b9e-829d-5faa-a2d8-edcb3edd3e53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
