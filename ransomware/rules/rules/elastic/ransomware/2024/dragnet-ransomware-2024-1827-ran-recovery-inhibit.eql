// Dragnet [Ransomware]: dragnet-ransomware-2024-1827 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 9cca1b4a-ad5c-5bfc-8e44-80971ae3b5f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
