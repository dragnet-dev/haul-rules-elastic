// Dragnet [Ransomware]: dragnet-ransomware-2024-2246 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 267ec3fe-dc40-5253-94ce-53bc7db1e44b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
