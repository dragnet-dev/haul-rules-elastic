// Dragnet [Ransomware]: dragnet-ransomware-2024-5169 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 4a391835-7167-53cd-836e-376f6ff54534

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
