// Dragnet [Ransomware]: dragnet-ransomware-2024-0699 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: dfe22ebb-9e59-5e13-b0d9-8fea6dbb76b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
