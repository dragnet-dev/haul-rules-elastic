// Dragnet [Ransomware]: dragnet-ransomware-2024-3388 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 4c7172a4-c563-596f-9e88-0b505cc4e656

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
