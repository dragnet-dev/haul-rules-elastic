// Dragnet [Ransomware]: dragnet-ransomware-2024-3350 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9271cb49-96c0-5a69-aeca-b2215a6ea6a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
