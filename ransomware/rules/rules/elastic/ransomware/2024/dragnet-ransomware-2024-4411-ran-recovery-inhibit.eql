// Dragnet [Ransomware]: dragnet-ransomware-2024-4411 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 0c8c2c46-7ccd-5510-976e-7068d1a5591f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
