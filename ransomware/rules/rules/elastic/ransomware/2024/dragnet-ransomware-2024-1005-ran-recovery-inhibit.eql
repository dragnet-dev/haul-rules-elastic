// Dragnet [Ransomware]: dragnet-ransomware-2024-1005 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 63aeee25-e67a-5e69-8812-f3a0dedccda9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
