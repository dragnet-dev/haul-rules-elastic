// Dragnet [Ransomware]: dragnet-ransomware-2024-2971 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b47677e3-b9c0-5538-8e53-ffe4e97b0420

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
