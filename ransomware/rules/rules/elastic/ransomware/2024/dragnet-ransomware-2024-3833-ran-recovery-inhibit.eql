// Dragnet [Ransomware]: dragnet-ransomware-2024-3833 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: 7f9609d8-7448-554e-958f-ad493ec069a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
