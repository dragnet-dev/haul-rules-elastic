// Dragnet [Ransomware]: dragnet-ransomware-2024-2414 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 61ae3c27-ca44-5873-b711-c57e8c43fd76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
