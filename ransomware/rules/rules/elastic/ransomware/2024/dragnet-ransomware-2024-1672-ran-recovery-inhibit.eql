// Dragnet [Ransomware]: dragnet-ransomware-2024-1672 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 191e70e2-3891-5561-85ab-2842db3361cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
