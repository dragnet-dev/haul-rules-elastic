// Dragnet [Ransomware]: dragnet-ransomware-2024-3135 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b9f5e4b0-7dca-594f-991f-425245e8d964

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
