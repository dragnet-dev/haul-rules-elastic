// Dragnet [Ransomware]: dragnet-ransomware-2024-0268 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: 820feecf-e401-5a5a-89e5-f5e7c8b5b177

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
