// Dragnet [Ransomware]: dragnet-ransomware-2024-4689 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: bed39a44-0aa7-5b0e-b037-0c34792b287c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
