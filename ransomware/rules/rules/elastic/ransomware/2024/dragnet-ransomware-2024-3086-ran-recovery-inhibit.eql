// Dragnet [Ransomware]: dragnet-ransomware-2024-3086 — Recovery Inhibition (moneymessage)
// Status: experimental | Level: high | ID: d3a020ba-f518-512f-9c86-f14bb7c4363e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
