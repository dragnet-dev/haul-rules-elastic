// Dragnet [Ransomware]: dragnet-ransomware-2024-1490 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 51404fec-8b40-5abb-9c59-bb1be9e76095

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
