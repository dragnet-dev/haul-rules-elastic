// Dragnet [Ransomware]: dragnet-ransomware-2024-4520 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 45ce1e2a-0e0b-5aba-a138-bec6cf76b483

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
