// Dragnet [Ransomware]: dragnet-ransomware-2024-5170 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 50efb2f4-4959-5277-8310-075c4b520a12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
