// Dragnet [Ransomware]: dragnet-ransomware-2024-0291 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 0a50ef67-eeb3-5434-af90-2e74186a36eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
