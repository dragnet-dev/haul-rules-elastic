// Dragnet [Ransomware]: dragnet-ransomware-2024-6009 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4f709b1a-a590-582d-8e82-e6cbf6873b9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
