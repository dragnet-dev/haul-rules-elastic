// Dragnet [Ransomware]: dragnet-ransomware-2024-3097 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: dc06680c-75e9-5976-b20e-9b91657245d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
