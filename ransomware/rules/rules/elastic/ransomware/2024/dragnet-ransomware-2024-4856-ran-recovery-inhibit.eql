// Dragnet [Ransomware]: dragnet-ransomware-2024-4856 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 050a21bd-789c-52bf-9fc4-bfb2694621eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
