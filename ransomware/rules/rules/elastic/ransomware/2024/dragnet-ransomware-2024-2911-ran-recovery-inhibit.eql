// Dragnet [Ransomware]: dragnet-ransomware-2024-2911 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 141c379b-7fe1-51af-8248-fffccc26b483

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
