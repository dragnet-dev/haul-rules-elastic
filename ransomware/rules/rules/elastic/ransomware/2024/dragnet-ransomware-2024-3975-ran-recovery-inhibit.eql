// Dragnet [Ransomware]: dragnet-ransomware-2024-3975 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 5b6c5fce-ff2f-5ad2-bdca-9ad270b6e2e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
