// Dragnet [Ransomware]: dragnet-ransomware-2024-5146 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4b232bd1-569e-558b-8618-5b29aadda879

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
