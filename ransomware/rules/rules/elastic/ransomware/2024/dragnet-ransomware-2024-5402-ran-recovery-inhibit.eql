// Dragnet [Ransomware]: dragnet-ransomware-2024-5402 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 0e75ac4e-5430-5255-9d7d-405c4f717c4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
