// Dragnet [Ransomware]: dragnet-ransomware-2024-3697 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f3a1aa7d-0523-5be1-8083-d313c059446e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
