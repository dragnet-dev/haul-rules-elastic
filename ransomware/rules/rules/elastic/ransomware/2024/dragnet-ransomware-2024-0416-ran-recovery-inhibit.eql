// Dragnet [Ransomware]: dragnet-ransomware-2024-0416 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 13b0a28d-ae14-532c-bb57-70a67d53a275

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
