// Dragnet [Ransomware]: dragnet-ransomware-2024-2497 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 576d3a04-9490-5601-bc44-4e1f10525087

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
