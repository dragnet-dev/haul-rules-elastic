// Dragnet [Ransomware]: dragnet-ransomware-2024-5309 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: aec06ba3-6f13-5b96-b07c-28d100e4d0c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
