// Dragnet [Ransomware]: dragnet-ransomware-2024-2931 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 835040a7-dab9-5688-8576-94a8a8218282

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
