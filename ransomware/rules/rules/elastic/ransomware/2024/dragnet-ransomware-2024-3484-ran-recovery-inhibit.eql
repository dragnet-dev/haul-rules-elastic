// Dragnet [Ransomware]: dragnet-ransomware-2024-3484 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: a0460739-0704-5984-999e-fc50dd04bae4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
