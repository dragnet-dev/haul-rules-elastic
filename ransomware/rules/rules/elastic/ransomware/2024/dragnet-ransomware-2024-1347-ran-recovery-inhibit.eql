// Dragnet [Ransomware]: dragnet-ransomware-2024-1347 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: f3174f93-ce38-5e98-a8f9-147e8106cafd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
