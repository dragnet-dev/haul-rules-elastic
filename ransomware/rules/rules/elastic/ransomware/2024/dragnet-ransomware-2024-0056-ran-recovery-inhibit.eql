// Dragnet [Ransomware]: dragnet-ransomware-2024-0056 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 03b40355-5e3f-5bd3-bd5d-ac7911db3233

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
