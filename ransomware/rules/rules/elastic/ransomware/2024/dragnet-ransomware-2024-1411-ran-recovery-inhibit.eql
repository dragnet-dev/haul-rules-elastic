// Dragnet [Ransomware]: dragnet-ransomware-2024-1411 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 84ea358f-ea10-533e-b290-33bfab652c3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
