// Dragnet [Ransomware]: dragnet-ransomware-2024-1912 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 0f8abae4-379b-5513-aca2-bae07ed1d47e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
