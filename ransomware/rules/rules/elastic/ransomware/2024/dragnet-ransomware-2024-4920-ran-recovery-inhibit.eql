// Dragnet [Ransomware]: dragnet-ransomware-2024-4920 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 7344b472-4167-57e3-a05a-45c94a8815bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
