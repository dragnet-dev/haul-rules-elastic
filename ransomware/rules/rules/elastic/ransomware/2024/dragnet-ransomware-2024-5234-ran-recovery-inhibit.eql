// Dragnet [Ransomware]: dragnet-ransomware-2024-5234 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 65653b3a-2207-5de1-811c-e99c068acd96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
