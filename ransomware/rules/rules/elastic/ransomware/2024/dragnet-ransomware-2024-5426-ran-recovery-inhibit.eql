// Dragnet [Ransomware]: dragnet-ransomware-2024-5426 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 79b5219a-9aa8-5585-8603-8e162c201897

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
