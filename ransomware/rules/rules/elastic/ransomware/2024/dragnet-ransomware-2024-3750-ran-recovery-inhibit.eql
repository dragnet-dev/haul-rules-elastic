// Dragnet [Ransomware]: dragnet-ransomware-2024-3750 — Recovery Inhibition (ElDorado)
// Status: experimental | Level: high | ID: 1068b568-8251-5c27-a70d-11d5bb7f025a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
