// Dragnet [Ransomware]: dragnet-ransomware-2024-3566 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 638395e0-dc2f-50ec-8fe6-9dc4d379c248

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
