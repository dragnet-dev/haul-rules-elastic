// Dragnet [Ransomware]: dragnet-ransomware-2024-0548 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 4e5010b4-b5e8-5c13-b5fa-7303ab97c5b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
