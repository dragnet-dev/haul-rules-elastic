// Dragnet [Ransomware]: dragnet-ransomware-2024-1439 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: fb3f071c-622b-5116-9f79-32a737d80785

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
