// Dragnet [Ransomware]: dragnet-ransomware-2024-1345 — Recovery Inhibition (hellcat)
// Status: deprecated | Level: high | ID: faf5a48a-c649-5e21-8bbb-c613af25498f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
