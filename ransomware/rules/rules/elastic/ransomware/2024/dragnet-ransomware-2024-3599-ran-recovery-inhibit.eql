// Dragnet [Ransomware]: dragnet-ransomware-2024-3599 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 6a104332-658c-5d25-8dd0-7ab2604ba0b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
