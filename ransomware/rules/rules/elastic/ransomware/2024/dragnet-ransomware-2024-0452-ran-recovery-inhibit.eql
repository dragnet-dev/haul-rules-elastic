// Dragnet [Ransomware]: dragnet-ransomware-2024-0452 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 873db165-c8bf-5fee-8203-1ca89bac4c8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
