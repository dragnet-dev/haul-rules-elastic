// Dragnet [Ransomware]: dragnet-ransomware-2024-3922 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ca5d3c92-e278-50eb-8f68-46d586ccfa80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
