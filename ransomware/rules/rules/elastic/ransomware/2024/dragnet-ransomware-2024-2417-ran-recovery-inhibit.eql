// Dragnet [Ransomware]: dragnet-ransomware-2024-2417 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 68b79441-5976-53b6-8906-2534808521c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
