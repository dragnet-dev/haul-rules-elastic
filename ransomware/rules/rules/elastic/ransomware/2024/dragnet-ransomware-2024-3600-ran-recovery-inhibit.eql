// Dragnet [Ransomware]: dragnet-ransomware-2024-3600 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 9c71c1ba-51ea-507b-b95f-fcb87e11135f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
