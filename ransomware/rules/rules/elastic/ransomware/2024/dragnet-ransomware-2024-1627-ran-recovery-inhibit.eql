// Dragnet [Ransomware]: dragnet-ransomware-2024-1627 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: f6b4ca87-675a-5951-85da-35f544abb903

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
