// Dragnet [Ransomware]: dragnet-ransomware-2024-5212 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f40b0e2a-cb7a-5f95-94df-14ae4dfcaf8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
