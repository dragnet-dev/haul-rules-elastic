// Dragnet [Ransomware]: dragnet-ransomware-2024-3613 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4cd6b45b-8fe9-5ea1-bc4e-e6ae2fdb043e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
