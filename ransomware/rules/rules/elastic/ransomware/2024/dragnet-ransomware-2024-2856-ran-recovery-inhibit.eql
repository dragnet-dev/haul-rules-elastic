// Dragnet [Ransomware]: dragnet-ransomware-2024-2856 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 0d9ebbe6-d398-5888-a8f0-365656553ccb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
