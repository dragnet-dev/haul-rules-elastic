// Dragnet [Ransomware]: dragnet-ransomware-2024-2615 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: cc4b41e7-2b59-5bce-99fe-8744ea439587

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
