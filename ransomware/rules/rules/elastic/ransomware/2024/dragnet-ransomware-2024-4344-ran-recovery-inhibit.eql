// Dragnet [Ransomware]: dragnet-ransomware-2024-4344 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c6e01f5a-d163-53b9-a38d-130568a37baf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
