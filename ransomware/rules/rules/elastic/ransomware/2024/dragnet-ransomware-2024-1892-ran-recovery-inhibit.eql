// Dragnet [Ransomware]: dragnet-ransomware-2024-1892 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3c54b69c-63ce-59cd-8c21-1f56cdc383a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
