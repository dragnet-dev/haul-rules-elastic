// Dragnet [Ransomware]: dragnet-ransomware-2024-2733 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6f8d52af-dc44-5575-9902-53c8d0dc3772

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
