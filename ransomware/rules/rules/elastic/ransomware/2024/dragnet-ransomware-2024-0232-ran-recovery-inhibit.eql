// Dragnet [Ransomware]: dragnet-ransomware-2024-0232 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 82a401e0-e0f8-566d-a84b-01bc7c6bcedb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
