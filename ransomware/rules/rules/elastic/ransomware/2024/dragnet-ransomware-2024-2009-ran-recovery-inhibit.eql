// Dragnet [Ransomware]: dragnet-ransomware-2024-2009 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 4effd7ff-3d37-598b-af5e-d09c67973991

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
