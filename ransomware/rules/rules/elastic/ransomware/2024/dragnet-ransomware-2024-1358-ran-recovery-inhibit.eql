// Dragnet [Ransomware]: dragnet-ransomware-2024-1358 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2083dd77-e845-5b91-8533-2559a5a5e9a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
