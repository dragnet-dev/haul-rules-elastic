// Dragnet [Ransomware]: dragnet-ransomware-2024-0093 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 3214f844-05b9-5bec-89ba-69fc1f423a16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
