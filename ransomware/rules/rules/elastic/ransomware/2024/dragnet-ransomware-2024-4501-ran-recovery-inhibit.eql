// Dragnet [Ransomware]: dragnet-ransomware-2024-4501 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: b4ac53e6-dd11-532c-83a7-82acbe972744

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
