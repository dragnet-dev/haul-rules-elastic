// Dragnet [Ransomware]: dragnet-ransomware-2024-3494 — Recovery Inhibition (ElDorado)
// Status: experimental | Level: high | ID: 688dc91a-41c9-5811-873e-e75bc6657d40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
