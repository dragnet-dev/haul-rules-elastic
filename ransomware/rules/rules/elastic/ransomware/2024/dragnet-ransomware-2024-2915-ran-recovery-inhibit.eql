// Dragnet [Ransomware]: dragnet-ransomware-2024-2915 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8a3e743a-7c01-5dd8-a382-52da7f8849d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
