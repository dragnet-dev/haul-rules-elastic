// Dragnet [Ransomware]: dragnet-ransomware-2024-0652 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 6ef06427-4ab9-5f3c-99df-350a5036bb2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
