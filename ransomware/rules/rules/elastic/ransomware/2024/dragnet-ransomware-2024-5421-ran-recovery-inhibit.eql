// Dragnet [Ransomware]: dragnet-ransomware-2024-5421 — Recovery Inhibition (hellogookie)
// Status: experimental | Level: high | ID: 6355361f-3ccd-5100-a601-22b51d4dbdc6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
