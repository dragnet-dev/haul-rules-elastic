// Dragnet [Ransomware]: dragnet-ransomware-2024-2156 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 0c44df5f-94e1-5c61-b1ac-068ad1f85da9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
