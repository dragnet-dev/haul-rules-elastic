// Dragnet [Ransomware]: dragnet-ransomware-2024-5986 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c5040d03-9e62-5bc3-938a-eb141d42f1e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
