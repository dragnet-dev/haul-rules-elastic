// Dragnet [Ransomware]: dragnet-ransomware-2024-2265 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 69600a58-96b8-58f0-b509-4c25fecf36ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
