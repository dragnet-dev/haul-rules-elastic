// Dragnet [Ransomware]: dragnet-ransomware-2024-4227 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b5c64fc7-7c91-58a6-8bc7-f73d1c2a1e44

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
