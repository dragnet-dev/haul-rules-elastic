// Dragnet [Ransomware]: dragnet-ransomware-2024-2813 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ddc1d9ed-9b2e-517f-be68-8c01b72b612a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
