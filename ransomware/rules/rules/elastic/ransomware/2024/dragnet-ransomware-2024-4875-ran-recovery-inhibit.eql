// Dragnet [Ransomware]: dragnet-ransomware-2024-4875 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 9910e630-fb5d-583b-86a5-75326ac0691c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
