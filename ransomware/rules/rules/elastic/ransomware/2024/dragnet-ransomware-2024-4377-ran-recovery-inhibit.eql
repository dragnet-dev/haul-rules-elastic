// Dragnet [Ransomware]: dragnet-ransomware-2024-4377 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 57121405-2dd3-51f8-9aec-52d3bce26303

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
