// Dragnet [Ransomware]: dragnet-ransomware-2024-0310 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 7051f729-3d27-54eb-9c8b-158b2ab4f3ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
