// Dragnet [Ransomware]: dragnet-ransomware-2024-3585 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 4358b427-175f-5299-a1f4-63fc85d7307e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
