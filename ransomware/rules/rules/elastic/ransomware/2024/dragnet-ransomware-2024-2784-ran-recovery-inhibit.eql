// Dragnet [Ransomware]: dragnet-ransomware-2024-2784 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: d2563da3-2c9b-5341-96e8-0f2c91e50bf2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
