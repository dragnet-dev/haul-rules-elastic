// Dragnet [Ransomware]: dragnet-ransomware-2024-1366 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 08a527d5-081f-5e6b-9af0-b3ec36c121cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
