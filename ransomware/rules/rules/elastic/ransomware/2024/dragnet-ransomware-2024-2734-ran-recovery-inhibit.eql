// Dragnet [Ransomware]: dragnet-ransomware-2024-2734 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 9993d310-03ad-5d81-a769-1dbf995dc818

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
