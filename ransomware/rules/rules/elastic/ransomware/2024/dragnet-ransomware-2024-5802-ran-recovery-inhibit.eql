// Dragnet [Ransomware]: dragnet-ransomware-2024-5802 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: a9489cad-0248-533b-bf22-07c4a4bbf4ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
