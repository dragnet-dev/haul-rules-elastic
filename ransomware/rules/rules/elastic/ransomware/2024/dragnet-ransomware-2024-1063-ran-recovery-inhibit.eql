// Dragnet [Ransomware]: dragnet-ransomware-2024-1063 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 7ab05316-029b-50c3-8e3b-3ea6e4d8e9a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
