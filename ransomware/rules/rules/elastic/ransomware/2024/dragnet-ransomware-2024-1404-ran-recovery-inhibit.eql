// Dragnet [Ransomware]: dragnet-ransomware-2024-1404 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: dd29e366-0e12-541d-9e53-2bd6917ac9a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
