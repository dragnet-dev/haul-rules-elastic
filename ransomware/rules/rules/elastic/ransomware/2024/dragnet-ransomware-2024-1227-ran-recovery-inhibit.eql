// Dragnet [Ransomware]: dragnet-ransomware-2024-1227 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: d0719664-baec-5b0d-aabe-ab8065ae3efd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
