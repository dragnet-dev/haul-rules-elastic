// Dragnet [Ransomware]: dragnet-ransomware-2024-3814 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 0d3c1bdf-fa42-5acb-b714-8f102f08ce81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
