// Dragnet [Ransomware]: dragnet-ransomware-2024-3284 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: feecbb25-8a15-58a7-9494-a744b67948bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
