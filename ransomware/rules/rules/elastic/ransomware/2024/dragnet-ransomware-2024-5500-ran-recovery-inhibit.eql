// Dragnet [Ransomware]: dragnet-ransomware-2024-5500 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: dbc67498-a25e-515a-b2cb-50b045d90a8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
