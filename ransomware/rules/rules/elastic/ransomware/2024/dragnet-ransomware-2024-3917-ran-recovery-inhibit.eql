// Dragnet [Ransomware]: dragnet-ransomware-2024-3917 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 1817dd65-714c-5a49-a64e-81aba9ecece8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
