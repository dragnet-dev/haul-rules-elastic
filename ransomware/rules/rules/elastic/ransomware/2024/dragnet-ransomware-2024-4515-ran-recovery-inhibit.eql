// Dragnet [Ransomware]: dragnet-ransomware-2024-4515 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6a560e71-93ab-5149-accf-557a5e9c1384

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
