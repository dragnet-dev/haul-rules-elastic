// Dragnet [Ransomware]: dragnet-ransomware-2024-1111 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a4e4c2e0-3a0d-5105-8f18-1ab71c6ce103

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
