// Dragnet [Ransomware]: dragnet-ransomware-2024-5485 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: f357b20e-5d23-5291-9786-a04f7578bca7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
