// Dragnet [Ransomware]: dragnet-ransomware-2024-0364 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: cc3bcfbb-d8cc-5d67-961e-e6477c551ee8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
