// Dragnet [Ransomware]: dragnet-ransomware-2024-5692 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 117b6ad3-0c63-594a-8e16-31e40ea2c94a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
