// Dragnet [Ransomware]: dragnet-ransomware-2024-4548 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 0f7a0632-af6b-5b8d-901b-b1ea6a61dbd2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
