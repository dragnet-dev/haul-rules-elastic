// Dragnet [Ransomware]: dragnet-ransomware-2024-0954 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 5316f5e8-0ea6-52e4-bc59-4bb0194b55d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
