// Dragnet [Ransomware]: dragnet-ransomware-2024-3155 — Recovery Inhibition (trinity)
// Status: experimental | Level: high | ID: ef164718-1706-5282-9e7b-76c687efe58f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
