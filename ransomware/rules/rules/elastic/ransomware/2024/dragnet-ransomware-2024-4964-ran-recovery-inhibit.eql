// Dragnet [Ransomware]: dragnet-ransomware-2024-4964 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: cbcb00e2-dcbc-5e0d-a04b-d5cd7713b3e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
