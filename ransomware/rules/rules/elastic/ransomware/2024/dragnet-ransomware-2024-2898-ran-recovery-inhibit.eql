// Dragnet [Ransomware]: dragnet-ransomware-2024-2898 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 250cbf05-b165-5198-ab16-739090cd88cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
