// Dragnet [Ransomware]: dragnet-ransomware-2024-4947 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 15522a76-8b17-5f3e-a250-598b818a6512

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
