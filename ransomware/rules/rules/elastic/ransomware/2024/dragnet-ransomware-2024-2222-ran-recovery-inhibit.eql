// Dragnet [Ransomware]: dragnet-ransomware-2024-2222 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a2b6c500-3f53-5aa7-9ebf-c901dfbe91a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
