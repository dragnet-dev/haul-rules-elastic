// Dragnet [Ransomware]: dragnet-ransomware-2024-1008 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: 9304aa86-1446-5d77-bd6d-b6c6d5cb8503

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
