// Dragnet [Ransomware]: dragnet-ransomware-2024-6031 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 9459af8e-f85b-51fc-9e6d-79a0213b396b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
