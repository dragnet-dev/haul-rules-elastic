// Dragnet [Ransomware]: dragnet-ransomware-2024-2418 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 46382288-8212-5bfa-80b7-163fa25d0eac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
