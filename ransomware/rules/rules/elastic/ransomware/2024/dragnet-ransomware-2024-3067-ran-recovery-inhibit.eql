// Dragnet [Ransomware]: dragnet-ransomware-2024-3067 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 0c5329fa-7370-54f7-bdcb-43dc1d22b3a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
