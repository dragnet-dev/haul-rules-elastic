// Dragnet [Ransomware]: dragnet-ransomware-2024-5211 — Recovery Inhibition (qiulong)
// Status: experimental | Level: high | ID: cab6a74e-3850-55be-aa3c-870f9ee7d7e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
