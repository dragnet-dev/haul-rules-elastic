// Dragnet [Ransomware]: dragnet-ransomware-2024-0618 — Recovery Inhibition (qiulong)
// Status: experimental | Level: high | ID: 310121c5-9756-5b48-84bc-5f08c636f442

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
