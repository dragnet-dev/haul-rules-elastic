// Dragnet [Ransomware]: dragnet-ransomware-2024-3949 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e8761acf-8cbf-5337-bc00-3a51f1e89708

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
