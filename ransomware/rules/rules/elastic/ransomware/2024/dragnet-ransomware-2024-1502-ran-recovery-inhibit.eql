// Dragnet [Ransomware]: dragnet-ransomware-2024-1502 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 7270afe0-fea5-591e-9e48-b4aad531fd17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
