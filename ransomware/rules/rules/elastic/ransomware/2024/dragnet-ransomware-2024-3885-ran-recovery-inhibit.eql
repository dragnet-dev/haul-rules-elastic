// Dragnet [Ransomware]: dragnet-ransomware-2024-3885 — Recovery Inhibition (dunghill)
// Status: experimental | Level: high | ID: 2bcc6968-7e8d-5b8a-b93c-48bda1820d0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
