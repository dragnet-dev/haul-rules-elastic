// Dragnet [Ransomware]: dragnet-ransomware-2024-3357 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5296671c-1821-564a-a5c1-18f21796238b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
