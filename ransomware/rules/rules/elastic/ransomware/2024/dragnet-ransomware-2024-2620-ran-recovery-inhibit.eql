// Dragnet [Ransomware]: dragnet-ransomware-2024-2620 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: a758b87f-a775-5563-9526-81b6a3857986

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
