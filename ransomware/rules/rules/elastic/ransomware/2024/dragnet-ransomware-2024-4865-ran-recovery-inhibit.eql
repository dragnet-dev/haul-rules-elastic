// Dragnet [Ransomware]: dragnet-ransomware-2024-4865 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 35377438-f5b6-5d54-b22e-3755cb7fbe89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
