// Dragnet [Ransomware]: dragnet-ransomware-2024-4576 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: b2c59b89-4809-59c5-a7c2-839ee28042ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
