// Dragnet [Ransomware]: dragnet-ransomware-2024-0777 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 9c5b9d05-4145-5092-8e21-6ba05287306a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
