// Dragnet [Ransomware]: dragnet-ransomware-2024-2605 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ec0c1b5e-2b46-53d8-a625-4095f86e23f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
