// Dragnet [Ransomware]: dragnet-ransomware-2024-3265 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 47d664a0-a1aa-5b09-94cb-a5b31f951857

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
