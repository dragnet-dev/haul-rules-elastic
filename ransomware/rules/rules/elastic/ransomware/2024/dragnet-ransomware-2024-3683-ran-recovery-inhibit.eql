// Dragnet [Ransomware]: dragnet-ransomware-2024-3683 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 7ea5cf93-4e94-54b2-94d1-4050f2acdddb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
