// Dragnet [Ransomware]: dragnet-ransomware-2024-5272 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 0b4ddec5-fba4-5e08-8633-f2f9cdd43cfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
