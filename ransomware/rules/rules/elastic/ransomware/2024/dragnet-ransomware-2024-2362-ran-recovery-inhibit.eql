// Dragnet [Ransomware]: dragnet-ransomware-2024-2362 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: b987c384-bd7c-5c45-9a1c-4476dba937c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
