// Dragnet [Ransomware]: dragnet-ransomware-2024-1477 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 2a45e67a-ea04-55ca-9a91-7978f16b20d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
