// Dragnet [Ransomware]: dragnet-ransomware-2024-4168 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 94940ef0-5294-5efd-b154-24fed33e916b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
