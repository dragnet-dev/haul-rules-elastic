// Dragnet [Ransomware]: dragnet-ransomware-2024-0577 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8f876626-af6b-5826-a6db-5fd1a0ad6293

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
