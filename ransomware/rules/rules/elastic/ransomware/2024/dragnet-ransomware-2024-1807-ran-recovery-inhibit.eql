// Dragnet [Ransomware]: dragnet-ransomware-2024-1807 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 445e1a9e-c4f8-56f4-904d-6ba10f12ee72

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
