// Dragnet [Ransomware]: dragnet-ransomware-2024-4192 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a8445c40-032f-571a-a0ae-734eadc11f18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
