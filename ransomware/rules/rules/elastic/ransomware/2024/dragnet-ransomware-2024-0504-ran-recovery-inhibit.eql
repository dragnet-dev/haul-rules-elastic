// Dragnet [Ransomware]: dragnet-ransomware-2024-0504 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: a6d21870-546f-52c4-b744-ee37c0bd7e00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
