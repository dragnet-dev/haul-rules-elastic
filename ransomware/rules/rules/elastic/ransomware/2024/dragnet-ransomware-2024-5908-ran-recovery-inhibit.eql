// Dragnet [Ransomware]: dragnet-ransomware-2024-5908 — Recovery Inhibition (redransomware)
// Status: deprecated | Level: high | ID: 3abdbfdf-1e28-5924-926b-e4ab6ca1e650

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
