// Dragnet [Ransomware]: dragnet-ransomware-2024-3765 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 875774fc-c9c1-55ff-93c7-b96e90a72215

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
