// Dragnet [Ransomware]: dragnet-ransomware-2024-4992 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ad501584-45bf-5d1c-b62e-bcbd3a75dad1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
