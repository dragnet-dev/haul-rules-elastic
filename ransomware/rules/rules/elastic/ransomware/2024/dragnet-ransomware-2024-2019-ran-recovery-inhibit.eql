// Dragnet [Ransomware]: dragnet-ransomware-2024-2019 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b5642693-e089-5d83-b4e0-5e517df36779

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
