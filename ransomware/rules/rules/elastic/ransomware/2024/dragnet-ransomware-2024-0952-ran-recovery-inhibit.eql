// Dragnet [Ransomware]: dragnet-ransomware-2024-0952 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 721e2a04-661f-5d55-8875-bfcc59deff70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
