// Dragnet [Ransomware]: dragnet-ransomware-2024-2632 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: aca1fc66-0ca7-5a70-9201-5fe40f0d4da0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
