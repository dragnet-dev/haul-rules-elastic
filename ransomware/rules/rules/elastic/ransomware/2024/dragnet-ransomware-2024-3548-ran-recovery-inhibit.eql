// Dragnet [Ransomware]: dragnet-ransomware-2024-3548 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: c0f0b578-bc8f-59ea-9a3a-3dbcae99813e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
