// Dragnet [Ransomware]: dragnet-ransomware-2024-1620 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f8c85eab-cc51-5af2-9312-9ddd0e9475cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
