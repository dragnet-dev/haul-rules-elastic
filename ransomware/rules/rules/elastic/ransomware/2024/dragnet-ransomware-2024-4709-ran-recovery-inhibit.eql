// Dragnet [Ransomware]: dragnet-ransomware-2024-4709 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 8bee8576-0d31-530e-9b91-cbbb6f634934

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
