// Dragnet [Ransomware]: dragnet-ransomware-2024-4948 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 261c192a-6940-5fc3-92a3-8802acf6e21b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
