// Dragnet [Ransomware]: dragnet-ransomware-2024-3795 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 7c4ad912-a6c0-583c-9359-71866084653e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
