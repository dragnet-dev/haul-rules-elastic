// Dragnet [Ransomware]: dragnet-ransomware-2024-0169 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: cf0b4e49-95ac-5c9c-935a-81cc813681ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
