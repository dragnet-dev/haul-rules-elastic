// Dragnet [Ransomware]: dragnet-ransomware-2024-5891 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: e3381d19-dbe7-55b5-8784-45a6086176ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
