// Dragnet [Ransomware]: dragnet-ransomware-2024-3315 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: af65056d-5e52-50bb-9329-bb2f579aff06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
