// Dragnet [Ransomware]: dragnet-ransomware-2024-1141 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0003a4fb-0324-5359-8ec6-52ee18bad98b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
