// Dragnet [Ransomware]: dragnet-ransomware-2024-0262 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3448f35d-0b29-52a1-b054-9a0ba2fe83af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
