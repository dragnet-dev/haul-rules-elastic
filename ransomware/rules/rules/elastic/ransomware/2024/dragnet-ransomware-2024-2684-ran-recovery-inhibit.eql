// Dragnet [Ransomware]: dragnet-ransomware-2024-2684 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b65d849b-8aee-5b64-9cac-ce94c2f843d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
