// Dragnet [Ransomware]: dragnet-ransomware-2024-1856 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 2d14b488-f7ca-5073-a540-180e807b8ea5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
