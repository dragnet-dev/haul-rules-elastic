// Dragnet [Ransomware]: dragnet-ransomware-2024-1641 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f52cbc35-86c9-501f-a2fe-7486dfbd3dab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
