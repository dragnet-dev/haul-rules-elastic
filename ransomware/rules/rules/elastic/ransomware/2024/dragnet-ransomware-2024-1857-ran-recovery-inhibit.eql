// Dragnet [Ransomware]: dragnet-ransomware-2024-1857 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: bf20b2e1-6ab4-52e3-bcf5-af931b522967

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
