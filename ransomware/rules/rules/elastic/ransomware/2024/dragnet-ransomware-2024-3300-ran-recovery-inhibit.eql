// Dragnet [Ransomware]: dragnet-ransomware-2024-3300 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: de160065-f685-59d1-b6e1-f60a65014ce5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
