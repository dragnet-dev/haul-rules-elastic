// Dragnet [Ransomware]: dragnet-ransomware-2024-5577 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2211d169-2b0c-521f-b2fb-1d3c10a6d4db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
