// Dragnet [Ransomware]: dragnet-ransomware-2024-4898 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 649fdece-77b0-597b-ac81-bafd65d44f5e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
