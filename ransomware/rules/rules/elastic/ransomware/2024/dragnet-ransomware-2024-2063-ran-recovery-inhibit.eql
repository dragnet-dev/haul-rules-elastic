// Dragnet [Ransomware]: dragnet-ransomware-2024-2063 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 3a05b6ad-7bbe-563f-b9bd-185ddf61001e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
