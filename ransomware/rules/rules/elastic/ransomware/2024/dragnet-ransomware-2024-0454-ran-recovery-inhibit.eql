// Dragnet [Ransomware]: dragnet-ransomware-2024-0454 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4362cbed-88bb-50f1-bcbc-ebc03870576d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
