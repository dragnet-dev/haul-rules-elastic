// Dragnet [Ransomware]: dragnet-ransomware-2024-5754 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f7f9e906-25d1-5b8e-a29f-934902428c95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
