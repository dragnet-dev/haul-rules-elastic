// Dragnet [Ransomware]: dragnet-ransomware-2024-4619 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2cef2804-7d71-5570-8e2d-6e6ea5432aee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
