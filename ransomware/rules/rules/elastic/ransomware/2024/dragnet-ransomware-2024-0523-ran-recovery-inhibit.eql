// Dragnet [Ransomware]: dragnet-ransomware-2024-0523 — Recovery Inhibition (chort)
// Status: experimental | Level: high | ID: f8ae70ec-4d91-5003-9bcc-d0dd750f13da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
