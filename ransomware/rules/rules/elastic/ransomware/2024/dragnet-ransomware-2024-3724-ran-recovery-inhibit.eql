// Dragnet [Ransomware]: dragnet-ransomware-2024-3724 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 730d7657-4564-5486-8dd3-1f5c053ff5de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
