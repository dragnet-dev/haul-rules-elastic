// Dragnet [Ransomware]: dragnet-ransomware-2024-2245 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: b878bf6a-4d81-5c37-a8ca-2c4e5c5bef40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
