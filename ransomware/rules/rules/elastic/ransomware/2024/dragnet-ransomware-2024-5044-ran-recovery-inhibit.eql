// Dragnet [Ransomware]: dragnet-ransomware-2024-5044 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: e3fada96-faa2-5683-8e02-dc839210fa9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
