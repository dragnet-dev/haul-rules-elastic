// Dragnet [Ransomware]: dragnet-ransomware-2024-1756 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b3096466-9fc2-59f5-afba-9c7c6ce4a657

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
