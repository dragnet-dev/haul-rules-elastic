// Dragnet [Ransomware]: dragnet-ransomware-2024-3272 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 33c40714-1a90-5aa1-9368-fb454efadb9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
