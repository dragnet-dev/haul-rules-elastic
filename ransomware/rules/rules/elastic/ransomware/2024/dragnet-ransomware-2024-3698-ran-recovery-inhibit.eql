// Dragnet [Ransomware]: dragnet-ransomware-2024-3698 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 1db35811-84fc-5cd3-878f-b8104f1c0641

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
