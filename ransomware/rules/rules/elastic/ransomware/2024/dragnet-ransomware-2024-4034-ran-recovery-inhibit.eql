// Dragnet [Ransomware]: dragnet-ransomware-2024-4034 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 94bb25b0-85bf-57ab-8e1b-e9840bd83244

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
