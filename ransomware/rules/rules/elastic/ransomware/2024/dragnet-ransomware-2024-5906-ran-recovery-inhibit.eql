// Dragnet [Ransomware]: dragnet-ransomware-2024-5906 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 528264f0-e990-5b79-8519-f4ff2be16269

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
