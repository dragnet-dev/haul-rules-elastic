// Dragnet [Ransomware]: dragnet-ransomware-2024-3024 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: fa78946e-2912-59c7-b67e-a5fa58376f71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
