// Dragnet [Ransomware]: dragnet-ransomware-2024-4722 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 3fc34a8c-455f-59d6-8709-c1ef7d9fb716

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
