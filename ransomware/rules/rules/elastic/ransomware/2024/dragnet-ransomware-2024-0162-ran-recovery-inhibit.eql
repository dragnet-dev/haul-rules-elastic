// Dragnet [Ransomware]: dragnet-ransomware-2024-0162 — Recovery Inhibition (frag)
// Status: deprecated | Level: high | ID: 8af58e42-d897-5cf9-a118-e0bf0b00f910

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
