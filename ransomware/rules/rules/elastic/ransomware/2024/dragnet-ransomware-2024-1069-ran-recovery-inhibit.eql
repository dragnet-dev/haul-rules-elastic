// Dragnet [Ransomware]: dragnet-ransomware-2024-1069 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3b2be0fc-126d-52c6-bcca-d31581557c9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
