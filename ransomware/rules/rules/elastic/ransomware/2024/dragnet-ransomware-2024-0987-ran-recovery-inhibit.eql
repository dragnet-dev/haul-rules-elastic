// Dragnet [Ransomware]: dragnet-ransomware-2024-0987 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: cfdb3bfc-3d67-5713-9814-769f46f1e5da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
