// Dragnet [Ransomware]: dragnet-ransomware-2024-1247 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: db5d15fd-8ceb-5799-905f-978a2899688b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
