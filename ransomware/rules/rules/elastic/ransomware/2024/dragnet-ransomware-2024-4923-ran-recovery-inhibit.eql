// Dragnet [Ransomware]: dragnet-ransomware-2024-4923 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 53dde729-fcb2-5f97-8812-4c41136a03cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
