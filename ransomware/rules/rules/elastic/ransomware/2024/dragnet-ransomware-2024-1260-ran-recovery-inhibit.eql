// Dragnet [Ransomware]: dragnet-ransomware-2024-1260 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 49facf6c-aaa3-5351-8319-b83d3e1862de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
