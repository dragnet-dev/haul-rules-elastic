// Dragnet [Ransomware]: dragnet-ransomware-2024-1774 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4b2400a5-90d7-57c0-8fb7-adda22c98816

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
