// Dragnet [Ransomware]: dragnet-ransomware-2024-1839 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: af4eac6b-7756-52eb-97b1-655482578e4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
