// Dragnet [Ransomware]: dragnet-ransomware-2024-0099 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 39715d0b-c5d1-5e3f-ba36-4fac3266fe5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
