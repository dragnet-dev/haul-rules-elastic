// Dragnet [Ransomware]: dragnet-ransomware-2024-1431 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 193f84d1-f3e1-5fae-ad72-7af030714951

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
