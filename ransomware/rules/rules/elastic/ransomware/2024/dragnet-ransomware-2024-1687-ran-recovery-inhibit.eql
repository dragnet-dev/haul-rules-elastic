// Dragnet [Ransomware]: dragnet-ransomware-2024-1687 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 9c4cac5d-ee3c-51e4-b34f-b0db95f1be17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
