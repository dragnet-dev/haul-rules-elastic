// Dragnet [Ransomware]: dragnet-ransomware-2024-2055 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 2bd668b9-0164-5cfa-b5f3-8980e14f8c4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
