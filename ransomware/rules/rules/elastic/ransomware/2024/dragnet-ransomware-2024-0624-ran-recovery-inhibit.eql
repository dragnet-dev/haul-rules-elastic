// Dragnet [Ransomware]: dragnet-ransomware-2024-0624 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: a254d63a-ee22-55c0-99a0-ea546b41d280

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
