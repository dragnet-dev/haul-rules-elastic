// Dragnet [Ransomware]: dragnet-ransomware-2024-0575 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 236d037f-8432-56a3-bbf7-19de8e91d706

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
