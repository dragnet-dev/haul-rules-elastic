// Dragnet [Ransomware]: dragnet-ransomware-2024-1519 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 99fefdab-ccb2-56c3-9d58-3a41ef6f8541

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
