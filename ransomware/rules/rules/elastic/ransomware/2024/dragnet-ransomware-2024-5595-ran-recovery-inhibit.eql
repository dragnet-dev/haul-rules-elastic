// Dragnet [Ransomware]: dragnet-ransomware-2024-5595 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 47bb4d6a-5e71-517d-8bce-1511769cf5fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
