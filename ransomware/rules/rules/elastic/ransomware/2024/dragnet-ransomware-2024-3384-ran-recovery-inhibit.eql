// Dragnet [Ransomware]: dragnet-ransomware-2024-3384 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 980ab723-21e7-5556-a3fd-dea0528d9b60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
