// Dragnet [Ransomware]: dragnet-ransomware-2024-0629 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: adbbd2bd-a6a0-5825-b1a6-36e26e1f2a0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
