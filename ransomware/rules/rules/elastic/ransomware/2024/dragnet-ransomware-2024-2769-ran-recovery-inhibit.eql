// Dragnet [Ransomware]: dragnet-ransomware-2024-2769 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: e74f66c1-f23d-54ae-85c1-d9945d1cc830

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
