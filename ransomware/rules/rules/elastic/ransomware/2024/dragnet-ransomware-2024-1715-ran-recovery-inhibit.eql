// Dragnet [Ransomware]: dragnet-ransomware-2024-1715 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: aa400ab4-62de-530b-b180-1a3fee5b83c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
