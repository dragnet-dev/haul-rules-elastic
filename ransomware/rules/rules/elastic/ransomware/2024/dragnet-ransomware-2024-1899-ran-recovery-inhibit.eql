// Dragnet [Ransomware]: dragnet-ransomware-2024-1899 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 22060f89-c421-5209-badf-00ab3a4ec90d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
