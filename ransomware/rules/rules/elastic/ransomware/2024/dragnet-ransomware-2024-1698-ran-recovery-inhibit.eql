// Dragnet [Ransomware]: dragnet-ransomware-2024-1698 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a9a8493f-b949-564b-b2f1-802b0677295c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
