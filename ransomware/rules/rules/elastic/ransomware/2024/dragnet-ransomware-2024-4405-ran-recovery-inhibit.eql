// Dragnet [Ransomware]: dragnet-ransomware-2024-4405 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 3dbc059f-75d1-5f02-894f-91259e7aed87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
