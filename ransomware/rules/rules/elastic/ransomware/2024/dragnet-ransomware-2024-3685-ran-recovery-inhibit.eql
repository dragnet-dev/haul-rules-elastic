// Dragnet [Ransomware]: dragnet-ransomware-2024-3685 — Recovery Inhibition (dAn0n)
// Status: deprecated | Level: high | ID: f55575c8-711c-597d-b5d0-45cc33d11859

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
