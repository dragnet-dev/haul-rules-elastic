// Dragnet [Ransomware]: dragnet-ransomware-2024-4451 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f8ff760f-c37f-5736-8bee-3966808513ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
