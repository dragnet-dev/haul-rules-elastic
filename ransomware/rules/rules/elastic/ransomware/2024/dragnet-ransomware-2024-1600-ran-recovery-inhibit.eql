// Dragnet [Ransomware]: dragnet-ransomware-2024-1600 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 25b8f510-aeb3-5e87-9257-2e5cee84492f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
