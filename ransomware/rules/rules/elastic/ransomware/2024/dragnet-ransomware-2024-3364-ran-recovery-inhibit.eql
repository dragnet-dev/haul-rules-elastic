// Dragnet [Ransomware]: dragnet-ransomware-2024-3364 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 95ae6af4-9385-5412-83eb-bbf4ed6e151e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
