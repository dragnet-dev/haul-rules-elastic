// Dragnet [Ransomware]: dragnet-ransomware-2024-5417 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a21573c7-e03e-54ce-ac28-335f80d4601e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
