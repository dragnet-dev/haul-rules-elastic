// Dragnet [Ransomware]: dragnet-ransomware-2024-4826 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 4e6bef16-c974-5067-acba-6f58e6b456eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
