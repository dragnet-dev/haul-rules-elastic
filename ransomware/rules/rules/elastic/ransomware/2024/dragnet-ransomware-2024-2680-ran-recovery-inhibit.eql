// Dragnet [Ransomware]: dragnet-ransomware-2024-2680 — Recovery Inhibition (vanirgroup)
// Status: deprecated | Level: high | ID: e70a01aa-0f49-576e-9f0b-e47153fc720e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
