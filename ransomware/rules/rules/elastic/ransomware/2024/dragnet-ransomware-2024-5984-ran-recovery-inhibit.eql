// Dragnet [Ransomware]: dragnet-ransomware-2024-5984 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: a3be9d76-20b7-5242-960c-aa824f5621e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
