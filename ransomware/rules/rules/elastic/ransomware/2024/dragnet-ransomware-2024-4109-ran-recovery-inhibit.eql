// Dragnet [Ransomware]: dragnet-ransomware-2024-4109 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 6ba3eb27-f61a-5c6b-ac98-92038119d86d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
