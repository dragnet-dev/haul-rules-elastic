// Dragnet [Ransomware]: dragnet-ransomware-2024-5519 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 05428a8e-7f26-5d1d-8a64-ba80ac52e7df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
