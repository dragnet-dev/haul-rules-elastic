// Dragnet [Ransomware]: dragnet-ransomware-2024-0686 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 15aa75f4-15c8-5895-80b4-f6acf2c4c8a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
