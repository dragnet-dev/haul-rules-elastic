// Dragnet [Ransomware]: dragnet-ransomware-2024-1207 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 8b3d128d-c44c-5a9c-a2fc-a6a316fa7539

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
