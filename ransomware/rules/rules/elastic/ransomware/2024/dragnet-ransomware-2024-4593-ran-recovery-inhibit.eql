// Dragnet [Ransomware]: dragnet-ransomware-2024-4593 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: 47bae4f0-0310-5df9-b357-824a2f3b413e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
