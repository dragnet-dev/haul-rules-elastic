// Dragnet [Ransomware]: dragnet-ransomware-2024-3470 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 70fddc74-6043-5832-b84d-a20ca5fbec5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
