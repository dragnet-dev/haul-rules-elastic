// Dragnet [Ransomware]: dragnet-ransomware-2024-5453 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b5693312-3d9a-58e8-b314-b07babbbbae7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
