// Dragnet [Ransomware]: dragnet-ransomware-2024-5762 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: afae9441-abc8-590a-acb6-46b5ebece15d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
