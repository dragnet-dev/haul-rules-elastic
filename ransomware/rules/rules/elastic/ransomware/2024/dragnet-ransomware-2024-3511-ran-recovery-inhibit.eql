// Dragnet [Ransomware]: dragnet-ransomware-2024-3511 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: fdbf1754-ee23-5808-add2-205260bcdd67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
