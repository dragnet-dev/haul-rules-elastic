// Dragnet [Ransomware]: dragnet-ransomware-2024-1211 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 58812952-be77-5b0c-ace0-4f2a8843a865

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
