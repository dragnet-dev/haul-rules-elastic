// Dragnet [Ransomware]: dragnet-ransomware-2024-1702 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: a3a99090-5919-58f0-add5-a37dd9ec585f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
