// Dragnet [Ransomware]: dragnet-ransomware-2024-3229 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 24a1e453-8a63-5d3d-952f-88af23b52b0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
