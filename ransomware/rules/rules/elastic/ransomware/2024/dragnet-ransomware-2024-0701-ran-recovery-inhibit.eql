// Dragnet [Ransomware]: dragnet-ransomware-2024-0701 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 0589bad1-5221-5b99-bfc3-503e3cf18164

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
