// Dragnet [Ransomware]: dragnet-ransomware-2024-3044 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 55ae780f-65cc-5f3a-ac5a-f87a7f7e41f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
