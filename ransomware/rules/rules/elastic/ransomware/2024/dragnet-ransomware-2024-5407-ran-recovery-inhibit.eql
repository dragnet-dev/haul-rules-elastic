// Dragnet [Ransomware]: dragnet-ransomware-2024-5407 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: b80eb121-14a7-50f4-ad9b-8e94724b8fc0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
