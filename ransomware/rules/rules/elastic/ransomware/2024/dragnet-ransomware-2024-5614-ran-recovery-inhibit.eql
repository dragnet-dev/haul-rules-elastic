// Dragnet [Ransomware]: dragnet-ransomware-2024-5614 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: bbb289ac-beed-56a0-96c9-aa2a14d07541

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
