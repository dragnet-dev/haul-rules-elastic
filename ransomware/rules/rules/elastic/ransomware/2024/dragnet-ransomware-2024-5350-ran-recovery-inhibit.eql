// Dragnet [Ransomware]: dragnet-ransomware-2024-5350 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: a3e83098-f5df-503f-84f4-35343d816691

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
