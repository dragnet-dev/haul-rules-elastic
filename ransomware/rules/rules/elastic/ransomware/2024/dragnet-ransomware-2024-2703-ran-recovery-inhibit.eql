// Dragnet [Ransomware]: dragnet-ransomware-2024-2703 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d98ac29a-e029-58ee-bac7-20007b355f7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
