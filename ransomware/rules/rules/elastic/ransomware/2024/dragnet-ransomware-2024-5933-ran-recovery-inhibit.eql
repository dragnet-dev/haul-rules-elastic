// Dragnet [Ransomware]: dragnet-ransomware-2024-5933 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: d4585b27-1556-5cbc-8f54-7e73c725d3d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
