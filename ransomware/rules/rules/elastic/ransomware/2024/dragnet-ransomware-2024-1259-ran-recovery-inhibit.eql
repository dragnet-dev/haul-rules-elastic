// Dragnet [Ransomware]: dragnet-ransomware-2024-1259 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5fdff351-6fed-55f1-a054-f6b8714640e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
