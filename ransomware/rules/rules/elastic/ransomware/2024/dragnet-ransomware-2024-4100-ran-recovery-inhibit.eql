// Dragnet [Ransomware]: dragnet-ransomware-2024-4100 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 94ff4a25-9f44-590c-8627-75613978b30e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
