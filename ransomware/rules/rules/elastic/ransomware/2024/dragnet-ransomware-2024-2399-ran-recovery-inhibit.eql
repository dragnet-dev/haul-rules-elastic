// Dragnet [Ransomware]: dragnet-ransomware-2024-2399 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8dae2c22-5478-540e-a5b3-c2568d728f09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
