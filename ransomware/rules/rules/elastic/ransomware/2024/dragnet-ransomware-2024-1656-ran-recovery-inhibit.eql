// Dragnet [Ransomware]: dragnet-ransomware-2024-1656 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 8845f2dd-da58-5a70-8dd3-5ef371eff871

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
