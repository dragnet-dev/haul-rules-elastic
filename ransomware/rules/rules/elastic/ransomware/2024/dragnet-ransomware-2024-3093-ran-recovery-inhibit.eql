// Dragnet [Ransomware]: dragnet-ransomware-2024-3093 — Recovery Inhibition (argonauts)
// Status: experimental | Level: high | ID: d75f2e4a-5d40-598a-834c-78b287f14f21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
