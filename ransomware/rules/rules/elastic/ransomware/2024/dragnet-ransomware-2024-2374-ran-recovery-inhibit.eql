// Dragnet [Ransomware]: dragnet-ransomware-2024-2374 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8cc865ad-5fef-566d-96c1-fcb06de100fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
