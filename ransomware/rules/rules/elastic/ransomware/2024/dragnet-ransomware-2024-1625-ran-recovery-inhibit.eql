// Dragnet [Ransomware]: dragnet-ransomware-2024-1625 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ead54e85-c3c7-5a08-86d6-b5fb0e515c19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
