// Dragnet [Ransomware]: dragnet-ransomware-2024-5939 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: bd2c9737-59b2-5b76-aaf1-20f2ab810752

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
