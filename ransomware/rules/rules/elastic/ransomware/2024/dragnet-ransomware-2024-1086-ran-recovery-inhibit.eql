// Dragnet [Ransomware]: dragnet-ransomware-2024-1086 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 02979778-19ed-5e74-a780-a6ed3235e6ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
