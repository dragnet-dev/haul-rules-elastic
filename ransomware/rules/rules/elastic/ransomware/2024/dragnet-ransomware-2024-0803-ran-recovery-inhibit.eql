// Dragnet [Ransomware]: dragnet-ransomware-2024-0803 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: d618d944-600e-548f-8ad8-6170d64988a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
