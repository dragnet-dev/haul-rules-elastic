// Dragnet [Ransomware]: dragnet-ransomware-2024-5096 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 00fb7ee6-c2ed-57c1-a18e-901beb4c41f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
