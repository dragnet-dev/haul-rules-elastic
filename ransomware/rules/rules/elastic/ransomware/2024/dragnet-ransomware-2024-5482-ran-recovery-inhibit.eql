// Dragnet [Ransomware]: dragnet-ransomware-2024-5482 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 70be1603-f74f-5bd0-b25e-b3dd8eb27834

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
