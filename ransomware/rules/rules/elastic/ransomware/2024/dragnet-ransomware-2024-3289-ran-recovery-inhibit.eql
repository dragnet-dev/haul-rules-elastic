// Dragnet [Ransomware]: dragnet-ransomware-2024-3289 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 1aaa858c-610b-5416-80eb-e0210bd85990

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
