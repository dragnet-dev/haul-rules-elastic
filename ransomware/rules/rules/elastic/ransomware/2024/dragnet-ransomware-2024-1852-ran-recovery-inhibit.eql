// Dragnet [Ransomware]: dragnet-ransomware-2024-1852 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c531caeb-8976-5038-9577-352a0b89b937

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
