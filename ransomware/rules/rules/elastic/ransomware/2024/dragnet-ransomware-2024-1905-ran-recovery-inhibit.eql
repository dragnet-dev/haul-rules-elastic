// Dragnet [Ransomware]: dragnet-ransomware-2024-1905 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: f3f1e682-bd67-578b-8d9f-08428e94ab30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
