// Dragnet [Ransomware]: dragnet-ransomware-2024-1456 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 7994be65-9911-5ef9-941e-a0b14478077c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
