// Dragnet [Ransomware]: dragnet-ransomware-2024-5512 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: e935216d-1c47-5bfe-a97b-9d0e5ef80b06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
