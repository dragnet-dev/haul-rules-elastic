// Dragnet [Ransomware]: dragnet-ransomware-2024-3804 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 42e51a8d-036f-5ffd-9a9f-f7756d7b6fc6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
