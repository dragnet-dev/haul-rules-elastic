// Dragnet [Ransomware]: dragnet-ransomware-2024-0067 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: d7bbc869-d93e-5fb1-bb41-b4489ecb380b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
