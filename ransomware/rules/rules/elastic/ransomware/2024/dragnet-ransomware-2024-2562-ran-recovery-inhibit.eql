// Dragnet [Ransomware]: dragnet-ransomware-2024-2562 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 4b977fca-1f70-543f-9ebe-07c8ae3339fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
