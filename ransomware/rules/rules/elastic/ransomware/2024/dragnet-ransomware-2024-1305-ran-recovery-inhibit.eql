// Dragnet [Ransomware]: dragnet-ransomware-2024-1305 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: 55575e83-720f-546c-9137-3325162fcb9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
