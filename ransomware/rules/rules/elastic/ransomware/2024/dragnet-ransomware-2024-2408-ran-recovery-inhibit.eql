// Dragnet [Ransomware]: dragnet-ransomware-2024-2408 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: 6fef54cc-3df5-59c2-9349-5a6416a40bef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
