// Dragnet [Ransomware]: dragnet-ransomware-2024-4604 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d75d9d8a-0377-5208-9cbd-8ca69c1844f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
