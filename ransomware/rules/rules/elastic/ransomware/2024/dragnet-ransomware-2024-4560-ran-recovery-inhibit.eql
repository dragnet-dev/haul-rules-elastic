// Dragnet [Ransomware]: dragnet-ransomware-2024-4560 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: f1db5366-8874-5c82-8908-d104ee501c79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
