// Dragnet [Ransomware]: dragnet-ransomware-2024-2225 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e301dfb1-4b84-50a4-acb5-a6726ef71381

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
