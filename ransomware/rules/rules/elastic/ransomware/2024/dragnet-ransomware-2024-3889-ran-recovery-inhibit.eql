// Dragnet [Ransomware]: dragnet-ransomware-2024-3889 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 4f3710f5-da27-5f72-ae86-7e313daefd6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
