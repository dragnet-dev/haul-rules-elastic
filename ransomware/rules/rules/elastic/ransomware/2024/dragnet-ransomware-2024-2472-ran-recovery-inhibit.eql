// Dragnet [Ransomware]: dragnet-ransomware-2024-2472 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: c2b71c65-3f2e-508e-bcdb-3e16322e469c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
