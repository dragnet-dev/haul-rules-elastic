// Dragnet [Ransomware]: dragnet-ransomware-2024-5267 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 98522c79-897f-5c6f-817f-13d015763f9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
