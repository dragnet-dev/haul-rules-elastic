// Dragnet [Ransomware]: dragnet-ransomware-2024-1648 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 83eef7eb-5195-5128-9170-d842601865ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
