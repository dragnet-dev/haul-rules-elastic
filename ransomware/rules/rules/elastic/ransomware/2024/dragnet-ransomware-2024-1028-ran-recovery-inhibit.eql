// Dragnet [Ransomware]: dragnet-ransomware-2024-1028 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 66471c62-ad3f-54d0-881f-8918e061cce6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
