// Dragnet [Ransomware]: dragnet-ransomware-2024-0685 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 244646bb-f33d-5f5f-bcc6-2c2f154f2546

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
