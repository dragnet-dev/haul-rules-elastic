// Dragnet [Ransomware]: dragnet-ransomware-2024-5128 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 4d84bee0-f2b8-5024-8ae9-8d2ab476c370

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
