// Dragnet [Ransomware]: dragnet-ransomware-2024-0314 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: abdb4405-0939-505e-90e9-2fc05aa55c08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
