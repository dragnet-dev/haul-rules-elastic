// Dragnet [Ransomware]: dragnet-ransomware-2024-2884 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: e1431d0b-0583-574c-a8d5-42557a375972

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
