// Dragnet [Ransomware]: dragnet-ransomware-2024-4682 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 50ab0bfe-c96d-5629-a76f-f15c2aa34939

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
