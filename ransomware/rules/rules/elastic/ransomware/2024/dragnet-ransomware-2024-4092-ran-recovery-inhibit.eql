// Dragnet [Ransomware]: dragnet-ransomware-2024-4092 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: 9093fc82-4d00-538f-bcd8-6d58d4750b96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
