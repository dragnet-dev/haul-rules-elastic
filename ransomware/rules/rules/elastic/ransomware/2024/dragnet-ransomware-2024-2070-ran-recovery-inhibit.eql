// Dragnet [Ransomware]: dragnet-ransomware-2024-2070 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 6acdc537-b149-5f73-88cb-69ab3a7d4968

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
