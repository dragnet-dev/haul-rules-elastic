// Dragnet [Ransomware]: dragnet-ransomware-2024-5282 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 14427d1c-c9d2-5886-8c9d-0a34c78f1df1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
