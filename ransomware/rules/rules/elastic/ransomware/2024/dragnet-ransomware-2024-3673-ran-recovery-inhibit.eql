// Dragnet [Ransomware]: dragnet-ransomware-2024-3673 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 93d2eb4f-25d1-5089-91c1-ae4317b6f0e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
