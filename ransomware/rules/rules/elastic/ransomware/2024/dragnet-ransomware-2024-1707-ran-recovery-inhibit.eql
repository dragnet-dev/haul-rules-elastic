// Dragnet [Ransomware]: dragnet-ransomware-2024-1707 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 6049738a-5c4f-5178-bffc-2334ee7da105

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
