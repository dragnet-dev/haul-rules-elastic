// Dragnet [Ransomware]: dragnet-ransomware-2024-0257 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 8b9bd5bb-5e04-5843-82d6-3c1fc03da0ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
