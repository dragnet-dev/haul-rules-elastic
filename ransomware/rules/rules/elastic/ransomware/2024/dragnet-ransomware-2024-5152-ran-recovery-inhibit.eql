// Dragnet [Ransomware]: dragnet-ransomware-2024-5152 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 04fd5ec4-ab25-5ad1-a3ee-54e2b1dc3408

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
