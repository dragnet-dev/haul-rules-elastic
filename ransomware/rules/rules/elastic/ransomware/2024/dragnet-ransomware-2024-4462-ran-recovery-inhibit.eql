// Dragnet [Ransomware]: dragnet-ransomware-2024-4462 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: 69694d14-affc-5f61-a693-a71a5e6ec2db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
