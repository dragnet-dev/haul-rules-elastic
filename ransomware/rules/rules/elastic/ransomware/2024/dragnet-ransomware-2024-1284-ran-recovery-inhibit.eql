// Dragnet [Ransomware]: dragnet-ransomware-2024-1284 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 57ecd6df-30a5-57a2-93ab-b4e82d5b7097

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
