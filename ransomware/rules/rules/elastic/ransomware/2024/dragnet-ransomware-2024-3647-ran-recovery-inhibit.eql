// Dragnet [Ransomware]: dragnet-ransomware-2024-3647 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2e5cc6a1-5750-59d7-9943-7a1d73330118

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
