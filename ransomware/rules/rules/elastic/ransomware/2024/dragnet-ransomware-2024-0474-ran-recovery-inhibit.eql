// Dragnet [Ransomware]: dragnet-ransomware-2024-0474 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 55475aea-d438-556d-9bdc-5e8cdce56500

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
