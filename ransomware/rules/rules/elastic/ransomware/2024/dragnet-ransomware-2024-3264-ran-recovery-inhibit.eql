// Dragnet [Ransomware]: dragnet-ransomware-2024-3264 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d3e427ff-c90e-5433-9204-76ceff0ddf3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
