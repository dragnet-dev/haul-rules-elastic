// Dragnet [Ransomware]: dragnet-ransomware-2024-0719 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: 9d8e5a37-4740-5799-9fdb-d86d69b2a1ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
