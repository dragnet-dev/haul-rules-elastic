// Dragnet [Ransomware]: dragnet-ransomware-2024-3091 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 78dd2b8b-b21a-5ed1-a1bb-eeb0f9a1625e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
