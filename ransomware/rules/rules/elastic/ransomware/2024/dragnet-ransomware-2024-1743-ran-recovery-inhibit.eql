// Dragnet [Ransomware]: dragnet-ransomware-2024-1743 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 57c692f5-dbbf-5beb-883b-4d953cb89a48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
