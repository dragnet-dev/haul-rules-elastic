// Dragnet [Ransomware]: dragnet-ransomware-2024-2030 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 40c6c742-30db-5ca0-b1c2-876cbe174a61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
