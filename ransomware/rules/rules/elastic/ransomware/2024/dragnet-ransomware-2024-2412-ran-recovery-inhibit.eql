// Dragnet [Ransomware]: dragnet-ransomware-2024-2412 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 1891415a-82d0-5fee-b945-5394986d651a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
