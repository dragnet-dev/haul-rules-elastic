// Dragnet [Ransomware]: dragnet-ransomware-2024-2901 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: eb601b48-ac0f-5934-939f-4c8468b3dad8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
