// Dragnet [Ransomware]: dragnet-ransomware-2024-0506 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 122016bf-c88a-5486-aaca-7b6039e967e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
