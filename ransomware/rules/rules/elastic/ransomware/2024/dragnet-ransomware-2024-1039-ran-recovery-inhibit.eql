// Dragnet [Ransomware]: dragnet-ransomware-2024-1039 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 888728fd-e346-5ec8-b2ea-41d9279e0e88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
