// Dragnet [Ransomware]: dragnet-ransomware-2024-3546 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 93d01b4c-bc74-5ec5-9f4a-87a1ba45f614

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
