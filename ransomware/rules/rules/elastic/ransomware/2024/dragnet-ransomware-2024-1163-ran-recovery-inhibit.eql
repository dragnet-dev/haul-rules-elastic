// Dragnet [Ransomware]: dragnet-ransomware-2024-1163 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 6bb34c37-fc4d-533b-89b5-537a144b7c4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
