// Dragnet [Ransomware]: dragnet-ransomware-2024-1942 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: aac8ab7e-ac13-5e53-9735-535b3d936216

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
