// Dragnet [Ransomware]: dragnet-ransomware-2024-3190 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 122fbba9-e5ed-5188-bb51-a9e1881132e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
