// Dragnet [Ransomware]: dragnet-ransomware-2024-2098 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: dae924f0-6d7e-5942-a40b-e89afcd34961

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
