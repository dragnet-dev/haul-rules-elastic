// Dragnet [Ransomware]: dragnet-ransomware-2024-2267 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 818749d1-fea4-53ba-81bb-52bbc78ae452

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
