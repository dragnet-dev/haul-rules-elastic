// Dragnet [Ransomware]: dragnet-ransomware-2024-5042 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 84a12875-3c71-5852-83dd-8208e91a1d6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
