// Dragnet [Ransomware]: dragnet-ransomware-2024-3299 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 81bdfc5c-3017-574b-a253-707594fced42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
