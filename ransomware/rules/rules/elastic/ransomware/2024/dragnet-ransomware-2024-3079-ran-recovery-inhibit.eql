// Dragnet [Ransomware]: dragnet-ransomware-2024-3079 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: d970573c-0463-5563-a7f1-c49872ca5e14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
