// Dragnet [Ransomware]: dragnet-ransomware-2024-1811 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3ec1e02b-8a4b-59fb-8c0b-5ebe4e1637c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
