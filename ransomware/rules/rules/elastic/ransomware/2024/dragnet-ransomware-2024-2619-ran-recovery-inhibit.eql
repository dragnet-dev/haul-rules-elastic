// Dragnet [Ransomware]: dragnet-ransomware-2024-2619 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: e32acbc6-7580-5a90-9a96-c8079f8d734f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
