// Dragnet [Ransomware]: dragnet-ransomware-2024-5129 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 5f244f83-a5f4-56f2-a622-2f40b9dc9a6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
