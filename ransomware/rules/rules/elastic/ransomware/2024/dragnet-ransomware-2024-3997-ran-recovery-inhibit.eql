// Dragnet [Ransomware]: dragnet-ransomware-2024-3997 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 03d0159d-ea49-5d7d-88de-87aa8c3d9da8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
