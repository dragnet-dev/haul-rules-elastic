// Dragnet [Ransomware]: dragnet-ransomware-2024-5443 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 5c0a6be2-30d3-5994-9b29-0358e99954b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
