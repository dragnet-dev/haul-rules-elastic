// Dragnet [Ransomware]: dragnet-ransomware-2024-5999 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 51daaca3-e594-5e21-9736-a456ba7aed0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
