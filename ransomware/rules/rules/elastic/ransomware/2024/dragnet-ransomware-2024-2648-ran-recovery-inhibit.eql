// Dragnet [Ransomware]: dragnet-ransomware-2024-2648 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: f6ddb520-addf-5934-bcb5-c98af9b90c5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
