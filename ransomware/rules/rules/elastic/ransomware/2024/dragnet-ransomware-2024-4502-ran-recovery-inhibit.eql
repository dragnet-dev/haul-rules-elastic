// Dragnet [Ransomware]: dragnet-ransomware-2024-4502 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: c8859634-783e-5d2f-9d0d-a4b8e208d1e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
