// Dragnet [Ransomware]: dragnet-ransomware-2024-4596 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f9641aa1-b237-53d0-8cec-1e6688a93a7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
