// Dragnet [Ransomware]: dragnet-ransomware-2024-0830 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 1938ec3f-0f90-5aa6-9062-7894b49d532a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
