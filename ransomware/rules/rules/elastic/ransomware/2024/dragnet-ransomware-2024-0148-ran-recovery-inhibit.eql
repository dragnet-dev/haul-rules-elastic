// Dragnet [Ransomware]: dragnet-ransomware-2024-0148 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 9e7488bc-7dc4-55ed-8c80-b6b4ec2f4fff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
