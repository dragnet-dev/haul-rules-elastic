// Dragnet [Ransomware]: dragnet-ransomware-2024-3186 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 41ae1868-0a46-55b6-a1fd-303a06c49edf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
