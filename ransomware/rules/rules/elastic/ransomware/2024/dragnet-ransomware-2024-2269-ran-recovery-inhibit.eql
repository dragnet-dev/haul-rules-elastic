// Dragnet [Ransomware]: dragnet-ransomware-2024-2269 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ef64fe02-7b8a-5251-b7b6-280a293b1a5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
