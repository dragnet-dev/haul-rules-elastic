// Dragnet [Ransomware]: dragnet-ransomware-2024-3169 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 58aa6088-8922-558b-bb44-325cc9c23e30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
