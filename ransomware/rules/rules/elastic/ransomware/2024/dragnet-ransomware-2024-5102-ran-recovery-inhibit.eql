// Dragnet [Ransomware]: dragnet-ransomware-2024-5102 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 2e1af3b8-d640-55e5-b3c0-5fca064950e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
