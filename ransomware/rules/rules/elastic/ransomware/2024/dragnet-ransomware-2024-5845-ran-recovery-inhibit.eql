// Dragnet [Ransomware]: dragnet-ransomware-2024-5845 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 362261e9-9889-50d1-b5c5-6f7705c547aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
