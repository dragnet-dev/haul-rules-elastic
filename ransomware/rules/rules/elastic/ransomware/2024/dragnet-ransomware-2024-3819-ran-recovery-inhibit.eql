// Dragnet [Ransomware]: dragnet-ransomware-2024-3819 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 391c511a-b9a7-5563-ac16-1f0055ffa39d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
