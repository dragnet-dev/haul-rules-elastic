// Dragnet [Ransomware]: dragnet-ransomware-2024-5827 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a0345d65-23f1-5f3c-af89-e30be56ac35a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
