// Dragnet [Ransomware]: dragnet-ransomware-2024-2261 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: 32cab6e4-24ea-5a12-8f9a-20346af8e357

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
