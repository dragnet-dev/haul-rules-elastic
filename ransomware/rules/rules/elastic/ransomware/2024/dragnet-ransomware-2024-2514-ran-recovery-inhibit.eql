// Dragnet [Ransomware]: dragnet-ransomware-2024-2514 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: bc6e2dce-6be0-5eec-9524-afcb079a73d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
