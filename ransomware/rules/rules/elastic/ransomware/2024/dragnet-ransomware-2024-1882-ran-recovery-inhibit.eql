// Dragnet [Ransomware]: dragnet-ransomware-2024-1882 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 76ec1e07-ff75-5f3d-b313-c9cabef97c15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
