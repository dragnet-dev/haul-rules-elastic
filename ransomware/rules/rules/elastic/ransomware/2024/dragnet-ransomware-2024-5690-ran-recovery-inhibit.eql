// Dragnet [Ransomware]: dragnet-ransomware-2024-5690 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: fa4f8e2b-f2b6-5abf-b548-844ee99b0bee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
