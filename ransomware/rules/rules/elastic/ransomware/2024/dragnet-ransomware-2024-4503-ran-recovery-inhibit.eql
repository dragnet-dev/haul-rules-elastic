// Dragnet [Ransomware]: dragnet-ransomware-2024-4503 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: bbf6dbd7-17f4-5e75-8d7e-4e08168eca54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
