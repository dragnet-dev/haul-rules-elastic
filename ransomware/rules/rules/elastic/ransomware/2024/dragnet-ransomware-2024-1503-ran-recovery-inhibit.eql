// Dragnet [Ransomware]: dragnet-ransomware-2024-1503 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 724ec0d0-5771-554a-b990-749d4dbfd602

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
