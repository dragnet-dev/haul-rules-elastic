// Dragnet [Ransomware]: dragnet-ransomware-2024-1393 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d6bcb8f3-f166-5059-b478-209b29d828e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
