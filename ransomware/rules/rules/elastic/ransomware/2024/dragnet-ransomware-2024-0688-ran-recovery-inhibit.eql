// Dragnet [Ransomware]: dragnet-ransomware-2024-0688 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 20fe7bbb-32f8-5a6b-a21c-920d5a12c912

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
