// Dragnet [Ransomware]: dragnet-ransomware-2024-3363 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: a167b19b-48ae-566f-a755-dbf14ff38a77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
