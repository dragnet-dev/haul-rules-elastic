// Dragnet [Ransomware]: dragnet-ransomware-2024-3498 — Recovery Inhibition (mogilevich)
// Status: deprecated | Level: high | ID: b8830123-b1bf-53f2-9911-d14727249f7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
