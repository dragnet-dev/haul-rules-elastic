// Dragnet [Ransomware]: dragnet-ransomware-2024-3231 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 894a9f39-2b0a-5ca6-8b96-0721468067f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
