// Dragnet [Ransomware]: dragnet-ransomware-2024-0292 — Recovery Inhibition (sensayq)
// Status: experimental | Level: high | ID: 45a3901a-605e-5fce-9fd0-0021ec1f4a22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
