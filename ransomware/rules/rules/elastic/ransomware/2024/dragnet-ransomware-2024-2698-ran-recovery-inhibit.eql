// Dragnet [Ransomware]: dragnet-ransomware-2024-2698 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: c7fd297a-c7ad-52c4-8849-3a096ac6775f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
