// Dragnet [Ransomware]: dragnet-ransomware-2024-3440 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: b479566a-55de-57af-9473-fd0c23d87dc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
