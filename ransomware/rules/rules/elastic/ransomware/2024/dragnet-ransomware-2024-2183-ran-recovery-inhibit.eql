// Dragnet [Ransomware]: dragnet-ransomware-2024-2183 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 2cbd6f22-4ecf-534d-9505-9176305f3231

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
