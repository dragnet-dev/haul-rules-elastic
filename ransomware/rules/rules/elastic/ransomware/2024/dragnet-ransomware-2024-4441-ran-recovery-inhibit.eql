// Dragnet [Ransomware]: dragnet-ransomware-2024-4441 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: c283ae95-57c0-585c-a434-b3ae67758123

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
