// Dragnet [Ransomware]: dragnet-ransomware-2024-5409 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 62803cbd-f882-5c58-ab3b-fcaa7cd89c22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
