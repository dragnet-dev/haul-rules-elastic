// Dragnet [Ransomware]: dragnet-ransomware-2024-1706 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: bc4c34c7-0c4f-5375-a3b6-d65293830a3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
