// Dragnet [Ransomware]: dragnet-ransomware-2024-1571 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 3e91a7bc-8c3b-5310-927e-b5335c5f660b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
