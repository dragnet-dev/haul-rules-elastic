// Dragnet [Ransomware]: dragnet-ransomware-2024-4296 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 5b8641ea-6140-5005-9dac-468533dd6f02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
