// Dragnet [Ransomware]: dragnet-ransomware-2024-3009 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 4293989f-4759-58da-9c64-bb94d93f76d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
