// Dragnet [Ransomware]: dragnet-ransomware-2024-0643 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 2f5c6518-029f-5620-8917-4b08c138ae0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
