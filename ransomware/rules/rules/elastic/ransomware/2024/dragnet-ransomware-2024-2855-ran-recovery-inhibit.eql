// Dragnet [Ransomware]: dragnet-ransomware-2024-2855 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0c2c9aa8-89da-5adf-ae67-fa639a0800cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
