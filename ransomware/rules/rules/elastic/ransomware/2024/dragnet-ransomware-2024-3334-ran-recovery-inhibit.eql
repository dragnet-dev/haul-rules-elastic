// Dragnet [Ransomware]: dragnet-ransomware-2024-3334 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 0b5910f5-962b-5544-8ee6-20caeb8ab077

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
