// Dragnet [Ransomware]: dragnet-ransomware-2024-4873 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: da0a2856-877b-5418-b9d7-76550e4187e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
