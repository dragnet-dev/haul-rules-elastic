// Dragnet [Ransomware]: dragnet-ransomware-2024-3593 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: f01d7121-5eb7-5da2-9b7f-c7f8cdec0803

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
