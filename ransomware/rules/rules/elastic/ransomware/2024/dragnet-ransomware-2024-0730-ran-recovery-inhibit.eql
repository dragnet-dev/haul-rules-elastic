// Dragnet [Ransomware]: dragnet-ransomware-2024-0730 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 78ea0a6e-94ff-54da-951e-9c0fa00f9570

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
