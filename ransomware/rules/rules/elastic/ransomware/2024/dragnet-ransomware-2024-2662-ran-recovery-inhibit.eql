// Dragnet [Ransomware]: dragnet-ransomware-2024-2662 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 5f470a77-1373-57d0-9443-664d4159d9f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
