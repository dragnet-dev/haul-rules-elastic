// Dragnet [Ransomware]: dragnet-ransomware-2024-3642 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: f19c61ad-53df-54eb-ac24-dcbbf551f5d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
