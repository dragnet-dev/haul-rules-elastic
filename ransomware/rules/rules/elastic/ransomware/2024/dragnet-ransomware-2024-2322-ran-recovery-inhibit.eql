// Dragnet [Ransomware]: dragnet-ransomware-2024-2322 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 271a89a2-ea6e-537b-b186-f2a5f3f92823

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
