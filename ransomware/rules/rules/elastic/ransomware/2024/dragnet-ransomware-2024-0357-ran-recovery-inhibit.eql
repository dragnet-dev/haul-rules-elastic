// Dragnet [Ransomware]: dragnet-ransomware-2024-0357 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 5b346b6c-e342-54d9-aed1-017aa53a0aec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
