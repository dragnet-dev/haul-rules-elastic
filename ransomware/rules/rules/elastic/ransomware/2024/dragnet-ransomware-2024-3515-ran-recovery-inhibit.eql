// Dragnet [Ransomware]: dragnet-ransomware-2024-3515 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 3e181e28-6e8a-5de4-8af1-1b5d863f85d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
