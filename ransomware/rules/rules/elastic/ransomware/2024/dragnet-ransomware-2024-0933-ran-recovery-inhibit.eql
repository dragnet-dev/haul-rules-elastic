// Dragnet [Ransomware]: dragnet-ransomware-2024-0933 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 74496b2c-2d39-5359-b425-1dee494c10ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
