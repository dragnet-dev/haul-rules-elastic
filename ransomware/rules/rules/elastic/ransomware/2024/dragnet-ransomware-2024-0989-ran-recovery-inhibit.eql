// Dragnet [Ransomware]: dragnet-ransomware-2024-0989 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3b2b5d83-548e-5e44-875f-58aa8dc2989a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
