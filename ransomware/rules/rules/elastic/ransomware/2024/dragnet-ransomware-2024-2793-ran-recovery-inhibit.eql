// Dragnet [Ransomware]: dragnet-ransomware-2024-2793 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 36ed0c6f-5122-5130-a35f-40cd787898ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
