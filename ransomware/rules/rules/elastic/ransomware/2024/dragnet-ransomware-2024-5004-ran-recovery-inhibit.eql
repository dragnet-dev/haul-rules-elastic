// Dragnet [Ransomware]: dragnet-ransomware-2024-5004 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 80b490f5-a65a-59ab-bb1f-a2980ff8b7e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
