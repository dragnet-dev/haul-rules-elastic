// Dragnet [Ransomware]: dragnet-ransomware-2024-0131 — Recovery Inhibition (cloak)
// Status: experimental | Level: high | ID: 1af455fd-f65e-5396-9e7a-d381bed6b47d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
