// Dragnet [Ransomware]: dragnet-ransomware-2024-0234 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: cfddf651-174b-51c3-8aa5-713d3fdae7f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
