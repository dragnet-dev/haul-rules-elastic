// Dragnet [Ransomware]: dragnet-ransomware-2024-1189 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 2926d8c5-6231-52b6-80dd-dd1c477c484e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
