// Dragnet [Ransomware]: dragnet-ransomware-2024-1917 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: fa37a454-a475-5043-895e-89f5ea12d32c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
