// Dragnet [Ransomware]: dragnet-ransomware-2024-2834 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1a50d494-ed59-51d9-8951-10d7d4576e09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
