// Dragnet [Ransomware]: dragnet-ransomware-2024-1798 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 86004c50-0d71-536c-b448-adf22b138c87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
