// Dragnet [Ransomware]: dragnet-ransomware-2024-4007 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: a2b336f6-1fa0-5508-a40f-d4bd94edc073

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
