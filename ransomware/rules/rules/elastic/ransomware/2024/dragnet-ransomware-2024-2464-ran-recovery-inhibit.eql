// Dragnet [Ransomware]: dragnet-ransomware-2024-2464 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: 73688f24-42f0-5ba3-9fa8-c533ccc83b82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
