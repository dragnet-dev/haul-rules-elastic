// Dragnet [Ransomware]: dragnet-ransomware-2024-2660 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 42e148cf-2250-59b9-b112-65eb6cdd6ea3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
