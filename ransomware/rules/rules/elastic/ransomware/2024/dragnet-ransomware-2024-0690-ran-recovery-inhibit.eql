// Dragnet [Ransomware]: dragnet-ransomware-2024-0690 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: fc452855-e024-5257-b3c5-74a28d189f41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
