// Dragnet [Ransomware]: dragnet-ransomware-2024-1637 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 5c5ab05e-cbc3-569b-a6b2-c49b1dd38b0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
