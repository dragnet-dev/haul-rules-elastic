// Dragnet [Ransomware]: dragnet-ransomware-2024-3656 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: e9d6b186-e9d7-5f3f-8a05-d6a214190741

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
