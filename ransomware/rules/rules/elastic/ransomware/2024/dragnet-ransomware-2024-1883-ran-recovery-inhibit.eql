// Dragnet [Ransomware]: dragnet-ransomware-2024-1883 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5c92d593-fce2-55b1-a018-546d7380c143

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
