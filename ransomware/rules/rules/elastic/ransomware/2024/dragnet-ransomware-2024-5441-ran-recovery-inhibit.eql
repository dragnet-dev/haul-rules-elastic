// Dragnet [Ransomware]: dragnet-ransomware-2024-5441 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f6f4ae51-1bfd-5428-aed5-1532be0faeb2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
