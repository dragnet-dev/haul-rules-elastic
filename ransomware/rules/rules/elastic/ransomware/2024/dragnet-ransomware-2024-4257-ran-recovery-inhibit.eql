// Dragnet [Ransomware]: dragnet-ransomware-2024-4257 — Recovery Inhibition (redransomware)
// Status: deprecated | Level: high | ID: bc74c3fb-0179-5d6c-bea2-e2740859aca7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
