// Dragnet [Ransomware]: dragnet-ransomware-2024-0145 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 6dc944da-ff74-5940-a75b-b874a65aa9eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
