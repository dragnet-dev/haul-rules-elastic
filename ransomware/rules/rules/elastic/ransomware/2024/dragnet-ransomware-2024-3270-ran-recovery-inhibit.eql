// Dragnet [Ransomware]: dragnet-ransomware-2024-3270 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 380abe62-b803-55ae-bfd3-a14ffc395552

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
