// Dragnet [Ransomware]: dragnet-ransomware-2024-0403 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 5bf76795-6332-5635-8960-b0173f60d50a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
