// Dragnet [Ransomware]: dragnet-ransomware-2024-1425 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0a86abd0-be71-5933-a100-857829904578

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
