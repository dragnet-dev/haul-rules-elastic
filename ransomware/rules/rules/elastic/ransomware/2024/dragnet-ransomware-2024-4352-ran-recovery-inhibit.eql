// Dragnet [Ransomware]: dragnet-ransomware-2024-4352 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: c10d5277-ffb7-5979-aa67-62261c46b409

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
