// Dragnet [Ransomware]: dragnet-ransomware-2024-2325 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: fe64e22d-2cbb-5692-81e5-c937135975a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
