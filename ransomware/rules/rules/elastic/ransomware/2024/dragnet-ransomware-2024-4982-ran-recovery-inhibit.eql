// Dragnet [Ransomware]: dragnet-ransomware-2024-4982 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: 9008f8f7-37a9-5a0d-927f-70e9cb5f1481

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
