// Dragnet [Ransomware]: dragnet-ransomware-2024-5695 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 87fe2718-ea13-58e3-879c-0c250d239bd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
