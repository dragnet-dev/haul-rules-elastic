// Dragnet [Ransomware]: dragnet-ransomware-2024-4404 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: f944ae4b-630e-51e0-b630-32eb1ffb2556

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
