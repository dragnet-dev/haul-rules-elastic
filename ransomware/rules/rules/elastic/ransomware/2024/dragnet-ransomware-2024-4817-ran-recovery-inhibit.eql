// Dragnet [Ransomware]: dragnet-ransomware-2024-4817 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 1cc78382-d70d-5c5b-b517-aee0c39e581c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
