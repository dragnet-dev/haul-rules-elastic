// Dragnet [Ransomware]: dragnet-ransomware-2024-0250 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 29668258-d21a-583c-91f0-952b122fae10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
