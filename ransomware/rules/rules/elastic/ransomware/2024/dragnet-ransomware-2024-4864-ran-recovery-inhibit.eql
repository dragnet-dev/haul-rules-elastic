// Dragnet [Ransomware]: dragnet-ransomware-2024-4864 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: cc86f0c4-27eb-52cd-9795-0d733daa5d83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
