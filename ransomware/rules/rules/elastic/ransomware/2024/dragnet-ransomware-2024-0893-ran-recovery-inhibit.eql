// Dragnet [Ransomware]: dragnet-ransomware-2024-0893 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: ba731287-530f-5d2c-b174-870c4bc28e96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
