// Dragnet [Ransomware]: dragnet-ransomware-2024-3243 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 7d461a49-d3c8-5ed0-8b13-3f4a79392ac8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
