// Dragnet [Ransomware]: dragnet-ransomware-2024-0925 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 307b799c-fab4-5ead-ba6c-ee205901d33f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
