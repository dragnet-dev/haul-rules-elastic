// Dragnet [Ransomware]: dragnet-ransomware-2024-1493 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: fd9f0b4a-9258-52a8-9faf-997ef6bdacd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
