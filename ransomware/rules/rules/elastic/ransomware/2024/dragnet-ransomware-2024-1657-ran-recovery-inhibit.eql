// Dragnet [Ransomware]: dragnet-ransomware-2024-1657 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 39fd899d-ba4f-5341-9fa3-692697f28711

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
