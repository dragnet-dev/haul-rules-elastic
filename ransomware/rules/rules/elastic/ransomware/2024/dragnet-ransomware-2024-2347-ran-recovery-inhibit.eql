// Dragnet [Ransomware]: dragnet-ransomware-2024-2347 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 82922a16-b3eb-5b30-84e2-a5655e4805c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
