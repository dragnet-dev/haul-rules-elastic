// Dragnet [Ransomware]: dragnet-ransomware-2024-4506 — Recovery Inhibition (trigona)
// Status: experimental | Level: high | ID: 13ecedca-9b06-535e-8875-fbca6af9fd14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
