// Dragnet [Ransomware]: dragnet-ransomware-2024-2410 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b76a401b-c1d3-5330-8435-a83f170d5125

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
