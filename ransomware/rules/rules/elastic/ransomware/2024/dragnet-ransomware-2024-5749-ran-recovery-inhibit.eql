// Dragnet [Ransomware]: dragnet-ransomware-2024-5749 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: c38d4983-4317-514c-8fa6-16738c275de8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
