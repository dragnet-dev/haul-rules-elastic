// Dragnet [Ransomware]: dragnet-ransomware-2024-1612 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: d1d02594-1c60-5b9a-9daa-2a578b905eee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
