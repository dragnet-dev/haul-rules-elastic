// Dragnet [Ransomware]: dragnet-ransomware-2024-3406 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 918ce09c-f5f0-5c02-872e-1733bc9bb22b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
