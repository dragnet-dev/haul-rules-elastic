// Dragnet [Ransomware]: dragnet-ransomware-2024-5437 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 46ea4887-f38f-5c8a-9217-aa05a4925d9c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
