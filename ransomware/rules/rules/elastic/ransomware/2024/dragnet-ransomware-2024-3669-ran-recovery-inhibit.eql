// Dragnet [Ransomware]: dragnet-ransomware-2024-3669 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 3526052b-74df-5482-a819-a39c3278e00d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
