// Dragnet [Ransomware]: dragnet-ransomware-2024-4381 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 2f8b8897-82c1-5855-8603-d3209752a7fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
