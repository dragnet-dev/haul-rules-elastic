// Dragnet [Ransomware]: dragnet-ransomware-2024-1443 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 4c6d9118-df2a-54e9-8234-ef7fed862851

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
