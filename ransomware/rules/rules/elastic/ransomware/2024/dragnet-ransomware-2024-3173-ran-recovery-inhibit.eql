// Dragnet [Ransomware]: dragnet-ransomware-2024-3173 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2b3725d2-b763-54d5-a35e-b52876c832a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
