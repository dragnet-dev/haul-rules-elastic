// Dragnet [Ransomware]: dragnet-ransomware-2024-5134 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 43290ddb-f80f-5563-a56f-b1531ed7d7c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
