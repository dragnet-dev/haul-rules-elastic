// Dragnet [Ransomware]: dragnet-ransomware-2024-4847 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: db70047a-7008-55d0-8d1e-238ca9cb86cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
