// Dragnet [Ransomware]: dragnet-ransomware-2024-4538 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 097c77b0-8049-55f5-bd71-5b34f6d7379f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
