// Dragnet [Ransomware]: dragnet-ransomware-2024-0376 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: ca4834e7-72bd-5b86-a3b7-6365eb734636

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
