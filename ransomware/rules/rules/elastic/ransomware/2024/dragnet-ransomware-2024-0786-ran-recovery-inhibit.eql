// Dragnet [Ransomware]: dragnet-ransomware-2024-0786 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0d0dbfcf-0fd3-5a7f-8d88-bc1a1b637369

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
