// Dragnet [Ransomware]: dragnet-ransomware-2024-5471 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: 119f4a77-c0f0-5c15-a0aa-5b19400af4c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
