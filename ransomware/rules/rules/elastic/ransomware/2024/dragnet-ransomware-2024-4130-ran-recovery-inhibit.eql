// Dragnet [Ransomware]: dragnet-ransomware-2024-4130 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 050bbc81-81ca-5a95-9a2f-5c7f9ea5a4cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
