// Dragnet [Ransomware]: dragnet-ransomware-2024-5380 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: cff4f480-8499-5d74-9e34-dcc7bcbfc9b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
