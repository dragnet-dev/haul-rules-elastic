// Dragnet [Ransomware]: dragnet-ransomware-2024-1514 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: a645de4d-a879-5c04-aacd-957a3597cf7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
