// Dragnet [Ransomware]: dragnet-ransomware-2024-1705 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f0e604df-4b3c-5fcd-98a2-b5c8e42e3afb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
