// Dragnet [Ransomware]: dragnet-ransomware-2024-2057 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6040d840-f08a-52ae-90e2-ec12f1b165ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
