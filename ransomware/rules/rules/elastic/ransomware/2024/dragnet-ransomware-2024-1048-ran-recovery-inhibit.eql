// Dragnet [Ransomware]: dragnet-ransomware-2024-1048 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 9a92d867-f374-5ea3-a827-763a5a3138e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
