// Dragnet [Ransomware]: dragnet-ransomware-2024-0064 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 11f6c162-ec95-5d63-a206-f9188053f8bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
