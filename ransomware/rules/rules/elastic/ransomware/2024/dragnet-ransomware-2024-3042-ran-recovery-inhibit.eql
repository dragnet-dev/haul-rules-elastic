// Dragnet [Ransomware]: dragnet-ransomware-2024-3042 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 69c48970-5881-5ce9-8311-931d3627cc92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
