// Dragnet [Ransomware]: dragnet-ransomware-2024-3955 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2ff61780-f770-596f-9f36-10a70a1b43e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
