// Dragnet [Ransomware]: dragnet-ransomware-2024-4657 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3f498276-7496-5f75-8825-90367cc2a017

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
