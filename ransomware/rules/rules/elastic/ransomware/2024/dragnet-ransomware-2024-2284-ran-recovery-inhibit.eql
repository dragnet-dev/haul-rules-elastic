// Dragnet [Ransomware]: dragnet-ransomware-2024-2284 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 376d5994-81e6-5d7b-a626-ff5183eb7813

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
