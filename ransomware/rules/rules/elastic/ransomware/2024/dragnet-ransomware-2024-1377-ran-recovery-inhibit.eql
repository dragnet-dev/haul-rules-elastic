// Dragnet [Ransomware]: dragnet-ransomware-2024-1377 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 290798f8-355b-534f-8cd7-a2ae95098488

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
