// Dragnet [Ransomware]: dragnet-ransomware-2024-3641 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: a68b93ed-b8af-51bc-9949-6d53f6802d85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
