// Dragnet [Ransomware]: dragnet-ransomware-2024-5943 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 2f976e6e-381d-5d02-b857-3dd4323cedf9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
