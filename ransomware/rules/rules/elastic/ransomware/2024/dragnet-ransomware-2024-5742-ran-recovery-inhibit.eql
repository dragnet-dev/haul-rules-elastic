// Dragnet [Ransomware]: dragnet-ransomware-2024-5742 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: e93ed3e1-53fc-51ea-889b-5ff20b89eb1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
