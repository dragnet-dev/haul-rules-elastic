// Dragnet [Ransomware]: dragnet-ransomware-2024-4815 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5e6d0d9d-1e0e-52ea-a2ad-bc36bc1763d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
