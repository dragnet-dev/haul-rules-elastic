// Dragnet [Ransomware]: dragnet-ransomware-2024-4363 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 88498275-6cb2-56cd-9a93-5037ef03ddc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
