// Dragnet [Ransomware]: dragnet-ransomware-2024-3957 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 5fe076d9-fdac-5ad3-9e46-8437edc416cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
