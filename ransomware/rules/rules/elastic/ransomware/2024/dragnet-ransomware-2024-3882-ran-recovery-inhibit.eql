// Dragnet [Ransomware]: dragnet-ransomware-2024-3882 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9ef47667-c2a4-557a-85aa-a6a48ce420c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
