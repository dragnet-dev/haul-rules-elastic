// Dragnet [Ransomware]: dragnet-ransomware-2024-1385 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 54ae2d4a-1c97-528e-b451-e911d1756a21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
