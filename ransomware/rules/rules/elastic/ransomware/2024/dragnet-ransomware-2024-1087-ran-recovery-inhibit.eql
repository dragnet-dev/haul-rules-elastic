// Dragnet [Ransomware]: dragnet-ransomware-2024-1087 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 9f9cdfeb-65de-522a-ac8c-25c1a1662a61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
