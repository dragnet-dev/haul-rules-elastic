// Dragnet [Ransomware]: dragnet-ransomware-2024-0739 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 1ef79d44-ad6c-525b-bacd-8b7135132b38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
