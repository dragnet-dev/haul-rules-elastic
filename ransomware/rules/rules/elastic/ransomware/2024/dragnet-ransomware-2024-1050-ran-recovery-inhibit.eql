// Dragnet [Ransomware]: dragnet-ransomware-2024-1050 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 6f73dd49-75a7-5e2c-bfbf-c31321fdbd71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
