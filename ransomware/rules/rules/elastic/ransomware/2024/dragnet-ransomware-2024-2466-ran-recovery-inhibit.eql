// Dragnet [Ransomware]: dragnet-ransomware-2024-2466 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: fc1cd12c-d089-5d6c-80cb-5c116ff42219

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
