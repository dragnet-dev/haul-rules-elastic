// Dragnet [Ransomware]: dragnet-ransomware-2024-1297 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: de1000cc-59cd-5d29-84d8-f6386dc1d825

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
