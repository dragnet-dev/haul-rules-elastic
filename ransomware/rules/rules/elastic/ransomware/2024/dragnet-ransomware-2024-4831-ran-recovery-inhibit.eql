// Dragnet [Ransomware]: dragnet-ransomware-2024-4831 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2b5dbe9a-99e4-5af4-b40e-26813e1384a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
