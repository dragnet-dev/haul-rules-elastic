// Dragnet [Ransomware]: dragnet-ransomware-2024-5732 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9868d093-a04a-5e86-adf6-a0b2012c5216

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
