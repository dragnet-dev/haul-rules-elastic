// Dragnet [Ransomware]: dragnet-ransomware-2024-4044 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 7d6af5e3-05a7-5c8e-8a56-19c12027cc2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
