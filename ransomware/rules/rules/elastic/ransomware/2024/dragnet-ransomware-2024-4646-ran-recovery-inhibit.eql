// Dragnet [Ransomware]: dragnet-ransomware-2024-4646 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: e0eb1635-7ee9-5aad-a7f9-57945d3d601b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
