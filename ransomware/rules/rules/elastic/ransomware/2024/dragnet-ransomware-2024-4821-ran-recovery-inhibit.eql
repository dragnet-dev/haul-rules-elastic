// Dragnet [Ransomware]: dragnet-ransomware-2024-4821 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: a4d90a5e-81db-5a6d-9fd7-99a89eec7846

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
