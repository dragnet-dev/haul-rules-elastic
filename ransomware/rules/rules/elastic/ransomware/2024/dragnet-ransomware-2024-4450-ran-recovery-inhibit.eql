// Dragnet [Ransomware]: dragnet-ransomware-2024-4450 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 4e4fd18a-a904-52ae-b8a5-b8bfa2e82471

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
