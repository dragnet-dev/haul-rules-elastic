// Dragnet [Ransomware]: dragnet-ransomware-2024-5883 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2f5e8a30-f311-508a-a4d1-29c10f034ef5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
