// Dragnet [Ransomware]: dragnet-ransomware-2024-4904 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 462f1ad5-27a2-5490-bb7c-954a22834b2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
