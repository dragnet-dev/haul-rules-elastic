// Dragnet [Ransomware]: dragnet-ransomware-2024-5926 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 9964a0bb-6167-513f-9528-9e8f17ef074a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
