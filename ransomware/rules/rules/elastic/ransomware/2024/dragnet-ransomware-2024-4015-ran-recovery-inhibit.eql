// Dragnet [Ransomware]: dragnet-ransomware-2024-4015 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 0633cf31-ef7b-5dbb-86b0-f13b49efee7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
