// Dragnet [Ransomware]: dragnet-ransomware-2024-0967 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 2376ca71-2c1d-5139-8ff2-b9d9d01d1e8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
