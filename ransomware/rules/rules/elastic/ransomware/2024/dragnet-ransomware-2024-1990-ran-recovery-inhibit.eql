// Dragnet [Ransomware]: dragnet-ransomware-2024-1990 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 33bb1dee-c646-5700-a100-a705f0818b69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
