// Dragnet [Ransomware]: dragnet-ransomware-2024-4343 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 77f7abcf-650a-5ed0-a02b-bb4381f2a214

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
