// Dragnet [Ransomware]: dragnet-ransomware-2024-2600 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: e025ea16-0cdb-5b19-a529-8f28f2ca05a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
