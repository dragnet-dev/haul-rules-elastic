// Dragnet [Ransomware]: dragnet-ransomware-2024-3433 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 324b8678-e57d-53b7-9738-e44f48b0e907

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
