// Dragnet [Ransomware]: dragnet-ransomware-2024-1881 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 638651ff-b167-55a7-9462-4c2fac75d88b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
