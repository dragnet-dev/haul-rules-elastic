// Dragnet [Ransomware]: dragnet-ransomware-2024-2736 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 802c3f11-37ff-52e5-a255-e4b82f982979

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
