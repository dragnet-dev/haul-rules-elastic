// Dragnet [Ransomware]: dragnet-ransomware-2024-0206 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: afc78452-aac9-57f7-b299-dc1be447bb48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
