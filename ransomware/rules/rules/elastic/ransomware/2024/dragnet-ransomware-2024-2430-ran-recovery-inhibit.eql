// Dragnet [Ransomware]: dragnet-ransomware-2024-2430 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 152bb7fa-f97a-5cf6-ae16-56793c390f2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
