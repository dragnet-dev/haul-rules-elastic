// Dragnet [Ransomware]: dragnet-ransomware-2024-4390 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: fc7ab018-4820-5e89-8bec-6d461a47a0b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
