// Dragnet [Ransomware]: dragnet-ransomware-2024-2565 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 879b4022-8342-5dc2-83cf-0e7d935d8017

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
