// Dragnet [Ransomware]: dragnet-ransomware-2024-1012 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 30ea3825-f20b-52e3-a1dd-58c827df4764

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
