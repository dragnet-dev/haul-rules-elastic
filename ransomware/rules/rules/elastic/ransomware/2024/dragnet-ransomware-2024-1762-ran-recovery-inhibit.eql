// Dragnet [Ransomware]: dragnet-ransomware-2024-1762 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0f2e8bc6-eb53-50bf-808d-1914b78de792

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
