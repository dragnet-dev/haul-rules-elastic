// Dragnet [Ransomware]: dragnet-ransomware-2024-6037 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6ad2ecce-b1e1-5161-986c-25be7ad728b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
