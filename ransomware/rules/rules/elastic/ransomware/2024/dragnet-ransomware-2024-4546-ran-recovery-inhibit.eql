// Dragnet [Ransomware]: dragnet-ransomware-2024-4546 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 72790e99-e520-55a6-9c05-03f22e6fed32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
