// Dragnet [Ransomware]: dragnet-ransomware-2024-5499 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: e59639a0-a23d-5d45-81ff-d0800245eca8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
