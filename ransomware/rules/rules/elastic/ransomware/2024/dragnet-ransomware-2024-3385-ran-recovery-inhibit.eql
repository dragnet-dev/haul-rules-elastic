// Dragnet [Ransomware]: dragnet-ransomware-2024-3385 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: ea815b00-2727-56ba-b442-d135ba54d269

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
