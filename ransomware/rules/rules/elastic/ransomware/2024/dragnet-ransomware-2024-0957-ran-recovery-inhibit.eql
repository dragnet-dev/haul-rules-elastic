// Dragnet [Ransomware]: dragnet-ransomware-2024-0957 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 655c38e7-31c7-568a-98b2-707e9b78819a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
