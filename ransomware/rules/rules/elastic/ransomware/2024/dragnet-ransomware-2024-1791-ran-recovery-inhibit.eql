// Dragnet [Ransomware]: dragnet-ransomware-2024-1791 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: cd6145de-c7f4-588c-987f-4d0092ecb451

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
