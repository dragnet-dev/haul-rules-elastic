// Dragnet [Ransomware]: dragnet-ransomware-2024-1336 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f9eeb5e0-d17c-5947-8ff6-687c81e4d2db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
