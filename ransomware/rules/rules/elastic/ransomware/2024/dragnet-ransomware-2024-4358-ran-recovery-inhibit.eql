// Dragnet [Ransomware]: dragnet-ransomware-2024-4358 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8b267610-84a0-5350-931a-6f9e96387941

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
