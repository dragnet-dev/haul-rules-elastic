// Dragnet [Ransomware]: dragnet-ransomware-2024-4033 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 9ffd9cdc-edf5-5d27-9e5e-878a63fa9321

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
