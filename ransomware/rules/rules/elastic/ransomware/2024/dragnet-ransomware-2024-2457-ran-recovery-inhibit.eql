// Dragnet [Ransomware]: dragnet-ransomware-2024-2457 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b98a9f4d-ced6-5e16-8575-d0a400c6cf0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
