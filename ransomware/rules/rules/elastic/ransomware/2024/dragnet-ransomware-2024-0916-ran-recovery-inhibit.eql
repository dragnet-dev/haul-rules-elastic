// Dragnet [Ransomware]: dragnet-ransomware-2024-0916 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: e7902321-8ad8-58d7-8866-e56ae500eb46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
