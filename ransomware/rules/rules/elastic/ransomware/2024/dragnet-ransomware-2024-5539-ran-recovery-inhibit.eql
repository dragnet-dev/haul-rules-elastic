// Dragnet [Ransomware]: dragnet-ransomware-2024-5539 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 0a933597-e180-5865-8a96-e33f8c0788b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
