// Dragnet [Ransomware]: dragnet-ransomware-2024-5187 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 2dd29641-d2f5-5649-a856-94736533f66d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
