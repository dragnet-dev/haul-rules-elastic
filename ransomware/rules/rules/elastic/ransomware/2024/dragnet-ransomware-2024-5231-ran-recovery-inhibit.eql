// Dragnet [Ransomware]: dragnet-ransomware-2024-5231 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 38c1a79e-690a-5861-b29d-9dfb86ce8d18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
