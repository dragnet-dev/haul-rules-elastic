// Dragnet [Ransomware]: dragnet-ransomware-2024-5653 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 4dac3703-8c0d-5227-941b-c6728e431eed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
