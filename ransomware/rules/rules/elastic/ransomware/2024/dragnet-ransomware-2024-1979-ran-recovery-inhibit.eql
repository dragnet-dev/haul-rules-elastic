// Dragnet [Ransomware]: dragnet-ransomware-2024-1979 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 7465a42e-1069-5fd2-84ed-db59bf429d86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
