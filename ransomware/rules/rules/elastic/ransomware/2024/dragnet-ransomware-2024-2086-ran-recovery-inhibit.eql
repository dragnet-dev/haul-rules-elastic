// Dragnet [Ransomware]: dragnet-ransomware-2024-2086 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 39e8dd24-b5e8-5e00-9c13-ea3a0c49dd05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
