// Dragnet [Ransomware]: dragnet-ransomware-2024-3815 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 571e53a7-64ca-5711-a6b6-4b68b809fc5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
