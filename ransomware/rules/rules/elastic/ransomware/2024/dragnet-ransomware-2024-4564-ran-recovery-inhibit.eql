// Dragnet [Ransomware]: dragnet-ransomware-2024-4564 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 48d415c2-3a70-5d33-afba-c4e6c99c7227

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
