// Dragnet [Ransomware]: dragnet-ransomware-2024-4832 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 9f1ea773-20b1-5697-829d-90fdc968fbd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
