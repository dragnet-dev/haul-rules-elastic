// Dragnet [Ransomware]: dragnet-ransomware-2024-1223 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b0da83d7-a9f2-5bc4-8a60-a78c7d77c35b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
