// Dragnet [Ransomware]: dragnet-ransomware-2024-0591 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: d7dae070-e09c-56a9-a674-fe5629840ba1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
