// Dragnet [Ransomware]: dragnet-ransomware-2024-2910 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 214a56af-79f9-5adc-9835-80e3fd06e914

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
