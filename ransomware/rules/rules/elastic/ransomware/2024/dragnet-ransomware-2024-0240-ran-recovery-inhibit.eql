// Dragnet [Ransomware]: dragnet-ransomware-2024-0240 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 4a41c401-e2bf-5b7c-9a3f-888a1190307d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
