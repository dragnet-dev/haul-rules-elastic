// Dragnet [Ransomware]: dragnet-ransomware-2024-5998 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: e9faa599-f462-52fc-8b85-ff09152b671a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
