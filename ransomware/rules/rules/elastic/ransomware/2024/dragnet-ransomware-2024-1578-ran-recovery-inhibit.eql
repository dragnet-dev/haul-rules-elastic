// Dragnet [Ransomware]: dragnet-ransomware-2024-1578 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7e77f345-691d-5dee-a6f0-23411af9b754

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
