// Dragnet [Ransomware]: dragnet-ransomware-2024-3004 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: fd091008-6307-55e0-ab52-f98d32f6883b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
