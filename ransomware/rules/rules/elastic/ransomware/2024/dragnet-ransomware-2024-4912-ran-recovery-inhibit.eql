// Dragnet [Ransomware]: dragnet-ransomware-2024-4912 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 7f4203c5-3fd0-5703-849f-3e573c741eaa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
