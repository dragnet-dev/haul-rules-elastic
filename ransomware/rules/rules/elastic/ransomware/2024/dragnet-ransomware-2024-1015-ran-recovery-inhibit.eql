// Dragnet [Ransomware]: dragnet-ransomware-2024-1015 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: bc44ffd9-445f-5d9b-b477-4b69f67c9a9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
