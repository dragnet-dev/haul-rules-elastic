// Dragnet [Ransomware]: dragnet-ransomware-2024-0837 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: b7384807-0680-5418-ad34-b93d41055939

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
