// Dragnet [Ransomware]: dragnet-ransomware-2024-1268 — Recovery Inhibition (sensayq)
// Status: experimental | Level: high | ID: 4650fac1-1e9c-5baa-871d-d41b11a81d6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
