// Dragnet [Ransomware]: dragnet-ransomware-2024-2012 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 37fa42e2-9dc2-50a3-92a5-c919087aff57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
