// Dragnet [Ransomware]: dragnet-ransomware-2024-2869 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 6a6e70ca-900b-5634-a2f4-146152ee6746

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
