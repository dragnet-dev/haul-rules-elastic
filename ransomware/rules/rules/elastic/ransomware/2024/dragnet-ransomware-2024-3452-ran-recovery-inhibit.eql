// Dragnet [Ransomware]: dragnet-ransomware-2024-3452 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 31b110e2-f873-5b2f-be6f-4c743e478d85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
