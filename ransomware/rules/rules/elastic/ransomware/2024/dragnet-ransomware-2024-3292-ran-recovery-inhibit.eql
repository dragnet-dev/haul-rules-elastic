// Dragnet [Ransomware]: dragnet-ransomware-2024-3292 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 5694b2ed-a069-5e82-8236-3d2bd4e9316f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
