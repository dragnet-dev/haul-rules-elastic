// Dragnet [Ransomware]: dragnet-ransomware-2024-0342 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 02948483-1e5b-556a-96ac-edcf7836752f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
