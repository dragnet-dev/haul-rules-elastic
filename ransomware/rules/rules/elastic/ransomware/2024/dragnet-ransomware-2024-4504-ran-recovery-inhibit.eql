// Dragnet [Ransomware]: dragnet-ransomware-2024-4504 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 28dfc40e-7d0b-51df-9be9-62e6d87c4409

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
