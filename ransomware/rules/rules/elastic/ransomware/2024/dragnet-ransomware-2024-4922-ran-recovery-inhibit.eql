// Dragnet [Ransomware]: dragnet-ransomware-2024-4922 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 4348a9c7-dfa0-599e-82c7-9f0f294a86fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
