// Dragnet [Ransomware]: dragnet-ransomware-2024-4854 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: ed69b9da-b66a-5307-81bc-d53a479b9d0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
