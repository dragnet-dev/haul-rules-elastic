// Dragnet [Ransomware]: dragnet-ransomware-2024-5433 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 50ec7621-a900-59c9-8a08-6223cadd130a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
