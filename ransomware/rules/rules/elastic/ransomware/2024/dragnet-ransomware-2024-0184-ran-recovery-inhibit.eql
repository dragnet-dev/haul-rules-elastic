// Dragnet [Ransomware]: dragnet-ransomware-2024-0184 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 91e15787-4d90-52f0-8f21-338c3d75a561

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
