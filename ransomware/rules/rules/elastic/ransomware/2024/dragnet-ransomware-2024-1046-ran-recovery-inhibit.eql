// Dragnet [Ransomware]: dragnet-ransomware-2024-1046 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 33b64e5f-bada-5f9a-90ac-a49e1f717257

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
