// Dragnet [Ransomware]: dragnet-ransomware-2024-0788 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 1926ee63-bc10-54af-b929-f26ea0988c49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
