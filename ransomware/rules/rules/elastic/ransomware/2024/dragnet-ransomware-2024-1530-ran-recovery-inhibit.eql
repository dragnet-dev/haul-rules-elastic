// Dragnet [Ransomware]: dragnet-ransomware-2024-1530 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 82a91b43-f1d8-5c73-9b17-a27b40d5bf15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
