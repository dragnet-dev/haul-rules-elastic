// Dragnet [Ransomware]: dragnet-ransomware-2024-3162 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 44e970db-e1a8-5ed8-b6a5-657764f16b78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
