// Dragnet [Ransomware]: dragnet-ransomware-2024-4338 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 686cb5ba-150f-50ca-987c-0954a095603a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
