// Dragnet [Ransomware]: dragnet-ransomware-2024-0353 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6a69f348-d426-5785-bebd-05e123d5f049

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
