// Dragnet [Ransomware]: dragnet-ransomware-2024-5520 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 1e911deb-5cf9-5dcf-a572-f5d55a703037

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
