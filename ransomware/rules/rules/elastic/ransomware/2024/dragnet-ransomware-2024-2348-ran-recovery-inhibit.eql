// Dragnet [Ransomware]: dragnet-ransomware-2024-2348 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 4dabe0a3-7b4d-5f42-a759-c77b634e42f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
