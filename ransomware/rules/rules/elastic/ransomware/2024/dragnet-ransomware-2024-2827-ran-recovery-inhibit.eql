// Dragnet [Ransomware]: dragnet-ransomware-2024-2827 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 52c0a632-9616-52cb-903a-57e9ce448a49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
