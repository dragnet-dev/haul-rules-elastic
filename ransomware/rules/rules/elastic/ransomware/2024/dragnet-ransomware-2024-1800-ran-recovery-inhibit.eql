// Dragnet [Ransomware]: dragnet-ransomware-2024-1800 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 69cba190-abe0-5df3-ab35-74766a43489d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
