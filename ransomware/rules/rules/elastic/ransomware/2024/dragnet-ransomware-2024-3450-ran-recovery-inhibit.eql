// Dragnet [Ransomware]: dragnet-ransomware-2024-3450 — Recovery Inhibition (qiulong)
// Status: experimental | Level: high | ID: e51c3269-1a6f-56d1-a0d0-9a6f7ea0faae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
