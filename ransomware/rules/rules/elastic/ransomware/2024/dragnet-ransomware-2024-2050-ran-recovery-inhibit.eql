// Dragnet [Ransomware]: dragnet-ransomware-2024-2050 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8a2be7c9-e5ec-515c-adb9-69cb6de5ec86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
