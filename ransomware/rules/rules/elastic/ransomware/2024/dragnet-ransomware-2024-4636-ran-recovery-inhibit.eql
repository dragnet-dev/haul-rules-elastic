// Dragnet [Ransomware]: dragnet-ransomware-2024-4636 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 37af7b01-022e-5e94-a7b4-f8099db3495f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
