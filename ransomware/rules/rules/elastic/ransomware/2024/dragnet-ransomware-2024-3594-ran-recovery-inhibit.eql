// Dragnet [Ransomware]: dragnet-ransomware-2024-3594 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5db4e612-7f55-59c6-8543-41ac4b6a67a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
