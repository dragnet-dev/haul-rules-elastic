// Dragnet [Ransomware]: dragnet-ransomware-2024-1943 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 64da5521-7810-5104-8fb2-169771672946

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
