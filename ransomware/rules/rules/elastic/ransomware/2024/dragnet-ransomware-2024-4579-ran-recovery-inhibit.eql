// Dragnet [Ransomware]: dragnet-ransomware-2024-4579 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 7904483b-4ab0-5793-aaba-e6136a6a55c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
