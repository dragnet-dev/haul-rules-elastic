// Dragnet [Ransomware]: dragnet-ransomware-2024-5550 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 84ebe213-de68-545e-9ec2-a767d70aacc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
