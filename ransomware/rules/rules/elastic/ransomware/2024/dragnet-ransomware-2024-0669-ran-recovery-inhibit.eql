// Dragnet [Ransomware]: dragnet-ransomware-2024-0669 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 4674f933-2149-51d5-9517-7070c70a89e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
