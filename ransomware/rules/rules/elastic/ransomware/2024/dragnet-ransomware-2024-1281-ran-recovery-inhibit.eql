// Dragnet [Ransomware]: dragnet-ransomware-2024-1281 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 5c0d86d5-2162-5620-9fb4-56b9de188f14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
