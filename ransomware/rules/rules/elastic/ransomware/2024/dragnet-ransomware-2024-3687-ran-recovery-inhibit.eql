// Dragnet [Ransomware]: dragnet-ransomware-2024-3687 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5ab75f81-cb4a-58de-99bc-6b937bee2b8f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
