// Dragnet [Ransomware]: dragnet-ransomware-2024-1339 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 55f74617-0a67-502b-b5e8-fb82dd9609fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
