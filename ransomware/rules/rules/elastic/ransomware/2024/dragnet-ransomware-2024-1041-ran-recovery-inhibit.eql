// Dragnet [Ransomware]: dragnet-ransomware-2024-1041 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: d129a553-0b15-52fa-95f1-e0ffda936a03

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
