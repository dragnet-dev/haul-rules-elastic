// Dragnet [Ransomware]: dragnet-ransomware-2024-3075 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 61e99b42-1b67-595b-9959-2fa419a5a306

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
