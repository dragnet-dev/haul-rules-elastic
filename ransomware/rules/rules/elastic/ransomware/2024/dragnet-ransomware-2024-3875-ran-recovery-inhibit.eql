// Dragnet [Ransomware]: dragnet-ransomware-2024-3875 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 35e799db-4020-5f0e-9d96-2a8501fb477c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
