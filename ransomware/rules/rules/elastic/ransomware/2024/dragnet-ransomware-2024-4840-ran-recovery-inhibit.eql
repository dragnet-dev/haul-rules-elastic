// Dragnet [Ransomware]: dragnet-ransomware-2024-4840 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 308dae1d-6b44-586d-906c-9913d9b7c7e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
