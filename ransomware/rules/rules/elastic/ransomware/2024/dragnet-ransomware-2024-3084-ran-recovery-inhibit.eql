// Dragnet [Ransomware]: dragnet-ransomware-2024-3084 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 2f420bd3-6fcd-5d6e-8180-d9d40e6d4b01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
