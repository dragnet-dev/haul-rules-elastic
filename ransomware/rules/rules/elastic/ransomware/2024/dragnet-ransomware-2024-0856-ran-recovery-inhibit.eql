// Dragnet [Ransomware]: dragnet-ransomware-2024-0856 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: b7620fa1-7d07-502a-8697-614bcf9c301a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
