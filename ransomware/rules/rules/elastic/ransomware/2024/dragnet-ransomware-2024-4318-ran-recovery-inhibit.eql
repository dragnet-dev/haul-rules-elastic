// Dragnet [Ransomware]: dragnet-ransomware-2024-4318 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 2ada5fcf-cb5e-5efe-9132-2aeb701d2c63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
