// Dragnet [Ransomware]: dragnet-ransomware-2024-4308 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: d2fb64fc-c5df-5ca0-8277-a0a289a9bb48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
