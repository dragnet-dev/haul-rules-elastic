// Dragnet [Ransomware]: dragnet-ransomware-2024-1995 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 14300f8f-8d49-5fc5-aef7-a49d8caa5bca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
