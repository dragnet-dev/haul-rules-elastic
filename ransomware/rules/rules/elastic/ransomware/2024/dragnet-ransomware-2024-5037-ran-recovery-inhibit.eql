// Dragnet [Ransomware]: dragnet-ransomware-2024-5037 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 18f95e11-2947-5493-873f-a2543b38e3cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
