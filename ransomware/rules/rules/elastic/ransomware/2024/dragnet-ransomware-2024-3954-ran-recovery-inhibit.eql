// Dragnet [Ransomware]: dragnet-ransomware-2024-3954 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4477de16-42fc-54b3-9e81-34307094a4ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
