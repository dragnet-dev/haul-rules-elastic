// Dragnet [Ransomware]: dragnet-ransomware-2024-0115 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: e3556012-1716-5f53-aa4d-259bdd0abb2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
