// Dragnet [Ransomware]: dragnet-ransomware-2024-3438 — Recovery Inhibition (trinity)
// Status: experimental | Level: high | ID: 6f65c206-30b6-5d04-ab11-c65be2befa79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
