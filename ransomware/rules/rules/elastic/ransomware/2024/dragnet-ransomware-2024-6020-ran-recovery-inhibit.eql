// Dragnet [Ransomware]: dragnet-ransomware-2024-6020 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 5c688c3e-b39d-5223-b563-077a4a9382ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
