// Dragnet [Ransomware]: dragnet-ransomware-2024-1996 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: f13a8046-748b-5735-a990-37702fda3b4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
