// Dragnet [Ransomware]: dragnet-ransomware-2024-3854 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: c8af744a-de4f-538f-a1e9-924c17798faa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
