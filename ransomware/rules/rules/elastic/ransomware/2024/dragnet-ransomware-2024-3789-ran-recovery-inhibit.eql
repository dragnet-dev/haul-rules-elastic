// Dragnet [Ransomware]: dragnet-ransomware-2024-3789 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 3fdfeedc-00bd-55f1-9a70-f08cd9099db8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
