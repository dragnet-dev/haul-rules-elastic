// Dragnet [Ransomware]: dragnet-ransomware-2024-3347 — Recovery Inhibition (madliberator)
// Status: experimental | Level: high | ID: b24ad924-5b58-5474-a4b1-213f135ed360

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
