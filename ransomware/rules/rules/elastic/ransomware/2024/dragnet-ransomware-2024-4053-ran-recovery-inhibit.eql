// Dragnet [Ransomware]: dragnet-ransomware-2024-4053 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2aa293b3-1415-5248-9f1f-9e630fa43523

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
