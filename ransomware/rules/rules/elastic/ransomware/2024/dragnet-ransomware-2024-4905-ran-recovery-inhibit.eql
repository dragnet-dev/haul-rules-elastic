// Dragnet [Ransomware]: dragnet-ransomware-2024-4905 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 050e52ba-6f27-5213-9cf3-dea73367efbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
