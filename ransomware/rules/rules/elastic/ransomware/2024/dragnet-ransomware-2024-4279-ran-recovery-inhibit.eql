// Dragnet [Ransomware]: dragnet-ransomware-2024-4279 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2525999b-6324-586c-b68b-456ee63f9dbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
