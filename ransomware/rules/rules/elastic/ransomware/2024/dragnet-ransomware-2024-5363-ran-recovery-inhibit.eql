// Dragnet [Ransomware]: dragnet-ransomware-2024-5363 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: e4b5306c-90ba-5bda-bf11-2cf160f8182f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
