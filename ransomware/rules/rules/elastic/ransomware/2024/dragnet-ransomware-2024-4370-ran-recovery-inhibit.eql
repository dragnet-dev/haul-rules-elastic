// Dragnet [Ransomware]: dragnet-ransomware-2024-4370 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 83c62d31-118c-5d98-b3b6-3bcece6b63d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
