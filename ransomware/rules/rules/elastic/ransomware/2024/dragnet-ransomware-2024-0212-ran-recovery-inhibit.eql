// Dragnet [Ransomware]: dragnet-ransomware-2024-0212 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d03f6fa5-d9fa-59bb-9c44-cc11e229a3f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
