// Dragnet [Ransomware]: dragnet-ransomware-2024-4998 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 1b154d14-edc5-5bb3-a2d6-c3e5c190d058

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
