// Dragnet [Ransomware]: dragnet-ransomware-2024-2255 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f0b61cf0-c7c6-5d50-a6ba-e1f8fc34639d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
