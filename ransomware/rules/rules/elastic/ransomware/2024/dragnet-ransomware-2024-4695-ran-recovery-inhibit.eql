// Dragnet [Ransomware]: dragnet-ransomware-2024-4695 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: d848664e-f37b-5793-8d83-2e00c6b29065

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
