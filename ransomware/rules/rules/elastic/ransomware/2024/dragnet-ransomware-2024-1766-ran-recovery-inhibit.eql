// Dragnet [Ransomware]: dragnet-ransomware-2024-1766 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 5abecf9f-bdb3-54d4-b66f-4fa2f23dcdd3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
