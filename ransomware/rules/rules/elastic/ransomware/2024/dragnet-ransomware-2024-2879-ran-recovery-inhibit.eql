// Dragnet [Ransomware]: dragnet-ransomware-2024-2879 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: dc02fdf2-9efe-5dc7-a4a7-0ebef9589d66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
