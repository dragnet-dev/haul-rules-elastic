// Dragnet [Ransomware]: dragnet-ransomware-2024-5268 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: fb13bda9-ee83-508a-9c7c-11db0ef1b387

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
