// Dragnet [Ransomware]: dragnet-ransomware-2024-5573 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 96bffdf6-dec0-591d-881f-dc2b01111d0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
