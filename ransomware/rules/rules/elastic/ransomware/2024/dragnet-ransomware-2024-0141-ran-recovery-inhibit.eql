// Dragnet [Ransomware]: dragnet-ransomware-2024-0141 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: b372f497-4bd5-5a3f-8513-3b2edd0f6efc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
