// Dragnet [Ransomware]: dragnet-ransomware-2024-2018 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: ec46c8e1-8595-5202-98e2-99422e2c1b98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
