// Dragnet [Ransomware]: dragnet-ransomware-2024-4436 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 2ce273b5-6fb4-5c88-a2b8-13ded90a8aef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
