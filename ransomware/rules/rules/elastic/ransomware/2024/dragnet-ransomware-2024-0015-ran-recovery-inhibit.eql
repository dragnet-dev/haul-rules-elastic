// Dragnet [Ransomware]: dragnet-ransomware-2024-0015 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e8d79f06-95ab-5f78-bde1-edd3fd3b978d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
