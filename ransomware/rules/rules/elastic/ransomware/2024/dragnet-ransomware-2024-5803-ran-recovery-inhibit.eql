// Dragnet [Ransomware]: dragnet-ransomware-2024-5803 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 7b49798c-953c-5797-a80f-fe1c4015ddae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
