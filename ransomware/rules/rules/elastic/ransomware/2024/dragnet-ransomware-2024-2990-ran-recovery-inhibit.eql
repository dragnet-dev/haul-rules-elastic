// Dragnet [Ransomware]: dragnet-ransomware-2024-2990 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 772b32bd-3e45-51e2-8d1f-b6901db0e890

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
