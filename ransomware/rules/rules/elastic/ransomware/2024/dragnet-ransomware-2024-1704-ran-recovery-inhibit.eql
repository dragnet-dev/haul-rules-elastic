// Dragnet [Ransomware]: dragnet-ransomware-2024-1704 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8e2033e5-c2de-5a11-af6d-679e4685b212

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
