// Dragnet [Ransomware]: dragnet-ransomware-2024-0281 — Recovery Inhibition (unsafe)
// Status: deprecated | Level: high | ID: ded82ce2-185d-58e4-8899-2bd43191eefb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
