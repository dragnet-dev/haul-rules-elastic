// Dragnet [Ransomware]: dragnet-ransomware-2024-0592 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 45e52c59-503a-55b6-b1c4-c726bbbaa1e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
