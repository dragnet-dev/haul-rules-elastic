// Dragnet [Ransomware]: dragnet-ransomware-2024-0328 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f8fca3b3-e3ea-5223-bafd-d4cd18e2bfc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
