// Dragnet [Ransomware]: dragnet-ransomware-2024-1090 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c802f031-bcdb-5d7a-acc8-236ae79f1b04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
