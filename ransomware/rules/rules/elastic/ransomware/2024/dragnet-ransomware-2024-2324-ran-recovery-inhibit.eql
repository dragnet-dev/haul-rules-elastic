// Dragnet [Ransomware]: dragnet-ransomware-2024-2324 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a6a6fcba-7aea-5cf7-a502-db78d9faef35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
