// Dragnet [Ransomware]: dragnet-ransomware-2024-2512 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: edccec5b-bb90-5d18-8b41-b4576787e392

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
