// Dragnet [Ransomware]: dragnet-ransomware-2024-0231 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c82dbfef-3d96-5174-b4fd-5801e6a4ab71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
