// Dragnet [Ransomware]: dragnet-ransomware-2024-2023 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 64a4d509-b0cb-5d83-8633-cabdf41f2f5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
