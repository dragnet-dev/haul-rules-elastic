// Dragnet [Ransomware]: dragnet-ransomware-2024-3008 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: be1380eb-ec29-5d2d-b04f-cbe1b68c7445

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
