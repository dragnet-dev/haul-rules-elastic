// Dragnet [Ransomware]: dragnet-ransomware-2024-3769 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: 5c2183df-2b20-53c7-a086-1af44322a59f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
