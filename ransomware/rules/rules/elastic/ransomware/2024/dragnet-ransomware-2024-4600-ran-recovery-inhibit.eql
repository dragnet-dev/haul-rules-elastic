// Dragnet [Ransomware]: dragnet-ransomware-2024-4600 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6ead27c2-2c5a-510f-aef5-1f6cb20e42f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
