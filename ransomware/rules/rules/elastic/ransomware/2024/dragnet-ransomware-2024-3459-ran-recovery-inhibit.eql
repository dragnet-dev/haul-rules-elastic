// Dragnet [Ransomware]: dragnet-ransomware-2024-3459 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3113bc0e-c452-5197-ac62-65042b937c9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
