// Dragnet [Ransomware]: dragnet-ransomware-2024-2647 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 027aa6e5-6cff-537a-ade7-b97030b6c889

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
