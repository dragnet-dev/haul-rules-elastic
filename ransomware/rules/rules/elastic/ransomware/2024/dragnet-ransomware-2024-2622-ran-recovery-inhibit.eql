// Dragnet [Ransomware]: dragnet-ransomware-2024-2622 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 516cd963-a2d3-5ed6-be77-eaac237e1d9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
