// Dragnet [Ransomware]: dragnet-ransomware-2024-3066 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f414de20-84cb-571c-861d-6e6a8835bd94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
