// Dragnet [Ransomware]: dragnet-ransomware-2024-0368 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 49087e9c-6f16-5bc7-9fe8-8ca64dc32285

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
