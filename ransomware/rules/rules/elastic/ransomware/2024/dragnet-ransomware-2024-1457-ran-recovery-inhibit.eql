// Dragnet [Ransomware]: dragnet-ransomware-2024-1457 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d514cba5-0764-5bb8-be62-4cd5c649483d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
