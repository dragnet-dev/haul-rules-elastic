// Dragnet [Ransomware]: dragnet-ransomware-2024-3530 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3adddc7d-5f6d-5dd8-bcc9-c4efb79eaf45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
