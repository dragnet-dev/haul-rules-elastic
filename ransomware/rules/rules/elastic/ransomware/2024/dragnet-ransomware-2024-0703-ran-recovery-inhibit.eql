// Dragnet [Ransomware]: dragnet-ransomware-2024-0703 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ff3842b7-60ca-5a19-8801-cbb86c10bd41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
