// Dragnet [Ransomware]: dragnet-ransomware-2024-0707 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1e9112dc-9c3e-53d9-8ea6-bb9332eb89c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
