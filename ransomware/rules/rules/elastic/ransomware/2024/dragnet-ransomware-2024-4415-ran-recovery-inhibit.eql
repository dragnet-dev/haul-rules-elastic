// Dragnet [Ransomware]: dragnet-ransomware-2024-4415 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 724696bf-e153-5ab2-b87d-33b6bf257adc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
