// Dragnet [Ransomware]: dragnet-ransomware-2024-4929 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 881bf566-9fed-5ccf-8c08-8df313e745a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
