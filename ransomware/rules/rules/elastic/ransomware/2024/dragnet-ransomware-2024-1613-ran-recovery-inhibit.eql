// Dragnet [Ransomware]: dragnet-ransomware-2024-1613 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: c7cee5d1-812d-5f4d-9258-7c0fa2c9b480

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
