// Dragnet [Ransomware]: dragnet-ransomware-2024-4903 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 6332b184-b911-54f4-a024-51e3f43bb3df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
