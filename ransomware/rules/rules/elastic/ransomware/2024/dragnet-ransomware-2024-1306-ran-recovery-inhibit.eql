// Dragnet [Ransomware]: dragnet-ransomware-2024-1306 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 48ec757c-40c8-5d6d-8fe2-0e980414a22d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
