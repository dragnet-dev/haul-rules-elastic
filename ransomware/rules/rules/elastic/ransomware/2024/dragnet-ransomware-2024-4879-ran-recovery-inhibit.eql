// Dragnet [Ransomware]: dragnet-ransomware-2024-4879 — Recovery Inhibition (dAn0n)
// Status: deprecated | Level: high | ID: a8bbb88e-5f4c-5e6b-9fbc-48ea6b079ccf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
