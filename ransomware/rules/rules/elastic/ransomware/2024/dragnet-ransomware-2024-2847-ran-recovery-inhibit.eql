// Dragnet [Ransomware]: dragnet-ransomware-2024-2847 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 37b9a30a-e669-5d9e-8dd9-6da7e9fa0da8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
