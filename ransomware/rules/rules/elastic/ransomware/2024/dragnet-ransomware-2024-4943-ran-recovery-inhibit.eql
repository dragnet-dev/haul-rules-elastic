// Dragnet [Ransomware]: dragnet-ransomware-2024-4943 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 955e28f0-f079-5dd4-9c68-1c4dfb7703cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
