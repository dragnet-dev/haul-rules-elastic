// Dragnet [Ransomware]: dragnet-ransomware-2024-2642 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a777c0c7-a6b3-5d30-b5bc-15775db78e2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
