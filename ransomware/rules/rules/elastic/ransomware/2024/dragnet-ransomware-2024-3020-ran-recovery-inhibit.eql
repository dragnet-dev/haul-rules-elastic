// Dragnet [Ransomware]: dragnet-ransomware-2024-3020 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f647c11b-f87d-5bb9-87bc-e857effcaf4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
