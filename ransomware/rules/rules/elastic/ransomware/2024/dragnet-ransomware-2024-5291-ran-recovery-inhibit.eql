// Dragnet [Ransomware]: dragnet-ransomware-2024-5291 — Recovery Inhibition (frag)
// Status: deprecated | Level: high | ID: 10b0ba46-c314-5b8d-b625-51fd23d4dd96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
