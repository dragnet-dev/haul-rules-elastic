// Dragnet [Ransomware]: dragnet-ransomware-2024-4726 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: cbeafb28-5ff3-5a3c-a7a4-19794ffe15d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
