// Dragnet [Ransomware]: dragnet-ransomware-2024-5087 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: d4589047-4bf5-5216-b0d5-fd6318f49149

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
