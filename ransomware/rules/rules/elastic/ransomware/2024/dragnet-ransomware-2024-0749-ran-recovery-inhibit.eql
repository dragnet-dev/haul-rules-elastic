// Dragnet [Ransomware]: dragnet-ransomware-2024-0749 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 4cb6723e-2e88-5d94-b224-e30ab19e0a52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
