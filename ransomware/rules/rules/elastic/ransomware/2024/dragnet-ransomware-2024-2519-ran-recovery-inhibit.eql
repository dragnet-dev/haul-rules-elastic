// Dragnet [Ransomware]: dragnet-ransomware-2024-2519 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 81cca983-3331-5eff-806a-d466c317a73c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
