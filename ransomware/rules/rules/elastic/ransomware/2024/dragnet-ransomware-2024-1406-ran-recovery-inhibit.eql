// Dragnet [Ransomware]: dragnet-ransomware-2024-1406 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d47b0f46-90f0-5252-b4d0-72de371dd8e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
