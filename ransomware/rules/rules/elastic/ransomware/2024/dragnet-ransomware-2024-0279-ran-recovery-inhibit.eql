// Dragnet [Ransomware]: dragnet-ransomware-2024-0279 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: 05903cba-2e10-55ac-b260-17fd966e123c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
