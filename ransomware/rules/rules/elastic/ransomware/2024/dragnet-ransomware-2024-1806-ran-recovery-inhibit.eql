// Dragnet [Ransomware]: dragnet-ransomware-2024-1806 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: e721ac3c-326a-5edc-9fc5-9ac99a9a45c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
