// Dragnet [Ransomware]: dragnet-ransomware-2024-0139 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 4e7dd384-210f-5345-8d09-c86669bcb1bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
