// Dragnet [Ransomware]: dragnet-ransomware-2024-2213 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: ffb6baf2-4d09-54f0-a133-ec3151b73f53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
