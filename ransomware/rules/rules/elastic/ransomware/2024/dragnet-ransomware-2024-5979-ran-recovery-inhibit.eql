// Dragnet [Ransomware]: dragnet-ransomware-2024-5979 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5da79b7a-489e-51d2-9462-fa3ede112420

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
