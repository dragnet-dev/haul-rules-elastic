// Dragnet [Ransomware]: dragnet-ransomware-2024-4882 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 816bcfa8-10eb-562f-80a3-4b46d48ddeb9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
