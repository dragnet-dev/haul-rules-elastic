// Dragnet [Ransomware]: dragnet-ransomware-2024-0530 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 6fae03bb-e63e-51e3-b4aa-fb3c02bca892

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
