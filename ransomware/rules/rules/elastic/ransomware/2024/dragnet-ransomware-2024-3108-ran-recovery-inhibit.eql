// Dragnet [Ransomware]: dragnet-ransomware-2024-3108 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 6ca9f95c-6dd2-5dd0-bd29-cd6bb3d69872

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
