// Dragnet [Ransomware]: dragnet-ransomware-2024-1591 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a63105ab-0180-58c6-9296-e2517d719085

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
