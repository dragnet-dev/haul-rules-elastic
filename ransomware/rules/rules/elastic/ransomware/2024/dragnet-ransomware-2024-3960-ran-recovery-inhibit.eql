// Dragnet [Ransomware]: dragnet-ransomware-2024-3960 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 8cbece49-3779-5f2f-8303-876bdba3584b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
