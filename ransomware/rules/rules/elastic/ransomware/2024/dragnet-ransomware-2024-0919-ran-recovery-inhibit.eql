// Dragnet [Ransomware]: dragnet-ransomware-2024-0919 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: da8252bd-d973-5f4c-a9cb-3de1a0ae484a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
