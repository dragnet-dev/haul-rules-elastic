// Dragnet [Ransomware]: dragnet-ransomware-2024-2816 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d8dd644b-ebf9-550f-8957-6894435d3402

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
