// Dragnet [Ransomware]: dragnet-ransomware-2024-3873 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: b082a365-ec85-5ca8-acef-cbf2f9932160

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
