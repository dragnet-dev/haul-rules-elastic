// Dragnet [Ransomware]: dragnet-ransomware-2024-2668 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: defa7068-abe9-54f8-b63d-668436275c95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
