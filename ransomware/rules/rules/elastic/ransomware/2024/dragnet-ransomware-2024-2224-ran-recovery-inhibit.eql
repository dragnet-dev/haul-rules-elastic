// Dragnet [Ransomware]: dragnet-ransomware-2024-2224 — Recovery Inhibition (hellcat)
// Status: deprecated | Level: high | ID: 70303ebc-7b9b-5bb2-9612-2615e6db3515

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
