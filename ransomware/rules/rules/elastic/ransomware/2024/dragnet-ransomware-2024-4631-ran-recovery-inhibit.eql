// Dragnet [Ransomware]: dragnet-ransomware-2024-4631 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ed433a2e-ee72-57c1-92ec-5d708dd49dcc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
