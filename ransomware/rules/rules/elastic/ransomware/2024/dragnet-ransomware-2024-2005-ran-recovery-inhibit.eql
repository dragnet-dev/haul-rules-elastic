// Dragnet [Ransomware]: dragnet-ransomware-2024-2005 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: de12f7c2-f3a3-52d4-80db-87fbeffc5680

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
