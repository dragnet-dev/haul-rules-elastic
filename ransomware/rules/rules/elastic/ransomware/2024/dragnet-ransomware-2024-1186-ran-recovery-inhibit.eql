// Dragnet [Ransomware]: dragnet-ransomware-2024-1186 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: ab0a9fcb-a855-58c7-af11-1da14493c450

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
