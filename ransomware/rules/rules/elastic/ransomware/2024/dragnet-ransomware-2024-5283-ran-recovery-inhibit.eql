// Dragnet [Ransomware]: dragnet-ransomware-2024-5283 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 2f693508-55b2-50e7-a962-0688918e0c75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
