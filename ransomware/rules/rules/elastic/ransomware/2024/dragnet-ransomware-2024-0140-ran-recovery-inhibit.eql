// Dragnet [Ransomware]: dragnet-ransomware-2024-0140 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: b5613c12-26a8-506e-9474-af8e1a611b49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
