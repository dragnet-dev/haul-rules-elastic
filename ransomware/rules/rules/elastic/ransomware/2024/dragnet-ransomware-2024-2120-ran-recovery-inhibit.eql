// Dragnet [Ransomware]: dragnet-ransomware-2024-2120 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: d0de37c7-8a80-5be9-a837-66890b1b0f2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
