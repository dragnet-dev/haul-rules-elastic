// Dragnet [Ransomware]: dragnet-ransomware-2024-0756 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: f74ef5fe-554a-5ddf-b594-1f00a7ffe1f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
