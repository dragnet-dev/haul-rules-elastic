// Dragnet [Ransomware]: dragnet-ransomware-2024-2714 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 1da265a5-3ec7-556c-87b6-00b1671f4539

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
