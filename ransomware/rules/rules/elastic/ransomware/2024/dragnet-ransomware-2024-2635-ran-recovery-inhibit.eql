// Dragnet [Ransomware]: dragnet-ransomware-2024-2635 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1ed58fcf-2b0a-5427-baff-74edc8d38116

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
