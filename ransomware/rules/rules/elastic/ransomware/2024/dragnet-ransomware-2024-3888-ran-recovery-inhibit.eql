// Dragnet [Ransomware]: dragnet-ransomware-2024-3888 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8b32acff-2c6f-5021-a5e0-96a8518136ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
