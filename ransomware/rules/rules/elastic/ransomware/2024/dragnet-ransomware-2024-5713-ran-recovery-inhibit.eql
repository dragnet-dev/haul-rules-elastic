// Dragnet [Ransomware]: dragnet-ransomware-2024-5713 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: bafd9105-af3e-5e1a-bfe9-0eeb5a0f34c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
