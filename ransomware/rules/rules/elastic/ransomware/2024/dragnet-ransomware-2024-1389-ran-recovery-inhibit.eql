// Dragnet [Ransomware]: dragnet-ransomware-2024-1389 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7e2b500e-d7b7-5c41-bf27-8c686ebff020

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
