// Dragnet [Ransomware]: dragnet-ransomware-2024-2243 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 6abc9d5c-43c3-570b-a6c4-60c38b604ba1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
