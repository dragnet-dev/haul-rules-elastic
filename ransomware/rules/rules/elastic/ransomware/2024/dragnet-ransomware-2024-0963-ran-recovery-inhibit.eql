// Dragnet [Ransomware]: dragnet-ransomware-2024-0963 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 341ce0a2-6a68-5e64-ba3a-af6714d9663e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
