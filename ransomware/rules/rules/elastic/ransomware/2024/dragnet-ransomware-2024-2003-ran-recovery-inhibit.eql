// Dragnet [Ransomware]: dragnet-ransomware-2024-2003 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 45c056e9-946a-5cf3-8fb9-cd136692b2dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
