// Dragnet [Ransomware]: dragnet-ransomware-2024-4321 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: cc631ecc-baaf-580d-85a8-ab38a28f9f90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
