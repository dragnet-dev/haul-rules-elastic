// Dragnet [Ransomware]: dragnet-ransomware-2024-3096 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: e798b63c-5e64-5186-9af8-022695f2aa2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
