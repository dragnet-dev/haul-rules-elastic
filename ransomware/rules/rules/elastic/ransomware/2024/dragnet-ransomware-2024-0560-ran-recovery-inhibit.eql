// Dragnet [Ransomware]: dragnet-ransomware-2024-0560 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: bf5153d7-fe9d-5d43-a0ad-1acfd8885e77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
