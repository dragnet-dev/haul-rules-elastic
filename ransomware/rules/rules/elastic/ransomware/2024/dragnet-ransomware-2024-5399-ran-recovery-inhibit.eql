// Dragnet [Ransomware]: dragnet-ransomware-2024-5399 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f931dfbf-8f38-5ff9-9f8a-04360c0db924

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
