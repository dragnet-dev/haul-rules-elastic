// Dragnet [Ransomware]: dragnet-ransomware-2024-5644 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: f31dc372-eea5-5bac-bcaf-777408012ae5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
