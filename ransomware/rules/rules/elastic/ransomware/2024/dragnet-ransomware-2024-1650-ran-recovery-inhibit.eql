// Dragnet [Ransomware]: dragnet-ransomware-2024-1650 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: f36bf838-c6cc-5be5-9ce6-b67da31b0b7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
