// Dragnet [Ransomware]: dragnet-ransomware-2024-2440 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 04a39b6d-4def-5d4f-8100-76197faf5050

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
