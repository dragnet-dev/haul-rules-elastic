// Dragnet [Ransomware]: dragnet-ransomware-2024-2556 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 6de3451c-2482-568d-bf0d-0a3e435255b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
