// Dragnet [Ransomware]: dragnet-ransomware-2024-3026 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: af873eb6-0175-573d-9149-136dd32e6738

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
