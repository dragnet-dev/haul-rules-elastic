// Dragnet [Ransomware]: dragnet-ransomware-2024-5525 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 764e9c6f-ba55-5f93-8833-a0c608b7c82d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
