// Dragnet [Ransomware]: dragnet-ransomware-2024-2947 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 686e8c45-5349-5b79-9688-bee87823247f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
