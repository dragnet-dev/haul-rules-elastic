// Dragnet [Ransomware]: dragnet-ransomware-2024-2427 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: f0babecc-24de-5504-88e5-b0fd64c7b6da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
