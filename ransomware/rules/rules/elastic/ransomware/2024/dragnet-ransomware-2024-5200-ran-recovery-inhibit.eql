// Dragnet [Ransomware]: dragnet-ransomware-2024-5200 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 26d81c9f-93e6-5cb5-91e3-c9121a2c7fa0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
