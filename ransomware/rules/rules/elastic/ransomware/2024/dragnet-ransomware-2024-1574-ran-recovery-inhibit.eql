// Dragnet [Ransomware]: dragnet-ransomware-2024-1574 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 3f0ad20e-ffe3-574a-86ae-744279b26e47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
