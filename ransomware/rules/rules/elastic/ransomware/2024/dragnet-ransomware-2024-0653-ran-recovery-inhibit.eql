// Dragnet [Ransomware]: dragnet-ransomware-2024-0653 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 586e1c8b-b460-50bb-bcf6-39ceec596292

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
