// Dragnet [Ransomware]: dragnet-ransomware-2024-2066 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 3e03f4dc-115d-56e0-b3bb-b5236a122667

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
