// Dragnet [Ransomware]: dragnet-ransomware-2024-1380 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0e4d55c2-2c56-5e18-95e9-0b3359f3eda5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
