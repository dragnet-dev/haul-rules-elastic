// Dragnet [Ransomware]: dragnet-ransomware-2024-3040 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: fad17395-bdf1-505a-b2e8-e9190478e94c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
