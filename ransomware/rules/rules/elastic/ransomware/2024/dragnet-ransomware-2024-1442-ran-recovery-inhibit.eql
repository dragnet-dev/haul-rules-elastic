// Dragnet [Ransomware]: dragnet-ransomware-2024-1442 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 011c88a1-b485-575b-ac6e-a7af133cbe04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
