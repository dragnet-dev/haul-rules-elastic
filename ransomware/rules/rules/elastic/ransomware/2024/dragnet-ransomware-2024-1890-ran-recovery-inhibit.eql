// Dragnet [Ransomware]: dragnet-ransomware-2024-1890 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: eecf3f7a-f25a-5b12-bc17-b6942c97bc93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
