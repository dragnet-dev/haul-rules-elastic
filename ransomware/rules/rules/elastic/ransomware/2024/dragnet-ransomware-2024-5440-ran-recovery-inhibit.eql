// Dragnet [Ransomware]: dragnet-ransomware-2024-5440 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b30f7062-634b-57e2-9c80-1c290172ab43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
