// Dragnet [Ransomware]: dragnet-ransomware-2024-1633 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c9a1a291-bfb6-5eb3-94ec-2d6149351bd6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
