// Dragnet [Ransomware]: dragnet-ransomware-2024-4397 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 9bc6f554-cbda-54f4-872a-9ecbb579461f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
