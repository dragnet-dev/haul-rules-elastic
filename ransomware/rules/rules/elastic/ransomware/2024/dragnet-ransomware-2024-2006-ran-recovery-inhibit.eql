// Dragnet [Ransomware]: dragnet-ransomware-2024-2006 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9722a7e7-cc8c-50d2-abaa-b5bedf54142a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
