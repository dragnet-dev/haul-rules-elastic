// Dragnet [Ransomware]: dragnet-ransomware-2024-4353 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 31a6295a-a652-5196-88a7-2039be13a7db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
