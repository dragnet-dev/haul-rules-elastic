// Dragnet [Ransomware]: dragnet-ransomware-2024-4521 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8333cac8-b741-5265-addd-acb3b8bfd77f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
