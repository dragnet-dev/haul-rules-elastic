// Dragnet [Ransomware]: dragnet-ransomware-2024-2046 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 0ffd3aa8-0bf8-50d5-9992-10c2ee31be07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
