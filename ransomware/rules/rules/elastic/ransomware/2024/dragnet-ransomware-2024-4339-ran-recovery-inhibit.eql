// Dragnet [Ransomware]: dragnet-ransomware-2024-4339 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d1e379bf-5e5d-5d8c-8b21-69085af8d74b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
