// Dragnet [Ransomware]: dragnet-ransomware-2024-2672 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ce2735c1-53e0-5268-9575-9c8d6ea7b72e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
