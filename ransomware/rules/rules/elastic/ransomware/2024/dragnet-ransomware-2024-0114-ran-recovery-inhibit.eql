// Dragnet [Ransomware]: dragnet-ransomware-2024-0114 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 9f6d14e1-49fd-5f9f-9d97-596dc81ae2ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
