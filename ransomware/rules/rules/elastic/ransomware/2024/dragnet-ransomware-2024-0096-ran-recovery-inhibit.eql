// Dragnet [Ransomware]: dragnet-ransomware-2024-0096 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: c1af5af7-c9d0-51ef-bb0e-08ee7e664d21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
