// Dragnet [Ransomware]: dragnet-ransomware-2024-0626 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4cd1a509-2efe-5d7f-b16f-5f4194d81a4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
