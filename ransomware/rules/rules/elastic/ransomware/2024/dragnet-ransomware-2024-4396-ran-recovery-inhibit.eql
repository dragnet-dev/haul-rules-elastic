// Dragnet [Ransomware]: dragnet-ransomware-2024-4396 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 3b605402-7505-5552-9ae3-1c171cf8d9a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
