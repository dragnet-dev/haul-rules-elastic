// Dragnet [Ransomware]: dragnet-ransomware-2024-3414 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: f52a1ffb-0046-50de-9cc0-5f42a143a436

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
