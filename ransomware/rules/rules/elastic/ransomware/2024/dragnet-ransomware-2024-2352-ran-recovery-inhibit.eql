// Dragnet [Ransomware]: dragnet-ransomware-2024-2352 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: ca3b4e52-0f40-5cf9-b2d0-6e8b3b808459

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
