// Dragnet [Ransomware]: dragnet-ransomware-2024-4266 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 70cb0411-4a50-5fbc-964d-9e995ece9720

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
