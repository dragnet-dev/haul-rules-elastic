// Dragnet [Ransomware]: dragnet-ransomware-2024-5373 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: ca98f0cb-5286-58ca-ba6d-1f4e2e53c9a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
