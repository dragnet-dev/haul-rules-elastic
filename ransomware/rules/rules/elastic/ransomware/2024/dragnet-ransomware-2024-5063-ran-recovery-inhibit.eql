// Dragnet [Ransomware]: dragnet-ransomware-2024-5063 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 0d9d9bbe-df55-5f30-a2a7-845538edc670

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
