// Dragnet [Ransomware]: dragnet-ransomware-2024-2657 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6988e63f-b06d-54e7-913e-60db6b564439

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
