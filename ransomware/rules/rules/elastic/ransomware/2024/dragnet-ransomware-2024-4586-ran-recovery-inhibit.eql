// Dragnet [Ransomware]: dragnet-ransomware-2024-4586 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 27c9f7d6-4402-558e-ac2e-b9ded9697f60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
