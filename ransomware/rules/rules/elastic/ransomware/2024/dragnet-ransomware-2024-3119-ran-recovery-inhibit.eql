// Dragnet [Ransomware]: dragnet-ransomware-2024-3119 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d7c30d3e-01ff-532c-ba3a-c92704853f42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
