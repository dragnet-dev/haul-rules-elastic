// Dragnet [Ransomware]: dragnet-ransomware-2024-5406 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: e872d857-515b-5bfc-ba10-678a9c2e7276

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
