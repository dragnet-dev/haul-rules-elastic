// Dragnet [Ransomware]: dragnet-ransomware-2024-0016 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: d7093e32-b948-5e2d-8282-bfdfa518cf04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
