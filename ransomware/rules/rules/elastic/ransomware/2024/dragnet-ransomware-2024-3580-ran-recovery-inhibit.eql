// Dragnet [Ransomware]: dragnet-ransomware-2024-3580 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 1a6a120a-8703-5787-9df4-64d759b9c1df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
