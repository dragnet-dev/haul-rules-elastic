// Dragnet [Ransomware]: dragnet-ransomware-2024-3027 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e67d022e-ddad-5982-b03b-6029f1be6ecb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
