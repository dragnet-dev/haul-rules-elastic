// Dragnet [Ransomware]: dragnet-ransomware-2024-4245 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: f1b5c0bc-f48e-5109-a2be-e441568a10c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
