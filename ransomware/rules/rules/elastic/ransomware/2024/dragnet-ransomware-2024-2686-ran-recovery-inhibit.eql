// Dragnet [Ransomware]: dragnet-ransomware-2024-2686 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 7602cca1-27e6-5e0e-9170-0765f68a81a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
