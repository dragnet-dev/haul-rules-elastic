// Dragnet [Ransomware]: dragnet-ransomware-2024-3073 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 97cad35f-a20b-50b2-840d-b29312b9fb24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
