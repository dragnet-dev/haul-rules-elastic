// Dragnet [Ransomware]: dragnet-ransomware-2024-0526 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cb4f2298-0739-5808-9461-dc85b3545d0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
