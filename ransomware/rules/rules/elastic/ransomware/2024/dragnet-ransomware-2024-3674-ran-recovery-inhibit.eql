// Dragnet [Ransomware]: dragnet-ransomware-2024-3674 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: ab8d5805-c0b1-51fd-aee3-0bcfad6117d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
