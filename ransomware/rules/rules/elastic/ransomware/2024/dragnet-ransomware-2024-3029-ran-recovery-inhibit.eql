// Dragnet [Ransomware]: dragnet-ransomware-2024-3029 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5acef04f-f17a-58c4-ab80-dab70341dfdc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
