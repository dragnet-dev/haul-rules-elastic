// Dragnet [Ransomware]: dragnet-ransomware-2024-4254 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 35391e0e-604d-590b-8939-8ec8f5f8c83b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
