// Dragnet [Ransomware]: dragnet-ransomware-2024-2532 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: c165516d-1778-51b4-b266-9f4b42053c84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
