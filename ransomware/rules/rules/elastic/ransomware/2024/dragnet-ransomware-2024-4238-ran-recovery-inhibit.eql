// Dragnet [Ransomware]: dragnet-ransomware-2024-4238 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 21076253-8ce2-55f3-adb4-7aa75b3990be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
