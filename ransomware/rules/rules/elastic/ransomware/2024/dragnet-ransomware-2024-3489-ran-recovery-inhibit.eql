// Dragnet [Ransomware]: dragnet-ransomware-2024-3489 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: ff6c395b-c7b1-5c7e-ac45-221a18609a94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
