// Dragnet [Ransomware]: dragnet-ransomware-2024-1950 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: a94ecd66-fb33-5461-bc96-a926fe6fb539

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
