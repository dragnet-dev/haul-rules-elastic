// Dragnet [Ransomware]: dragnet-ransomware-2024-4329 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: c694415f-5ee4-5b3c-99c4-6c024e106d07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
