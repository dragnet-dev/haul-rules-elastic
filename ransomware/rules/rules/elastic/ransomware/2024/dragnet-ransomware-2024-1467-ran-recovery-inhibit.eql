// Dragnet [Ransomware]: dragnet-ransomware-2024-1467 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 70f76a7e-427f-5781-a604-47b9e899f90f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
