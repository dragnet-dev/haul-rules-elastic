// Dragnet [Ransomware]: dragnet-ransomware-2024-2547 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7cea22a7-5975-51fc-8942-e895dffe9668

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
