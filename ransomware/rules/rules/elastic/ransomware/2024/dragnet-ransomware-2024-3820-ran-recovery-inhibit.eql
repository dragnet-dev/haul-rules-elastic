// Dragnet [Ransomware]: dragnet-ransomware-2024-3820 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f0c6ae99-f58f-5a36-ac8d-d60d8354859c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
