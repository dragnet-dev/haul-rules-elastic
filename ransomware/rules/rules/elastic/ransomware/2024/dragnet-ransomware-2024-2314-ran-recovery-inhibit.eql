// Dragnet [Ransomware]: dragnet-ransomware-2024-2314 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 0250e93f-8012-5752-a6f0-7c1d068334da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
