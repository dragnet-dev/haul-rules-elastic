// Dragnet [Ransomware]: dragnet-ransomware-2024-1566 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 3ef951ca-249c-5916-80cd-ef2b63251660

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
