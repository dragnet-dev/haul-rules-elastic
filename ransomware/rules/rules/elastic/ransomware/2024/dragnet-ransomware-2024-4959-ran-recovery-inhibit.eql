// Dragnet [Ransomware]: dragnet-ransomware-2024-4959 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: fd216b35-c785-5918-bc65-1c94a9b24d95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
