// Dragnet [Ransomware]: dragnet-ransomware-2024-1638 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 66ccfbcd-e0fa-5745-b829-47555025d02c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
