// Dragnet [Ransomware]: dragnet-ransomware-2024-0331 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 957babda-df4f-50c2-97e5-878d211a1733

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
