// Dragnet [Ransomware]: dragnet-ransomware-2024-0593 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 35bfe783-c2a0-5a2f-950d-953457933d59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
