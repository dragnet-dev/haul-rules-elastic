// Dragnet [Ransomware]: dragnet-ransomware-2024-5697 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: d184e02e-291d-5f56-8010-55d46d379f60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
