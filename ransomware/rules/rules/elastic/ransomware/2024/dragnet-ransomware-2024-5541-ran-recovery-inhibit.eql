// Dragnet [Ransomware]: dragnet-ransomware-2024-5541 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 48bb85c7-c9f0-54d1-8695-0ee2cd983a54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
