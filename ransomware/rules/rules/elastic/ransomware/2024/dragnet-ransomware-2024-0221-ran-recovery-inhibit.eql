// Dragnet [Ransomware]: dragnet-ransomware-2024-0221 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e23546a5-6f65-5a6d-b600-feb6ba6a5330

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
