// Dragnet [Ransomware]: dragnet-ransomware-2024-1924 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: f26f7087-5621-5b8e-b871-4846a6d92d50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
