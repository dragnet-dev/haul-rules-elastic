// Dragnet [Ransomware]: dragnet-ransomware-2024-0841 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 96a9d8f3-72c4-5164-9a22-514767e75a87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
