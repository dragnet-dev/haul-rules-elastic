// Dragnet [Ransomware]: dragnet-ransomware-2024-1476 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ee2a8e3a-267e-5c8c-af61-e6bc846dd5ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
