// Dragnet [Ransomware]: dragnet-ransomware-2024-2201 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 86e60aae-dac6-58f5-bdfc-055314d29752

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
