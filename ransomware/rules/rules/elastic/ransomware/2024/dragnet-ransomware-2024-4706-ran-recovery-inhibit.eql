// Dragnet [Ransomware]: dragnet-ransomware-2024-4706 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 3e4b38aa-61c7-5b0c-bfd1-aa9118b4c4dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
