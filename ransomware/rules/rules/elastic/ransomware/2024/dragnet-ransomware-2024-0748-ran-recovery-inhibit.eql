// Dragnet [Ransomware]: dragnet-ransomware-2024-0748 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c72bfdf9-7440-5649-8c65-639ca3983c62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
