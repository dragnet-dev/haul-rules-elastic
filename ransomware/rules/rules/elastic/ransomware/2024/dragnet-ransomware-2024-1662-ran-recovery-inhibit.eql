// Dragnet [Ransomware]: dragnet-ransomware-2024-1662 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 5add4b47-fbac-5720-a3b9-8b2f79b3486c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
