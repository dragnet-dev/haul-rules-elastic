// Dragnet [Ransomware]: dragnet-ransomware-2024-2594 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 2e97614b-877f-58e7-a3f6-a7aa099f12a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
