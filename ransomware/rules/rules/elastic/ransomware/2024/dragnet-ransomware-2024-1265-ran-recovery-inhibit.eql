// Dragnet [Ransomware]: dragnet-ransomware-2024-1265 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: a17fdf12-b560-5f2e-b174-bb70354425d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
