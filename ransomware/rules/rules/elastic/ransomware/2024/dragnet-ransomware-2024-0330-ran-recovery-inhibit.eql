// Dragnet [Ransomware]: dragnet-ransomware-2024-0330 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: ce5372ae-78f5-59a9-97d1-f664c3220304

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
