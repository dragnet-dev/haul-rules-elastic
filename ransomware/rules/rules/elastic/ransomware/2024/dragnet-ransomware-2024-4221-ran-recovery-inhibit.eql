// Dragnet [Ransomware]: dragnet-ransomware-2024-4221 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 9eeddf66-0777-5fe3-a34c-47556846c93d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
