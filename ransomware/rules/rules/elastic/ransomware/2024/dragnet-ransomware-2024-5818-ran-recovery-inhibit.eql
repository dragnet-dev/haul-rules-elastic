// Dragnet [Ransomware]: dragnet-ransomware-2024-5818 — Recovery Inhibition (mogilevich)
// Status: deprecated | Level: high | ID: b64b8a9e-3f1a-584f-b4d9-014fb904f4f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
