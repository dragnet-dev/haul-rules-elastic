// Dragnet [Ransomware]: dragnet-ransomware-2024-3333 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: c7b5f8d4-7c50-5371-9302-7e37396f01d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
