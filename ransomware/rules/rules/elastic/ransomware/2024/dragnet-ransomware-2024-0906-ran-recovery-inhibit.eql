// Dragnet [Ransomware]: dragnet-ransomware-2024-0906 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 623d981a-3eb8-5cd0-adad-8f76dd25a700

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
