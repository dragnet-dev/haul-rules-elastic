// Dragnet [Ransomware]: dragnet-ransomware-2024-2122 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7979f3d4-8751-5384-abfe-a5d4a8a2ad3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
