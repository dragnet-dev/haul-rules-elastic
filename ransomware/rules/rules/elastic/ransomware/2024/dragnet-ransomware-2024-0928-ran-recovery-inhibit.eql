// Dragnet [Ransomware]: dragnet-ransomware-2024-0928 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f342d4d2-2378-516b-8b89-dd120321f7bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
