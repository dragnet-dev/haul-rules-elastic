// Dragnet [Ransomware]: dragnet-ransomware-2024-2027 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: 70ba67cc-abf4-5cdc-bf4e-29a9bc5642fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
