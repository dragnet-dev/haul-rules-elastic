// Dragnet [Ransomware]: dragnet-ransomware-2024-0634 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 4dbad049-cd6f-5355-9871-2df9d76148d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
