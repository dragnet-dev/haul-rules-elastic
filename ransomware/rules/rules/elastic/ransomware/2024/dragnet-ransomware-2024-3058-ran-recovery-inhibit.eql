// Dragnet [Ransomware]: dragnet-ransomware-2024-3058 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: d6410b00-b1f3-51b9-bfc5-0afabeb8c584

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
