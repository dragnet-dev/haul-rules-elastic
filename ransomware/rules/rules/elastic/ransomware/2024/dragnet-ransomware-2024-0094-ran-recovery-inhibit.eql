// Dragnet [Ransomware]: dragnet-ransomware-2024-0094 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f47948eb-ec86-59f8-855d-ef9ba2f2481f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
