// Dragnet [Ransomware]: dragnet-ransomware-2024-0612 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 926619f2-d78f-5390-b8c8-884b81525787

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
