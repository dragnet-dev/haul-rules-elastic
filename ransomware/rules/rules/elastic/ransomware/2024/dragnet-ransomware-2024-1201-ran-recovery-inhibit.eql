// Dragnet [Ransomware]: dragnet-ransomware-2024-1201 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b08bf7c0-7a78-53eb-abf5-2f378668d532

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
