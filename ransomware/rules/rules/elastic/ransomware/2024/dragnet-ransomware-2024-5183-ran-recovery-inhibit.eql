// Dragnet [Ransomware]: dragnet-ransomware-2024-5183 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: cb4fc801-f733-59d3-978e-69c9564a01b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
