// Dragnet [Ransomware]: dragnet-ransomware-2024-2274 — Recovery Inhibition (ElDorado)
// Status: experimental | Level: high | ID: 93920926-c7ed-546b-882e-b98602b4561e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
