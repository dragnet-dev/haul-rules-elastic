// Dragnet [Ransomware]: dragnet-ransomware-2024-4754 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: ea85fe1c-85c6-54a3-82c2-9f6d1e31992b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
