// Dragnet [Ransomware]: dragnet-ransomware-2024-5290 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 48c0d56d-3fcd-5ec0-9384-d7579489effe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
