// Dragnet [Ransomware]: dragnet-ransomware-2024-3542 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: a881ee09-b534-535a-b61d-8555e2656dbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
