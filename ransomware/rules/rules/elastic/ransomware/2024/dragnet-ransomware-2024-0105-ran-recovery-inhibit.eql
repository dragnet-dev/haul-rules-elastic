// Dragnet [Ransomware]: dragnet-ransomware-2024-0105 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: eb057930-86ff-550a-88cc-03270d1ce85e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
