// Dragnet [Ransomware]: dragnet-ransomware-2024-2202 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 08baea96-8f23-556c-a02a-720a7682890f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
