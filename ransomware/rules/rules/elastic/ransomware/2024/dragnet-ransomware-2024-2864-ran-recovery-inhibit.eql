// Dragnet [Ransomware]: dragnet-ransomware-2024-2864 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 3351e377-ef0a-54a5-857a-e177dba40c7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
