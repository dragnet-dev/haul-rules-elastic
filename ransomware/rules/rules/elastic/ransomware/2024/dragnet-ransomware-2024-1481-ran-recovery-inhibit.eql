// Dragnet [Ransomware]: dragnet-ransomware-2024-1481 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1882cc02-8a98-580f-b15e-66854a75a8e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
