// Dragnet [Ransomware]: dragnet-ransomware-2024-3663 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: b28a4618-dbe9-5435-a62d-441135742b49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
