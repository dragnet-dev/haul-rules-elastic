// Dragnet [Ransomware]: dragnet-ransomware-2024-2597 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 09499834-75e7-5e93-880d-d9cc085cf762

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
