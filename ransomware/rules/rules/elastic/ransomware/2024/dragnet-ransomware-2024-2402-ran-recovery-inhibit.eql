// Dragnet [Ransomware]: dragnet-ransomware-2024-2402 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: a60b50b1-9cda-5b97-a626-d2ab451ffd22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
