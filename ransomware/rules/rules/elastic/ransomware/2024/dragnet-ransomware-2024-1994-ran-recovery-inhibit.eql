// Dragnet [Ransomware]: dragnet-ransomware-2024-1994 — Recovery Inhibition (dragonransomware)
// Status: experimental | Level: high | ID: 5212359f-0f30-5bbe-9686-cc9815eed120

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
