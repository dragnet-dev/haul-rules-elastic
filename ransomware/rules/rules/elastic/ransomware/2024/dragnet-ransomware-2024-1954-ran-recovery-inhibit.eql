// Dragnet [Ransomware]: dragnet-ransomware-2024-1954 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: c23599d1-1abd-5c61-ad5d-b7ba1efdb504

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
