// Dragnet [Ransomware]: dragnet-ransomware-2024-3995 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d2a0b9d2-95ed-565c-92af-cc08ddf0b791

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
