// Dragnet [Ransomware]: dragnet-ransomware-2024-4460 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: 295ea266-fa59-59ba-bfcf-b07b8d17401d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
