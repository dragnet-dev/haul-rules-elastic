// Dragnet [Ransomware]: dragnet-ransomware-2024-0007 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: ae45b2d2-8027-5060-92ce-d12b59980520

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
