// Dragnet [Ransomware]: dragnet-ransomware-2024-1344 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: aa21a199-a5da-575d-8d29-99095bfb28ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
