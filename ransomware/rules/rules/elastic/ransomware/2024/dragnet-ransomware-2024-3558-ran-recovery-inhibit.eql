// Dragnet [Ransomware]: dragnet-ransomware-2024-3558 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 03a42014-7a60-5650-acaf-075d9404d5b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
