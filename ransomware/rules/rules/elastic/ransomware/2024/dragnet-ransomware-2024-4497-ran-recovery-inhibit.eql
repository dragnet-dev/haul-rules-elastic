// Dragnet [Ransomware]: dragnet-ransomware-2024-4497 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: e2068398-c3ed-59a7-948c-9855c0ae83ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
