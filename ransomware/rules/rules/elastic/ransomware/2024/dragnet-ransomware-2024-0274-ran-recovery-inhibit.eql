// Dragnet [Ransomware]: dragnet-ransomware-2024-0274 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 49f4ae93-be21-5f74-a092-a09f657ca1c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
