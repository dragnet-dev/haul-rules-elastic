// Dragnet [Ransomware]: dragnet-ransomware-2024-2809 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: f50e80ab-48c9-5592-b6d0-992462f730d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
