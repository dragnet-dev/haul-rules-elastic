// Dragnet [Ransomware]: dragnet-ransomware-2024-5344 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 1bb4d23d-d0e7-577d-9a33-b9379906d492

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
