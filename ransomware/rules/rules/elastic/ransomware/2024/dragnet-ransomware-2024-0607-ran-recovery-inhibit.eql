// Dragnet [Ransomware]: dragnet-ransomware-2024-0607 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9d560756-f796-51e3-9f5e-88581989d94b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
