// Dragnet [Ransomware]: dragnet-ransomware-2024-0655 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d126579b-4d1a-59aa-a118-f93d1efd741c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
