// Dragnet [Ransomware]: dragnet-ransomware-2024-4430 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 4b4b87d5-3b23-57a9-975f-6c503a1242c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
