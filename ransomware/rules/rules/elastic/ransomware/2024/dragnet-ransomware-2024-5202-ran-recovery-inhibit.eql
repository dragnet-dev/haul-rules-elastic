// Dragnet [Ransomware]: dragnet-ransomware-2024-5202 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: 6c027018-dba6-5bdd-938b-aaad7f09a226

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
