// Dragnet [Ransomware]: dragnet-ransomware-2024-0388 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: bae68423-2721-5454-af11-d01662c5e19f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
