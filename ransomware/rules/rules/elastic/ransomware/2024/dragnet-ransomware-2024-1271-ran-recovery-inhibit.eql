// Dragnet [Ransomware]: dragnet-ransomware-2024-1271 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: 53de821e-9a68-57a4-8118-7a1b2968efea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
