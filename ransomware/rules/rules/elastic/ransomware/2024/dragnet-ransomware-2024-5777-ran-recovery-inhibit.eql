// Dragnet [Ransomware]: dragnet-ransomware-2024-5777 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 42ab34d3-faae-57f2-b5be-3c98874b8ad6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
