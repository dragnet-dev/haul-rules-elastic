// Dragnet [Ransomware]: dragnet-ransomware-2024-2309 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 5f5deed8-2ae5-5a88-801a-23924e04ac45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
