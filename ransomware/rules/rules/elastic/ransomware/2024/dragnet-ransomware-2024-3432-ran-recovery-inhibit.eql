// Dragnet [Ransomware]: dragnet-ransomware-2024-3432 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: fe9e3b03-711e-549f-ad5d-f063cd301f8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
