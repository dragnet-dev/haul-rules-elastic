// Dragnet [Ransomware]: dragnet-ransomware-2024-1736 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 4b9b7878-0e7b-5702-b037-cd02a62095a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
