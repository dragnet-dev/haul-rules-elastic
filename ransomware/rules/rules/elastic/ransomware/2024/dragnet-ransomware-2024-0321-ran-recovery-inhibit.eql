// Dragnet [Ransomware]: dragnet-ransomware-2024-0321 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 1d6e4bb0-be38-5067-bb1d-f176f8da7ab0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
