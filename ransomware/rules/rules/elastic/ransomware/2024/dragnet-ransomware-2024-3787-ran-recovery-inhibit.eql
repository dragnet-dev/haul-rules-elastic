// Dragnet [Ransomware]: dragnet-ransomware-2024-3787 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: eda8d963-9497-56c1-9e0e-029668be5322

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
