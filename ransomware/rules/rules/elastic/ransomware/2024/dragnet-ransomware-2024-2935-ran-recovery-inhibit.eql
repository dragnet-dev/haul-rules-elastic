// Dragnet [Ransomware]: dragnet-ransomware-2024-2935 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 966cde9c-42cf-5274-91d4-aeb0fe4ebcae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
