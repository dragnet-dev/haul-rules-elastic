// Dragnet [Ransomware]: dragnet-ransomware-2024-1577 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0f275f7a-fac7-565f-9f47-81104b94a7c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
