// Dragnet [Ransomware]: dragnet-ransomware-2024-2815 — Recovery Inhibition (frag)
// Status: deprecated | Level: high | ID: aecdca60-ab77-561e-b63e-fb2d5e1d251d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
