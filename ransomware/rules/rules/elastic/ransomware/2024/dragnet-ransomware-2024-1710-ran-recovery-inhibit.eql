// Dragnet [Ransomware]: dragnet-ransomware-2024-1710 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e7f5cdcf-a8f6-5de4-831f-e4f0d0575498

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
