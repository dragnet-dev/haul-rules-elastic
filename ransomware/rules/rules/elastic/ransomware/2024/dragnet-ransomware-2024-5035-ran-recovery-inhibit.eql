// Dragnet [Ransomware]: dragnet-ransomware-2024-5035 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: dfa4d65e-6b19-5ce5-86a3-1c8e4b2a8ca1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
