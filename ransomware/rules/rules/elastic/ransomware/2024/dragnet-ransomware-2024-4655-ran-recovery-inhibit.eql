// Dragnet [Ransomware]: dragnet-ransomware-2024-4655 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 790e66b8-c7bb-595d-9e0b-78802f3f13fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
