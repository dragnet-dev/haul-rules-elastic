// Dragnet [Ransomware]: dragnet-ransomware-2024-0974 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b353b94c-8f0c-53c3-a087-0eff842199db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
