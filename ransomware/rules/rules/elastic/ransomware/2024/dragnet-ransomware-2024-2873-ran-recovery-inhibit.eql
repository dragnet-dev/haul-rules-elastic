// Dragnet [Ransomware]: dragnet-ransomware-2024-2873 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 6b74f6b4-b430-5ee3-aaab-1bfe55b0b2d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
