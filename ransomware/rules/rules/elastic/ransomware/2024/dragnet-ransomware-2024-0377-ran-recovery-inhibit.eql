// Dragnet [Ransomware]: dragnet-ransomware-2024-0377 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 79fbb974-31ed-532b-84a1-178e61fa68d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
