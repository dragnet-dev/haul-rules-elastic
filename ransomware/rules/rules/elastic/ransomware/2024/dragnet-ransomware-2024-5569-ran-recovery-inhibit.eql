// Dragnet [Ransomware]: dragnet-ransomware-2024-5569 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b85ca658-dcd6-53e8-8f68-cd7b15f26d60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
