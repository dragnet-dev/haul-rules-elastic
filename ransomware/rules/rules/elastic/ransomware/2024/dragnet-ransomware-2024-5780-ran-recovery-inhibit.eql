// Dragnet [Ransomware]: dragnet-ransomware-2024-5780 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 10611b60-022c-57b8-a267-67f29733014e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
