// Dragnet [Ransomware]: dragnet-ransomware-2024-0812 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 6e4f7e2f-33ac-51e6-a0a6-055ca090ec93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
