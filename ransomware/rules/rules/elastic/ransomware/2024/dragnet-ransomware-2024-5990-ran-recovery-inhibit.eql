// Dragnet [Ransomware]: dragnet-ransomware-2024-5990 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 560211dd-bd95-59ae-858f-b9eed9a163ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
