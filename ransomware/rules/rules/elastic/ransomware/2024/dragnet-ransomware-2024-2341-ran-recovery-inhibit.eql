// Dragnet [Ransomware]: dragnet-ransomware-2024-2341 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 90f1b2dc-c37e-5fac-b841-048110e327c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
