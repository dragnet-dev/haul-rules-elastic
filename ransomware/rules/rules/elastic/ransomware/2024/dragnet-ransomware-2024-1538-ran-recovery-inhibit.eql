// Dragnet [Ransomware]: dragnet-ransomware-2024-1538 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 912ed0bd-7f48-57b2-aab7-6c0f8c024650

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
