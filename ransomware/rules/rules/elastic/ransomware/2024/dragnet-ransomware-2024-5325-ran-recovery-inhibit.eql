// Dragnet [Ransomware]: dragnet-ransomware-2024-5325 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: c83c114f-9878-5642-9f71-c938cc9fdf3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
