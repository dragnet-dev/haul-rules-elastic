// Dragnet [Ransomware]: dragnet-ransomware-2024-2017 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 92b29913-3c75-5bcc-b8e3-2d9b8b1f5f59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
