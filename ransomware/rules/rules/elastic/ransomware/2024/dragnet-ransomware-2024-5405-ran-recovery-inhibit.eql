// Dragnet [Ransomware]: dragnet-ransomware-2024-5405 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e202fae2-a7d5-55af-ba73-4b0800d816e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
