// Dragnet [Ransomware]: dragnet-ransomware-2024-0927 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: cefee193-95be-5f82-b3b0-71fbd2745c12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
