// Dragnet [Ransomware]: dragnet-ransomware-2024-3604 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b92e79c3-e95f-580f-9f4b-b8910fef2826

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
