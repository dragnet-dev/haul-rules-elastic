// Dragnet [Ransomware]: dragnet-ransomware-2024-3182 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: e6d5410c-6e8a-5320-8c2b-9a5eba955aa9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
