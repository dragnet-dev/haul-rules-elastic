// Dragnet [Ransomware]: dragnet-ransomware-2024-1556 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 401c8df7-9c64-5f69-b65a-8e5aee096d7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
