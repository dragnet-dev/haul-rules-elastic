// Dragnet [Ransomware]: dragnet-ransomware-2024-2182 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 03045fd3-6ba1-5b7f-bb92-bdec999115d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
