// Dragnet [Ransomware]: dragnet-ransomware-2024-5693 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: 887762ce-d0ed-55d2-ad0b-7e415a383b32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
