// Dragnet [Ransomware]: dragnet-ransomware-2024-3967 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 71902746-3d69-5275-9c20-1741eb56c573

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
