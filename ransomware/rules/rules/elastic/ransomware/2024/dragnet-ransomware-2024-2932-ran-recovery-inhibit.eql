// Dragnet [Ransomware]: dragnet-ransomware-2024-2932 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: 120e0a0c-0b00-5b72-b845-351ca18a1757

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
