// Dragnet [Ransomware]: dragnet-ransomware-2024-3550 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 3f716bc4-50d0-5139-a536-81139c5b351d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
