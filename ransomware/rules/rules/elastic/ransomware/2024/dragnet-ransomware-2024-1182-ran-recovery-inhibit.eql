// Dragnet [Ransomware]: dragnet-ransomware-2024-1182 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 0bdf08c6-886f-516f-a621-848dca10037b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
