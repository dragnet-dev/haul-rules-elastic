// Dragnet [Ransomware]: dragnet-ransomware-2024-3700 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: db7ad3b6-1e73-58fc-9e48-b3c04e301be9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
