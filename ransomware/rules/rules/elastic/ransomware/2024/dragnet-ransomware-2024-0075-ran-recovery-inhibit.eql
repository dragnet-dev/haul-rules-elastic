// Dragnet [Ransomware]: dragnet-ransomware-2024-0075 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: c58eee7f-5c83-568a-a623-957eb47a2279

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
