// Dragnet [Ransomware]: dragnet-ransomware-2024-0475 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: eb140abe-534e-57ef-b12b-939ca528a93e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
