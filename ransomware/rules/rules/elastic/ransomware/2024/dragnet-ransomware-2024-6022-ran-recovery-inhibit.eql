// Dragnet [Ransomware]: dragnet-ransomware-2024-6022 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 15a8f356-b839-5f25-87e9-12392878d193

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
