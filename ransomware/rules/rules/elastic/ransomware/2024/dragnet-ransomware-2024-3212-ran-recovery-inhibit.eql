// Dragnet [Ransomware]: dragnet-ransomware-2024-3212 — Recovery Inhibition (knight)
// Status: experimental | Level: high | ID: 221dcb96-2492-51ed-8e4b-049fa736dacc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
