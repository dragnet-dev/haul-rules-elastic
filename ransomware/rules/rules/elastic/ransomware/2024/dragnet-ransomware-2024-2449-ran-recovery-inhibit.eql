// Dragnet [Ransomware]: dragnet-ransomware-2024-2449 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 871c58ad-b4db-54b5-a16d-5e0b9d999847

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
