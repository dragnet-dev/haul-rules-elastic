// Dragnet [Ransomware]: dragnet-ransomware-2024-5806 — Recovery Inhibition (akira)
// Status: experimental | Level: high | ID: 752a8ca7-85a2-50d3-9f82-034eedec6730

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
