// Dragnet [Ransomware]: dragnet-ransomware-2024-0708 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 106f57be-3dc2-5646-84f4-68a2264f67d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
