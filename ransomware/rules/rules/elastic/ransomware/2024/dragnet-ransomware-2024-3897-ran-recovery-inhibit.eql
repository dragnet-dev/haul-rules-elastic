// Dragnet [Ransomware]: dragnet-ransomware-2024-3897 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: a54dc634-f3eb-55ec-b2e0-13b9abb03762

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
