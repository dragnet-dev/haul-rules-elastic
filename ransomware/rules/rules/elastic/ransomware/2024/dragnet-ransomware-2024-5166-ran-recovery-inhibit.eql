// Dragnet [Ransomware]: dragnet-ransomware-2024-5166 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 85876bef-33df-5d40-885e-b9dcc64620f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
