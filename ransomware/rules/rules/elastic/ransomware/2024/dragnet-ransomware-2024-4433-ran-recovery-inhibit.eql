// Dragnet [Ransomware]: dragnet-ransomware-2024-4433 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: df7a6712-9285-51fd-a004-4a16f14e1e83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
