// Dragnet [Ransomware]: dragnet-ransomware-2024-2141 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a4611ca0-a09e-5b8e-822f-0e16ad115a94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
