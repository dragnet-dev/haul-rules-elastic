// Dragnet [Ransomware]: dragnet-ransomware-2024-0871 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 92ebbd8a-2a36-5052-ad8f-1552441968b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
