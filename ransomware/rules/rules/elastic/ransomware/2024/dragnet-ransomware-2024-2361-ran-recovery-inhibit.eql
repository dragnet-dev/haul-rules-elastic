// Dragnet [Ransomware]: dragnet-ransomware-2024-2361 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: c84d64b1-65da-5ecf-934a-5668caea3170

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
