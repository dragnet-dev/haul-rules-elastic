// Dragnet [Ransomware]: dragnet-ransomware-2024-4496 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 9526e846-bc54-5fa6-b222-1e218164930c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
