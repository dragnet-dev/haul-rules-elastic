// Dragnet [Ransomware]: dragnet-ransomware-2024-4791 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 5ee3d1e8-80b1-5803-8478-22ba93e88d25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
