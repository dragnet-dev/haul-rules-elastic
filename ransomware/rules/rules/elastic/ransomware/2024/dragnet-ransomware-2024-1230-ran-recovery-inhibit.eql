// Dragnet [Ransomware]: dragnet-ransomware-2024-1230 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 5e46094f-8717-5740-9b8a-90c4d7f639ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
