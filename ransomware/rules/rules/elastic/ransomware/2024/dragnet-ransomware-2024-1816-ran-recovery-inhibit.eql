// Dragnet [Ransomware]: dragnet-ransomware-2024-1816 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 809a15c3-90d8-5aba-bf64-a3814baa240b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
