// Dragnet [Ransomware]: dragnet-ransomware-2024-5524 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 9435db98-b432-56e0-911b-0df497fd8bf7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
