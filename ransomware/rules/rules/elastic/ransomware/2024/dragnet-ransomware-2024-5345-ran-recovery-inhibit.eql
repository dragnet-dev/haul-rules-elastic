// Dragnet [Ransomware]: dragnet-ransomware-2024-5345 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 4f9ba3ca-6610-5d65-bae8-3adae24fa5d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
