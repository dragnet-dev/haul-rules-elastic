// Dragnet [Ransomware]: dragnet-ransomware-2024-5478 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 58295acc-6020-57a6-a906-90923598227e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
