// Dragnet [Ransomware]: dragnet-ransomware-2024-1109 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 373cf713-eb78-5525-bfba-7b17889dcfc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
