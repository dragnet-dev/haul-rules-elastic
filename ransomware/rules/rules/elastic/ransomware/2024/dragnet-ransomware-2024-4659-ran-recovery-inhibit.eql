// Dragnet [Ransomware]: dragnet-ransomware-2024-4659 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: ab27c9a1-da50-5b59-9130-621a67b78696

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
