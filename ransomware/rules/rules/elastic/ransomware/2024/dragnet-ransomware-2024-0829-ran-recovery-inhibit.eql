// Dragnet [Ransomware]: dragnet-ransomware-2024-0829 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 67b928fb-b9c1-53d8-ae02-2c3b1f1ed88a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
