// Dragnet [Ransomware]: dragnet-ransomware-2024-4088 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a1b22367-2135-59d9-972c-95dd83915afc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
