// Dragnet [Ransomware]: dragnet-ransomware-2024-5934 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: e4254f8c-e6a4-50ff-8258-71bbd9dba2ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
