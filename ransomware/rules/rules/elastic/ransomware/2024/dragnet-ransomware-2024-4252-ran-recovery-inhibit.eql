// Dragnet [Ransomware]: dragnet-ransomware-2024-4252 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 8096cbdf-138a-574d-ab9e-6a8a65d61fdf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
