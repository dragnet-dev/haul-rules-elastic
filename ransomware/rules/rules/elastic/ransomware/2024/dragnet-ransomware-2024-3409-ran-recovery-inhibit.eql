// Dragnet [Ransomware]: dragnet-ransomware-2024-3409 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 5a917cbe-1bfc-5d52-8fe7-7e48a3d2b336

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
