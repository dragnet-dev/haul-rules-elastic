// Dragnet [Ransomware]: dragnet-ransomware-2024-2292 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 3675447d-2f50-5d0d-b9cd-5248b6035cce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
