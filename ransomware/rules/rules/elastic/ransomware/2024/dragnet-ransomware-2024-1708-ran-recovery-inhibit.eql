// Dragnet [Ransomware]: dragnet-ransomware-2024-1708 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: fd8034f4-247a-50d9-ba3b-2702817f44ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
