// Dragnet [Ransomware]: dragnet-ransomware-2024-1740 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 586bb08e-63b4-5778-ad0d-02e992fa5baa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
