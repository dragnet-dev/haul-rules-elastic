// Dragnet [Ransomware]: dragnet-ransomware-2024-5092 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 72f29072-5970-583a-997e-19ceb1646337

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
