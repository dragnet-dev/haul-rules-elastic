// Dragnet [Ransomware]: dragnet-ransomware-2024-4322 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 65d849d8-4adc-5dd3-8a86-ed354b41adb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
