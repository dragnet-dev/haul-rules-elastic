// Dragnet [Ransomware]: dragnet-ransomware-2024-0960 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: a50abebd-2953-56db-ae21-62ca052493c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
