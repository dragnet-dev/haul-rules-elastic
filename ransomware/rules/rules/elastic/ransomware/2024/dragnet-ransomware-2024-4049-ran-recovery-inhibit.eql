// Dragnet [Ransomware]: dragnet-ransomware-2024-4049 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 582a8146-fb24-5d7f-9463-daa303807432

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
