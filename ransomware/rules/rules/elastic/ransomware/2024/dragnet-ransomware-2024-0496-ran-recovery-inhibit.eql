// Dragnet [Ransomware]: dragnet-ransomware-2024-0496 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8dcfcc25-516a-5681-8b49-481a80d3203e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
