// Dragnet [Ransomware]: dragnet-ransomware-2024-0929 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: ec5164ec-c39a-5fa0-9158-b7d307f48591

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
