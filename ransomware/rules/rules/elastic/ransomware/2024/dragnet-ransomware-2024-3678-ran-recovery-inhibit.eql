// Dragnet [Ransomware]: dragnet-ransomware-2024-3678 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 2bca7cfc-125f-5493-97c1-0f13d072c5df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
