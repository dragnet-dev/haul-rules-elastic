// Dragnet [Ransomware]: dragnet-ransomware-2024-5016 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 40938d8d-3e3d-5f6d-842b-63e6487b8ef1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
