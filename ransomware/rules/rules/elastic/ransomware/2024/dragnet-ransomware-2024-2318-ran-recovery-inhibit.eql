// Dragnet [Ransomware]: dragnet-ransomware-2024-2318 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: c812d3cb-f6d7-5262-9eff-7eaa80042b7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
