// Dragnet [Ransomware]: dragnet-ransomware-2024-0320 — Recovery Inhibition (orca)
// Status: experimental | Level: high | ID: d0870366-cdec-51b9-8605-f781731f76b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
