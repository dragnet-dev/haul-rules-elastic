// Dragnet [Ransomware]: dragnet-ransomware-2024-3853 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 88401783-7e2a-5c9f-bcd3-d3aa4a0a1def

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
