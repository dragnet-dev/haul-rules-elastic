// Dragnet [Ransomware]: dragnet-ransomware-2024-0828 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 5190e995-5c57-5d85-a3c4-aa41986a996f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
