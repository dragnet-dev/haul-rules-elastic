// Dragnet [Ransomware]: dragnet-ransomware-2024-3242 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ef0b99ad-c13b-524a-84a2-3d087cecede9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
