// Dragnet [Ransomware]: dragnet-ransomware-2024-5077 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 19d59db3-f2ed-52ad-9dff-71ce05925259

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
