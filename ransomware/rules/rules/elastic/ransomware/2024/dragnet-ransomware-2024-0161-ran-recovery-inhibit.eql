// Dragnet [Ransomware]: dragnet-ransomware-2024-0161 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 5156eb71-69ae-589b-9bed-7fa40a63677c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
