// Dragnet [Ransomware]: dragnet-ransomware-2024-5785 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: affa818b-e2dd-5e30-8db2-20fc77c8d14a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
