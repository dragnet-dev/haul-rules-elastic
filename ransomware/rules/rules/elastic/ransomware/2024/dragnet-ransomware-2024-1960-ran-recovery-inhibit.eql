// Dragnet [Ransomware]: dragnet-ransomware-2024-1960 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ea6ff283-ca0e-5cad-adb8-1fd230c9d368

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
