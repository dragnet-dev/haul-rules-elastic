// Dragnet [Ransomware]: dragnet-ransomware-2024-2852 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: cab26368-f8fa-5318-88d7-224f65e4deff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
