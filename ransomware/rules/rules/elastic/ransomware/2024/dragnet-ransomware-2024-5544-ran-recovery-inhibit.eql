// Dragnet [Ransomware]: dragnet-ransomware-2024-5544 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 16d4dcad-84b2-54a7-b1cf-2d27a46f5ffb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
