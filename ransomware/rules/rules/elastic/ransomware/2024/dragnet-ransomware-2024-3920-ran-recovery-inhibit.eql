// Dragnet [Ransomware]: dragnet-ransomware-2024-3920 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 44afa24d-d0b5-5c49-8d68-a26bdf9beaa9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
