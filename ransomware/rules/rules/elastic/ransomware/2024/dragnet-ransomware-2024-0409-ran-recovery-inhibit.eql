// Dragnet [Ransomware]: dragnet-ransomware-2024-0409 — Recovery Inhibition (playboy)
// Status: experimental | Level: high | ID: a620f187-f801-57c2-aa43-f1221dde27b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
