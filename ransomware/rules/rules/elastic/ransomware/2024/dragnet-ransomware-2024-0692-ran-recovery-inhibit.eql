// Dragnet [Ransomware]: dragnet-ransomware-2024-0692 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 113649af-04f5-5a4d-a1b6-bde8bc2b99e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
