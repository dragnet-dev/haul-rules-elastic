// Dragnet [Ransomware]: dragnet-ransomware-2024-3128 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 63675beb-08ef-57d9-970b-f47c44fc73e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
