// Dragnet [Ransomware]: dragnet-ransomware-2024-0380 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 6cf63e25-d7c2-5860-b697-a39156eee92e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
