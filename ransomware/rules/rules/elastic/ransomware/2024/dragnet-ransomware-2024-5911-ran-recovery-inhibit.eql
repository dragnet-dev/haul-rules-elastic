// Dragnet [Ransomware]: dragnet-ransomware-2024-5911 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 9f2eb179-3cce-5f60-bad0-d6d46643eb9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
