// Dragnet [Ransomware]: dragnet-ransomware-2024-0977 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 68659002-158e-52bc-b9cd-028ad16f0a60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
