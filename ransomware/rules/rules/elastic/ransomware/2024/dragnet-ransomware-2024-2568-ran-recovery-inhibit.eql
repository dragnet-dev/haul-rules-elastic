// Dragnet [Ransomware]: dragnet-ransomware-2024-2568 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e0d9d076-7c24-5211-8c95-d5215aa00e82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
