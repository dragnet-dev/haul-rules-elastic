// Dragnet [Ransomware]: dragnet-ransomware-2024-3574 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: fa19b4fa-111a-5653-af69-e60f6d8cf8a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
