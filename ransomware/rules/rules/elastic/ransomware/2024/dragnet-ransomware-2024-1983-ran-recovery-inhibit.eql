// Dragnet [Ransomware]: dragnet-ransomware-2024-1983 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 32ccdc8f-a355-5bf1-b66f-fd9f0971ae6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
