// Dragnet [Ransomware]: dragnet-ransomware-2024-1929 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0b009aa6-8e60-5c54-907f-847c9522d07b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
