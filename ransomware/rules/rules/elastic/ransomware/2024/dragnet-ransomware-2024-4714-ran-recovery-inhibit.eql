// Dragnet [Ransomware]: dragnet-ransomware-2024-4714 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: bddba3c7-a900-55a6-b85a-3f1709f74351

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
