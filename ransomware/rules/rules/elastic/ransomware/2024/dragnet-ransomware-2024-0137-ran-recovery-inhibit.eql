// Dragnet [Ransomware]: dragnet-ransomware-2024-0137 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 88995174-3d96-5a62-9363-60811f569d77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
