// Dragnet [Ransomware]: dragnet-ransomware-2024-1158 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: d0277de3-6990-56f2-9271-a8b9196dfab0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
