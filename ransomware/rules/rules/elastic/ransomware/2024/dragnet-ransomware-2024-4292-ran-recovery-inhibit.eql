// Dragnet [Ransomware]: dragnet-ransomware-2024-4292 — Recovery Inhibition (daixin)
// Status: deprecated | Level: high | ID: 0c8a6281-b96e-5ac3-a042-13c532a3615d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
