// Dragnet [Ransomware]: dragnet-ransomware-2024-2171 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 81612ecc-891e-5423-800a-19bc9cf0c1a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
