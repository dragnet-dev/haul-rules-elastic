// Dragnet [Ransomware]: dragnet-ransomware-2024-1614 — Recovery Inhibition (qiulong)
// Status: experimental | Level: high | ID: 0d7e5bcd-df9a-5186-899b-200d220bae9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
