// Dragnet [Ransomware]: dragnet-ransomware-2024-1138 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 002dcc65-d822-5f34-bff7-54bd349757bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
