// Dragnet [Ransomware]: dragnet-ransomware-2024-5136 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f68b7b11-0421-5e26-af19-0557bc1d7a86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
