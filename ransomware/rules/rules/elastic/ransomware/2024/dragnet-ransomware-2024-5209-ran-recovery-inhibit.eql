// Dragnet [Ransomware]: dragnet-ransomware-2024-5209 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: cdf29608-e951-5cb4-976d-8d9eece0cd6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
