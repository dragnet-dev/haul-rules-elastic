// Dragnet [Ransomware]: dragnet-ransomware-2024-3925 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 111fd6be-aa92-527b-b021-a6c0da7b9720

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
