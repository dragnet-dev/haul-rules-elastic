// Dragnet [Ransomware]: dragnet-ransomware-2024-4902 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: b62eda4b-7160-529c-a890-a4cb53288955

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
