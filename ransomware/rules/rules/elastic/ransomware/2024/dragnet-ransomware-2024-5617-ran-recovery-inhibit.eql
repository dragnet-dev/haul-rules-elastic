// Dragnet [Ransomware]: dragnet-ransomware-2024-5617 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 59ce88bf-308e-59ec-8967-97dae37feb52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
