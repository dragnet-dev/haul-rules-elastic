// Dragnet [Ransomware]: dragnet-ransomware-2024-1075 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: da82020d-08dc-5083-9230-09878c1e9c23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
