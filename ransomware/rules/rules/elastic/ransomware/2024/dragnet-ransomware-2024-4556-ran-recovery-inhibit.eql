// Dragnet [Ransomware]: dragnet-ransomware-2024-4556 — Recovery Inhibition (ElDorado)
// Status: experimental | Level: high | ID: 3fecb138-bd42-5fb8-b0d0-26a1731d28df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
