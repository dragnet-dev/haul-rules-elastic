// Dragnet [Ransomware]: dragnet-ransomware-2024-1829 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 0445b0c3-7d63-592f-845d-74ee59cdd71b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
