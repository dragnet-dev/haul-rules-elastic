// Dragnet [Ransomware]: dragnet-ransomware-2024-2673 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 06d17eba-1ac6-554a-8269-35e8159513dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
