// Dragnet [Ransomware]: dragnet-ransomware-2024-1911 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5b6245b7-9baf-5085-ad88-ff2ed407530b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
