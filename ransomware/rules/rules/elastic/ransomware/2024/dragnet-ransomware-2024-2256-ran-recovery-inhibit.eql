// Dragnet [Ransomware]: dragnet-ransomware-2024-2256 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 4a280879-3976-5915-9673-2a4b3f82a89f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
