// Dragnet [Ransomware]: dragnet-ransomware-2024-5970 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 1852de5d-7c92-59d1-8b8a-994b3c204ed3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
