// Dragnet [Ransomware]: dragnet-ransomware-2024-5961 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 7acbdc35-6634-5901-b0f2-41c243c8e4b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
