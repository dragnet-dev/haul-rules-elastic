// Dragnet [Ransomware]: dragnet-ransomware-2024-2942 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 72e67595-a4ab-526f-8d17-a7726bad0dd4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
