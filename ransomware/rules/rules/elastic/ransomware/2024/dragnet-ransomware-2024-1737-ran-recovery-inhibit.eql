// Dragnet [Ransomware]: dragnet-ransomware-2024-1737 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d919e474-3f10-544d-aa7b-0761ca44934a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
