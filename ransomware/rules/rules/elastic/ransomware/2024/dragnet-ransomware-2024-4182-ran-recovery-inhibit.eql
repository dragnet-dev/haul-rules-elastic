// Dragnet [Ransomware]: dragnet-ransomware-2024-4182 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: f9b2288d-92b1-581c-895c-5ec2a26e3834

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
