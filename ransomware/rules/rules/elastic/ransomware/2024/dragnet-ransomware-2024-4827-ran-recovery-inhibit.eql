// Dragnet [Ransomware]: dragnet-ransomware-2024-4827 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: 34c90644-29fe-5c69-aea6-f3f6819456eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
