// Dragnet [Ransomware]: dragnet-ransomware-2024-4744 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 54e8d86e-ee9e-590c-a6b9-aecf78783d87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
