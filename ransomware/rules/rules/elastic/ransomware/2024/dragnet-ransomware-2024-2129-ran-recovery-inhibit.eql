// Dragnet [Ransomware]: dragnet-ransomware-2024-2129 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: f8e00a11-8ae5-5ec2-a46a-f8388c67e643

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
