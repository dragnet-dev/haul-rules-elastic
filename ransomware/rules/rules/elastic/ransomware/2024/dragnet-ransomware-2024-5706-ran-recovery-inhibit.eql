// Dragnet [Ransomware]: dragnet-ransomware-2024-5706 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: c5747297-71b5-583d-8706-3597d02aa27a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
