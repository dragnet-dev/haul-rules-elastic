// Dragnet [Ransomware]: dragnet-ransomware-2024-5745 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 1a53d3ba-3b29-5076-9686-fc3d3adc9f2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
