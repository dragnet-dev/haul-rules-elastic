// Dragnet [Ransomware]: dragnet-ransomware-2024-3348 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: fe18d9ee-0cc7-501c-b27c-328424cb0b91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
