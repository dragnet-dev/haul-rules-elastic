// Dragnet [Ransomware]: dragnet-ransomware-2024-4994 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2504d105-4c1c-58ed-ad5b-67ac037b6534

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
