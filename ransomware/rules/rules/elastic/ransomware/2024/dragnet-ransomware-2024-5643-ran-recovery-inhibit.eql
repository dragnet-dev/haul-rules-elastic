// Dragnet [Ransomware]: dragnet-ransomware-2024-5643 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 92be5a2b-c642-5bf5-977a-c295a8733fdd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
