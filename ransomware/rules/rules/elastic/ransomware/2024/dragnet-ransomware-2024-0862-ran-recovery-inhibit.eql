// Dragnet [Ransomware]: dragnet-ransomware-2024-0862 — Recovery Inhibition (dAn0n)
// Status: experimental | Level: high | ID: 37dad8ea-2d74-5d17-8934-a445ce03aa38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
