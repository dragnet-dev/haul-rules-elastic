// Dragnet [Ransomware]: dragnet-ransomware-2024-3130 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: f8354ed6-30c0-5128-9a8a-a9d005865758

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
