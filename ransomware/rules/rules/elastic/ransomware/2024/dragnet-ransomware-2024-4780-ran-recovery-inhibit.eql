// Dragnet [Ransomware]: dragnet-ransomware-2024-4780 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7998a6f8-d7cf-5bfc-b792-8f58afca2447

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
