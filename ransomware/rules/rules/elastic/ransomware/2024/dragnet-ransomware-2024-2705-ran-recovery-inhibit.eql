// Dragnet [Ransomware]: dragnet-ransomware-2024-2705 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a84fbf8d-9d1f-58c3-936c-5293d7bd9b07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
