// Dragnet [Ransomware]: dragnet-ransomware-2024-4825 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: f87d28f1-7e34-5f09-bcfc-4a9e2410748f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
