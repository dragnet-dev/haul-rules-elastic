// Dragnet [Ransomware]: dragnet-ransomware-2024-4437 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 79380222-d609-52bb-a3d1-7aa4f955206c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
