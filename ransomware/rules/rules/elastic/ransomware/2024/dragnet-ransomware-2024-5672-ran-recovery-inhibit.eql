// Dragnet [Ransomware]: dragnet-ransomware-2024-5672 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5689e10a-ac2b-5da9-8501-e72556926c80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
