// Dragnet [Ransomware]: dragnet-ransomware-2024-1712 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: b6c90dfe-9140-5f8e-a116-0b2e77bddf6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
