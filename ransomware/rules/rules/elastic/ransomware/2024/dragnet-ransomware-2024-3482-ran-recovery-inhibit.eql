// Dragnet [Ransomware]: dragnet-ransomware-2024-3482 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 5612f849-d297-585a-8aaf-4b632ff1774c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
