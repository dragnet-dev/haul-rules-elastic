// Dragnet [Ransomware]: dragnet-ransomware-2024-5796 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: dcab88e4-2384-5ba4-9dcd-7ee9035de64a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
