// Dragnet [Ransomware]: dragnet-ransomware-2024-0130 — Recovery Inhibition (cloak)
// Status: experimental | Level: high | ID: ec52a3a9-b111-505f-a5cf-075c09d44561

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
