// Dragnet [Ransomware]: dragnet-ransomware-2024-0832 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: d23431e7-b6cb-5bfe-8047-1ed443a031ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
