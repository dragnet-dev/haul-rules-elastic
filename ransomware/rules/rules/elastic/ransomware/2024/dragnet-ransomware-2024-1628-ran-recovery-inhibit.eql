// Dragnet [Ransomware]: dragnet-ransomware-2024-1628 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 3c3f2bc1-7684-5a45-b39b-e6ef4d23fdb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
