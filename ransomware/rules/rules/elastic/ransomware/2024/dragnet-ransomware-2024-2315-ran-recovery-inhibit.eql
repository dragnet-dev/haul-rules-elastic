// Dragnet [Ransomware]: dragnet-ransomware-2024-2315 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 4886bb33-dad7-5cb5-8755-8fa971008709

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
