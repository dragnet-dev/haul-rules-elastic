// Dragnet [Ransomware]: dragnet-ransomware-2024-4326 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 79b36958-8f4b-5d34-831a-5419528659ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
