// Dragnet [Ransomware]: dragnet-ransomware-2024-3764 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: e2295b5a-afcc-5674-96c4-c89800589c33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
