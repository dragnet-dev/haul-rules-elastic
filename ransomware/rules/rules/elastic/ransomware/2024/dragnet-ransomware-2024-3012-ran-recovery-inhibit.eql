// Dragnet [Ransomware]: dragnet-ransomware-2024-3012 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: 8e1502e1-6a9a-5788-9483-176660e5dcd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
