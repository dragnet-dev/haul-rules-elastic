// Dragnet [Ransomware]: dragnet-ransomware-2024-0554 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 1313263f-e81f-5aee-8e63-9018d9e3a2d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
