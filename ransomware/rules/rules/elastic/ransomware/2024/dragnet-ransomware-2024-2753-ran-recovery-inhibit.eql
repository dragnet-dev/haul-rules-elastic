// Dragnet [Ransomware]: dragnet-ransomware-2024-2753 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 59eb0b8d-e865-5315-b8c4-c7bd74d50618

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
