// Dragnet [Ransomware]: dragnet-ransomware-2024-5859 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: f31034c2-08d9-53cb-bb67-8c09431c59fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
