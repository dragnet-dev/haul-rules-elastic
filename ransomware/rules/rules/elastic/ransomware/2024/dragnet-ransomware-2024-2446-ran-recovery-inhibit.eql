// Dragnet [Ransomware]: dragnet-ransomware-2024-2446 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: dea4ff3c-a93a-52c8-82ba-dff87cde51de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
