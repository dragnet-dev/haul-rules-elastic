// Dragnet [Ransomware]: dragnet-ransomware-2024-3089 — Recovery Inhibition (moneymessage)
// Status: experimental | Level: high | ID: 90ec48c5-5f67-5e9b-954d-8ffdb8a408b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
