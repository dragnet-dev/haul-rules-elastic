// Dragnet [Ransomware]: dragnet-ransomware-2024-2436 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: a20e12b8-42ba-5105-8636-88f3fb70ae3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
