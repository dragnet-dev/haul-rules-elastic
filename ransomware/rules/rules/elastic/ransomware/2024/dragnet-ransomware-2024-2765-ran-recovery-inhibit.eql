// Dragnet [Ransomware]: dragnet-ransomware-2024-2765 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 92ae2f46-00c6-5c5e-96e3-4c16e437a148

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
