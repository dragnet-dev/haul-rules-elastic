// Dragnet [Ransomware]: dragnet-ransomware-2024-1886 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 8435ef82-d812-545d-b357-8cd136f504f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
