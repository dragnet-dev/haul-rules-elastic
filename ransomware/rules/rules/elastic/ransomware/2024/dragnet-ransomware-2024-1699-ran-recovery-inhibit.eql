// Dragnet [Ransomware]: dragnet-ransomware-2024-1699 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ae80ed0b-3613-5f52-9da1-94ae3957e2d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
