// Dragnet [Ransomware]: dragnet-ransomware-2024-1982 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: cc1e329a-30e9-58ba-8485-3530fca70587

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
