// Dragnet [Ransomware]: dragnet-ransomware-2024-1998 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: f16d78e1-6c5c-5d7a-9729-ad71a4dc9e1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
