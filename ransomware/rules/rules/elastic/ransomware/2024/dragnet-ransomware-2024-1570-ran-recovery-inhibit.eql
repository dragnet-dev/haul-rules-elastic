// Dragnet [Ransomware]: dragnet-ransomware-2024-1570 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 59d745cb-418e-5738-87f6-2a5cff03e761

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
