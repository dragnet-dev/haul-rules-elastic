// Dragnet [Ransomware]: dragnet-ransomware-2024-0863 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 276e657f-3e4a-597d-a743-ce919fd868c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
