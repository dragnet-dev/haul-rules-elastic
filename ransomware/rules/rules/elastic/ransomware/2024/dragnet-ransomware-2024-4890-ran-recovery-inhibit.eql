// Dragnet [Ransomware]: dragnet-ransomware-2024-4890 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 0629abfd-98ff-55a7-88c4-fa5353c63f55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
