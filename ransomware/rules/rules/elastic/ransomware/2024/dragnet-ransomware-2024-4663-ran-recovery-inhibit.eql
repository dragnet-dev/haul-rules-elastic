// Dragnet [Ransomware]: dragnet-ransomware-2024-4663 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 2758406e-a1aa-5685-9d52-b799b190518e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
