// Dragnet [Ransomware]: dragnet-ransomware-2024-3778 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: e00ed29f-2e92-5f99-b406-abe37360f92b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
