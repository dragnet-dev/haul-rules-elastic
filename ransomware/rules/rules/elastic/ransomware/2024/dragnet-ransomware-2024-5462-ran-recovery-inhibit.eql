// Dragnet [Ransomware]: dragnet-ransomware-2024-5462 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 1066638f-68e4-5e54-907c-d62ea1df2f6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
