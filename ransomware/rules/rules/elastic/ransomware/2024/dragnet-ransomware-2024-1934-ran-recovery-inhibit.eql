// Dragnet [Ransomware]: dragnet-ransomware-2024-1934 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cb169d19-2088-5a1a-901d-6dd340b9b14c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
