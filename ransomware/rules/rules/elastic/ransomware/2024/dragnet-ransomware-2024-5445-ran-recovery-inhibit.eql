// Dragnet [Ransomware]: dragnet-ransomware-2024-5445 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 7b1d7526-40fb-5119-8837-e7e8e003c513

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
