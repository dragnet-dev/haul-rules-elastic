// Dragnet [Ransomware]: dragnet-ransomware-2024-2469 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 69012d81-b2ad-51c3-9611-bdec3102dbe7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
