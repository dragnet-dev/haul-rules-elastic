// Dragnet [Ransomware]: dragnet-ransomware-2024-4540 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: 9aa9b072-b76d-5fbb-af60-3aa6a85aed8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
