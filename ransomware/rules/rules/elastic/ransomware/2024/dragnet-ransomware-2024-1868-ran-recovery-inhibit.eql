// Dragnet [Ransomware]: dragnet-ransomware-2024-1868 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: a23f5c21-436c-5423-91d9-d99523d9d919

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
