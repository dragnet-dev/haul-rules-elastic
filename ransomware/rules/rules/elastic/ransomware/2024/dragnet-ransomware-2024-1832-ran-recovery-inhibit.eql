// Dragnet [Ransomware]: dragnet-ransomware-2024-1832 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: a16e32c3-13d0-545e-b713-3175349cfb8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
