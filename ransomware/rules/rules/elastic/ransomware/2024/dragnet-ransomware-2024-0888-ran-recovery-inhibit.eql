// Dragnet [Ransomware]: dragnet-ransomware-2024-0888 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 22b6d0a1-c1e7-5673-9466-6d26c39441c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
