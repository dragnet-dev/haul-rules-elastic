// Dragnet [Ransomware]: dragnet-ransomware-2024-5067 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 3e28920b-d004-50a6-bfcf-d7f8f5b899c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
