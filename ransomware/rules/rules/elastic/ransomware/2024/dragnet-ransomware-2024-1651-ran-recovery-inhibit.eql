// Dragnet [Ransomware]: dragnet-ransomware-2024-1651 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f12d149e-6263-5f8f-a5a5-7463c9394bde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
