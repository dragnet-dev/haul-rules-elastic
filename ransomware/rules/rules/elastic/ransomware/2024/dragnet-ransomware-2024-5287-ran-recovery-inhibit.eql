// Dragnet [Ransomware]: dragnet-ransomware-2024-5287 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 5be44e61-f8c1-5911-8b49-703a33c350c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
