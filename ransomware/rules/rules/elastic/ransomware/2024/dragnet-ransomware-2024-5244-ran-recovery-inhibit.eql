// Dragnet [Ransomware]: dragnet-ransomware-2024-5244 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 97bed065-965c-5a98-888a-9d54eb1a7b02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
