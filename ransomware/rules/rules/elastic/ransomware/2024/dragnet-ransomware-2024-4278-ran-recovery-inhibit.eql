// Dragnet [Ransomware]: dragnet-ransomware-2024-4278 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: ca5dbdc1-c928-55db-95bc-563fd937326a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
