// Dragnet [Ransomware]: dragnet-ransomware-2024-5138 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: f3596206-7dc8-587e-b8a0-bcec7e1ff253

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
