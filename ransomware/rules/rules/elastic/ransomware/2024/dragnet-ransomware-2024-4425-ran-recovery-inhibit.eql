// Dragnet [Ransomware]: dragnet-ransomware-2024-4425 — Recovery Inhibition (raworld)
// Status: experimental | Level: high | ID: 7235641d-3d47-549d-8f1b-68085978b94b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
