// Dragnet [Ransomware]: dragnet-ransomware-2024-3343 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 7aa59d4f-a6d4-5af5-ba45-7b5e9d1eb949

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
