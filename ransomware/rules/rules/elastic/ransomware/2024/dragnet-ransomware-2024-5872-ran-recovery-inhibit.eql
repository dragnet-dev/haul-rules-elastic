// Dragnet [Ransomware]: dragnet-ransomware-2024-5872 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 340de662-665a-530b-9fbf-988774dd4ab7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
