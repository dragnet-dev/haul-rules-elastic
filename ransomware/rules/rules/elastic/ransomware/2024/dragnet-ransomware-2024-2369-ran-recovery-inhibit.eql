// Dragnet [Ransomware]: dragnet-ransomware-2024-2369 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f2b9e269-9322-5f71-bb18-3f560514364d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
