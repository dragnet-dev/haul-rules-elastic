// Dragnet [Ransomware]: dragnet-ransomware-2024-4820 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2e11b7a4-50a2-5bbd-90f0-e6a35299186a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
