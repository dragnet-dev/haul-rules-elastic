// Dragnet [Ransomware]: dragnet-ransomware-2024-5708 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 0f3536e5-2a1a-53db-b3bd-afaeb5ad9d94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
