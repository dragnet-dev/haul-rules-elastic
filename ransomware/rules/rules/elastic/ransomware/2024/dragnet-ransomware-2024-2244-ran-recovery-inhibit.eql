// Dragnet [Ransomware]: dragnet-ransomware-2024-2244 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1522b631-37f9-58cf-b5d1-2aab4f703129

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
