// Dragnet [Ransomware]: dragnet-ransomware-2024-0079 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: a398c0d4-a669-5098-9e3b-9788c2cfabc0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
