// Dragnet [Ransomware]: dragnet-ransomware-2024-0355 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 05109f04-4fb5-5de9-b040-2a536017be2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
