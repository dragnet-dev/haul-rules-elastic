// Dragnet [Ransomware]: dragnet-ransomware-2024-1975 — Recovery Inhibition (safepay)
// Status: deprecated | Level: high | ID: 62dfc697-737e-53bf-99e3-f9d0b3977806

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
