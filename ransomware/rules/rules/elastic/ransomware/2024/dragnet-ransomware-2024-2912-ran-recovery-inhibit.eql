// Dragnet [Ransomware]: dragnet-ransomware-2024-2912 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: ab4817ad-1ec8-54c7-835d-78d618d53ea0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
