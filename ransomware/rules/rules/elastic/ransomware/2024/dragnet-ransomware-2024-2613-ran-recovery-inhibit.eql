// Dragnet [Ransomware]: dragnet-ransomware-2024-2613 — Recovery Inhibition (frag)
// Status: deprecated | Level: high | ID: d711fab3-02e5-540d-991f-33365bdfd9db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
