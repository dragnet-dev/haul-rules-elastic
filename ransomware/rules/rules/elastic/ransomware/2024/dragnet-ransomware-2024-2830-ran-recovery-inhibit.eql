// Dragnet [Ransomware]: dragnet-ransomware-2024-2830 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 12553bd1-8eb8-5959-b5db-07c47eb1e9db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
