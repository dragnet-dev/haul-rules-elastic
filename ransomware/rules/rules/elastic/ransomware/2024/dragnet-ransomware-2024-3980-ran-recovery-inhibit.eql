// Dragnet [Ransomware]: dragnet-ransomware-2024-3980 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 7258300d-c123-5aae-84b1-42bede819b76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
