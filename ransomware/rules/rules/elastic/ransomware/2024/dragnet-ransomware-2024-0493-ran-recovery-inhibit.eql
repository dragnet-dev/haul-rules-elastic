// Dragnet [Ransomware]: dragnet-ransomware-2024-0493 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: deec838f-180c-51f9-bac1-6cc08fe87364

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
