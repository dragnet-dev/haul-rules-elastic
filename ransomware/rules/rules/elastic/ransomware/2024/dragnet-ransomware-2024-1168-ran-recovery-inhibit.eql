// Dragnet [Ransomware]: dragnet-ransomware-2024-1168 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: a6cab7ea-49a4-56a2-a73a-319814407ee1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
