// Dragnet [Ransomware]: dragnet-ransomware-2024-0132 — Recovery Inhibition (cloak)
// Status: experimental | Level: high | ID: a3ddcea3-b995-5704-b721-cfd109f25867

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
