// Dragnet [Ransomware]: dragnet-ransomware-2024-2677 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 8b641ae1-2fa4-56f9-957b-3668e1c10434

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
