// Dragnet [Ransomware]: dragnet-ransomware-2024-1102 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: f00c05fd-ba93-5683-956b-1aca03457bf3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
