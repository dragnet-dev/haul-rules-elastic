// Dragnet [Ransomware]: dragnet-ransomware-2024-4771 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 6e11f88f-437c-5dae-a5bd-ef4443e9a97d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
