// Dragnet [Ransomware]: dragnet-ransomware-2024-5921 — Recovery Inhibition (helldown)
// Status: experimental | Level: high | ID: 72e25aee-514e-5b57-bc24-dd7efd375a57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
