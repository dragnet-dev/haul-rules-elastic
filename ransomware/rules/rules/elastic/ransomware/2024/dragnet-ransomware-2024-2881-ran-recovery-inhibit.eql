// Dragnet [Ransomware]: dragnet-ransomware-2024-2881 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 14994976-aa55-531b-8680-e0511bcd41df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
