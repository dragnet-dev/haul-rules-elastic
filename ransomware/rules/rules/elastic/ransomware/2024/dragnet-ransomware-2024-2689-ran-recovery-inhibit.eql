// Dragnet [Ransomware]: dragnet-ransomware-2024-2689 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 976e13fe-4a2e-52c0-9342-b8b460325cef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
