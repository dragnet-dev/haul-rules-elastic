// Dragnet [Ransomware]: dragnet-ransomware-2024-2419 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: bb999c6f-5265-5ff1-90a2-b5434353c9bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
