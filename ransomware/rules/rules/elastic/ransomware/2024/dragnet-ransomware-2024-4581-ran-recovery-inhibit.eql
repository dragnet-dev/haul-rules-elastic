// Dragnet [Ransomware]: dragnet-ransomware-2024-4581 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: d09c4670-c289-5e01-bc43-9a72c9eab067

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
