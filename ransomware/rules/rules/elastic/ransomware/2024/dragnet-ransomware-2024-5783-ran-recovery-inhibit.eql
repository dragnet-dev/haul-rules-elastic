// Dragnet [Ransomware]: dragnet-ransomware-2024-5783 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: c6448c65-65ca-5fcf-995a-7856559c9ada

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
