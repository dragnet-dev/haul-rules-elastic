// Dragnet [Ransomware]: dragnet-ransomware-2024-3062 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f09ee9c8-372b-5940-8e09-dacc2ff0a1c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
