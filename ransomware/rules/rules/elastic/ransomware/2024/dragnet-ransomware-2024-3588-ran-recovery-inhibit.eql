// Dragnet [Ransomware]: dragnet-ransomware-2024-3588 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8a5dcfea-7d1e-5999-aedf-c68d9d2ee984

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
