// Dragnet [Ransomware]: dragnet-ransomware-2024-5875 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: d7089423-88cc-5415-92ce-96c1118ff42a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
