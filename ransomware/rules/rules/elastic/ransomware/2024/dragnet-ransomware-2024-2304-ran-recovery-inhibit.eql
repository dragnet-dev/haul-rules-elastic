// Dragnet [Ransomware]: dragnet-ransomware-2024-2304 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: 54334f19-30d4-528d-a2db-31e1862038e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
