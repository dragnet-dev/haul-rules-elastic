// Dragnet [Ransomware]: dragnet-ransomware-2024-0975 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a4ba55c2-706a-5530-a892-9f16c4a73206

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
