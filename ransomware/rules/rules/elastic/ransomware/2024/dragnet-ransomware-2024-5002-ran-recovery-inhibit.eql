// Dragnet [Ransomware]: dragnet-ransomware-2024-5002 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: fadf3f24-3a55-56b6-84bc-9cea7995f94d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
