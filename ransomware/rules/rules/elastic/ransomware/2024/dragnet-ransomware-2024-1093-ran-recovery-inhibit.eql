// Dragnet [Ransomware]: dragnet-ransomware-2024-1093 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: b5531bd6-3809-52e0-934a-f71a15ab6581

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
