// Dragnet [Ransomware]: dragnet-ransomware-2024-2160 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b0211fcd-303b-5ddd-a75c-4b456adad185

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
