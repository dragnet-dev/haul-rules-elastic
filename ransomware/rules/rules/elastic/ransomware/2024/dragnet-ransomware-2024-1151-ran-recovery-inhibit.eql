// Dragnet [Ransomware]: dragnet-ransomware-2024-1151 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 4d8df2da-47a1-5e85-94c3-a7e04278b031

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
