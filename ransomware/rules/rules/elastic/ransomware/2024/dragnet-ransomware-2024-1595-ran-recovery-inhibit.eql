// Dragnet [Ransomware]: dragnet-ransomware-2024-1595 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: c63f6b59-6a32-576c-adee-e30f9233e5b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
