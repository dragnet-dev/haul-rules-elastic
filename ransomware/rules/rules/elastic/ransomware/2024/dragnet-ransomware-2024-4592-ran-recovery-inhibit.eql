// Dragnet [Ransomware]: dragnet-ransomware-2024-4592 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 9df4e863-ca74-5ccf-abcf-882108d2f7ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
