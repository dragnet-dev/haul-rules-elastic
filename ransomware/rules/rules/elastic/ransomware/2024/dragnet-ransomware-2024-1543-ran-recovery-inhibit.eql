// Dragnet [Ransomware]: dragnet-ransomware-2024-1543 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: c258305b-0876-50df-9e8c-7c619b7d57f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
