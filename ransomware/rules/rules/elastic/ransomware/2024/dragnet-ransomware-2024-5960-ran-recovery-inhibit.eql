// Dragnet [Ransomware]: dragnet-ransomware-2024-5960 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: 0e9c41da-15e6-5184-9a8f-ce3fd7244f6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
