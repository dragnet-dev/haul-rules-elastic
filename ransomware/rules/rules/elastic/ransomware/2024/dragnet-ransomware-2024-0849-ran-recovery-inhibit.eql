// Dragnet [Ransomware]: dragnet-ransomware-2024-0849 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6f8204fb-31c5-5b9a-b73b-257d050fd5c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
