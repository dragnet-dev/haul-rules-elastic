// Dragnet [Ransomware]: dragnet-ransomware-2024-4087 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: af6bb60f-c0a8-532f-988c-fc20c801f4d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
