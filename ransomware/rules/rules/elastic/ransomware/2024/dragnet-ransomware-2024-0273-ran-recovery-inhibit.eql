// Dragnet [Ransomware]: dragnet-ransomware-2024-0273 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 15653d50-858c-54ca-a1e0-ea67f00c00dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
