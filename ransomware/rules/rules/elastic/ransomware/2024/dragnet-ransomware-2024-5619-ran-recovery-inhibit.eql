// Dragnet [Ransomware]: dragnet-ransomware-2024-5619 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a78e5bde-4413-5018-b9ab-fafb29f18586

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
