// Dragnet [Ransomware]: dragnet-ransomware-2024-3396 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e0e2b288-95ba-5db8-a9d0-22b9a0795061

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
