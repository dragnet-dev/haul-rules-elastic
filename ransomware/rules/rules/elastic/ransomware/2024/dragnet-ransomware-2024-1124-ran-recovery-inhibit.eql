// Dragnet [Ransomware]: dragnet-ransomware-2024-1124 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 2fd68625-f7cb-5a50-87d0-858858d2cca6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
