// Dragnet [Ransomware]: dragnet-ransomware-2024-3926 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 8bd7e1a2-39b9-5ad3-b850-3d3491558353

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
