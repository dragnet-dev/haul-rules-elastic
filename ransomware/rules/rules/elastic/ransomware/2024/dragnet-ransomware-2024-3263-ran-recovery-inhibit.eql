// Dragnet [Ransomware]: dragnet-ransomware-2024-3263 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 1c2125a2-9f77-5710-b16b-ccaa5cdd0afb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
