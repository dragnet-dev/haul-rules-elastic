// Dragnet [Ransomware]: dragnet-ransomware-2024-3734 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 64e80445-ba6f-5e8e-aacf-1a77eabbfbdf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
