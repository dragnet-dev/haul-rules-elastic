// Dragnet [Ransomware]: dragnet-ransomware-2024-5150 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 44c4bb93-df3c-567c-bc4e-12064fba1159

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
