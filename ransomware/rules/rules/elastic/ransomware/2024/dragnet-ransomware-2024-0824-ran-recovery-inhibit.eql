// Dragnet [Ransomware]: dragnet-ransomware-2024-0824 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: bb941546-0eea-5698-9184-7e601392a1dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
