// Dragnet [Ransomware]: dragnet-ransomware-2024-5526 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 17fdfca0-0da2-5bab-b720-c5039d8d91a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
