// Dragnet [Ransomware]: dragnet-ransomware-2024-5145 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 1a3e8c89-aa1d-52d2-9456-e117c14c81b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
