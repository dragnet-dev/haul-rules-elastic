// Dragnet [Ransomware]: dragnet-ransomware-2024-2980 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 18eeaa5a-6443-5769-aaa2-55e585f6331c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
