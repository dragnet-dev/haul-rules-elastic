// Dragnet [Ransomware]: dragnet-ransomware-2024-6019 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 568e78dc-8b18-5884-a0a5-c9e2d4116e79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
