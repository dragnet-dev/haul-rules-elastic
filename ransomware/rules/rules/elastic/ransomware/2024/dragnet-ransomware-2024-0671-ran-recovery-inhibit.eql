// Dragnet [Ransomware]: dragnet-ransomware-2024-0671 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: dafaf916-0230-54ed-851c-cbdb768c0eee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
