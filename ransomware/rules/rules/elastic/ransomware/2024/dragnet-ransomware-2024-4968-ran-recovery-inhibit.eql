// Dragnet [Ransomware]: dragnet-ransomware-2024-4968 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: ed0fa375-1c05-5f15-8571-b6620a33c318

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
