// Dragnet [Ransomware]: dragnet-ransomware-2024-5642 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: de630b8e-a166-5e83-82eb-e11283d9389d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
