// Dragnet [Ransomware]: dragnet-ransomware-2024-1023 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 1dff653c-1920-53df-a4f7-6bb3a83e531d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
