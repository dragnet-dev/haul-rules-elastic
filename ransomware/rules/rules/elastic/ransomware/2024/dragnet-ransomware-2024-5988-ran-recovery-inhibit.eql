// Dragnet [Ransomware]: dragnet-ransomware-2024-5988 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: 5a0ae204-8fca-5248-b36b-52138c52fb6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
