// Dragnet [Ransomware]: dragnet-ransomware-2024-2751 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: a8054253-f932-538a-a23b-cfae3be46ae8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
