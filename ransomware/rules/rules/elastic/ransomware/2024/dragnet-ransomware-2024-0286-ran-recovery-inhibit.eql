// Dragnet [Ransomware]: dragnet-ransomware-2024-0286 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: cb8b235a-ad32-5683-8237-9b7acb7113bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
