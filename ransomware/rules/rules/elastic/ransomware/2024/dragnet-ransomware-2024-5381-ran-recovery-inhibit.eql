// Dragnet [Ransomware]: dragnet-ransomware-2024-5381 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b8aafa9a-abd4-5e9d-83ff-31ebd44b0351

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
