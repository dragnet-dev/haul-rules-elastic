// Dragnet [Ransomware]: dragnet-ransomware-2024-1234 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 581b1c79-b123-5950-9a6d-284e86d29fe4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
