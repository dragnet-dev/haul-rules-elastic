// Dragnet [Ransomware]: dragnet-ransomware-2024-1392 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 11fabf1c-1fe4-583a-ae68-ffe29cfaaf69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
