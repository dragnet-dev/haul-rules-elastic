// Dragnet [Ransomware]: dragnet-ransomware-2024-2216 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 0b7515ec-fb17-533e-81ee-7874aa716b52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
