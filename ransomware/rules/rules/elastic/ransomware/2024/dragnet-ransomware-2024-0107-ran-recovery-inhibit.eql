// Dragnet [Ransomware]: dragnet-ransomware-2024-0107 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: 97937a8b-fdee-56b1-85f0-c5593bd79cd6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
