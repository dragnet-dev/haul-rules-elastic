// Dragnet [Ransomware]: dragnet-ransomware-2024-1815 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4b61cc02-31f2-54dd-a7f6-3eac8bd298b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
