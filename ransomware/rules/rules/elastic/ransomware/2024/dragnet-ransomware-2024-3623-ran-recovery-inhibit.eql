// Dragnet [Ransomware]: dragnet-ransomware-2024-3623 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: e48991e8-f3c9-5965-82eb-3bb033ab14cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
