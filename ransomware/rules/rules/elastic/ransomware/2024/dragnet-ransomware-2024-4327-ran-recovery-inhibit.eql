// Dragnet [Ransomware]: dragnet-ransomware-2024-4327 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: aa8d804b-3be6-59f7-9b03-819321aad7e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
