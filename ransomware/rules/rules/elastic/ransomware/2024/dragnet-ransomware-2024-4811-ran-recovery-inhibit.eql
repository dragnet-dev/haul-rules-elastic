// Dragnet [Ransomware]: dragnet-ransomware-2024-4811 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1407c6e6-55b9-5200-b9e0-13a8ace1e587

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
