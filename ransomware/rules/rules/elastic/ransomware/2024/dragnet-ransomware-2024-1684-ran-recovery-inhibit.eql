// Dragnet [Ransomware]: dragnet-ransomware-2024-1684 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1af49c82-126c-5e71-bb45-49a466247567

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
