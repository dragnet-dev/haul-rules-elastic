// Dragnet [Ransomware]: dragnet-ransomware-2024-2290 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 3e737ada-b1a1-5821-92a3-74e060ef3e9c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
