// Dragnet [Ransomware]: dragnet-ransomware-2024-5012 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 62263430-d07a-5062-80be-a869bf444d64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
