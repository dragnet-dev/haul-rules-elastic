// Dragnet [Ransomware]: dragnet-ransomware-2024-5606 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2959c6ba-081e-5614-b894-bfda5407b632

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
