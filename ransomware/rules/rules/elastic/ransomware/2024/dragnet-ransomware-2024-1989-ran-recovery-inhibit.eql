// Dragnet [Ransomware]: dragnet-ransomware-2024-1989 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 93d082fb-e238-5cf6-bbab-d42859b159ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
