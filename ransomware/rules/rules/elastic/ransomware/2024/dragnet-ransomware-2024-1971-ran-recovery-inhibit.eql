// Dragnet [Ransomware]: dragnet-ransomware-2024-1971 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 121f42e0-dddc-53ce-ad68-c5f749368ef0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
