// Dragnet [Ransomware]: dragnet-ransomware-2024-2524 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 35aa2b5c-35a6-5bcb-a484-4fb84c1ccb58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
