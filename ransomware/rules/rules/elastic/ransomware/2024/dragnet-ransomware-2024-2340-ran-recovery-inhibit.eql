// Dragnet [Ransomware]: dragnet-ransomware-2024-2340 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9cf21e36-ddaa-5360-89ee-648d555c9110

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
