// Dragnet [Ransomware]: dragnet-ransomware-2024-3929 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: f03c0bf4-b7a6-5f22-9b39-f8678201677d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
