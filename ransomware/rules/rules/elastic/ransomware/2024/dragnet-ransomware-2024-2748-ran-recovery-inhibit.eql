// Dragnet [Ransomware]: dragnet-ransomware-2024-2748 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: d2959660-b152-5d07-85a6-e621bf565435

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
