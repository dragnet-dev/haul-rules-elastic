// Dragnet [Ransomware]: dragnet-ransomware-2024-5332 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 056954b6-93f3-51ea-ad6f-6623a8048fbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
