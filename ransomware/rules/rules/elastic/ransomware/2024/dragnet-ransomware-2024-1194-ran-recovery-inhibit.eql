// Dragnet [Ransomware]: dragnet-ransomware-2024-1194 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: a8804289-52ad-5192-a3e1-4d21bd7dba33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
