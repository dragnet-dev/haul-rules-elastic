// Dragnet [Ransomware]: dragnet-ransomware-2024-5610 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: e19222b0-0623-5c75-ab60-c75d3240c559

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
