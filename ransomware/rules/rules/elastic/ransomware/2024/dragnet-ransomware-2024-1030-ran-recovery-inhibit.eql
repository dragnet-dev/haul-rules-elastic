// Dragnet [Ransomware]: dragnet-ransomware-2024-1030 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: dfd6ee8e-3f4f-511d-8c19-b230b2a9f424

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
