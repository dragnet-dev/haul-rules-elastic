// Dragnet [Ransomware]: dragnet-ransomware-2024-5266 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 211fc06a-4190-5019-8c27-b535a334dff8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
