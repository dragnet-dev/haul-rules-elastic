// Dragnet [Ransomware]: dragnet-ransomware-2024-5155 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 8e28c93b-ffba-5509-8e5f-a7c9a5a05194

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
