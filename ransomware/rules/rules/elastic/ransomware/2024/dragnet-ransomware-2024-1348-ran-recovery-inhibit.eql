// Dragnet [Ransomware]: dragnet-ransomware-2024-1348 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: dff2d0a2-aa44-52c1-9023-f6d523ba7598

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
