// Dragnet [Ransomware]: dragnet-ransomware-2024-3160 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c1e44c45-5500-5237-b282-db60309e4f12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
