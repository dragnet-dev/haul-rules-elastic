// Dragnet [Ransomware]: dragnet-ransomware-2024-3124 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 79031537-18e8-5742-af80-552a17fdf1d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
