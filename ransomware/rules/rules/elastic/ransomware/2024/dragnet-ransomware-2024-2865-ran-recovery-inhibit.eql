// Dragnet [Ransomware]: dragnet-ransomware-2024-2865 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 3d7d1977-56a8-567b-be75-63daba3d429b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
