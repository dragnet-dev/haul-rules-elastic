// Dragnet [Ransomware]: dragnet-ransomware-2024-0066 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: aab11fa8-6e36-535e-8c85-29b5e552c29a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
