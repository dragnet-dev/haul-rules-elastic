// Dragnet [Ransomware]: dragnet-ransomware-2024-3224 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 1396c639-e0bf-5aea-b24f-262b262fbf2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
