// Dragnet [Ransomware]: dragnet-ransomware-2024-3763 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4e3c862e-cc4a-56e5-80cf-7e4c25d35a1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
