// Dragnet [Ransomware]: dragnet-ransomware-2024-2821 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e846b532-c7ad-5c0f-94c5-60ff8d02f197

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
