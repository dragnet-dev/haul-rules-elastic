// Dragnet [Ransomware]: dragnet-ransomware-2024-0913 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 1ecb1e15-4919-5879-ab29-e570aaeb130f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
