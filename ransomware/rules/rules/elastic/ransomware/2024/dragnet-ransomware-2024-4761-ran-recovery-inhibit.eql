// Dragnet [Ransomware]: dragnet-ransomware-2024-4761 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e31aaf70-10b1-519b-87bb-31af90f19bc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
