// Dragnet [Ransomware]: dragnet-ransomware-2024-2155 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: db676211-f859-5fe1-b74b-e66225d1090f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
