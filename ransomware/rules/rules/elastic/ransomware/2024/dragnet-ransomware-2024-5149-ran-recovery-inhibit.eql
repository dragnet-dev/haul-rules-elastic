// Dragnet [Ransomware]: dragnet-ransomware-2024-5149 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: fac5ab28-221f-554c-b21e-257877493899

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
