// Dragnet [Ransomware]: dragnet-ransomware-2024-2876 — Recovery Inhibition (dragonforce)
// Status: deprecated | Level: high | ID: ad958aae-1dde-530b-815e-a5bab81f51a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
