// Dragnet [Ransomware]: dragnet-ransomware-2024-0003 — Recovery Inhibition (meow)
// Status: experimental | Level: high | ID: aae2d985-aefa-535f-9be2-b6a0d131feac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
