// Dragnet [Ransomware]: dragnet-ransomware-2024-5956 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 5daec791-5429-52f2-b8e8-76dd9a8f7e18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
