// Dragnet [Ransomware]: dragnet-ransomware-2024-2228 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: 887298bd-5be8-59eb-94d4-ecf485d97544

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
