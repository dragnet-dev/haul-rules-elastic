// Dragnet [Ransomware]: dragnet-ransomware-2024-3240 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 82978b14-2cb2-5028-a689-b73289f7d0f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
