// Dragnet [Ransomware]: dragnet-ransomware-2024-2537 — Recovery Inhibition (blackbasta)
// Status: experimental | Level: high | ID: e8dea83b-8c87-5566-9465-41b6d0ae4ffd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
