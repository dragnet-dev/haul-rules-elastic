// Dragnet [Ransomware]: dragnet-ransomware-2024-4185 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: f1a492c4-1710-550f-8b04-ed54e91d3932

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
