// Dragnet [Ransomware]: dragnet-ransomware-2024-4670 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 80e2cac5-ffc8-5d76-be65-1ec60c2e02b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
