// Dragnet [Ransomware]: dragnet-ransomware-2022-2653 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: f7e83bf9-1aef-5110-984d-473c0f7d06c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
