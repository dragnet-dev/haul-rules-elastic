// Dragnet [Ransomware]: dragnet-ransomware-2022-0856 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 7664e5b5-c8db-5943-b273-c6dc4fec0e5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
