// Dragnet [Ransomware]: dragnet-ransomware-2022-2686 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 8ec095ef-184c-5fc4-9b4a-bd8e44e325dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
