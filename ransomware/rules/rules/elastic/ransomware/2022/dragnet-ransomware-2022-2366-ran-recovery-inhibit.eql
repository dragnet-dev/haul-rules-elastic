// Dragnet [Ransomware]: dragnet-ransomware-2022-2366 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 19eabfcb-a2d0-5908-8945-a7a7ca815d1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
