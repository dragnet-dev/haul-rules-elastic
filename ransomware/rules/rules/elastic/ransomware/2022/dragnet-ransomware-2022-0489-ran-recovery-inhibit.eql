// Dragnet [Ransomware]: dragnet-ransomware-2022-0489 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 09f3e198-e870-5297-9ca6-2cbf33eb8df0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
