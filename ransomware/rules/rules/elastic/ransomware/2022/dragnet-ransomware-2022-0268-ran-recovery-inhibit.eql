// Dragnet [Ransomware]: dragnet-ransomware-2022-0268 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 3be7ccad-1eca-5bff-8d7b-0838ec7ecd35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
