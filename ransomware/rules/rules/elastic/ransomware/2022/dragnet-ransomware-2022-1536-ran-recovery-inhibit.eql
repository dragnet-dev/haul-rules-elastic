// Dragnet [Ransomware]: dragnet-ransomware-2022-1536 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 79cadfea-ae7b-5bd2-afe7-949231106992

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
