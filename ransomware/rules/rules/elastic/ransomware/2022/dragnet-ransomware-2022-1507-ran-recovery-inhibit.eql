// Dragnet [Ransomware]: dragnet-ransomware-2022-1507 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: b0998ca4-2940-52ae-a7af-110da7ba032e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
