// Dragnet [Ransomware]: dragnet-ransomware-2022-2560 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: b1c9ef16-c0e0-585e-a833-a6409255c572

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
