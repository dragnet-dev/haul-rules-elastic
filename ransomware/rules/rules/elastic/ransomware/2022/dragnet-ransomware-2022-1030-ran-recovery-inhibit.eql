// Dragnet [Ransomware]: dragnet-ransomware-2022-1030 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: e1658022-cfa9-5f6a-a93e-32519d642bc9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
