// Dragnet [Ransomware]: dragnet-ransomware-2022-0543 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4f89d444-d51a-5ad0-bba8-d81b60ef64c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
