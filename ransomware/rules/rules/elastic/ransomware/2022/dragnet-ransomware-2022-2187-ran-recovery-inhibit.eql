// Dragnet [Ransomware]: dragnet-ransomware-2022-2187 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 6a7e5a40-d516-53d4-85d1-5e101a1de0ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
