// Dragnet [Ransomware]: dragnet-ransomware-2022-2745 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a0890e52-f801-547d-8419-1b0ed7024125

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
