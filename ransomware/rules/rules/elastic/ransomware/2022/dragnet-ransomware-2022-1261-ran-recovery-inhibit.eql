// Dragnet [Ransomware]: dragnet-ransomware-2022-1261 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 7aaafa98-6e41-5dc1-9435-d7ec0281ebc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
