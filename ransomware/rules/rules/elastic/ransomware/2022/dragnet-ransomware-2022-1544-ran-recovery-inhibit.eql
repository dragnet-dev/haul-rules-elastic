// Dragnet [Ransomware]: dragnet-ransomware-2022-1544 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 7ffa78e3-212b-5958-999f-a33853d2a505

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
