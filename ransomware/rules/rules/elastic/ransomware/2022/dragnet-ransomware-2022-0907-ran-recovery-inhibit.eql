// Dragnet [Ransomware]: dragnet-ransomware-2022-0907 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ec5f6022-9387-563a-a539-2e2f939f304b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
