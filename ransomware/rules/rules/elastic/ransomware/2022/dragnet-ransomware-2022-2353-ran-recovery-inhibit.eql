// Dragnet [Ransomware]: dragnet-ransomware-2022-2353 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 0410252e-3492-5c07-b16e-6972c0904ac5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
