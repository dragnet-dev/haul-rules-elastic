// Dragnet [Ransomware]: dragnet-ransomware-2022-3128 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: d4a3e157-f26a-52f0-9bac-ae5fe00ca8ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
