// Dragnet [Ransomware]: dragnet-ransomware-2022-0850 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: d8c01954-c08f-56fc-885d-362c26dcc3c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
