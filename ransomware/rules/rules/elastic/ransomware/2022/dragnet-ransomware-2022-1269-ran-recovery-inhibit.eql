// Dragnet [Ransomware]: dragnet-ransomware-2022-1269 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: 7a078927-5707-5b7d-b187-4ff14a98c995

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
