// Dragnet [Ransomware]: dragnet-ransomware-2022-2241 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: d04ae64c-9c24-55d7-bb3e-da06abee054f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
