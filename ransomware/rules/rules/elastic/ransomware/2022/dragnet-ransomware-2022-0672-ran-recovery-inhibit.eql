// Dragnet [Ransomware]: dragnet-ransomware-2022-0672 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 5e7289df-aae6-53cb-8b10-794d3a91994a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
