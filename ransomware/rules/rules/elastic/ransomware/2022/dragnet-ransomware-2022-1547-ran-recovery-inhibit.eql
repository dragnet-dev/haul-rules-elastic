// Dragnet [Ransomware]: dragnet-ransomware-2022-1547 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 986c912a-5cf7-5c29-940d-000c35042028

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
