// Dragnet [Ransomware]: dragnet-ransomware-2022-0217 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 85434bd8-c0e9-5083-a8c8-b95661992104

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
