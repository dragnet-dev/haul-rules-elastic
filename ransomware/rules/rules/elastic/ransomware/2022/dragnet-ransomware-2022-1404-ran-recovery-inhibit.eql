// Dragnet [Ransomware]: dragnet-ransomware-2022-1404 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: abda41d5-76b7-5071-b0b9-2c82e6efa0df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
