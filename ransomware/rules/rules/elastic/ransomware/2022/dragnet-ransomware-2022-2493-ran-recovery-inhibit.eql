// Dragnet [Ransomware]: dragnet-ransomware-2022-2493 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5aa926bc-b7be-56d2-b4ad-4fca5bfd9830

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
