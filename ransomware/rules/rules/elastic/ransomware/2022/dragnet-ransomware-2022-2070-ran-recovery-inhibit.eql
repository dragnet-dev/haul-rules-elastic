// Dragnet [Ransomware]: dragnet-ransomware-2022-2070 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 63b10c85-56b6-5101-a1f0-d04ca3825e31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
