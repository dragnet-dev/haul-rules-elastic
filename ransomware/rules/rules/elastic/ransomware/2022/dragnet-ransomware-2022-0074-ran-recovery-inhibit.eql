// Dragnet [Ransomware]: dragnet-ransomware-2022-0074 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 4db4778a-2b6d-56d9-869c-d7e17140427e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
