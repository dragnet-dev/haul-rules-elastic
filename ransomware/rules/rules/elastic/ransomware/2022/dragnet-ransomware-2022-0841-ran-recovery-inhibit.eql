// Dragnet [Ransomware]: dragnet-ransomware-2022-0841 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: df07cadf-de71-581a-bf54-97d6add3f10a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
