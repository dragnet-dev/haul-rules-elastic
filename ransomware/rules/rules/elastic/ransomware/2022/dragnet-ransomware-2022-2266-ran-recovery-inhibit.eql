// Dragnet [Ransomware]: dragnet-ransomware-2022-2266 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 4d1b29fd-bb2e-5526-ba0d-f840742b9580

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
