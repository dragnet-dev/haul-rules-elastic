// Dragnet [Ransomware]: dragnet-ransomware-2022-1731 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: d5baa1db-e067-5473-aa45-02e55cf4ecea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
