// Dragnet [Ransomware]: dragnet-ransomware-2022-1143 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 44d1bea7-dc3a-52e5-a47d-c8cf1bf9822a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
