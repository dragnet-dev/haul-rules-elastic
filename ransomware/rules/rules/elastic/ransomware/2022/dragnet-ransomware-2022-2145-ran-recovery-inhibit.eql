// Dragnet [Ransomware]: dragnet-ransomware-2022-2145 — Recovery Inhibition (daixin)
// Status: deprecated | Level: high | ID: a641d964-30f0-50ea-b181-9abfe790e799

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
