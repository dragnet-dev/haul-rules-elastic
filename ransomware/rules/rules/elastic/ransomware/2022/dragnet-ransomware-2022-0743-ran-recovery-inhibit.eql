// Dragnet [Ransomware]: dragnet-ransomware-2022-0743 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5be98efa-556f-5bc8-9bed-607b18b7cf13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
