// Dragnet [Ransomware]: dragnet-ransomware-2022-2899 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 8383e5a7-f60e-5663-8645-90c721557ed8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
