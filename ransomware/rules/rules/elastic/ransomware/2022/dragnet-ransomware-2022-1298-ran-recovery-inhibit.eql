// Dragnet [Ransomware]: dragnet-ransomware-2022-1298 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 446e06ec-eb97-569b-b1c0-b363ff93bdce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
