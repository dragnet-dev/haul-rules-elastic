// Dragnet [Ransomware]: dragnet-ransomware-2022-3019 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 4d68ce51-6e44-57ef-8e8e-11e163fccec6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
