// Dragnet [Ransomware]: dragnet-ransomware-2022-1762 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: aa3b1575-1785-5155-b117-806e6066c48a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
