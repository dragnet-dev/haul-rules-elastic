// Dragnet [Ransomware]: dragnet-ransomware-2022-2456 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e2c0a021-6219-5bec-9fa7-ee4e161a0742

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
