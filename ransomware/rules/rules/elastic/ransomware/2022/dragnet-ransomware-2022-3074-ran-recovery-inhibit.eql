// Dragnet [Ransomware]: dragnet-ransomware-2022-3074 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 224261eb-687f-59c6-b316-2957b2fb582a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
