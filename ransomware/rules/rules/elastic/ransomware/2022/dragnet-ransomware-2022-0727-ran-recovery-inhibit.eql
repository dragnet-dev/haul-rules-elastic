// Dragnet [Ransomware]: dragnet-ransomware-2022-0727 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 1337c91d-2ad3-598d-bb36-da74df97fc3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
