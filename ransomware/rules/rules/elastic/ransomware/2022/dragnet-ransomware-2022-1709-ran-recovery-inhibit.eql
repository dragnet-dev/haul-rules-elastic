// Dragnet [Ransomware]: dragnet-ransomware-2022-1709 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 6fd6e1db-eeb7-5a76-b975-8dff26d9425d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
