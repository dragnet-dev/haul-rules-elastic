// Dragnet [Ransomware]: dragnet-ransomware-2022-0681 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 01ab1b3a-95ad-5312-9334-31fc36c013f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
