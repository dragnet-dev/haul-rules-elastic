// Dragnet [Ransomware]: dragnet-ransomware-2022-0550 — Recovery Inhibition (projectrelic)
// Status: deprecated | Level: high | ID: 20a0c801-fc7c-5b3e-9e44-2c66608ff92f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
