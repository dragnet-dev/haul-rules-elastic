// Dragnet [Ransomware]: dragnet-ransomware-2022-1934 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: e79949c6-6e23-5eac-8493-7d040307fae1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
