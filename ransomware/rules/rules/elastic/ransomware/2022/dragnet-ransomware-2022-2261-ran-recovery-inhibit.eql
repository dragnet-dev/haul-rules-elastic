// Dragnet [Ransomware]: dragnet-ransomware-2022-2261 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 984a2bb3-dc04-5738-80c7-7ba219b0694b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
