// Dragnet [Ransomware]: dragnet-ransomware-2022-1627 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 7f037a77-748c-575c-a5ab-dc75d7772529

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
