// Dragnet [Ransomware]: dragnet-ransomware-2022-0229 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: bb1296d2-a8df-5e2d-894e-5bd9fce7b633

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
