// Dragnet [Ransomware]: dragnet-ransomware-2022-2865 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: c2e41e21-a166-5d54-9e63-7141ac84824b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
