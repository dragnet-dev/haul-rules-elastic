// Dragnet [Ransomware]: dragnet-ransomware-2022-2511 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: be4ceaa7-a5c6-5ac9-bdb5-bebba749ff27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
