// Dragnet [Ransomware]: dragnet-ransomware-2022-2896 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: da5edbf3-cf72-5cd4-841b-3c133f9cba25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
