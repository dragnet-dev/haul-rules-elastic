// Dragnet [Ransomware]: dragnet-ransomware-2022-1497 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 3697c6d9-dda0-57f2-80c0-576c4a7d4c42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
