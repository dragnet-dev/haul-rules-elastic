// Dragnet [Ransomware]: dragnet-ransomware-2022-1910 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: d311eafb-fb64-5995-a58a-e24eb6c5e334

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
