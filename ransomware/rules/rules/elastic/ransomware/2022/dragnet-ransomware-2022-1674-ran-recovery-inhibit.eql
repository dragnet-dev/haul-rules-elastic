// Dragnet [Ransomware]: dragnet-ransomware-2022-1674 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 325dc659-c04c-593f-b64f-c78a9fe359fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
