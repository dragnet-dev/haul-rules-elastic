// Dragnet [Ransomware]: dragnet-ransomware-2022-0058 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 2231ad61-cc1e-575b-b467-d2190d3f76c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
