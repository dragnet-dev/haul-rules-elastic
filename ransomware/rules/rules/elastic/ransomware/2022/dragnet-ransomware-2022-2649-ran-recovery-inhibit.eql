// Dragnet [Ransomware]: dragnet-ransomware-2022-2649 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: f0373f56-172e-5322-b274-bdb862b1b829

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
