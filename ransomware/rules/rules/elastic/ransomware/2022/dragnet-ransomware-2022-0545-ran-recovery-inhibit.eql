// Dragnet [Ransomware]: dragnet-ransomware-2022-0545 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 2d07f7d5-f68b-5404-8116-0fff7d98d193

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
