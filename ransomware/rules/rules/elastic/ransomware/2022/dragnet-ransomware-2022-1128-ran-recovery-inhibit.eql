// Dragnet [Ransomware]: dragnet-ransomware-2022-1128 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 37e41d60-a552-50f2-a2a9-335e660fc31c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
