// Dragnet [Ransomware]: dragnet-ransomware-2022-2654 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 9c60feb1-20cf-57e9-b554-4283545ef5a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
