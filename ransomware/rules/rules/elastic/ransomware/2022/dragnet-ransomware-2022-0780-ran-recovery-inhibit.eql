// Dragnet [Ransomware]: dragnet-ransomware-2022-0780 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a2dd7a29-6157-5db6-bfed-6e070acac5d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
