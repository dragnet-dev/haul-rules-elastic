// Dragnet [Ransomware]: dragnet-ransomware-2022-1496 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a6b47a8e-487b-51f9-a8cd-c03a9cff5114

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
