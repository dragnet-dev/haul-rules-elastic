// Dragnet [Ransomware]: dragnet-ransomware-2022-3135 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e9d179c9-3df0-5d54-8b43-08418cc8b2ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
