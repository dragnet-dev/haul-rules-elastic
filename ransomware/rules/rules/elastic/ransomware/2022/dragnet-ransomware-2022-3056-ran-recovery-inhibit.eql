// Dragnet [Ransomware]: dragnet-ransomware-2022-3056 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 66984542-7001-5bad-8a5f-7e06792f2ad2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
