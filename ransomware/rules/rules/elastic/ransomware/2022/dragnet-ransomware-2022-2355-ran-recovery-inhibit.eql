// Dragnet [Ransomware]: dragnet-ransomware-2022-2355 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f629eeab-6db9-5bdc-b346-79839a8cb83c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
