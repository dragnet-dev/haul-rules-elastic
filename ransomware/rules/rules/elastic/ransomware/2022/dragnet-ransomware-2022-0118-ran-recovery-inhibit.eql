// Dragnet [Ransomware]: dragnet-ransomware-2022-0118 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: a278f568-fcb4-5394-b324-80c8579a21aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
