// Dragnet [Ransomware]: dragnet-ransomware-2022-1292 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 870e6e7d-cb85-5478-a90c-283292cd61d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
