// Dragnet [Ransomware]: dragnet-ransomware-2022-0999 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: 740c8606-1ca0-5d1b-8305-cceafaa72da6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
