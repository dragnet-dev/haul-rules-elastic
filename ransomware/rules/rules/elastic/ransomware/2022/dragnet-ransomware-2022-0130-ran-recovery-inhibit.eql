// Dragnet [Ransomware]: dragnet-ransomware-2022-0130 — Recovery Inhibition (pandora)
// Status: deprecated | Level: high | ID: 38afc2ed-78b8-5e9a-925a-1b784f6487f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
