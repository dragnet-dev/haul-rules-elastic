// Dragnet [Ransomware]: dragnet-ransomware-2022-1997 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: b09ab53f-b05e-50c9-9328-3b672f903e18

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
