// Dragnet [Ransomware]: dragnet-ransomware-2022-2396 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: 3af99d63-4659-5c08-a2d0-d37850d8e1a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
