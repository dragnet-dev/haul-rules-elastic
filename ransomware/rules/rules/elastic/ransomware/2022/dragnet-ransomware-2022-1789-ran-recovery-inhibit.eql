// Dragnet [Ransomware]: dragnet-ransomware-2022-1789 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 1af13088-86c2-5fea-a7a4-68c927f81c80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
