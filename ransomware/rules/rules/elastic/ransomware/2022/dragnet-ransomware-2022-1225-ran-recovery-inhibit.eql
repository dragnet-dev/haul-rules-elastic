// Dragnet [Ransomware]: dragnet-ransomware-2022-1225 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 33f046af-a2f3-5ec4-833d-ee519d13695d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
