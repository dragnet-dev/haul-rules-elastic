// Dragnet [Ransomware]: dragnet-ransomware-2022-2919 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 1fe06dca-da35-5852-8158-45fec72ed006

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
