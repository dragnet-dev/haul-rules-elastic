// Dragnet [Ransomware]: dragnet-ransomware-2022-1633 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: f969b95e-578a-5d08-9c5a-8ae47c027e8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
