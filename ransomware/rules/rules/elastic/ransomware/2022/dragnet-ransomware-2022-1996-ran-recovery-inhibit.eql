// Dragnet [Ransomware]: dragnet-ransomware-2022-1996 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 200730ad-a2c2-5bda-a54f-8cab0338d12b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
