// Dragnet [Ransomware]: dragnet-ransomware-2022-0872 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 4b1ff896-d9fa-59af-9dc1-381240bf3b3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
