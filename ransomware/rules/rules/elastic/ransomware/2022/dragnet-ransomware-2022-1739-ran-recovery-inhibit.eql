// Dragnet [Ransomware]: dragnet-ransomware-2022-1739 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: d9d74b29-4575-5626-aac6-e27b936b939f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
