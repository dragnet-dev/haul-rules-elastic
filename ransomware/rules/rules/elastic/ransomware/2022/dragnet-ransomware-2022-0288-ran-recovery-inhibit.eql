// Dragnet [Ransomware]: dragnet-ransomware-2022-0288 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 55c94a4f-c1fc-5126-8b30-adc9b64cd01b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
