// Dragnet [Ransomware]: dragnet-ransomware-2022-1353 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8b957ad5-67f9-5cdb-ba33-4edc0cc374be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
