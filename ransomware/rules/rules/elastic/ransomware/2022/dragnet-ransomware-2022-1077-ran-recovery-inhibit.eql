// Dragnet [Ransomware]: dragnet-ransomware-2022-1077 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 59ca8ff2-9523-5e18-b603-0cb5e13f2f9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
