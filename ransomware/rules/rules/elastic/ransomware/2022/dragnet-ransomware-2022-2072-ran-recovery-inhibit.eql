// Dragnet [Ransomware]: dragnet-ransomware-2022-2072 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2021254b-b902-5a7b-bc2c-ea3946d57aea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
