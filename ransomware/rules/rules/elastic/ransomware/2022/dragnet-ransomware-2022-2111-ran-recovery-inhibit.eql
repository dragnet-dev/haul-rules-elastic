// Dragnet [Ransomware]: dragnet-ransomware-2022-2111 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: fb5f3a7c-e858-578f-a55e-e51e90c9a3ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
