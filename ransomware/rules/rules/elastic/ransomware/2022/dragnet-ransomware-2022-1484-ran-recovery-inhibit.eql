// Dragnet [Ransomware]: dragnet-ransomware-2022-1484 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: 638181bc-bce0-5125-ad75-8f190ec7452a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
