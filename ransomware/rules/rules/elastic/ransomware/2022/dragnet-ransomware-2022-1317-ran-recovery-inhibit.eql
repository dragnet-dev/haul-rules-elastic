// Dragnet [Ransomware]: dragnet-ransomware-2022-1317 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 7341b85a-4d49-5050-9523-7a40b28d8575

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
