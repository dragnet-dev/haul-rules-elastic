// Dragnet [Ransomware]: dragnet-ransomware-2022-1792 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5802a859-71bf-51af-9d13-611869357f93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
