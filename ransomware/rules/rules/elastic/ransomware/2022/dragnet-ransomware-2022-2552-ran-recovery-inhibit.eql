// Dragnet [Ransomware]: dragnet-ransomware-2022-2552 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 377c53a0-2a54-5fd8-9424-06864a9cbd93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
