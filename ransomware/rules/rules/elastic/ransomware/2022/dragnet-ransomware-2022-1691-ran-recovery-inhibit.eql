// Dragnet [Ransomware]: dragnet-ransomware-2022-1691 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 2fa22e45-9609-5cdc-9d92-83c5af00275b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
