// Dragnet [Ransomware]: dragnet-ransomware-2022-0622 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4521353d-fddd-50fd-9c6c-040fb29a7f81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
