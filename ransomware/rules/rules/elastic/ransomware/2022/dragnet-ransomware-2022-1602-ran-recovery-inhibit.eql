// Dragnet [Ransomware]: dragnet-ransomware-2022-1602 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 861f45d8-f426-5b01-9a58-da2ba609dea2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
