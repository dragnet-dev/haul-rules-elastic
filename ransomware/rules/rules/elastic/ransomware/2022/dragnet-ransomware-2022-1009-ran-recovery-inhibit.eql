// Dragnet [Ransomware]: dragnet-ransomware-2022-1009 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 10ce754c-05ef-5a26-87d1-e66fbb96c92f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
