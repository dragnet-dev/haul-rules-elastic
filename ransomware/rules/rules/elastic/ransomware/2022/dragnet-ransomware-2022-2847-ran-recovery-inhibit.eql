// Dragnet [Ransomware]: dragnet-ransomware-2022-2847 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a9832e08-2f88-5aae-8fa6-c719545750a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
