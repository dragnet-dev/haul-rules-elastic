// Dragnet [Ransomware]: dragnet-ransomware-2022-2061 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 85e1954e-beff-5f8f-97a6-afa009b32581

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
