// Dragnet [Ransomware]: dragnet-ransomware-2022-3115 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 9524cc5c-ee8c-5d05-aeb2-b94c058804e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
