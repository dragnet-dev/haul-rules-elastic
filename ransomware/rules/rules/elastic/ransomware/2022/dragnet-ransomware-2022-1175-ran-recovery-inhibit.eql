// Dragnet [Ransomware]: dragnet-ransomware-2022-1175 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: d862d3aa-74a4-5bad-9234-7dd6f47b0eeb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
