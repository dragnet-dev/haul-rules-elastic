// Dragnet [Ransomware]: dragnet-ransomware-2022-2739 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: df9e1881-3ef6-5808-acb1-bf7a354d3e7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
