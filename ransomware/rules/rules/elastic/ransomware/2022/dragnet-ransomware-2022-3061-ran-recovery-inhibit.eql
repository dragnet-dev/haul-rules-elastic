// Dragnet [Ransomware]: dragnet-ransomware-2022-3061 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 32a9cd65-7f1c-50da-aec0-4f5b9ce368db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
