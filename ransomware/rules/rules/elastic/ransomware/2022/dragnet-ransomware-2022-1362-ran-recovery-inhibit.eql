// Dragnet [Ransomware]: dragnet-ransomware-2022-1362 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: a4ed7686-aeb0-54a1-92bb-889eff86c3bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
