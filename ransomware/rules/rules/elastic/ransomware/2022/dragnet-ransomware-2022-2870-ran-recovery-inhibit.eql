// Dragnet [Ransomware]: dragnet-ransomware-2022-2870 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 9cb4b12c-7b6c-5714-8dcc-480cc5858964

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
