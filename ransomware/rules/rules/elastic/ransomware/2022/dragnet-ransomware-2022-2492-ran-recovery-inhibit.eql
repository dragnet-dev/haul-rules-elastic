// Dragnet [Ransomware]: dragnet-ransomware-2022-2492 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a5d0a16b-4633-5ec7-81c4-7e5c02ef1d2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
