// Dragnet [Ransomware]: dragnet-ransomware-2022-1205 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: cad66bb5-3800-5066-b752-72b469ac9999

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
