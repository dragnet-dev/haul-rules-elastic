// Dragnet [Ransomware]: dragnet-ransomware-2022-0688 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: f448c061-cc26-58dc-907f-f8104ffece17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
