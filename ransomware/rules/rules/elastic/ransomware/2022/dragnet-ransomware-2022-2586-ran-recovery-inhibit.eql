// Dragnet [Ransomware]: dragnet-ransomware-2022-2586 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: befcdcf6-cbac-57f0-ba22-5dea6dba4074

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
