// Dragnet [Ransomware]: dragnet-ransomware-2022-1897 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: fa0aadb8-f024-5cf3-9082-ac1b65b9bdec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
