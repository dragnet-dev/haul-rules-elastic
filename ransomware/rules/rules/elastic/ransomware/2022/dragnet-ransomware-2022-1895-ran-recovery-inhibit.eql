// Dragnet [Ransomware]: dragnet-ransomware-2022-1895 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: b3470827-21e7-5b49-8df7-ebb5ff423bb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
