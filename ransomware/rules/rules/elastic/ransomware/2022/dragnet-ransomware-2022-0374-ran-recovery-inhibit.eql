// Dragnet [Ransomware]: dragnet-ransomware-2022-0374 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5441259a-8554-53ff-8023-40026272ad53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
