// Dragnet [Ransomware]: dragnet-ransomware-2022-0635 — Recovery Inhibition (leaktheanalyst)
// Status: deprecated | Level: high | ID: 8facb10e-52d9-5683-ae58-1550d868866a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
