// Dragnet [Ransomware]: dragnet-ransomware-2022-2122 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 0408f8d8-ca3a-56d5-af5f-c25fc128adf7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
