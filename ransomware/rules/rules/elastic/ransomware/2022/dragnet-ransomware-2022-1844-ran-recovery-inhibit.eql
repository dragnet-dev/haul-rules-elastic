// Dragnet [Ransomware]: dragnet-ransomware-2022-1844 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: f70fc639-d914-5160-8758-b4d9ad5ec267

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
