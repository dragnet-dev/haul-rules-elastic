// Dragnet [Ransomware]: dragnet-ransomware-2022-2129 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: e8b64b32-33d2-5a07-ac57-495664157b12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
