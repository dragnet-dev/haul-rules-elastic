// Dragnet [Ransomware]: dragnet-ransomware-2022-1080 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 86cd540d-7a7d-5563-a154-e9d555fcdd3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
