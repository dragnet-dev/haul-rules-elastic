// Dragnet [Ransomware]: dragnet-ransomware-2022-1553 — Recovery Inhibition (medusalocker)
// Status: deprecated | Level: high | ID: fc9380e0-8c05-51aa-866b-a78b1ff34d43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
