// Dragnet [Ransomware]: dragnet-ransomware-2022-0337 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: b3602823-96d1-5144-864c-dee5c5620d78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
