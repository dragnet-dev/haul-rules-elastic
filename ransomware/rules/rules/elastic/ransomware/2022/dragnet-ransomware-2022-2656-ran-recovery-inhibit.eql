// Dragnet [Ransomware]: dragnet-ransomware-2022-2656 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 83cc41c0-53ec-5edb-8b64-067358ab95a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
