// Dragnet [Ransomware]: dragnet-ransomware-2022-3152 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 2ce29608-4011-568c-843e-97472b08bc9c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
