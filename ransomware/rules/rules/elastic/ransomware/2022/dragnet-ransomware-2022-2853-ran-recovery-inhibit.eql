// Dragnet [Ransomware]: dragnet-ransomware-2022-2853 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: a5267c0f-3d01-5a62-b29b-1650ea94c4ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
