// Dragnet [Ransomware]: dragnet-ransomware-2022-1359 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 764ed0e5-381f-591c-9835-7ffb780ade16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
