// Dragnet [Ransomware]: dragnet-ransomware-2022-2143 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 93dfba17-b8b7-5041-8671-d6e48a8899ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
