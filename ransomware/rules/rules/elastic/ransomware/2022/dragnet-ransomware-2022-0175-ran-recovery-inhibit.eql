// Dragnet [Ransomware]: dragnet-ransomware-2022-0175 — Recovery Inhibition (icefire)
// Status: deprecated | Level: high | ID: 31552991-b2bc-50ae-9745-7077fdb5d24f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
