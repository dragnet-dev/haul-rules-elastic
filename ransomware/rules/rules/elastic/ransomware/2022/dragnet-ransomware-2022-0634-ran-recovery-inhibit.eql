// Dragnet [Ransomware]: dragnet-ransomware-2022-0634 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: f1941d26-9aa0-5c26-aedb-565a3f334a81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
