// Dragnet [Ransomware]: dragnet-ransomware-2022-1479 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f8ecc3de-ce91-55f1-acd7-5fc0456cd12a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
