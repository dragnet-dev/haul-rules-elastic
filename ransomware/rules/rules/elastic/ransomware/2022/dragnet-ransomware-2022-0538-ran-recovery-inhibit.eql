// Dragnet [Ransomware]: dragnet-ransomware-2022-0538 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 992693bf-0512-51e5-9119-1e02115fd093

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
