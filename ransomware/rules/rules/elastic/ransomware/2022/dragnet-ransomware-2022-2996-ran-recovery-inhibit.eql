// Dragnet [Ransomware]: dragnet-ransomware-2022-2996 — Recovery Inhibition (cheers)
// Status: deprecated | Level: high | ID: f0ad8d68-c8e9-5970-b479-5223704c6509

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
