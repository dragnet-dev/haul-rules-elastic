// Dragnet [Ransomware]: dragnet-ransomware-2022-2961 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 079057f1-a076-5356-8b68-8c232bb5a19a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
