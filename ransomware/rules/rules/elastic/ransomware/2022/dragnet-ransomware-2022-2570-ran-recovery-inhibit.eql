// Dragnet [Ransomware]: dragnet-ransomware-2022-2570 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: cf13ce8a-26de-5548-8486-dd449c1a72c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
