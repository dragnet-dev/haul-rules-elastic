// Dragnet [Ransomware]: dragnet-ransomware-2022-2975 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: ab6a7f80-3464-5a97-96f9-2c15273c7669

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
