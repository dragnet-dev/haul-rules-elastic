// Dragnet [Ransomware]: dragnet-ransomware-2022-0382 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: bce38296-abaa-56f3-a61e-b6b80f12ef09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
