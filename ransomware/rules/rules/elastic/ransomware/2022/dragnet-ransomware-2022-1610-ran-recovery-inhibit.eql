// Dragnet [Ransomware]: dragnet-ransomware-2022-1610 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 1ed46e8c-19b1-59b0-8d08-476a9a004b57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
