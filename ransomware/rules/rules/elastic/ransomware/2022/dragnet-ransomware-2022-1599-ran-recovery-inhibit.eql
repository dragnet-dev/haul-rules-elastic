// Dragnet [Ransomware]: dragnet-ransomware-2022-1599 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: cd0268a8-2047-5be6-bab4-78cf6f4fc7ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
