// Dragnet [Ransomware]: dragnet-ransomware-2022-2489 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 201252b5-a05b-5c46-afec-445622aaea40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
