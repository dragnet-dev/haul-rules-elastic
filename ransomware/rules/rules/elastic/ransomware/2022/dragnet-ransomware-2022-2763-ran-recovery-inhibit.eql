// Dragnet [Ransomware]: dragnet-ransomware-2022-2763 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: e495d0ec-ada2-5ea2-b117-dad30031ded4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
