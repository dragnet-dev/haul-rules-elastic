// Dragnet [Ransomware]: dragnet-ransomware-2022-2184 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 470a6c34-facf-51e5-98d9-c1940fcba751

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
