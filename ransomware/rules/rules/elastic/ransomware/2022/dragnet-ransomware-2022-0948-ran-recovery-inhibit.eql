// Dragnet [Ransomware]: dragnet-ransomware-2022-0948 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 036ceae0-fb9f-534a-9724-653cc0a102ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
