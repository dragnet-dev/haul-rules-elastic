// Dragnet [Ransomware]: dragnet-ransomware-2022-1475 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 64435a68-7675-5df4-9064-e1ee7bd61d0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
