// Dragnet [Ransomware]: dragnet-ransomware-2022-3014 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 9a627d93-a5e0-51bf-810a-c21ffc6d3fc9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
