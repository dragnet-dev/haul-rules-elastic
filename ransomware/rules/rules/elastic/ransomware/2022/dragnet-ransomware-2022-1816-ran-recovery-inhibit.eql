// Dragnet [Ransomware]: dragnet-ransomware-2022-1816 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5d41e676-2c1b-550b-9a08-c3dde94e79b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
