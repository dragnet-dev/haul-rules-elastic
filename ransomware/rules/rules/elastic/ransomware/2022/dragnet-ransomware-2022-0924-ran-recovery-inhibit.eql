// Dragnet [Ransomware]: dragnet-ransomware-2022-0924 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 98860347-36f2-5ae8-94ff-bbcc6fc1ab45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
