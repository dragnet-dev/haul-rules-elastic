// Dragnet [Ransomware]: dragnet-ransomware-2022-2997 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 6072de96-2664-5d47-b9cc-cd5f13f95cb3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
