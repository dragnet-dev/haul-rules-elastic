// Dragnet [Ransomware]: dragnet-ransomware-2022-2386 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: efac1cbc-bb2f-5382-b555-6d300a3dac22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
