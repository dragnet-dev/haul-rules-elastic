// Dragnet [Ransomware]: dragnet-ransomware-2022-0661 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 9cadcdc6-c2b5-5b02-8099-43d1dbb01393

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
