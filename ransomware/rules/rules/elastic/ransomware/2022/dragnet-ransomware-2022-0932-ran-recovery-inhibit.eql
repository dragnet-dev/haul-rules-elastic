// Dragnet [Ransomware]: dragnet-ransomware-2022-0932 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 72d41098-89c5-582c-a1fd-4e6963a4776b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
