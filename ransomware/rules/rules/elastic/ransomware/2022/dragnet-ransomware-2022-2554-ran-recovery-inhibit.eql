// Dragnet [Ransomware]: dragnet-ransomware-2022-2554 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: c0bfaa71-e7d7-58c8-81cc-8b1891fb179b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
