// Dragnet [Ransomware]: dragnet-ransomware-2022-2078 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 10f47bc9-c4bd-58be-a257-36daf89e5b02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
