// Dragnet [Ransomware]: dragnet-ransomware-2022-1914 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 6c4cc04c-b903-5521-b291-d711f2b2992a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
