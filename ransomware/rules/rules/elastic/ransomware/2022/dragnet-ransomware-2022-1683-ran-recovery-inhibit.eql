// Dragnet [Ransomware]: dragnet-ransomware-2022-1683 — Recovery Inhibition (la_piovra)
// Status: experimental | Level: high | ID: 1e070186-088b-5532-9a49-507a97c39a95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
