// Dragnet [Ransomware]: dragnet-ransomware-2022-0313 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 84e5a3de-62ab-5283-b006-2b8e714d76bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
