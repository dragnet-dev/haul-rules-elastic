// Dragnet [Ransomware]: dragnet-ransomware-2022-2906 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: ff8ad5c1-a305-5d73-8664-8f6b36d88946

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
