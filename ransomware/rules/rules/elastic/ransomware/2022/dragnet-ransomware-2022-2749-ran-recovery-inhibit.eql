// Dragnet [Ransomware]: dragnet-ransomware-2022-2749 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: a0585e76-2df4-539c-86db-6b02f68711dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
