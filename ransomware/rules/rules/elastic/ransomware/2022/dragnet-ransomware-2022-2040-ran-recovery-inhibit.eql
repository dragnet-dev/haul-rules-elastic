// Dragnet [Ransomware]: dragnet-ransomware-2022-2040 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5b8e2df3-5cba-5d20-b1ca-43c7ee49891d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
