// Dragnet [Ransomware]: dragnet-ransomware-2022-1766 — Recovery Inhibition (freecivilian)
// Status: deprecated | Level: high | ID: 60991294-66e7-52d9-906e-fe0f1c5a8b78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
