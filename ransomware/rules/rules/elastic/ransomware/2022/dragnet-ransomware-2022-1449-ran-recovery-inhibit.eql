// Dragnet [Ransomware]: dragnet-ransomware-2022-1449 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 950b307b-1610-569d-aae7-f33a1acb2d04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
