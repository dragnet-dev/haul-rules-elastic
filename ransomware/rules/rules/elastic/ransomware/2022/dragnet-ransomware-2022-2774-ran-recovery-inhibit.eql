// Dragnet [Ransomware]: dragnet-ransomware-2022-2774 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: 705a59b0-7b58-5bfa-ab2c-6f6ddfc32a15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
