// Dragnet [Ransomware]: dragnet-ransomware-2022-0557 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: ca4bf524-20f5-52ac-9a34-026f56bfc442

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
