// Dragnet [Ransomware]: dragnet-ransomware-2022-3109 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: d0860326-419f-5dbc-9025-77bf95ebbd8f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
