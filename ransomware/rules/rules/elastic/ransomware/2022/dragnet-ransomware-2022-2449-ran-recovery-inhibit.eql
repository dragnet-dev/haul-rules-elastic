// Dragnet [Ransomware]: dragnet-ransomware-2022-2449 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: eebc8377-a3e6-5897-8b44-042d8f07fc7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
