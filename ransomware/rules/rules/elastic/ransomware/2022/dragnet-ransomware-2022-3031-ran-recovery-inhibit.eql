// Dragnet [Ransomware]: dragnet-ransomware-2022-3031 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5aa1edd6-bc6a-5064-a8af-108ce0bbc33e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
