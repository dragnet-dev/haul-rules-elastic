// Dragnet [Ransomware]: dragnet-ransomware-2022-1308 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 9a27d4bc-ac4f-53ff-ba10-83f7b5661620

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
