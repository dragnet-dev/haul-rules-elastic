// Dragnet [Ransomware]: dragnet-ransomware-2022-0729 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: e99d63ce-df04-5cc9-a982-071f9b26202a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
