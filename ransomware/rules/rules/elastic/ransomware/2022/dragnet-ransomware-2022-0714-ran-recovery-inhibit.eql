// Dragnet [Ransomware]: dragnet-ransomware-2022-0714 — Recovery Inhibition (redalert)
// Status: deprecated | Level: high | ID: 01239067-5f8c-5b53-b980-1e1ca2860eb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
