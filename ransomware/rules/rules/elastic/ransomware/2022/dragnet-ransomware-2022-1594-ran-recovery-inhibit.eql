// Dragnet [Ransomware]: dragnet-ransomware-2022-1594 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: eb06ffd2-b9b4-549f-8abc-f8c5cb93c624

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
