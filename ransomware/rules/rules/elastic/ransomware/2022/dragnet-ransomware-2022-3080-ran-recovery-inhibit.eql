// Dragnet [Ransomware]: dragnet-ransomware-2022-3080 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 891da3e2-f467-5d6f-a5d0-897024571e1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
