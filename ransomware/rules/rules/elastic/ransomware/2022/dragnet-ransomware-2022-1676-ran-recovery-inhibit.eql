// Dragnet [Ransomware]: dragnet-ransomware-2022-1676 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: baf3706b-74d3-5839-aeeb-64300b643c53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
