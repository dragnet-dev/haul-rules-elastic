// Dragnet [Ransomware]: dragnet-ransomware-2022-2930 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 583a159a-0dd9-52e2-b24c-d69ffd044bf3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
