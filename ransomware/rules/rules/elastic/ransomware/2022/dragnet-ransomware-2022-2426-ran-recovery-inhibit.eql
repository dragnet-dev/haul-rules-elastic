// Dragnet [Ransomware]: dragnet-ransomware-2022-2426 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 39d1b9e5-480e-5dd4-948f-bb5dabea6633

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
