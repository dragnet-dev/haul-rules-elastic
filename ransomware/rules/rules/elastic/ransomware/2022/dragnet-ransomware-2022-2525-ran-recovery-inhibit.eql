// Dragnet [Ransomware]: dragnet-ransomware-2022-2525 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: c45aab88-8086-5dfa-99cc-347a32f593f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
