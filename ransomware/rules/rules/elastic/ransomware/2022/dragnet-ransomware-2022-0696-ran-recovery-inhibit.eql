// Dragnet [Ransomware]: dragnet-ransomware-2022-0696 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a2447c39-9e5d-56ff-b64d-895234432c1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
