// Dragnet [Ransomware]: dragnet-ransomware-2022-2324 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: 4d4f9415-9b3b-5827-a5ea-bd0782947952

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
