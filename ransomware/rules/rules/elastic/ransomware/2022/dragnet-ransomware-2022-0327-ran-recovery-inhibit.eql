// Dragnet [Ransomware]: dragnet-ransomware-2022-0327 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: dbfb1d6d-ffb2-581a-b01d-4fefdb9bd156

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
