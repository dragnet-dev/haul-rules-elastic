// Dragnet [Ransomware]: dragnet-ransomware-2022-2856 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: deff8856-2c86-544d-bc74-8f1b2904f75c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
