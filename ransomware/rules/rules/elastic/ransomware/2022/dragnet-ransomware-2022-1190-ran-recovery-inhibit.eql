// Dragnet [Ransomware]: dragnet-ransomware-2022-1190 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: de2e10ce-38c4-57a9-a86c-92a11fe3d357

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
