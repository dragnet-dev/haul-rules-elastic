// Dragnet [Ransomware]: dragnet-ransomware-2022-2967 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 3a72d18f-64c1-5b64-b7c7-49806d1e032f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
