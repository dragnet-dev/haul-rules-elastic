// Dragnet [Ransomware]: dragnet-ransomware-2022-0979 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 40632363-7f1b-58a7-8887-18db38df926a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
