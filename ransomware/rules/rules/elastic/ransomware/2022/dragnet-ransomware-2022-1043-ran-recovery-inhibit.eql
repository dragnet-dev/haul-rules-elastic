// Dragnet [Ransomware]: dragnet-ransomware-2022-1043 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 528a305b-61f4-517b-8995-a26cb3ad3e00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
