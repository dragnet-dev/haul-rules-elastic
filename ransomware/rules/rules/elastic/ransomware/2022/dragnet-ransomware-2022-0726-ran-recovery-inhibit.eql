// Dragnet [Ransomware]: dragnet-ransomware-2022-0726 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: bc6f16d8-68fb-58d1-83bd-3351b3c605b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
