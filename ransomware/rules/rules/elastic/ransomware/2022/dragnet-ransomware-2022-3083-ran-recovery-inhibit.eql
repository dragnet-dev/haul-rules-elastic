// Dragnet [Ransomware]: dragnet-ransomware-2022-3083 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 45724afa-b3ce-5531-aa6c-bf4309c71323

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
