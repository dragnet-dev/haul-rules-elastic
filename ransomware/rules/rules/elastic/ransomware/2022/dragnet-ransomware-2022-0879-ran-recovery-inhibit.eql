// Dragnet [Ransomware]: dragnet-ransomware-2022-0879 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 020667d7-a6cc-53d0-b910-5aef707e40ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
