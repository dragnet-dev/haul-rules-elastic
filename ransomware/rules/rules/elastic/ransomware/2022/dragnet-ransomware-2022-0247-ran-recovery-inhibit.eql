// Dragnet [Ransomware]: dragnet-ransomware-2022-0247 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: b9d62f19-a816-59c4-901e-900f6e9c05d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
