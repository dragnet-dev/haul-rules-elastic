// Dragnet [Ransomware]: dragnet-ransomware-2022-0791 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: daec3c1d-62db-5549-b948-4d31aa1ed346

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
