// Dragnet [Ransomware]: dragnet-ransomware-2022-2498 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 893abaad-b4bf-5d89-8390-7bd6b2c7e09c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
