// Dragnet [Ransomware]: dragnet-ransomware-2022-1025 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 8cb1493e-51d6-5460-97d0-8e51148b6ace

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
