// Dragnet [Ransomware]: dragnet-ransomware-2022-2004 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: da4690e9-2d16-5dc9-b823-765424f92ec7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
