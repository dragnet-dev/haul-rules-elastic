// Dragnet [Ransomware]: dragnet-ransomware-2022-1698 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 32826a61-9419-554e-b20d-707cd3411f26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
