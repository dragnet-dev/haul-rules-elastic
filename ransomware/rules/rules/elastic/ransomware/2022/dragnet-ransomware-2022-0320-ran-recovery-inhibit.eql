// Dragnet [Ransomware]: dragnet-ransomware-2022-0320 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: cf274b8b-edce-5a15-b623-9fec7db06a84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
