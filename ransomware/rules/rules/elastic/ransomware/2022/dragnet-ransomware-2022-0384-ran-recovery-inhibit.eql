// Dragnet [Ransomware]: dragnet-ransomware-2022-0384 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: 95a15b34-5686-5c17-afa2-59ce2d577341

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
