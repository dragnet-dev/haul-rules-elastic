// Dragnet [Ransomware]: dragnet-ransomware-2022-1865 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 0e373eb0-c736-5f7f-97d9-b5a8323b6ba3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
