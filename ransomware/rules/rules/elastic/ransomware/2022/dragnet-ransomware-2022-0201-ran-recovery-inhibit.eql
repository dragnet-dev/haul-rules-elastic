// Dragnet [Ransomware]: dragnet-ransomware-2022-0201 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 08077b7f-2db3-5084-8fa0-818cda169586

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
