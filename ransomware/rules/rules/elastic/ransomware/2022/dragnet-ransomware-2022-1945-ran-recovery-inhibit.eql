// Dragnet [Ransomware]: dragnet-ransomware-2022-1945 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5956f6f9-1d4e-5327-af70-c56af8e17b6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
