// Dragnet [Ransomware]: dragnet-ransomware-2022-0719 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 6c97bbfe-2c5d-5de8-90b5-f3411c70d30f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
