// Dragnet [Ransomware]: dragnet-ransomware-2022-1689 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: acda3ec8-4073-5c7c-bf50-115b6d73264f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
