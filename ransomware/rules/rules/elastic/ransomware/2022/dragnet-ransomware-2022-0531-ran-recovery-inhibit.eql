// Dragnet [Ransomware]: dragnet-ransomware-2022-0531 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2626964b-812d-53c8-8608-040542468ae2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
