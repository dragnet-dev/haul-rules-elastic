// Dragnet [Ransomware]: dragnet-ransomware-2022-1109 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 818b85a0-b6a6-5a18-bc70-ddcfd352b432

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
