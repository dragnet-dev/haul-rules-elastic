// Dragnet [Ransomware]: dragnet-ransomware-2022-1283 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6ea42521-8001-5e04-9a4b-7b4a67088866

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
