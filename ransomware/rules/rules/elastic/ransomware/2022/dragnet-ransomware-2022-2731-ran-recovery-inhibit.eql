// Dragnet [Ransomware]: dragnet-ransomware-2022-2731 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: 716d92bc-02fd-5ad8-ae5d-71e0c34238c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
