// Dragnet [Ransomware]: dragnet-ransomware-2022-0398 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 14b9df5c-e5c6-568e-9216-65db05c5a4bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
