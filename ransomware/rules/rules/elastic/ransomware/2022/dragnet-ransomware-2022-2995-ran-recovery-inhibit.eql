// Dragnet [Ransomware]: dragnet-ransomware-2022-2995 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c799c22f-b500-586c-b8c3-3651a447b5c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
