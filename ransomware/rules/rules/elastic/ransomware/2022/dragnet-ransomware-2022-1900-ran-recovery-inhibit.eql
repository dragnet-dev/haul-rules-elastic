// Dragnet [Ransomware]: dragnet-ransomware-2022-1900 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 7aefd285-7df1-5de4-87ad-0a5e6b59a403

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
