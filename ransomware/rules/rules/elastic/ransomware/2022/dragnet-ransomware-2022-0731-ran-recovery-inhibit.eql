// Dragnet [Ransomware]: dragnet-ransomware-2022-0731 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 0fc3c104-885f-5560-a456-b1a398d27c8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
