// Dragnet [Ransomware]: dragnet-ransomware-2022-2677 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6505ac76-953b-59f0-bbb5-cb6ba6a47194

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
