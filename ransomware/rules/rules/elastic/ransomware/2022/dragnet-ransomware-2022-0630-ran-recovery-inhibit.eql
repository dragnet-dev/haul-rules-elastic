// Dragnet [Ransomware]: dragnet-ransomware-2022-0630 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 20f8e8e6-42a3-5848-9673-7827426664fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
