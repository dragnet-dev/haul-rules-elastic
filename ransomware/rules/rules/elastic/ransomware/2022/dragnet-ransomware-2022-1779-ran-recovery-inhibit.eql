// Dragnet [Ransomware]: dragnet-ransomware-2022-1779 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: 2219826f-9985-5e7d-aa7f-808f123c5ed4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
