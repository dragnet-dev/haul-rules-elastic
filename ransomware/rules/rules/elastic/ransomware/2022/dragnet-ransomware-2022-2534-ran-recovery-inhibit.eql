// Dragnet [Ransomware]: dragnet-ransomware-2022-2534 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 85a005e3-7c42-5cc3-8e06-94c1ca81d960

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
