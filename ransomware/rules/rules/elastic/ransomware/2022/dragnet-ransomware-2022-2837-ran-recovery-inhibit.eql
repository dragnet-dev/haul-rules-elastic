// Dragnet [Ransomware]: dragnet-ransomware-2022-2837 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 3ae285f5-f669-55a3-986b-67f4fc35d2e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
