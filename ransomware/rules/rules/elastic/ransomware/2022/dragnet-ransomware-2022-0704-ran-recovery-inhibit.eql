// Dragnet [Ransomware]: dragnet-ransomware-2022-0704 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8bf6e09c-7101-5003-a460-dee1b22902b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
