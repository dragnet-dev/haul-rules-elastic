// Dragnet [Ransomware]: dragnet-ransomware-2022-0228 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 62de74b5-d3fd-5641-a6da-c6b6ed36efd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
