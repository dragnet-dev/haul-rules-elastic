// Dragnet [Ransomware]: dragnet-ransomware-2022-1984 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: c9841540-636f-54b1-bfcb-86dc89b84095

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
