// Dragnet [Ransomware]: dragnet-ransomware-2022-3086 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: f6b25fb7-d4d7-5ba1-a7a6-deec7697067d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
