// Dragnet [Ransomware]: dragnet-ransomware-2022-0378 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 28e7a540-0d6a-5d1e-beae-e3f783ddb235

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
