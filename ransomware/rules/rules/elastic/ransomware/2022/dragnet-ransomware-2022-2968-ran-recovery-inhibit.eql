// Dragnet [Ransomware]: dragnet-ransomware-2022-2968 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 800e9b38-7c82-5a4b-a29c-9c72c2b3df8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
