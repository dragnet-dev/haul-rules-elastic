// Dragnet [Ransomware]: dragnet-ransomware-2022-1035 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 6324a293-ec9b-59fc-ab97-4259c4f25367

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
