// Dragnet [Ransomware]: dragnet-ransomware-2022-0318 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: f5ab7cbb-1201-57e4-908c-81788b9ad99f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
