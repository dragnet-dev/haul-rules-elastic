// Dragnet [Ransomware]: dragnet-ransomware-2022-1011 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 73c048a6-9257-5b6b-8074-4e0fbc1de539

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
