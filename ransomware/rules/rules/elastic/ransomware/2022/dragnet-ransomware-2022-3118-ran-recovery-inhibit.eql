// Dragnet [Ransomware]: dragnet-ransomware-2022-3118 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: b58797a9-9bba-5f76-b1e0-afd9190393d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
