// Dragnet [Ransomware]: dragnet-ransomware-2022-1351 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 3018f1e3-1d3f-5d45-87c6-4aa6a58faccc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
