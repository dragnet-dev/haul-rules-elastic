// Dragnet [Ransomware]: dragnet-ransomware-2022-0542 — Recovery Inhibition (monti)
// Status: deprecated | Level: high | ID: b60821e6-3183-5d39-847c-995e719b6971

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
