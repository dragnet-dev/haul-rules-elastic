// Dragnet [Ransomware]: dragnet-ransomware-2022-1111 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 0701dee8-7963-5535-90b2-724d147046e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
