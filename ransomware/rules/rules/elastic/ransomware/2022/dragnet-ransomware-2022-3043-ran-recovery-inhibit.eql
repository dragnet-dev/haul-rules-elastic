// Dragnet [Ransomware]: dragnet-ransomware-2022-3043 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: f846b715-f514-5ab2-a03d-b186bcfc8d2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
