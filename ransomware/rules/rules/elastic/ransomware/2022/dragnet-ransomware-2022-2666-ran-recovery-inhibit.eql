// Dragnet [Ransomware]: dragnet-ransomware-2022-2666 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: a524365f-0c64-5ff0-9ad2-1e056441022f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
