// Dragnet [Ransomware]: dragnet-ransomware-2022-1952 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 2d4fda43-4984-55cc-a3a4-ed96119e3c3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
