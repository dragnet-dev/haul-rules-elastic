// Dragnet [Ransomware]: dragnet-ransomware-2022-2848 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 37fe9568-e6e4-5841-b454-5d43d85fcdf8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
