// Dragnet [Ransomware]: dragnet-ransomware-2022-3002 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 0a723b66-cec3-526f-ae19-b238efa268ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
