// Dragnet [Ransomware]: dragnet-ransomware-2022-0546 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 298b4ecf-284d-5113-9477-ce93f4cba7f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
