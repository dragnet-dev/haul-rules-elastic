// Dragnet [Ransomware]: dragnet-ransomware-2022-2488 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 36290df4-fcfc-5c67-9aeb-00a11ca6f09f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
