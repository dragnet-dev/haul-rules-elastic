// Dragnet [Ransomware]: dragnet-ransomware-2022-1987 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: bbcf3c46-10d9-576d-b816-d2538e537525

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
