// Dragnet [Ransomware]: dragnet-ransomware-2022-1295 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: bca7faef-13cc-5933-a21a-8d8632864b2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
