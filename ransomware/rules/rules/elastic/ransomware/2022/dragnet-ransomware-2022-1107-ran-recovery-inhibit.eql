// Dragnet [Ransomware]: dragnet-ransomware-2022-1107 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: abfa2c8a-1be0-53f8-a705-d172ef5e14e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
