// Dragnet [Ransomware]: dragnet-ransomware-2022-2303 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a7623933-9407-5bf9-accb-bed25a912375

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
