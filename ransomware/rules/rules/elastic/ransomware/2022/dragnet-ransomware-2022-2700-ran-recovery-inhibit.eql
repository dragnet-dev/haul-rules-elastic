// Dragnet [Ransomware]: dragnet-ransomware-2022-2700 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: e97d4f8d-0b0e-501e-8ddc-6ade6c1e5b07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
