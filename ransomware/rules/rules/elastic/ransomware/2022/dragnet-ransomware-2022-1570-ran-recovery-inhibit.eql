// Dragnet [Ransomware]: dragnet-ransomware-2022-1570 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: bc6f692f-181f-547b-8704-1eedd292f730

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
