// Dragnet [Ransomware]: dragnet-ransomware-2022-1800 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 76cc40b1-b367-5aba-9117-ef6b99bfae5e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
