// Dragnet [Ransomware]: dragnet-ransomware-2022-0990 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 47be16ac-70c1-5c7f-9c67-4dbb591d53e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
