// Dragnet [Ransomware]: dragnet-ransomware-2022-1581 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 8d58517f-33bb-5610-8923-50f9611776d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
