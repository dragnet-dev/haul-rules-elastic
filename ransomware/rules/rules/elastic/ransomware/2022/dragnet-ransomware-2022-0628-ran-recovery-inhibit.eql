// Dragnet [Ransomware]: dragnet-ransomware-2022-0628 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 675cb5ee-e2e0-5275-866e-4094972be8e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
