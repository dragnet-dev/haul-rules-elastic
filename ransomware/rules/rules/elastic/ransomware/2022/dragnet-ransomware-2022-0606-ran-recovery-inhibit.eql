// Dragnet [Ransomware]: dragnet-ransomware-2022-0606 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 65cb805a-6144-58e4-99d5-65f512156b21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
