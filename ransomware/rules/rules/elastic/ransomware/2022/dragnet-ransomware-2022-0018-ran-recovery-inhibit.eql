// Dragnet [Ransomware]: dragnet-ransomware-2022-0018 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 1a54b63e-eb31-53e7-8581-026d4de572e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
