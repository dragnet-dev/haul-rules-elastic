// Dragnet [Ransomware]: dragnet-ransomware-2022-1555 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 8e7cccd9-e191-559c-9a23-73b5c85ead0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
