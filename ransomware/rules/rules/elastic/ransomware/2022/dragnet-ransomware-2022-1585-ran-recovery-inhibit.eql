// Dragnet [Ransomware]: dragnet-ransomware-2022-1585 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 2d4d0f12-85fe-514d-9d8c-313e9cae5f08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
