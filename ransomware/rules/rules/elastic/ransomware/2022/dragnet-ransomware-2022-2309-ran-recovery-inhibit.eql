// Dragnet [Ransomware]: dragnet-ransomware-2022-2309 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 0d21090f-1051-58e6-9424-60499d615794

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
