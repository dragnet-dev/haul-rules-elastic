// Dragnet [Ransomware]: dragnet-ransomware-2022-2901 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 9d983d91-d05d-5899-9623-88cfebb440ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
