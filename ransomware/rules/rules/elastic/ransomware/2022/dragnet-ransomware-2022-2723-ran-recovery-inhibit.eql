// Dragnet [Ransomware]: dragnet-ransomware-2022-2723 — Recovery Inhibition (unsafe)
// Status: deprecated | Level: high | ID: c52ebb0c-3294-5c41-ba91-d880b1bc318a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
