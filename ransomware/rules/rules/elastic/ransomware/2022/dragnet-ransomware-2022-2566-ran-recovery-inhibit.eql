// Dragnet [Ransomware]: dragnet-ransomware-2022-2566 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 62e44d52-ab9c-5e7c-9e3a-9cff9d9fdc56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
