// Dragnet [Ransomware]: dragnet-ransomware-2022-0613 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 631cd3cc-708d-5524-a925-12e861ddbfb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
