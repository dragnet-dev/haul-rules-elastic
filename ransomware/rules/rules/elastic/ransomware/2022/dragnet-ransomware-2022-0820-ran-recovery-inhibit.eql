// Dragnet [Ransomware]: dragnet-ransomware-2022-0820 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2d32312f-8fe7-50a9-a7e5-88a51f496cd0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
