// Dragnet [Ransomware]: dragnet-ransomware-2022-3154 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: cc9b3843-4d4c-5761-bc69-3547db37b8bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
