// Dragnet [Ransomware]: dragnet-ransomware-2022-0605 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: f1925f84-0f05-5e02-8a65-2157128563a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
