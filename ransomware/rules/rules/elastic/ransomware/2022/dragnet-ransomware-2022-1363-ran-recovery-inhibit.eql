// Dragnet [Ransomware]: dragnet-ransomware-2022-1363 — Recovery Inhibition (icefire)
// Status: deprecated | Level: high | ID: 99cf8802-750b-5c5b-9718-1407d520ced1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
