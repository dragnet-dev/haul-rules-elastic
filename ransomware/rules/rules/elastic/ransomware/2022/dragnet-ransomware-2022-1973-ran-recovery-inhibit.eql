// Dragnet [Ransomware]: dragnet-ransomware-2022-1973 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a3e77bb1-b400-5192-9092-5ea8056b1b19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
