// Dragnet [Ransomware]: dragnet-ransomware-2022-2285 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 0a2f89dc-36fa-5aed-92d6-939a57c8a23b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
