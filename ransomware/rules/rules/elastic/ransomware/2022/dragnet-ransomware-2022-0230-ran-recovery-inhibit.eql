// Dragnet [Ransomware]: dragnet-ransomware-2022-0230 — Recovery Inhibition (leaktheanalyst)
// Status: deprecated | Level: high | ID: 4dfb3531-cdc7-5d8e-b8a4-87aa1c299cb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
