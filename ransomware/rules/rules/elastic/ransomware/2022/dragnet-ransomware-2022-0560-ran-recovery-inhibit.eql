// Dragnet [Ransomware]: dragnet-ransomware-2022-0560 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 9a8279cd-a050-5c03-8d67-5913832ed950

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
