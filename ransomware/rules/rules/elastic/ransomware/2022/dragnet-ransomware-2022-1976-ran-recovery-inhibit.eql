// Dragnet [Ransomware]: dragnet-ransomware-2022-1976 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 49bc3240-0b38-59c5-9d18-c47a0a471e7c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
