// Dragnet [Ransomware]: dragnet-ransomware-2022-2573 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 510842d1-0e6c-5d0c-ae78-8f9042e5d4b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
