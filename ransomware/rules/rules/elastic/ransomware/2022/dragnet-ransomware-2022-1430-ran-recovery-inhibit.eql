// Dragnet [Ransomware]: dragnet-ransomware-2022-1430 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8e588f6a-ed79-540a-adc6-9f3ecf56ef30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
