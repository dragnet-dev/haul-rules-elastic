// Dragnet [Ransomware]: dragnet-ransomware-2022-2051 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: b788ae15-a5c3-537e-becd-fe0d359c6bde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
