// Dragnet [Ransomware]: dragnet-ransomware-2022-2042 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 7921c9d0-11fa-597a-9dd4-252d99a6196b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
