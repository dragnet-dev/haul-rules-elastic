// Dragnet [Ransomware]: dragnet-ransomware-2022-1239 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: e7b2b290-2382-565a-b7f2-a58bb7079713

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
