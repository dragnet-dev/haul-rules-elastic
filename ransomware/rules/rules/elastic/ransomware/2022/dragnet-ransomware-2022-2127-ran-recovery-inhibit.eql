// Dragnet [Ransomware]: dragnet-ransomware-2022-2127 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 4f0b86b9-eb80-5b7f-a0f6-86d6ddadd9b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
