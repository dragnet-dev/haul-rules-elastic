// Dragnet [Ransomware]: dragnet-ransomware-2022-1817 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 68db0096-bf76-565b-8052-35aa4df15f3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
