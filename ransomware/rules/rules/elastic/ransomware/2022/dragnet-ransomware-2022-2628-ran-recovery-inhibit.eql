// Dragnet [Ransomware]: dragnet-ransomware-2022-2628 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: acc73a22-345b-5cd5-b6fa-0d8ba1aa5abe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
