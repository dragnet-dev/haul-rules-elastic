// Dragnet [Ransomware]: dragnet-ransomware-2022-1530 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: cc0d4a1a-df6a-5580-b744-d61de80e40cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
