// Dragnet [Ransomware]: dragnet-ransomware-2022-1304 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 18afa5c8-b6a6-5b2a-a334-8fc2edaf3417

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
