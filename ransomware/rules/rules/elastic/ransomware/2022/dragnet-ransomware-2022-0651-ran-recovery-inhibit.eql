// Dragnet [Ransomware]: dragnet-ransomware-2022-0651 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: 619d2307-9328-5e25-acd0-0ccb35416c41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
