// Dragnet [Ransomware]: dragnet-ransomware-2022-1988 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 4c74e933-fd01-52fb-a2d4-0f6d1c7a2f06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
