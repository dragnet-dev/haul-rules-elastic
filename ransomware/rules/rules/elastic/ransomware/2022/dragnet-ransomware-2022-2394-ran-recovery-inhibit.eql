// Dragnet [Ransomware]: dragnet-ransomware-2022-2394 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: f5edef1d-c20b-522a-bdc4-fbc5b8638aec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
