// Dragnet [Ransomware]: dragnet-ransomware-2022-0055 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b11e9356-d1d9-5220-b4fc-2b2639fc2ffc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
