// Dragnet [Ransomware]: dragnet-ransomware-2022-2893 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 00c92eca-6c08-5720-b100-bb1d74deedd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
