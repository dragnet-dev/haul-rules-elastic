// Dragnet [Ransomware]: dragnet-ransomware-2022-1389 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 3afc5d68-5753-5b78-913c-5800b3c89abf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
