// Dragnet [Ransomware]: dragnet-ransomware-2022-2146 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: fc828c70-3538-5864-a20b-8aad6044daab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
