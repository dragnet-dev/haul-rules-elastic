// Dragnet [Ransomware]: dragnet-ransomware-2022-3146 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: a4be142e-c31e-550e-b37f-f670779a3005

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
