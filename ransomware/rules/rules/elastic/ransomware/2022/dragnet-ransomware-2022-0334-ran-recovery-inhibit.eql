// Dragnet [Ransomware]: dragnet-ransomware-2022-0334 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: fc68157e-bab5-5d56-a54e-0fa297fc6a17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
