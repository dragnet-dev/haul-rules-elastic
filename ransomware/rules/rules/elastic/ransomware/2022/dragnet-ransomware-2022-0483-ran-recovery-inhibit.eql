// Dragnet [Ransomware]: dragnet-ransomware-2022-0483 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 33619f0e-8c05-564b-9741-915e8d903284

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
