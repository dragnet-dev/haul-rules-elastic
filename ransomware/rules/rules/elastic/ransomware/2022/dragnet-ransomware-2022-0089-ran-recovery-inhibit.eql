// Dragnet [Ransomware]: dragnet-ransomware-2022-0089 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 0d821242-d656-5888-bc2a-5e7aaec4b8e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
