// Dragnet [Ransomware]: dragnet-ransomware-2022-1465 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4494e181-87f8-525b-b5c5-d1945b3c9f56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
