// Dragnet [Ransomware]: dragnet-ransomware-2022-0189 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: b6c60839-f78d-55e6-9cfe-c0abb0240a0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
