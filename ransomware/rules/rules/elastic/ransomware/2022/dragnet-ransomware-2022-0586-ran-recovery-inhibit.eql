// Dragnet [Ransomware]: dragnet-ransomware-2022-0586 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 806e7d41-a7c0-5296-8eff-fe0348f98482

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
