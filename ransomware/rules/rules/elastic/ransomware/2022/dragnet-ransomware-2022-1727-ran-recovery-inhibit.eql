// Dragnet [Ransomware]: dragnet-ransomware-2022-1727 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: eadf9b04-9bbb-5254-a984-47f653e82d3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
