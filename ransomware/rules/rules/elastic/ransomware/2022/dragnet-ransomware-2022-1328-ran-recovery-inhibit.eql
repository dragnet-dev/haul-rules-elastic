// Dragnet [Ransomware]: dragnet-ransomware-2022-1328 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 1d30e3f3-a553-5074-936d-d8c40960e15d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
