// Dragnet [Ransomware]: dragnet-ransomware-2022-0494 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: b84778d6-351d-508e-93c7-b22cf13f20e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
