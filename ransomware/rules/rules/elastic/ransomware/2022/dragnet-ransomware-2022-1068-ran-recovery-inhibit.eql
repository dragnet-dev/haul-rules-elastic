// Dragnet [Ransomware]: dragnet-ransomware-2022-1068 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 0699770d-77d6-55e8-9039-291469c3f85b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
