// Dragnet [Ransomware]: dragnet-ransomware-2022-0426 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 64bfd9d4-7a4c-5920-baa0-8d17a98f2d8f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
