// Dragnet [Ransomware]: dragnet-ransomware-2022-3033 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 4c410be5-1708-5c31-8e8b-38cfbed945e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
