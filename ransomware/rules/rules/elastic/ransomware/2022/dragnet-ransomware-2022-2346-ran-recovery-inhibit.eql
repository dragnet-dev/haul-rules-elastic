// Dragnet [Ransomware]: dragnet-ransomware-2022-2346 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: bd47cb17-60cb-559a-9720-96ea079830c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
