// Dragnet [Ransomware]: dragnet-ransomware-2022-0150 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 14ddcf62-ee0f-5760-aff8-2fbe01683651

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
