// Dragnet [Ransomware]: dragnet-ransomware-2022-2341 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 3bf72195-d114-55da-af97-e012f8fd12c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
