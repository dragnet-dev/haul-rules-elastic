// Dragnet [Ransomware]: dragnet-ransomware-2022-1860 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: cf6acbc7-fb6b-5495-b3d9-e8aecff6ab5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
