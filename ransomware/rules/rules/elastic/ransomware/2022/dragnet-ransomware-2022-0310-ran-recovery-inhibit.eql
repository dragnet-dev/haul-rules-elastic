// Dragnet [Ransomware]: dragnet-ransomware-2022-0310 — Recovery Inhibition (cheers)
// Status: deprecated | Level: high | ID: f2fbf078-0b49-5167-97b2-e7aec026e1dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
