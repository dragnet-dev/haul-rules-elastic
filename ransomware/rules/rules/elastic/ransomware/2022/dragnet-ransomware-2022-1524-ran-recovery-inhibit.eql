// Dragnet [Ransomware]: dragnet-ransomware-2022-1524 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 6bf2a5e6-a259-5456-8125-a2a828f974da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
