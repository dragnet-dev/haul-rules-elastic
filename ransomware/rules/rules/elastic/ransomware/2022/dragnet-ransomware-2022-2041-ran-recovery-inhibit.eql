// Dragnet [Ransomware]: dragnet-ransomware-2022-2041 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 6c5192b3-7fc1-5b35-9d5d-6ed59d209758

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
