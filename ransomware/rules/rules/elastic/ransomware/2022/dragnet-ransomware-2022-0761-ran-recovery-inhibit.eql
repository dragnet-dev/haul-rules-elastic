// Dragnet [Ransomware]: dragnet-ransomware-2022-0761 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 9dcdf25e-d6dc-5af6-89c8-96afc127c0bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
