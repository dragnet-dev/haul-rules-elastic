// Dragnet [Ransomware]: dragnet-ransomware-2022-0052 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: eacb4b52-a26e-532e-bbb9-3cd2d26b7eec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
