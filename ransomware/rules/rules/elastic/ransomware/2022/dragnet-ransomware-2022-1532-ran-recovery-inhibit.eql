// Dragnet [Ransomware]: dragnet-ransomware-2022-1532 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: fa428c1f-03a1-5d87-bfa1-e0093f2f74de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
