// Dragnet [Ransomware]: dragnet-ransomware-2022-2787 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: ddfebcb3-46ce-5957-9d7f-57b6fbf6463d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
