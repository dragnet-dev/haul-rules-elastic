// Dragnet [Ransomware]: dragnet-ransomware-2022-0581 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: de3d7c4d-48de-5488-9da7-f49fa158b5f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
