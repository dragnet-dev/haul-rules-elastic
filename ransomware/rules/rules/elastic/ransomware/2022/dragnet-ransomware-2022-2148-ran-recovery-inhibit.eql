// Dragnet [Ransomware]: dragnet-ransomware-2022-2148 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: e3c8d8d8-cdc3-5fdc-874c-660ad4e0c52e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
