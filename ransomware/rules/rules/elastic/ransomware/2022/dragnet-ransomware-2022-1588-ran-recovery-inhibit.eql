// Dragnet [Ransomware]: dragnet-ransomware-2022-1588 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: c14d7cfc-3152-59cf-896a-032b52feeebf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
