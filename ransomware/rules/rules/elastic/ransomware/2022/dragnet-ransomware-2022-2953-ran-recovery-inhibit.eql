// Dragnet [Ransomware]: dragnet-ransomware-2022-2953 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: 32739412-544d-5970-ae89-3a9e1424e1fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
