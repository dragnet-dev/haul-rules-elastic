// Dragnet [Ransomware]: dragnet-ransomware-2022-1194 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 7a344a7d-8801-58b2-8d06-0b49dce7e54e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
