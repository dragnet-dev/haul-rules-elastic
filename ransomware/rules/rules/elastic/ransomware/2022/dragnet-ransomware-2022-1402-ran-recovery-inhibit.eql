// Dragnet [Ransomware]: dragnet-ransomware-2022-1402 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 49b7eb8c-323e-5bb9-82ec-0557355ea7b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
