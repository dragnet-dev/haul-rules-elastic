// Dragnet [Ransomware]: dragnet-ransomware-2022-0699 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 47c2c4f5-f961-5c06-942a-ac72b9adbd21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
