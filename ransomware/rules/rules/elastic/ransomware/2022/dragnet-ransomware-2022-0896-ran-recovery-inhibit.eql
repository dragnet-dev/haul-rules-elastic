// Dragnet [Ransomware]: dragnet-ransomware-2022-0896 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 11e360db-1d81-534c-8fca-dbfd8987a2a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
