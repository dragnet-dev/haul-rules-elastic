// Dragnet [Ransomware]: dragnet-ransomware-2022-2673 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d68c890e-ce41-5ec5-a50a-1b257147124a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
