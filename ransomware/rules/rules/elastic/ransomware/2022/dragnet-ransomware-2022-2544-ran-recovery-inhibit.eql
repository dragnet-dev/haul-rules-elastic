// Dragnet [Ransomware]: dragnet-ransomware-2022-2544 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 6a4aeafe-52ac-5cbd-b512-ce4804d0fcdc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
