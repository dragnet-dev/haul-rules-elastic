// Dragnet [Ransomware]: dragnet-ransomware-2022-0419 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 56f29e19-5234-58b0-a990-a91cfafd4ffa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
