// Dragnet [Ransomware]: dragnet-ransomware-2022-1200 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 1bb24e43-69c8-503c-bc9a-74619de2f5ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
