// Dragnet [Ransomware]: dragnet-ransomware-2022-3073 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f695c61f-a72e-5249-a506-633e23396a08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
