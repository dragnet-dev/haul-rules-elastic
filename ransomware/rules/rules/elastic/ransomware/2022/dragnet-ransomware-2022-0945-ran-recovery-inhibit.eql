// Dragnet [Ransomware]: dragnet-ransomware-2022-0945 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c7279e73-52a7-53cc-9f1c-0b603da52ec2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
