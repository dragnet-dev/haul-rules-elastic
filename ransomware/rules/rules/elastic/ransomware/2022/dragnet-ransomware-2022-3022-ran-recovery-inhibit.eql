// Dragnet [Ransomware]: dragnet-ransomware-2022-3022 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: a2fedb00-cd6a-51a9-acf3-d23dcb9eb328

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
