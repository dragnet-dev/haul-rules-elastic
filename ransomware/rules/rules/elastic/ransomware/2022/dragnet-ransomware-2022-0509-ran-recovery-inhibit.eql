// Dragnet [Ransomware]: dragnet-ransomware-2022-0509 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 00e294d4-772c-55d8-8de5-c9cf540fa12a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
