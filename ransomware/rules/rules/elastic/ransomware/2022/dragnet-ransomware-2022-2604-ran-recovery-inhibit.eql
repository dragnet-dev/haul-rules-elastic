// Dragnet [Ransomware]: dragnet-ransomware-2022-2604 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: d054450d-d181-592a-810f-035e0c5c4dcc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
