// Dragnet [Ransomware]: dragnet-ransomware-2022-2834 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 0336bd99-412b-5734-9b16-ecdc2a2e0232

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
