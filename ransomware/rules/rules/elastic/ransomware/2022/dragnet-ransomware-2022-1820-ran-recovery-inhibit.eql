// Dragnet [Ransomware]: dragnet-ransomware-2022-1820 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 7aefbd51-e898-535e-ba5b-1eecdd3ce6f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
