// Dragnet [Ransomware]: dragnet-ransomware-2022-0808 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: fb3fb690-70b4-5b42-8122-f70e009f13f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
