// Dragnet [Ransomware]: dragnet-ransomware-2022-2316 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: d0a1123a-f552-57a1-a6d9-56a1a3e81622

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
