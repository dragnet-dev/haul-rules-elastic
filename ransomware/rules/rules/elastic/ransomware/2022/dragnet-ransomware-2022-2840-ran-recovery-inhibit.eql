// Dragnet [Ransomware]: dragnet-ransomware-2022-2840 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 449b1955-382c-5c95-9b91-5db14556d65c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
