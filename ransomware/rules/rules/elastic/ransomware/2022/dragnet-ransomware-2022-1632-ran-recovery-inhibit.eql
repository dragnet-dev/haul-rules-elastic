// Dragnet [Ransomware]: dragnet-ransomware-2022-1632 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: b405afd1-5abf-52e9-85df-3f1ce4d64a25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
