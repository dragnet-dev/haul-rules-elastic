// Dragnet [Ransomware]: dragnet-ransomware-2022-2479 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: f84921fd-314e-599f-836b-a41ed0ed0c34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
