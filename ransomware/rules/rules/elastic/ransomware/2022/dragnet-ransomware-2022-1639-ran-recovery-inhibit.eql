// Dragnet [Ransomware]: dragnet-ransomware-2022-1639 — Recovery Inhibition (icefire)
// Status: deprecated | Level: high | ID: 6c1915f1-428a-5b86-af2c-0ba2af8c0754

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
