// Dragnet [Ransomware]: dragnet-ransomware-2022-3095 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: cabfeba3-cf54-538a-9981-bda1cc299e77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
