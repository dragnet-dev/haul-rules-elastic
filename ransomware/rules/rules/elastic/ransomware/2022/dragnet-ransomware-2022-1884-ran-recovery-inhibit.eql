// Dragnet [Ransomware]: dragnet-ransomware-2022-1884 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 66fac4f9-e143-51af-9e7a-b2cc14693c77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
