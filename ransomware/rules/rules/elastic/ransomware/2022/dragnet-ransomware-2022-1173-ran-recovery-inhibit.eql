// Dragnet [Ransomware]: dragnet-ransomware-2022-1173 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 26e125af-b021-556d-b56a-8fc959405cc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
