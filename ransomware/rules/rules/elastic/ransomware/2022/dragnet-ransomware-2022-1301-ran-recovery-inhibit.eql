// Dragnet [Ransomware]: dragnet-ransomware-2022-1301 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: cce50711-6eee-5e7a-85f7-083f105b2df2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
