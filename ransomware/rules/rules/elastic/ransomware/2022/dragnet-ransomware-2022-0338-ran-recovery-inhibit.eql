// Dragnet [Ransomware]: dragnet-ransomware-2022-0338 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: f6cee74a-e736-5f30-992a-e0f4f9a683db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
