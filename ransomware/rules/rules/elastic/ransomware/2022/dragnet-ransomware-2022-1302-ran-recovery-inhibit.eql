// Dragnet [Ransomware]: dragnet-ransomware-2022-1302 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 59722c99-873b-5fe1-96c2-f981b618487e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
