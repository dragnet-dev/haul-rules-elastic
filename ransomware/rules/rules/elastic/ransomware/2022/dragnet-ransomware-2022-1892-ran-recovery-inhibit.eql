// Dragnet [Ransomware]: dragnet-ransomware-2022-1892 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: afd4d5c9-076a-5726-9189-97fb8c22e3f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
