// Dragnet [Ransomware]: dragnet-ransomware-2022-1096 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 135748fb-2393-55e0-9a6c-92442a805290

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
