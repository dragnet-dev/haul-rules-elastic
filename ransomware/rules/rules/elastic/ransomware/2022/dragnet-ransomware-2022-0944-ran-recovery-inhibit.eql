// Dragnet [Ransomware]: dragnet-ransomware-2022-0944 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: ee9a3210-1c02-5331-a7f8-8f63b496e72c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
