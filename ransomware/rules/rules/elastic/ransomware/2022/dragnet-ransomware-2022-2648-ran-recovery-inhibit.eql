// Dragnet [Ransomware]: dragnet-ransomware-2022-2648 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: d5b367a1-a66f-580e-b5d2-1d9a2c970e8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
