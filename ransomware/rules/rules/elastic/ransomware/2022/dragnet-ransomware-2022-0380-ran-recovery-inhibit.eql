// Dragnet [Ransomware]: dragnet-ransomware-2022-0380 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 5b8ff709-14aa-5deb-a7f0-37bf678a29ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
