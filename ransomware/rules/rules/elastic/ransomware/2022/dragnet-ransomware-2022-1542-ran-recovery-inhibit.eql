// Dragnet [Ransomware]: dragnet-ransomware-2022-1542 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 22e34e5a-cb4b-5e67-b7d9-b24fc6ec6d1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
