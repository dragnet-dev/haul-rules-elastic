// Dragnet [Ransomware]: dragnet-ransomware-2022-2685 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 26e74b9b-5a0f-5e3f-bce0-42b1522669a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
