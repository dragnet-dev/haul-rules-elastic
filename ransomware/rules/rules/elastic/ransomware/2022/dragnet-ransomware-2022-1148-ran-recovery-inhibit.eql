// Dragnet [Ransomware]: dragnet-ransomware-2022-1148 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: de4560ec-173f-52ac-9224-881ad57e84f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
