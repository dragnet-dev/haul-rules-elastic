// Dragnet [Ransomware]: dragnet-ransomware-2022-0467 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 8c00eed4-5017-58df-aa40-2530b7f6b193

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
