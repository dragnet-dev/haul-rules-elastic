// Dragnet [Ransomware]: dragnet-ransomware-2022-2439 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 62ae3fd6-38cb-55b5-9d75-198cf386b915

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
