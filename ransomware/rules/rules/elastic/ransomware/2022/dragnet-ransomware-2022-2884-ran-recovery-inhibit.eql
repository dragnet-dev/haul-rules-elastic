// Dragnet [Ransomware]: dragnet-ransomware-2022-2884 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 76278182-e7af-5e07-bc75-fb7c21d3accb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
