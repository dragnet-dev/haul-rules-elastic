// Dragnet [Ransomware]: dragnet-ransomware-2022-0473 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8996d698-b1c3-5059-a281-fc58475d9b9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
