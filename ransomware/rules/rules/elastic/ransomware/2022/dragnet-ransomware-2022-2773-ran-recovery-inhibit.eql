// Dragnet [Ransomware]: dragnet-ransomware-2022-2773 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: e28f3b35-dfa8-5ad5-90f4-5dc98ad72993

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
