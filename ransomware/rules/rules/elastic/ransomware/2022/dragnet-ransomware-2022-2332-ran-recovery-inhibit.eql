// Dragnet [Ransomware]: dragnet-ransomware-2022-2332 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: 35688768-85a7-572c-80df-a7a4eff3f50f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
