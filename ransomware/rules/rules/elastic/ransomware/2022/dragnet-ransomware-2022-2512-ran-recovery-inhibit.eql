// Dragnet [Ransomware]: dragnet-ransomware-2022-2512 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6624f4cf-0e16-5c9a-aebe-b231ff5a409c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
