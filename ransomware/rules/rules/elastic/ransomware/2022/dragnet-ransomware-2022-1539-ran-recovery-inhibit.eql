// Dragnet [Ransomware]: dragnet-ransomware-2022-1539 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: c242e81b-c1bc-5a79-81a0-a551033e5c2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
