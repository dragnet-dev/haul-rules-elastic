// Dragnet [Ransomware]: dragnet-ransomware-2022-1652 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 8631bddf-5d90-5058-beb3-e51c0d74a4ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
