// Dragnet [Ransomware]: dragnet-ransomware-2022-0725 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: fd10f597-c0fd-5898-afd9-7d612410ebf2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
