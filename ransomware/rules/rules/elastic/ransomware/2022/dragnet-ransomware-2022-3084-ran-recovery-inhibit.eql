// Dragnet [Ransomware]: dragnet-ransomware-2022-3084 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 9b9a1618-6453-523a-a710-d7cdd90928ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
