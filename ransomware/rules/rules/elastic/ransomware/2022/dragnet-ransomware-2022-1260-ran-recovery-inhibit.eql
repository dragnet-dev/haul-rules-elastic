// Dragnet [Ransomware]: dragnet-ransomware-2022-1260 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: abc18b67-bdc2-5891-a34f-6670549742e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
