// Dragnet [Ransomware]: dragnet-ransomware-2022-1644 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 2266a81c-b754-5a89-a835-c28f0eb8f11f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
