// Dragnet [Ransomware]: dragnet-ransomware-2022-2053 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 6a515ce5-d8c4-5f08-bc83-1f494fad0180

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
