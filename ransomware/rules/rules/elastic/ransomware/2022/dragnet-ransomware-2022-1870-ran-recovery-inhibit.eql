// Dragnet [Ransomware]: dragnet-ransomware-2022-1870 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 2be26b3f-116e-57e7-b8fa-2962fede1310

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
