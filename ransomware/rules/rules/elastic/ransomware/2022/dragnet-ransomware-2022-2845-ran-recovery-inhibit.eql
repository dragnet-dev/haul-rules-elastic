// Dragnet [Ransomware]: dragnet-ransomware-2022-2845 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: e09d9bac-3f4f-5050-8376-10d8df360d40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
