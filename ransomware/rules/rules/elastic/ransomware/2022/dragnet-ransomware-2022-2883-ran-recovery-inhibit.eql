// Dragnet [Ransomware]: dragnet-ransomware-2022-2883 — Recovery Inhibition (leaktheanalyst)
// Status: deprecated | Level: high | ID: 5096d9dd-c481-575f-804f-b79963f0fc5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
