// Dragnet [Ransomware]: dragnet-ransomware-2022-2254 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 1136cb4b-ce60-5719-a263-f1aa383562d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
