// Dragnet [Ransomware]: dragnet-ransomware-2022-0986 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 0892ce74-2487-586b-b155-377195d7497b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
