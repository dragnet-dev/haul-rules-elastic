// Dragnet [Ransomware]: dragnet-ransomware-2022-2596 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 94ac09e2-d37c-5038-a35a-e771c248554c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
