// Dragnet [Ransomware]: dragnet-ransomware-2022-2226 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: c6bf2b3d-e78c-502b-9279-c09d36a0d7e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
