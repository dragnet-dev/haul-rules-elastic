// Dragnet [Ransomware]: dragnet-ransomware-2022-0597 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 906209d7-5e74-50f9-9f1f-fb1a6dcd2631

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
