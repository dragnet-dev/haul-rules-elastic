// Dragnet [Ransomware]: dragnet-ransomware-2022-3045 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a6bc396a-bfbf-5e22-81b8-932106c8c7a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
