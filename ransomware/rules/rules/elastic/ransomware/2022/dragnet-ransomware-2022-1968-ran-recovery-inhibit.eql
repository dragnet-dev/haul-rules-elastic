// Dragnet [Ransomware]: dragnet-ransomware-2022-1968 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: eff6f5c5-af6a-59f8-85f5-239857c5f413

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
