// Dragnet [Ransomware]: dragnet-ransomware-2022-0927 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: 8813649f-cca6-5d64-ae38-be502fefaeba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
