// Dragnet [Ransomware]: dragnet-ransomware-2022-1425 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: de3f9fe5-7e5d-5d85-95a0-1b8cee958621

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
