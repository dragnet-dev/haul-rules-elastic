// Dragnet [Ransomware]: dragnet-ransomware-2022-2737 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 2b0bf1fd-af9e-5b29-aa4c-51dfe9c0c0a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
