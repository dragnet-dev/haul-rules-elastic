// Dragnet [Ransomware]: dragnet-ransomware-2022-1442 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: 939322c8-b73f-5071-b536-973ebe81ac2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
