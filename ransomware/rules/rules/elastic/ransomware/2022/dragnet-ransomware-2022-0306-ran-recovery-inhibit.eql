// Dragnet [Ransomware]: dragnet-ransomware-2022-0306 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 61f78f66-38b6-5531-b7e7-c2b49d4b9193

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
