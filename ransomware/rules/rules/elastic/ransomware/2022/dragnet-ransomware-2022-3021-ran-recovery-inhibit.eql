// Dragnet [Ransomware]: dragnet-ransomware-2022-3021 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: c67cbc1a-1902-5f16-9e73-03ae975aeeeb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
