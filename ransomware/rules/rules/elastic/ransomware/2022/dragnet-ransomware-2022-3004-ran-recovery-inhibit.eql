// Dragnet [Ransomware]: dragnet-ransomware-2022-3004 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: e2eda35d-71b8-57ed-8f8e-0559bfc3e3fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
