// Dragnet [Ransomware]: dragnet-ransomware-2022-1001 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5de8d496-95b0-5d2e-8903-0e7bc2fd84a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
