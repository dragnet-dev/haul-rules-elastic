// Dragnet [Ransomware]: dragnet-ransomware-2022-2296 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 444bb462-cfc2-5b44-8c1e-9efc66d7f2eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
