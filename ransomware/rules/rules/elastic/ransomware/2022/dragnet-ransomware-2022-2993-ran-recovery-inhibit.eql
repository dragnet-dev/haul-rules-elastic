// Dragnet [Ransomware]: dragnet-ransomware-2022-2993 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c575ebd2-787a-5e61-948b-7fd24d55a751

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
