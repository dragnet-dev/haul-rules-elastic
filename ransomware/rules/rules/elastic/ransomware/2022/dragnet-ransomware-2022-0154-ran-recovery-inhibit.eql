// Dragnet [Ransomware]: dragnet-ransomware-2022-0154 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: d2223912-6e9e-51a6-bbf6-55160f18cf6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
