// Dragnet [Ransomware]: dragnet-ransomware-2022-1598 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 56850c8c-63d1-5be7-86c4-8991da141d4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
