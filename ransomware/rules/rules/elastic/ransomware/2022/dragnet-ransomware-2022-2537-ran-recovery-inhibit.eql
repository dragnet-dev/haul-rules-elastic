// Dragnet [Ransomware]: dragnet-ransomware-2022-2537 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 14d082ca-215c-5515-b683-f169911f15b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
