// Dragnet [Ransomware]: dragnet-ransomware-2022-1538 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: dab7b2d8-b7f5-5553-b796-ddd19a497549

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
