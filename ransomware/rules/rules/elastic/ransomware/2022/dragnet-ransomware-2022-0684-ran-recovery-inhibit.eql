// Dragnet [Ransomware]: dragnet-ransomware-2022-0684 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: cc65180d-daf4-57ae-822e-ff9ce10bb2f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
