// Dragnet [Ransomware]: dragnet-ransomware-2022-2747 — Recovery Inhibition (arvinclub)
// Status: deprecated | Level: high | ID: bb87a8bf-01a3-502c-b107-384c4f613397

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
