// Dragnet [Ransomware]: dragnet-ransomware-2022-0187 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: eb7ba3a7-8e71-576f-96bf-9ed581a70c22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
