// Dragnet [Ransomware]: dragnet-ransomware-2022-0453 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: cd224534-083c-5a5e-9f6d-f2b40fa8a107

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
