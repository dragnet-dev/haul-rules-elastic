// Dragnet [Ransomware]: dragnet-ransomware-2022-3024 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: f431207d-c8dd-5780-96a7-15391e243c08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
