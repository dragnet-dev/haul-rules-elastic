// Dragnet [Ransomware]: dragnet-ransomware-2022-2591 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 9f040262-a4cc-5ac3-8aed-036eaafe4f76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
