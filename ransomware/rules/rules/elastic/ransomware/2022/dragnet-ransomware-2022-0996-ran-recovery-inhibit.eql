// Dragnet [Ransomware]: dragnet-ransomware-2022-0996 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 5fc259d5-16f9-53f8-802d-da791f8db89d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
