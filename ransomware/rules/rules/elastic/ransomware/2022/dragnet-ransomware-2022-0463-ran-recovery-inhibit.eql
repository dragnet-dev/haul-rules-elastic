// Dragnet [Ransomware]: dragnet-ransomware-2022-0463 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a10aee11-caae-5605-997d-175a82142841

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
