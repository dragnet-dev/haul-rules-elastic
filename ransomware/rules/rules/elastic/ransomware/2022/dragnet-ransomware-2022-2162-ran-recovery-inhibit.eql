// Dragnet [Ransomware]: dragnet-ransomware-2022-2162 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 91b8a35a-fc74-5bd6-9481-efacb25a0784

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
