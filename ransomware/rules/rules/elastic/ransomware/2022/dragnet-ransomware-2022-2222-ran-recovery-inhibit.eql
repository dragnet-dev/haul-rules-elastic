// Dragnet [Ransomware]: dragnet-ransomware-2022-2222 — Recovery Inhibition (sparta)
// Status: deprecated | Level: high | ID: 0b0a4126-08bf-526d-be5f-af9c081edf4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
