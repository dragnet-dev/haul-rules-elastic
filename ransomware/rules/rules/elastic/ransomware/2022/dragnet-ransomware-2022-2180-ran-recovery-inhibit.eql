// Dragnet [Ransomware]: dragnet-ransomware-2022-2180 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 1cc63fd9-9c93-5241-9998-75d5b841fd56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
