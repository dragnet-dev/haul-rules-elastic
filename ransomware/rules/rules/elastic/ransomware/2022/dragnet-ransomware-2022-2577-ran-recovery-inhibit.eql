// Dragnet [Ransomware]: dragnet-ransomware-2022-2577 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 236783c4-225a-5b3e-afcb-d252fb1a704b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
