// Dragnet [Ransomware]: dragnet-ransomware-2022-2582 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 4b2bb9ba-4898-5cd5-9c56-b1d698b793cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
