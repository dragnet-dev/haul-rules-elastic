// Dragnet [Ransomware]: dragnet-ransomware-2022-1280 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 22716da4-aae3-5804-b431-f7e7cac458df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
