// Dragnet [Ransomware]: dragnet-ransomware-2022-2786 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: ea6e3a3e-c1d3-5bc2-9cd5-4e356111a491

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
