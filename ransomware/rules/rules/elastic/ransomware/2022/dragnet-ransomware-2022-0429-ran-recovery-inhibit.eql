// Dragnet [Ransomware]: dragnet-ransomware-2022-0429 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 65ac0a17-acc7-59ef-8c80-5b165906147c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
