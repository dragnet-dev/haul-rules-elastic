// Dragnet [Ransomware]: dragnet-ransomware-2022-1831 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: f33adc86-f7af-512e-9191-05419429b8bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
