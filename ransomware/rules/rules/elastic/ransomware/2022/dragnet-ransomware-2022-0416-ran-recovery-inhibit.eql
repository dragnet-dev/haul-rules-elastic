// Dragnet [Ransomware]: dragnet-ransomware-2022-0416 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: decffcec-7060-5ee7-8147-41c9210ad768

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
