// Dragnet [Ransomware]: dragnet-ransomware-2022-1036 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: b420f323-16ba-5385-99d6-55d083a79c7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
