// Dragnet [Ransomware]: dragnet-ransomware-2022-0044 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: e394badf-e289-532a-a1ab-2a1ca6bf3bb9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
