// Dragnet [Ransomware]: dragnet-ransomware-2022-0795 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 0663c84b-421b-5f59-9b56-ff23b4274e8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
