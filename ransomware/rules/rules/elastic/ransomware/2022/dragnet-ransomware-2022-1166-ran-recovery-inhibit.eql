// Dragnet [Ransomware]: dragnet-ransomware-2022-1166 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 48ee1586-cdfc-586c-816f-4de40fedd8f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
