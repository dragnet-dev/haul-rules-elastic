// Dragnet [Ransomware]: dragnet-ransomware-2022-2496 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: fd5459cc-938c-57fd-85bd-88423b4d00b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
