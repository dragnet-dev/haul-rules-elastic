// Dragnet [Ransomware]: dragnet-ransomware-2022-2795 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b019d3ae-022e-539b-aa82-da4cca6e0b28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
