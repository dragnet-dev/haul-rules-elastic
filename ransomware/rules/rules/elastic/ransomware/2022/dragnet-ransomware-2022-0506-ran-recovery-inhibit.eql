// Dragnet [Ransomware]: dragnet-ransomware-2022-0506 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 2b6f1d9f-5b31-5aba-b013-54cc6e79b576

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
