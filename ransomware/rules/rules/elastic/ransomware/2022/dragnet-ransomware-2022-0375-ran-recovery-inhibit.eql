// Dragnet [Ransomware]: dragnet-ransomware-2022-0375 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c688d43d-6559-5ee3-942c-cc35f60e98fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
