// Dragnet [Ransomware]: dragnet-ransomware-2022-1163 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 254006a8-5d72-55b1-a2db-2519f8d037a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
