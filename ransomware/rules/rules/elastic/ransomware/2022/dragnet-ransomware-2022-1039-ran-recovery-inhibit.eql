// Dragnet [Ransomware]: dragnet-ransomware-2022-1039 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 4917a8fb-c705-5375-9d1c-89ee5764945d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
