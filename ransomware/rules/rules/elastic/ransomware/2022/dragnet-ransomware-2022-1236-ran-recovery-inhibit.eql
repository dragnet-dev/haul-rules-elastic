// Dragnet [Ransomware]: dragnet-ransomware-2022-1236 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 74d476bf-c334-5767-93ae-35abeef3cacd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
