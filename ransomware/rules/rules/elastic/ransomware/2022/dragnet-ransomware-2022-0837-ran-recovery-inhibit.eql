// Dragnet [Ransomware]: dragnet-ransomware-2022-0837 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: e333099a-1d55-5d90-b747-0ce8b8fd871c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
