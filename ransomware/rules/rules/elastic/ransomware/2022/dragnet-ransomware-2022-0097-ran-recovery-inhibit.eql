// Dragnet [Ransomware]: dragnet-ransomware-2022-0097 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 4d51d0f7-24a9-5f8d-b8db-c573b6ec1d98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
