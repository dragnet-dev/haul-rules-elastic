// Dragnet [Ransomware]: dragnet-ransomware-2022-2662 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ab07b092-6483-57dc-8bde-feee72088271

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
