// Dragnet [Ransomware]: dragnet-ransomware-2022-0365 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 7f014329-5f3f-5865-bf0d-ec08dc18b27a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
