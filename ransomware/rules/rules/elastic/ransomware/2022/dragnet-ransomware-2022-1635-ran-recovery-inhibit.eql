// Dragnet [Ransomware]: dragnet-ransomware-2022-1635 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 8ddee663-2777-50a2-86fb-f60d9bf7fc9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
