// Dragnet [Ransomware]: dragnet-ransomware-2022-0823 — Recovery Inhibition (daixin)
// Status: deprecated | Level: high | ID: de83d189-3f46-570a-bd96-dbf9d1ff355c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
