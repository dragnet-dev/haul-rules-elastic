// Dragnet [Ransomware]: dragnet-ransomware-2022-2373 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: 77ec9c2c-7f96-53b9-b7be-7c97ed931a4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
