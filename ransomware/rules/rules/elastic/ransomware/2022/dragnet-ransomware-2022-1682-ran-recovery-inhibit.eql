// Dragnet [Ransomware]: dragnet-ransomware-2022-1682 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 302716fe-56e1-533d-b246-1da5a0c6788c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
