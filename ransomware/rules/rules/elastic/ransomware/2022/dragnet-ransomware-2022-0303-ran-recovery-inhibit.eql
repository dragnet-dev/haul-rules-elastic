// Dragnet [Ransomware]: dragnet-ransomware-2022-0303 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 1d48e6b8-5f16-5165-8937-00ae98bb1503

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
