// Dragnet [Ransomware]: dragnet-ransomware-2022-1472 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 2dfbe46d-b3b4-5ac2-a270-54432e10510a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
