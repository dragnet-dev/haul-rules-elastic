// Dragnet [Ransomware]: dragnet-ransomware-2022-0075 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 974298b7-52b6-5fcd-be27-9fe1e2658327

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
