// Dragnet [Ransomware]: dragnet-ransomware-2022-1099 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: a5f46214-6f71-52b5-a506-534e34501608

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
