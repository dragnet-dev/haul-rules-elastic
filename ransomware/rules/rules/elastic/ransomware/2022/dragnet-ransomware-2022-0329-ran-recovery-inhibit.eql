// Dragnet [Ransomware]: dragnet-ransomware-2022-0329 — Recovery Inhibition (sparta)
// Status: deprecated | Level: high | ID: b41fc77c-e461-5934-8f24-4aa4519f06c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
