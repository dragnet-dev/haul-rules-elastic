// Dragnet [Ransomware]: dragnet-ransomware-2022-0206 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 702b6db7-bf82-5931-8bf6-90198dcc8830

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
