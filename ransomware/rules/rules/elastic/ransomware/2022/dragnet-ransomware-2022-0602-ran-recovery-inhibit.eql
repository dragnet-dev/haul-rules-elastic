// Dragnet [Ransomware]: dragnet-ransomware-2022-0602 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 3fd7be88-f384-5990-8666-f5167e0f8b34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
