// Dragnet [Ransomware]: dragnet-ransomware-2022-1669 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 5dde4a0e-c958-5572-b410-7c3b04e52448

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
