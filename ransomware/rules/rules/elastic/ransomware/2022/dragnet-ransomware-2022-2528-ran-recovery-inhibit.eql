// Dragnet [Ransomware]: dragnet-ransomware-2022-2528 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 29a05937-75cd-58c8-9899-d7df873176f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
