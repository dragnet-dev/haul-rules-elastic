// Dragnet [Ransomware]: dragnet-ransomware-2022-1551 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: b61b3eff-3a4a-5dd9-ab5c-40d4f049f291

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
