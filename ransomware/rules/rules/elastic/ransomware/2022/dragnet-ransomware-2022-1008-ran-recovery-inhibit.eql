// Dragnet [Ransomware]: dragnet-ransomware-2022-1008 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 6e4b45b4-3155-59d3-a15d-cb2edad83b94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
