// Dragnet [Ransomware]: dragnet-ransomware-2022-2447 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: b3e8a6a5-2215-51c7-84ab-e3ad572172b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
