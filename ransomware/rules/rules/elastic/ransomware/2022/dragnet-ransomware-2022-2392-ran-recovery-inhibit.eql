// Dragnet [Ransomware]: dragnet-ransomware-2022-2392 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: e0ad159b-bcaa-596d-adfa-89f4bd280650

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
