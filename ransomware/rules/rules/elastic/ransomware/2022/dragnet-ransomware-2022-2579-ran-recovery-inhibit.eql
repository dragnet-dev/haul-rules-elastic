// Dragnet [Ransomware]: dragnet-ransomware-2022-2579 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: b4d5ebed-81c1-5168-8782-a44c6f1186c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
