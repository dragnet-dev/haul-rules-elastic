// Dragnet [Ransomware]: dragnet-ransomware-2022-1306 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 1079df32-662d-5188-92ac-f36a3a35ad72

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
