// Dragnet [Ransomware]: dragnet-ransomware-2022-0976 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 27d9d49f-01f7-5186-a59b-aaf49297ba65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
