// Dragnet [Ransomware]: dragnet-ransomware-2022-1382 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 7ecc39c8-d3ff-5697-80c4-f9d0dd270ac2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
