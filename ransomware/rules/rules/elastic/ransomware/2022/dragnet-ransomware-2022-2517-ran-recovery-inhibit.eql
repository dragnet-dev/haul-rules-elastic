// Dragnet [Ransomware]: dragnet-ransomware-2022-2517 — Recovery Inhibition (mallox)
// Status: deprecated | Level: high | ID: 4fe15c7b-1dd5-58e0-be6d-d8bce5a83227

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
