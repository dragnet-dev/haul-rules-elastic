// Dragnet [Ransomware]: dragnet-ransomware-2022-2780 — Recovery Inhibition (yanluowang)
// Status: deprecated | Level: high | ID: 0a65fbff-78fc-5462-8941-842ec364186e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
