// Dragnet [Ransomware]: dragnet-ransomware-2022-0812 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 9788d373-6027-5efe-9228-093d3b25a0d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
