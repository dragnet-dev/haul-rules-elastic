// Dragnet [Ransomware]: dragnet-ransomware-2022-2182 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 2efbc30a-b38c-5b1a-bf75-c3d4cf57718e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
