// Dragnet [Ransomware]: dragnet-ransomware-2022-0335 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ec057f3b-850e-5cc6-a862-259d7877c703

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
