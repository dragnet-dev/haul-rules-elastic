// Dragnet [Ransomware]: dragnet-ransomware-2022-0145 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 6236771b-6d9e-5f00-b79f-5a51b86ff8af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
