// Dragnet [Ransomware]: dragnet-ransomware-2022-2877 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 59a3efa5-b3f8-5cbf-9447-1eefa198c620

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
