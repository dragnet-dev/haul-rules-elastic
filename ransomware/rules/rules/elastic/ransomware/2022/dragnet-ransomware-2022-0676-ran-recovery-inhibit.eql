// Dragnet [Ransomware]: dragnet-ransomware-2022-0676 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 3a121fea-07f7-571e-8e5a-0044c24399a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
