// Dragnet [Ransomware]: dragnet-ransomware-2022-1616 — Recovery Inhibition (sparta)
// Status: deprecated | Level: high | ID: 110055e1-b682-5495-af68-47cc89d467e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
