// Dragnet [Ransomware]: dragnet-ransomware-2022-1246 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: dcc65c8f-ea9c-52b7-bb7a-7f4e2fe995e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
