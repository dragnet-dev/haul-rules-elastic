// Dragnet [Ransomware]: dragnet-ransomware-2022-0360 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 1959a2ee-f01f-5da3-8705-adaac2dc942b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
