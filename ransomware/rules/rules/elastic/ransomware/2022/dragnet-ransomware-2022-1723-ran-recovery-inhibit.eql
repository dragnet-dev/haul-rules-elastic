// Dragnet [Ransomware]: dragnet-ransomware-2022-1723 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 827104b4-6ab8-5f53-b118-179e37d0df63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
