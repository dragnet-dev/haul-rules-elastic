// Dragnet [Ransomware]: dragnet-ransomware-2022-0411 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c91cc475-4063-5dc2-8f75-8e45a7bb30a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
