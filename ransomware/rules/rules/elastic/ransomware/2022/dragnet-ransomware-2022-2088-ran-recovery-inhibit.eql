// Dragnet [Ransomware]: dragnet-ransomware-2022-2088 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 93541137-c0b8-5f4d-b2e9-a79780a5bf24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
