// Dragnet [Ransomware]: dragnet-ransomware-2022-2482 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 4ffe5c92-cd8e-5b44-950e-c80784af1460

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
