// Dragnet [Ransomware]: dragnet-ransomware-2022-0569 — Recovery Inhibition (sabbath)
// Status: deprecated | Level: high | ID: e66cd4cc-8d19-55ce-b33d-8af156918726

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
