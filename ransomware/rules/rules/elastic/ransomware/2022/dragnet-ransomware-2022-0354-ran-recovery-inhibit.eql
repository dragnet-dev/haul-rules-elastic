// Dragnet [Ransomware]: dragnet-ransomware-2022-0354 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 50367377-18c8-52d4-a969-960f2d98232f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
