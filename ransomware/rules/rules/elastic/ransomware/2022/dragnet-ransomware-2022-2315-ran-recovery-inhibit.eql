// Dragnet [Ransomware]: dragnet-ransomware-2022-2315 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5f9e8c68-d3bb-5b20-adbc-f6a08ef214f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
