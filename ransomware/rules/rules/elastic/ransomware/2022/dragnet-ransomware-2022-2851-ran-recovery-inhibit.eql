// Dragnet [Ransomware]: dragnet-ransomware-2022-2851 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 97eaabb2-1f8c-5806-8cc9-edcc837420ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
