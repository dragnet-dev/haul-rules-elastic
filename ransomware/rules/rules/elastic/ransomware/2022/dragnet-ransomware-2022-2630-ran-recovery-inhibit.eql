// Dragnet [Ransomware]: dragnet-ransomware-2022-2630 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 108c4c6f-495f-5d4b-b5d7-472e756cee3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
