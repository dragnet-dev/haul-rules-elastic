// Dragnet [Ransomware]: dragnet-ransomware-2022-1650 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 422c16b4-38b2-57d2-b999-e002ec098cd7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
