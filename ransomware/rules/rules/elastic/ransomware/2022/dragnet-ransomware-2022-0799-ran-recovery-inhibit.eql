// Dragnet [Ransomware]: dragnet-ransomware-2022-0799 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 07967622-698f-5c2b-abde-3dc0698baebc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
