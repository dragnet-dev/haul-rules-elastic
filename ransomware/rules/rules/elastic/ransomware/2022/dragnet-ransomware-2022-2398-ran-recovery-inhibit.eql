// Dragnet [Ransomware]: dragnet-ransomware-2022-2398 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 2bd430b5-a399-5353-80d7-a79dcb8e2e2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
