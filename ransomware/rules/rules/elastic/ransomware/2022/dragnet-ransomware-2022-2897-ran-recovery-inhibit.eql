// Dragnet [Ransomware]: dragnet-ransomware-2022-2897 — Recovery Inhibition (sabbath)
// Status: deprecated | Level: high | ID: e958daa3-d603-5e8e-bd2c-a0bf73ccf78b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
