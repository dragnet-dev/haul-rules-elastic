// Dragnet [Ransomware]: dragnet-ransomware-2022-2627 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 11ff7d89-6cd2-56d2-9836-242bd1e59379

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
