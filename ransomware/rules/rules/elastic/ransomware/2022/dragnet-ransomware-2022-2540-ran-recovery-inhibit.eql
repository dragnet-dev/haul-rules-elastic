// Dragnet [Ransomware]: dragnet-ransomware-2022-2540 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 8bc25f73-7c37-51b0-9789-22d3f6b21521

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
