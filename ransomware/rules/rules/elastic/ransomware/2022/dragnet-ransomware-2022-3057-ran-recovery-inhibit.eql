// Dragnet [Ransomware]: dragnet-ransomware-2022-3057 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: d71166cb-5986-5557-8d30-c34a7fbf17d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
