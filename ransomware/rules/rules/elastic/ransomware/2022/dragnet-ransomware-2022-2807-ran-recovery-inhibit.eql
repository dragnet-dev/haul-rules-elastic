// Dragnet [Ransomware]: dragnet-ransomware-2022-2807 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: e8a643ba-91cd-5eee-8d9e-858128f41961

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
