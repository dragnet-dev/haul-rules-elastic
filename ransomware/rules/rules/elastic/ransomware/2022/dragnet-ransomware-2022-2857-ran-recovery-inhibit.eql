// Dragnet [Ransomware]: dragnet-ransomware-2022-2857 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: c7b0a455-863a-5533-be26-3a1483c94736

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
