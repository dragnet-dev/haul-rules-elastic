// Dragnet [Ransomware]: dragnet-ransomware-2022-0436 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 72fe4707-9e0c-584d-95d0-e610a4898afe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
