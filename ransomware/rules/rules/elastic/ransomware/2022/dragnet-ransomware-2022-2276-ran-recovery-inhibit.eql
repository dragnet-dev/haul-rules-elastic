// Dragnet [Ransomware]: dragnet-ransomware-2022-2276 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: d23deefa-2b3d-5fdb-bfd4-a97a68261738

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
