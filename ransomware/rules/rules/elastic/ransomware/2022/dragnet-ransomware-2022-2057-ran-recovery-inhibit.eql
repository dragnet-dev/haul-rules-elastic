// Dragnet [Ransomware]: dragnet-ransomware-2022-2057 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 9bf83f89-137a-55d1-8210-8c4c6224416e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
