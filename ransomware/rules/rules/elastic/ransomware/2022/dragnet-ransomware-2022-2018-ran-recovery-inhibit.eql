// Dragnet [Ransomware]: dragnet-ransomware-2022-2018 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d4ac0dd6-e93d-5265-9f93-a225fb18d6c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
