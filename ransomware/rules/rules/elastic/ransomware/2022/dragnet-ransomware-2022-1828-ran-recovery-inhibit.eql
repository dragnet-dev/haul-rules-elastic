// Dragnet [Ransomware]: dragnet-ransomware-2022-1828 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 9d659e5e-7665-5b0d-b8f7-c2190dfe2045

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
