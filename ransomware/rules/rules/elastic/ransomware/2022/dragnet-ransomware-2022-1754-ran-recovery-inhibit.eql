// Dragnet [Ransomware]: dragnet-ransomware-2022-1754 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: ccfa4a04-2bde-5166-84e2-8b27287783f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
