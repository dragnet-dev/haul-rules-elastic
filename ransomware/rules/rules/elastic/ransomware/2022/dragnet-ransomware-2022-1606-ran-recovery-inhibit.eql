// Dragnet [Ransomware]: dragnet-ransomware-2022-1606 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 55729727-ed1d-59a2-9769-083cea944724

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
