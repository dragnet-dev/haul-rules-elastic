// Dragnet [Ransomware]: dragnet-ransomware-2022-1049 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 304305a9-0cd0-5fe3-9cd0-750e6b60742b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
