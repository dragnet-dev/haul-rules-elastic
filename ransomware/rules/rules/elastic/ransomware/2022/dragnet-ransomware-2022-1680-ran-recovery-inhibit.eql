// Dragnet [Ransomware]: dragnet-ransomware-2022-1680 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 1bbb31fc-8e94-559e-9753-9b3abb2562c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
