// Dragnet [Ransomware]: dragnet-ransomware-2022-1003 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 360920aa-74fa-59db-a631-76ca6b9e690b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
