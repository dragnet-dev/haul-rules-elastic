// Dragnet [Ransomware]: dragnet-ransomware-2022-1510 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 4f984370-e1dc-583a-ac0e-0f2f456b7a1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
