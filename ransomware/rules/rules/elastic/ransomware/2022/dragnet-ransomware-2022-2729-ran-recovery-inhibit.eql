// Dragnet [Ransomware]: dragnet-ransomware-2022-2729 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 407cf371-f51d-5f0d-9dd4-9b31b3bfe177

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
