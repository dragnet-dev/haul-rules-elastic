// Dragnet [Ransomware]: dragnet-ransomware-2022-2038 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: f047cd8e-1d14-53a7-9b74-eead02b1ccb2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
