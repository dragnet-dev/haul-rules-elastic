// Dragnet [Ransomware]: dragnet-ransomware-2022-0051 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 49b20e27-9bf4-59fe-b279-b9042f02480f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
