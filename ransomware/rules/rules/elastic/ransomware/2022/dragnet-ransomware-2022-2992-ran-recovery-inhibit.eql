// Dragnet [Ransomware]: dragnet-ransomware-2022-2992 — Recovery Inhibition (lapsus$)
// Status: deprecated | Level: high | ID: 650b747b-2722-5e22-97a6-f50df29c279f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
