// Dragnet [Ransomware]: dragnet-ransomware-2022-2609 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 656f4807-2ead-5ffa-8d49-41ebdfd08979

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
