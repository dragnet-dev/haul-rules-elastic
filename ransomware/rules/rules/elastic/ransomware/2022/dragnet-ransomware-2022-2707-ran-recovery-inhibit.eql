// Dragnet [Ransomware]: dragnet-ransomware-2022-2707 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: edc41eb4-a4c6-517c-82da-0ae9b99d9596

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
