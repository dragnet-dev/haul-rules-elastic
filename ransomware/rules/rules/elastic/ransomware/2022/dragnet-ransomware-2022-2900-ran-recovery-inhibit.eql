// Dragnet [Ransomware]: dragnet-ransomware-2022-2900 — Recovery Inhibition (sparta)
// Status: deprecated | Level: high | ID: 98580283-558e-5f6a-ace8-47e008f65eac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
