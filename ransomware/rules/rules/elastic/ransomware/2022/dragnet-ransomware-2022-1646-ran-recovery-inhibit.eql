// Dragnet [Ransomware]: dragnet-ransomware-2022-1646 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a34630b3-a7e1-5d94-9fa6-8234db943a3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
