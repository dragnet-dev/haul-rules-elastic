// Dragnet [Ransomware]: dragnet-ransomware-2022-2850 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 1aeca8c3-6b62-507a-b6cb-a2bd25900445

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
