// Dragnet [Ransomware]: dragnet-ransomware-2022-0804 — Recovery Inhibition (unsafe)
// Status: deprecated | Level: high | ID: 85331271-3b93-5cb6-8dd2-85da78af59af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
