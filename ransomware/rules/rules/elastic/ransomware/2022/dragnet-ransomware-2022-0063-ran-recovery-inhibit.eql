// Dragnet [Ransomware]: dragnet-ransomware-2022-0063 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 12b2bf55-37f9-584e-917e-4f977fcab3c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
