// Dragnet [Ransomware]: dragnet-ransomware-2022-1291 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: 6dece95f-3c83-56dd-81d7-bf95d1c7125f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
