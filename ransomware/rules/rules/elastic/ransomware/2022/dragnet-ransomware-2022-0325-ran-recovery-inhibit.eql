// Dragnet [Ransomware]: dragnet-ransomware-2022-0325 — Recovery Inhibition (projectrelic)
// Status: deprecated | Level: high | ID: ece32472-6d62-509d-8cc9-dd12569fa22f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
