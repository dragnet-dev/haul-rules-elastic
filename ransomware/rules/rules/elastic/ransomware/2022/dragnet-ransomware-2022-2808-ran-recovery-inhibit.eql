// Dragnet [Ransomware]: dragnet-ransomware-2022-2808 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 785c4257-48c4-5b03-b30d-bfaf535d8121

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
