// Dragnet [Ransomware]: dragnet-ransomware-2022-1878 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 7e426fca-9e7f-5e17-a0ea-85079d12013d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
