// Dragnet [Ransomware]: dragnet-ransomware-2022-0793 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 31e571cb-4051-5770-b1a2-a7fae9811bd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
