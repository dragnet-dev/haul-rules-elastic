// Dragnet [Ransomware]: dragnet-ransomware-2022-2597 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 51e8386a-9177-50ad-a838-fd43f9bc0a81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
