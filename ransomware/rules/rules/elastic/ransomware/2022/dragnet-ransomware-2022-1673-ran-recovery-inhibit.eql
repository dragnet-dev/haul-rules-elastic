// Dragnet [Ransomware]: dragnet-ransomware-2022-1673 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6417368b-80c1-589f-b66b-7d458c95d7d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
