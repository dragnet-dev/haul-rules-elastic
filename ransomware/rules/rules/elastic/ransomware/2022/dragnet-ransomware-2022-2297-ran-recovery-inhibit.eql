// Dragnet [Ransomware]: dragnet-ransomware-2022-2297 — Recovery Inhibition (icefire)
// Status: deprecated | Level: high | ID: e895fd6e-924a-54fd-9ac5-1410f2db5c66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
