// Dragnet [Ransomware]: dragnet-ransomware-2022-2946 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 04bc1a60-2326-5846-b265-8af3bdf474c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
