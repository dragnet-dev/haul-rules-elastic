// Dragnet [Ransomware]: dragnet-ransomware-2022-0928 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 49b616bf-3561-5890-b9f6-9a32df395d2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
