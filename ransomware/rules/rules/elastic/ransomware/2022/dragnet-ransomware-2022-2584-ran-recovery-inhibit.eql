// Dragnet [Ransomware]: dragnet-ransomware-2022-2584 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 9a203534-33f1-5c6b-ba0b-bbd8f2489ff0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
