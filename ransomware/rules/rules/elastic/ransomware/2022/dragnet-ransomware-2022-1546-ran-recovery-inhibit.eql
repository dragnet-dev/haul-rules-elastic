// Dragnet [Ransomware]: dragnet-ransomware-2022-1546 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: cc420a8b-5836-53a0-83ee-baaee70508f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
