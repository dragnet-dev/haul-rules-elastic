// Dragnet [Ransomware]: dragnet-ransomware-2022-1368 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 031fd0f8-02de-5a50-9356-ea2042507ff3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
