// Dragnet [Ransomware]: dragnet-ransomware-2022-2340 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 0aef9464-8a7d-53bb-87b4-b480a155660d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
