// Dragnet [Ransomware]: dragnet-ransomware-2022-2238 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: b30b04a6-8ba5-516b-a623-536d13b5e265

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
