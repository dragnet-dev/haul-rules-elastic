// Dragnet [Ransomware]: dragnet-ransomware-2022-0973 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e0d38bff-a214-5f8e-94c0-9289775c7675

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
