// Dragnet [Ransomware]: dragnet-ransomware-2022-0450 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 39d6e7f1-5360-5f9b-b791-f54b7c93bd10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
