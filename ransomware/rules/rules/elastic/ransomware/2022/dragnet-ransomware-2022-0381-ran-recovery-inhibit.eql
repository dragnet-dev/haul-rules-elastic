// Dragnet [Ransomware]: dragnet-ransomware-2022-0381 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 60b41284-5669-5788-b969-44c319f76314

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
