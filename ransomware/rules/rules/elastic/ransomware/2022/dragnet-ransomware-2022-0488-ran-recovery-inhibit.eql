// Dragnet [Ransomware]: dragnet-ransomware-2022-0488 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 3f49285f-3abd-5e33-b636-7b43c8beaf92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
