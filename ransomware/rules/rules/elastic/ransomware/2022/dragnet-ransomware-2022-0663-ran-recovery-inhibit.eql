// Dragnet [Ransomware]: dragnet-ransomware-2022-0663 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: fd8b9dc3-eb28-513e-8ca9-26630da6c7be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
