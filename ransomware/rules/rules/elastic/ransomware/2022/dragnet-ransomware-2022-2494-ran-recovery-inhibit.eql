// Dragnet [Ransomware]: dragnet-ransomware-2022-2494 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 4b81db29-4d95-5566-97e7-bab7657d716a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
