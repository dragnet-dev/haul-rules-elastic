// Dragnet [Ransomware]: dragnet-ransomware-2022-1621 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 808055b0-efd9-5f7d-9c94-301f8fb3545a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
