// Dragnet [Ransomware]: dragnet-ransomware-2022-1783 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 7518a9c9-1d96-5324-bbe3-905ca1a39a6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
