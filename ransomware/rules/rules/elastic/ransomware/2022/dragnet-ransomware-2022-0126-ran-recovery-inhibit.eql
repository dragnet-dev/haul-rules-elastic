// Dragnet [Ransomware]: dragnet-ransomware-2022-0126 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: fe9d2f76-5667-5b1d-8f2a-ffbb080bbbf9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
