// Dragnet [Ransomware]: dragnet-ransomware-2022-0317 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 767d1bb3-978b-54ad-84ec-a74da29d2e9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
