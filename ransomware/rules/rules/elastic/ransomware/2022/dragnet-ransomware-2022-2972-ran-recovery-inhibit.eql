// Dragnet [Ransomware]: dragnet-ransomware-2022-2972 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: 3aabf9b5-a3d4-559e-b26a-d39ae22364d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
