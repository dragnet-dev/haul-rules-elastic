// Dragnet [Ransomware]: dragnet-ransomware-2022-0842 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 9a00e505-80dc-5515-97be-3b156a1deb9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
