// Dragnet [Ransomware]: dragnet-ransomware-2022-1540 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 10c29120-1857-568c-833e-dada1cc398a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
