// Dragnet [Ransomware]: dragnet-ransomware-2022-2178 — Recovery Inhibition (leaktheanalyst)
// Status: deprecated | Level: high | ID: b6fafce1-299f-55a8-8959-94979d8cf0fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
