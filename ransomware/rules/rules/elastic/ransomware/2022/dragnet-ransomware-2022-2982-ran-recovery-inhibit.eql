// Dragnet [Ransomware]: dragnet-ransomware-2022-2982 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: f214ee8f-3c3c-513a-b874-a8b8a5a3a208

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
