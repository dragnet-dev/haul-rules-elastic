// Dragnet [Ransomware]: dragnet-ransomware-2022-3132 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e790fb85-f748-5fe0-a359-831a07a078e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
