// Dragnet [Ransomware]: dragnet-ransomware-2022-2013 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3e396646-5d33-5d27-b601-0ec456a3d290

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
