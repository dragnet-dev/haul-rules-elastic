// Dragnet [Ransomware]: dragnet-ransomware-2022-0098 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 07708f54-d31a-56be-a0bb-3f9055bc719b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
