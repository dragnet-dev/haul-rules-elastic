// Dragnet [Ransomware]: dragnet-ransomware-2022-0612 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 5714719c-55a3-57e7-930b-f71e34278317

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
