// Dragnet [Ransomware]: dragnet-ransomware-2022-2186 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 7e4f67a1-80ee-57f1-ae38-17ac47e9d666

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
