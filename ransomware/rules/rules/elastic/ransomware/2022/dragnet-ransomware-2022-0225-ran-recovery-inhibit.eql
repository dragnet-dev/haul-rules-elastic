// Dragnet [Ransomware]: dragnet-ransomware-2022-0225 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 3a01814b-27dc-5135-8eff-e9dc328c420d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
