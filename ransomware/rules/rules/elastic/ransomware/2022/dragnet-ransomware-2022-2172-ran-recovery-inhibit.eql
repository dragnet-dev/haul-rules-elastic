// Dragnet [Ransomware]: dragnet-ransomware-2022-2172 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 40cb5f14-bd76-556f-b96a-9a4b01e3a5a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
