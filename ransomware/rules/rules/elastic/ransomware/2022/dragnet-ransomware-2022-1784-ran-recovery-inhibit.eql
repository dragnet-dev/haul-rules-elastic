// Dragnet [Ransomware]: dragnet-ransomware-2022-1784 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: ddcffe2d-573f-561c-aeae-33a6365a8d0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
