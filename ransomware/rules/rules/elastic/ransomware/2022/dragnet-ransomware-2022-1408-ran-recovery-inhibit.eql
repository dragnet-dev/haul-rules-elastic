// Dragnet [Ransomware]: dragnet-ransomware-2022-1408 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c68f0aa1-a682-573a-8324-f777533c1e2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
