// Dragnet [Ransomware]: dragnet-ransomware-2022-1972 — Recovery Inhibition (leaktheanalyst)
// Status: deprecated | Level: high | ID: 76fa6744-adb4-5ac7-b6c5-969594599e42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
