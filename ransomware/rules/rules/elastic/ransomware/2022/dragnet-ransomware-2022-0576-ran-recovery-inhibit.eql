// Dragnet [Ransomware]: dragnet-ransomware-2022-0576 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: b8be82c4-eb0c-5870-954a-bf5079db48cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
