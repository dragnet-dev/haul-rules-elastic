// Dragnet [Ransomware]: dragnet-ransomware-2022-1759 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 4d982a72-ed2c-5db0-967e-b39150e4fc4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
