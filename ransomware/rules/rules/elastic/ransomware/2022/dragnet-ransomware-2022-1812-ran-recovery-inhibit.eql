// Dragnet [Ransomware]: dragnet-ransomware-2022-1812 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 4bc8f934-4ae3-51be-92ae-507139882dec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
