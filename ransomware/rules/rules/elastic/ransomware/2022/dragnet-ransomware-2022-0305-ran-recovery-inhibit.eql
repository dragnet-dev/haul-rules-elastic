// Dragnet [Ransomware]: dragnet-ransomware-2022-0305 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 7a9c3e95-2a19-589d-a732-6f2abac028a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
