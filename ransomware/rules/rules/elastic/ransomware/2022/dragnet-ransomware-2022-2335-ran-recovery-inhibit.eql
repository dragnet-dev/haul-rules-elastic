// Dragnet [Ransomware]: dragnet-ransomware-2022-2335 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 0438f40e-5873-5518-9786-8f64dad83e16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
