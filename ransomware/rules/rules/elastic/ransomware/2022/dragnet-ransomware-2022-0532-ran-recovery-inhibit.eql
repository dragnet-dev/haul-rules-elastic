// Dragnet [Ransomware]: dragnet-ransomware-2022-0532 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b2ced6aa-9029-59db-ae80-89370a84d83c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
