// Dragnet [Ransomware]: dragnet-ransomware-2022-1913 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 85e28676-eade-5092-b836-fdc907c28584

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
