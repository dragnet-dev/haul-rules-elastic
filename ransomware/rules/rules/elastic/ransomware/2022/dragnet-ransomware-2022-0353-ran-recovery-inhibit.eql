// Dragnet [Ransomware]: dragnet-ransomware-2022-0353 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e343188d-115e-5828-ad79-e7f71f9e9b85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
