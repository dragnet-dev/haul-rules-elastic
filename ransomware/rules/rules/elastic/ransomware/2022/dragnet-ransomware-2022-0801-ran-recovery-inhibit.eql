// Dragnet [Ransomware]: dragnet-ransomware-2022-0801 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c3c2ff8c-65d8-5ded-81b1-913596403564

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
