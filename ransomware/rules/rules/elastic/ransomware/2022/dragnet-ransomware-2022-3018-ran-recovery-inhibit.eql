// Dragnet [Ransomware]: dragnet-ransomware-2022-3018 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 77ab1093-e443-5dcd-b43a-3cd775fdc2f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
