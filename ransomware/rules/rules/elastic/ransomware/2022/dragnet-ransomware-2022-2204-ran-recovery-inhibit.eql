// Dragnet [Ransomware]: dragnet-ransomware-2022-2204 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 7ecc773a-7ca8-559e-9e20-d0f86c452185

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
