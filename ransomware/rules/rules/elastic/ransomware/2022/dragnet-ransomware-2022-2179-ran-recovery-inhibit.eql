// Dragnet [Ransomware]: dragnet-ransomware-2022-2179 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ca80bc2f-c310-58cd-bb61-c14da545ac36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
