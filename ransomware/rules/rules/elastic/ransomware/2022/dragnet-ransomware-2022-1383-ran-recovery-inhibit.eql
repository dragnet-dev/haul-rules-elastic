// Dragnet [Ransomware]: dragnet-ransomware-2022-1383 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 5e56e630-9ee6-51b4-90bc-87d8385445c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
