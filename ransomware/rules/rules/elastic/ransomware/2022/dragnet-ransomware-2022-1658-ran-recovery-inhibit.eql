// Dragnet [Ransomware]: dragnet-ransomware-2022-1658 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 09a22526-50f7-5221-a4c3-56572e2be713

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
