// Dragnet [Ransomware]: dragnet-ransomware-2022-0109 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 5c21e4c5-ae74-5e34-9b8d-7e595c6f71f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
