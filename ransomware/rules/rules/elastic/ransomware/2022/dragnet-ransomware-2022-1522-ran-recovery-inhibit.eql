// Dragnet [Ransomware]: dragnet-ransomware-2022-1522 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 9792369a-5ae7-5c4b-8828-252b78c66a0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
