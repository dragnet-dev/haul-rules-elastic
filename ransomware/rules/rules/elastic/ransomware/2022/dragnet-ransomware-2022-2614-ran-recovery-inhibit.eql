// Dragnet [Ransomware]: dragnet-ransomware-2022-2614 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 6e6c99b8-c2c7-56c1-94b9-f098576e9029

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
