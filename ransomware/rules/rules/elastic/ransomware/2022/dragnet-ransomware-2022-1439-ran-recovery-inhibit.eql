// Dragnet [Ransomware]: dragnet-ransomware-2022-1439 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 3a995d4a-8131-561f-9bf0-4650216ee511

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
