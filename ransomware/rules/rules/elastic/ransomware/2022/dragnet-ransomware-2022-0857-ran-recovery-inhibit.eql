// Dragnet [Ransomware]: dragnet-ransomware-2022-0857 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 9a93c589-37a0-5796-8372-20985caf9d88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
