// Dragnet [Ransomware]: dragnet-ransomware-2022-0196 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5cacfad4-15f2-5c6d-a292-a02db219853c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
