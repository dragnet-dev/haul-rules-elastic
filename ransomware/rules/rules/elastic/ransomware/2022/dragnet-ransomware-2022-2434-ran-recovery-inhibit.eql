// Dragnet [Ransomware]: dragnet-ransomware-2022-2434 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 7c13e406-bccd-5fd6-9820-04921fe90256

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
