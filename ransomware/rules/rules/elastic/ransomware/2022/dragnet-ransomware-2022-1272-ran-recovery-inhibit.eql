// Dragnet [Ransomware]: dragnet-ransomware-2022-1272 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 0d0308c0-97bc-550d-8d4d-591cb619bbbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
