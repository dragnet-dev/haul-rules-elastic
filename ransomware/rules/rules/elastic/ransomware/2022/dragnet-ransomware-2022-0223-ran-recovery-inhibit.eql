// Dragnet [Ransomware]: dragnet-ransomware-2022-0223 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 1e6e0d84-d270-5b3c-8f73-7ee05b81d57f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
