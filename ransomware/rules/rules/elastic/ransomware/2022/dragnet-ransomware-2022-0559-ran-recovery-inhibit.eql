// Dragnet [Ransomware]: dragnet-ransomware-2022-0559 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: f354227c-c204-5424-9ffe-9fab0156ef2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
