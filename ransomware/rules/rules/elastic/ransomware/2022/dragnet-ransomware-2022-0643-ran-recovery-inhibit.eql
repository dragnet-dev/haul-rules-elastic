// Dragnet [Ransomware]: dragnet-ransomware-2022-0643 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 3e25708b-d109-545b-b877-9a7562fb1d33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
