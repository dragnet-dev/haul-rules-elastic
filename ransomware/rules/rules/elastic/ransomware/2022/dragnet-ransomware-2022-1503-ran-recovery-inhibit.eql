// Dragnet [Ransomware]: dragnet-ransomware-2022-1503 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 13c9f5d7-0eda-5a52-b792-3bf6c2e86023

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
