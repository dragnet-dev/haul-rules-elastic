// Dragnet [Ransomware]: dragnet-ransomware-2022-2173 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 27951475-a194-5159-8cba-8f95f0ddbf82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
