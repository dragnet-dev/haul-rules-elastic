// Dragnet [Ransomware]: dragnet-ransomware-2022-1845 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 47bdc883-71ec-5058-99b2-c9b6cf1dcb73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
