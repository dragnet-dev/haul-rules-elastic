// Dragnet [Ransomware]: dragnet-ransomware-2022-0992 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: de46edb9-1957-5ec4-8eda-0caf1e92b5a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
