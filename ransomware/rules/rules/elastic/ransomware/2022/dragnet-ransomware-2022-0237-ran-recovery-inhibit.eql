// Dragnet [Ransomware]: dragnet-ransomware-2022-0237 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: dc9073eb-a1a6-50be-a162-b49843f64686

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
