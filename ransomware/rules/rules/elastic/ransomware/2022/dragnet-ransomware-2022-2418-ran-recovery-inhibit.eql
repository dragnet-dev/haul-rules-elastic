// Dragnet [Ransomware]: dragnet-ransomware-2022-2418 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 3392bef2-25f0-59ff-98b2-8223e04aea52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
