// Dragnet [Ransomware]: dragnet-ransomware-2022-1344 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: bbaac324-c4a7-57eb-a3fb-54744a637987

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
