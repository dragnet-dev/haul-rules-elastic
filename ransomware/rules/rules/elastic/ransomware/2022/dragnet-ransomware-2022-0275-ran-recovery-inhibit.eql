// Dragnet [Ransomware]: dragnet-ransomware-2022-0275 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 296a430e-c84e-586b-8c63-8576376eac8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
