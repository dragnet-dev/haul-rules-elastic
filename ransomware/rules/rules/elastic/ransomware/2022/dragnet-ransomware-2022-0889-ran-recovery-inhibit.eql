// Dragnet [Ransomware]: dragnet-ransomware-2022-0889 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: b0102f7b-caa4-587f-8bfc-e4737cb8bfd7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
