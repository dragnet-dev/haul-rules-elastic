// Dragnet [Ransomware]: dragnet-ransomware-2022-0673 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c0bb32b1-0075-5e48-b0db-6edec7fca8fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
