// Dragnet [Ransomware]: dragnet-ransomware-2022-2852 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: bf886be7-91af-51fa-a063-76352760f219

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
