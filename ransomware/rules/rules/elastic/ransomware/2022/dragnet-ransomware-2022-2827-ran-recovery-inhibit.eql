// Dragnet [Ransomware]: dragnet-ransomware-2022-2827 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: fd00e058-8081-5a46-8dce-bced6dc2f1d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
