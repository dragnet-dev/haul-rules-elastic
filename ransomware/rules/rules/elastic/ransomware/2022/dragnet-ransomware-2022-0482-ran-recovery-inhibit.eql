// Dragnet [Ransomware]: dragnet-ransomware-2022-0482 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: b5fea0be-d921-5198-b7e4-5a04de40a999

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
