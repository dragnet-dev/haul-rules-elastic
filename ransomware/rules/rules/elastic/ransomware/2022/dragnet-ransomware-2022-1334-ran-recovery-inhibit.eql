// Dragnet [Ransomware]: dragnet-ransomware-2022-1334 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 23400514-303e-5876-a47f-ba3f7f185d93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
