// Dragnet [Ransomware]: dragnet-ransomware-2022-0298 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: aa53c751-ff17-53cc-b6b7-0bcef1d38c05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
