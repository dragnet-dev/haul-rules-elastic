// Dragnet [Ransomware]: dragnet-ransomware-2022-2547 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8160abc3-c902-5653-9e6d-a0893f2ce855

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
