// Dragnet [Ransomware]: dragnet-ransomware-2022-1155 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 2c37d572-8500-5266-b725-71762a2fcc77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
