// Dragnet [Ransomware]: dragnet-ransomware-2022-2909 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 36a3d63b-05aa-5031-9845-6601f9bc5ac7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
