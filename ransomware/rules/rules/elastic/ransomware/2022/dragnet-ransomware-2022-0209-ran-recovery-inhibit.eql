// Dragnet [Ransomware]: dragnet-ransomware-2022-0209 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: b8cf91b5-3460-5840-a827-66fc84b990e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
