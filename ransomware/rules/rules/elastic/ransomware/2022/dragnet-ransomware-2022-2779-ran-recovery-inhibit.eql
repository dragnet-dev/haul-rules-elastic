// Dragnet [Ransomware]: dragnet-ransomware-2022-2779 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 5b937b9c-6ac8-55c9-ac01-561bf68d7d61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
