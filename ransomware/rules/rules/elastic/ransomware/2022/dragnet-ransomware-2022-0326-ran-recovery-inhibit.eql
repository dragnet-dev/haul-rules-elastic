// Dragnet [Ransomware]: dragnet-ransomware-2022-0326 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 3a2db3a3-0c83-5cdd-8681-945818a4e3be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
