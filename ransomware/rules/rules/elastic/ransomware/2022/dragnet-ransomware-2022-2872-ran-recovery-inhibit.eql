// Dragnet [Ransomware]: dragnet-ransomware-2022-2872 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: 4aa51850-eb52-535d-8a76-c4e4e4019d4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
