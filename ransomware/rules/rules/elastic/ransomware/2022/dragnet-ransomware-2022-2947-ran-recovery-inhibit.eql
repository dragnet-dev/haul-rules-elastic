// Dragnet [Ransomware]: dragnet-ransomware-2022-2947 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 2ad6ea30-d279-5d84-b455-43e9c0c16c32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
