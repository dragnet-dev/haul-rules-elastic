// Dragnet [Ransomware]: dragnet-ransomware-2022-0810 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2f8819f1-a217-5548-85fb-d081a48ba481

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
