// Dragnet [Ransomware]: dragnet-ransomware-2022-1105 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 134a3b6e-339f-5ce9-ad3a-711ddbe6ebd1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
