// Dragnet [Ransomware]: dragnet-ransomware-2022-3155 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 24235fa1-f5bf-5273-8056-7d071e16f5d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
