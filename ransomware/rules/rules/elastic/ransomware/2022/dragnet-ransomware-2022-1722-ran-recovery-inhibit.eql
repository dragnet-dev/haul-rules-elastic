// Dragnet [Ransomware]: dragnet-ransomware-2022-1722 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: ab3900f8-7cd8-5d13-ba2d-e7e59396e47b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
