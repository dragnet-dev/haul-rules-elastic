// Dragnet [Ransomware]: dragnet-ransomware-2022-0331 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 3a37f132-394b-5f15-9d1a-028e7460610e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
