// Dragnet [Ransomware]: dragnet-ransomware-2022-1888 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 8397532e-ee73-554e-8827-955c2dd3253a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
