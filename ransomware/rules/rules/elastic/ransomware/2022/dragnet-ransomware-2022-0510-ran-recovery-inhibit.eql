// Dragnet [Ransomware]: dragnet-ransomware-2022-0510 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 34c8f2ff-2412-5b0e-9c12-5f0207ecd5b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
