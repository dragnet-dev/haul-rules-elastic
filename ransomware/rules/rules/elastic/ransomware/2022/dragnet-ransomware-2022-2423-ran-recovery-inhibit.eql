// Dragnet [Ransomware]: dragnet-ransomware-2022-2423 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8a43f466-5f56-5449-8516-970e99caa138

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
