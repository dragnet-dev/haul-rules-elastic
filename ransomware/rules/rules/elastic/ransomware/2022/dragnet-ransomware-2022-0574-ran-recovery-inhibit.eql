// Dragnet [Ransomware]: dragnet-ransomware-2022-0574 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 93d8c833-6fc1-5829-b37a-a7220e87b527

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
