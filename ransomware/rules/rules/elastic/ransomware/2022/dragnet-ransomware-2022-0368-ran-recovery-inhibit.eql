// Dragnet [Ransomware]: dragnet-ransomware-2022-0368 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: a77f7b53-1dfd-51c9-a164-bd20d0def42a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
