// Dragnet [Ransomware]: dragnet-ransomware-2022-2716 — Recovery Inhibition (medusalocker)
// Status: deprecated | Level: high | ID: aca10ba8-bc96-5917-afa3-e48a639db5ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
