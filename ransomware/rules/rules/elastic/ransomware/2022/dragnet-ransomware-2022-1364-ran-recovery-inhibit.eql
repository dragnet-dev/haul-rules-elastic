// Dragnet [Ransomware]: dragnet-ransomware-2022-1364 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 200ad7ed-0fcb-55d0-9678-96bb08e78e16

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
