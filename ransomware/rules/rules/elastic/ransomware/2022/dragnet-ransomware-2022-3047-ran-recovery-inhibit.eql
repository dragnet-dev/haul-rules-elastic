// Dragnet [Ransomware]: dragnet-ransomware-2022-3047 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 82bbe6be-9621-591e-ac9d-1a7c56585f67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
