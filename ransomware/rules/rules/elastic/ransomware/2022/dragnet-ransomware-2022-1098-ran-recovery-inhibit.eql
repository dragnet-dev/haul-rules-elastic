// Dragnet [Ransomware]: dragnet-ransomware-2022-1098 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d7d765c6-8ea9-5234-b327-40de7b653c2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
