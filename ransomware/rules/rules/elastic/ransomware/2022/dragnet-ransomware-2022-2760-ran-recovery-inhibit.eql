// Dragnet [Ransomware]: dragnet-ransomware-2022-2760 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: c081cc52-74e9-5035-8b7b-16485be586f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
