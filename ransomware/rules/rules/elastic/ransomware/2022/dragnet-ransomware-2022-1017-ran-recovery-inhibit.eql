// Dragnet [Ransomware]: dragnet-ransomware-2022-1017 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: aad8f71b-e8bb-57da-a321-91c5bd87aa35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
