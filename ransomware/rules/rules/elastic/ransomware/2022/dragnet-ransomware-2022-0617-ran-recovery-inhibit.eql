// Dragnet [Ransomware]: dragnet-ransomware-2022-0617 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 7b0af87f-47ad-52bd-b728-2d2c1cb8b149

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
