// Dragnet [Ransomware]: dragnet-ransomware-2022-0752 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f3cc4dfe-4cca-5b3e-b60f-7b8ce8772eca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
