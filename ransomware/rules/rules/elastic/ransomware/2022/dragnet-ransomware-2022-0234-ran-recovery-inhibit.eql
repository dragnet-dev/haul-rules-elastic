// Dragnet [Ransomware]: dragnet-ransomware-2022-0234 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 656f057a-26bf-549b-87bb-d8ccb22326d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
