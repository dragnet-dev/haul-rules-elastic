// Dragnet [Ransomware]: dragnet-ransomware-2022-0122 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 172f97e6-6e18-5b5c-8046-24b6e67fd7e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
