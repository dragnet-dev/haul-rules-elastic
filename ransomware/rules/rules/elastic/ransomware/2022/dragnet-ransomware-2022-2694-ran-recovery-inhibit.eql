// Dragnet [Ransomware]: dragnet-ransomware-2022-2694 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4852d293-e7d1-543d-a65d-d81896b6d3e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
