// Dragnet [Ransomware]: dragnet-ransomware-2022-0029 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: eaa05a11-cb94-5854-8ec3-a39bccf68906

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
