// Dragnet [Ransomware]: dragnet-ransomware-2022-2563 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: a0ac6ad3-d630-5fb5-b041-f58ceb1e3ab2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
