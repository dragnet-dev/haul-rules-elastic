// Dragnet [Ransomware]: dragnet-ransomware-2022-2684 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 46d24c99-a36e-5853-a1eb-405e0fabe9f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
