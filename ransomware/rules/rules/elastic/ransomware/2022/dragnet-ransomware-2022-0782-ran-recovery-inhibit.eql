// Dragnet [Ransomware]: dragnet-ransomware-2022-0782 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: b20ab87b-996b-5a23-ad49-a682263e8f04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
