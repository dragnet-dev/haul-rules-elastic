// Dragnet [Ransomware]: dragnet-ransomware-2022-1874 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: 55d3805b-5c5c-5b3a-b9fd-9d40c137675e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
