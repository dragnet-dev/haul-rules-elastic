// Dragnet [Ransomware]: dragnet-ransomware-2022-2462 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8e932a83-81a5-5883-9035-0b57e1abc788

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
