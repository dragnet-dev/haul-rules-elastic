// Dragnet [Ransomware]: dragnet-ransomware-2022-1369 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 1b90c9b2-d876-5ebe-bced-ae8dad2ed25e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
