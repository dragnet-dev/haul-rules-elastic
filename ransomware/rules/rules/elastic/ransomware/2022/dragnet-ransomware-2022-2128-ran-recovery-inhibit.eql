// Dragnet [Ransomware]: dragnet-ransomware-2022-2128 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b8ad427c-3ab3-566c-b07d-0d031c6d943f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
