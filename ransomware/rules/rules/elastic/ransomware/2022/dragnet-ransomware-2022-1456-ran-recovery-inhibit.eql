// Dragnet [Ransomware]: dragnet-ransomware-2022-1456 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 114b6cd1-46a0-515d-8c30-1505898819df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
