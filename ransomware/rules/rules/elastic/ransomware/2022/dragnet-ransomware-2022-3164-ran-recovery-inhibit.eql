// Dragnet [Ransomware]: dragnet-ransomware-2022-3164 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: a214ce91-d073-500b-bb3e-bca3f9b7e7c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
