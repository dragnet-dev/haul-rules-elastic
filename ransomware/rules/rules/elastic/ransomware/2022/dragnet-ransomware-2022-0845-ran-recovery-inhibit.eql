// Dragnet [Ransomware]: dragnet-ransomware-2022-0845 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: b4d5d4b5-c228-5be2-935c-6c48b5d7d769

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
