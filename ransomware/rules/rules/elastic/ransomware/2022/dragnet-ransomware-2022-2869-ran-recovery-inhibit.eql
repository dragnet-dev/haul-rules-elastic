// Dragnet [Ransomware]: dragnet-ransomware-2022-2869 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 71d07148-9003-5f41-b57f-c0f9e111b789

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
