// Dragnet [Ransomware]: dragnet-ransomware-2022-2843 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 7fed20af-96d4-567e-bd1b-002170171cc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
