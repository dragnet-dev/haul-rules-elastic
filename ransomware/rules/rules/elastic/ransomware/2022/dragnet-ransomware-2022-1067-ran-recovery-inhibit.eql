// Dragnet [Ransomware]: dragnet-ransomware-2022-1067 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4565fea2-7e30-5d4f-bfd5-2faaac4b1c12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
