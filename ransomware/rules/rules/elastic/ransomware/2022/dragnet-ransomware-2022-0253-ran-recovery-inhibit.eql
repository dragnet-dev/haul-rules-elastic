// Dragnet [Ransomware]: dragnet-ransomware-2022-0253 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 72b0af75-fe77-5868-863a-a141d59e1754

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
