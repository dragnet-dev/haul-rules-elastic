// Dragnet [Ransomware]: dragnet-ransomware-2022-1410 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 1ec8a294-2519-5c48-8557-99fc33341e3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
