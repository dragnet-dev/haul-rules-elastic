// Dragnet [Ransomware]: dragnet-ransomware-2022-2918 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 17560b3c-0a14-5962-b8e6-bcb8e5687964

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
