// Dragnet [Ransomware]: dragnet-ransomware-2022-0076 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5fdba655-5306-534e-99e3-8e8aef26462f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
