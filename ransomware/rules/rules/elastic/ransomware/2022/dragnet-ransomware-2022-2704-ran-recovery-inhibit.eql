// Dragnet [Ransomware]: dragnet-ransomware-2022-2704 — Recovery Inhibition (bitlocker)
// Status: deprecated | Level: high | ID: 5b47f382-153d-5aae-bc85-01664d1a7e0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
