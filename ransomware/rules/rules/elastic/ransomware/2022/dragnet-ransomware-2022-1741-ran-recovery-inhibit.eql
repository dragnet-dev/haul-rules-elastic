// Dragnet [Ransomware]: dragnet-ransomware-2022-1741 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: ada50f7e-3048-545b-ac55-08b33db865ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
