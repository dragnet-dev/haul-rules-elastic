// Dragnet [Ransomware]: dragnet-ransomware-2022-0828 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d053b42f-ee3a-5ae2-89db-894991688d71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
