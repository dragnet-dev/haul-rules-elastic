// Dragnet [Ransomware]: dragnet-ransomware-2022-0598 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 30a013ee-dd54-5334-955e-4ce222effc45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
