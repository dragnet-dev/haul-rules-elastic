// Dragnet [Ransomware]: dragnet-ransomware-2022-2701 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: f4d1064e-dc16-5fe6-acbb-ff520319fcff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
