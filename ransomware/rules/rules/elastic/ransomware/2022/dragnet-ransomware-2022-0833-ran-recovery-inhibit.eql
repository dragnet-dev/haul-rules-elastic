// Dragnet [Ransomware]: dragnet-ransomware-2022-0833 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e3f682cd-af83-54ed-b7f6-fa686b45284f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
