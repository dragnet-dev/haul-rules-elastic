// Dragnet [Ransomware]: dragnet-ransomware-2022-3165 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 9310cfd8-7c31-5614-8bc6-927e5c6dc625

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
