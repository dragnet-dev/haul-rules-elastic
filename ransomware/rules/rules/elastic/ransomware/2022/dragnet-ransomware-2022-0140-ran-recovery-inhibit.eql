// Dragnet [Ransomware]: dragnet-ransomware-2022-0140 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 931294c7-77dc-59b7-976a-8b8b29309ac0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
