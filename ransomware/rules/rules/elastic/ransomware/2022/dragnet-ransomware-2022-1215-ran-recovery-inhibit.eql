// Dragnet [Ransomware]: dragnet-ransomware-2022-1215 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 30c88a10-6776-5a82-a345-01a379b450d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
