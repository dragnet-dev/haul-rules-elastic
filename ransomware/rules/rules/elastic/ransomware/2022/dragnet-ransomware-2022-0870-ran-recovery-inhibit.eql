// Dragnet [Ransomware]: dragnet-ransomware-2022-0870 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: b030edcc-be0f-5b6f-8a0e-683fbb5fd8c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
