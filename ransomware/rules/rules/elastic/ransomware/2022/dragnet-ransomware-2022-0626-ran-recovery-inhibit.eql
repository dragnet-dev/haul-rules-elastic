// Dragnet [Ransomware]: dragnet-ransomware-2022-0626 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 0e5fdf2e-9c4c-5395-aafa-4840e805c60e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
