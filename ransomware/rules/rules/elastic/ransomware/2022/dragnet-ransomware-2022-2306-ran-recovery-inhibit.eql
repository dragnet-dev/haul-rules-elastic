// Dragnet [Ransomware]: dragnet-ransomware-2022-2306 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 294f4839-ea45-59ff-9b24-5307b33628e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
