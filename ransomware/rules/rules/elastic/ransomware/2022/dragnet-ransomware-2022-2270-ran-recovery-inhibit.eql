// Dragnet [Ransomware]: dragnet-ransomware-2022-2270 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: fa36d74b-1952-513a-95c9-efaec4ab9e3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
