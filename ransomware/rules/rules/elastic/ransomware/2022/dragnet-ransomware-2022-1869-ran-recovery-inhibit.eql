// Dragnet [Ransomware]: dragnet-ransomware-2022-1869 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 860cb4e3-cacb-5c2b-8aea-0f4140e66187

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
