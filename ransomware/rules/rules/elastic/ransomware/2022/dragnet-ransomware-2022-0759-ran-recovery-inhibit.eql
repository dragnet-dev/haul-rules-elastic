// Dragnet [Ransomware]: dragnet-ransomware-2022-0759 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 4aa50869-ee35-5dc0-aece-c488c91c269f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
