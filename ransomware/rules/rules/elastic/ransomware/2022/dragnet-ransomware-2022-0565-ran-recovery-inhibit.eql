// Dragnet [Ransomware]: dragnet-ransomware-2022-0565 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 39a71793-8efb-5b94-b27f-c3926dab3e96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
