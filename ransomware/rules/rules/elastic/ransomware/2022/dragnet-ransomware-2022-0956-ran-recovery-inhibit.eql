// Dragnet [Ransomware]: dragnet-ransomware-2022-0956 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c94fd72e-dea8-5117-b51a-582e82dea2df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
