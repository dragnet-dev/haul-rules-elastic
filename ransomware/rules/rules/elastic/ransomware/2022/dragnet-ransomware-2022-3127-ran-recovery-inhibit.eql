// Dragnet [Ransomware]: dragnet-ransomware-2022-3127 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: 4c2acbd2-374a-5c01-95a4-d28175236da6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
