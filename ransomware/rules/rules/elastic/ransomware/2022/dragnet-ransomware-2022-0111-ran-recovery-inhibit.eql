// Dragnet [Ransomware]: dragnet-ransomware-2022-0111 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: 73e4eb6f-7994-5a6d-81a7-69c1d75cc12e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
