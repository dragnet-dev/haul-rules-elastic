// Dragnet [Ransomware]: dragnet-ransomware-2022-0291 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: fec9097a-96af-59b7-ad3e-966c5fad0b8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
