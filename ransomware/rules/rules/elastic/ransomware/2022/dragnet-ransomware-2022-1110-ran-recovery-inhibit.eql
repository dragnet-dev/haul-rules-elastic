// Dragnet [Ransomware]: dragnet-ransomware-2022-1110 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: b8529864-09fb-574a-9c70-b3eec047a00e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
