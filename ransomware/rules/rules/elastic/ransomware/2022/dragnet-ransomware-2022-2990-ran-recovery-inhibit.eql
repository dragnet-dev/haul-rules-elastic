// Dragnet [Ransomware]: dragnet-ransomware-2022-2990 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 10157bef-15e1-56f8-b989-df15791c3a4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
