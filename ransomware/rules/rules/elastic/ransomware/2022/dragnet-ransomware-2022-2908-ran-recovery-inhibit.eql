// Dragnet [Ransomware]: dragnet-ransomware-2022-2908 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 03fd95ce-7a0f-5e87-9df7-d5805c4f637e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
