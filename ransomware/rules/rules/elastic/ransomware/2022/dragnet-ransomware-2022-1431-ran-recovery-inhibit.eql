// Dragnet [Ransomware]: dragnet-ransomware-2022-1431 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 593af261-c849-5620-a86a-ef4304093a02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
