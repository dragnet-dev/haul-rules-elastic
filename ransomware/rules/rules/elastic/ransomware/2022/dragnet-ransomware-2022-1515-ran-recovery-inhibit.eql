// Dragnet [Ransomware]: dragnet-ransomware-2022-1515 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 47d362b0-5277-5a9a-8b95-ac62108c3040

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
