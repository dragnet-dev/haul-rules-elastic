// Dragnet [Ransomware]: dragnet-ransomware-2022-0959 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: cd2a17ce-6cbe-593d-a969-83482adb35f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
