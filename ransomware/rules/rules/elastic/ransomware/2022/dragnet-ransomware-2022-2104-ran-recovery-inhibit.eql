// Dragnet [Ransomware]: dragnet-ransomware-2022-2104 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 0a780f16-49e5-5e0b-80eb-dd89804fbe68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
