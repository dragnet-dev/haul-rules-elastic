// Dragnet [Ransomware]: dragnet-ransomware-2022-2798 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 85c76253-5258-5ed9-8573-0f853e265b83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
