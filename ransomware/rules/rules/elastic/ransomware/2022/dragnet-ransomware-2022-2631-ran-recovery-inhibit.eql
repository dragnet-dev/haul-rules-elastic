// Dragnet [Ransomware]: dragnet-ransomware-2022-2631 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: cd9f4c20-7e18-5970-b7a7-3d38df0c70bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
