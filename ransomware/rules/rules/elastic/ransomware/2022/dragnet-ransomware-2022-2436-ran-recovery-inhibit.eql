// Dragnet [Ransomware]: dragnet-ransomware-2022-2436 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 8cd6ce0b-0ac0-500a-93b7-93b7389a38b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
