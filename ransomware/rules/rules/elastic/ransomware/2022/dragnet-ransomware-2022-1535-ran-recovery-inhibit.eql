// Dragnet [Ransomware]: dragnet-ransomware-2022-1535 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 6555be49-ee8a-5f7f-bf79-b364f6991460

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
