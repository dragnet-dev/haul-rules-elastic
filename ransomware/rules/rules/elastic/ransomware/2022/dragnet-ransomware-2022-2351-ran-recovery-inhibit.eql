// Dragnet [Ransomware]: dragnet-ransomware-2022-2351 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 45019181-4ab6-58f7-b918-7fade96cb7d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
