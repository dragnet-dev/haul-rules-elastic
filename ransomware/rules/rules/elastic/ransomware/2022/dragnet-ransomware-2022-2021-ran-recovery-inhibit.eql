// Dragnet [Ransomware]: dragnet-ransomware-2022-2021 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 4bd6314a-4f41-52f1-8c6a-0537f9ed89d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
