// Dragnet [Ransomware]: dragnet-ransomware-2022-2562 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: c6e305be-9638-5a2a-a232-8e4a1f42b6d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
