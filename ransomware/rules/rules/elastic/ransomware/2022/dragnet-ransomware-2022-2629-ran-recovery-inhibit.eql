// Dragnet [Ransomware]: dragnet-ransomware-2022-2629 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 0f76db8d-b2d6-5a04-9d40-c4e941248cd0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
