// Dragnet [Ransomware]: dragnet-ransomware-2022-0127 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 65d27448-1e4b-5fe1-aa3d-da3351c6e06d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
