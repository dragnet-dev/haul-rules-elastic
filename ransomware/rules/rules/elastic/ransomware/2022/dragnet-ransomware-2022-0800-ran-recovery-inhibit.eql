// Dragnet [Ransomware]: dragnet-ransomware-2022-0800 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 7dde087d-6173-5d28-a413-5a1699b546ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
