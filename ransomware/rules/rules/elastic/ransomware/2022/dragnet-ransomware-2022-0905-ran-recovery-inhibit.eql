// Dragnet [Ransomware]: dragnet-ransomware-2022-0905 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 3dcf13ad-644b-5f64-ae20-b87401934c91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
