// Dragnet [Ransomware]: dragnet-ransomware-2022-3141 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2dcb3735-23e3-5473-ba58-6faf42b28046

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
