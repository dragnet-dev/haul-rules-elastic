// Dragnet [Ransomware]: dragnet-ransomware-2022-1259 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 517d740c-1553-5855-871f-2dc80b50579e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
