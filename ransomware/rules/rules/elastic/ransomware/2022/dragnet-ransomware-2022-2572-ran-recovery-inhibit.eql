// Dragnet [Ransomware]: dragnet-ransomware-2022-2572 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: e1fdec62-0137-505e-bd2a-69a623735d37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
