// Dragnet [Ransomware]: dragnet-ransomware-2022-0439 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c3760178-e1c5-5402-917c-36da42fdb144

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
