// Dragnet [Ransomware]: dragnet-ransomware-2022-1434 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 430d846d-e132-5ecf-8e9e-10f1cad6dac7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
