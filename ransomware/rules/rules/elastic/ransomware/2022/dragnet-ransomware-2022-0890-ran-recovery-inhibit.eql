// Dragnet [Ransomware]: dragnet-ransomware-2022-0890 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 805d046e-69f4-5186-a7f1-f71f2c30a60b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
