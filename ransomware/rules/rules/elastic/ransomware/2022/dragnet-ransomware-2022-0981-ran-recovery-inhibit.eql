// Dragnet [Ransomware]: dragnet-ransomware-2022-0981 — Recovery Inhibition (leaktheanalyst)
// Status: deprecated | Level: high | ID: 67c795c2-f5a4-5175-a6be-a1ebbb61613a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
