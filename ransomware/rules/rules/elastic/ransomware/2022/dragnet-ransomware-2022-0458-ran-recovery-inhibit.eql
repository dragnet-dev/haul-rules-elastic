// Dragnet [Ransomware]: dragnet-ransomware-2022-0458 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: f8858bce-621e-531d-b81e-9369106e20ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
