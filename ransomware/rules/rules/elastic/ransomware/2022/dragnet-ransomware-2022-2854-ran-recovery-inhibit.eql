// Dragnet [Ransomware]: dragnet-ransomware-2022-2854 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b1d45e62-7d79-5442-9e99-aa4f3806658a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
