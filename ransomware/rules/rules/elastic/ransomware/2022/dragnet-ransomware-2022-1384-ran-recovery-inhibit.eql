// Dragnet [Ransomware]: dragnet-ransomware-2022-1384 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 824fc139-ce69-569f-9e9b-ccdfcff7c484

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
