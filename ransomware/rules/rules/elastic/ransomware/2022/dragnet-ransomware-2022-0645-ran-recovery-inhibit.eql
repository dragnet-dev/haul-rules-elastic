// Dragnet [Ransomware]: dragnet-ransomware-2022-0645 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 321ffb11-1108-59ec-9d73-85325cf717c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
