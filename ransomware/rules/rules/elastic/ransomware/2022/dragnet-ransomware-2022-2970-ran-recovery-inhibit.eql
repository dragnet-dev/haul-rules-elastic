// Dragnet [Ransomware]: dragnet-ransomware-2022-2970 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 5c277571-0827-55b3-b70c-45cf2bb9cec4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
