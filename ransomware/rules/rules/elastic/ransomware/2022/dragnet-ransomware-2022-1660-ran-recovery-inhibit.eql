// Dragnet [Ransomware]: dragnet-ransomware-2022-1660 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 803a0ec0-5b6d-5f57-bd37-8a1350b1a364

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
