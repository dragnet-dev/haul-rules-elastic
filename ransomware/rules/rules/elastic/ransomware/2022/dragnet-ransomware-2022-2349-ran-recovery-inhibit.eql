// Dragnet [Ransomware]: dragnet-ransomware-2022-2349 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a7e2004b-55d3-570f-8d40-ef30097b7e15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
