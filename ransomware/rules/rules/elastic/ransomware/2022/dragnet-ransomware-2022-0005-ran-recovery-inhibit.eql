// Dragnet [Ransomware]: dragnet-ransomware-2022-0005 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a80ad044-8a6e-59d4-a6b1-2f9883f61d21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
