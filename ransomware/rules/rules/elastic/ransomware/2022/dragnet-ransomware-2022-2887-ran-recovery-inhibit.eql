// Dragnet [Ransomware]: dragnet-ransomware-2022-2887 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: b83aab48-0f6c-563f-8d92-fdec08bdf87c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
