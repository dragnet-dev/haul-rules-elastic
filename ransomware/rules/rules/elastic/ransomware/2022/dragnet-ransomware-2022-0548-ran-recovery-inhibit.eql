// Dragnet [Ransomware]: dragnet-ransomware-2022-0548 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 5a7655c3-2cc6-5d17-b394-5a86912cbe07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
