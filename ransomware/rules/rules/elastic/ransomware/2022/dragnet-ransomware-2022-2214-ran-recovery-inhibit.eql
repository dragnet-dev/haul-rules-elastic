// Dragnet [Ransomware]: dragnet-ransomware-2022-2214 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: e2fec164-44e8-57d1-b89f-686384fe9d8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
