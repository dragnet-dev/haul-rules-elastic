// Dragnet [Ransomware]: dragnet-ransomware-2022-2724 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 64da8ec6-081e-5062-8b5e-e8c8b09be91c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
