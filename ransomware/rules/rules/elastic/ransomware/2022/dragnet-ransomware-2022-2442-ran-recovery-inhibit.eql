// Dragnet [Ransomware]: dragnet-ransomware-2022-2442 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 96543595-140c-577c-a1a5-5aa0565a85fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
