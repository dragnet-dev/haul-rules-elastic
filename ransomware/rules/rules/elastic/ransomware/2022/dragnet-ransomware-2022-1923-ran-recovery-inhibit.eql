// Dragnet [Ransomware]: dragnet-ransomware-2022-1923 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 25a0458a-e979-5241-b7a6-9d91a8ceb746

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
