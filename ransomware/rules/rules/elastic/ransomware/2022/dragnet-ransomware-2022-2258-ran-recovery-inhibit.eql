// Dragnet [Ransomware]: dragnet-ransomware-2022-2258 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: f58ce0d3-fa25-5874-b016-2ba1c6f350f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
