// Dragnet [Ransomware]: dragnet-ransomware-2022-2980 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: 7aa72669-7b3f-5d66-817b-c3d718ca7ee1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
