// Dragnet [Ransomware]: dragnet-ransomware-2022-1579 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: e2cb7921-9f53-5f69-a390-57dfa9a6dd3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
