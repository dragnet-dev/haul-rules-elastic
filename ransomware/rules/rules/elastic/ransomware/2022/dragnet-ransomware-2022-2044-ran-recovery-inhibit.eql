// Dragnet [Ransomware]: dragnet-ransomware-2022-2044 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 7c66b01d-243d-5668-bf45-0c05c8abc89b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
