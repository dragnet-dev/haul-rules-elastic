// Dragnet [Ransomware]: dragnet-ransomware-2022-2002 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 741bd029-8d22-581b-a803-b5f2517051ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
