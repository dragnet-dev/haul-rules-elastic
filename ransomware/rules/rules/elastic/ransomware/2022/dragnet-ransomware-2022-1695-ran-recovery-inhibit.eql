// Dragnet [Ransomware]: dragnet-ransomware-2022-1695 — Recovery Inhibition (donutleaks)
// Status: deprecated | Level: high | ID: 3dc24376-3ebb-5184-8443-56e4bacc852e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
