// Dragnet [Ransomware]: dragnet-ransomware-2022-3098 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 11dbae66-e3b7-56ec-8a2f-19814ca871b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
