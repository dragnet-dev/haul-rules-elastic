// Dragnet [Ransomware]: dragnet-ransomware-2022-1748 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a7543803-3335-5973-9588-5b66dbd54956

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
