// Dragnet [Ransomware]: dragnet-ransomware-2022-1586 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 8eab3c20-b3a7-52a5-81ee-9b58a7594002

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
