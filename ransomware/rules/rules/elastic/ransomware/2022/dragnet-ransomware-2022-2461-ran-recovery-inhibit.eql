// Dragnet [Ransomware]: dragnet-ransomware-2022-2461 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: a9ad50a0-0601-5d70-b02d-230a9d2528f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
