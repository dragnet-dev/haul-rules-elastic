// Dragnet [Ransomware]: dragnet-ransomware-2022-1345 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 7b2220c3-87b3-5561-a051-2724118e49dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
