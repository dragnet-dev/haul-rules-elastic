// Dragnet [Ransomware]: dragnet-ransomware-2022-1703 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 48a3e58c-b41a-599b-99e8-4a7a799473bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
