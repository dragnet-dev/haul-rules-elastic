// Dragnet [Ransomware]: dragnet-ransomware-2022-2523 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 9073f7de-82db-5642-a393-254782c7f67f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
