// Dragnet [Ransomware]: dragnet-ransomware-2022-2216 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 165dbede-8d0e-542e-901c-936cd640396b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
