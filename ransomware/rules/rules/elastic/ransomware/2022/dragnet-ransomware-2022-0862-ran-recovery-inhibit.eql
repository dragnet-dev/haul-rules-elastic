// Dragnet [Ransomware]: dragnet-ransomware-2022-0862 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: ffa1e68a-9f32-53c3-bf40-6f072e03e849

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
