// Dragnet [Ransomware]: dragnet-ransomware-2022-2384 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ea54b165-5ae4-5d46-91b2-f6f4c1fc08f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
