// Dragnet [Ransomware]: dragnet-ransomware-2022-0717 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 3d440934-78a2-5804-85ab-9fa0f3947111

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
