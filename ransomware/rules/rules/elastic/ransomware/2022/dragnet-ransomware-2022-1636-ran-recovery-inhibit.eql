// Dragnet [Ransomware]: dragnet-ransomware-2022-1636 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 1438576a-7444-578c-a184-d7ce75445d0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
