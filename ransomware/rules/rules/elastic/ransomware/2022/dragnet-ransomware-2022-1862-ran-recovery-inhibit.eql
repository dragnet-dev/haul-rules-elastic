// Dragnet [Ransomware]: dragnet-ransomware-2022-1862 — Recovery Inhibition (onyx)
// Status: deprecated | Level: high | ID: fde88172-8182-5e70-822a-c8613cbed4c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
