// Dragnet [Ransomware]: dragnet-ransomware-2022-2983 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: 4ab31431-3b18-5bf0-b785-999cab57f32b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
