// Dragnet [Ransomware]: dragnet-ransomware-2022-1763 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 5b2b6bf8-acbf-5b7c-b2af-8a79f22d8902

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
