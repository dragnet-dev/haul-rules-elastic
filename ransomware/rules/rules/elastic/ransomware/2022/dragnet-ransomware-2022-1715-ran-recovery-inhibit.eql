// Dragnet [Ransomware]: dragnet-ransomware-2022-1715 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 06144a4f-68f5-5a56-937d-171649434396

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
