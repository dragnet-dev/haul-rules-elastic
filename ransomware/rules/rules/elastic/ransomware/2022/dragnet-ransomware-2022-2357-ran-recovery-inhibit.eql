// Dragnet [Ransomware]: dragnet-ransomware-2022-2357 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 109df652-d165-5010-871c-c571d9887c9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
