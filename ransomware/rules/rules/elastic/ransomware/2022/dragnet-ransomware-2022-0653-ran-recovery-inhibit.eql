// Dragnet [Ransomware]: dragnet-ransomware-2022-0653 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 637d237b-5dff-5f7d-9fec-b392301167d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
