// Dragnet [Ransomware]: dragnet-ransomware-2022-2165 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: f74ffde1-446f-5c0b-817b-5595ad38866e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
