// Dragnet [Ransomware]: dragnet-ransomware-2022-1210 — Recovery Inhibition (yanluowang)
// Status: deprecated | Level: high | ID: c18ec558-af48-5d12-869c-0034cda64a2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
