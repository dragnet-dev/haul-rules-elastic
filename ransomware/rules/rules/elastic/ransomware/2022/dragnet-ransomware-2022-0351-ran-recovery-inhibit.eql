// Dragnet [Ransomware]: dragnet-ransomware-2022-0351 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 22966809-339c-550e-b38d-d2011e8ccad2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
