// Dragnet [Ransomware]: dragnet-ransomware-2022-0181 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: b8a374c0-6cfd-5b1f-8aa6-ed3e782adaef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
