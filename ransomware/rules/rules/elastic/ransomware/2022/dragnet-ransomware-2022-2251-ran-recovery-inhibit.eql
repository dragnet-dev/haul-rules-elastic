// Dragnet [Ransomware]: dragnet-ransomware-2022-2251 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 7e69318f-c186-5956-8054-be09b6b757a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
