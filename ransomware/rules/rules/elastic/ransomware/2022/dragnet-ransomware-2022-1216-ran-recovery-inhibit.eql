// Dragnet [Ransomware]: dragnet-ransomware-2022-1216 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d2ae9210-f5de-5a6d-b4fe-60120f332b9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
