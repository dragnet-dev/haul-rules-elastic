// Dragnet [Ransomware]: dragnet-ransomware-2022-2252 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0ad61a5d-4cea-5a04-b47a-8a2a32d31956

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
