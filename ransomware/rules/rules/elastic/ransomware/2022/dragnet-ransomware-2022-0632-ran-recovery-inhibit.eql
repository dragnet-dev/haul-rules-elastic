// Dragnet [Ransomware]: dragnet-ransomware-2022-0632 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 676c80cd-c8d7-523c-8f52-e5eaa22f1ec9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
