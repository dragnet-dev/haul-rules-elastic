// Dragnet [Ransomware]: dragnet-ransomware-2022-2832 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: ea1a42f7-e5bd-5de2-840b-d2fa95acc066

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
