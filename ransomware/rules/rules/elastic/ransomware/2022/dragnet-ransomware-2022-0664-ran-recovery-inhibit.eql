// Dragnet [Ransomware]: dragnet-ransomware-2022-0664 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 40b62714-8894-5897-abae-2a65f5bf3b6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
