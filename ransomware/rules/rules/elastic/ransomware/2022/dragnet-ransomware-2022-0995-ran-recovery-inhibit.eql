// Dragnet [Ransomware]: dragnet-ransomware-2022-0995 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 26e2a507-fad8-58b3-83c7-dca61f2f4c7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
