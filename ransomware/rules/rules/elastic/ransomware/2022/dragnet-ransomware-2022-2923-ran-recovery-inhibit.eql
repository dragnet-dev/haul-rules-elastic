// Dragnet [Ransomware]: dragnet-ransomware-2022-2923 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: e173dd61-9353-5857-a27a-877c12696ff3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
