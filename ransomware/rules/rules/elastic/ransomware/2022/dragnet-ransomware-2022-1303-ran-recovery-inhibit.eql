// Dragnet [Ransomware]: dragnet-ransomware-2022-1303 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 694f2e93-a62f-5713-80e7-f7d8294160a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
