// Dragnet [Ransomware]: dragnet-ransomware-2022-2800 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 70db3722-c9f6-5015-b0f7-e2b1eef9562f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
