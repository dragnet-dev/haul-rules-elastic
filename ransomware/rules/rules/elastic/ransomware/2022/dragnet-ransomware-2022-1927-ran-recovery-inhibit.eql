// Dragnet [Ransomware]: dragnet-ransomware-2022-1927 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0143bb66-55fe-5491-8660-13ca60fe3640

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
