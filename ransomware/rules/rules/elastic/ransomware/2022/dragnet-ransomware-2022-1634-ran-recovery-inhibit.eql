// Dragnet [Ransomware]: dragnet-ransomware-2022-1634 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 3c210946-4c32-5ae1-aee5-bd5e86f3796d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
