// Dragnet [Ransomware]: dragnet-ransomware-2022-2683 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 53066bbe-72a6-5f1d-ba7e-fea2ee031d32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
