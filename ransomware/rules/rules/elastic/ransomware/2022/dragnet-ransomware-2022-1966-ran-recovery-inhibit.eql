// Dragnet [Ransomware]: dragnet-ransomware-2022-1966 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 8f18f688-848a-51be-8630-0777592d5a1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
