// Dragnet [Ransomware]: dragnet-ransomware-2022-2907 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e1e1446e-6e03-59b3-824e-bfd3a0021dd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
