// Dragnet [Ransomware]: dragnet-ransomware-2022-1052 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: 7ff4831a-7fcb-572d-b3b2-9f19e5f4bebb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
