// Dragnet [Ransomware]: dragnet-ransomware-2022-0716 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 4c89045d-b942-5d81-8f13-fb12340cbb09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
