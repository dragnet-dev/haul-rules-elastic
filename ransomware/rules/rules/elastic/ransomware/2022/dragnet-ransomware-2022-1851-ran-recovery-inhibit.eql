// Dragnet [Ransomware]: dragnet-ransomware-2022-1851 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: bf64f34a-21b4-52e8-bf13-ed1d8a0a76b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
