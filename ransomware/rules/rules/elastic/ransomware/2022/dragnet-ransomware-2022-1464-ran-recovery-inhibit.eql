// Dragnet [Ransomware]: dragnet-ransomware-2022-1464 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 16c486d8-4f25-5fc6-bee3-0211b597950b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
