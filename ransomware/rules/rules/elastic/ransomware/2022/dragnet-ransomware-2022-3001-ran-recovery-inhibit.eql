// Dragnet [Ransomware]: dragnet-ransomware-2022-3001 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: f90f070d-8bf5-5077-8be8-63513f784f86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
