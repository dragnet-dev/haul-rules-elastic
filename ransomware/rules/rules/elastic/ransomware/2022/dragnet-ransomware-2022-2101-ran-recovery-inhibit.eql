// Dragnet [Ransomware]: dragnet-ransomware-2022-2101 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 40eaa4ed-886a-572a-879e-dc3288f97064

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
