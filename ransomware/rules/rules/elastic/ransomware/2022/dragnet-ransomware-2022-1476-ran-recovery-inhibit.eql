// Dragnet [Ransomware]: dragnet-ransomware-2022-1476 — Recovery Inhibition (redalert)
// Status: deprecated | Level: high | ID: 9efc7e2b-0fdc-5a87-941a-e0dd2dcc79c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
