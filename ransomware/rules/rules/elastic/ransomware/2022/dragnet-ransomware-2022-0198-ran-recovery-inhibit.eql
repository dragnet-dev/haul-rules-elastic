// Dragnet [Ransomware]: dragnet-ransomware-2022-0198 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 364c3684-d786-58af-ad3c-df0748fb7599

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
