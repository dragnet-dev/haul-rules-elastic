// Dragnet [Ransomware]: dragnet-ransomware-2022-0481 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c41ca140-54c2-5f46-99d0-6567285db3bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
