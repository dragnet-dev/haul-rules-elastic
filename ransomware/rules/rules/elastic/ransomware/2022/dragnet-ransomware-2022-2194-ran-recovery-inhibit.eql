// Dragnet [Ransomware]: dragnet-ransomware-2022-2194 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a6a3e307-5250-58d0-b210-8d66a7dc2244

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
