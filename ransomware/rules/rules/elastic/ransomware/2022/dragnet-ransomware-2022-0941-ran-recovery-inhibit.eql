// Dragnet [Ransomware]: dragnet-ransomware-2022-0941 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: fd7c294c-79ec-5094-a94d-7fbc3432c3c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
