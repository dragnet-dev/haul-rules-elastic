// Dragnet [Ransomware]: dragnet-ransomware-2022-1168 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 4ce01d1e-b310-5626-925a-686bed081787

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
