// Dragnet [Ransomware]: dragnet-ransomware-2022-2600 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: 1af34d3e-3d2c-55a8-a634-ef61caf1fced

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
