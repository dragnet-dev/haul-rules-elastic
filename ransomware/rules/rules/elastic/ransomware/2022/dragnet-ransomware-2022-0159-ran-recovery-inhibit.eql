// Dragnet [Ransomware]: dragnet-ransomware-2022-0159 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 33c1009f-7572-5acc-9d3e-5b936e33cd55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
