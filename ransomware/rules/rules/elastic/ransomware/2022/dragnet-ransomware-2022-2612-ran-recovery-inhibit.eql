// Dragnet [Ransomware]: dragnet-ransomware-2022-2612 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 1114cb95-deb7-5326-8ea6-b6bd0786f6a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
