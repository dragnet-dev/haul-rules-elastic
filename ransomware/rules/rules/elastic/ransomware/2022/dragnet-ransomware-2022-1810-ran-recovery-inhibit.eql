// Dragnet [Ransomware]: dragnet-ransomware-2022-1810 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 7c7a39f9-b4e5-5d73-b2f0-b7e750ee1134

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
