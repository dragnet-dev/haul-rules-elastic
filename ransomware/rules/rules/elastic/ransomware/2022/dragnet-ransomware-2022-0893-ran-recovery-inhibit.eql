// Dragnet [Ransomware]: dragnet-ransomware-2022-0893 — Recovery Inhibition (medusalocker)
// Status: deprecated | Level: high | ID: 434bd617-5116-5d95-a1d9-6d3dad844bab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
