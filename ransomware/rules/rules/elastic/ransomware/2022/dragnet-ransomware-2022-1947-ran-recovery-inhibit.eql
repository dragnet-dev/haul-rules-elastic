// Dragnet [Ransomware]: dragnet-ransomware-2022-1947 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: b16a3858-85dc-5af5-9d37-61a760063d2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
