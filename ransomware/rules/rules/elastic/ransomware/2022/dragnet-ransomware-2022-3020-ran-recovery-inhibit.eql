// Dragnet [Ransomware]: dragnet-ransomware-2022-3020 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: d4818445-a732-5cde-9e3c-78ed9bdebdec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
