// Dragnet [Ransomware]: dragnet-ransomware-2022-2580 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 9bd8443b-b068-5699-b837-b535f9baa330

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
