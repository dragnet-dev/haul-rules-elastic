// Dragnet [Ransomware]: dragnet-ransomware-2022-2228 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 49282a16-a219-5502-a72f-c11e79a99001

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
