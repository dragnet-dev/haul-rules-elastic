// Dragnet [Ransomware]: dragnet-ransomware-2022-1788 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8fd35e99-2c8c-52a4-8581-850870d1ab71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
