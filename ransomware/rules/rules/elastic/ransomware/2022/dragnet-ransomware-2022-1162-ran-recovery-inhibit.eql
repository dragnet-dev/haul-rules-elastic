// Dragnet [Ransomware]: dragnet-ransomware-2022-1162 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: aa544be1-e77c-5d9b-9b16-a3d419cc355d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
