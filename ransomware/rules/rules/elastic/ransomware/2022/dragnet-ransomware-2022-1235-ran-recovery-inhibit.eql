// Dragnet [Ransomware]: dragnet-ransomware-2022-1235 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: afbdb081-daf9-5a12-afae-066d26b4b9a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
