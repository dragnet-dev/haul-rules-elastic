// Dragnet [Ransomware]: dragnet-ransomware-2022-0639 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 16575285-db64-502f-b444-13ac00afeef9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
