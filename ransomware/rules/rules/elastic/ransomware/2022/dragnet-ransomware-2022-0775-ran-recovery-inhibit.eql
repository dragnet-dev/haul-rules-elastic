// Dragnet [Ransomware]: dragnet-ransomware-2022-0775 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: a0d8af9f-0167-5fe7-9d3f-d14379bb782e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
