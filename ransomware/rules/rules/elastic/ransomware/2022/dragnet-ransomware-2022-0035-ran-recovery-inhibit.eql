// Dragnet [Ransomware]: dragnet-ransomware-2022-0035 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: ed9ea7c5-73ae-5c13-aa7e-5726ef38690b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
