// Dragnet [Ransomware]: dragnet-ransomware-2022-2717 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 58b0e9cf-63f9-59a5-837e-26b4c9899c53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
