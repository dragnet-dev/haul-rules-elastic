// Dragnet [Ransomware]: dragnet-ransomware-2022-1637 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 2adf61ec-9098-5f3f-b874-791397793c6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
