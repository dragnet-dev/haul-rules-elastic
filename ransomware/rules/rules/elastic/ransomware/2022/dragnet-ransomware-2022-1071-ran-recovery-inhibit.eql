// Dragnet [Ransomware]: dragnet-ransomware-2022-1071 — Recovery Inhibition (sabbath)
// Status: deprecated | Level: high | ID: c452547e-bea1-5cce-bff1-9bd94170f2fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
