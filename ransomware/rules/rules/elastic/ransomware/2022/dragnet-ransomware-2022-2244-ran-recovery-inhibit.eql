// Dragnet [Ransomware]: dragnet-ransomware-2022-2244 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 525fb51d-120c-5a4c-9d6c-5b48322cf80f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
