// Dragnet [Ransomware]: dragnet-ransomware-2022-2506 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: fe437320-4c4e-51c7-9817-49317667985a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
