// Dragnet [Ransomware]: dragnet-ransomware-2022-3044 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 34cdb9ca-9504-503b-a676-005ffa0a4286

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
