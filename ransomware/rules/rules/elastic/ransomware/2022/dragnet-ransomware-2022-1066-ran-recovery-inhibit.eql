// Dragnet [Ransomware]: dragnet-ransomware-2022-1066 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: afe30faf-ea74-5248-b675-5f88732ff168

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
