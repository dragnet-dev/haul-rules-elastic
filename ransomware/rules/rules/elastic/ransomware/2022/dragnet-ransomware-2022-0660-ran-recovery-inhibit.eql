// Dragnet [Ransomware]: dragnet-ransomware-2022-0660 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: c9543faa-858c-50fe-99d8-3792d5398955

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
