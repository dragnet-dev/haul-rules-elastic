// Dragnet [Ransomware]: dragnet-ransomware-2022-0786 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 24847b16-33a3-5fc4-9852-2e6187b8dab8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
