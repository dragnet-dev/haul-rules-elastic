// Dragnet [Ransomware]: dragnet-ransomware-2022-2925 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 858a550b-2e05-570f-b805-a02ccc8b37d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
