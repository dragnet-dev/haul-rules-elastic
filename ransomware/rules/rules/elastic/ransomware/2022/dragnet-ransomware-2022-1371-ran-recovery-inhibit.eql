// Dragnet [Ransomware]: dragnet-ransomware-2022-1371 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 4760cf72-9e4f-5043-bcb8-6d6310969c72

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
