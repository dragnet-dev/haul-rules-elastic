// Dragnet [Ransomware]: dragnet-ransomware-2022-2507 — Recovery Inhibition (icefire)
// Status: deprecated | Level: high | ID: 1efed6df-70da-58be-92f1-2aea2e834171

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
