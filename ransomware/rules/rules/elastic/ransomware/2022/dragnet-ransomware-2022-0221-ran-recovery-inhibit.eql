// Dragnet [Ransomware]: dragnet-ransomware-2022-0221 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 7cfdec78-66fe-5316-94b9-ecca34fa8e72

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
