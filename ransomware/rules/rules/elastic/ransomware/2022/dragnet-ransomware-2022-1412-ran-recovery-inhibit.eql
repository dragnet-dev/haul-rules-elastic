// Dragnet [Ransomware]: dragnet-ransomware-2022-1412 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: f9161310-626e-5f71-94c8-890fdf1f1e7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
