// Dragnet [Ransomware]: dragnet-ransomware-2022-1576 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: a3bb2214-969e-5c0c-a0a2-ff492bab5be9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
