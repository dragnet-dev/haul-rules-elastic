// Dragnet [Ransomware]: dragnet-ransomware-2022-2274 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: 08374051-6461-5f7e-b8ef-d0ec1a93b9ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
