// Dragnet [Ransomware]: dragnet-ransomware-2022-1006 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: df915138-f251-5316-a40a-ea1652257a3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
