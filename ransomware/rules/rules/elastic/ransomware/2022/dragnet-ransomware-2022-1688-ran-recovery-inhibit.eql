// Dragnet [Ransomware]: dragnet-ransomware-2022-1688 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 5d7d82f3-9098-544d-b961-c95651a9d05a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
