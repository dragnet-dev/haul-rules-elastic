// Dragnet [Ransomware]: dragnet-ransomware-2022-3027 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 7d20ef5f-54fa-5d29-ba6f-c5941145bc23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
