// Dragnet [Ransomware]: dragnet-ransomware-2022-2448 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 259a8e17-cb5c-56da-a1bd-856376131f37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
