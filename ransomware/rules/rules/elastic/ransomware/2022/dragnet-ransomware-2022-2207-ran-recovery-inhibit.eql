// Dragnet [Ransomware]: dragnet-ransomware-2022-2207 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 924d00e8-6199-56c7-9160-83c2ebd7d1e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
