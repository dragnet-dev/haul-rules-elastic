// Dragnet [Ransomware]: dragnet-ransomware-2022-2625 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2f552c98-ddda-59e5-8bc9-4c73eb04c9fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
