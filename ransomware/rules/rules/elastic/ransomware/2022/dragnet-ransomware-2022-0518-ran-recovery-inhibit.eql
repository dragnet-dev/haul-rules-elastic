// Dragnet [Ransomware]: dragnet-ransomware-2022-0518 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 5328e672-3c21-59b4-8a97-9230c1d889df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
