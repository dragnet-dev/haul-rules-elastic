// Dragnet [Ransomware]: dragnet-ransomware-2022-1904 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 9c0b8333-a182-5dda-bb30-de9f35ceea97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
