// Dragnet [Ransomware]: dragnet-ransomware-2022-1281 — Recovery Inhibition (donutleaks)
// Status: deprecated | Level: high | ID: 38296ee4-f738-573a-b6a7-96da3d755123

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
