// Dragnet [Ransomware]: dragnet-ransomware-2022-2089 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: c0b698a5-44a3-5790-9dd1-f77eb882296c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
