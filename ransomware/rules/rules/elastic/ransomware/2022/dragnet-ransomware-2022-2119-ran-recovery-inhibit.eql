// Dragnet [Ransomware]: dragnet-ransomware-2022-2119 — Recovery Inhibition (mindware)
// Status: deprecated | Level: high | ID: a00b3d1a-2245-55c4-b2d7-caf9ef11945a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
