// Dragnet [Ransomware]: dragnet-ransomware-2022-1108 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 4181f535-8d7b-5114-a26f-a7aa160676c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
