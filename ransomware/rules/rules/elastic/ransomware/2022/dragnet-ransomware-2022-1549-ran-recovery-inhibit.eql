// Dragnet [Ransomware]: dragnet-ransomware-2022-1549 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: fbcbd563-6ccd-5b66-8170-e4fc4efe20fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
