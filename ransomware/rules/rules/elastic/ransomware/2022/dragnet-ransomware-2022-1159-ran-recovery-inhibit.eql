// Dragnet [Ransomware]: dragnet-ransomware-2022-1159 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: bbb4c343-5089-5261-bbc9-818bea6e1440

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
