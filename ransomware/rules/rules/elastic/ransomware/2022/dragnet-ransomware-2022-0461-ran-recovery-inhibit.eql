// Dragnet [Ransomware]: dragnet-ransomware-2022-0461 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 2715587c-6b73-541b-813e-38e7c13ff2cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
