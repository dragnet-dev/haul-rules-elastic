// Dragnet [Ransomware]: dragnet-ransomware-2022-0040 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 221f7a96-dfdd-5286-b429-5bc29ed9afed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
