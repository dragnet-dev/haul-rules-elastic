// Dragnet [Ransomware]: dragnet-ransomware-2022-1376 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 12a4d7dd-5b94-58ac-a49d-42a28e487b01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
