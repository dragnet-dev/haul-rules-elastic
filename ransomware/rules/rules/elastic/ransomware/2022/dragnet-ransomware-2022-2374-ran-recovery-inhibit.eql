// Dragnet [Ransomware]: dragnet-ransomware-2022-2374 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 012ef1da-bca0-5172-9951-3dc087e6903b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
