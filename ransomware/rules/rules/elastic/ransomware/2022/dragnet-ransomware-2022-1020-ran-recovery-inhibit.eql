// Dragnet [Ransomware]: dragnet-ransomware-2022-1020 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: f706ba46-11f9-5330-9176-2da6f11c91d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
