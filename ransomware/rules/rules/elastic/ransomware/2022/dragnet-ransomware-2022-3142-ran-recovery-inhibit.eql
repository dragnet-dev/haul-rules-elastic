// Dragnet [Ransomware]: dragnet-ransomware-2022-3142 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c22cf94c-027e-5123-a1f2-29a47f30db91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
