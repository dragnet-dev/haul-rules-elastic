// Dragnet [Ransomware]: dragnet-ransomware-2022-0646 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: a1d0583b-cd47-51fe-850f-60d780941f5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
