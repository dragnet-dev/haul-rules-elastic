// Dragnet [Ransomware]: dragnet-ransomware-2022-1189 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: d11ee89b-2cd0-5672-9c10-f160b6cf5fef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
