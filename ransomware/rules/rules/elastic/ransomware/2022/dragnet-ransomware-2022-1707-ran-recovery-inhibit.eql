// Dragnet [Ransomware]: dragnet-ransomware-2022-1707 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: ce904134-75c6-5821-a3f1-4d34ebfee841

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
