// Dragnet [Ransomware]: dragnet-ransomware-2022-0768 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 074f7e9f-7f01-5376-9598-b4f255befd35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
