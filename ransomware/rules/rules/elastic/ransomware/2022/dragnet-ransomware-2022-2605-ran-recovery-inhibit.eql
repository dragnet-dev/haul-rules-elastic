// Dragnet [Ransomware]: dragnet-ransomware-2022-2605 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 45fa9686-a23d-535f-a80d-bddcf017d8bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
