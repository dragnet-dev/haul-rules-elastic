// Dragnet [Ransomware]: dragnet-ransomware-2022-1116 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 887c66ba-d5ee-5727-86dd-125df6e4caf5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
