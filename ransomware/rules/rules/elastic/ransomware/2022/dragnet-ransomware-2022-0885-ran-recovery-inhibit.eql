// Dragnet [Ransomware]: dragnet-ransomware-2022-0885 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 35d5fe66-a811-5a02-9639-36e0da6527a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
