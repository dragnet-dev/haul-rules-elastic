// Dragnet [Ransomware]: dragnet-ransomware-2022-1311 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 26a34a57-14fd-5445-9f39-19bd68d96a50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
