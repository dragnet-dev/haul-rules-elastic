// Dragnet [Ransomware]: dragnet-ransomware-2022-2114 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 7575f158-ad01-531f-aef2-a2931f45d192

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
