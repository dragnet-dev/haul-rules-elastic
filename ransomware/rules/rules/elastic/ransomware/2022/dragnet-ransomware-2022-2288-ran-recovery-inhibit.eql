// Dragnet [Ransomware]: dragnet-ransomware-2022-2288 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 29d24e9e-1760-593b-a753-7a842a4b2ccc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
