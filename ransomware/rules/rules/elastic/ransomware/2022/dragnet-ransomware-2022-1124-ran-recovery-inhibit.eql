// Dragnet [Ransomware]: dragnet-ransomware-2022-1124 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 02450734-f855-5d79-9955-d0d62a52d5fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
