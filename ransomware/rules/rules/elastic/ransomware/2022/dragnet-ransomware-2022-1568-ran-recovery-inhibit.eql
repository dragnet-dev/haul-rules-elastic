// Dragnet [Ransomware]: dragnet-ransomware-2022-1568 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 9926a393-be75-55f8-90b1-4f27a85ae86a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
