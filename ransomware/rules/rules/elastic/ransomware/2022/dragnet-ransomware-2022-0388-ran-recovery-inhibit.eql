// Dragnet [Ransomware]: dragnet-ransomware-2022-0388 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 6d45851e-1535-5d09-8595-5fed95cdd328

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
