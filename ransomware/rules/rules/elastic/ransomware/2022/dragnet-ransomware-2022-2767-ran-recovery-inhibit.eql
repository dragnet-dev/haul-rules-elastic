// Dragnet [Ransomware]: dragnet-ransomware-2022-2767 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: b678186f-ac97-55e8-b520-b0856ca06b53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
