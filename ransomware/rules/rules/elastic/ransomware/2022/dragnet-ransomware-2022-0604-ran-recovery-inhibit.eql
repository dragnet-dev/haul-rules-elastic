// Dragnet [Ransomware]: dragnet-ransomware-2022-0604 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 4689f79b-2127-5ea5-9d4c-18e877fd5eac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
