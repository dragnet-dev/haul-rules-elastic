// Dragnet [Ransomware]: dragnet-ransomware-2022-0377 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 9b616022-b17f-5189-82d4-0ce4e17d427a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
