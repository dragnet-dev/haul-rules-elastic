// Dragnet [Ransomware]: dragnet-ransomware-2022-0405 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 10a59074-a054-5535-bf9b-84754a41088b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
