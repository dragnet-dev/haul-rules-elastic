// Dragnet [Ransomware]: dragnet-ransomware-2022-2239 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: c57a3d42-3e89-5bda-91e0-f6b60e48f5c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
