// Dragnet [Ransomware]: dragnet-ransomware-2022-0487 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 0a7e27ca-1389-5684-974e-baa45255c423

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
