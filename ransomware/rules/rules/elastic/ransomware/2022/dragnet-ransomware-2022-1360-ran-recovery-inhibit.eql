// Dragnet [Ransomware]: dragnet-ransomware-2022-1360 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: ab279ac2-a016-5a89-9089-3e1eca256ec1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
