// Dragnet [Ransomware]: dragnet-ransomware-2022-1829 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 144c9d94-b7a4-504d-840d-101efb28b8d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
