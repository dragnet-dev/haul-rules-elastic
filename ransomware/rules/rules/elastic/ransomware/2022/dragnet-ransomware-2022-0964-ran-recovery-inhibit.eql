// Dragnet [Ransomware]: dragnet-ransomware-2022-0964 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: db55a8c6-d8a2-56ce-a155-722820ebd287

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
