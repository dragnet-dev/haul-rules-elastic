// Dragnet [Ransomware]: dragnet-ransomware-2022-0238 — Recovery Inhibition (leaktheanalyst)
// Status: deprecated | Level: high | ID: e9f0be7d-be07-5829-8c40-bb8a9fa7b919

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
