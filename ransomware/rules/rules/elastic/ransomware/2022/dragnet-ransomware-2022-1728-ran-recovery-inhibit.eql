// Dragnet [Ransomware]: dragnet-ransomware-2022-1728 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 7572311d-8878-53fb-b8cc-5081d3d9e894

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
