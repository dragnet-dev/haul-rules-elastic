// Dragnet [Ransomware]: dragnet-ransomware-2022-1787 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 70b8bdf3-b3a2-559c-8d41-f4cd5bc05aa1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
