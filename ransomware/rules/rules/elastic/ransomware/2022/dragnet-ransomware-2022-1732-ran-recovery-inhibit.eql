// Dragnet [Ransomware]: dragnet-ransomware-2022-1732 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: eabfe5ae-6f79-5b80-ad31-a044bc37416a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
