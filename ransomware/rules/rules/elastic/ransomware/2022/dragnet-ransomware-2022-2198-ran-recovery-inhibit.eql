// Dragnet [Ransomware]: dragnet-ransomware-2022-2198 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 198d58d2-b941-5461-b917-268c75c983e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
