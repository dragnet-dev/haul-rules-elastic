// Dragnet [Ransomware]: dragnet-ransomware-2022-0513 — Recovery Inhibition (cheers)
// Status: deprecated | Level: high | ID: d26923f8-eaa7-5840-9e1d-c89bc5afac8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
