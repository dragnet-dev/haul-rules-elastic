// Dragnet [Ransomware]: dragnet-ransomware-2022-1777 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 8f696201-4685-5c89-8ddf-a4f9ae93f90f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
