// Dragnet [Ransomware]: dragnet-ransomware-2022-2100 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 59f9e6bf-e3b1-58c1-acc8-4e5af19808bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
