// Dragnet [Ransomware]: dragnet-ransomware-2022-2790 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: 9a798f4c-dd22-5409-b147-3a770ed2f004

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
