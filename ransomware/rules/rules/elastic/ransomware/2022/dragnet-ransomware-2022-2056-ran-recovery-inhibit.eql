// Dragnet [Ransomware]: dragnet-ransomware-2022-2056 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 6987ecd0-56f4-508a-8f84-dc4555e421c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
