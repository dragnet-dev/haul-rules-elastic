// Dragnet [Ransomware]: dragnet-ransomware-2022-0219 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 8fcf1e87-07ef-5357-9ca8-d3b030509e49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
