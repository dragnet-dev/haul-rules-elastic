// Dragnet [Ransomware]: dragnet-ransomware-2022-0440 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6fcdbcb6-c7fd-58d9-a18c-a38bd78737a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
