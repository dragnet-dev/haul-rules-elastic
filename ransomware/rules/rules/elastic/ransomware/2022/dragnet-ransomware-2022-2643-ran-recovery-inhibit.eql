// Dragnet [Ransomware]: dragnet-ransomware-2022-2643 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 29adbd89-30b1-5baa-8ee2-964ca91549c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
