// Dragnet [Ransomware]: dragnet-ransomware-2022-1932 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: ed8605f1-9037-52cf-83ce-f7bd7f2cdf3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
