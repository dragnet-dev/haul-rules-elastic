// Dragnet [Ransomware]: dragnet-ransomware-2022-0715 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 90abcdd6-95cc-58cd-86b8-e49f3950857b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
