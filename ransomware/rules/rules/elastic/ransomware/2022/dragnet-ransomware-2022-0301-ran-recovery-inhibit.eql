// Dragnet [Ransomware]: dragnet-ransomware-2022-0301 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: d5f09f31-15ae-572b-b615-9b39c55150ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
