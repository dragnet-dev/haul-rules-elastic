// Dragnet [Ransomware]: dragnet-ransomware-2022-0647 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 532b43b8-a267-570b-92fa-69955cf6b7c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
