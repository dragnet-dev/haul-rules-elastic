// Dragnet [Ransomware]: dragnet-ransomware-2022-2568 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c55f0503-6a2c-5caf-9425-8c9e44a2d87c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
