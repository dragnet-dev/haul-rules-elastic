// Dragnet [Ransomware]: dragnet-ransomware-2022-2916 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3a5deb1a-4f55-5395-a4db-1d5005559a06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
