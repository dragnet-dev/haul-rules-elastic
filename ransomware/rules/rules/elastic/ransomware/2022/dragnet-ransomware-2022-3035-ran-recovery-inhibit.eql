// Dragnet [Ransomware]: dragnet-ransomware-2022-3035 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: cf3a5800-cf7f-5347-a4b2-cc17d58caa09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
