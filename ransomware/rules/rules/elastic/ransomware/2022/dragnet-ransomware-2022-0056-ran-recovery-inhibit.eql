// Dragnet [Ransomware]: dragnet-ransomware-2022-0056 — Recovery Inhibition (mindware)
// Status: deprecated | Level: high | ID: 4e9623f6-195a-5f6a-bd09-2066eba134a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
