// Dragnet [Ransomware]: dragnet-ransomware-2022-1583 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 42b45e23-238d-5de1-8985-4e7bf545b21f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
