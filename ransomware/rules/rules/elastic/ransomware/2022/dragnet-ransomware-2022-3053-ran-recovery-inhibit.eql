// Dragnet [Ransomware]: dragnet-ransomware-2022-3053 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 44e32c87-5108-5446-9817-1aaea2c79875

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
