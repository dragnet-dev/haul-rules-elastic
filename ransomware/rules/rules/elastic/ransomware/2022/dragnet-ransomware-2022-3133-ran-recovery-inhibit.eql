// Dragnet [Ransomware]: dragnet-ransomware-2022-3133 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 524af13f-312e-5d9c-8543-fac62fe0c9b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
