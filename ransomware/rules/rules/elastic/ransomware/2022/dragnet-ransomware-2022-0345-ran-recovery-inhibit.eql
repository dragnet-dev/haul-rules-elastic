// Dragnet [Ransomware]: dragnet-ransomware-2022-0345 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b27cf8ac-badb-5aef-a34c-ae27906a6f14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
