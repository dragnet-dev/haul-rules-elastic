// Dragnet [Ransomware]: dragnet-ransomware-2022-0009 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 0f9142df-be6f-5615-9e7c-5730f73295cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
