// Dragnet [Ransomware]: dragnet-ransomware-2022-2327 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 79fd0ca7-cef1-5017-96c5-946adf25a945

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
