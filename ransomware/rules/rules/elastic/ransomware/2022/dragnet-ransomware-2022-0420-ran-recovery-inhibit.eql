// Dragnet [Ransomware]: dragnet-ransomware-2022-0420 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d9608819-ca25-515e-a607-9548b7b9b47b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
