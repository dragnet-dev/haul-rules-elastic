// Dragnet [Ransomware]: dragnet-ransomware-2022-2541 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 3982ac54-ce83-53a5-aaf1-adee8fc16709

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
