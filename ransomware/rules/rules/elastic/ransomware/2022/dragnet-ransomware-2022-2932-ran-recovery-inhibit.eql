// Dragnet [Ransomware]: dragnet-ransomware-2022-2932 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 1fa44829-02a1-5fa7-91b4-179e75648fe5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
