// Dragnet [Ransomware]: dragnet-ransomware-2022-2188 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 15197e93-ac03-556e-89c2-116fba32d151

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
