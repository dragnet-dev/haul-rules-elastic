// Dragnet [Ransomware]: dragnet-ransomware-2022-3028 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: dd434295-6653-5fbd-a250-00c196306c4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
