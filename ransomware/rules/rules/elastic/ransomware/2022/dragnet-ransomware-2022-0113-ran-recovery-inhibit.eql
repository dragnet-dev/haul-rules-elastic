// Dragnet [Ransomware]: dragnet-ransomware-2022-0113 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: e3c2dac7-2ca3-5f57-9c1d-16dc7246f46f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
