// Dragnet [Ransomware]: dragnet-ransomware-2022-0324 — Recovery Inhibition (0mega)
// Status: deprecated | Level: high | ID: 8fd9555e-373c-57e3-8406-f4f5169487c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
