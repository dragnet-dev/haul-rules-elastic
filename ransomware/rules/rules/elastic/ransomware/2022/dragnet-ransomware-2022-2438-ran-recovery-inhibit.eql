// Dragnet [Ransomware]: dragnet-ransomware-2022-2438 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: b45be812-3069-537a-a76c-61d60dfaec15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
