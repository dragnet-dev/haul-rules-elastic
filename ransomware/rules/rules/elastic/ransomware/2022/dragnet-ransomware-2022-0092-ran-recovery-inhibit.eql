// Dragnet [Ransomware]: dragnet-ransomware-2022-0092 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: cb0a694d-89d0-5cda-93d7-5478642f956b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
