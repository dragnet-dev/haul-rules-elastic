// Dragnet [Ransomware]: dragnet-ransomware-2022-2149 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: b6f46a14-1f16-592a-9f58-424346cc05c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
