// Dragnet [Ransomware]: dragnet-ransomware-2022-0668 — Recovery Inhibition (play)
// Status: deprecated | Level: high | ID: d70f85ca-d599-513f-88f1-79def080047c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
