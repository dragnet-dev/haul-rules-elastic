// Dragnet [Ransomware]: dragnet-ransomware-2022-0723 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: a74f506a-60a3-5384-b9e4-f729cc313236

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
