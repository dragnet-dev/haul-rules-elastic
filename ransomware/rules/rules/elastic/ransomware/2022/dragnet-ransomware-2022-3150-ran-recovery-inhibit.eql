// Dragnet [Ransomware]: dragnet-ransomware-2022-3150 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 64db259f-e99d-5aaa-8b53-a769243f1ae6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
