// Dragnet [Ransomware]: dragnet-ransomware-2022-3013 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 7c1e42c0-a8f6-54c4-8de3-0016a7bb4be0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
