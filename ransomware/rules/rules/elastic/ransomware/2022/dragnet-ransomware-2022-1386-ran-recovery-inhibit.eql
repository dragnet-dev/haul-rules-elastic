// Dragnet [Ransomware]: dragnet-ransomware-2022-1386 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 69fb8648-1147-562a-8269-7d9998795754

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
