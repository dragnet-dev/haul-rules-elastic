// Dragnet [Ransomware]: dragnet-ransomware-2022-1390 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 7ba74c56-ecd2-5ccc-9a3a-aac539925f20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
