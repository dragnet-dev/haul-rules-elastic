// Dragnet [Ransomware]: dragnet-ransomware-2022-1980 — Recovery Inhibition (blogxx)
// Status: deprecated | Level: high | ID: 1813bb84-d8c9-5087-b1d6-1af5ad421488

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
