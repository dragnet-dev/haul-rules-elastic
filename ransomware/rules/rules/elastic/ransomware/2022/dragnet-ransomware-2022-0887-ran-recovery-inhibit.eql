// Dragnet [Ransomware]: dragnet-ransomware-2022-0887 — Recovery Inhibition (kelvinsecurity)
// Status: deprecated | Level: high | ID: 07817091-cad5-5061-8366-0d6ebd0eb4c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
