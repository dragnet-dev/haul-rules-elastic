// Dragnet [Ransomware]: dragnet-ransomware-2022-0762 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 32491de0-9af1-5230-a5b1-52491962a19e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
