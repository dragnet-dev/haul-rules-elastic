// Dragnet [Ransomware]: dragnet-ransomware-2022-2948 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c717b5f6-17eb-58fe-b6d0-d128ea23a057

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
