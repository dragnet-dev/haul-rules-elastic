// Dragnet [Ransomware]: dragnet-ransomware-2022-1601 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: f4166ab1-a2e6-5f62-9509-e49c2b0f8866

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
