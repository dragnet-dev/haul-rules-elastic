// Dragnet [Ransomware]: dragnet-ransomware-2022-1233 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: ac5587cf-75d3-58ec-9f92-065b74828c41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
