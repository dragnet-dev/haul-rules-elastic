// Dragnet [Ransomware]: dragnet-ransomware-2022-2867 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: c3d798af-7d8c-5ab2-be82-20bb6aba01b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
