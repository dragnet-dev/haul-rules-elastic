// Dragnet [Ransomware]: dragnet-ransomware-2022-3036 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: b916ffde-808e-5b19-b77e-9b0f3c5a2e12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
