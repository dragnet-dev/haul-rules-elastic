// Dragnet [Ransomware]: dragnet-ransomware-2022-2989 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: c88b6927-ab25-51e4-8fda-c5fb63b0f0e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
