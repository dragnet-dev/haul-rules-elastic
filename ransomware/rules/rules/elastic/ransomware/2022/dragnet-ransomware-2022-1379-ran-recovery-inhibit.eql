// Dragnet [Ransomware]: dragnet-ransomware-2022-1379 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8d98676a-b280-56f7-a1a2-331fc5d7e663

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
