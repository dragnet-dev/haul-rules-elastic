// Dragnet [Ransomware]: dragnet-ransomware-2022-0031 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: de2ecfba-de95-5bcb-ac5c-3f2ffbcede46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
