// Dragnet [Ransomware]: dragnet-ransomware-2022-3051 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: db73b44d-cb22-59a2-851d-eb7eafea309c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
