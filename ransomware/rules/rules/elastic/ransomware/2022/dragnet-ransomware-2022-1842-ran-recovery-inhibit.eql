// Dragnet [Ransomware]: dragnet-ransomware-2022-1842 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5bd8d31e-405c-5632-b64a-3816c2720bf8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
