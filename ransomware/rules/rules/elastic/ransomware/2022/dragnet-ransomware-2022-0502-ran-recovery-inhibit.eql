// Dragnet [Ransomware]: dragnet-ransomware-2022-0502 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: dfe5b9e0-fa7b-59bf-9af6-150ba046fd39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
