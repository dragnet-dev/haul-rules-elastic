// Dragnet [Ransomware]: dragnet-ransomware-2022-0358 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 8c8d2464-6278-52c2-aaa2-43d3c31a6945

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
