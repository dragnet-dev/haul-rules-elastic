// Dragnet [Ransomware]: dragnet-ransomware-2022-0685 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 6369ed03-589a-5a5b-8f90-beb83f8c1461

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
