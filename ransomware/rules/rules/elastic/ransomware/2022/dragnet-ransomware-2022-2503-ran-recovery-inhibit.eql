// Dragnet [Ransomware]: dragnet-ransomware-2022-2503 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2ad53f19-605d-58d9-b14c-3c3481d9f4b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
