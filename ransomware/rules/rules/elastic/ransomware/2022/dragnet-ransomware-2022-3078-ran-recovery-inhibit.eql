// Dragnet [Ransomware]: dragnet-ransomware-2022-3078 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 35218208-cab3-5331-99ad-87a422ae2a0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
