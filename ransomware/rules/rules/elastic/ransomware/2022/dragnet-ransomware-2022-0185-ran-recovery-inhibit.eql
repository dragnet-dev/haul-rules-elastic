// Dragnet [Ransomware]: dragnet-ransomware-2022-0185 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: abc0cdb6-d79e-5e64-93b5-f835fdafc1db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
