// Dragnet [Ransomware]: dragnet-ransomware-2022-0403 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 4f8b764b-83cc-5be9-89e7-5277d124ce9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
