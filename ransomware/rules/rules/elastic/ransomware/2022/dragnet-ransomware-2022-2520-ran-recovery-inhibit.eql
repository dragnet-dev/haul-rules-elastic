// Dragnet [Ransomware]: dragnet-ransomware-2022-2520 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 6f9be560-298f-52d5-96e2-a88945ec9a2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
