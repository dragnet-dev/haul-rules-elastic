// Dragnet [Ransomware]: dragnet-ransomware-2022-2655 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 8edf2fa9-00cf-595c-b68e-24b2d520896d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
