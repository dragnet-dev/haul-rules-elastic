// Dragnet [Ransomware]: dragnet-ransomware-2022-2347 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 0f3625fb-1cf8-592e-aa80-c6b9ec22e3da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
