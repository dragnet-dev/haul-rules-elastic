// Dragnet [Ransomware]: dragnet-ransomware-2022-2030 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: 4ced89a2-442e-579f-8cb6-64b43f2e18c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
