// Dragnet [Ransomware]: dragnet-ransomware-2022-1604 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 209a0933-637d-57f0-a096-af263a137cbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
