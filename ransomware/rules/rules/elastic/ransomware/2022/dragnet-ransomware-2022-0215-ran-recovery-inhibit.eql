// Dragnet [Ransomware]: dragnet-ransomware-2022-0215 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 8e03eb81-483b-5f1a-a69b-b792785890bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
