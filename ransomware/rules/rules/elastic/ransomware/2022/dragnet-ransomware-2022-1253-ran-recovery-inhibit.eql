// Dragnet [Ransomware]: dragnet-ransomware-2022-1253 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 2bf1fe39-bcbb-5d00-b1aa-99fc3ed58c6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
