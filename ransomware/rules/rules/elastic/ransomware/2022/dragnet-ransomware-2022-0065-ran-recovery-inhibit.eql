// Dragnet [Ransomware]: dragnet-ransomware-2022-0065 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7bc9583c-263e-5126-82cb-8db40417c75a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
