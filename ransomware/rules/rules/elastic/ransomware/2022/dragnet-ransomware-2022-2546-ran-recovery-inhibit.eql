// Dragnet [Ransomware]: dragnet-ransomware-2022-2546 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ec56edd4-8e55-5ec3-91c3-0e82e2c204e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
