// Dragnet [Ransomware]: dragnet-ransomware-2022-1614 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 1c074ed6-a502-5edf-87af-d8744cd86240

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
