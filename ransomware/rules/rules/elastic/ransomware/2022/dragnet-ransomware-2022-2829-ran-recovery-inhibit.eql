// Dragnet [Ransomware]: dragnet-ransomware-2022-2829 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: b717feb4-256e-538d-bbed-e3f5fc5282f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
