// Dragnet [Ransomware]: dragnet-ransomware-2022-2863 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: c3a41cc7-ec9d-5eb1-94e3-9e11f76ce04a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
