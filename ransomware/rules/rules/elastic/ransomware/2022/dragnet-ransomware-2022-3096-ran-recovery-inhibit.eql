// Dragnet [Ransomware]: dragnet-ransomware-2022-3096 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5bf83eab-ab09-5434-ad03-de8f3b19db94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
