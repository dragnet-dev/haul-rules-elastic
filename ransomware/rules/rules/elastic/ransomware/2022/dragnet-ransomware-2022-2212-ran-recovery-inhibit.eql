// Dragnet [Ransomware]: dragnet-ransomware-2022-2212 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: e00719d1-8a83-5c66-9859-a05f294b95b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
