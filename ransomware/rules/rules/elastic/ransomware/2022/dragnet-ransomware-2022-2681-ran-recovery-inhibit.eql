// Dragnet [Ransomware]: dragnet-ransomware-2022-2681 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 44611f53-fd38-5dec-bc37-4eeb47023cd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
