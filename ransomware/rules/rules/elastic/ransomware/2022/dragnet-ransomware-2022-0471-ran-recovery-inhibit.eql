// Dragnet [Ransomware]: dragnet-ransomware-2022-0471 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: caa386eb-9298-5c1b-988e-59d038db1837

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
