// Dragnet [Ransomware]: dragnet-ransomware-2022-0293 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: bf80e5aa-9d67-5be9-bcf4-644bdea48318

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
