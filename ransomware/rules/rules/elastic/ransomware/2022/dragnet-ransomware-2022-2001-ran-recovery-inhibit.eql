// Dragnet [Ransomware]: dragnet-ransomware-2022-2001 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2ede9234-bbb9-5eb7-a8fd-655162006aef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
