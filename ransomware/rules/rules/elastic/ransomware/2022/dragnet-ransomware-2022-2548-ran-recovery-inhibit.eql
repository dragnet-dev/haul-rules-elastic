// Dragnet [Ransomware]: dragnet-ransomware-2022-2548 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 3ced3abd-2e68-5fe1-b716-28ea3d761362

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
