// Dragnet [Ransomware]: dragnet-ransomware-2022-0438 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: 44fd606c-ba3e-59dd-8bd8-fdda9a7d9a14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
