// Dragnet [Ransomware]: dragnet-ransomware-2022-0158 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 656e76b6-f15d-5d86-9172-3102193d4288

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
