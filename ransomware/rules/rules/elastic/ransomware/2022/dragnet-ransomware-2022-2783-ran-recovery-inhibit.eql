// Dragnet [Ransomware]: dragnet-ransomware-2022-2783 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: db02599f-7977-5a7e-8485-65d762b7e7f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
