// Dragnet [Ransomware]: dragnet-ransomware-2022-2735 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 2dfa2e8d-6791-5da1-b244-d89bccf64209

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
