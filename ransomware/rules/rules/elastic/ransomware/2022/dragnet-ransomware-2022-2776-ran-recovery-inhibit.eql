// Dragnet [Ransomware]: dragnet-ransomware-2022-2776 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: f1774f4c-12a1-5baf-8cbf-824e9d8d39c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
