// Dragnet [Ransomware]: dragnet-ransomware-2022-2578 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 73fcc2ed-ff30-5243-9ae9-6d34ac61271b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
