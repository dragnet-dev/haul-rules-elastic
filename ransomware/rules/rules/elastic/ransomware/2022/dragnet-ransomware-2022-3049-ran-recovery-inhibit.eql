// Dragnet [Ransomware]: dragnet-ransomware-2022-3049 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 483bfc2f-310d-5d8c-8974-afb89413737f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
