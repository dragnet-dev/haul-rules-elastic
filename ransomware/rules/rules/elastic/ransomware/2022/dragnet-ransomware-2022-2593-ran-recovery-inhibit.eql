// Dragnet [Ransomware]: dragnet-ransomware-2022-2593 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 12dda30a-8131-5a7e-bbee-85e163b63f81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
