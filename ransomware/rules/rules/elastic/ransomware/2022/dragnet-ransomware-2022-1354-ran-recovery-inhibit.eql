// Dragnet [Ransomware]: dragnet-ransomware-2022-1354 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8fd0df02-e6d4-5d01-8886-2ea1b507b0b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
