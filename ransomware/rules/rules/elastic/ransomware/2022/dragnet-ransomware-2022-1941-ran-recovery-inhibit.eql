// Dragnet [Ransomware]: dragnet-ransomware-2022-1941 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 32e7cd69-0c69-505a-a56c-83a163bf8137

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
