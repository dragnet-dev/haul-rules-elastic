// Dragnet [Ransomware]: dragnet-ransomware-2022-1424 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: e73828bd-4e06-5fdb-b62c-83f6d0be87d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
