// Dragnet [Ransomware]: dragnet-ransomware-2022-0952 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: ad52c395-9441-5dab-87fe-291cb6e8e87c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
