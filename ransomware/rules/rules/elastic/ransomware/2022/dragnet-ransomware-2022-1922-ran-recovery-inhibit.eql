// Dragnet [Ransomware]: dragnet-ransomware-2022-1922 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 3d65ed56-531b-5c76-af21-98ef4603dcb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
