// Dragnet [Ransomware]: dragnet-ransomware-2022-1248 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: fa461d22-398b-583e-9284-5e32f485907d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
