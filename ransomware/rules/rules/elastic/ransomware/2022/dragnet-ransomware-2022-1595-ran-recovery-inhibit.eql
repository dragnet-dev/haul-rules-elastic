// Dragnet [Ransomware]: dragnet-ransomware-2022-1595 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 93f65da0-feb1-56cc-bd4f-1ec41b406ba9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
