// Dragnet [Ransomware]: dragnet-ransomware-2022-0601 — Recovery Inhibition (sparta)
// Status: deprecated | Level: high | ID: c15afc81-ba6c-5067-b90a-2a206dda9cfa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
