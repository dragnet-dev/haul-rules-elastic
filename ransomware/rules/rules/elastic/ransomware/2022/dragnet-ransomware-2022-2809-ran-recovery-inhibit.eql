// Dragnet [Ransomware]: dragnet-ransomware-2022-2809 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 44bd3de4-2ed8-5cfa-92d5-4117ac39f1fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
