// Dragnet [Ransomware]: dragnet-ransomware-2022-2476 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 15d3903b-6c4b-5211-b8fe-606f1878c4ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
