// Dragnet [Ransomware]: dragnet-ransomware-2022-1653 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: fa3c1ca5-1af8-500d-a556-35a95f2fe401

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
