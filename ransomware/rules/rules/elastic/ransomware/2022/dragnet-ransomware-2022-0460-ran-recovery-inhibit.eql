// Dragnet [Ransomware]: dragnet-ransomware-2022-0460 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 92b63f63-66ab-5bc8-b0a3-6401b1989fab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
