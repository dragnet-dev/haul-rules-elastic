// Dragnet [Ransomware]: dragnet-ransomware-2022-0918 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 1e2bb1c4-733d-5236-ba55-8163e0e71fdb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
