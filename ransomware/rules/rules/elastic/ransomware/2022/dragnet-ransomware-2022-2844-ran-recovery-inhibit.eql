// Dragnet [Ransomware]: dragnet-ransomware-2022-2844 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: a5e55144-4b3e-52b0-9c96-e80d98a622c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
