// Dragnet [Ransomware]: dragnet-ransomware-2022-0965 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: a913752c-9404-5748-aae2-7de66b1a27fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
