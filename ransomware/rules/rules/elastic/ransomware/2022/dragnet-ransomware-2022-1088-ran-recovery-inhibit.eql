// Dragnet [Ransomware]: dragnet-ransomware-2022-1088 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 2a17e7d9-3c7c-59e2-a920-ed070235186c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
