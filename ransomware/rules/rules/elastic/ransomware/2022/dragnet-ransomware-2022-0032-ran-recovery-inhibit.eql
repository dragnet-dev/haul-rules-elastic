// Dragnet [Ransomware]: dragnet-ransomware-2022-0032 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 9d574d2d-4bd1-5d90-a500-20a8de0d3627

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
