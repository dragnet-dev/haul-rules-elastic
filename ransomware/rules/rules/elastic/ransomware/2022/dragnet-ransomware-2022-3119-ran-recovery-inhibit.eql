// Dragnet [Ransomware]: dragnet-ransomware-2022-3119 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 54028e15-9fa0-5df7-80f4-56c9e2174fca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
