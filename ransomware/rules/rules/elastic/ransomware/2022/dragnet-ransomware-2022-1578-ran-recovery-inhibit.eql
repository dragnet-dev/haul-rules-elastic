// Dragnet [Ransomware]: dragnet-ransomware-2022-1578 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: b6d14b8d-e296-5bbf-88db-259137bcee2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
