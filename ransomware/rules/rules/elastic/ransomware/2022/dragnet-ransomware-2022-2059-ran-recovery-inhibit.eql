// Dragnet [Ransomware]: dragnet-ransomware-2022-2059 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: 84adaa38-48d3-5f94-8a27-cf4d2c649c61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
