// Dragnet [Ransomware]: dragnet-ransomware-2022-0269 — Recovery Inhibition (cryptbb)
// Status: experimental | Level: high | ID: ef6c9e4b-2b4f-5993-8836-4b6daa491c7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
