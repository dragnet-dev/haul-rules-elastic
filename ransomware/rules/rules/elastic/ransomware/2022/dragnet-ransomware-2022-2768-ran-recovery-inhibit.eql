// Dragnet [Ransomware]: dragnet-ransomware-2022-2768 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: c0e938ec-96f6-50af-ba8e-ac69a730f34b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
