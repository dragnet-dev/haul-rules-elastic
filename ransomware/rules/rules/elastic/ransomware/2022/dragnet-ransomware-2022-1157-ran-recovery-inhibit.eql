// Dragnet [Ransomware]: dragnet-ransomware-2022-1157 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: e65388fc-1cbf-57ba-92b2-466df5c033f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
