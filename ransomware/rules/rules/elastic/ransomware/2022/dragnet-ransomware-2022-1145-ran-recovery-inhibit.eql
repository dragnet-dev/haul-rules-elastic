// Dragnet [Ransomware]: dragnet-ransomware-2022-1145 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 87b462bd-467d-59a9-89e4-ca9cd6af7941

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
