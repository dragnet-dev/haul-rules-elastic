// Dragnet [Ransomware]: dragnet-ransomware-2022-0166 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: fa896f92-d311-537b-99de-d651346ec20b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
