// Dragnet [Ransomware]: dragnet-ransomware-2022-0264 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: f879c0ab-c523-55aa-bcf1-2d7c36f5f5fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
