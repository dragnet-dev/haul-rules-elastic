// Dragnet [Ransomware]: dragnet-ransomware-2022-1202 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 9c041630-7fdb-5eb7-958d-eb78a66775ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
