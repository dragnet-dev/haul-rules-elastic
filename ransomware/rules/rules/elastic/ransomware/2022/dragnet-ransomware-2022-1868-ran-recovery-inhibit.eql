// Dragnet [Ransomware]: dragnet-ransomware-2022-1868 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 0712df1d-f6fe-5821-9801-4d610db3609a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
