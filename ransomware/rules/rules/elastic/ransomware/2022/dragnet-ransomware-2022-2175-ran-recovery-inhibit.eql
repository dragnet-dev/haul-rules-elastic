// Dragnet [Ransomware]: dragnet-ransomware-2022-2175 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 76ef3f09-39eb-571b-9ff5-2852b607c382

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
