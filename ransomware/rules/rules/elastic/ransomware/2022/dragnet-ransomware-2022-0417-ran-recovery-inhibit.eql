// Dragnet [Ransomware]: dragnet-ransomware-2022-0417 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 57c64257-a4c1-50dd-ae39-091c6ae680c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
