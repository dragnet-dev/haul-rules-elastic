// Dragnet [Ransomware]: dragnet-ransomware-2022-2026 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 43e65836-7cda-5285-b64f-e03607a9c677

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
