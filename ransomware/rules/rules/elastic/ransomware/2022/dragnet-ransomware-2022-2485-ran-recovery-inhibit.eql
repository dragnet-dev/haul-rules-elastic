// Dragnet [Ransomware]: dragnet-ransomware-2022-2485 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 4df82c33-17d8-5865-8caa-73e9d46562d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
