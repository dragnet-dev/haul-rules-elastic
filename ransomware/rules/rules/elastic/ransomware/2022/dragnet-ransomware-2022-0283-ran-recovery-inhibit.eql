// Dragnet [Ransomware]: dragnet-ransomware-2022-0283 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 7054006c-b187-5c0a-bed4-87e13925b12a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
