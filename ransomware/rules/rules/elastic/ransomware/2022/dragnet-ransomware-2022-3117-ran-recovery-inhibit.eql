// Dragnet [Ransomware]: dragnet-ransomware-2022-3117 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: b0421614-9b6d-557c-a607-f39115d5f024

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
