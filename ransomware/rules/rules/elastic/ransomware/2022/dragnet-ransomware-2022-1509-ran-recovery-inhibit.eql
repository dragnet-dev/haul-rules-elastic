// Dragnet [Ransomware]: dragnet-ransomware-2022-1509 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 9699008b-e2cd-5a12-9946-900504d43634

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
