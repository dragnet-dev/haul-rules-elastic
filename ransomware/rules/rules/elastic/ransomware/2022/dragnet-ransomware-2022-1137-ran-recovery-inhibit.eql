// Dragnet [Ransomware]: dragnet-ransomware-2022-1137 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 2954d0de-1547-545b-bafc-bdb947e70a27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
