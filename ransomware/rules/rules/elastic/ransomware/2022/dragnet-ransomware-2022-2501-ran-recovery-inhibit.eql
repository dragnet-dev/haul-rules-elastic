// Dragnet [Ransomware]: dragnet-ransomware-2022-2501 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 357f7aa3-a20d-5f27-9072-90bba73a4646

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
