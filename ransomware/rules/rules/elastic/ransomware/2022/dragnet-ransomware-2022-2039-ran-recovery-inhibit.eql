// Dragnet [Ransomware]: dragnet-ransomware-2022-2039 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: b9ae8559-c63f-5334-94a4-5b9c978efd3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
