// Dragnet [Ransomware]: dragnet-ransomware-2022-1470 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: fd1f9377-592e-5c58-83ab-3099bf8e539f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
