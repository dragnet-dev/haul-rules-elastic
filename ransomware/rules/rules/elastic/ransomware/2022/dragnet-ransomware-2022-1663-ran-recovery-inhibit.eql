// Dragnet [Ransomware]: dragnet-ransomware-2022-1663 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 0519313f-afaa-5e20-814b-e3b32237511c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
