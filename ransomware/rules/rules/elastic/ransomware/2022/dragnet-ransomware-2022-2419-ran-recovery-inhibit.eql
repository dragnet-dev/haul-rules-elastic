// Dragnet [Ransomware]: dragnet-ransomware-2022-2419 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 970bea10-c194-5235-8636-6f4f26a20c97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
