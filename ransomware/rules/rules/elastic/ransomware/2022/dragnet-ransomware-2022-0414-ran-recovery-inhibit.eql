// Dragnet [Ransomware]: dragnet-ransomware-2022-0414 — Recovery Inhibition (daixin)
// Status: deprecated | Level: high | ID: b8b8efaf-718d-53c0-8084-7af6bc586559

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
