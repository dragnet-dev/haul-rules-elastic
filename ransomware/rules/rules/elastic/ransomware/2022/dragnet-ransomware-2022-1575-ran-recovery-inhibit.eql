// Dragnet [Ransomware]: dragnet-ransomware-2022-1575 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 0c456c6a-404f-54db-a405-9993dcfdca40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
