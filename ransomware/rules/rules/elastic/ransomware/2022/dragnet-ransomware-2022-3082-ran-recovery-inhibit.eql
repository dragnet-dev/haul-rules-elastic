// Dragnet [Ransomware]: dragnet-ransomware-2022-3082 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 83850040-777b-5453-9e84-0a1265e7feb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
