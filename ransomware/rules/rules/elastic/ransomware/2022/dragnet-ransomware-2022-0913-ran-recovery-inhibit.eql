// Dragnet [Ransomware]: dragnet-ransomware-2022-0913 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: dd37ffa0-9ae3-510f-8238-5296cac9f256

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
