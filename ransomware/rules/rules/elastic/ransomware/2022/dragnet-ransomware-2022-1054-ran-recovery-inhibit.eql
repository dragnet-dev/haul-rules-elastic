// Dragnet [Ransomware]: dragnet-ransomware-2022-1054 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: d1ca63c7-cdbc-51a2-85c0-4c45465ca593

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
