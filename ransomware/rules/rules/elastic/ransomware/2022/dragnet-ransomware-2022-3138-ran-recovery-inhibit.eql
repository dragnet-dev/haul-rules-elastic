// Dragnet [Ransomware]: dragnet-ransomware-2022-3138 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: b49a4c4a-7c9b-532e-9e2b-fdc065ccd731

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
