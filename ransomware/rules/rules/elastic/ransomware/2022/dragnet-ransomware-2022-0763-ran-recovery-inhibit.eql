// Dragnet [Ransomware]: dragnet-ransomware-2022-0763 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: a588a924-d5ba-5813-a1b7-cc20369d044c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
