// Dragnet [Ransomware]: dragnet-ransomware-2022-0998 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 68d727ad-b03b-55cc-a180-a11a96fd700e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
