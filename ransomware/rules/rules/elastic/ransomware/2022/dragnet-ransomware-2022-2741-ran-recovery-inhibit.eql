// Dragnet [Ransomware]: dragnet-ransomware-2022-2741 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 8c014769-98b7-5151-aeaa-04e2475acaaf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
