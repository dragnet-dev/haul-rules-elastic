// Dragnet [Ransomware]: dragnet-ransomware-2022-2931 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 8c7ac893-38d1-562c-866f-334b5309a485

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
