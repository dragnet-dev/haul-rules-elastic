// Dragnet [Ransomware]: dragnet-ransomware-2022-2035 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: b9ff1bc1-6958-54c9-89cf-55efa5002038

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
