// Dragnet [Ransomware]: dragnet-ransomware-2022-1724 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 1fa90c19-3c36-5ded-8721-35f2c206eef9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
