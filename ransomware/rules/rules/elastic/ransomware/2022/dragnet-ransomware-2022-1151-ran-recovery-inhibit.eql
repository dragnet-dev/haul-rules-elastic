// Dragnet [Ransomware]: dragnet-ransomware-2022-1151 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: c36db0c1-874a-5596-b6b9-f9ca9319c7ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
