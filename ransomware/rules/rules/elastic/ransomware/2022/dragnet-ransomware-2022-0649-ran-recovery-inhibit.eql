// Dragnet [Ransomware]: dragnet-ransomware-2022-0649 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: 5e455670-0c46-510f-be23-dc159ff0c036

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
