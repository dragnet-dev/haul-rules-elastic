// Dragnet [Ransomware]: dragnet-ransomware-2022-0364 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: 3aa060ed-b64b-54f9-93b7-ca24f97ef931

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
