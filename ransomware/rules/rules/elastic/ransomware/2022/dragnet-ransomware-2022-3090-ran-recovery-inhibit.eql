// Dragnet [Ransomware]: dragnet-ransomware-2022-3090 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: e5bd7be8-9621-505a-ba2b-895e053bd2db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
