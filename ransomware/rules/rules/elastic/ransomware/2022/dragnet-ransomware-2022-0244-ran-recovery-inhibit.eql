// Dragnet [Ransomware]: dragnet-ransomware-2022-0244 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: af284500-8336-5ec1-a3e8-e0f3fbbb544d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
