// Dragnet [Ransomware]: dragnet-ransomware-2022-1620 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0a7d8fe9-3acc-5d3a-a230-da229edf4850

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
