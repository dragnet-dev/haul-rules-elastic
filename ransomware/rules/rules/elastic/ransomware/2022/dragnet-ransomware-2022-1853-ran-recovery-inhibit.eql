// Dragnet [Ransomware]: dragnet-ransomware-2022-1853 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: e3ac48b6-9872-5104-8682-5d2a25e8c9da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
