// Dragnet [Ransomware]: dragnet-ransomware-2022-0060 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: b245812f-db0d-537a-9c7e-2f0d86c9c1c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
