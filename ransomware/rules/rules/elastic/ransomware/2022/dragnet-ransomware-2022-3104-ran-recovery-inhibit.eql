// Dragnet [Ransomware]: dragnet-ransomware-2022-3104 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 16c0b856-220c-568d-af22-ffba8391c83c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
