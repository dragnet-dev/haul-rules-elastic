// Dragnet [Ransomware]: dragnet-ransomware-2022-1329 — Recovery Inhibition (sparta)
// Status: deprecated | Level: high | ID: 2bffdf37-c847-5015-82ed-665bcf1e7eb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
