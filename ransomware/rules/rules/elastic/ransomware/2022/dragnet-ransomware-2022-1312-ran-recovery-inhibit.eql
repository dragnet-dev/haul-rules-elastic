// Dragnet [Ransomware]: dragnet-ransomware-2022-1312 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 155d638a-1a89-5b66-9987-ee56f1217793

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
