// Dragnet [Ransomware]: dragnet-ransomware-2022-1975 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: 5ef38ab1-3f0a-55c2-bfc7-e988899fc683

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
