// Dragnet [Ransomware]: dragnet-ransomware-2022-2842 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: bb175af1-be7d-562e-811f-72f801ee0c05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
