// Dragnet [Ransomware]: dragnet-ransomware-2022-0216 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: a79be7a3-2919-5ab0-83d9-b20ba5c22fed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
