// Dragnet [Ransomware]: dragnet-ransomware-2022-1065 — Recovery Inhibition (avoslocker)
// Status: deprecated | Level: high | ID: a4a57d1d-50f8-5af4-9d19-41194c596aca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
