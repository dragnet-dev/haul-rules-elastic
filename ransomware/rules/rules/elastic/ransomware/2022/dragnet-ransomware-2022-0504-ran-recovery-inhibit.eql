// Dragnet [Ransomware]: dragnet-ransomware-2022-0504 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: 7474555b-5210-510f-8758-440eac332412

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
