// Dragnet [Ransomware]: dragnet-ransomware-2022-1487 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: c2d5f56d-084f-56c8-864e-b3f5b22d0ebf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
