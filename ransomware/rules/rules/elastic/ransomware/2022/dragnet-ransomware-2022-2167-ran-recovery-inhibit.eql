// Dragnet [Ransomware]: dragnet-ransomware-2022-2167 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 7749a414-fbf1-5898-a1e3-87f0622ca260

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
