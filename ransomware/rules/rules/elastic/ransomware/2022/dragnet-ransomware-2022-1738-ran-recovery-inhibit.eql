// Dragnet [Ransomware]: dragnet-ransomware-2022-1738 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 457833d5-ca68-548b-a8fd-d65d8bfc1598

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
