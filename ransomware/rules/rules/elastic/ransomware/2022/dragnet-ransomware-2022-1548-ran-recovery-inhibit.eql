// Dragnet [Ransomware]: dragnet-ransomware-2022-1548 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: d87a49b3-6b8d-5fad-91bc-281e7a79f6cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
