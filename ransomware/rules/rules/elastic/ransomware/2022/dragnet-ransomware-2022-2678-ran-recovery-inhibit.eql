// Dragnet [Ransomware]: dragnet-ransomware-2022-2678 — Recovery Inhibition (snatch)
// Status: experimental | Level: high | ID: 3d9a2a68-64f7-5279-874b-b5be4020b3ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
