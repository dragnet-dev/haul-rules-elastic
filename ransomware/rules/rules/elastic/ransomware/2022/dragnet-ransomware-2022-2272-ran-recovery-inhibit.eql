// Dragnet [Ransomware]: dragnet-ransomware-2022-2272 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 07d0e9fb-ba05-5a47-8a0f-6599f1af2021

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
