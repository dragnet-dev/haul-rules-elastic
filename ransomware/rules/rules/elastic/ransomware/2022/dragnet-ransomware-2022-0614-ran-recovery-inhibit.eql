// Dragnet [Ransomware]: dragnet-ransomware-2022-0614 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ff75fa97-091c-5f57-82e1-7371bcf36b5e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
