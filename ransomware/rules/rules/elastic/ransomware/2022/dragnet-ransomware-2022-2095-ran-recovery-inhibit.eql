// Dragnet [Ransomware]: dragnet-ransomware-2022-2095 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: 78d15dd4-faca-55fe-9fae-a69127c1349a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
