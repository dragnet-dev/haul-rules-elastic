// Dragnet [Ransomware]: dragnet-ransomware-2022-2017 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 333979bc-bcdb-574b-9355-38c6e8c90874

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
