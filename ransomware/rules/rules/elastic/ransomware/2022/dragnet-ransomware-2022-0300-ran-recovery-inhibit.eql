// Dragnet [Ransomware]: dragnet-ransomware-2022-0300 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 88272c55-c7c6-52f0-b0f0-2a7050506d5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
