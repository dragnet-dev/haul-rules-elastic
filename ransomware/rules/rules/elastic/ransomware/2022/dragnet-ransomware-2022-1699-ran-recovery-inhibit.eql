// Dragnet [Ransomware]: dragnet-ransomware-2022-1699 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 4a923c84-b40b-5acd-ace2-4d134536bf03

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
