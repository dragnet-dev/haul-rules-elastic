// Dragnet [Ransomware]: dragnet-ransomware-2022-0361 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ed4e3f5d-e6f7-5ff4-8a81-b4991f8e8f0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
