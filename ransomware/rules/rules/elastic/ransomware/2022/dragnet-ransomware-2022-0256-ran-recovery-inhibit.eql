// Dragnet [Ransomware]: dragnet-ransomware-2022-0256 — Recovery Inhibition (cuba)
// Status: deprecated | Level: high | ID: c20346c1-4ce6-552c-a525-62601e9d58c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
