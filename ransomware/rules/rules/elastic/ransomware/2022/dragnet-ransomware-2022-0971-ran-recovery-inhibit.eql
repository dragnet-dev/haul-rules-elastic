// Dragnet [Ransomware]: dragnet-ransomware-2022-0971 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 1e6260c5-303d-5559-ba5b-8ce58b587861

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
