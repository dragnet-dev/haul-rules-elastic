// Dragnet [Ransomware]: dragnet-ransomware-2022-3097 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 64dd3b2b-3dd6-573d-a4eb-c66d0e96dde4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
