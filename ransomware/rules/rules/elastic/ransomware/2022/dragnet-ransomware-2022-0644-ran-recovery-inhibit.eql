// Dragnet [Ransomware]: dragnet-ransomware-2022-0644 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 53d82e24-1867-518d-9021-5d15f33d6b5c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
