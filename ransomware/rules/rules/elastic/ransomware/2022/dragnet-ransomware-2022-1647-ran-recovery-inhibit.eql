// Dragnet [Ransomware]: dragnet-ransomware-2022-1647 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: 73360375-b199-5618-8e5b-69d92e6ee49c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
