// Dragnet [Ransomware]: dragnet-ransomware-2022-0570 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: f9a6cc92-57cc-5663-9c72-1a178bd2a92e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
