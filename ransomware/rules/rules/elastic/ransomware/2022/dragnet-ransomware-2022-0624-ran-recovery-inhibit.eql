// Dragnet [Ransomware]: dragnet-ransomware-2022-0624 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 5983206d-d4d9-5b87-9f74-375b9cf1767a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
