// Dragnet [Ransomware]: dragnet-ransomware-2022-2775 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 545812fb-6e8e-5c7f-ba6c-2c11051e6133

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
