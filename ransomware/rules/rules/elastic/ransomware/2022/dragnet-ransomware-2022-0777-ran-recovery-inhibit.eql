// Dragnet [Ransomware]: dragnet-ransomware-2022-0777 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: c690253f-fff1-5b83-a8c7-187ee0d5d245

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
