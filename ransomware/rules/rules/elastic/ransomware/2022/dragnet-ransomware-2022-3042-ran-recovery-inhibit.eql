// Dragnet [Ransomware]: dragnet-ransomware-2022-3042 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 16d3ba82-5935-51ed-b996-d787f7a845c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
