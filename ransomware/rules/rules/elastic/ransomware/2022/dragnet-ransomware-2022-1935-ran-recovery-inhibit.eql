// Dragnet [Ransomware]: dragnet-ransomware-2022-1935 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 20523080-bafe-5d8a-9ff5-d0a9ef1c5aa6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
