// Dragnet [Ransomware]: dragnet-ransomware-2022-2831 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 23ad8ea0-6b33-505e-ad23-fad9817578da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
