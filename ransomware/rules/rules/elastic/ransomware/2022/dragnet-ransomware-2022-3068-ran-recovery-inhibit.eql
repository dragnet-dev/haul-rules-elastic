// Dragnet [Ransomware]: dragnet-ransomware-2022-3068 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: e47923b1-3bd5-5d82-bdaf-6b042ebd7653

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
