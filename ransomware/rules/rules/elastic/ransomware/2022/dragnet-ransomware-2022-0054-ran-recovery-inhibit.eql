// Dragnet [Ransomware]: dragnet-ransomware-2022-0054 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 3fd31c71-ed13-521a-a412-ebfcb0e75d01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
