// Dragnet [Ransomware]: dragnet-ransomware-2022-0903 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: ca8d8773-efd5-5028-beab-075191fdfb2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
