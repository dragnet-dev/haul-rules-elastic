// Dragnet [Ransomware]: dragnet-ransomware-2022-2791 — Recovery Inhibition (bianlian)
// Status: deprecated | Level: high | ID: 1a49aaba-23b9-57d5-b35e-b1c2b786524f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
