// Dragnet [Ransomware]: dragnet-ransomware-2022-3017 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 6a8e1583-c08f-5032-8988-9257120de223

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
