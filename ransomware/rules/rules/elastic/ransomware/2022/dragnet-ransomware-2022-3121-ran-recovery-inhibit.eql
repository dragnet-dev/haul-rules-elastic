// Dragnet [Ransomware]: dragnet-ransomware-2022-3121 — Recovery Inhibition (snatch)
// Status: deprecated | Level: high | ID: d914142f-4380-5646-9aa1-5dd86fb3e339

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
