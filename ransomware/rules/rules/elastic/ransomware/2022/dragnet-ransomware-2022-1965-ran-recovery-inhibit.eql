// Dragnet [Ransomware]: dragnet-ransomware-2022-1965 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 5a4cab1c-6e9a-5ab7-938c-2bedbd2725f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
