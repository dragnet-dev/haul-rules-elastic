// Dragnet [Ransomware]: dragnet-ransomware-2022-2657 — Recovery Inhibition (quantum)
// Status: deprecated | Level: high | ID: 1cab83b4-fe37-5bc5-abbe-5859d67eaf6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
