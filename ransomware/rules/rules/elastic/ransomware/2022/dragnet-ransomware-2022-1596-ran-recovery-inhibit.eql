// Dragnet [Ransomware]: dragnet-ransomware-2022-1596 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: 75bd4cf4-a865-5c8d-bb11-604bf9271f82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
