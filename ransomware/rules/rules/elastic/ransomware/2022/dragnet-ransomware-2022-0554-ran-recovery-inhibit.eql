// Dragnet [Ransomware]: dragnet-ransomware-2022-0554 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 64653b75-42c5-528c-8fb6-f51b1b08b391

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
