// Dragnet [Ransomware]: dragnet-ransomware-2022-1172 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 39b724c1-8849-577c-a087-215e1cc67792

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
