// Dragnet [Ransomware]: dragnet-ransomware-2022-2994 — Recovery Inhibition (hive)
// Status: deprecated | Level: high | ID: e8979086-8cda-5b84-9011-d3288b43ae23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
