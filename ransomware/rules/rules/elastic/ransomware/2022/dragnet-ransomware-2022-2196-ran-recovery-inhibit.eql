// Dragnet [Ransomware]: dragnet-ransomware-2022-2196 — Recovery Inhibition (karakurt)
// Status: deprecated | Level: high | ID: 8d593090-c835-52d3-aea9-14ac9bb6eedf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
