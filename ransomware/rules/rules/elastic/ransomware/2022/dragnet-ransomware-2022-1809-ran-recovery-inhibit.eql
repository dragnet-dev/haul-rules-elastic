// Dragnet [Ransomware]: dragnet-ransomware-2022-1809 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: 247ecbfb-df10-56cb-aa7c-7e7d13dc3ff4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
