// Dragnet [Ransomware]: dragnet-ransomware-2022-0737 — Recovery Inhibition (alphv)
// Status: experimental | Level: high | ID: c82205c4-89f0-54aa-8f74-f8a16400be3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
