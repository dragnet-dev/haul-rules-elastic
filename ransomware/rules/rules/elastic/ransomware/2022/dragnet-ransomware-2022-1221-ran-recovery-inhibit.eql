// Dragnet [Ransomware]: dragnet-ransomware-2022-1221 — Recovery Inhibition (karakurt)
// Status: experimental | Level: high | ID: ed9f3bcf-33f5-5b4c-a400-04bff3c6e52f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
