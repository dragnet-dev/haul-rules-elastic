// Dragnet [Ransomware]: dragnet-ransomware-2022-1847 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: bdc9db20-01f4-5b05-a127-06113b6b7cbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
