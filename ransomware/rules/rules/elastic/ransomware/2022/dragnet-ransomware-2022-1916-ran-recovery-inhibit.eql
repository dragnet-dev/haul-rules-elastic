// Dragnet [Ransomware]: dragnet-ransomware-2022-1916 — Recovery Inhibition (royal)
// Status: deprecated | Level: high | ID: 6616269e-edb0-5f0e-bf0f-998295262ebe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
