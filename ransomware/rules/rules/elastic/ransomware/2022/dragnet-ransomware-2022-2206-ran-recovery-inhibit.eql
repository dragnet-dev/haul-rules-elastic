// Dragnet [Ransomware]: dragnet-ransomware-2022-2206 — Recovery Inhibition (midas)
// Status: deprecated | Level: high | ID: 76d0d3ec-26cd-5466-a55f-a35086ae0541

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
