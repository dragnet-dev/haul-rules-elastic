// Dragnet [Ransomware]: dragnet-ransomware-2022-0515 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: 1405937b-8db1-5f71-826b-2d5b4f424796

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
