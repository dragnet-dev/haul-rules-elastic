// Dragnet [Ransomware]: dragnet-ransomware-2022-2408 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: b6bb4555-dc77-5d9c-a532-dac8dfe2058a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
