// Dragnet [Ransomware]: dragnet-ransomware-2022-1340 — Recovery Inhibition (vicesociety)
// Status: deprecated | Level: high | ID: e250b4b1-2e6d-5795-a67f-4f5abfb89a9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
