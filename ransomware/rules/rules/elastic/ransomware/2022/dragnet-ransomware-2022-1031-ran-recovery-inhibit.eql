// Dragnet [Ransomware]: dragnet-ransomware-2022-1031 — Recovery Inhibition (lv)
// Status: deprecated | Level: high | ID: 1fabfedd-f513-53ad-bf12-890d3e60e96c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
