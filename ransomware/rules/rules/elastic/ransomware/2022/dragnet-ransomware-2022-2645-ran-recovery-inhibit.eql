// Dragnet [Ransomware]: dragnet-ransomware-2022-2645 — Recovery Inhibition (everest)
// Status: deprecated | Level: high | ID: 7418db9a-3cab-5728-854f-343882e874ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
