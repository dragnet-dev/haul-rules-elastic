// Dragnet [Ransomware]: dragnet-ransomware-2022-0153 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: dccf54f0-d4e9-51de-a735-ac4ddcf8876b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
