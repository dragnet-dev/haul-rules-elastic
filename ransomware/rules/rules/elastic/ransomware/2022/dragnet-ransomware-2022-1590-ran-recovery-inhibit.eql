// Dragnet [Ransomware]: dragnet-ransomware-2022-1590 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: b198a46a-6ff9-5087-a07e-c604eecfe0ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
