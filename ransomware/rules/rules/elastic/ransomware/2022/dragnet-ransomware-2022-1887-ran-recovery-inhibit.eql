// Dragnet [Ransomware]: dragnet-ransomware-2022-1887 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: 4cd8476d-cd54-5ebf-aa40-d5e7a6be2fa9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
