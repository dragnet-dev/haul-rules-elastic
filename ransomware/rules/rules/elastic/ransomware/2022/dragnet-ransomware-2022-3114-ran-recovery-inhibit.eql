// Dragnet [Ransomware]: dragnet-ransomware-2022-3114 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3674df15-afe0-5c47-83d3-402dec276d22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
