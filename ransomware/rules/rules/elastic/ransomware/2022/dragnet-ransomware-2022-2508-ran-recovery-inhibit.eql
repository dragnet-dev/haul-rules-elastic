// Dragnet [Ransomware]: dragnet-ransomware-2022-2508 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 8eccad37-b76d-50e7-aaa9-9d6701524603

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
