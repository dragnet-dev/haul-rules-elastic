// Dragnet [Ransomware]: dragnet-ransomware-2022-1262 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 9efa45cb-7b24-56b1-a22e-91e76f2514a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
