// Dragnet [Ransomware]: dragnet-ransomware-2022-2859 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 5fcf5708-9e3c-527f-aebd-4d0bed5bce07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
