// Dragnet [Ransomware]: dragnet-ransomware-2022-0013 — Recovery Inhibition (lorenz)
// Status: experimental | Level: high | ID: 59c01f7d-5e64-53d5-a1c6-780894f2108a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
