// Dragnet [Ransomware]: dragnet-ransomware-2022-0831 — Recovery Inhibition (lockbit2)
// Status: deprecated | Level: high | ID: 772dc5d1-5cb8-5938-80f1-04ce041aac78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
