// Dragnet [Ransomware]: dragnet-ransomware-2022-1403 — Recovery Inhibition (lockbit3)
// Status: deprecated | Level: high | ID: 9c437e93-e312-5f28-bcd5-0dc8d3f4a38c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
