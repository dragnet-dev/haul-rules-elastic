// Dragnet [Ransomware]: dragnet-ransomware-2022-2107 — Recovery Inhibition (ransomhouse)
// Status: deprecated | Level: high | ID: 15591b8a-34f4-5b78-9263-5b493f62fd0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
