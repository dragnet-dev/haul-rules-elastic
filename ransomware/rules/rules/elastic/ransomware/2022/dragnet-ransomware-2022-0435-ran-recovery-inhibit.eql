// Dragnet [Ransomware]: dragnet-ransomware-2022-0435 — Recovery Inhibition (darkleakmarket)
// Status: deprecated | Level: high | ID: 7b7cb271-efa6-53a5-8e43-c6c1675540aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
