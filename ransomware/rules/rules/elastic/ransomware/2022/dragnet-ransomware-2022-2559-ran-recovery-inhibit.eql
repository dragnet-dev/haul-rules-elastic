// Dragnet [Ransomware]: dragnet-ransomware-2022-2559 — Recovery Inhibition (blackbasta)
// Status: deprecated | Level: high | ID: fe1ec3a0-dbaf-5b1b-8980-da3c4df73831

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
