// Dragnet [Ransomware]: dragnet-ransomware-2022-1979 — Recovery Inhibition (alphv)
// Status: deprecated | Level: high | ID: fd4d3769-64ca-5cab-afac-d5811f911a2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
