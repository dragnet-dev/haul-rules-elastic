// Dragnet [Ransomware]: dragnet-ransomware-2020-0246 — Recovery Inhibition (netwalker)
// Status: deprecated | Level: high | ID: 5d447a58-ab6e-54fe-8ea7-91636674e1a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
