// Dragnet [Ransomware]: dragnet-ransomware-2020-0233 — Recovery Inhibition (ragnarlocker)
// Status: experimental | Level: high | ID: c8de8acf-963c-56f2-bdab-fc9ae6509c22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
