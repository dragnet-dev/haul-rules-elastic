// Dragnet [Ransomware]: dragnet-ransomware-2020-0164 — Recovery Inhibition (netwalker)
// Status: deprecated | Level: high | ID: 47ea9ed2-4f37-5311-86fc-2655363fa453

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
