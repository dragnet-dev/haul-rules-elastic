// Dragnet [Ransomware]: dragnet-ransomware-2020-0202 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 23ee7890-5ebe-54a0-9aed-29a75a48ac30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
