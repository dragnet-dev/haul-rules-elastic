// Dragnet [Ransomware]: dragnet-ransomware-2020-0019 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 9da8081e-c399-55bc-851a-015eef772ee2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
