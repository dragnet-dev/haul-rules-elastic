// Dragnet [Ransomware]: dragnet-ransomware-2020-0245 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: bb618a96-8994-55ae-abf8-674d15899dff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
