// Dragnet [Ransomware]: dragnet-ransomware-2020-0072 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: cd1abf56-0ebe-5dc0-b390-b646a1742d4f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
