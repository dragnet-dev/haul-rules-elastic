// Dragnet [Ransomware]: dragnet-ransomware-2020-0175 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: c7f8d3a8-74e6-5692-b842-86a27da1ccdf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
