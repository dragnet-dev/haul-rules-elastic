// Dragnet [Ransomware]: dragnet-ransomware-2020-0170 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 627c4119-081c-5f7f-ae02-91095928cc74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
