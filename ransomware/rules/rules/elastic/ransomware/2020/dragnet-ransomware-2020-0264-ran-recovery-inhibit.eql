// Dragnet [Ransomware]: dragnet-ransomware-2020-0264 — Recovery Inhibition (prolock)
// Status: deprecated | Level: high | ID: b026b2f9-ca1b-50ad-9adb-82c43ba3d240

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
