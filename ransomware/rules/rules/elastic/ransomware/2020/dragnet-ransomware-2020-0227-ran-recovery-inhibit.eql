// Dragnet [Ransomware]: dragnet-ransomware-2020-0227 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 7337a00b-a83f-51cd-9079-e4506a2a5672

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
