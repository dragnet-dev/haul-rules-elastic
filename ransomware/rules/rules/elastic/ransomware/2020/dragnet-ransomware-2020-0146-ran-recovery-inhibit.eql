// Dragnet [Ransomware]: dragnet-ransomware-2020-0146 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: f363804c-85de-53f3-984e-c09d34c62cae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
