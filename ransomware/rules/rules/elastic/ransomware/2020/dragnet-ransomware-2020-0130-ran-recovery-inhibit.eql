// Dragnet [Ransomware]: dragnet-ransomware-2020-0130 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: ea7ad453-b113-5b0d-80c1-8fb5442f7f12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
