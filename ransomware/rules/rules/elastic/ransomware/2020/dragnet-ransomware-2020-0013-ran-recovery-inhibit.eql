// Dragnet [Ransomware]: dragnet-ransomware-2020-0013 — Recovery Inhibition (doppelpaymer)
// Status: deprecated | Level: high | ID: d55708b9-28a6-55e0-91db-e8534aba80fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
