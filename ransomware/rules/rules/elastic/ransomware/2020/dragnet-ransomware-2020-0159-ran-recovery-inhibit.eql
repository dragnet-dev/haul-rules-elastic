// Dragnet [Ransomware]: dragnet-ransomware-2020-0159 — Recovery Inhibition (snake)
// Status: deprecated | Level: high | ID: 06abb7c1-a7da-51a5-a3d0-e8567eb5e684

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
