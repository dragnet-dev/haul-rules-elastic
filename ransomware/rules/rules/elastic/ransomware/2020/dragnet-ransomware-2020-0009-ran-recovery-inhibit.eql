// Dragnet [Ransomware]: dragnet-ransomware-2020-0009 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: 8195388c-5d17-5787-afd6-5a3c648ad086

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
