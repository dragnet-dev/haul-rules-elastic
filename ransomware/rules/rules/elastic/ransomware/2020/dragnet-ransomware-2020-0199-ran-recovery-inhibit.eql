// Dragnet [Ransomware]: dragnet-ransomware-2020-0199 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: 5521711d-044b-5578-8069-163c2adfd1ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
