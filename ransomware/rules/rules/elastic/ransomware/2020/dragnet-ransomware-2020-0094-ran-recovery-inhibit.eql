// Dragnet [Ransomware]: dragnet-ransomware-2020-0094 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 32342b82-b635-5e41-92c1-cdd23130f2bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
