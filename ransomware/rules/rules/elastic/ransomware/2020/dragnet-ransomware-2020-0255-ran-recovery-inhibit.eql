// Dragnet [Ransomware]: dragnet-ransomware-2020-0255 — Recovery Inhibition (snake)
// Status: deprecated | Level: high | ID: 7c7dc8b3-bb35-5f17-a0ef-5814521b6c23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
