// Dragnet [Ransomware]: dragnet-ransomware-2020-0046 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: 065bf609-3f48-59b5-8031-82a76f584bf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
