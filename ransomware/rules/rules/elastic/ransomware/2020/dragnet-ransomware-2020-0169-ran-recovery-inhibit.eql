// Dragnet [Ransomware]: dragnet-ransomware-2020-0169 — Recovery Inhibition (egregor)
// Status: deprecated | Level: high | ID: 8f1c5bb6-f66a-568d-925e-0d534496590c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
