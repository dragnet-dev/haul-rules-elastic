// Dragnet [Ransomware]: dragnet-ransomware-2020-0157 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 15d8d442-870e-5a26-ad3f-21d9fb8c6c7f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
