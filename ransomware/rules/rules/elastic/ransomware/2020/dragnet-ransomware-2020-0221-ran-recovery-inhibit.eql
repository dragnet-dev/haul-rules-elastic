// Dragnet [Ransomware]: dragnet-ransomware-2020-0221 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 29d3c491-21c5-50bb-b71f-3843687283c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
