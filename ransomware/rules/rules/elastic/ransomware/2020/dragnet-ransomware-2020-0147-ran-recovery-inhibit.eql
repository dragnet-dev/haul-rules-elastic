// Dragnet [Ransomware]: dragnet-ransomware-2020-0147 — Recovery Inhibition (coldlock)
// Status: deprecated | Level: high | ID: 18183819-6861-5230-b29f-9086070fa876

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
