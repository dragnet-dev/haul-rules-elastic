// Dragnet [Ransomware]: dragnet-ransomware-2020-0156 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: e73331f8-3e1e-59c9-9fb8-60caf4bcd362

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
