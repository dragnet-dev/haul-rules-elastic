// Dragnet [Ransomware]: dragnet-ransomware-2020-0215 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: df6ad2a8-d456-54aa-bfcd-c1c7130687d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
