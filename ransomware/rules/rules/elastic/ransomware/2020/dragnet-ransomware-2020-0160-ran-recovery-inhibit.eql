// Dragnet [Ransomware]: dragnet-ransomware-2020-0160 — Recovery Inhibition (doppelpaymer)
// Status: deprecated | Level: high | ID: 35f6127e-5afc-5ce1-8232-b95f046be146

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
