// Dragnet [Ransomware]: dragnet-ransomware-2020-0182 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: e08ae91e-144c-58ed-8811-ef36eee1409d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
