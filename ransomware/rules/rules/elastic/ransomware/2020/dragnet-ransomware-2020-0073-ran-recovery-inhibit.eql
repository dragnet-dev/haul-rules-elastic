// Dragnet [Ransomware]: dragnet-ransomware-2020-0073 — Recovery Inhibition (ransomexx)
// Status: deprecated | Level: high | ID: 514ac63a-9589-5863-9dfa-e4a2eedf2215

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
