// Dragnet [Ransomware]: dragnet-ransomware-2020-0242 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: ec5016af-2a0e-52ef-bd78-6849c0c6c47b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
