// Dragnet [Ransomware]: dragnet-ransomware-2020-0119 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: cd81ce8b-ef03-5f05-9a34-7866ff2cda74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
