// Dragnet [Ransomware]: dragnet-ransomware-2020-0149 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: 41c54aa6-8527-52b6-bd27-26e18396b0f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
