// Dragnet [Ransomware]: dragnet-ransomware-2020-0054 — Recovery Inhibition (netwalker)
// Status: deprecated | Level: high | ID: 514d0045-2639-5977-8379-469c4895a8d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
