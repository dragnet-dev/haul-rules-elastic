// Dragnet [Ransomware]: dragnet-ransomware-2020-0050 — Recovery Inhibition (doppelpaymer)
// Status: deprecated | Level: high | ID: f4da7262-f551-5b34-bf52-64ade182c299

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
