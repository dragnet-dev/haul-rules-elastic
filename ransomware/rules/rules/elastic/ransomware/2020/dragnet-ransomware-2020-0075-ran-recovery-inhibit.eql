// Dragnet [Ransomware]: dragnet-ransomware-2020-0075 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: ea5ae183-8218-54db-be56-17548a419871

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
