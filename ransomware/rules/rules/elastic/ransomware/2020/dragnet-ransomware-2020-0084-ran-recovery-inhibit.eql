// Dragnet [Ransomware]: dragnet-ransomware-2020-0084 — Recovery Inhibition (netwalker)
// Status: deprecated | Level: high | ID: a69ddee6-ab0a-5399-8fe9-0ce1245734bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
