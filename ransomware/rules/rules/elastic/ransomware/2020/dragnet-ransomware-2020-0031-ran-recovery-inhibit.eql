// Dragnet [Ransomware]: dragnet-ransomware-2020-0031 — Recovery Inhibition (agelocker)
// Status: deprecated | Level: high | ID: 18849ee0-c2f5-52ab-940d-7b4b91c2b817

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
