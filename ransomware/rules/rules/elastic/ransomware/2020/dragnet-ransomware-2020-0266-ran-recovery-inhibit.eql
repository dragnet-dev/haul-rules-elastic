// Dragnet [Ransomware]: dragnet-ransomware-2020-0266 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: a3c10f55-c1e9-5ef7-bf96-1d356a7526c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
