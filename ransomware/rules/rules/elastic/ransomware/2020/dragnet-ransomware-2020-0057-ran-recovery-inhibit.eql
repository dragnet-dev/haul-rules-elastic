// Dragnet [Ransomware]: dragnet-ransomware-2020-0057 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: f401b66e-2aac-5673-af0f-73fcd87fe4fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
