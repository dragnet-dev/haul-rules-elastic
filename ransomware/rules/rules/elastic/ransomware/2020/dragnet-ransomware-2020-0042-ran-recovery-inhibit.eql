// Dragnet [Ransomware]: dragnet-ransomware-2020-0042 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 8f15acdb-8ee2-54ca-be59-554ab28e4bba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
