// Dragnet [Ransomware]: dragnet-ransomware-2020-0126 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: 1ccc731c-13bd-51b1-b549-0d14f67d5990

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
