// Dragnet [Ransomware]: dragnet-ransomware-2020-0093 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 8f3bdfd6-4dbb-5ea0-a551-0493cf33fc42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
