// Dragnet [Ransomware]: dragnet-ransomware-2020-0097 — Recovery Inhibition (lorenz)
// Status: deprecated | Level: high | ID: a49f344e-d448-54cf-a060-69c5c4ac7fa1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
