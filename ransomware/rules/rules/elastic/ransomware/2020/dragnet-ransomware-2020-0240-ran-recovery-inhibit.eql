// Dragnet [Ransomware]: dragnet-ransomware-2020-0240 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 38ae9f33-2888-52e4-8bdb-a709ef1cedce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
