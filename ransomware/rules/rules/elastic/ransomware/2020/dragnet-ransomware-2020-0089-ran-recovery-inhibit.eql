// Dragnet [Ransomware]: dragnet-ransomware-2020-0089 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: 22d2d015-f491-5357-ae42-deb9098f8728

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
