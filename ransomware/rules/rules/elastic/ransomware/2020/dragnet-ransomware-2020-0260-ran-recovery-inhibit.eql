// Dragnet [Ransomware]: dragnet-ransomware-2020-0260 — Recovery Inhibition (netwalker)
// Status: deprecated | Level: high | ID: 5802c762-6af3-51de-a225-68cc4119b25d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
