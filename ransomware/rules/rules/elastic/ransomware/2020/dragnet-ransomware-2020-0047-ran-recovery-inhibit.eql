// Dragnet [Ransomware]: dragnet-ransomware-2020-0047 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: a5681602-0d2d-510d-9aa5-d754fe3e46a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
