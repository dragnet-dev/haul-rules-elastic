// Dragnet [Ransomware]: dragnet-ransomware-2020-0250 — Recovery Inhibition (doppelpaymer)
// Status: deprecated | Level: high | ID: 365ccf60-4965-5928-8e1a-386eacc002a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
