// Dragnet [Ransomware]: dragnet-ransomware-2020-0208 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: b3ccf491-a872-5e75-8fbe-fc36fa49428f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
