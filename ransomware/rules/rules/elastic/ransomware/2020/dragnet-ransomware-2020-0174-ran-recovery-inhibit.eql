// Dragnet [Ransomware]: dragnet-ransomware-2020-0174 — Recovery Inhibition (sekhmet)
// Status: deprecated | Level: high | ID: 452fc3c5-be5c-5701-a636-3b8d837198b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
