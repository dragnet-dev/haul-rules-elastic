// Dragnet [Ransomware]: dragnet-ransomware-2020-0247 — Recovery Inhibition (netwalker)
// Status: deprecated | Level: high | ID: 81fa7cb4-e583-5902-ac4d-97d9455b44f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
