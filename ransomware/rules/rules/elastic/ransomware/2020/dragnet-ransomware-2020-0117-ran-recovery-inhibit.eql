// Dragnet [Ransomware]: dragnet-ransomware-2020-0117 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: 23888e52-e762-5e93-ba54-b330e56549c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
