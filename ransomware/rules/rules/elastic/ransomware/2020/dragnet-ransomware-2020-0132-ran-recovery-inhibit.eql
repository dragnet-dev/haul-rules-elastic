// Dragnet [Ransomware]: dragnet-ransomware-2020-0132 — Recovery Inhibition (netwalker)
// Status: deprecated | Level: high | ID: 515e0d75-7b21-5e1d-9d03-8ed1fdbc0e6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
