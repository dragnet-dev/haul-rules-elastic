// Dragnet [Ransomware]: dragnet-ransomware-2020-0220 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: 3e355196-3efd-545c-815f-68955429ba20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
