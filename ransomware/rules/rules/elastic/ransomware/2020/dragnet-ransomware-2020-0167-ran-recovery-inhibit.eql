// Dragnet [Ransomware]: dragnet-ransomware-2020-0167 — Recovery Inhibition (netwalker)
// Status: deprecated | Level: high | ID: 45548a3b-8599-5c87-9ce8-5d79d86d9f6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
