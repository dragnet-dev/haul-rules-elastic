// Dragnet [Ransomware]: dragnet-ransomware-2020-0265 — Recovery Inhibition (netwalker)
// Status: deprecated | Level: high | ID: 627b6a5d-fb41-5b29-93ae-72091079586c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
