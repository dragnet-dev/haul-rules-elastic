// Dragnet [Ransomware]: dragnet-ransomware-2020-0036 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: 0ce790ee-7cab-57c1-a010-e02ff48f07a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
