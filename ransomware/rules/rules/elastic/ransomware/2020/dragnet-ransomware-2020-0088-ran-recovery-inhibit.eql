// Dragnet [Ransomware]: dragnet-ransomware-2020-0088 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 84e7982f-2fed-5b99-baca-72219d896d80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
