// Dragnet [Ransomware]: dragnet-ransomware-2020-0223 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: 5f44bbd6-9e1e-5144-b1ce-a70f76e537f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
