// Dragnet [Ransomware]: dragnet-ransomware-2020-0136 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: 7d999f90-8b97-5f7b-beee-2e949e052130

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
