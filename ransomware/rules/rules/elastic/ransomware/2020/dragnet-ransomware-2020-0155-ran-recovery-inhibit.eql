// Dragnet [Ransomware]: dragnet-ransomware-2020-0155 — Recovery Inhibition (conti)
// Status: deprecated | Level: high | ID: 24f49bba-79c1-540b-b241-166fded4d862

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
