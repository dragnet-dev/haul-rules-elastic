// Dragnet [Ransomware]: dragnet-ransomware-2020-0158 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: bf042795-6f7d-5217-8f9a-cc9dcf6f6744

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
