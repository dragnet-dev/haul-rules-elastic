// Dragnet [Ransomware]: dragnet-ransomware-2020-0137 — Recovery Inhibition (prolock)
// Status: deprecated | Level: high | ID: 9ba35d39-a99f-53f9-90e1-956321020cb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
