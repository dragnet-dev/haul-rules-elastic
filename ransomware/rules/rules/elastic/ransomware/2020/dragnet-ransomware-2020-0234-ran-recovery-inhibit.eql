// Dragnet [Ransomware]: dragnet-ransomware-2020-0234 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: da4eb0d3-f4d8-50c5-8855-c1161356b656

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
