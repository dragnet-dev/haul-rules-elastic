// Dragnet [Ransomware]: dragnet-ransomware-2020-0142 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: 0e30bf07-74fd-542f-9348-51d7fd4647bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
