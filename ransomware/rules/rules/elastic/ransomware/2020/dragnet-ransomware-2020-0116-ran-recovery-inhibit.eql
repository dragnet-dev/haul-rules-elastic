// Dragnet [Ransomware]: dragnet-ransomware-2020-0116 — Recovery Inhibition (suncrypt)
// Status: deprecated | Level: high | ID: dbd9725a-295a-53a4-ab6b-2c35a0ce4af8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
