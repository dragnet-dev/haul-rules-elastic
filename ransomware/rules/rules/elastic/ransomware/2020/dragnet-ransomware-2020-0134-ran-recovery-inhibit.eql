// Dragnet [Ransomware]: dragnet-ransomware-2020-0134 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: 51abac4f-7155-5ae9-8bfb-4e53a63c0b61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
