// Dragnet [Ransomware]: dragnet-ransomware-2020-0099 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 387fb54f-ed71-554e-920e-3f111878c2df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
