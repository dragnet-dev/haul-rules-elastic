// Dragnet [Ransomware]: dragnet-ransomware-2020-0219 — Recovery Inhibition (doppelpaymer)
// Status: deprecated | Level: high | ID: 3cbcff4e-5c5e-5b3f-932f-231b84d22075

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
