// Dragnet [Ransomware]: dragnet-ransomware-2020-0076 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: dd026edf-650b-5f33-8969-96b818d30406

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
