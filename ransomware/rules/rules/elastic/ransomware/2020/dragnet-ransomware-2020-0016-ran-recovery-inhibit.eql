// Dragnet [Ransomware]: dragnet-ransomware-2020-0016 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: 136d4158-a859-5885-affc-369bf9f62cff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
