// Dragnet [Ransomware]: dragnet-ransomware-2020-0043 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 10344df3-6999-5172-8003-a4c25a45e0d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
