// Dragnet [Ransomware]: dragnet-ransomware-2020-0228 — Recovery Inhibition (revil)
// Status: deprecated | Level: high | ID: f3ab473c-2c3b-5833-9532-6833170d7e1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
