// Dragnet [Ransomware]: dragnet-ransomware-2020-0052 — Recovery Inhibition (maze)
// Status: deprecated | Level: high | ID: 1b2cda79-8682-5b63-aeed-0906743ea07f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
