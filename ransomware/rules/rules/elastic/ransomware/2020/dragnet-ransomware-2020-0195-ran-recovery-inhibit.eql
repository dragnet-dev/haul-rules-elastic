// Dragnet [Ransomware]: dragnet-ransomware-2020-0195 — Recovery Inhibition (ragnarlocker)
// Status: deprecated | Level: high | ID: 28606290-bc55-527d-b67e-98f6a4e87ee0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
