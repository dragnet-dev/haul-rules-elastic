// Dragnet [Ransomware]: dragnet-ransomware-2020-0252 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: 99615255-56c5-5059-9a6c-a22092fe0afb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
