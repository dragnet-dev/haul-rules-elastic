// Dragnet [Ransomware]: dragnet-ransomware-2020-0020 — Recovery Inhibition (doppelpaymer)
// Status: deprecated | Level: high | ID: 4eca7bee-0a45-5d3d-991a-d450c262633e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
