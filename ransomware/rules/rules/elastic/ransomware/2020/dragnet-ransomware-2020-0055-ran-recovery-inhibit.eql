// Dragnet [Ransomware]: dragnet-ransomware-2020-0055 — Recovery Inhibition (dispossessor)
// Status: experimental | Level: high | ID: c344f837-df5a-5bb9-ae56-a8dc3aa6be48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
