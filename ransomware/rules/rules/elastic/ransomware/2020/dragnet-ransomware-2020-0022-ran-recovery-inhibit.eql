// Dragnet [Ransomware]: dragnet-ransomware-2020-0022 — Recovery Inhibition (ryuk)
// Status: deprecated | Level: high | ID: e4f1d650-69b9-5089-834f-abea558c46bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
