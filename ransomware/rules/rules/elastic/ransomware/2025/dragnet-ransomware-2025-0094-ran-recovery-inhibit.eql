// Dragnet [Ransomware]: dragnet-ransomware-2025-0094 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: d4e06257-6b5e-50f2-9fd9-0346892d25a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
