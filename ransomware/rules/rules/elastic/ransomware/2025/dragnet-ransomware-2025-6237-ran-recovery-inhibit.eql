// Dragnet [Ransomware]: dragnet-ransomware-2025-6237 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1ecb7558-ca02-5fba-8d0d-0dba34cd37c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
