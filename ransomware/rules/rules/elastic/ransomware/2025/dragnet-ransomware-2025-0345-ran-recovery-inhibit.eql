// Dragnet [Ransomware]: dragnet-ransomware-2025-0345 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 7612cf1c-6f43-50af-8029-9cbcc5732795

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
