// Dragnet [Ransomware]: dragnet-ransomware-2025-2840 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1bf67236-75b6-5bb2-8e4f-49b8a7d03022

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
