// Dragnet [Ransomware]: dragnet-ransomware-2025-3980 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 20b4de95-3275-5033-a077-e4218304bfe2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
