// Dragnet [Ransomware]: dragnet-ransomware-2025-3524 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 6bf9cff0-9b1a-5e81-904b-fe6608a0fb7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
