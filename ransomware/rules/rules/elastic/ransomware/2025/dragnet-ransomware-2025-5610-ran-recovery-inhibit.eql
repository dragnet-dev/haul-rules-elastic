// Dragnet [Ransomware]: dragnet-ransomware-2025-5610 — Recovery Inhibition (rhysida)
// Status: test | Level: high | ID: 880fc88e-81e8-5cc3-9605-bc06c3f137d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
