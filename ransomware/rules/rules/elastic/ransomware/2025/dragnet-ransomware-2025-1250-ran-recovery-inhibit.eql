// Dragnet [Ransomware]: dragnet-ransomware-2025-1250 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1b9cda36-309a-55c8-a19e-a52a5e129d9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
