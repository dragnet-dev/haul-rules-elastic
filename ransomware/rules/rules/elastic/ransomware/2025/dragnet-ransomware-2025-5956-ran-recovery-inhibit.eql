// Dragnet [Ransomware]: dragnet-ransomware-2025-5956 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e8ee5edd-8e82-5bb5-b932-b32a61ec3a4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
