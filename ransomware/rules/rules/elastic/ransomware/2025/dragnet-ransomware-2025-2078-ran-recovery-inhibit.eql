// Dragnet [Ransomware]: dragnet-ransomware-2025-2078 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 60539224-4b00-5ddd-864f-0c856b1fa05e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
