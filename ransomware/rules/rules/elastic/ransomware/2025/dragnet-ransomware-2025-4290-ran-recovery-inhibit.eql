// Dragnet [Ransomware]: dragnet-ransomware-2025-4290 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 1db6d980-d4aa-53c5-84d9-718746a9c44a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
