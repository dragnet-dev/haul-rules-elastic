// Dragnet [Ransomware]: dragnet-ransomware-2025-3061 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 38a8b8be-b18e-5578-9a14-044f72cfcf77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
