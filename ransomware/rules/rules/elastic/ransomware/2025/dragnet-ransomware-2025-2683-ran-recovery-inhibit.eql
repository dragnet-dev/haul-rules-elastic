// Dragnet [Ransomware]: dragnet-ransomware-2025-2683 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e5731038-95de-5c7f-8d04-e6cdabccff41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
