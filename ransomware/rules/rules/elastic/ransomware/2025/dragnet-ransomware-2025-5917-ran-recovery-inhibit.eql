// Dragnet [Ransomware]: dragnet-ransomware-2025-5917 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: bf4820a4-396e-57e1-a6d3-bcbf5ea7a872

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
