// Dragnet [Ransomware]: dragnet-ransomware-2025-0829 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 78ef9546-f214-52f1-8fb1-5b6de3b60bed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
