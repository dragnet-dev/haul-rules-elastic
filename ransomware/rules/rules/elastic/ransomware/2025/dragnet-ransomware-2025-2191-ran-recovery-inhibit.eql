// Dragnet [Ransomware]: dragnet-ransomware-2025-2191 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: f3f260c3-aa07-5db5-b83b-f81d47db98e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
