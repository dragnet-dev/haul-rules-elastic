// Dragnet [Ransomware]: dragnet-ransomware-2025-4943 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: 2491f46a-34b7-5d0d-9238-b1d3a22c4c0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
