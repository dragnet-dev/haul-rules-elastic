// Dragnet [Ransomware]: dragnet-ransomware-2025-6582 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 0dbc55c8-94fc-5411-8c25-afeec2d744a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
