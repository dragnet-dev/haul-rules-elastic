// Dragnet [Ransomware]: dragnet-ransomware-2025-2706 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: cd32e930-f490-5ea7-bbbc-8b3a5538f37f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
