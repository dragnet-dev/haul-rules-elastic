// Dragnet [Ransomware]: dragnet-ransomware-2025-7751 — Recovery Inhibition (payoutsking)
// Status: deprecated | Level: high | ID: b197a4f2-19f1-528b-9b92-c037cb56a6fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
