// Dragnet [Ransomware]: dragnet-ransomware-2025-4645 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 56c5ac87-623c-56e7-9a6f-0e0737fcb9b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
