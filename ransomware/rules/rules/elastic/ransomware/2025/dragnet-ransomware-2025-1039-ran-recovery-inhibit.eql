// Dragnet [Ransomware]: dragnet-ransomware-2025-1039 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 4046dc5b-7e24-56e7-83fb-18469b8c2bd0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
