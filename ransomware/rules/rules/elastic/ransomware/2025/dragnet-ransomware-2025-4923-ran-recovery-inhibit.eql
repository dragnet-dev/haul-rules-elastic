// Dragnet [Ransomware]: dragnet-ransomware-2025-4923 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 99afd321-bd03-51e7-bacd-6a8172bf3ba5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
