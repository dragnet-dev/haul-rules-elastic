// Dragnet [Ransomware]: dragnet-ransomware-2025-1454 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 296aaefb-904f-5c03-936a-7af09b546cd6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
