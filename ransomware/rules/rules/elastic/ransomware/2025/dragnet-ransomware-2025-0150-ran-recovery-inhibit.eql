// Dragnet [Ransomware]: dragnet-ransomware-2025-0150 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: ad66c4ab-fe2f-5bf0-a5cb-d9f083fd456f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
