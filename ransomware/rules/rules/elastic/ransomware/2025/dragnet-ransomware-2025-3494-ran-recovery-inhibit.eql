// Dragnet [Ransomware]: dragnet-ransomware-2025-3494 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 213abc4b-6826-56f7-8dbb-e97d7c32bca2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
