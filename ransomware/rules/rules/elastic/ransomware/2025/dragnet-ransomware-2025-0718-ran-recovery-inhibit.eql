// Dragnet [Ransomware]: dragnet-ransomware-2025-0718 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: edaee40f-7f87-5c24-bf30-c1019b923504

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
