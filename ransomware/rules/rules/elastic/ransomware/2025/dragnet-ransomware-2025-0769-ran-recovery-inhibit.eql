// Dragnet [Ransomware]: dragnet-ransomware-2025-0769 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: 9e8adfd8-bbbb-52a1-99b2-ee768b7a1ec7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
