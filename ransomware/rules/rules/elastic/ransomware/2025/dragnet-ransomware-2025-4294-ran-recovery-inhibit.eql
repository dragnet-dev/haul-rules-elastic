// Dragnet [Ransomware]: dragnet-ransomware-2025-4294 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 2208ed38-7bef-5115-97a7-22ab037d194a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
