// Dragnet [Ransomware]: dragnet-ransomware-2025-5110 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: abe82a22-6a26-58b1-ae10-a2612aa81147

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
