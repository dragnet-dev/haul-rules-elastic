// Dragnet [Ransomware]: dragnet-ransomware-2025-2210 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 3920e790-3fcd-5778-bffc-4c52bcde2ff0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
