// Dragnet [Ransomware]: dragnet-ransomware-2025-0264 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 1208fdf2-e8bf-5991-bab4-a8d467423831

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
