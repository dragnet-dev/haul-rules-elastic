// Dragnet [Ransomware]: dragnet-ransomware-2025-1522 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: dd784ba6-2cd1-5d20-b49a-aa9c63dff1ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
