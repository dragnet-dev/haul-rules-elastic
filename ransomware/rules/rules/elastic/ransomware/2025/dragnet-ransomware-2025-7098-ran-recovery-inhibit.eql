// Dragnet [Ransomware]: dragnet-ransomware-2025-7098 — Recovery Inhibition (blackshrantac)
// Status: experimental | Level: high | ID: 4a002684-ad46-529c-8c26-bf5b46d44504

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
