// Dragnet [Ransomware]: dragnet-ransomware-2025-1205 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 32d657d3-06f2-55aa-a925-05da682e099a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
