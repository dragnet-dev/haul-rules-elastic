// Dragnet [Ransomware]: dragnet-ransomware-2025-6387 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 71dbc679-b2e0-51a2-825f-0136eb1bf772

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
