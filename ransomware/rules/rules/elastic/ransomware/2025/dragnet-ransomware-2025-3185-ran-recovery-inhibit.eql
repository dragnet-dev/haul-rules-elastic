// Dragnet [Ransomware]: dragnet-ransomware-2025-3185 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8401816e-70a8-58f1-8ff1-51ffe285a50e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
