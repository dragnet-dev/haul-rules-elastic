// Dragnet [Ransomware]: dragnet-ransomware-2025-0953 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e63411e4-5a64-5fa4-87d4-22b6521c68ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
