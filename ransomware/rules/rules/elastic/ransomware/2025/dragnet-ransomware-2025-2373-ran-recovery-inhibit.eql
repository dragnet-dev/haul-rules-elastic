// Dragnet [Ransomware]: dragnet-ransomware-2025-2373 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 80af5bc7-e47b-5928-867e-5d30887fba8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
