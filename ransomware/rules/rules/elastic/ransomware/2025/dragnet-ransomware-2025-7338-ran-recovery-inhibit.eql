// Dragnet [Ransomware]: dragnet-ransomware-2025-7338 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 612cfb72-064d-5077-981c-c7eaaec69f5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
