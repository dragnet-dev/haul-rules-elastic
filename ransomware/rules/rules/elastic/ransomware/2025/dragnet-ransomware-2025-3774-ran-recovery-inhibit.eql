// Dragnet [Ransomware]: dragnet-ransomware-2025-3774 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9ac05b5b-102f-5342-91c9-9c0c979c7f8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
