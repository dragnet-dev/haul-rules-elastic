// Dragnet [Ransomware]: dragnet-ransomware-2025-4239 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a61c039e-1508-5970-b0f7-6ce5a66506c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
