// Dragnet [Ransomware]: dragnet-ransomware-2025-6087 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 79292175-fea4-5f54-9f31-2fa3c1480094

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
