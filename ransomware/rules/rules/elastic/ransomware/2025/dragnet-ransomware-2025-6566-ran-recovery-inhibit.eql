// Dragnet [Ransomware]: dragnet-ransomware-2025-6566 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 52ce5526-8c9f-5dde-a8a1-e0aa5dc1b19a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
