// Dragnet [Ransomware]: dragnet-ransomware-2025-5400 — Recovery Inhibition (lunalock)
// Status: experimental | Level: high | ID: 4246726b-d364-5268-8fea-8650381f7608

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
