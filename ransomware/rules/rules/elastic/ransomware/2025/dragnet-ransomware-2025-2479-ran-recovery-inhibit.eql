// Dragnet [Ransomware]: dragnet-ransomware-2025-2479 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: d10557fa-1219-5f42-a06c-8bc30b1d7cd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
