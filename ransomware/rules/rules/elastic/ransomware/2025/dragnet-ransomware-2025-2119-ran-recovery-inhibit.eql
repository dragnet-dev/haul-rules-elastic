// Dragnet [Ransomware]: dragnet-ransomware-2025-2119 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: aae4acb7-41b5-5f1a-b61e-89901105af45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
