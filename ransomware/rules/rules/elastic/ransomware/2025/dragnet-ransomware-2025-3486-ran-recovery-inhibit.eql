// Dragnet [Ransomware]: dragnet-ransomware-2025-3486 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 78af07f4-889b-50f8-993c-306c76bf3388

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
