// Dragnet [Ransomware]: dragnet-ransomware-2025-3857 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: d4272f41-ae60-5d11-9812-f955feb245a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
