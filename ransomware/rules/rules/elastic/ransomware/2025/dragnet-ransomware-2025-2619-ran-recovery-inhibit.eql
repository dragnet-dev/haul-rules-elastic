// Dragnet [Ransomware]: dragnet-ransomware-2025-2619 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 3318ea36-298a-5d54-8347-3544fa557a85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
