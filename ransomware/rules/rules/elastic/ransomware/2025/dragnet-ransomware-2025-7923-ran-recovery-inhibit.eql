// Dragnet [Ransomware]: dragnet-ransomware-2025-7923 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 40b6813f-dbc7-5d77-8073-9fa6342c8f6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
