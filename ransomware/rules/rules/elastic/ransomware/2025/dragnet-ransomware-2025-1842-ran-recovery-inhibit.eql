// Dragnet [Ransomware]: dragnet-ransomware-2025-1842 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 89e17848-0389-56db-8976-2447750e7b83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
