// Dragnet [Ransomware]: dragnet-ransomware-2025-6644 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: ca4d2ff1-f782-505e-93e6-e88be0e6ba6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
