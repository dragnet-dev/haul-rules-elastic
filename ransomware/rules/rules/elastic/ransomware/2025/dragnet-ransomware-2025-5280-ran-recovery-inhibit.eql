// Dragnet [Ransomware]: dragnet-ransomware-2025-5280 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7ef8e791-7e99-5771-b683-85a52bbf09e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
