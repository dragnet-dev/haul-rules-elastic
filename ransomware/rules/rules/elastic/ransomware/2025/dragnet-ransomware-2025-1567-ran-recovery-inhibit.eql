// Dragnet [Ransomware]: dragnet-ransomware-2025-1567 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: bc300bc0-819e-5ed8-9013-85955d5028fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
