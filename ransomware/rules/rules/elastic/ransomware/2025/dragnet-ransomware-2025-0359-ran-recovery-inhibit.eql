// Dragnet [Ransomware]: dragnet-ransomware-2025-0359 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 6724c6de-cdb3-525a-be63-7ce6c86a3c83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
