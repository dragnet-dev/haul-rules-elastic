// Dragnet [Ransomware]: dragnet-ransomware-2025-3713 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 8fda7fd4-ef78-5ea0-a39c-959c15a6ed66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
