// Dragnet [Ransomware]: dragnet-ransomware-2025-6085 — Recovery Inhibition (crazyhunter)
// Status: experimental | Level: high | ID: a4f42fd2-d03b-514e-8f79-fa095a125fc1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
