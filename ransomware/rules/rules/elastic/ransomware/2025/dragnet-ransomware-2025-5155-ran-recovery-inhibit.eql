// Dragnet [Ransomware]: dragnet-ransomware-2025-5155 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2a6da244-3dbe-5b7f-89b9-e9e57959afcf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
