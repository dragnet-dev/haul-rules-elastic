// Dragnet [Ransomware]: dragnet-ransomware-2025-0527 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: 230bcf42-91c1-590f-99e9-cfaa06909b9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
