// Dragnet [Ransomware]: dragnet-ransomware-2025-6159 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 0a022a55-e8ff-59cd-a00d-8cc158520cc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
