// Dragnet [Ransomware]: dragnet-ransomware-2025-7811 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e7adf847-f1fd-5a60-8c82-c18f596c569d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
