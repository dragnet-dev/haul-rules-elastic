// Dragnet [Ransomware]: dragnet-ransomware-2025-5242 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 981729f8-2d54-5170-b42d-77829a19596c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
