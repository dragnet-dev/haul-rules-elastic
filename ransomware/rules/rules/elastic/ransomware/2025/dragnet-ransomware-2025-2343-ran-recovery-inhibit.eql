// Dragnet [Ransomware]: dragnet-ransomware-2025-2343 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 6df6b328-a704-5be3-b0bd-a0ebd1d326db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
