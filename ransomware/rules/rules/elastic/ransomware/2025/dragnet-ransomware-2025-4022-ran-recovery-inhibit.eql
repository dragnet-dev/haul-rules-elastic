// Dragnet [Ransomware]: dragnet-ransomware-2025-4022 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 8982a95a-bacc-52f3-a702-063712573967

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
