// Dragnet [Ransomware]: dragnet-ransomware-2025-3023 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f49f7060-581b-5d71-ba57-1d3d61bef139

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
