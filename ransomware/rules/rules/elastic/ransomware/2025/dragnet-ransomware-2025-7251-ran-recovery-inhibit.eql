// Dragnet [Ransomware]: dragnet-ransomware-2025-7251 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: cc0b79ef-6150-5b47-87c8-5bffbfd20c0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
