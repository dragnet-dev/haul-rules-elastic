// Dragnet [Ransomware]: dragnet-ransomware-2025-1817 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4d82a66c-1b44-583b-8aec-af3965d759fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
