// Dragnet [Ransomware]: dragnet-ransomware-2025-4787 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: a7c3be93-37f6-50f3-a825-150bd87518ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
