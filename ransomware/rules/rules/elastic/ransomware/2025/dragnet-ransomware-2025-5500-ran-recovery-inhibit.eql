// Dragnet [Ransomware]: dragnet-ransomware-2025-5500 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: e743fa74-d7df-5ce4-9ca2-64b9322b93ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
