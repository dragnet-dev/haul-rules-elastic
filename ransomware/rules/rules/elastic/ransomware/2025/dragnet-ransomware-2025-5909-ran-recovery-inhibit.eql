// Dragnet [Ransomware]: dragnet-ransomware-2025-5909 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 343f5b04-2172-531a-aaa6-320c5b7441a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
