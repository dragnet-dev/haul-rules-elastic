// Dragnet [Ransomware]: dragnet-ransomware-2025-1007 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b1ea7f93-dda3-509d-bcec-bc686240bc63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
