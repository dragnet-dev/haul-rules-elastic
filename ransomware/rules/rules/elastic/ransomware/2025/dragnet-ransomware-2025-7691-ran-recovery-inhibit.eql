// Dragnet [Ransomware]: dragnet-ransomware-2025-7691 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 92d53b28-d61d-5475-91aa-15497850e58f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
