// Dragnet [Ransomware]: dragnet-ransomware-2025-6438 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: 133a527a-6a94-563d-a5f3-ba233afdf5dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
