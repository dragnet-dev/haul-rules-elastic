// Dragnet [Ransomware]: dragnet-ransomware-2025-6138 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 00fbc8ac-98a0-5c51-8daa-4f2b91a252da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
