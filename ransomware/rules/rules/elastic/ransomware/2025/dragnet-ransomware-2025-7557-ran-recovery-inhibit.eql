// Dragnet [Ransomware]: dragnet-ransomware-2025-7557 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: b1d7d772-02f9-5851-9ed9-9a89b957d86d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
