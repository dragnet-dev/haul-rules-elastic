// Dragnet [Ransomware]: dragnet-ransomware-2025-3257 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 970f2916-3975-50f8-b207-f4381011e690

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
