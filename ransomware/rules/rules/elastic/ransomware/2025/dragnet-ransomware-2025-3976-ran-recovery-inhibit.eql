// Dragnet [Ransomware]: dragnet-ransomware-2025-3976 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 5ae845de-10c1-523a-8570-1c6caeb307fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
