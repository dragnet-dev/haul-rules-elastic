// Dragnet [Ransomware]: dragnet-ransomware-2025-3155 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 535915bd-2990-5ab5-b840-82eb90aa1cb2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
