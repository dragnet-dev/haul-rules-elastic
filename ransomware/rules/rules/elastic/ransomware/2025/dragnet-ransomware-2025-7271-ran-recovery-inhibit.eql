// Dragnet [Ransomware]: dragnet-ransomware-2025-7271 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 4aa57fe5-b148-5364-a4a0-410644b048d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
