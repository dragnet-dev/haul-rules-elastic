// Dragnet [Ransomware]: dragnet-ransomware-2025-3261 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4fdb6b53-710d-5764-a433-57bda312dc28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
