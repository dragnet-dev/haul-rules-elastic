// Dragnet [Ransomware]: dragnet-ransomware-2025-4433 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: 244af178-7442-56d0-ab00-31822d943ac6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
