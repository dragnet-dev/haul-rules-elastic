// Dragnet [Ransomware]: dragnet-ransomware-2025-0058 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: e04f162b-3f8c-56c6-bcf3-763758a88bee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
