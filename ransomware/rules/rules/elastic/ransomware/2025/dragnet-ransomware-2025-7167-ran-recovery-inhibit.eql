// Dragnet [Ransomware]: dragnet-ransomware-2025-7167 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 36a51192-b474-5d5c-977b-8f800e9d257c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
