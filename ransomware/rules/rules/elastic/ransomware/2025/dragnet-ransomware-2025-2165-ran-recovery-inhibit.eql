// Dragnet [Ransomware]: dragnet-ransomware-2025-2165 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 89fe4296-ffa5-5212-8373-98969467d1f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
