// Dragnet [Ransomware]: dragnet-ransomware-2025-3398 — Recovery Inhibition (direwolf)
// Status: test | Level: high | ID: c971e64b-4b2c-5aac-a374-464312cd8557

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
