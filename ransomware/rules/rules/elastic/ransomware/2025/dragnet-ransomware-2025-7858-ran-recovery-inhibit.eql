// Dragnet [Ransomware]: dragnet-ransomware-2025-7858 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 06cc7539-3f78-52a5-a384-52c779b98519

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
