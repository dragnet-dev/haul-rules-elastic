// Dragnet [Ransomware]: dragnet-ransomware-2025-3659 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 024a4c33-987c-5f90-a8e5-31766cd45237

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
