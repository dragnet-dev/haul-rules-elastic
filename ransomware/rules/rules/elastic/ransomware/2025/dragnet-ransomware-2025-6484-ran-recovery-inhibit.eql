// Dragnet [Ransomware]: dragnet-ransomware-2025-6484 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 46d6f09f-0ef3-5560-b864-24420aa69481

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
