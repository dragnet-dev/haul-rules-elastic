// Dragnet [Ransomware]: dragnet-ransomware-2025-6822 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 6d7decda-7bd4-5991-8c94-935b0be91f90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
