// Dragnet [Ransomware]: dragnet-ransomware-2025-4025 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3e0658cd-b6a1-52f7-b131-84770a33c503

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
