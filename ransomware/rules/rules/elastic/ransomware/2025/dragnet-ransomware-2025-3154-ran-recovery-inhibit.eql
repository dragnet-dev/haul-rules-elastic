// Dragnet [Ransomware]: dragnet-ransomware-2025-3154 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: a323b695-e50a-5941-867a-a716e479f608

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
