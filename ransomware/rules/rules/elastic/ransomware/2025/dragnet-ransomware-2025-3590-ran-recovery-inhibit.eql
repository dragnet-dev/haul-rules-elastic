// Dragnet [Ransomware]: dragnet-ransomware-2025-3590 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 40d6de8b-c116-5a26-b037-c5cc732ba2c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
