// Dragnet [Ransomware]: dragnet-ransomware-2025-2743 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 824d1355-b71e-5c4b-91c5-cd84bce7f22a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
