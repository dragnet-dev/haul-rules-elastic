// Dragnet [Ransomware]: dragnet-ransomware-2025-1632 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 07793844-8e2b-5cab-8fb4-a7da9796bde6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
