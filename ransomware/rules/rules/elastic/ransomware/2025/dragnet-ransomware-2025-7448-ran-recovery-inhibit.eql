// Dragnet [Ransomware]: dragnet-ransomware-2025-7448 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 3c0115cf-bf1c-5b9d-b848-34d4dc4d8b6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
