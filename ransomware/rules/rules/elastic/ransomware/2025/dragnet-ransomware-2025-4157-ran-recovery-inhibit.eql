// Dragnet [Ransomware]: dragnet-ransomware-2025-4157 — Recovery Inhibition (kraken)
// Status: experimental | Level: high | ID: 77b9dd0e-74dd-593f-84fc-ab8efdbfe24a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
