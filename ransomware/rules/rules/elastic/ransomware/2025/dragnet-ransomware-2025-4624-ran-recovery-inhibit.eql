// Dragnet [Ransomware]: dragnet-ransomware-2025-4624 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: d5f6ab88-1533-5dec-8870-da0eaaa61e56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
