// Dragnet [Ransomware]: dragnet-ransomware-2025-7314 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a8934ef0-9191-5229-8a8f-499abddd5b3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
