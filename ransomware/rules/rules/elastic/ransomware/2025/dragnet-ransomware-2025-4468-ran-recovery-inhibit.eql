// Dragnet [Ransomware]: dragnet-ransomware-2025-4468 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 286c198a-41b0-573e-a635-88ee32a42af3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
