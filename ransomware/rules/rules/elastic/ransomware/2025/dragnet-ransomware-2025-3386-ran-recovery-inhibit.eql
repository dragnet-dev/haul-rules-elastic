// Dragnet [Ransomware]: dragnet-ransomware-2025-3386 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 2f8b7fe5-3ae2-5571-865c-e38ad39c168e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
