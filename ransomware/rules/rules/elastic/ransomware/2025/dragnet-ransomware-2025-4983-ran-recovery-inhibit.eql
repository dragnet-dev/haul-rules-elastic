// Dragnet [Ransomware]: dragnet-ransomware-2025-4983 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: 13ad481f-2620-50c5-8010-23e2ac4ff2e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
