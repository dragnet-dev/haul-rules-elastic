// Dragnet [Ransomware]: dragnet-ransomware-2025-3827 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 7bec14b2-20b9-59c6-8fd9-3f1912ff2623

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
