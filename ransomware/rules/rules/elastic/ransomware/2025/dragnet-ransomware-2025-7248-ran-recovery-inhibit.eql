// Dragnet [Ransomware]: dragnet-ransomware-2025-7248 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 6ee01b80-9344-5e5b-8959-815f0f4d8716

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
