// Dragnet [Ransomware]: dragnet-ransomware-2025-0991 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b96170d3-6daa-5877-bc01-d8bd6af0df29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
