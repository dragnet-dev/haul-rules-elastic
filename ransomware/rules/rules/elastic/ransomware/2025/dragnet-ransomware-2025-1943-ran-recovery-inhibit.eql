// Dragnet [Ransomware]: dragnet-ransomware-2025-1943 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 8e7743d9-5197-5ee3-bffc-dd12e527e286

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
