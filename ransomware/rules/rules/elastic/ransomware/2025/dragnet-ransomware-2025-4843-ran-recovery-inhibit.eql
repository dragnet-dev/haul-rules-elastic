// Dragnet [Ransomware]: dragnet-ransomware-2025-4843 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 731c51aa-a924-5835-a04c-1c99b055ca5d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
