// Dragnet [Ransomware]: dragnet-ransomware-2025-3503 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9d69d107-0499-5ca4-aa5f-4ab77a2b018b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
