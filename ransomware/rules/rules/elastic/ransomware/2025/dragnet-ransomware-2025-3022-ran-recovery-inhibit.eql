// Dragnet [Ransomware]: dragnet-ransomware-2025-3022 — Recovery Inhibition (blackshrantac)
// Status: experimental | Level: high | ID: 4226971b-ed5e-5ba5-976f-bf81b477e2c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
