// Dragnet [Ransomware]: dragnet-ransomware-2025-2858 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 24d5ff4c-8312-5067-abbb-e0674dcc3d28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
