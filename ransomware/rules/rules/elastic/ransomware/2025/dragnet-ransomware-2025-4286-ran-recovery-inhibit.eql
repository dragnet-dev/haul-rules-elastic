// Dragnet [Ransomware]: dragnet-ransomware-2025-4286 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b8730a79-84df-5b36-bd67-c7ba0cc9638c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
