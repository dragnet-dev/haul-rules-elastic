// Dragnet [Ransomware]: dragnet-ransomware-2025-4604 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 52fb9d9d-9329-5ae8-ba37-9ed6f8afcb89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
