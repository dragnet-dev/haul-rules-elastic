// Dragnet [Ransomware]: dragnet-ransomware-2025-2987 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5108be9f-4c6e-5bf2-a485-363cbd6cca4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
