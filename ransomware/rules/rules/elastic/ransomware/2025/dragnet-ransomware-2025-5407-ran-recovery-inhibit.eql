// Dragnet [Ransomware]: dragnet-ransomware-2025-5407 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 96f841da-307a-5ea7-9dd4-0c8892c9b285

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
