// Dragnet [Ransomware]: dragnet-ransomware-2025-0233 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: c14f993c-62a9-500a-8e02-6f5e59b6a1df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
