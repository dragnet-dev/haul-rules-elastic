// Dragnet [Ransomware]: dragnet-ransomware-2025-4084 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 2b3a4684-2aab-5bab-a4ab-ca8b2d253032

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
