// Dragnet [Ransomware]: dragnet-ransomware-2025-7654 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f5edf75b-eee2-5fc8-8ec1-b3fb71785ef8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
