// Dragnet [Ransomware]: dragnet-ransomware-2025-2784 — Recovery Inhibition (blackshrantac)
// Status: experimental | Level: high | ID: 60c43fe5-fc3e-5865-a1fe-40560f50523e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
