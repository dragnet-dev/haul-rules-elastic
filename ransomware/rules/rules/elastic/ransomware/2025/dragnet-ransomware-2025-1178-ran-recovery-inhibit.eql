// Dragnet [Ransomware]: dragnet-ransomware-2025-1178 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 551b396a-e409-5fc9-a9ba-52529255ae5e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
