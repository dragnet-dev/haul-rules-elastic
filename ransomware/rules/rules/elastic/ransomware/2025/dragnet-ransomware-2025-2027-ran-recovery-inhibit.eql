// Dragnet [Ransomware]: dragnet-ransomware-2025-2027 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 41c95fd2-4d7c-52f0-bbc8-321fe2ac4167

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
