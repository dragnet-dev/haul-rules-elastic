// Dragnet [Ransomware]: dragnet-ransomware-2025-0496 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 84d66e68-4ad1-56f7-a685-edb1a0844e59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
