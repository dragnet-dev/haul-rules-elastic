// Dragnet [Ransomware]: dragnet-ransomware-2025-2708 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 9c2cd154-be8c-5e10-84aa-3b66ba39d569

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
