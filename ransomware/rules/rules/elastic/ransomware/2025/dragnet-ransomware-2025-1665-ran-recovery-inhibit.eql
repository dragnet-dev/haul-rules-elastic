// Dragnet [Ransomware]: dragnet-ransomware-2025-1665 — Recovery Inhibition (kryptos)
// Status: deprecated | Level: high | ID: b8990227-7807-5412-ac04-d59389a13f75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
