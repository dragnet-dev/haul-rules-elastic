// Dragnet [Ransomware]: dragnet-ransomware-2025-2240 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: 3d4b9c2d-7ca3-520e-895a-3b1e74a71ef1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
