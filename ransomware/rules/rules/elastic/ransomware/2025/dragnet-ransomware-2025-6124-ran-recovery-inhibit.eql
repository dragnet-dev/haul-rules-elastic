// Dragnet [Ransomware]: dragnet-ransomware-2025-6124 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: c9ca0bb2-2eaf-52c0-863b-895132cd3f2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
