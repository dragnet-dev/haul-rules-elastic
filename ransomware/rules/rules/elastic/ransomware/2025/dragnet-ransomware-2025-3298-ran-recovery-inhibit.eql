// Dragnet [Ransomware]: dragnet-ransomware-2025-3298 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: 446ce881-3b1e-5288-b81c-550a999a0ac3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
