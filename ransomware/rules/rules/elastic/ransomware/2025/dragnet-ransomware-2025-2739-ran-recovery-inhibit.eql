// Dragnet [Ransomware]: dragnet-ransomware-2025-2739 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: dfa0d5cd-eee7-5fa0-a816-ff692165d302

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
