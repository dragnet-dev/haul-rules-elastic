// Dragnet [Ransomware]: dragnet-ransomware-2025-5482 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: adfb1da1-9534-5b0c-abeb-2606fc274d75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
