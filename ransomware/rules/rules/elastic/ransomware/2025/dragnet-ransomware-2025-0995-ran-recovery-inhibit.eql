// Dragnet [Ransomware]: dragnet-ransomware-2025-0995 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a30a8b07-221a-53ce-9f65-a242ed125604

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
