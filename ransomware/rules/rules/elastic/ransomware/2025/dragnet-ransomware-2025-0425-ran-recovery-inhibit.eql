// Dragnet [Ransomware]: dragnet-ransomware-2025-0425 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 2929346a-545c-5241-b715-c4990b409825

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
