// Dragnet [Ransomware]: dragnet-ransomware-2025-2015 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: c2cbdefe-af53-5bec-b43f-693f5baf467f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
