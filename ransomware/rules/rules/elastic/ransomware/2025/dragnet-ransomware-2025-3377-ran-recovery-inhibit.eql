// Dragnet [Ransomware]: dragnet-ransomware-2025-3377 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 37aae35d-5005-516e-96c7-a50ec8ea05bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
