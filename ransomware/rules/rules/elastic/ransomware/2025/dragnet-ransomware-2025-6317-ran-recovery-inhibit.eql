// Dragnet [Ransomware]: dragnet-ransomware-2025-6317 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 5b05950e-ad5f-598b-876e-ca5a3bf0f2d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
