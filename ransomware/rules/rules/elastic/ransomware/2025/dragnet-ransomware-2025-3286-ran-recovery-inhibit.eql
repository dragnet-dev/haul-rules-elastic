// Dragnet [Ransomware]: dragnet-ransomware-2025-3286 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2c62ac00-d7ac-5b6f-b4da-de4130989e04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
