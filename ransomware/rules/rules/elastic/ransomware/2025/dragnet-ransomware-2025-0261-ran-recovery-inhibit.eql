// Dragnet [Ransomware]: dragnet-ransomware-2025-0261 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b2afc982-44b4-5f1a-a998-25a196d7458e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
