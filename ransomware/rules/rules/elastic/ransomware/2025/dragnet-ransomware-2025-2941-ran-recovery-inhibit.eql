// Dragnet [Ransomware]: dragnet-ransomware-2025-2941 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 13162bb3-e890-5c6c-b07c-5b92f0e976ad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
