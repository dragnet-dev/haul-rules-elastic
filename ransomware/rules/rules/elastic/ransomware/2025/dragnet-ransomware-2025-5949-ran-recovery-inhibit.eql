// Dragnet [Ransomware]: dragnet-ransomware-2025-5949 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: c34888a6-4a89-5872-8e2b-acaf8a230cfc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
