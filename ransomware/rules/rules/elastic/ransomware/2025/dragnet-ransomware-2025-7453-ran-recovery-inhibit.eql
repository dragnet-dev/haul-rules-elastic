// Dragnet [Ransomware]: dragnet-ransomware-2025-7453 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 855e1fc6-e1b2-52d8-9a99-139aed97bb0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
