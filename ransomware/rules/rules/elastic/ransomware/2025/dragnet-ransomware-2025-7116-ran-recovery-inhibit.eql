// Dragnet [Ransomware]: dragnet-ransomware-2025-7116 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 7d939d30-7215-5ca1-88cc-a978bf6a9617

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
