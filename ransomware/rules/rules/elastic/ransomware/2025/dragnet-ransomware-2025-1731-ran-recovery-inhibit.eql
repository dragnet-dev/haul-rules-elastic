// Dragnet [Ransomware]: dragnet-ransomware-2025-1731 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 390829e7-c432-505a-92ba-b585cfb1956d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
