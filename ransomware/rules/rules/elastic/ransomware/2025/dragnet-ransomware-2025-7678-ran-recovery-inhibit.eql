// Dragnet [Ransomware]: dragnet-ransomware-2025-7678 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b362574f-4893-5130-9792-4b0b00a4c5ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
