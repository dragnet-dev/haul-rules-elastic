// Dragnet [Ransomware]: dragnet-ransomware-2025-0761 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 5438f726-e5f4-5741-890e-d0431acf1617

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
