// Dragnet [Ransomware]: dragnet-ransomware-2025-1767 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 4a64fb4b-897e-5662-bc37-aa7f83422a09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
