// Dragnet [Ransomware]: dragnet-ransomware-2025-2607 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 85f9e55a-5bc6-5e90-9ece-5e5510360e1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
