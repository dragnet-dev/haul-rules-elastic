// Dragnet [Ransomware]: dragnet-ransomware-2025-5559 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 62ad7815-cdb3-581d-a9c0-38e91c10df1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
