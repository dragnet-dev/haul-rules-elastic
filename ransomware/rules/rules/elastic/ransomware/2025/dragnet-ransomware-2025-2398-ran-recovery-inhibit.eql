// Dragnet [Ransomware]: dragnet-ransomware-2025-2398 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 0cc6ba6d-01ff-50ff-b626-c3a6736d584c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
