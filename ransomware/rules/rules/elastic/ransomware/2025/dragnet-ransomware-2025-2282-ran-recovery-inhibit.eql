// Dragnet [Ransomware]: dragnet-ransomware-2025-2282 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 65453fea-8415-51dd-8c48-f6f7e75df37c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
