// Dragnet [Ransomware]: dragnet-ransomware-2025-7840 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 7bfb4d6a-0490-5715-a368-04e80ce31d7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
