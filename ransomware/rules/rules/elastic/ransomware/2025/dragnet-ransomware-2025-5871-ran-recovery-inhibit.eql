// Dragnet [Ransomware]: dragnet-ransomware-2025-5871 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 722e57ff-e7bc-512e-84a6-0fe513819bb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
