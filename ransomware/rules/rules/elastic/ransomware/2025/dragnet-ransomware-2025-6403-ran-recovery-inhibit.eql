// Dragnet [Ransomware]: dragnet-ransomware-2025-6403 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 2c762951-1f46-56db-b73a-2da4a4ff5833

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
