// Dragnet [Ransomware]: dragnet-ransomware-2025-6471 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: add3bddd-c822-5a11-8017-4eac02682f58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
