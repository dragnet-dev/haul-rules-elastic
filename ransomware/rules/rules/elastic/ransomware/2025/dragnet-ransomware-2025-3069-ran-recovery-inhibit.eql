// Dragnet [Ransomware]: dragnet-ransomware-2025-3069 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: bc6aaaa7-e082-5089-8cea-4096c6eebe0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
