// Dragnet [Ransomware]: dragnet-ransomware-2025-4277 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: b8ce755c-c14a-53b6-8e3c-556a6abad89f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
