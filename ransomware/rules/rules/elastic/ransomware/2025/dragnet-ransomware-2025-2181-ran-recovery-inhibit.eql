// Dragnet [Ransomware]: dragnet-ransomware-2025-2181 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 49467ea3-ecfe-5106-9eb5-c42630f962c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
