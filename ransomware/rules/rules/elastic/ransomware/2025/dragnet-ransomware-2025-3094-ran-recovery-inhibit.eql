// Dragnet [Ransomware]: dragnet-ransomware-2025-3094 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fdfb8cd9-6f4c-56f9-96ac-ab09d23d1fc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
