// Dragnet [Ransomware]: dragnet-ransomware-2025-4632 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4d3d20b3-b464-5a7e-99a7-0fdfe303d99d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
