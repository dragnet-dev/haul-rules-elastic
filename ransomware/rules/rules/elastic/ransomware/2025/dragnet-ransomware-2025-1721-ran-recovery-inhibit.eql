// Dragnet [Ransomware]: dragnet-ransomware-2025-1721 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 8c25ef97-8f92-5095-b919-c031dc53ba33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
