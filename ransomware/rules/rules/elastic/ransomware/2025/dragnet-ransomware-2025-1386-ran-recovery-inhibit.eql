// Dragnet [Ransomware]: dragnet-ransomware-2025-1386 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 5e175068-fdd6-5dac-aff8-23899acc00bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
