// Dragnet [Ransomware]: dragnet-ransomware-2025-4550 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 903bbc7b-0f90-5d35-a5c2-2a829e0f5068

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
