// Dragnet [Ransomware]: dragnet-ransomware-2025-7848 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 110b1777-e346-5242-9f47-c070f2cfcdb2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
