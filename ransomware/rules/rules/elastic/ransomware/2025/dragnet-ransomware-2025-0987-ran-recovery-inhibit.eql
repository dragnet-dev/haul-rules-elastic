// Dragnet [Ransomware]: dragnet-ransomware-2025-0987 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 546a8603-132b-50bf-b196-c3a61b6759a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
