// Dragnet [Ransomware]: dragnet-ransomware-2025-4121 — Recovery Inhibition (kraken)
// Status: experimental | Level: high | ID: e91c570c-0e56-59a9-b7fa-9118a3e06724

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
