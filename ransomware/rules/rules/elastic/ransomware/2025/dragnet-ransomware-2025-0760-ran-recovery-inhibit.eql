// Dragnet [Ransomware]: dragnet-ransomware-2025-0760 — Recovery Inhibition (kawa4096)
// Status: experimental | Level: high | ID: 4ca0f20d-4b1d-5ead-929c-e5cd3cce5731

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
