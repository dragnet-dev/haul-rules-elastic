// Dragnet [Ransomware]: dragnet-ransomware-2025-6039 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: f1d3690b-eb14-527c-91fb-037a4baa07ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
