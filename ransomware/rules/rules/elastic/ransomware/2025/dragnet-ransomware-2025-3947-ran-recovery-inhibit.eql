// Dragnet [Ransomware]: dragnet-ransomware-2025-3947 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 1cd17496-80d0-50a4-9e3b-4b0ebbb45882

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
