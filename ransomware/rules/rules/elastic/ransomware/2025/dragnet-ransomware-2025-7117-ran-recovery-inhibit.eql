// Dragnet [Ransomware]: dragnet-ransomware-2025-7117 — Recovery Inhibition (datacarry)
// Status: deprecated | Level: high | ID: 8f7a43a6-66bf-5bfd-b28d-a8b064f6ed30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
