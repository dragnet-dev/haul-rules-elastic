// Dragnet [Ransomware]: dragnet-ransomware-2025-1933 — Recovery Inhibition (IMNCrew)
// Status: experimental | Level: high | ID: d6b9950a-e542-57ba-a262-a6afac444853

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
