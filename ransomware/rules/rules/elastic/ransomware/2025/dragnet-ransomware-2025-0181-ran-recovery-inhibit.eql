// Dragnet [Ransomware]: dragnet-ransomware-2025-0181 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: dba4da15-e6bd-5251-95cd-e5a7e08d581a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
