// Dragnet [Ransomware]: dragnet-ransomware-2025-0550 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 00d585cf-0923-5a1a-9e75-e6916a224783

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
