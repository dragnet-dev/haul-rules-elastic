// Dragnet [Ransomware]: dragnet-ransomware-2025-7902 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 408704ab-f0ab-5049-8601-32cea52db87c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
