// Dragnet [Ransomware]: dragnet-ransomware-2025-2717 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7bcb13a8-1f13-57e5-9012-4ce994d5649f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
