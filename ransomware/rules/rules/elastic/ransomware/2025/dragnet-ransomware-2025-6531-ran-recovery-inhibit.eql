// Dragnet [Ransomware]: dragnet-ransomware-2025-6531 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d1714745-0351-5723-a77b-8c78ea007ec4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
