// Dragnet [Ransomware]: dragnet-ransomware-2025-6464 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: be8d3d1c-4f94-5e49-b6e1-e140f3352493

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
