// Dragnet [Ransomware]: dragnet-ransomware-2025-2147 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c1a5e2bc-4fed-53fe-9609-3fed6a941f49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
