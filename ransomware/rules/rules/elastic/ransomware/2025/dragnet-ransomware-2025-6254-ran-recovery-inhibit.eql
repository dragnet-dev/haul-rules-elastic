// Dragnet [Ransomware]: dragnet-ransomware-2025-6254 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: f76455fd-190b-5ef8-9816-ea7f56140a9c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
