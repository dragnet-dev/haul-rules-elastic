// Dragnet [Ransomware]: dragnet-ransomware-2025-1711 — Recovery Inhibition (insomnia)
// Status: test | Level: high | ID: f66c0d36-625d-5d2b-95b9-ed1f2b433bbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
