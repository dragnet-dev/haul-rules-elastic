// Dragnet [Ransomware]: dragnet-ransomware-2025-3430 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 08308f11-8aa3-576d-9b09-be83cf98db97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
