// Dragnet [Ransomware]: dragnet-ransomware-2025-0492 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 4e336e5e-017f-5957-bfab-2389b483b582

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
