// Dragnet [Ransomware]: dragnet-ransomware-2025-0764 — Recovery Inhibition (kraken)
// Status: experimental | Level: high | ID: 3ff9253e-0d0f-52eb-81a5-b087eee4c58c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
