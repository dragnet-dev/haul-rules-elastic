// Dragnet [Ransomware]: dragnet-ransomware-2025-7807 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: cc8a2533-a472-5e0c-8eb9-4d47990f7155

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
