// Dragnet [Ransomware]: dragnet-ransomware-2025-0364 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 60b3bd50-bbce-5d80-8969-eac94fd59b6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
