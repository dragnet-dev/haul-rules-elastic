// Dragnet [Ransomware]: dragnet-ransomware-2025-6271 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: d6a902c8-06c6-5458-adfd-38e7dad0517e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
