// Dragnet [Ransomware]: dragnet-ransomware-2025-5940 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 6c0e07dc-43b9-519a-b7d1-7ff0c3fc7f61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
