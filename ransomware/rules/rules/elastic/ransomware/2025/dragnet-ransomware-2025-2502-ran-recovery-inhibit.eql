// Dragnet [Ransomware]: dragnet-ransomware-2025-2502 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 9a66911a-464f-5d1c-baf6-29c493c4f6e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
