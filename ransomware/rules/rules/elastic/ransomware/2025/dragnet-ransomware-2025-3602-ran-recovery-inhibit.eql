// Dragnet [Ransomware]: dragnet-ransomware-2025-3602 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 8b2a0c30-6619-592c-b2c6-af7f2d8e2c02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
