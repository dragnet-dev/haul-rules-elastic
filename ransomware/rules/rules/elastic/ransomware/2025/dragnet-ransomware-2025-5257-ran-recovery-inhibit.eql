// Dragnet [Ransomware]: dragnet-ransomware-2025-5257 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 454c5027-3c09-5793-93e9-9989c6327f5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
