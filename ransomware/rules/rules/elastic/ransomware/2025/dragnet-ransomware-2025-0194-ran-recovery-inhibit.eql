// Dragnet [Ransomware]: dragnet-ransomware-2025-0194 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8ef40cee-6f3c-584a-8102-e7639b42511b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
