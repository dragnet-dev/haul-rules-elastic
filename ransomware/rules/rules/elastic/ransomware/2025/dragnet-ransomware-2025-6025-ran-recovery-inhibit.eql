// Dragnet [Ransomware]: dragnet-ransomware-2025-6025 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 913b7715-f292-5861-90c6-47b1db5ead6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
