// Dragnet [Ransomware]: dragnet-ransomware-2025-6287 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: f91d840c-161f-521f-819e-554953aed467

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
