// Dragnet [Ransomware]: dragnet-ransomware-2025-4335 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 92f604b2-e0f5-58ae-a112-24cae1c190cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
