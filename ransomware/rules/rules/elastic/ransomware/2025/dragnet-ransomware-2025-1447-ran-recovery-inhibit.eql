// Dragnet [Ransomware]: dragnet-ransomware-2025-1447 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 17f6faa9-4083-56de-9ccf-f4b7dbd855d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
