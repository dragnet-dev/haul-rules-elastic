// Dragnet [Ransomware]: dragnet-ransomware-2025-6030 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 9ea726b3-f033-5b84-9989-152435947c4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
