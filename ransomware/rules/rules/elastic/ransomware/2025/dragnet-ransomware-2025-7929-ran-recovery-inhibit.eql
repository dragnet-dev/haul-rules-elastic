// Dragnet [Ransomware]: dragnet-ransomware-2025-7929 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 18b15a04-305d-5565-9cf5-c95102800d6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
