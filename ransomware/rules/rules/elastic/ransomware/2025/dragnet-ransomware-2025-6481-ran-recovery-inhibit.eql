// Dragnet [Ransomware]: dragnet-ransomware-2025-6481 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 045aa58c-00aa-5405-8993-08fb8039a507

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
