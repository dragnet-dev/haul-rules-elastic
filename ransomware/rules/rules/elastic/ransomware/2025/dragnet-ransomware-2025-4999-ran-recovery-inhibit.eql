// Dragnet [Ransomware]: dragnet-ransomware-2025-4999 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: eecd91fe-e161-53e6-93ec-b6b5d9d25314

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
