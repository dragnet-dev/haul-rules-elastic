// Dragnet [Ransomware]: dragnet-ransomware-2025-0079 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 1915fbad-ee18-58f4-94f3-9aa04f895e9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
