// Dragnet [Ransomware]: dragnet-ransomware-2025-6238 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 87627196-9350-5782-8190-345630e2c348

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
