// Dragnet [Ransomware]: dragnet-ransomware-2025-4127 — Recovery Inhibition (blackshrantac)
// Status: experimental | Level: high | ID: 07d041e0-8203-5da1-8bc7-7a6c9967bd85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
