// Dragnet [Ransomware]: dragnet-ransomware-2025-7464 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 64db133d-f56a-51f2-bd9f-e0551358fb49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
