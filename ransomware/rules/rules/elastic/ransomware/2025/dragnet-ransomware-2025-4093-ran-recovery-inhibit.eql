// Dragnet [Ransomware]: dragnet-ransomware-2025-4093 — Recovery Inhibition (d4rk4rmy)
// Status: deprecated | Level: high | ID: 3592208d-2818-5378-92d4-35f02eb41e01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
