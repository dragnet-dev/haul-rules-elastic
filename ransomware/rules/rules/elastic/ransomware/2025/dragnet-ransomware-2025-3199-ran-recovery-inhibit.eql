// Dragnet [Ransomware]: dragnet-ransomware-2025-3199 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: 0107988b-bec2-5b7a-995d-b0e1390212be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
