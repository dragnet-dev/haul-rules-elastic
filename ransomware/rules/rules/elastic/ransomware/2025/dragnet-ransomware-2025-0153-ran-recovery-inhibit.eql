// Dragnet [Ransomware]: dragnet-ransomware-2025-0153 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d72c8c22-ea0d-5844-bee0-b9c54f3ecc2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
