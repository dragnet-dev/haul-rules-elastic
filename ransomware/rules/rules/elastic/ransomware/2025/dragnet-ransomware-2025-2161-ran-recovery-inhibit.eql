// Dragnet [Ransomware]: dragnet-ransomware-2025-2161 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 8e0c3d1b-a5c4-5ed9-8aab-429f5d46a24e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
