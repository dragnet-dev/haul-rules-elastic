// Dragnet [Ransomware]: dragnet-ransomware-2025-7099 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d47606a3-78db-566b-8bbd-bc487df329a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
