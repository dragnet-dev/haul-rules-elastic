// Dragnet [Ransomware]: dragnet-ransomware-2025-3116 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 61fc2d46-09d5-5160-ad33-aa05ff659733

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
