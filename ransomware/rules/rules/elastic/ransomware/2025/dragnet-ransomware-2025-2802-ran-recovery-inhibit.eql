// Dragnet [Ransomware]: dragnet-ransomware-2025-2802 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: edf2414a-756c-5df7-8235-df248338c606

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
