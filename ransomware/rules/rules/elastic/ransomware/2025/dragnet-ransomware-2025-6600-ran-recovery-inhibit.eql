// Dragnet [Ransomware]: dragnet-ransomware-2025-6600 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f4231df6-c3a4-5183-8678-99d5e32e7ed8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
