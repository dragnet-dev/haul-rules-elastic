// Dragnet [Ransomware]: dragnet-ransomware-2025-0687 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 706359ce-9f3f-58d0-86e2-e348ad032720

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
