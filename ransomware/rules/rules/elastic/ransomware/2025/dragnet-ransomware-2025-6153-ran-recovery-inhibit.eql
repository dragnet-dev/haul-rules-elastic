// Dragnet [Ransomware]: dragnet-ransomware-2025-6153 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: c2c97ab8-1c75-5340-81a2-dc7e1d57adc0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
