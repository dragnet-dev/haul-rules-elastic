// Dragnet [Ransomware]: dragnet-ransomware-2025-3234 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8d9e5d63-8cc1-59f6-bdf3-a67b2108ae31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
