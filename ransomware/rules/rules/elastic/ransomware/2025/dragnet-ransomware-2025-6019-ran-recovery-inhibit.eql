// Dragnet [Ransomware]: dragnet-ransomware-2025-6019 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 55f406b4-5ffd-5b8e-a5d1-29f1ed77ccd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
