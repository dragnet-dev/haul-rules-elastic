// Dragnet [Ransomware]: dragnet-ransomware-2025-4667 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 5494840c-d0a0-55ab-bc9e-56a35a87b36d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
