// Dragnet [Ransomware]: dragnet-ransomware-2025-5283 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 957d70f5-09e9-5a8a-b548-4dc3aae024ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
