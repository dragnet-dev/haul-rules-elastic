// Dragnet [Ransomware]: dragnet-ransomware-2025-5449 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 114093ab-a6b3-5686-9fb9-111277791028

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
