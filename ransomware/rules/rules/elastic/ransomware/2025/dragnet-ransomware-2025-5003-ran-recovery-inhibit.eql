// Dragnet [Ransomware]: dragnet-ransomware-2025-5003 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 9dc9960c-dd39-58e5-b1e3-5415167ee314

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
