// Dragnet [Ransomware]: dragnet-ransomware-2025-4691 — Recovery Inhibition (qilin)
// Status: deprecated | Level: high | ID: e8af4f92-bd20-56ce-927d-f19e7a81cbe9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
