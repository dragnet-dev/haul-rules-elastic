// Dragnet [Ransomware]: dragnet-ransomware-2025-0329 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6f9f121d-d747-52e4-944c-75719cc26371

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
