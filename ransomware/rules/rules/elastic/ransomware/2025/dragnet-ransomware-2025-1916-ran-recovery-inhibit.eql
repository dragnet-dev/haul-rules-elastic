// Dragnet [Ransomware]: dragnet-ransomware-2025-1916 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3a9bdbfe-6016-53c2-8153-8e7dd1edbacd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
