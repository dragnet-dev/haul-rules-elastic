// Dragnet [Ransomware]: dragnet-ransomware-2025-0443 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 21dc6c97-4cd1-5244-8be8-0a62966414d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
