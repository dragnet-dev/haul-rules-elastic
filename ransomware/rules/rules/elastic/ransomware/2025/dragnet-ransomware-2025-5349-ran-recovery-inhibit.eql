// Dragnet [Ransomware]: dragnet-ransomware-2025-5349 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 3f99d85d-55cf-5ae3-9471-83a28eeccaac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
