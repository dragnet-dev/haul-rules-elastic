// Dragnet [Ransomware]: dragnet-ransomware-2025-6092 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9e891f11-b90a-589b-be4c-3179a023bd8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
