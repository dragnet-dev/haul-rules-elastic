// Dragnet [Ransomware]: dragnet-ransomware-2025-4162 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: ad8851e2-ebca-51b7-9fd6-3067c7a88174

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
