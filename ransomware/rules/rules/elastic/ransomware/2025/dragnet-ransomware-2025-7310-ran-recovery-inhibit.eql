// Dragnet [Ransomware]: dragnet-ransomware-2025-7310 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 19e0aaa1-852d-5c86-a03a-7323c340cac3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
