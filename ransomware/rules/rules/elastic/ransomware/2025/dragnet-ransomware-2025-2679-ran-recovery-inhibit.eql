// Dragnet [Ransomware]: dragnet-ransomware-2025-2679 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: f1426c83-c0c8-5a7d-b867-c3b119fa180c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
