// Dragnet [Ransomware]: dragnet-ransomware-2025-3958 — Recovery Inhibition (tridentlocker)
// Status: experimental | Level: high | ID: 38da6268-7674-53f2-9f1f-a9a8ec0e0808

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
