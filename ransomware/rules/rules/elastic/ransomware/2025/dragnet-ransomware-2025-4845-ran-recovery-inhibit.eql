// Dragnet [Ransomware]: dragnet-ransomware-2025-4845 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 0a639470-378c-5723-8023-50869c434420

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
