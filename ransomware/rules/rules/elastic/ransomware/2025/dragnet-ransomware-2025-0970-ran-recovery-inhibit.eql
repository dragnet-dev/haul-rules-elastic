// Dragnet [Ransomware]: dragnet-ransomware-2025-0970 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 63b351e3-9caf-573b-9a44-381a19e9ff36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
