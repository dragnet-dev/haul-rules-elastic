// Dragnet [Ransomware]: dragnet-ransomware-2025-6146 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 94812097-0cb9-5a93-a805-94f4fad23459

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
