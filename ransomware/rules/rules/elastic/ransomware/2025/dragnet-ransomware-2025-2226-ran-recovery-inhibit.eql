// Dragnet [Ransomware]: dragnet-ransomware-2025-2226 — Recovery Inhibition (fog)
// Status: deprecated | Level: high | ID: 43d633a3-ff5f-5fd0-b17f-7c584a411447

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
