// Dragnet [Ransomware]: dragnet-ransomware-2025-7330 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 2f7fc049-333b-51c3-913c-beb412276aa6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
