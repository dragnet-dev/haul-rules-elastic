// Dragnet [Ransomware]: dragnet-ransomware-2025-4224 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 6b416f06-de1b-5494-9c2f-92cf27e8e46c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
