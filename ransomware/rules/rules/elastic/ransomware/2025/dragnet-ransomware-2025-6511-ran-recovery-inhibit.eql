// Dragnet [Ransomware]: dragnet-ransomware-2025-6511 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 1c8e94a9-f869-5902-aadf-6109d8136928

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
