// Dragnet [Ransomware]: dragnet-ransomware-2025-4789 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: e9b479fe-e14f-598e-8ace-8da3619a1a92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
