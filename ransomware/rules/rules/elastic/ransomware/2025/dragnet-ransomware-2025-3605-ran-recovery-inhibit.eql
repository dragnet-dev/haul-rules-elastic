// Dragnet [Ransomware]: dragnet-ransomware-2025-3605 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: b50b5851-2ae5-55e1-b4d1-6d8149253c86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
