// Dragnet [Ransomware]: dragnet-ransomware-2025-3012 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 34faa8cd-b309-5b98-b7f5-0dc36f79ec40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
