// Dragnet [Ransomware]: dragnet-ransomware-2025-7655 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: eb79cab7-2df0-5d5a-b078-3d68572753ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
