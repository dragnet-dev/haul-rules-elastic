// Dragnet [Ransomware]: dragnet-ransomware-2025-2304 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: db9bc0ff-0774-5fb2-81fc-899b29b3ddf9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
