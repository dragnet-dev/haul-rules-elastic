// Dragnet [Ransomware]: dragnet-ransomware-2025-5662 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fc82b605-2cc8-5654-b592-4a1117fe3209

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
