// Dragnet [Ransomware]: dragnet-ransomware-2025-5381 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 71cc224b-fed7-52aa-ba26-349e81bdbaca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
