// Dragnet [Ransomware]: dragnet-ransomware-2025-2201 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 33327749-9db8-50b4-aa1c-649b2097cf10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
