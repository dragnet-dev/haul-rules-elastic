// Dragnet [Ransomware]: dragnet-ransomware-2025-1238 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: 4e922647-e8ff-5a0f-8b4d-581402fabcc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
