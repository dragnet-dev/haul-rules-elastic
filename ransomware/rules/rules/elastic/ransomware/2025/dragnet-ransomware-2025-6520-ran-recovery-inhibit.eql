// Dragnet [Ransomware]: dragnet-ransomware-2025-6520 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: c287a5d8-3063-5906-9488-0eb81e9d7b3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
