// Dragnet [Ransomware]: dragnet-ransomware-2025-7509 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 599b3dec-b625-5dca-b552-6c5d5ec74027

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
