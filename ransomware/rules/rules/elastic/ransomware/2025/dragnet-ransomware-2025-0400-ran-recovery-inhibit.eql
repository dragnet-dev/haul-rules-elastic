// Dragnet [Ransomware]: dragnet-ransomware-2025-0400 — Recovery Inhibition (obscura)
// Status: experimental | Level: high | ID: 15c7794b-92e4-5c90-b4a2-42951ed4e6d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
