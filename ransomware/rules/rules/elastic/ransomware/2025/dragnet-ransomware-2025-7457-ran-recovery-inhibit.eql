// Dragnet [Ransomware]: dragnet-ransomware-2025-7457 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 3b2f3b93-5766-5acc-8c0b-f519a67596f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
