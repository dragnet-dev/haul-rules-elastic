// Dragnet [Ransomware]: dragnet-ransomware-2025-3203 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 14b693b5-a619-506b-9cfb-e41db343ce51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
