// Dragnet [Ransomware]: dragnet-ransomware-2025-5551 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: ff26b15f-ce6a-55df-bffb-37dd87252f8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
