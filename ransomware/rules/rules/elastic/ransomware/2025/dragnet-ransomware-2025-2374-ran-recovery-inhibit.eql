// Dragnet [Ransomware]: dragnet-ransomware-2025-2374 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: d98a7a9b-895b-5926-ac66-a4d286794d0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
