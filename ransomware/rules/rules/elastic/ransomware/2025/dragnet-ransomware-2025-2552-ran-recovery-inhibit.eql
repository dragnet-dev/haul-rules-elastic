// Dragnet [Ransomware]: dragnet-ransomware-2025-2552 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 8f25ccf9-4998-5119-af55-d6172f0235cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
