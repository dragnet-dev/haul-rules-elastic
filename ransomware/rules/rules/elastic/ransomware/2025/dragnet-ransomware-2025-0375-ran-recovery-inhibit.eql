// Dragnet [Ransomware]: dragnet-ransomware-2025-0375 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 5bc9513b-44ef-53eb-b982-200b186071a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
