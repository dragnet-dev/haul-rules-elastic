// Dragnet [Ransomware]: dragnet-ransomware-2025-4452 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d5d2924b-c2c6-5a18-8537-61f4c5762fc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
