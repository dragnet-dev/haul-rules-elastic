// Dragnet [Ransomware]: dragnet-ransomware-2025-5929 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 89063ba5-8602-5538-81b8-eb3bfe8cb2d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
