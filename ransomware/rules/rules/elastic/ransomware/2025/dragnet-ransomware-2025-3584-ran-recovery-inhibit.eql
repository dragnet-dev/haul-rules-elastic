// Dragnet [Ransomware]: dragnet-ransomware-2025-3584 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 57f05b45-dbc6-5755-967d-158a8697535e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
