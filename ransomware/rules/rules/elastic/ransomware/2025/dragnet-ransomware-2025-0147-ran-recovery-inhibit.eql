// Dragnet [Ransomware]: dragnet-ransomware-2025-0147 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 6c708a84-ccb8-59e8-94d7-a76a7075376b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
