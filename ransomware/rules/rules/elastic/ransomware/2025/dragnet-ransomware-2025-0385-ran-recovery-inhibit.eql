// Dragnet [Ransomware]: dragnet-ransomware-2025-0385 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 77f7a4c6-1370-51de-8f05-f2bb99650d04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
