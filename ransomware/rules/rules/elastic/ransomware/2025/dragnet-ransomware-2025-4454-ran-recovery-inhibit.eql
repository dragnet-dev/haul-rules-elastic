// Dragnet [Ransomware]: dragnet-ransomware-2025-4454 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: e7bd0c6b-a121-51e6-b1c5-972ac7c5d2b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
