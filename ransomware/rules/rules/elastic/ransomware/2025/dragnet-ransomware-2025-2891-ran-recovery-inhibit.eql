// Dragnet [Ransomware]: dragnet-ransomware-2025-2891 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 764269c7-a602-5d84-b3ea-d8dc54fcb145

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
