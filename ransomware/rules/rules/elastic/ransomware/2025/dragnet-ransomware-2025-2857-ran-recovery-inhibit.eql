// Dragnet [Ransomware]: dragnet-ransomware-2025-2857 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 63fd8b9f-794e-5d12-865b-d72346157a81

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
