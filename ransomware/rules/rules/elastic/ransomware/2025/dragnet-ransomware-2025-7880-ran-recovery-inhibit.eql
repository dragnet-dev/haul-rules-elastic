// Dragnet [Ransomware]: dragnet-ransomware-2025-7880 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 6033bc4c-52f7-507e-8ba0-00902ffa4baa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
