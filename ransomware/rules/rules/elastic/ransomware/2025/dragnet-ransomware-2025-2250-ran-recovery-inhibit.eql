// Dragnet [Ransomware]: dragnet-ransomware-2025-2250 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b3ea507c-844e-5027-b6a5-6097b5a2c35f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
