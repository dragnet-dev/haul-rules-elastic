// Dragnet [Ransomware]: dragnet-ransomware-2025-2684 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 27a65130-bddf-5983-afd6-dc196ac9517c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
