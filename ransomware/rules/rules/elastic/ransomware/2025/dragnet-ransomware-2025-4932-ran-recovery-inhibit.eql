// Dragnet [Ransomware]: dragnet-ransomware-2025-4932 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4f07d773-7c23-53de-bc44-846e70432b86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
