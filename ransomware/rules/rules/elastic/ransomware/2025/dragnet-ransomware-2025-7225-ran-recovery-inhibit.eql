// Dragnet [Ransomware]: dragnet-ransomware-2025-7225 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: afeefc7f-afe4-53c1-8cdc-a7f65224c402

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
