// Dragnet [Ransomware]: dragnet-ransomware-2025-5049 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: dbf61575-1fcb-5351-899d-c321c2ad242c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
