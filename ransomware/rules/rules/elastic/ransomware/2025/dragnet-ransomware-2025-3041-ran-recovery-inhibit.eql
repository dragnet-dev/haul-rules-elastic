// Dragnet [Ransomware]: dragnet-ransomware-2025-3041 — Recovery Inhibition (medusa)
// Status: test | Level: high | ID: 730ce9dd-19be-50f7-9461-70a7e0c46ced

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
