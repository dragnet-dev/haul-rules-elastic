// Dragnet [Ransomware]: dragnet-ransomware-2025-2573 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: acc81b8c-433f-5c72-81a1-211b9f03a897

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
