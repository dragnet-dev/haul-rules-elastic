// Dragnet [Ransomware]: dragnet-ransomware-2025-7418 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 7260324c-2645-58bb-a6f0-2e9da8ac7934

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
