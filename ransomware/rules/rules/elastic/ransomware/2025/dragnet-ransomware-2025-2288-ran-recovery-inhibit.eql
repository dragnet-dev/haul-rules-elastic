// Dragnet [Ransomware]: dragnet-ransomware-2025-2288 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 099645fd-dcc1-5ffc-9f73-efa2a920e56f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
