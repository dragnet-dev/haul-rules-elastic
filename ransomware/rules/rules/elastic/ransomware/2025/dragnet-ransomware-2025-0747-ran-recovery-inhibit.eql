// Dragnet [Ransomware]: dragnet-ransomware-2025-0747 — Recovery Inhibition (anubis)
// Status: experimental | Level: high | ID: 81406868-9041-5fbb-aaf4-e5b8da69b729

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
