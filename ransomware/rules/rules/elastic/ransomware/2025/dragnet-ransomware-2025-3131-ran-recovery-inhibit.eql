// Dragnet [Ransomware]: dragnet-ransomware-2025-3131 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 30324d3b-267e-5d9b-81ed-67b5fc842197

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
