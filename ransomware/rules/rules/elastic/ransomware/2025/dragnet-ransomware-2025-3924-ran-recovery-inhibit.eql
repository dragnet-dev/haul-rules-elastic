// Dragnet [Ransomware]: dragnet-ransomware-2025-3924 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 71506e14-7f02-565d-808c-bf337e53eb75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
