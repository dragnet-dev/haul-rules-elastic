// Dragnet [Ransomware]: dragnet-ransomware-2025-6425 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7f81848b-1e07-5ec5-81dc-7bb91d572883

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
