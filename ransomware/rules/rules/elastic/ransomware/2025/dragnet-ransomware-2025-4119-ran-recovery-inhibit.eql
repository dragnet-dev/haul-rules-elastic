// Dragnet [Ransomware]: dragnet-ransomware-2025-4119 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: ca4abbcd-b420-534b-b5a3-a7b7fef4745a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
