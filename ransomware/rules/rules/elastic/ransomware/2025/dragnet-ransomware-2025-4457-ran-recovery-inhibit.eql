// Dragnet [Ransomware]: dragnet-ransomware-2025-4457 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: e58414d6-7797-56b5-878c-af618fe04bb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
