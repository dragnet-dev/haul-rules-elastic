// Dragnet [Ransomware]: dragnet-ransomware-2025-0571 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3f8c5471-df6a-5fe2-b4b9-dddd266aa341

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
