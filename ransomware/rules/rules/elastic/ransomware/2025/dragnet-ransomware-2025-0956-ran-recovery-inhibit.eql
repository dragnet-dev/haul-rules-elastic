// Dragnet [Ransomware]: dragnet-ransomware-2025-0956 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 7a2d11b6-c53b-5e5d-bcfd-7b832878ea6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
