// Dragnet [Ransomware]: dragnet-ransomware-2025-3685 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 52479124-fc2b-5a9f-b89b-1734176bfbc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
