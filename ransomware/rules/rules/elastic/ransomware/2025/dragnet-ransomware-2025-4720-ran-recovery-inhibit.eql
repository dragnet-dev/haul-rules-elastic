// Dragnet [Ransomware]: dragnet-ransomware-2025-4720 — Recovery Inhibition (RunSomeWares)
// Status: experimental | Level: high | ID: e152cc79-b41e-553a-890a-3857d98cfc1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
