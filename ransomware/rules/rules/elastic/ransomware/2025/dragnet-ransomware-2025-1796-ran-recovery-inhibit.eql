// Dragnet [Ransomware]: dragnet-ransomware-2025-1796 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 9c395802-5cba-5233-9e00-112d700b18ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
