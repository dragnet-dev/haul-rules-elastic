// Dragnet [Ransomware]: dragnet-ransomware-2025-1829 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 163d62d5-cbf6-5d84-889c-eb33a4a63250

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
