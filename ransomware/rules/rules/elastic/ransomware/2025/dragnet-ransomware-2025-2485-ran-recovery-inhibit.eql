// Dragnet [Ransomware]: dragnet-ransomware-2025-2485 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 496f0b4b-c18b-5404-a328-6a2ab96f86d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
