// Dragnet [Ransomware]: dragnet-ransomware-2025-0828 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 4a453902-0f8e-57b0-b1d0-b0e551d43a50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
