// Dragnet [Ransomware]: dragnet-ransomware-2025-3727 — Recovery Inhibition (skira)
// Status: experimental | Level: high | ID: 0a195239-a4a8-5704-9222-c6de036a5a55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
