// Dragnet [Ransomware]: dragnet-ransomware-2025-3718 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f41ba93f-5f50-5db9-8c66-20cbef7dce44

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
