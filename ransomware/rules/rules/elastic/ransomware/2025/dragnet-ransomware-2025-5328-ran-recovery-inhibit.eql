// Dragnet [Ransomware]: dragnet-ransomware-2025-5328 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ec00fc4d-ff57-50d8-8227-9dbc3cbeacc4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
