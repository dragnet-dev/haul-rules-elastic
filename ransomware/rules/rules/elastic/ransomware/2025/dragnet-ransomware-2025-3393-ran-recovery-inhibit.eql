// Dragnet [Ransomware]: dragnet-ransomware-2025-3393 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 3dace171-7672-563e-9afd-2163a8bd270f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
