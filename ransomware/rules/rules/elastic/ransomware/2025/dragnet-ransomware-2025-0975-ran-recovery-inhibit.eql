// Dragnet [Ransomware]: dragnet-ransomware-2025-0975 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: a43dc9f5-099f-5bd3-b030-25a1e6aaf6f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
