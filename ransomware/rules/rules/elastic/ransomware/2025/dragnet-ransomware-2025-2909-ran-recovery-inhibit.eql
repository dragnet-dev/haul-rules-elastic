// Dragnet [Ransomware]: dragnet-ransomware-2025-2909 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: 9e93da90-6bbc-51bb-b144-74ee5127f842

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
