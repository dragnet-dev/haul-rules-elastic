// Dragnet [Ransomware]: dragnet-ransomware-2025-3063 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 4045c871-18c9-50f8-aa34-c1d4ef10302d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
