// Dragnet [Ransomware]: dragnet-ransomware-2025-3835 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: 88b7be7c-6be2-5886-96cf-464fb6445bbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
