// Dragnet [Ransomware]: dragnet-ransomware-2025-6973 — Recovery Inhibition (securotrop)
// Status: experimental | Level: high | ID: cabc1c39-2aee-511b-b9d6-49079b92e9b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
