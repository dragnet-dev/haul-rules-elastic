// Dragnet [Ransomware]: dragnet-ransomware-2025-2246 — Recovery Inhibition (hellcat)
// Status: deprecated | Level: high | ID: 22f32a74-fad0-5d15-92cd-c7f9d2828dfd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
