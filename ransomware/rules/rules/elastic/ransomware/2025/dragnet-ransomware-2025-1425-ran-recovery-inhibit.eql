// Dragnet [Ransomware]: dragnet-ransomware-2025-1425 — Recovery Inhibition (gunra)
// Status: experimental | Level: high | ID: 59e68232-2401-57b6-b154-e298b903ff59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
