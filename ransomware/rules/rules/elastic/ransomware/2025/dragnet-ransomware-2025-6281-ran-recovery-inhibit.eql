// Dragnet [Ransomware]: dragnet-ransomware-2025-6281 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: e2a5b129-fb40-5077-8dc4-81419274eb82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
