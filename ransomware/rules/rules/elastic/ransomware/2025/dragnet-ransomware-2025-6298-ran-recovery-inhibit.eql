// Dragnet [Ransomware]: dragnet-ransomware-2025-6298 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 42a72b29-9d13-529c-8432-849ef48e9fab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
