// Dragnet [Ransomware]: dragnet-ransomware-2025-5661 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: cd1499f4-f334-5703-8654-291a07aabd13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
