// Dragnet [Ransomware]: dragnet-ransomware-2025-4059 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 4cdbd055-87ab-540b-9dc8-2c1cba5ebaf5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
