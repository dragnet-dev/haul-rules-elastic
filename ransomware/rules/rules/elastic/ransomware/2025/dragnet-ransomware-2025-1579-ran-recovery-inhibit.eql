// Dragnet [Ransomware]: dragnet-ransomware-2025-1579 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 1950937f-713b-5899-937d-16077e0d898d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
