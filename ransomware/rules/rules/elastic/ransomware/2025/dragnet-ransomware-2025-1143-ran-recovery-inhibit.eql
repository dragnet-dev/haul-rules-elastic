// Dragnet [Ransomware]: dragnet-ransomware-2025-1143 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 400afd22-75b7-5c37-bc19-25b617735cf4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
