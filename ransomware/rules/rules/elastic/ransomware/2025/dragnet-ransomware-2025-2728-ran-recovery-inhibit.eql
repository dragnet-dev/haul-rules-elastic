// Dragnet [Ransomware]: dragnet-ransomware-2025-2728 — Recovery Inhibition (lunalock)
// Status: experimental | Level: high | ID: 2f75ed9d-7208-58ba-82d7-84a02c168694

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
