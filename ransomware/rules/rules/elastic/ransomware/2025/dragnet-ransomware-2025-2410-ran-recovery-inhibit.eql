// Dragnet [Ransomware]: dragnet-ransomware-2025-2410 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: b379e80d-c236-53ea-8eb8-f5e6fc9a3522

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
