// Dragnet [Ransomware]: dragnet-ransomware-2025-0822 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c74296d9-dfc7-5d72-a22e-e47c9c92f8bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
