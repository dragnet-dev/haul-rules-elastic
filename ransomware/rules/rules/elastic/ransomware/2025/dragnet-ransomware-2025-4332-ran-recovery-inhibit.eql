// Dragnet [Ransomware]: dragnet-ransomware-2025-4332 — Recovery Inhibition (crazyhunter)
// Status: experimental | Level: high | ID: 964af573-6245-55c0-a375-93eab6f58295

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
