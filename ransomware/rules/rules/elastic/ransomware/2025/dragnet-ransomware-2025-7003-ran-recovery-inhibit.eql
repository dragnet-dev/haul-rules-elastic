// Dragnet [Ransomware]: dragnet-ransomware-2025-7003 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: 67c2fd67-287f-5b6a-8d45-e262859d74d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
