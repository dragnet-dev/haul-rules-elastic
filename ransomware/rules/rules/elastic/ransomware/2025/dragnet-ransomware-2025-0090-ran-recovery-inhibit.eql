// Dragnet [Ransomware]: dragnet-ransomware-2025-0090 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: a0ade4eb-ecbd-50ba-8882-0645118ea760

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
