// Dragnet [Ransomware]: dragnet-ransomware-2025-4821 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 4621a935-a347-5647-a4ad-ec94ec478901

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
