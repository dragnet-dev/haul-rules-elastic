// Dragnet [Ransomware]: dragnet-ransomware-2025-6033 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: e14c8163-0593-5099-a717-97913442371c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
