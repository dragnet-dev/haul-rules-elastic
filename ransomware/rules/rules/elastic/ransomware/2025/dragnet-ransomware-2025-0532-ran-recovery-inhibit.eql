// Dragnet [Ransomware]: dragnet-ransomware-2025-0532 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 732b3280-8bcd-57b7-bf71-02f186053f22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
