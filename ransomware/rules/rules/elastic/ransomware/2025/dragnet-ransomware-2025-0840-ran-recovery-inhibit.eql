// Dragnet [Ransomware]: dragnet-ransomware-2025-0840 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ef652b09-c731-5592-82a8-f3982c7df531

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
