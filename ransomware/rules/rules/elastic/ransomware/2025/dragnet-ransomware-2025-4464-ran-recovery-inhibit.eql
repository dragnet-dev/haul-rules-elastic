// Dragnet [Ransomware]: dragnet-ransomware-2025-4464 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 993af343-a469-58f6-b347-64911bae726c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
