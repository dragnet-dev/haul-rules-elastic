// Dragnet [Ransomware]: dragnet-ransomware-2025-6143 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: eede26b5-b017-5e76-9023-350226b2fce2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
