// Dragnet [Ransomware]: dragnet-ransomware-2025-3615 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: c3b912b8-91c9-524d-a603-529d9d55436f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
