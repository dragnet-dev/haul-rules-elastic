// Dragnet [Ransomware]: dragnet-ransomware-2025-7808 — Recovery Inhibition (insomnia)
// Status: test | Level: high | ID: 952e3990-5672-5eba-8de5-5e931d9916ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
