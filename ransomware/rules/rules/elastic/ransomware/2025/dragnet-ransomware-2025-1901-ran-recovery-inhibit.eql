// Dragnet [Ransomware]: dragnet-ransomware-2025-1901 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: db356398-a0e8-5b6f-92b0-ed7e47f4627f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
