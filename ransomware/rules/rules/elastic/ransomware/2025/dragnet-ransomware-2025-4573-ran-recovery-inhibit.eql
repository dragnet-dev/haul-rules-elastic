// Dragnet [Ransomware]: dragnet-ransomware-2025-4573 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 7d9b32be-a982-5ae7-80d4-8368991e5805

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
