// Dragnet [Ransomware]: dragnet-ransomware-2025-2710 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 506be6fd-60b9-5df3-95ab-edbdbfc17702

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
