// Dragnet [Ransomware]: dragnet-ransomware-2025-1123 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 70006531-d593-5636-82fe-359412dc90eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
