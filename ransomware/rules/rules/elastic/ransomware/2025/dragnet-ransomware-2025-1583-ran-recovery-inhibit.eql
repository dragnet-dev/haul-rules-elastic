// Dragnet [Ransomware]: dragnet-ransomware-2025-1583 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 8cca1b26-2f1b-5d05-af8c-a5054a9142c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
