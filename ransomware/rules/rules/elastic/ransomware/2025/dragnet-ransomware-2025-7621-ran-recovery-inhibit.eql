// Dragnet [Ransomware]: dragnet-ransomware-2025-7621 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 3e7c2325-8c7f-5034-bc6f-48910ec60a5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
