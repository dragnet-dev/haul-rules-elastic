// Dragnet [Ransomware]: dragnet-ransomware-2025-6722 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 9f64f094-14a9-5820-9305-6e9cf1093a3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
