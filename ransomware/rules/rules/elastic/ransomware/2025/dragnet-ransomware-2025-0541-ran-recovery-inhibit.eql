// Dragnet [Ransomware]: dragnet-ransomware-2025-0541 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 5bf839f7-5932-5848-985f-66b5ec5146d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
