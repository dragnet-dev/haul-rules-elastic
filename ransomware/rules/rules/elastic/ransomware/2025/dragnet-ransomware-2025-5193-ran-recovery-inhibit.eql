// Dragnet [Ransomware]: dragnet-ransomware-2025-5193 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 9f7c6998-9e79-5ca7-9f20-e4d4627debf1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
