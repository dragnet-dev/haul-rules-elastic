// Dragnet [Ransomware]: dragnet-ransomware-2025-1929 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 5d8da812-6f54-583f-82f2-049172a6bc29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
