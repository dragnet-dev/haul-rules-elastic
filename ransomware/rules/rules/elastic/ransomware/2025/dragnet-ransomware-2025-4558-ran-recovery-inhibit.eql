// Dragnet [Ransomware]: dragnet-ransomware-2025-4558 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ec97bf86-268b-5352-90b2-62d0e733dc0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
