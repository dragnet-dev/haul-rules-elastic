// Dragnet [Ransomware]: dragnet-ransomware-2025-1442 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 3e60c51b-b0a1-5f1d-9324-e4d03b3f48f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
