// Dragnet [Ransomware]: dragnet-ransomware-2025-6709 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 6ff896b6-f2c0-5497-b463-66c55ea79ea0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
