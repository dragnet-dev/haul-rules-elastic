// Dragnet [Ransomware]: dragnet-ransomware-2025-0602 — Recovery Inhibition (silent)
// Status: experimental | Level: high | ID: fc87908f-f43a-50ec-b479-e3964ac04249

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
