// Dragnet [Ransomware]: dragnet-ransomware-2025-5030 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 34f4080e-88a2-556a-8e5b-b5092cd84bcc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
