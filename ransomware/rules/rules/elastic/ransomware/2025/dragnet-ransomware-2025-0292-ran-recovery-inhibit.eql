// Dragnet [Ransomware]: dragnet-ransomware-2025-0292 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 38be3747-d8bd-5e33-9fe5-375d18f4e591

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
