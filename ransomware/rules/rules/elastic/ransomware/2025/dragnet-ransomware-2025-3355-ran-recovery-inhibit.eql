// Dragnet [Ransomware]: dragnet-ransomware-2025-3355 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 72c9cb41-0d35-5ee4-a159-be75b039719a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
