// Dragnet [Ransomware]: dragnet-ransomware-2025-5826 — Recovery Inhibition (radar)
// Status: deprecated | Level: high | ID: 7b69ef10-165b-57ef-ba2e-5a70a858c19b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
