// Dragnet [Ransomware]: dragnet-ransomware-2025-0288 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ab98cf1f-4f8d-5222-bfb5-e6874a0d3b00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
