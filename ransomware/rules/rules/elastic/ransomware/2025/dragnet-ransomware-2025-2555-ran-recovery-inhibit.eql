// Dragnet [Ransomware]: dragnet-ransomware-2025-2555 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b55f8700-322e-5ecf-8017-3315586eb26d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
