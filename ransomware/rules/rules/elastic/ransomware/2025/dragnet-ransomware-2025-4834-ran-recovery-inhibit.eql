// Dragnet [Ransomware]: dragnet-ransomware-2025-4834 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3422e403-fee2-5834-b588-b9222777438b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
