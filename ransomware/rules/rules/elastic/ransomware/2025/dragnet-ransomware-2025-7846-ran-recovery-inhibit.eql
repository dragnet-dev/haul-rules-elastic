// Dragnet [Ransomware]: dragnet-ransomware-2025-7846 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: ec7dae0c-738f-5d80-a869-ac6e80177ad1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
