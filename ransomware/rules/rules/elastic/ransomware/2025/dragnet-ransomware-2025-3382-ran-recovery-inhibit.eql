// Dragnet [Ransomware]: dragnet-ransomware-2025-3382 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 9ad27261-0baf-570a-8af4-622445f6de97

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
