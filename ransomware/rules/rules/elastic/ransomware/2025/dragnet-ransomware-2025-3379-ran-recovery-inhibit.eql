// Dragnet [Ransomware]: dragnet-ransomware-2025-3379 — Recovery Inhibition (ransomhouse)
// Status: test | Level: high | ID: d70fa9f1-fc93-50fd-beaa-2e4a5b7b6bd6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
