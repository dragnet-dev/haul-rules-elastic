// Dragnet [Ransomware]: dragnet-ransomware-2025-4333 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d4fc1150-c970-5a32-bb18-d8a74c1226da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
