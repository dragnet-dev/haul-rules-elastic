// Dragnet [Ransomware]: dragnet-ransomware-2025-1237 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 5971f040-aa39-53b6-af3c-f2bfdbcb0073

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
