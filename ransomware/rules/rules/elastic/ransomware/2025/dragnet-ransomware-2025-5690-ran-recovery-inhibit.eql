// Dragnet [Ransomware]: dragnet-ransomware-2025-5690 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 6608ef9e-e06e-5a7e-a5e0-da68aea81346

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
