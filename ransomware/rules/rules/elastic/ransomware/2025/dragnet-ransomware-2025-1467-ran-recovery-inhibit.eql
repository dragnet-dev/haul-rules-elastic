// Dragnet [Ransomware]: dragnet-ransomware-2025-1467 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 3730451d-abc5-5d9f-bfe3-eb29de415e43

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
