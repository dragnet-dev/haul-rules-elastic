// Dragnet [Ransomware]: dragnet-ransomware-2025-1908 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 86959aef-5637-5b6b-a53d-b2a759026c3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
