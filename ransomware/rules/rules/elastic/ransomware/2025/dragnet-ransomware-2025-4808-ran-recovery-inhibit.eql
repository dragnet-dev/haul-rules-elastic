// Dragnet [Ransomware]: dragnet-ransomware-2025-4808 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: f35b3890-ddbd-5ff4-acfe-851129932d82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
