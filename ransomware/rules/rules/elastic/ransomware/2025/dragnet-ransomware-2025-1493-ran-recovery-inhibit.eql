// Dragnet [Ransomware]: dragnet-ransomware-2025-1493 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 30849c42-40e1-595d-a7ae-76601f8b9ee4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
