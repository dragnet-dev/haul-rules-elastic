// Dragnet [Ransomware]: dragnet-ransomware-2025-7665 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f48cbda3-8da7-5fd0-94df-81e43dc6a851

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
