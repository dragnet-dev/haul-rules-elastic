// Dragnet [Ransomware]: dragnet-ransomware-2025-1231 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 728d1397-d1d5-5bb0-a12a-a6e283b46ee1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
