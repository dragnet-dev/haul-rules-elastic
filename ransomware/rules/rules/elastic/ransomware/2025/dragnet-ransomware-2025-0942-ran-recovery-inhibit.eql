// Dragnet [Ransomware]: dragnet-ransomware-2025-0942 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c963b3b1-6dee-53ff-be31-718dd362a202

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
