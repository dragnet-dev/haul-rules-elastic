// Dragnet [Ransomware]: dragnet-ransomware-2025-3053 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 119beca7-ea4b-571c-be1e-4ccc343b8543

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
