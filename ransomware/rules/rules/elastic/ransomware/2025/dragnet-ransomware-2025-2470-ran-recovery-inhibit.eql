// Dragnet [Ransomware]: dragnet-ransomware-2025-2470 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 368d391f-5ea2-5e27-a4d7-cee6896b63fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
