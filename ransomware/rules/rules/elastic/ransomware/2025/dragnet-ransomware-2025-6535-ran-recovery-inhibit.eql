// Dragnet [Ransomware]: dragnet-ransomware-2025-6535 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 6de57897-2c4a-5ed3-b3b4-6c9456ea9ae9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
