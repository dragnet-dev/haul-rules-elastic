// Dragnet [Ransomware]: dragnet-ransomware-2025-6277 — Recovery Inhibition (securotrop)
// Status: experimental | Level: high | ID: 250b5a65-5ba3-52f7-8b98-f6ea3e4d8f3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
