// Dragnet [Ransomware]: dragnet-ransomware-2025-1279 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: cbe07b16-0a0f-535a-9ab6-f343bf29f163

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
