// Dragnet [Ransomware]: dragnet-ransomware-2025-0778 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: b2661302-41fe-52bd-a21a-675d8e116dae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
