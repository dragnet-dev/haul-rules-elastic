// Dragnet [Ransomware]: dragnet-ransomware-2025-3997 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 05bad916-6a47-59df-99a6-58d0232ae39a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
