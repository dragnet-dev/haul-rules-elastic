// Dragnet [Ransomware]: dragnet-ransomware-2025-6210 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1537ef0c-f696-5f77-85da-0967e07ab3c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
