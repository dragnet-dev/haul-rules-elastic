// Dragnet [Ransomware]: dragnet-ransomware-2025-6942 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: c6cbbbbc-adba-59ae-89d3-d68b9d9348e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
