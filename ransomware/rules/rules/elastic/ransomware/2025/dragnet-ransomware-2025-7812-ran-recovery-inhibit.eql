// Dragnet [Ransomware]: dragnet-ransomware-2025-7812 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 4ffe2ec8-c512-5c99-88b3-0cd74eece546

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
