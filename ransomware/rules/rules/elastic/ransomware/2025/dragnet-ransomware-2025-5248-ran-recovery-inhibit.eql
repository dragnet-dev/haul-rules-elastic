// Dragnet [Ransomware]: dragnet-ransomware-2025-5248 — Recovery Inhibition (ralord)
// Status: experimental | Level: high | ID: 5b929c9e-e082-5969-8967-ae6769bb1f65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
