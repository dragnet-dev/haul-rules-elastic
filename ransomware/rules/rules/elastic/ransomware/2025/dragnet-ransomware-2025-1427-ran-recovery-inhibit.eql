// Dragnet [Ransomware]: dragnet-ransomware-2025-1427 — Recovery Inhibition (brotherhood)
// Status: deprecated | Level: high | ID: c8796b37-05ed-596a-9f47-d7480149cba0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
