// Dragnet [Ransomware]: dragnet-ransomware-2025-6288 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 7e61a7e4-d3a2-58d3-98e2-fc289d8e23d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
