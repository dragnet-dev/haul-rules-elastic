// Dragnet [Ransomware]: dragnet-ransomware-2025-3581 — Recovery Inhibition (underground)
// Status: experimental | Level: high | ID: 4fb2fb9a-31ee-50b1-8e56-e3d008f29f2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
