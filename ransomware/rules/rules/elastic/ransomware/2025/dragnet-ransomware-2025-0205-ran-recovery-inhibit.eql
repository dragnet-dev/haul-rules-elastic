// Dragnet [Ransomware]: dragnet-ransomware-2025-0205 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: 7012c76b-cf4a-5b96-92cf-d5e6512cf571

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
