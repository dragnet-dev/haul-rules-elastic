// Dragnet [Ransomware]: dragnet-ransomware-2025-1950 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 60168142-fab9-5bbc-b0c3-3addef7e740d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
