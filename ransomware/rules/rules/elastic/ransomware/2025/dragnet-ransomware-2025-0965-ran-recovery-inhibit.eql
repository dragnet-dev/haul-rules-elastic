// Dragnet [Ransomware]: dragnet-ransomware-2025-0965 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0d77ab59-faed-5242-afd9-39bbe0c32b79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
