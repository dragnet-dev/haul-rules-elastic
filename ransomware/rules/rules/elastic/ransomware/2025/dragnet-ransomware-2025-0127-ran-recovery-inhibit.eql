// Dragnet [Ransomware]: dragnet-ransomware-2025-0127 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: e007dee8-b47a-5f75-93d5-107dd0116d46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
