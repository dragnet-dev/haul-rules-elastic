// Dragnet [Ransomware]: dragnet-ransomware-2025-5806 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: e24d0bc8-490e-506c-baac-14464e21f62d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
