// Dragnet [Ransomware]: dragnet-ransomware-2025-2300 — Recovery Inhibition (anubis)
// Status: experimental | Level: high | ID: cb7b39d7-2e52-552c-9439-d573753cb17e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
