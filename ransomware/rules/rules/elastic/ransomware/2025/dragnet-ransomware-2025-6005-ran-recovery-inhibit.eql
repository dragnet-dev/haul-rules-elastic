// Dragnet [Ransomware]: dragnet-ransomware-2025-6005 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 1a73d82d-7c71-513f-b438-e2929f047e83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
