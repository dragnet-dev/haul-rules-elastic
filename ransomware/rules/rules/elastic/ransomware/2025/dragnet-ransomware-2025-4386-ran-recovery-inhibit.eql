// Dragnet [Ransomware]: dragnet-ransomware-2025-4386 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: b10a66d7-11b4-5750-820b-a38c126f6a9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
