// Dragnet [Ransomware]: dragnet-ransomware-2025-6500 — Recovery Inhibition (securotrop)
// Status: experimental | Level: high | ID: 7b70ebcd-e0a1-587b-a52e-4f85b06f9f3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
