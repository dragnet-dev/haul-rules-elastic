// Dragnet [Ransomware]: dragnet-ransomware-2025-3365 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: cbf77bcb-f815-59b6-80d9-b7e8839acf30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
