// Dragnet [Ransomware]: dragnet-ransomware-2025-0254 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a9c7fae8-3cc4-52ed-90f9-82a0948c225a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
