// Dragnet [Ransomware]: dragnet-ransomware-2025-3013 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d7e160fd-0a3e-562a-b6b5-a3d530639edd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
