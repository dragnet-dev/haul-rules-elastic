// Dragnet [Ransomware]: dragnet-ransomware-2025-1053 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 954d01ed-403b-58d8-bc20-6e27537a4705

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
