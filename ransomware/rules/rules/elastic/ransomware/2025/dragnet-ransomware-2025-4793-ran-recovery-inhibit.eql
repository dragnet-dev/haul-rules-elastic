// Dragnet [Ransomware]: dragnet-ransomware-2025-4793 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 40aae445-6fb2-590b-876c-ece1b8551467

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
