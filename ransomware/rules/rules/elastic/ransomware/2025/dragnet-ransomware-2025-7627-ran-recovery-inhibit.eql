// Dragnet [Ransomware]: dragnet-ransomware-2025-7627 — Recovery Inhibition (cephalus)
// Status: deprecated | Level: high | ID: 2c624de8-0e1c-50b1-9060-4cb051421c7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
