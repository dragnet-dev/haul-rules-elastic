// Dragnet [Ransomware]: dragnet-ransomware-2025-0491 — Recovery Inhibition (kraken)
// Status: experimental | Level: high | ID: 35e0383a-a216-5e0b-a8ea-5e5691764e9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
