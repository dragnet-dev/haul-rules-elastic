// Dragnet [Ransomware]: dragnet-ransomware-2025-0632 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b58417c7-0fc8-5dd1-a58b-d9ea89a57f68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
