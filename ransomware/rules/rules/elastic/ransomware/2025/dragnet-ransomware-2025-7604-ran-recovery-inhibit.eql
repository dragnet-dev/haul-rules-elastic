// Dragnet [Ransomware]: dragnet-ransomware-2025-7604 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 5464137a-c4d9-51b5-9b9f-acb3806c1d31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
