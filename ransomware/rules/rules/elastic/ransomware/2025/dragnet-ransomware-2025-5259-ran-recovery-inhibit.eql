// Dragnet [Ransomware]: dragnet-ransomware-2025-5259 — Recovery Inhibition (payoutsking)
// Status: test | Level: high | ID: b0b2318c-06e1-56b3-92cc-f8dfe85fb061

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
