// Dragnet [Ransomware]: dragnet-ransomware-2025-3337 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 947ace11-bc04-5039-ad31-870dd5a03ca4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
