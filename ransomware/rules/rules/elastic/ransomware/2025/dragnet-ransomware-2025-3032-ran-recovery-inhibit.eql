// Dragnet [Ransomware]: dragnet-ransomware-2025-3032 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b8e20e63-c2c7-5d4b-a6bb-3bcfbb95ed25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
