// Dragnet [Ransomware]: dragnet-ransomware-2025-0039 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: eab4f593-7ab6-5f17-898c-44e706430463

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
