// Dragnet [Ransomware]: dragnet-ransomware-2025-4478 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 10571291-a558-50d8-b430-8a2bc82396fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
