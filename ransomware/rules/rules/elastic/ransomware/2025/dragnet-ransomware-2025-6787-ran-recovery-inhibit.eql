// Dragnet [Ransomware]: dragnet-ransomware-2025-6787 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 3900d914-c096-507d-b84a-f87268df03c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
