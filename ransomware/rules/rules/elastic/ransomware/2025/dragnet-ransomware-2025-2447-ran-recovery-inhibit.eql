// Dragnet [Ransomware]: dragnet-ransomware-2025-2447 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 499e6d39-1a5e-5fd8-a0f3-4a2eb13e0914

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
