// Dragnet [Ransomware]: dragnet-ransomware-2025-3683 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 6b2fecff-32ad-50d7-8b3c-ee26d4f783b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
