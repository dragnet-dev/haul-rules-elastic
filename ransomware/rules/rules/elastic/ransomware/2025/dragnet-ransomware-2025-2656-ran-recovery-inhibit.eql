// Dragnet [Ransomware]: dragnet-ransomware-2025-2656 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: e1243897-0941-5bd4-8992-d5623a95adb8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
