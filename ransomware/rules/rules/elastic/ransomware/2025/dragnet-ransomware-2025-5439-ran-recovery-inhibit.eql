// Dragnet [Ransomware]: dragnet-ransomware-2025-5439 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 227cf090-43a7-53d8-991e-2634a2f0154e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
