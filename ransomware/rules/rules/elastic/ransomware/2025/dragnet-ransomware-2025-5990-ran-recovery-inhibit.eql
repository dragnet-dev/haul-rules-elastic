// Dragnet [Ransomware]: dragnet-ransomware-2025-5990 — Recovery Inhibition (radar)
// Status: deprecated | Level: high | ID: a153765d-6dd9-55a6-a63f-97bea881bc25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
