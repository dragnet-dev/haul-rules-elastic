// Dragnet [Ransomware]: dragnet-ransomware-2025-2155 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 18261fc2-51ce-59bf-abc4-24a1c3d312ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
