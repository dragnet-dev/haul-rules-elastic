// Dragnet [Ransomware]: dragnet-ransomware-2025-4750 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 7e4f03e4-7e9c-5fcb-a120-a98c3d47f146

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
