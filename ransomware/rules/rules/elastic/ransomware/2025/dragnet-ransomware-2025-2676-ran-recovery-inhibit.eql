// Dragnet [Ransomware]: dragnet-ransomware-2025-2676 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 5e182dea-6612-5d6c-b319-913ede71bb53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
