// Dragnet [Ransomware]: dragnet-ransomware-2025-7696 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 97314057-694d-552b-96bc-4265441c49c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
