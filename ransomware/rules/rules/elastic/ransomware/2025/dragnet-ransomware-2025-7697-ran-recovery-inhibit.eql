// Dragnet [Ransomware]: dragnet-ransomware-2025-7697 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: add64556-eb23-5b84-89ad-973ed9254544

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
