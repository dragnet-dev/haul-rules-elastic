// Dragnet [Ransomware]: dragnet-ransomware-2025-2356 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 49a33d12-8794-5a6a-8d5d-0d61fc99c339

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
