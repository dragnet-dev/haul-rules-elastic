// Dragnet [Ransomware]: dragnet-ransomware-2025-4638 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 3507eaa7-57ec-57bf-a034-ec1af80f2a10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
