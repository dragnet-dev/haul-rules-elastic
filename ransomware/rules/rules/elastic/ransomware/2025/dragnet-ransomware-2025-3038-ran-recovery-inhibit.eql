// Dragnet [Ransomware]: dragnet-ransomware-2025-3038 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: d9c51b18-50f1-5ad8-914f-fb5a3b79c9d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
