// Dragnet [Ransomware]: dragnet-ransomware-2025-1184 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 06dd6097-78c8-555c-b4fc-e5a329bd8cff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
