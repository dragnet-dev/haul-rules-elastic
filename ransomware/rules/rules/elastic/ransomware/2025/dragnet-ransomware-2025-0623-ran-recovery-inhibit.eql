// Dragnet [Ransomware]: dragnet-ransomware-2025-0623 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: da686f67-987f-527a-93f0-3632706f8d85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
