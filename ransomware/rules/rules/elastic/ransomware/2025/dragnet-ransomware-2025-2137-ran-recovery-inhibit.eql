// Dragnet [Ransomware]: dragnet-ransomware-2025-2137 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: 56b44177-f89d-555c-8af1-4d2a0c864e24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
