// Dragnet [Ransomware]: dragnet-ransomware-2025-0485 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: 6ead4c71-379e-5f6a-a579-2943df8402dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
