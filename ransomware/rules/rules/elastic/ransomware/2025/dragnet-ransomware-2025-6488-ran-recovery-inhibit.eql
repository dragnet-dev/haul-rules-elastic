// Dragnet [Ransomware]: dragnet-ransomware-2025-6488 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: deb0401c-9155-595f-9b6c-aad8776103dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
