// Dragnet [Ransomware]: dragnet-ransomware-2025-5855 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0b612dd1-58c7-5bc1-b471-0690f5ef68e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
