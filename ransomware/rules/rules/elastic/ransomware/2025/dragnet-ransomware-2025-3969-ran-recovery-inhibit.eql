// Dragnet [Ransomware]: dragnet-ransomware-2025-3969 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 67b7d307-1eb0-5b70-86d0-693622384891

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
