// Dragnet [Ransomware]: dragnet-ransomware-2025-5620 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: a1564c54-e870-5a9e-a21b-64933485238c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
