// Dragnet [Ransomware]: dragnet-ransomware-2025-4500 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 66e129f3-22e5-509f-bbfd-968837ed591f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
