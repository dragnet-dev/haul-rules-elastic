// Dragnet [Ransomware]: dragnet-ransomware-2025-6169 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: a83b795c-9abc-5cb6-be14-951011bff067

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
