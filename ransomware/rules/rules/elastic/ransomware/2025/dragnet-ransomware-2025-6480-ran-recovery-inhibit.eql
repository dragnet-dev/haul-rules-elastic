// Dragnet [Ransomware]: dragnet-ransomware-2025-6480 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: d2465900-09e3-585f-b14b-501b85c83d52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
