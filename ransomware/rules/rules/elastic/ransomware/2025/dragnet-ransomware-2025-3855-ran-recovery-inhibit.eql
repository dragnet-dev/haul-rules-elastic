// Dragnet [Ransomware]: dragnet-ransomware-2025-3855 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: b90337d7-5042-568d-a924-2f4534248ae6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
