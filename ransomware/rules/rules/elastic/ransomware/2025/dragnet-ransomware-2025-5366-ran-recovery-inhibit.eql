// Dragnet [Ransomware]: dragnet-ransomware-2025-5366 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 37316cde-c978-5087-96d1-f7e72da002df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
