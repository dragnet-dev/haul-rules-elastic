// Dragnet [Ransomware]: dragnet-ransomware-2025-0263 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 2e4d3506-9933-58df-b0c0-1b7c7ba08758

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
