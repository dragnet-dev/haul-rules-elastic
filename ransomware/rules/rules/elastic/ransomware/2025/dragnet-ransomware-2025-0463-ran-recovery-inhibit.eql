// Dragnet [Ransomware]: dragnet-ransomware-2025-0463 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fcae1484-0a41-5583-9c03-96694296e19d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
