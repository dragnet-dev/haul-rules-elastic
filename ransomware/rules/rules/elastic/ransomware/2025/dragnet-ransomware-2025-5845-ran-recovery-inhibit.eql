// Dragnet [Ransomware]: dragnet-ransomware-2025-5845 — Recovery Inhibition (gunra)
// Status: experimental | Level: high | ID: 8440b669-2bd6-5117-86fc-dab60fb4212e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
