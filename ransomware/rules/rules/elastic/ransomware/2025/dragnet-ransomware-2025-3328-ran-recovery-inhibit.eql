// Dragnet [Ransomware]: dragnet-ransomware-2025-3328 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: afc7540c-c71f-5ee6-8e2e-5f64e261e305

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
