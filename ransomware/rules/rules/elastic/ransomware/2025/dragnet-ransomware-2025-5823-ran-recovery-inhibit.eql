// Dragnet [Ransomware]: dragnet-ransomware-2025-5823 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b2d1b6a5-36b0-5b8a-a507-be93316f7848

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
