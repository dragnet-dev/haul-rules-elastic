// Dragnet [Ransomware]: dragnet-ransomware-2025-5876 — Recovery Inhibition (silent)
// Status: experimental | Level: high | ID: da058ebf-e201-5a79-8be5-f5c107ea11ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
