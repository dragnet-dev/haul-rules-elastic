// Dragnet [Ransomware]: dragnet-ransomware-2025-5294 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 951e13a6-a68a-5366-b731-2f82a0028384

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
