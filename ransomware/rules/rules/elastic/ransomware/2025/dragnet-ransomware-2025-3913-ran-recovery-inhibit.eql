// Dragnet [Ransomware]: dragnet-ransomware-2025-3913 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 1ff94775-26ef-5773-a33e-3d34f1656c61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
