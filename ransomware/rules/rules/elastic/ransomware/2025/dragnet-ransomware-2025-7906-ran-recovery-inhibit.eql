// Dragnet [Ransomware]: dragnet-ransomware-2025-7906 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 6dba5d6c-d54c-5644-b167-c69c26694965

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
