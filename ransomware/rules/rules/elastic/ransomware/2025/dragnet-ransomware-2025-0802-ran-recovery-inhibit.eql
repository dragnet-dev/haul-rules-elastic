// Dragnet [Ransomware]: dragnet-ransomware-2025-0802 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: af901b43-e190-5345-97e7-b959684b0017

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
