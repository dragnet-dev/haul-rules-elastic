// Dragnet [Ransomware]: dragnet-ransomware-2025-6293 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f98265db-c6c7-5201-919e-60415d77194f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
