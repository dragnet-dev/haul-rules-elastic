// Dragnet [Ransomware]: dragnet-ransomware-2025-4893 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: 2a510826-dc8b-5567-92d4-0b02a264a8b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
