// Dragnet [Ransomware]: dragnet-ransomware-2025-6595 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 891c6e69-3683-5d55-a60b-d0fe092f9a5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
