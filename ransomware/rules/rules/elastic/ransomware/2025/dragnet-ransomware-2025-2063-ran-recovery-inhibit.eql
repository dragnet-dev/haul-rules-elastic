// Dragnet [Ransomware]: dragnet-ransomware-2025-2063 — Recovery Inhibition (kawa4096)
// Status: deprecated | Level: high | ID: f4448acb-4f34-59fe-a55a-1c9f475ee249

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
