// Dragnet [Ransomware]: dragnet-ransomware-2025-2927 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 66be90a9-eb78-56bb-b010-145f817866f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
