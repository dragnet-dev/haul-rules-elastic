// Dragnet [Ransomware]: dragnet-ransomware-2025-2157 — Recovery Inhibition (blackshrantac)
// Status: experimental | Level: high | ID: f205c851-e44a-5b55-af2c-39cf360ae737

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
