// Dragnet [Ransomware]: dragnet-ransomware-2025-0565 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ed056a16-a154-5d82-a803-55f8dbb0e457

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
