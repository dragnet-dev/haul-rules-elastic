// Dragnet [Ransomware]: dragnet-ransomware-2025-6837 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 7ec64730-7ac3-57e1-a380-d03258a71307

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
