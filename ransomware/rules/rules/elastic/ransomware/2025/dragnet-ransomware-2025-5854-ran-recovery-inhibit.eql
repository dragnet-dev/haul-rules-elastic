// Dragnet [Ransomware]: dragnet-ransomware-2025-5854 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e8700fbd-7fdf-53a7-86cf-15ef2959ee77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
