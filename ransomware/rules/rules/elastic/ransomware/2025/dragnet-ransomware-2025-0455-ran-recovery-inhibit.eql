// Dragnet [Ransomware]: dragnet-ransomware-2025-0455 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7395e8e9-5ac1-58c0-9dfd-aed6784e1220

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
