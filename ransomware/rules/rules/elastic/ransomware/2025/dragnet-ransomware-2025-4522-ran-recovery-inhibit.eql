// Dragnet [Ransomware]: dragnet-ransomware-2025-4522 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 9b244f0f-b5fd-5a40-a2e8-6ae31cde6fff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
