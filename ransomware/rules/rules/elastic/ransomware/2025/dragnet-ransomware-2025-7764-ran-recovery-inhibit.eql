// Dragnet [Ransomware]: dragnet-ransomware-2025-7764 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 89e726d1-d946-565f-8b19-5557ee9bbe4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
