// Dragnet [Ransomware]: dragnet-ransomware-2025-3219 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c124839f-6951-59a4-ad15-1b3f5b6bc241

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
