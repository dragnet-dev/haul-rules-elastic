// Dragnet [Ransomware]: dragnet-ransomware-2025-6830 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b57c2361-56db-5889-ab63-140f19b492b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
