// Dragnet [Ransomware]: dragnet-ransomware-2025-2923 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7d8393fa-ae15-5898-9e62-b8e3c1419060

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
