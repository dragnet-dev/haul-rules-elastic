// Dragnet [Ransomware]: dragnet-ransomware-2025-7279 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 77240efc-1390-5ba1-a6fb-6cf126e25c8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
