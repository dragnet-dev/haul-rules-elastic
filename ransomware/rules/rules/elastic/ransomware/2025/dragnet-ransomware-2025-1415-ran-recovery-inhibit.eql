// Dragnet [Ransomware]: dragnet-ransomware-2025-1415 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 974ec662-c84f-5963-8455-b42701f7dc05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
