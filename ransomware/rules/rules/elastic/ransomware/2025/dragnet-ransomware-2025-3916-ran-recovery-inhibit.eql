// Dragnet [Ransomware]: dragnet-ransomware-2025-3916 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 4d022d3f-edbb-58c3-b907-a9f53dfa928a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
