// Dragnet [Ransomware]: dragnet-ransomware-2025-4051 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d974ecaf-de1e-548a-a7d7-fe61cc0b96d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
