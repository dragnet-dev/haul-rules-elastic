// Dragnet [Ransomware]: dragnet-ransomware-2025-7372 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 630b2e93-b23c-5938-bad4-652934be0417

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
