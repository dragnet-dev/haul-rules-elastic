// Dragnet [Ransomware]: dragnet-ransomware-2025-1190 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 79c1a4b6-2ef6-517b-a760-5b79d0f8c10d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
