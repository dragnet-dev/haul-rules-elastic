// Dragnet [Ransomware]: dragnet-ransomware-2025-5906 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 42b23598-4a7d-5ffe-aee4-bd1dbebf6fa9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
