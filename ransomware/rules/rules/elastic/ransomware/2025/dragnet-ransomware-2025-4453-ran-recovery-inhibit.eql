// Dragnet [Ransomware]: dragnet-ransomware-2025-4453 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: b19eb78f-cde8-5805-8974-2b74f60112a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
