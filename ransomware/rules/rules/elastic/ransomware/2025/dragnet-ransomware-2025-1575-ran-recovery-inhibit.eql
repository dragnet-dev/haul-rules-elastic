// Dragnet [Ransomware]: dragnet-ransomware-2025-1575 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: c6878c87-f3c2-5211-9b13-44a2fde9de89

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
