// Dragnet [Ransomware]: dragnet-ransomware-2025-3011 — Recovery Inhibition (cephalus)
// Status: deprecated | Level: high | ID: d9c24d8e-dc06-5369-ac26-9b7425b351cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
