// Dragnet [Ransomware]: dragnet-ransomware-2025-4395 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 4027e5db-d57c-5c69-b275-06cae65015a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
