// Dragnet [Ransomware]: dragnet-ransomware-2025-0814 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 120963fc-d05d-584b-8223-df5c139d0cb3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
