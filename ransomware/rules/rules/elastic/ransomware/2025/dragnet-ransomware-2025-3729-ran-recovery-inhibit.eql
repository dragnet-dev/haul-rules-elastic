// Dragnet [Ransomware]: dragnet-ransomware-2025-3729 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 513f69e1-7bbf-5e57-a0d6-9cc2c874f3bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
