// Dragnet [Ransomware]: dragnet-ransomware-2025-7920 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 29d1f7ef-9cc1-562f-b12c-8623f0c9e12f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
