// Dragnet [Ransomware]: dragnet-ransomware-2025-7582 — Recovery Inhibition (kawa4096)
// Status: deprecated | Level: high | ID: aa53d86a-0b5f-5c69-aff6-eefbb0a0faec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
