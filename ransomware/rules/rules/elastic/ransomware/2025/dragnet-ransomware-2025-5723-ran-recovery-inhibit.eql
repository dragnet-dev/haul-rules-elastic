// Dragnet [Ransomware]: dragnet-ransomware-2025-5723 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 3854cfb3-3758-583e-b681-a3b305a077f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
