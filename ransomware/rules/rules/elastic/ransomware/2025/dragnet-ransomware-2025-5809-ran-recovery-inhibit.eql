// Dragnet [Ransomware]: dragnet-ransomware-2025-5809 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 434476cf-5398-5a3e-8fff-64bcf03b9a62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
