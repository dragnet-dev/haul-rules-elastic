// Dragnet [Ransomware]: dragnet-ransomware-2025-5688 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e611ab48-8c4a-5d88-9f76-f2c80e3fb2b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
