// Dragnet [Ransomware]: dragnet-ransomware-2025-0348 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 24e166ae-c653-506a-a853-4c40ac176d86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
