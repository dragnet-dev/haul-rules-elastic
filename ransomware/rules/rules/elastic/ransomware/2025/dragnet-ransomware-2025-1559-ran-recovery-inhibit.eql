// Dragnet [Ransomware]: dragnet-ransomware-2025-1559 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: aef11864-234a-5819-b705-6614ab8c3c01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
