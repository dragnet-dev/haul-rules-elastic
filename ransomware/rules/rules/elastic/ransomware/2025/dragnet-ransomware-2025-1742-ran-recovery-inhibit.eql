// Dragnet [Ransomware]: dragnet-ransomware-2025-1742 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: f0e88cc5-926f-5153-aa14-09d04a930145

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
