// Dragnet [Ransomware]: dragnet-ransomware-2025-5332 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 9282063b-ea91-5a2f-b57b-2137cdcfa067

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
