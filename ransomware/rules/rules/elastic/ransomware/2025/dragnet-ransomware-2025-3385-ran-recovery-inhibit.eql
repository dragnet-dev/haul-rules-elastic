// Dragnet [Ransomware]: dragnet-ransomware-2025-3385 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: 43d6899b-278e-5258-b76b-e457b48a25ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
