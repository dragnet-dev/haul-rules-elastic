// Dragnet [Ransomware]: dragnet-ransomware-2025-3024 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: bd75996e-027d-5d71-95bc-fabaf12da2c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
