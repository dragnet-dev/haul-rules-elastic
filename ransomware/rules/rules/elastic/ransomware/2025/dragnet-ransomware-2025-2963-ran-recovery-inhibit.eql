// Dragnet [Ransomware]: dragnet-ransomware-2025-2963 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: bb644252-bd23-53e7-94c8-39e57101d66f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
