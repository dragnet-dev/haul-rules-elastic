// Dragnet [Ransomware]: dragnet-ransomware-2025-1870 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: acba7349-5205-5088-a273-b602719d40b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
