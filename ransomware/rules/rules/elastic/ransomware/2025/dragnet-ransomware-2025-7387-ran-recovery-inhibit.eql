// Dragnet [Ransomware]: dragnet-ransomware-2025-7387 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6b6f2271-e15d-50d5-bcd2-4dae0ed0ecc6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
