// Dragnet [Ransomware]: dragnet-ransomware-2025-7663 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b037d5a1-ffb8-55c4-983d-bb52154b367e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
