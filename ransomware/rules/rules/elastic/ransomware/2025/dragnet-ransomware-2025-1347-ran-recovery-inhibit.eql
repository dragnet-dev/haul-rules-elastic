// Dragnet [Ransomware]: dragnet-ransomware-2025-1347 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 711e99d4-df58-5110-8b78-043c578828ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
