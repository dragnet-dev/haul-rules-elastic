// Dragnet [Ransomware]: dragnet-ransomware-2025-4042 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 4c42db07-bde0-535c-8f59-988f9d533ce7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
