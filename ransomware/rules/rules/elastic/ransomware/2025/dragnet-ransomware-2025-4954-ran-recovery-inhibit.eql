// Dragnet [Ransomware]: dragnet-ransomware-2025-4954 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6ddf41cd-337e-5d47-bf06-a58c1c6b59d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
