// Dragnet [Ransomware]: dragnet-ransomware-2025-7321 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 76eb7849-f601-5ab5-bb35-3303679c4b63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
