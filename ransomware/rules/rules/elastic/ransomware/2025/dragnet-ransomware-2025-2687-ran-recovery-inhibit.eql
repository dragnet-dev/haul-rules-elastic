// Dragnet [Ransomware]: dragnet-ransomware-2025-2687 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3504c5db-e076-5be0-9fec-55093c007ea9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
