// Dragnet [Ransomware]: dragnet-ransomware-2025-4748 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: a4aeabaa-ebe1-5d81-be83-289d0d60dd95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
