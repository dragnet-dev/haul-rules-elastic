// Dragnet [Ransomware]: dragnet-ransomware-2025-1404 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 58324481-7da1-53ea-853c-0a440e342169

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
