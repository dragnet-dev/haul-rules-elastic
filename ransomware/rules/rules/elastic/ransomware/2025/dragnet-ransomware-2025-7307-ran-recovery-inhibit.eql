// Dragnet [Ransomware]: dragnet-ransomware-2025-7307 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 2072c42a-b395-5d85-adb2-dbf9cd7c4a28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
