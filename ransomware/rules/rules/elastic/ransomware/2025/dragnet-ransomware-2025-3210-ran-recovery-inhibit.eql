// Dragnet [Ransomware]: dragnet-ransomware-2025-3210 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7b450c01-a02c-502f-adfb-bc06ae4afa2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
