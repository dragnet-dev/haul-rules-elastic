// Dragnet [Ransomware]: dragnet-ransomware-2025-3265 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 3ab8f63d-3586-5185-974a-148d5e14373d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
