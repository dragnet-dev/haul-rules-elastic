// Dragnet [Ransomware]: dragnet-ransomware-2025-1086 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 104802e7-45e1-5d0a-9b67-3e5536ad3e5f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
