// Dragnet [Ransomware]: dragnet-ransomware-2025-6321 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: b6d46feb-d181-55b9-a381-9067af5f0b9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
