// Dragnet [Ransomware]: dragnet-ransomware-2025-4823 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 8d0156b3-8d93-5601-a9ca-add6af63af2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
