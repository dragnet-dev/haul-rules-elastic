// Dragnet [Ransomware]: dragnet-ransomware-2025-4683 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 50fa3ddd-6beb-5f53-825c-3badb59de871

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
