// Dragnet [Ransomware]: dragnet-ransomware-2025-6935 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: cb378a84-6e15-57f6-85f8-064ee9850ffc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
