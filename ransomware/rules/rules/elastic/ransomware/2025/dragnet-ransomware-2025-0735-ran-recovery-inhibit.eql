// Dragnet [Ransomware]: dragnet-ransomware-2025-0735 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e1b48fed-d2da-592e-94be-1cdc5a1a43c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
