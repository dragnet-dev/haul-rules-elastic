// Dragnet [Ransomware]: dragnet-ransomware-2025-0603 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 96b58997-4d02-562d-b6eb-79fb661515c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
