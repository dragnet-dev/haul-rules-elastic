// Dragnet [Ransomware]: dragnet-ransomware-2025-6066 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 1da5199b-7aec-54ca-8fdf-8451b160eb6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
