// Dragnet [Ransomware]: dragnet-ransomware-2025-2284 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: cd6f3920-6400-5a56-9058-7be6b437c056

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
