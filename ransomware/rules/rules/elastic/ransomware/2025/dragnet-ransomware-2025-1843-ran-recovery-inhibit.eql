// Dragnet [Ransomware]: dragnet-ransomware-2025-1843 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 91c1c7d6-c149-5d79-958c-65a98280e77d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
