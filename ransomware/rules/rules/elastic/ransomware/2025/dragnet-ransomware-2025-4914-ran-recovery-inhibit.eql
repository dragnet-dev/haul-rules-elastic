// Dragnet [Ransomware]: dragnet-ransomware-2025-4914 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 6fde3856-3d78-5a32-8cc6-461670858463

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
