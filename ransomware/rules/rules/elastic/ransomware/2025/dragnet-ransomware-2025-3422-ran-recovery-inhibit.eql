// Dragnet [Ransomware]: dragnet-ransomware-2025-3422 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 8c5f3e6b-9793-57eb-b62e-6aeefa8b6373

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
