// Dragnet [Ransomware]: dragnet-ransomware-2025-0677 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 50a0510b-5b62-5eb7-a64b-be8c5da84569

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
