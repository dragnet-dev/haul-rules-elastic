// Dragnet [Ransomware]: dragnet-ransomware-2025-0121 — Recovery Inhibition (anubis)
// Status: experimental | Level: high | ID: 046ae7f0-9501-575a-bee4-94d49082062e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
