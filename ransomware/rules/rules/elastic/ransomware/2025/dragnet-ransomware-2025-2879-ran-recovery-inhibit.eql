// Dragnet [Ransomware]: dragnet-ransomware-2025-2879 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 1a91d529-bd17-5c9f-9330-971501b6cc8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
