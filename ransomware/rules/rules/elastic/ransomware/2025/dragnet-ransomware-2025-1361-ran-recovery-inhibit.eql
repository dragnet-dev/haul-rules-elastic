// Dragnet [Ransomware]: dragnet-ransomware-2025-1361 — Recovery Inhibition (hellcat)
// Status: deprecated | Level: high | ID: 167f34b8-edcc-5679-8801-45e4883ba4fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
