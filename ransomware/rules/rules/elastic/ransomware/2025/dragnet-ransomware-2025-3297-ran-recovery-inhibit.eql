// Dragnet [Ransomware]: dragnet-ransomware-2025-3297 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c1147058-e63c-54be-ad8a-097cca0ae663

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
