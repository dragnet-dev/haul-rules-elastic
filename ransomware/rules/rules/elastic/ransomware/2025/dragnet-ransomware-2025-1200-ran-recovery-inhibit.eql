// Dragnet [Ransomware]: dragnet-ransomware-2025-1200 — Recovery Inhibition (nitrogen)
// Status: test | Level: high | ID: 103368e2-ca0a-51c9-b8b2-b70531c7214c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
