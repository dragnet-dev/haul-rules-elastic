// Dragnet [Ransomware]: dragnet-ransomware-2025-1564 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: f919c473-7f5c-57b6-bb20-fd30efa50fbc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
