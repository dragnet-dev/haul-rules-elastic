// Dragnet [Ransomware]: dragnet-ransomware-2025-0510 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 35863c45-80ea-5771-9e47-2074de2f4d03

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
