// Dragnet [Ransomware]: dragnet-ransomware-2025-6525 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 6f21f4e7-f7b9-5008-b7f3-b3653a22ded3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
