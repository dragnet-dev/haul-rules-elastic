// Dragnet [Ransomware]: dragnet-ransomware-2025-5380 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 4f70c6dc-1706-5277-88f1-bb7cd15b87ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
