// Dragnet [Ransomware]: dragnet-ransomware-2025-0993 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 67ee91e9-1315-5e85-8be4-c79bd100b4b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
