// Dragnet [Ransomware]: dragnet-ransomware-2025-5796 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 024802dc-f1ab-5d42-ad73-a096ecc35eba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
