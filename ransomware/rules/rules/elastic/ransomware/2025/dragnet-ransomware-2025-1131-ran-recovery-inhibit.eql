// Dragnet [Ransomware]: dragnet-ransomware-2025-1131 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: 0baf6b5e-8ded-587d-8e16-6db694a295a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
