// Dragnet [Ransomware]: dragnet-ransomware-2025-5992 — Recovery Inhibition (insomnia)
// Status: test | Level: high | ID: 72fd1f87-2391-5a8b-a4d6-04a7a6b2934b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
