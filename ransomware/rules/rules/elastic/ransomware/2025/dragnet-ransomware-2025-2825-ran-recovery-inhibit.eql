// Dragnet [Ransomware]: dragnet-ransomware-2025-2825 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5126757e-eaa6-5e9a-8e09-b387f8dd76a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
