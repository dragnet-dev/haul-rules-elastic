// Dragnet [Ransomware]: dragnet-ransomware-2025-1325 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: c662cde6-da94-516d-aeb0-b5142ff6379f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
