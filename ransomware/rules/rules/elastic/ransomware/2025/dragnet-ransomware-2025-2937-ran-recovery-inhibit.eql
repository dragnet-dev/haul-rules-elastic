// Dragnet [Ransomware]: dragnet-ransomware-2025-2937 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 26a98e29-9795-5731-b3a7-95d058647b2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
