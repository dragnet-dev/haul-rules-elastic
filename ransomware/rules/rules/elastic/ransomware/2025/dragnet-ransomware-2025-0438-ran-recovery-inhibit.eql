// Dragnet [Ransomware]: dragnet-ransomware-2025-0438 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 565f3269-351a-5dd8-aa29-3acf5c0d200c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
