// Dragnet [Ransomware]: dragnet-ransomware-2025-1029 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: bab8c5be-1207-5cbb-b743-10653f2bdd82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
