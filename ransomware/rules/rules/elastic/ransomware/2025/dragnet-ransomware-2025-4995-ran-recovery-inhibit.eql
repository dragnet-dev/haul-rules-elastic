// Dragnet [Ransomware]: dragnet-ransomware-2025-4995 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 69e76b22-ba64-5c44-accd-32fe36e4a002

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
