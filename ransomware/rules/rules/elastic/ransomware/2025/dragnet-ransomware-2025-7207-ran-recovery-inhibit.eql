// Dragnet [Ransomware]: dragnet-ransomware-2025-7207 — Recovery Inhibition (shinyhunters)
// Status: deprecated | Level: high | ID: 8512f8f8-1284-5d36-b4f6-a78c340ea4cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
