// Dragnet [Ransomware]: dragnet-ransomware-2025-6350 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: b3aec83d-932a-5205-9f6a-91639a282168

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
