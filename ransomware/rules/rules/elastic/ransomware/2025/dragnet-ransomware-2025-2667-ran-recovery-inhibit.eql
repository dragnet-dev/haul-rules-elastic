// Dragnet [Ransomware]: dragnet-ransomware-2025-2667 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: e9af53fa-e79e-5777-b411-c0fadcb75d13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
