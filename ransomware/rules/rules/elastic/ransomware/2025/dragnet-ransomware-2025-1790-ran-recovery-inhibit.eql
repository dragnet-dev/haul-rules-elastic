// Dragnet [Ransomware]: dragnet-ransomware-2025-1790 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 20794107-73bc-5080-b252-eb5507d2240f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
