// Dragnet [Ransomware]: dragnet-ransomware-2025-0457 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 9c207b82-5770-5dd1-b6a7-5494b9e7a7af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
