// Dragnet [Ransomware]: dragnet-ransomware-2025-6906 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 14027261-8669-5833-a62b-8a62cccd6f0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
