// Dragnet [Ransomware]: dragnet-ransomware-2025-0534 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: e512b7fe-ab26-5a79-8097-24328a071e05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
