// Dragnet [Ransomware]: dragnet-ransomware-2025-7694 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 0464e8db-b2ae-5bbe-8d2f-49b0c1d3c7c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
