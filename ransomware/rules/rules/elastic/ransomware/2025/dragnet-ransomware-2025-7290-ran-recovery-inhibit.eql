// Dragnet [Ransomware]: dragnet-ransomware-2025-7290 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 185931d1-7cff-5932-bd57-733565b90f09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
