// Dragnet [Ransomware]: dragnet-ransomware-2025-7257 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 35a498f4-ee3e-5ddc-8a03-99cb073515ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
