// Dragnet [Ransomware]: dragnet-ransomware-2025-7541 — Recovery Inhibition (blackshrantac)
// Status: experimental | Level: high | ID: 44e81ef6-5354-5ac5-a9a1-71f12943c036

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
