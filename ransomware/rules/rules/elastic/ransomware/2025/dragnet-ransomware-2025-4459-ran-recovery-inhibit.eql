// Dragnet [Ransomware]: dragnet-ransomware-2025-4459 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 05053c56-1c71-505e-aa19-bf1c62b8004b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
