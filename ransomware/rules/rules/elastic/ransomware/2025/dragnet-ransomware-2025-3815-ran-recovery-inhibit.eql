// Dragnet [Ransomware]: dragnet-ransomware-2025-3815 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 8eef94d8-c715-575c-b186-91271c803d82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
