// Dragnet [Ransomware]: dragnet-ransomware-2025-5465 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: 64285328-80d8-5744-ac83-b541521e3181

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
