// Dragnet [Ransomware]: dragnet-ransomware-2025-5087 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 0c9e6ef1-146f-5d7e-a9c5-d2e8f1478d66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
