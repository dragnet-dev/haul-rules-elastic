// Dragnet [Ransomware]: dragnet-ransomware-2025-0022 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 14e19371-0ee8-5e6b-a8a1-936257f11d58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
