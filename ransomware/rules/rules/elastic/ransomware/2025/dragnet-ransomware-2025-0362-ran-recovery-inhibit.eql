// Dragnet [Ransomware]: dragnet-ransomware-2025-0362 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: b8977038-3b24-50d4-8418-a7ad266e91e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
