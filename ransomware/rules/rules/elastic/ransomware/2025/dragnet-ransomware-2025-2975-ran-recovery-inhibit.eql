// Dragnet [Ransomware]: dragnet-ransomware-2025-2975 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 53066490-b478-5c95-a6e9-5c218099e81d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
