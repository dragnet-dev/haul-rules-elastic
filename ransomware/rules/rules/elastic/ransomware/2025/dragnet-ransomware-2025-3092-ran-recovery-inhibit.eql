// Dragnet [Ransomware]: dragnet-ransomware-2025-3092 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 199be3b9-56db-53ca-a9f0-f6c519579120

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
