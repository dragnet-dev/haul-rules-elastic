// Dragnet [Ransomware]: dragnet-ransomware-2025-0772 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 2e987947-9c3f-5f8e-a869-b896534a13c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
