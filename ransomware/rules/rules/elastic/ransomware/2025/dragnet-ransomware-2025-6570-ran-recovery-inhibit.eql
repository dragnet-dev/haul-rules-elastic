// Dragnet [Ransomware]: dragnet-ransomware-2025-6570 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 46612ca5-b169-5f3b-8300-106dfe48b767

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
