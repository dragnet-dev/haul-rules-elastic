// Dragnet [Ransomware]: dragnet-ransomware-2025-3169 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: cbab6d9d-7c6a-5acc-a8f8-c47d9941f72d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
