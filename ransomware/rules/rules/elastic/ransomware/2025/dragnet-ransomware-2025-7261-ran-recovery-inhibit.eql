// Dragnet [Ransomware]: dragnet-ransomware-2025-7261 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 3316aa67-c8da-5b88-b1f9-731f3b3bd829

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
