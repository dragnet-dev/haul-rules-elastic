// Dragnet [Ransomware]: dragnet-ransomware-2025-5339 — Recovery Inhibition (kawa4096)
// Status: deprecated | Level: high | ID: 502da289-eed9-576c-b9e6-7a203f839967

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
