// Dragnet [Ransomware]: dragnet-ransomware-2025-2272 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a990a24c-4ae4-5ef4-9359-a9131f5a4302

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
