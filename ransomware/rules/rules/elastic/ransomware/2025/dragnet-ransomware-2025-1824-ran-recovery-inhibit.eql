// Dragnet [Ransomware]: dragnet-ransomware-2025-1824 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ac3f6908-95a5-5a12-9619-90ab6467b8b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
