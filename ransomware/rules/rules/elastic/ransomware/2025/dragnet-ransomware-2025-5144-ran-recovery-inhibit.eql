// Dragnet [Ransomware]: dragnet-ransomware-2025-5144 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: beba5e55-417c-5ba5-9730-90a4c8327cd4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
