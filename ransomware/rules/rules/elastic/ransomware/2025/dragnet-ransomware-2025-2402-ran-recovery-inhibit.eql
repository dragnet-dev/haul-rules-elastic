// Dragnet [Ransomware]: dragnet-ransomware-2025-2402 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: c0fd38bf-e850-585c-8dcd-70de5d2220ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
