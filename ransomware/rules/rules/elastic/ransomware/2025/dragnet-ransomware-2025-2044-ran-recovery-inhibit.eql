// Dragnet [Ransomware]: dragnet-ransomware-2025-2044 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: 0fbb0d04-e8aa-5e0a-87f0-5806d4810f0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
