// Dragnet [Ransomware]: dragnet-ransomware-2025-4837 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: 04262195-99c0-5296-adbe-3b21860a370d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
