// Dragnet [Ransomware]: dragnet-ransomware-2025-2659 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9f459b96-4616-5b4b-9f2c-689422c8a84e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
