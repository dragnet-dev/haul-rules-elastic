// Dragnet [Ransomware]: dragnet-ransomware-2025-6472 — Recovery Inhibition (ralord)
// Status: experimental | Level: high | ID: 9d354e61-81a2-507a-a3eb-b697be25f7ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
