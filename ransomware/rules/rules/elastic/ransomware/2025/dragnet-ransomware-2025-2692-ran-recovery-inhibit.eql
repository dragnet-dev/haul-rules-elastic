// Dragnet [Ransomware]: dragnet-ransomware-2025-2692 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: a27543ac-358d-517d-a695-418b75e3bd87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
