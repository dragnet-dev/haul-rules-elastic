// Dragnet [Ransomware]: dragnet-ransomware-2025-7045 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: e9f29385-48c7-5cf0-862b-89383fa86357

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
