// Dragnet [Ransomware]: dragnet-ransomware-2025-7636 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: c33cf9f1-7463-5810-b613-78b68aeac807

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
