// Dragnet [Ransomware]: dragnet-ransomware-2025-0226 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 38fd9ac5-a671-5a62-9628-e0c5065ac24e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
