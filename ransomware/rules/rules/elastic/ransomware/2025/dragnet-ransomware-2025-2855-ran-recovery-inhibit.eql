// Dragnet [Ransomware]: dragnet-ransomware-2025-2855 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: 3101b6eb-2730-5b1e-bfcb-49b1c5527c91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
