// Dragnet [Ransomware]: dragnet-ransomware-2025-3369 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 0b227b26-ed43-5697-be5c-81d682b5ae62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
