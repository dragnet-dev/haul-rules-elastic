// Dragnet [Ransomware]: dragnet-ransomware-2025-0508 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 55d1ba82-a115-5e9d-8ca5-f9a376812ab0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
