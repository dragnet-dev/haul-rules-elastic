// Dragnet [Ransomware]: dragnet-ransomware-2025-1993 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: f660b7c3-33b4-565e-92c9-dd8204cf1c00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
