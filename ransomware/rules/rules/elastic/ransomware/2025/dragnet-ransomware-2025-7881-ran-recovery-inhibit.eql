// Dragnet [Ransomware]: dragnet-ransomware-2025-7881 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 0dad7a5e-e8bd-58d3-884b-a39a9e880e58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
