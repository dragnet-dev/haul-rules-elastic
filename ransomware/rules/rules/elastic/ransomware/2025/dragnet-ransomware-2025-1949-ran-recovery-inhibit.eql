// Dragnet [Ransomware]: dragnet-ransomware-2025-1949 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 87b445a2-8d36-59c8-8017-855c888eeffb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
