// Dragnet [Ransomware]: dragnet-ransomware-2025-1276 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: f655b7d2-380c-58ca-a102-f2183774c945

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
