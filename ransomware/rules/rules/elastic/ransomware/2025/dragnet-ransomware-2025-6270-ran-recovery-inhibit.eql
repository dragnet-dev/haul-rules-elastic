// Dragnet [Ransomware]: dragnet-ransomware-2025-6270 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: 1d184aad-b24a-519d-a3b6-f6ca1363c6f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
