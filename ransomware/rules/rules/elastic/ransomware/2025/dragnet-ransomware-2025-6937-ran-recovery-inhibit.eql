// Dragnet [Ransomware]: dragnet-ransomware-2025-6937 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: 96cac7a9-4793-54c1-a660-b7c51eb283e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
