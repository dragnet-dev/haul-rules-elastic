// Dragnet [Ransomware]: dragnet-ransomware-2025-3196 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 264afc71-0824-5161-aa3c-9015079efd6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
