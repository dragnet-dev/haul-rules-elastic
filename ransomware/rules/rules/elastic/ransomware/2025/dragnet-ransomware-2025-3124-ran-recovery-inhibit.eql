// Dragnet [Ransomware]: dragnet-ransomware-2025-3124 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f5e31176-3b57-5dd5-8d04-11a45c9f65b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
