// Dragnet [Ransomware]: dragnet-ransomware-2025-1692 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: c1db6f18-a839-5562-a80d-1f50059a2dcc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
