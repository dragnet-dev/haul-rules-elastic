// Dragnet [Ransomware]: dragnet-ransomware-2025-7067 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9cf3804f-85b0-5623-929a-2049421e6961

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
