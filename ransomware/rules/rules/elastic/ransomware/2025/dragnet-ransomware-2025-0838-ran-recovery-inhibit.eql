// Dragnet [Ransomware]: dragnet-ransomware-2025-0838 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3fe1e568-4f91-5e81-9087-22083733159e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
