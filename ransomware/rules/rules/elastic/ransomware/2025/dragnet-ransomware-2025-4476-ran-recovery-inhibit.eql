// Dragnet [Ransomware]: dragnet-ransomware-2025-4476 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 13bea7a5-ebd1-51cf-9d4b-aa26c814c297

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
