// Dragnet [Ransomware]: dragnet-ransomware-2025-6902 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 02f5df09-8da5-55a4-b822-b99a2bc63ccf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
