// Dragnet [Ransomware]: dragnet-ransomware-2025-0653 — Recovery Inhibition (ralord)
// Status: experimental | Level: high | ID: acb1c261-101c-564f-a361-c69fa3a360f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
