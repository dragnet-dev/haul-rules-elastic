// Dragnet [Ransomware]: dragnet-ransomware-2025-0006 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 56409e9c-7232-5eda-8742-0d92b695f239

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
