// Dragnet [Ransomware]: dragnet-ransomware-2025-6913 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 75219f15-84d1-527d-97b0-8d3e24596006

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
