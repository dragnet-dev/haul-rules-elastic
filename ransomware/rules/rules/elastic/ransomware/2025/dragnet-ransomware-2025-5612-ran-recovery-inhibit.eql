// Dragnet [Ransomware]: dragnet-ransomware-2025-5612 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 06019b0d-93cf-5f17-bf00-7833f6810ab1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
