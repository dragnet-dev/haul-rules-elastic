// Dragnet [Ransomware]: dragnet-ransomware-2025-2396 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 1255d4b4-f9ba-5365-ba18-59960380aa37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
