// Dragnet [Ransomware]: dragnet-ransomware-2025-6714 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: ce2d83e9-4b27-5136-90cb-4df6cbc63b06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
