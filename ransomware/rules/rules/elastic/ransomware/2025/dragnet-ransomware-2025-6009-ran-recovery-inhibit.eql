// Dragnet [Ransomware]: dragnet-ransomware-2025-6009 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c1b45ce8-bfbe-58c1-8f64-47a0fe8a8a10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
