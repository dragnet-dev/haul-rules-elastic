// Dragnet [Ransomware]: dragnet-ransomware-2025-6828 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 6f674dac-1e83-5bfa-bc7f-d53252e9bd6d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
