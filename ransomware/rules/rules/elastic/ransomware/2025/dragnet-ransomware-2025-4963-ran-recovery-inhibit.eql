// Dragnet [Ransomware]: dragnet-ransomware-2025-4963 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 74374718-1b0f-58f8-9d03-66bf829011a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
