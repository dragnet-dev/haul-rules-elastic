// Dragnet [Ransomware]: dragnet-ransomware-2025-0658 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ceac5eb5-76d4-5246-83ac-2222c8291616

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
