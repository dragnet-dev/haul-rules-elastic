// Dragnet [Ransomware]: dragnet-ransomware-2025-5767 — Recovery Inhibition (genesis)
// Status: experimental | Level: high | ID: 69173def-8152-54c0-9982-61b25b7915b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
