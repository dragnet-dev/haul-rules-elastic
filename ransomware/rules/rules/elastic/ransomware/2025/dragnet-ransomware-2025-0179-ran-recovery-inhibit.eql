// Dragnet [Ransomware]: dragnet-ransomware-2025-0179 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: d4616609-613c-5801-acb8-a5612386a9cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
