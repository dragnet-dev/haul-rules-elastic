// Dragnet [Ransomware]: dragnet-ransomware-2025-3557 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: a034defa-b4e8-5950-9b09-013b139ad53a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
