// Dragnet [Ransomware]: dragnet-ransomware-2025-0664 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 9959b16f-40ff-55dd-adbe-75801e130180

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
