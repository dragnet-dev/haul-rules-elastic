// Dragnet [Ransomware]: dragnet-ransomware-2025-5589 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 50ec855b-f233-5051-86d1-2adbb5750ac9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
