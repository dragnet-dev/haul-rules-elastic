// Dragnet [Ransomware]: dragnet-ransomware-2025-2449 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 6657c376-3e3a-5815-89eb-ab3ef6c60a7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
