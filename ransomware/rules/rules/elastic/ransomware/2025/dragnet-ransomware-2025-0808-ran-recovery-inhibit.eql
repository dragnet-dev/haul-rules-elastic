// Dragnet [Ransomware]: dragnet-ransomware-2025-0808 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: de772d18-7727-52c8-86d5-4f257cd93007

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
