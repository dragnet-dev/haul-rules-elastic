// Dragnet [Ransomware]: dragnet-ransomware-2025-6479 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d1f25567-3e74-5345-833a-38411518bccd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
