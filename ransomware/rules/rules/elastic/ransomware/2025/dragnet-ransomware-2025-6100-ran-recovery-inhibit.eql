// Dragnet [Ransomware]: dragnet-ransomware-2025-6100 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 8a4c8f28-7310-59e4-9031-1645004749c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
