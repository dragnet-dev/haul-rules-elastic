// Dragnet [Ransomware]: dragnet-ransomware-2025-7069 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: a31e9576-ff17-55c2-be0e-f2baac87d958

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
