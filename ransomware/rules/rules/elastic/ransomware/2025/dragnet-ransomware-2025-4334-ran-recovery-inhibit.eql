// Dragnet [Ransomware]: dragnet-ransomware-2025-4334 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 3365f901-dc05-50a1-8303-9cd5732ca02a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
