// Dragnet [Ransomware]: dragnet-ransomware-2025-2506 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 368acf4e-e978-5317-8248-195a73148070

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
