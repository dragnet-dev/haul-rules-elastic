// Dragnet [Ransomware]: dragnet-ransomware-2025-5074 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 11c8e022-6232-5963-8db4-23b356a87d1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
