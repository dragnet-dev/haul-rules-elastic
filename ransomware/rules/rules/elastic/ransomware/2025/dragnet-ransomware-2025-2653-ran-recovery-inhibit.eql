// Dragnet [Ransomware]: dragnet-ransomware-2025-2653 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: c701dc4b-7ef1-51c8-b35f-fa8ae830bae1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
