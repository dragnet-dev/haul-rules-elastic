// Dragnet [Ransomware]: dragnet-ransomware-2025-1962 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: ec8e1b01-bae6-5759-8eb6-b2dc482952ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
