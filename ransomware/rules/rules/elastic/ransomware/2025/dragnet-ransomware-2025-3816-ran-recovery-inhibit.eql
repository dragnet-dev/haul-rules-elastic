// Dragnet [Ransomware]: dragnet-ransomware-2025-3816 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5fb9d8d1-1002-5d1e-8cac-90b3abc46bb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
