// Dragnet [Ransomware]: dragnet-ransomware-2025-2270 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 78ae3435-7559-5962-9703-2c698b8c44a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
