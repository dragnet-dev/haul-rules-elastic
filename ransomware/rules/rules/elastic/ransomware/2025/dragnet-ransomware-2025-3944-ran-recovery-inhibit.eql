// Dragnet [Ransomware]: dragnet-ransomware-2025-3944 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: e7ed1a52-4201-5bfc-b066-e9dc358503a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
