// Dragnet [Ransomware]: dragnet-ransomware-2025-2578 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: fd3288d7-e168-54cd-ab17-492c6bf4202e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
