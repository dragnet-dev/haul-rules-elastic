// Dragnet [Ransomware]: dragnet-ransomware-2025-2224 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 5153d7bc-f9cf-56c0-9165-8a69a1bef085

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
