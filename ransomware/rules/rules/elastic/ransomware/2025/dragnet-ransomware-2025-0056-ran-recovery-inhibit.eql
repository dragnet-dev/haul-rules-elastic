// Dragnet [Ransomware]: dragnet-ransomware-2025-0056 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: b15ec758-e8a5-5b0e-a6a9-49fbc56d6263

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
