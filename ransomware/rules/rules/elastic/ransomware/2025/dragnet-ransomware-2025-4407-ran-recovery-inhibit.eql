// Dragnet [Ransomware]: dragnet-ransomware-2025-4407 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: 598e0efd-3e5a-5d90-9108-035be9d1ebea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
