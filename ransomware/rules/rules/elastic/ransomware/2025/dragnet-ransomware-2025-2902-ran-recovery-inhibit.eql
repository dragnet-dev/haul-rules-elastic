// Dragnet [Ransomware]: dragnet-ransomware-2025-2902 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: dc841f30-4da2-5347-ad19-73ed57efb8b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
