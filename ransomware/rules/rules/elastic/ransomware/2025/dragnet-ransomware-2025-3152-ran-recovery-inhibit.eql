// Dragnet [Ransomware]: dragnet-ransomware-2025-3152 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 541190c7-322d-57c0-b5ef-806520caf07e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
