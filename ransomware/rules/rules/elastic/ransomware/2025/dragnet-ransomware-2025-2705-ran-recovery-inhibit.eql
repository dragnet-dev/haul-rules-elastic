// Dragnet [Ransomware]: dragnet-ransomware-2025-2705 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 824f69aa-3ee5-5fed-96b0-ecda963c9cc6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
