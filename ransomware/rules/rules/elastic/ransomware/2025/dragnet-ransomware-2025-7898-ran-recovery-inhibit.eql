// Dragnet [Ransomware]: dragnet-ransomware-2025-7898 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: acf34bbc-90e8-538e-8734-09d1deae9d42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
