// Dragnet [Ransomware]: dragnet-ransomware-2025-1189 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 1e13fe3e-6475-582b-8dbe-3eb9eafba90c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
