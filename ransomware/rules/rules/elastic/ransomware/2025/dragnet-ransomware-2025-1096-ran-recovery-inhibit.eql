// Dragnet [Ransomware]: dragnet-ransomware-2025-1096 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b94fe90c-7503-5d60-a5b4-58662c958685

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
