// Dragnet [Ransomware]: dragnet-ransomware-2025-2123 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 446f7817-ab66-5527-8748-c950a0e16e6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
