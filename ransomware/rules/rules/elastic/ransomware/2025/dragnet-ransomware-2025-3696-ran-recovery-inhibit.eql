// Dragnet [Ransomware]: dragnet-ransomware-2025-3696 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: 1dff595d-d112-54ad-9c17-2c9420d63c39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
