// Dragnet [Ransomware]: dragnet-ransomware-2025-7416 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 303d5cbd-f498-5f09-9a0b-d74406c2af59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
