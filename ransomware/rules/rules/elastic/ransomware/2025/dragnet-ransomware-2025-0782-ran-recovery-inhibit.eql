// Dragnet [Ransomware]: dragnet-ransomware-2025-0782 — Recovery Inhibition (bert)
// Status: experimental | Level: high | ID: 37fda110-3d27-544a-92fe-d9ffc1628eef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
