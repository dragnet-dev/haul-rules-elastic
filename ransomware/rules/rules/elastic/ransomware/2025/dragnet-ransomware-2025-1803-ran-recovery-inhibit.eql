// Dragnet [Ransomware]: dragnet-ransomware-2025-1803 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 64fa41e4-cc69-5797-b01c-6e2c963c7900

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
