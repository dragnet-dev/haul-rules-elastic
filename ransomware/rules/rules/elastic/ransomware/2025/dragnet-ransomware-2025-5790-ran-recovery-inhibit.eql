// Dragnet [Ransomware]: dragnet-ransomware-2025-5790 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: fa54c74b-8716-5584-ac51-67330035ef01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
