// Dragnet [Ransomware]: dragnet-ransomware-2025-1662 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 585b802f-febd-56e8-8241-8b4381d4f9a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
