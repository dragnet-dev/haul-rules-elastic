// Dragnet [Ransomware]: dragnet-ransomware-2025-1635 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: b6df423f-49f1-55d7-8341-3a35f76cf0ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
