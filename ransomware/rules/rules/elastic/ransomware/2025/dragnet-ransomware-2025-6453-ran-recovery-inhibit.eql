// Dragnet [Ransomware]: dragnet-ransomware-2025-6453 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 5e0b89ef-63b5-5d09-842d-e5d46c0609e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
