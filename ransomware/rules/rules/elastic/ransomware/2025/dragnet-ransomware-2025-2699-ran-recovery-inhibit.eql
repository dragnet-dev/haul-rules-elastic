// Dragnet [Ransomware]: dragnet-ransomware-2025-2699 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4136518c-d85f-5678-aea0-8bd0b2e3a418

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
