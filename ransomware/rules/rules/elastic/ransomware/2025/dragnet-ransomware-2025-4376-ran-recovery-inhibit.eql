// Dragnet [Ransomware]: dragnet-ransomware-2025-4376 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 61ca84d2-2d4e-5e18-9614-e9fea27d8cb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
