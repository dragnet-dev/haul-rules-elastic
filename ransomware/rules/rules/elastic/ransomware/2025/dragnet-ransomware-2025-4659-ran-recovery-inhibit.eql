// Dragnet [Ransomware]: dragnet-ransomware-2025-4659 — Recovery Inhibition (spacebears)
// Status: test | Level: high | ID: 6693f28a-b7fb-5b8f-b60b-1ab7be4e2a14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
