// Dragnet [Ransomware]: dragnet-ransomware-2025-4778 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 9d421362-5693-5b84-a275-dba4cd1d74d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
