// Dragnet [Ransomware]: dragnet-ransomware-2025-2790 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 12ec1e80-74d1-5019-b961-1d3600a289bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
