// Dragnet [Ransomware]: dragnet-ransomware-2025-4675 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 408277ea-516c-5899-828e-b07a2139016b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
