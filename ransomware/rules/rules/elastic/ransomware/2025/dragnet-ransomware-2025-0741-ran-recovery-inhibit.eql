// Dragnet [Ransomware]: dragnet-ransomware-2025-0741 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 01a75509-9ee9-5717-8dce-e804d5ad2acd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
