// Dragnet [Ransomware]: dragnet-ransomware-2025-7312 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 1c66bcdb-77fb-5476-9a60-091f48cd76f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
