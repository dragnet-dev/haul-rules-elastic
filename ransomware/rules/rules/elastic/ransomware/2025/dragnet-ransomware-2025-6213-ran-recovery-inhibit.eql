// Dragnet [Ransomware]: dragnet-ransomware-2025-6213 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4038d3e1-182c-54cf-b69e-2a565bb93b3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
