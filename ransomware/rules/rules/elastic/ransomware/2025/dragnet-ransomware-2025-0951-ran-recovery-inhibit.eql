// Dragnet [Ransomware]: dragnet-ransomware-2025-0951 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 83d500f2-5c67-533c-930d-ddf0c6315598

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
