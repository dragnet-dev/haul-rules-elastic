// Dragnet [Ransomware]: dragnet-ransomware-2025-5425 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 7bcd1b0e-6186-58c7-bab8-454a2e2cb073

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
