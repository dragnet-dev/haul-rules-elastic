// Dragnet [Ransomware]: dragnet-ransomware-2025-5103 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1fa0bd0f-a019-50dc-bfe5-59565fcf51fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
