// Dragnet [Ransomware]: dragnet-ransomware-2025-2979 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1f841816-d001-567c-b902-f398f932c4c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
