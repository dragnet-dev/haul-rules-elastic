// Dragnet [Ransomware]: dragnet-ransomware-2025-4105 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f498da1d-25fb-58a5-a16e-0ff9ecee414a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
