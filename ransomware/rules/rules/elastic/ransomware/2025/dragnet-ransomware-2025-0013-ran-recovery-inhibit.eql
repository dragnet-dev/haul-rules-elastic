// Dragnet [Ransomware]: dragnet-ransomware-2025-0013 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 8743b5de-80ba-5da9-bdb0-872f00a402fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
