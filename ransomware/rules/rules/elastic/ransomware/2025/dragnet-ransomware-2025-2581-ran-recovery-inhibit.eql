// Dragnet [Ransomware]: dragnet-ransomware-2025-2581 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4b21eafc-8869-5454-8946-b74b0ffff3b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
