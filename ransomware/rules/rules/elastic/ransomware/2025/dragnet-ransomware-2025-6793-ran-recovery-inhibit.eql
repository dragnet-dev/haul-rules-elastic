// Dragnet [Ransomware]: dragnet-ransomware-2025-6793 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 071793aa-fe6c-5ef5-a728-097d80e916f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
