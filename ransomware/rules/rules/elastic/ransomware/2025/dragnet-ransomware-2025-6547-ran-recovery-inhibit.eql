// Dragnet [Ransomware]: dragnet-ransomware-2025-6547 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2a1f4225-812c-59fd-9e42-fe5fa64688ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
