// Dragnet [Ransomware]: dragnet-ransomware-2025-3202 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: bacf93e2-8f79-5117-a17f-3aa65986de00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
