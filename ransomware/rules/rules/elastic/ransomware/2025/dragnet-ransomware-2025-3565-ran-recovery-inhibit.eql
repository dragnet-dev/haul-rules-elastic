// Dragnet [Ransomware]: dragnet-ransomware-2025-3565 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 80d4fd01-b3ff-578b-844f-f52681b719f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
