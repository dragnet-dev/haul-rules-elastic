// Dragnet [Ransomware]: dragnet-ransomware-2025-0412 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: c38b2b19-2e1c-5e11-9b68-9b209ec9c83b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
