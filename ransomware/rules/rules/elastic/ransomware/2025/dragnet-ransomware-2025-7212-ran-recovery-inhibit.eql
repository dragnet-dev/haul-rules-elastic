// Dragnet [Ransomware]: dragnet-ransomware-2025-7212 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 3292396f-1715-54dc-bd82-6a42901cc156

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
