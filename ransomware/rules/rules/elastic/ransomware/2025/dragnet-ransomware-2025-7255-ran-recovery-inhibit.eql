// Dragnet [Ransomware]: dragnet-ransomware-2025-7255 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 9d9fd066-08fe-59fe-accb-333944cba4c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
