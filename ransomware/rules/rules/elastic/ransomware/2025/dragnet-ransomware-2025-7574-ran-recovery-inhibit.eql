// Dragnet [Ransomware]: dragnet-ransomware-2025-7574 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 30c3c6ad-2d22-5435-ab13-c10cafaa82db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
