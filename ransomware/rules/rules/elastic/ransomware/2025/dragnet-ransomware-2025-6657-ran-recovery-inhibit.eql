// Dragnet [Ransomware]: dragnet-ransomware-2025-6657 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2f8bb78c-04da-5db3-8ff7-29ecdcfaae8f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
