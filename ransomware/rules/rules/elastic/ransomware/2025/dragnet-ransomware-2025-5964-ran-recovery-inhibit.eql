// Dragnet [Ransomware]: dragnet-ransomware-2025-5964 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: c0872c39-f19e-5e22-990e-01c246a3ecc1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
