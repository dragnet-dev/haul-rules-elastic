// Dragnet [Ransomware]: dragnet-ransomware-2025-0314 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 571e195f-168d-51ef-9dc7-2edf2199d1d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
