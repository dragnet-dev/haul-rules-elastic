// Dragnet [Ransomware]: dragnet-ransomware-2025-6038 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1bd19e8c-ce14-5e2f-9a79-d642a9259da2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
