// Dragnet [Ransomware]: dragnet-ransomware-2025-7576 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 642c3d99-30d3-50f1-8724-da2160e6ba95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
