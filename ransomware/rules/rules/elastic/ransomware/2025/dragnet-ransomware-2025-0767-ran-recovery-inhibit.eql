// Dragnet [Ransomware]: dragnet-ransomware-2025-0767 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: 9bd38086-fa22-5b33-b9fe-92c4d0d9b6f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
