// Dragnet [Ransomware]: dragnet-ransomware-2025-0618 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: e7a306d3-90ec-5e96-afe6-c68bcd7a6490

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
