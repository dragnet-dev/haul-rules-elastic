// Dragnet [Ransomware]: dragnet-ransomware-2025-2673 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: ff9e5177-d50c-5dba-94cc-8f3ecc88d8ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
