// Dragnet [Ransomware]: dragnet-ransomware-2025-7015 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 44129947-5c2d-5b32-ac68-9bbb0c56258e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
