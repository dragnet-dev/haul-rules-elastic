// Dragnet [Ransomware]: dragnet-ransomware-2025-3563 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 6934770a-3078-523b-b880-f285a8ab7882

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
