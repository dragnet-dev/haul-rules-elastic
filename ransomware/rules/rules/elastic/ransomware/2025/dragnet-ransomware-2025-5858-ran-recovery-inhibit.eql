// Dragnet [Ransomware]: dragnet-ransomware-2025-5858 — Recovery Inhibition (tengu)
// Status: test | Level: high | ID: a8b472e2-5229-5765-ab57-c1684654ddb2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
