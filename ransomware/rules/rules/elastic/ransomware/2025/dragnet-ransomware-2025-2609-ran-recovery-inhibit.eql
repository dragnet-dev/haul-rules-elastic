// Dragnet [Ransomware]: dragnet-ransomware-2025-2609 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2eb50e29-605f-512b-8213-ba9fead3fa1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
