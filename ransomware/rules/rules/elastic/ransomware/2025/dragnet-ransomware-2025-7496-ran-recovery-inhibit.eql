// Dragnet [Ransomware]: dragnet-ransomware-2025-7496 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 4e0cc03b-4bf3-5d56-b798-4bd2eb838b74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
