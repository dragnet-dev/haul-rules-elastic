// Dragnet [Ransomware]: dragnet-ransomware-2025-7087 — Recovery Inhibition (worldleaks)
// Status: test | Level: high | ID: c970174c-f317-52aa-95ce-b0f8b342a940

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
