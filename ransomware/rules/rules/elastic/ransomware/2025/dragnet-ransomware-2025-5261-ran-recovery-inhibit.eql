// Dragnet [Ransomware]: dragnet-ransomware-2025-5261 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: a54b5d78-31f6-59a5-bfc6-633f9be2e46c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
