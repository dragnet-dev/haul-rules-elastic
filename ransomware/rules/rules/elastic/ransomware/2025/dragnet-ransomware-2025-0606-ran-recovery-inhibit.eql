// Dragnet [Ransomware]: dragnet-ransomware-2025-0606 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 135fed6c-fa09-5ff3-836f-f91ade7ac8c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
