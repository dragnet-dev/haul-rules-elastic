// Dragnet [Ransomware]: dragnet-ransomware-2025-4323 — Recovery Inhibition (embargo)
// Status: test | Level: high | ID: 9b5f182f-2e05-59cc-a3c6-d3cfe3f03166

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
