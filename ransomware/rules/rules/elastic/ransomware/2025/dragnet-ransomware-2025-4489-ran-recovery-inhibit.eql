// Dragnet [Ransomware]: dragnet-ransomware-2025-4489 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8012622f-e217-5ec6-ae0e-b31a034c0faa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
