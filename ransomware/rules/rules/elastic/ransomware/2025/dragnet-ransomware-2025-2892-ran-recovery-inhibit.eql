// Dragnet [Ransomware]: dragnet-ransomware-2025-2892 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 2d005f11-4865-5477-9dc9-14583d372845

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
