// Dragnet [Ransomware]: dragnet-ransomware-2025-3231 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 63c39715-507e-573f-96fa-011ea2909ce5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
