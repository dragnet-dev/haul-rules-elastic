// Dragnet [Ransomware]: dragnet-ransomware-2025-4836 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: ccf2c2ce-e230-5997-b956-c22f6ccf86a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
