// Dragnet [Ransomware]: dragnet-ransomware-2025-2199 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 4eb797eb-c193-5ca3-acd2-b7cfb7e64791

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
