// Dragnet [Ransomware]: dragnet-ransomware-2025-1111 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a01a0cfc-47f7-5967-80e5-a955679a9e27

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
