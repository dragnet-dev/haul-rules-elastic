// Dragnet [Ransomware]: dragnet-ransomware-2025-3984 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: d8ee21f7-535f-590a-926a-e1f5ea68a292

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
