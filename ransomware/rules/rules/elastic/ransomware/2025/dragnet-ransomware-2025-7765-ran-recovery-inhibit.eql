// Dragnet [Ransomware]: dragnet-ransomware-2025-7765 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: ec3f6a15-33c8-54dd-82b4-9fb99a9aa7b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
