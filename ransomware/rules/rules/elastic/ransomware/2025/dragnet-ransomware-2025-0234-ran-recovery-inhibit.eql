// Dragnet [Ransomware]: dragnet-ransomware-2025-0234 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5c696c23-99d4-5e08-85a9-160bc00d0fd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
