// Dragnet [Ransomware]: dragnet-ransomware-2025-3362 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f83cbf2e-597e-5ce6-ac34-cd5db76554ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
