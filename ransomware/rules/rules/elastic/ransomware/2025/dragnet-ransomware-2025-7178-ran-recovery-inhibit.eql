// Dragnet [Ransomware]: dragnet-ransomware-2025-7178 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1117a997-4f00-5899-834a-17aaa591d1af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
