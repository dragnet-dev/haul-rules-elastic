// Dragnet [Ransomware]: dragnet-ransomware-2025-5304 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 526d67c7-2a91-5d20-b0b8-ac39daa97881

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
