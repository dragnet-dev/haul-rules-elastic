// Dragnet [Ransomware]: dragnet-ransomware-2025-6102 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: dd219b43-2167-556d-8e8d-7ff2677d975f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
