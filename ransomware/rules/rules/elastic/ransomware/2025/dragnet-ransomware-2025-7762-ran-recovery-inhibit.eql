// Dragnet [Ransomware]: dragnet-ransomware-2025-7762 — Recovery Inhibition (minteye)
// Status: deprecated | Level: high | ID: 4852173f-5bb1-5267-9566-7a7cab28a698

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
