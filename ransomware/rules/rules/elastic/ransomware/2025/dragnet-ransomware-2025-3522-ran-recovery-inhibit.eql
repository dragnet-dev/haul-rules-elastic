// Dragnet [Ransomware]: dragnet-ransomware-2025-3522 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bc08e53a-953a-538c-95ff-af3c34700b67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
