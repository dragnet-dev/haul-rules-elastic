// Dragnet [Ransomware]: dragnet-ransomware-2025-3536 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 39b6ac2e-4f17-554f-a08d-09d5e39d14b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
