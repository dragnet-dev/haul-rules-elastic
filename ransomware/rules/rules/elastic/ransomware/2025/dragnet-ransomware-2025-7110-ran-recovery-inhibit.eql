// Dragnet [Ransomware]: dragnet-ransomware-2025-7110 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 7a04bd9c-0566-59a6-b4a0-d1d1a81c1008

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
