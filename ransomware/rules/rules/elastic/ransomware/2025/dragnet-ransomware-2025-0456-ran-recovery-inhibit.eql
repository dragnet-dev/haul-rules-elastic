// Dragnet [Ransomware]: dragnet-ransomware-2025-0456 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: c49d958e-b9f4-51af-9fbd-7d18232c2a48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
