// Dragnet [Ransomware]: dragnet-ransomware-2025-7215 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: f52d309c-ba4c-5523-926b-dcabebb959a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
