// Dragnet [Ransomware]: dragnet-ransomware-2025-0715 — Recovery Inhibition (kryptos)
// Status: deprecated | Level: high | ID: 26778694-7f9d-5f83-a48e-07828b761617

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
