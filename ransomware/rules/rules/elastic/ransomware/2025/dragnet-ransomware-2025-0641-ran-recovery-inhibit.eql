// Dragnet [Ransomware]: dragnet-ransomware-2025-0641 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 62cb88f1-4a33-58a5-9269-66d06d358d67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
