// Dragnet [Ransomware]: dragnet-ransomware-2025-1992 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 6971307f-e8f1-5283-b5f6-c450c5d2f40b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
