// Dragnet [Ransomware]: dragnet-ransomware-2025-2492 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 4f26958f-0209-5d82-b853-12af4031a07a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
