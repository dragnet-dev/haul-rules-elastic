// Dragnet [Ransomware]: dragnet-ransomware-2025-2381 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 53a2cd1d-ac27-5e3e-aa6f-9815e294a128

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
