// Dragnet [Ransomware]: dragnet-ransomware-2025-5591 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: d920fee8-9dc2-5f65-bedf-66e308e11732

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
