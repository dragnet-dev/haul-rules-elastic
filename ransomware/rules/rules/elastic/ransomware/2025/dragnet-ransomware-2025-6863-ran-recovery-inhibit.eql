// Dragnet [Ransomware]: dragnet-ransomware-2025-6863 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 6112fc63-2b11-5b12-a23c-0689d66efc55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
