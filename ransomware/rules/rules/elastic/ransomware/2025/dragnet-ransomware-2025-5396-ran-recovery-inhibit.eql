// Dragnet [Ransomware]: dragnet-ransomware-2025-5396 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 8df30ea0-d84b-556c-966a-84973bb17052

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
