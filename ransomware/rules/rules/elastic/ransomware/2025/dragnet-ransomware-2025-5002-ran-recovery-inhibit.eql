// Dragnet [Ransomware]: dragnet-ransomware-2025-5002 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 4df67558-9217-54c0-9517-d4dbce0a760b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
