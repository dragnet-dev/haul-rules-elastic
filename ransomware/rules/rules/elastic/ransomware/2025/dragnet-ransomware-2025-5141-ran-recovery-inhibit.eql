// Dragnet [Ransomware]: dragnet-ransomware-2025-5141 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 2f599e16-e154-54c9-b0b0-9c212ed28be2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
