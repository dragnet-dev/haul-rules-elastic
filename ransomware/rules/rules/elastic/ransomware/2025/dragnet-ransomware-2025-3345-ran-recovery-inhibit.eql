// Dragnet [Ransomware]: dragnet-ransomware-2025-3345 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 7c49eaf0-c3c2-5853-a8a3-a0a28938e237

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
