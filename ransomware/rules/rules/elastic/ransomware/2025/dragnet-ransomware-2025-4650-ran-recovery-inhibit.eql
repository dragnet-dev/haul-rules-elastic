// Dragnet [Ransomware]: dragnet-ransomware-2025-4650 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 04d5c15e-d1cb-5083-863b-ab6e7d95253f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
