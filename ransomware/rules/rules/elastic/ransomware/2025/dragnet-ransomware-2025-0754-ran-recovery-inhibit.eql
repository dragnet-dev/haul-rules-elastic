// Dragnet [Ransomware]: dragnet-ransomware-2025-0754 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: 8a5468fb-c101-55fc-af65-4b3ebfa05096

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
