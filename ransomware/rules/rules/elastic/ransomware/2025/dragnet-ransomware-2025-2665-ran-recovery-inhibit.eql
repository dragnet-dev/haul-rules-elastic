// Dragnet [Ransomware]: dragnet-ransomware-2025-2665 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 0e526f48-2982-5077-a498-6a52c7b25492

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
