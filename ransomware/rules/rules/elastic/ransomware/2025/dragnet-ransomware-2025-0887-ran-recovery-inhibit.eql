// Dragnet [Ransomware]: dragnet-ransomware-2025-0887 — Recovery Inhibition (interlock)
// Status: test | Level: high | ID: 71b8b4a8-e3e4-54e0-8352-e7191ea2246c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
