// Dragnet [Ransomware]: dragnet-ransomware-2025-3863 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: cfe65b01-56f8-561a-93aa-26f38d12d7ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
