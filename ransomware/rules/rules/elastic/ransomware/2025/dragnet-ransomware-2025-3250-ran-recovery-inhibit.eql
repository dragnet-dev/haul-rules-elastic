// Dragnet [Ransomware]: dragnet-ransomware-2025-3250 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 01c4419c-6819-5f40-83d2-b44cde616b23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
