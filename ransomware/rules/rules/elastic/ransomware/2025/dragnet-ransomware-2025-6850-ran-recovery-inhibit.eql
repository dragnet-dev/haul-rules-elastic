// Dragnet [Ransomware]: dragnet-ransomware-2025-6850 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 5591fef0-b4cc-57e5-821f-ddf243c3f285

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
