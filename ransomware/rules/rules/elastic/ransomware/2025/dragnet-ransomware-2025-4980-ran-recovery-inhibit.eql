// Dragnet [Ransomware]: dragnet-ransomware-2025-4980 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 57d34f01-aba4-5eb1-b4b9-2eb0c43cf448

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
