// Dragnet [Ransomware]: dragnet-ransomware-2025-6665 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e81d5e1b-3a2e-57bf-8690-7d655f08a31b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
