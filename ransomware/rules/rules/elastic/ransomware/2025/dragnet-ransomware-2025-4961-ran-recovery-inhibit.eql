// Dragnet [Ransomware]: dragnet-ransomware-2025-4961 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: 695f3fc1-0897-5d7b-968d-c4849d5e8e34

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
