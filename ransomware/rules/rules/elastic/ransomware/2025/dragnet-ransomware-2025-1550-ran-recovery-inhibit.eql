// Dragnet [Ransomware]: dragnet-ransomware-2025-1550 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 59c72284-0466-5a78-9416-522f2586fd56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
