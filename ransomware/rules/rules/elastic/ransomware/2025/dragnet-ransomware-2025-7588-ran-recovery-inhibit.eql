// Dragnet [Ransomware]: dragnet-ransomware-2025-7588 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 35599b10-1519-5028-9cd7-87265f70a052

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
