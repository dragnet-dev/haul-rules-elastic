// Dragnet [Ransomware]: dragnet-ransomware-2025-7467 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: b1f5a217-dc70-57b7-bfcf-0ac9c068bc8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
