// Dragnet [Ransomware]: dragnet-ransomware-2025-1080 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f1781f16-2970-5851-bc0c-fbdf14e95f0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
