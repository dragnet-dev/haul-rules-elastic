// Dragnet [Ransomware]: dragnet-ransomware-2025-5916 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: 364477e2-f51a-508b-a8c2-1ccecee5395e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
