// Dragnet [Ransomware]: dragnet-ransomware-2025-6768 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f9225e73-2efe-5740-8de7-a35eccdf05f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
