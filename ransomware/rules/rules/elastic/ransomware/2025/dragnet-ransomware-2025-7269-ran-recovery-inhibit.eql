// Dragnet [Ransomware]: dragnet-ransomware-2025-7269 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: d8761507-3f30-5fac-a226-84878b44637f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
