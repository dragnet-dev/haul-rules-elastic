// Dragnet [Ransomware]: dragnet-ransomware-2025-1263 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8704dc5b-3ff7-52dc-91af-8f1ccac70b66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
