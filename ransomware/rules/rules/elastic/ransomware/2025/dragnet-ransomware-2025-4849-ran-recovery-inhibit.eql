// Dragnet [Ransomware]: dragnet-ransomware-2025-4849 — Recovery Inhibition (insomnia)
// Status: experimental | Level: high | ID: ee3d2389-d6b5-504e-85a1-6b529297fe6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
