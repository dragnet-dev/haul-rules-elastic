// Dragnet [Ransomware]: dragnet-ransomware-2025-0780 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 82aa0ce9-65ce-5760-a642-613f8ed7a601

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
