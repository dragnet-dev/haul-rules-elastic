// Dragnet [Ransomware]: dragnet-ransomware-2025-3088 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 50b54812-ab36-5d52-b9a4-a0c257802216

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
