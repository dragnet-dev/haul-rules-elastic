// Dragnet [Ransomware]: dragnet-ransomware-2025-4291 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: d8fbf3de-f826-5b51-8433-096fdfee4948

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
