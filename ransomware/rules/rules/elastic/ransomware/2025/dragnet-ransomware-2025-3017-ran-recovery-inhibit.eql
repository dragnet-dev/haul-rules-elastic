// Dragnet [Ransomware]: dragnet-ransomware-2025-3017 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 913b5e65-f0bb-5522-ace2-7b844a743d77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
