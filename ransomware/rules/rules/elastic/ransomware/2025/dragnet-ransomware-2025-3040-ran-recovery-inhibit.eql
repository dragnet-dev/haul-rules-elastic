// Dragnet [Ransomware]: dragnet-ransomware-2025-3040 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 8d86c573-99b1-5be8-bddb-16bcdae15ba0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
