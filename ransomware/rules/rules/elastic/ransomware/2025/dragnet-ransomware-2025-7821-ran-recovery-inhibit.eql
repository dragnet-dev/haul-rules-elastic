// Dragnet [Ransomware]: dragnet-ransomware-2025-7821 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 2e2897de-b0c2-5a38-af79-8c403c0d5e6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
