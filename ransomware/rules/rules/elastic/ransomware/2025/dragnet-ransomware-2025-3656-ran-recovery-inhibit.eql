// Dragnet [Ransomware]: dragnet-ransomware-2025-3656 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 23c0c6d5-8948-5c0f-91d6-4295f03dbfd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
