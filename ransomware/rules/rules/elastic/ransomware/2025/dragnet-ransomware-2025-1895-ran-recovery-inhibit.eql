// Dragnet [Ransomware]: dragnet-ransomware-2025-1895 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 634d0497-2722-5324-925a-60fb9f3bdbcb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
