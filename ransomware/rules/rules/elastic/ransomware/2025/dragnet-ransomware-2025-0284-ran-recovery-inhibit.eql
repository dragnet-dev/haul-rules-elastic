// Dragnet [Ransomware]: dragnet-ransomware-2025-0284 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 8ecfdd11-ca40-5423-9b9e-72fb995d28c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
