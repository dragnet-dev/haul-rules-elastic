// Dragnet [Ransomware]: dragnet-ransomware-2025-7128 — Recovery Inhibition (direwolf)
// Status: test | Level: high | ID: 937c1906-a1ed-593a-ac12-d9727393d95f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
