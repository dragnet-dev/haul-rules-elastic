// Dragnet [Ransomware]: dragnet-ransomware-2025-7040 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 821ee66f-a40a-58dc-8074-ba59ebdcc4d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
