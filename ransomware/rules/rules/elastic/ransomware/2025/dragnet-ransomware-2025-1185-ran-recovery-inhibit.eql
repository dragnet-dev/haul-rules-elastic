// Dragnet [Ransomware]: dragnet-ransomware-2025-1185 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: fe16a074-6039-5de9-985d-8e24a3b7bca7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
