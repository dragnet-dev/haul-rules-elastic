// Dragnet [Ransomware]: dragnet-ransomware-2025-7017 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 8978d3f0-5655-521d-a459-33ebeb7d8cee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
