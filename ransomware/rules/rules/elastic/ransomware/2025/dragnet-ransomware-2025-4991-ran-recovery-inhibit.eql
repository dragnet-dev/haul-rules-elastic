// Dragnet [Ransomware]: dragnet-ransomware-2025-4991 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 8bfdf409-5f4a-5748-b978-7a987c7d9401

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
