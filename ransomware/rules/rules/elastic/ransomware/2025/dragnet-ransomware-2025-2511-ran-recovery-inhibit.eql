// Dragnet [Ransomware]: dragnet-ransomware-2025-2511 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f721e505-07b6-50e7-982f-92782ead4236

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
