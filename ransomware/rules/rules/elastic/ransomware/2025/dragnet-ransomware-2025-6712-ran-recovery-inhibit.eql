// Dragnet [Ransomware]: dragnet-ransomware-2025-6712 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 2b6598ad-b9b0-55de-93c8-dc7e7954783a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
