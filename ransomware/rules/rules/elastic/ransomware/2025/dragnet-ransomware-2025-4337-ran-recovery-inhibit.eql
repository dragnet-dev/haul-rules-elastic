// Dragnet [Ransomware]: dragnet-ransomware-2025-4337 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: ae73049a-4c59-5fdd-86d7-2da3b2963b92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
