// Dragnet [Ransomware]: dragnet-ransomware-2025-6892 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: e50ad8f6-4f03-59dd-b624-6fe10015dd2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
