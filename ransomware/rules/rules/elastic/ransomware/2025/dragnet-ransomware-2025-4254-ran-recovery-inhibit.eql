// Dragnet [Ransomware]: dragnet-ransomware-2025-4254 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: fef84d4b-76ea-5ada-8549-4e4bed2b0d8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
