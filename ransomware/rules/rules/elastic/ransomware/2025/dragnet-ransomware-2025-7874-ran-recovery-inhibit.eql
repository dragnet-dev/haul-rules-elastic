// Dragnet [Ransomware]: dragnet-ransomware-2025-7874 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: dcb2b779-fe76-53db-86ab-f48be644e827

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
