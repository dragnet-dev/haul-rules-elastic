// Dragnet [Ransomware]: dragnet-ransomware-2025-5553 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d0a2d656-4e61-50b5-960c-f575771bc80b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
