// Dragnet [Ransomware]: dragnet-ransomware-2025-4189 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 62fe366f-a687-54d2-9dd0-ea06983f497c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
