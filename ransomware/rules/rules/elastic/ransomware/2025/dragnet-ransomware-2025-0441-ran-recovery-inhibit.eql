// Dragnet [Ransomware]: dragnet-ransomware-2025-0441 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 0f692ab8-3824-53c0-b8d5-e2b9bd34d554

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
