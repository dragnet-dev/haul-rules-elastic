// Dragnet [Ransomware]: dragnet-ransomware-2025-7734 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 8b0b7b21-71fe-5d9c-9db2-ed9ae77d158b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
