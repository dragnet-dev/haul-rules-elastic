// Dragnet [Ransomware]: dragnet-ransomware-2025-2531 — Recovery Inhibition (ralord)
// Status: experimental | Level: high | ID: 888f1f24-4dd3-57ab-92f0-ef0c1b6fd613

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
