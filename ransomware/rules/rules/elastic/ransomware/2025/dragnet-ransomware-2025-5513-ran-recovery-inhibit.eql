// Dragnet [Ransomware]: dragnet-ransomware-2025-5513 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: cf3a7eb2-d6fa-5e33-a997-dfffddf8f552

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
