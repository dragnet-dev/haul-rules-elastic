// Dragnet [Ransomware]: dragnet-ransomware-2025-3021 — Recovery Inhibition (blackshrantac)
// Status: experimental | Level: high | ID: 12de8726-3707-5978-b23f-2e000901b162

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
