// Dragnet [Ransomware]: dragnet-ransomware-2025-4514 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 4547ccb5-4baf-506d-9060-256db983415d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
