// Dragnet [Ransomware]: dragnet-ransomware-2025-1014 — Recovery Inhibition (osiris)
// Status: deprecated | Level: high | ID: 32d356c5-41ab-5847-a87c-ffbefa174490

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
