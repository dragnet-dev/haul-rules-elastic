// Dragnet [Ransomware]: dragnet-ransomware-2025-7134 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 97d909e8-79e2-5642-9cdf-778191259d7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
