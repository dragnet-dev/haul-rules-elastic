// Dragnet [Ransomware]: dragnet-ransomware-2025-2686 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: d2075f00-f9f7-5d9b-89d7-447caa7c3cec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
