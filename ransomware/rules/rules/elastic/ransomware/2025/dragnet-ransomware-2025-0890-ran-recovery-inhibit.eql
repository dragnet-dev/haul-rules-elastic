// Dragnet [Ransomware]: dragnet-ransomware-2025-0890 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: adcb9303-a8b6-55cd-aa5c-2b33ab1590b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
