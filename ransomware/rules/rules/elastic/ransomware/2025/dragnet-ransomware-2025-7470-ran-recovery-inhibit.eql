// Dragnet [Ransomware]: dragnet-ransomware-2025-7470 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 540e9e67-eeaf-5077-80d3-a34abe21cacf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
