// Dragnet [Ransomware]: dragnet-ransomware-2025-4371 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 7abc51bf-3fff-52af-ae8d-91e88d5f7b56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
