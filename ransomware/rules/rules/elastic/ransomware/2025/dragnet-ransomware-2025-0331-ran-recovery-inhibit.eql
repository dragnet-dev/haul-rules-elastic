// Dragnet [Ransomware]: dragnet-ransomware-2025-0331 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 7a0ec1d7-8e28-57e8-bdb0-6ed3d0a23d3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
