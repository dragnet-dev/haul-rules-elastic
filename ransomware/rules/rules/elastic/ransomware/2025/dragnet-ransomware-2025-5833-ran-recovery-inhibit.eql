// Dragnet [Ransomware]: dragnet-ransomware-2025-5833 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: e8a54723-0d39-5eef-a351-1095f57de888

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
