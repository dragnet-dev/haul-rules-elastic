// Dragnet [Ransomware]: dragnet-ransomware-2025-4779 — Recovery Inhibition (radar)
// Status: deprecated | Level: high | ID: 7dd9e51f-b81b-585a-b548-674037728d3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
