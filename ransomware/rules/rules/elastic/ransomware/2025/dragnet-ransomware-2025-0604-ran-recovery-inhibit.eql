// Dragnet [Ransomware]: dragnet-ransomware-2025-0604 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 49c41358-0715-5000-aec2-ee5c68845946

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
