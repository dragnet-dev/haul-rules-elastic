// Dragnet [Ransomware]: dragnet-ransomware-2025-3825 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: e3738605-a6f1-5f8a-a593-4f87048c51e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
