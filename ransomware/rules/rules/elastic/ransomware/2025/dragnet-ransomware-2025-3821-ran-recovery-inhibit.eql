// Dragnet [Ransomware]: dragnet-ransomware-2025-3821 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ff775f60-056d-516c-899f-71e67c8b073d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
