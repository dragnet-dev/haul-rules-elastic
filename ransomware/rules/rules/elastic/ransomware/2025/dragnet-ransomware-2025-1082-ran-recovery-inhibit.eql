// Dragnet [Ransomware]: dragnet-ransomware-2025-1082 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b13f13e2-18ec-593e-b303-724fa5dff95a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
