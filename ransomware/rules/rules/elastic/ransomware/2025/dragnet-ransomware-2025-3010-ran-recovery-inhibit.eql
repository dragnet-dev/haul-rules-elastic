// Dragnet [Ransomware]: dragnet-ransomware-2025-3010 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 6477c0b9-b7a1-5556-bf48-b2daadf4d177

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
