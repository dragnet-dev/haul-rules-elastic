// Dragnet [Ransomware]: dragnet-ransomware-2025-6304 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 35707d08-7b07-577e-a24e-fdac6d6b4974

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
