// Dragnet [Ransomware]: dragnet-ransomware-2025-3469 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: b279a1b4-ee2c-5944-ae02-2df772bf0156

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
