// Dragnet [Ransomware]: dragnet-ransomware-2025-5171 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 4205fdd1-9f83-55cc-8717-5a0fb03e48b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
