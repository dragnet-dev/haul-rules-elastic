// Dragnet [Ransomware]: dragnet-ransomware-2025-4494 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: fc9bbdaa-c0d1-5835-80ca-b06693419ef5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
