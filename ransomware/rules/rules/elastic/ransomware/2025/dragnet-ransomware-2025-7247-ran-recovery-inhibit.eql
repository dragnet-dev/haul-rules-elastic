// Dragnet [Ransomware]: dragnet-ransomware-2025-7247 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: fb9f3625-b9ea-5a73-8bd6-6d04a4268ef5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
