// Dragnet [Ransomware]: dragnet-ransomware-2025-0337 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 37cad9bf-a535-571e-97d2-81d32bb8fd1b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
