// Dragnet [Ransomware]: dragnet-ransomware-2025-7810 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 298399b8-80a1-5496-ad3d-98c9250cb24c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
