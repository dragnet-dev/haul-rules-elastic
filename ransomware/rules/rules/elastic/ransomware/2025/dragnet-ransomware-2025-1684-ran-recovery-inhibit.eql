// Dragnet [Ransomware]: dragnet-ransomware-2025-1684 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 6c1a89c2-3e3c-5ce8-8b91-98eb7e34cbde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
