// Dragnet [Ransomware]: dragnet-ransomware-2025-2004 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 53b93bec-597e-5af0-9872-7516fb0845c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
