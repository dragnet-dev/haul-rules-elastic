// Dragnet [Ransomware]: dragnet-ransomware-2025-0831 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d8b8d28f-596e-5e50-8fce-df25528eac3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
