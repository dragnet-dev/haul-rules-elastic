// Dragnet [Ransomware]: dragnet-ransomware-2025-7062 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: fe4c59ce-7604-587e-94e5-63dd20ad576a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
