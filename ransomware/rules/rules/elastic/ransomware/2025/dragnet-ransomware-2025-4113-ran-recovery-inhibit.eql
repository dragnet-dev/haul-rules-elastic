// Dragnet [Ransomware]: dragnet-ransomware-2025-4113 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 1d7245d8-fd4c-560b-8f0a-f35069d29424

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
