// Dragnet [Ransomware]: dragnet-ransomware-2025-4461 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 2df8bda5-dfa8-5025-81e9-cce80b664b8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
