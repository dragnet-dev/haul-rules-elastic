// Dragnet [Ransomware]: dragnet-ransomware-2025-0516 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 4c5ae05a-0619-5648-a6ec-56a275c9a310

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
