// Dragnet [Ransomware]: dragnet-ransomware-2025-3772 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: a22f0974-59f4-5f89-8d86-f901365b8433

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
