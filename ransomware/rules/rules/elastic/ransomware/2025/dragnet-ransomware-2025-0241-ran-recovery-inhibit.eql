// Dragnet [Ransomware]: dragnet-ransomware-2025-0241 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 2f84a1a6-3f41-5d34-b0f0-fed8f4d75c5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
