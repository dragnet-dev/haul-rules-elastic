// Dragnet [Ransomware]: dragnet-ransomware-2025-0222 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 58605b6a-1411-5f3c-81a1-67b7f8e31478

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
