// Dragnet [Ransomware]: dragnet-ransomware-2025-7567 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 9700ddaa-f2e4-5d46-a5ed-ab40a4111587

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
