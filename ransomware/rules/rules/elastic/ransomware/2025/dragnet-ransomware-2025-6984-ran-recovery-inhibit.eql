// Dragnet [Ransomware]: dragnet-ransomware-2025-6984 — Recovery Inhibition (securotrop)
// Status: test | Level: high | ID: 90539677-92df-5367-9c35-2b1e0fce2a28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
