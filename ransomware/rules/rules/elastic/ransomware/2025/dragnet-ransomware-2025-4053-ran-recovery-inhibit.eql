// Dragnet [Ransomware]: dragnet-ransomware-2025-4053 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: b69fe918-397c-585e-afeb-e782593cda3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
