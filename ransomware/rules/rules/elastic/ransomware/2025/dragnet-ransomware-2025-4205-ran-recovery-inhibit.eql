// Dragnet [Ransomware]: dragnet-ransomware-2025-4205 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: f9667fd1-dd21-58be-ac59-01ab1fcc2dad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
