// Dragnet [Ransomware]: dragnet-ransomware-2025-6121 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 209e46d7-6dad-5ef2-8326-82d5fc5e1a88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
