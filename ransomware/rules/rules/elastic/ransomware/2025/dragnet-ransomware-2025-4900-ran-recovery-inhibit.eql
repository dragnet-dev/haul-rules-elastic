// Dragnet [Ransomware]: dragnet-ransomware-2025-4900 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: a61cd063-956b-5982-ad4a-792da28e1038

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
