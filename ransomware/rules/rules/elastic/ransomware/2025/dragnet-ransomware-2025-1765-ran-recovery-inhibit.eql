// Dragnet [Ransomware]: dragnet-ransomware-2025-1765 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 51f48642-c8c6-5fc6-873e-1951b3c389b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
