// Dragnet [Ransomware]: dragnet-ransomware-2025-2050 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d9139e4d-0b25-590f-a964-a093adddcdd3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
