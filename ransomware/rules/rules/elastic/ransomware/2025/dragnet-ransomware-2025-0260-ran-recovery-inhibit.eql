// Dragnet [Ransomware]: dragnet-ransomware-2025-0260 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a75ec700-1731-567d-8d08-ffbfa2b55d2a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
