// Dragnet [Ransomware]: dragnet-ransomware-2025-3401 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 39c153b2-cb95-546b-8e52-5f1fe98108a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
