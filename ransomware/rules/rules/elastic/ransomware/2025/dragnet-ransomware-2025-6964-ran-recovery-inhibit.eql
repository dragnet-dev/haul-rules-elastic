// Dragnet [Ransomware]: dragnet-ransomware-2025-6964 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: f889f7cb-51b9-5654-abbb-0077d071e357

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
