// Dragnet [Ransomware]: dragnet-ransomware-2025-0298 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 643e6fdc-59e0-526b-8d6d-0160baea25eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
