// Dragnet [Ransomware]: dragnet-ransomware-2025-7270 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: aad9a3e4-f3f2-5512-865a-7bb384d77a6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
