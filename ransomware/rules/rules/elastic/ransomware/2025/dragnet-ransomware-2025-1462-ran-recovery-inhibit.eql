// Dragnet [Ransomware]: dragnet-ransomware-2025-1462 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: bccfddd2-2da6-50f8-938d-1f781e4d1621

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
