// Dragnet [Ransomware]: dragnet-ransomware-2025-5477 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 3323c324-cf39-5932-b0e5-a514c5fc794d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
