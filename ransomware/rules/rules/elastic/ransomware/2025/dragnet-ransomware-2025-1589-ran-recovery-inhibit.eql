// Dragnet [Ransomware]: dragnet-ransomware-2025-1589 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9789b2fe-0372-5dec-993a-fa9b98ca30a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
