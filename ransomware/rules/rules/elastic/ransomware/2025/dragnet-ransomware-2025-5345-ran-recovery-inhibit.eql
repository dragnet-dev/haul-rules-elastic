// Dragnet [Ransomware]: dragnet-ransomware-2025-5345 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8a9e9d6b-e17c-522c-a5d4-4e09540149ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
