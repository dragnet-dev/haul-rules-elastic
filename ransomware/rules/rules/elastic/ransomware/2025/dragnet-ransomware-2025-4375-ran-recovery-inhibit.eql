// Dragnet [Ransomware]: dragnet-ransomware-2025-4375 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: b6e3b20e-18c9-5625-a15c-fecf9db967eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
