// Dragnet [Ransomware]: dragnet-ransomware-2025-1600 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 09d2a303-b4d9-52fe-8084-bf77ab3959ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
