// Dragnet [Ransomware]: dragnet-ransomware-2025-6848 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b83ded4b-187f-5826-942c-ea8a5cf6f98b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
