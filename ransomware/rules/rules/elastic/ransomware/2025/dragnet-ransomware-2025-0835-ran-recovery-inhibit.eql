// Dragnet [Ransomware]: dragnet-ransomware-2025-0835 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 746fade3-2847-5ccb-a742-256293318320

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
