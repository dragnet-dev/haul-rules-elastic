// Dragnet [Ransomware]: dragnet-ransomware-2025-0395 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 55cbe857-1b99-5548-aa36-ddecd74354b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
