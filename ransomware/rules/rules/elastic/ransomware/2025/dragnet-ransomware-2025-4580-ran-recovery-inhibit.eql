// Dragnet [Ransomware]: dragnet-ransomware-2025-4580 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 971d805b-7ffa-54f7-9659-5581ced515ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
