// Dragnet [Ransomware]: dragnet-ransomware-2025-0097 — Recovery Inhibition (obscura)
// Status: experimental | Level: high | ID: f08f67b1-dee9-569d-b52c-cd98ec339521

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
