// Dragnet [Ransomware]: dragnet-ransomware-2025-2285 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: cef8b91a-eff2-500e-98e2-121114ff6c08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
