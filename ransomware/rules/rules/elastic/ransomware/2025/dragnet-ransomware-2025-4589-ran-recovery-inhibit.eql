// Dragnet [Ransomware]: dragnet-ransomware-2025-4589 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: 88dff95c-8e7c-5bf1-837d-fd8060060084

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
