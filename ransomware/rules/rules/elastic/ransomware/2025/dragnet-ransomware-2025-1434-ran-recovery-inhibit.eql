// Dragnet [Ransomware]: dragnet-ransomware-2025-1434 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 36ee900e-61eb-5ac6-9643-14310db943d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
