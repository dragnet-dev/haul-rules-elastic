// Dragnet [Ransomware]: dragnet-ransomware-2025-2105 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: 3990b1d4-b001-5791-82d4-23c118741a3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
