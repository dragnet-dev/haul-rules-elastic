// Dragnet [Ransomware]: dragnet-ransomware-2025-6585 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b285b396-ea18-500d-8f0e-6895d12fe276

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
