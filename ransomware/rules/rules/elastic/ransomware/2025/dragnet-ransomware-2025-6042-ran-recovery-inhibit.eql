// Dragnet [Ransomware]: dragnet-ransomware-2025-6042 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: b3bd9b5f-0890-5971-bfb6-9327f09f9e17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
