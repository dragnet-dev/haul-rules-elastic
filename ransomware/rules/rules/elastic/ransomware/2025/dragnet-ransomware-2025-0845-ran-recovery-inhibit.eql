// Dragnet [Ransomware]: dragnet-ransomware-2025-0845 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: cd8af0e8-28fd-5c83-b690-37ebb49e5659

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
