// Dragnet [Ransomware]: dragnet-ransomware-2025-0895 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 1bad7674-e8d2-5c28-b772-822e2543910b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
