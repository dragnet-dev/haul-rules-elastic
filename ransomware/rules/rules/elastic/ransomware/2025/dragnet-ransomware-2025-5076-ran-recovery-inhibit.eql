// Dragnet [Ransomware]: dragnet-ransomware-2025-5076 — Recovery Inhibition (GDLockerSec)
// Status: experimental | Level: high | ID: 90ee6214-732e-5f63-8377-fc347e31dacc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
