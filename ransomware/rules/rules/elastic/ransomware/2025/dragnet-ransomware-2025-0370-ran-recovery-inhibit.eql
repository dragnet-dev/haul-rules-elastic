// Dragnet [Ransomware]: dragnet-ransomware-2025-0370 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a19e9469-f6c2-5ed9-a417-4a33eb50c7af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
