// Dragnet [Ransomware]: dragnet-ransomware-2025-3289 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: cb2d5980-8724-5aa6-810f-c2ff80106793

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
