// Dragnet [Ransomware]: dragnet-ransomware-2025-5870 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 8ab80768-0e93-54d9-b1a2-a90299608522

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
