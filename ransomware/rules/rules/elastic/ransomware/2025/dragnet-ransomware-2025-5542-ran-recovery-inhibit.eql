// Dragnet [Ransomware]: dragnet-ransomware-2025-5542 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 085522bf-b57b-51f0-b7cc-c21664f056fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
