// Dragnet [Ransomware]: dragnet-ransomware-2025-0540 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bb4495d8-1266-5833-a6e0-d7cab8c2e9d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
