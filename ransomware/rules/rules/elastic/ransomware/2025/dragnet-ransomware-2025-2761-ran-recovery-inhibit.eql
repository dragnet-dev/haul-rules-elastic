// Dragnet [Ransomware]: dragnet-ransomware-2025-2761 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 64cab827-8ff5-5e2f-bcde-4a15e9acab25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
