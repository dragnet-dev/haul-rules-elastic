// Dragnet [Ransomware]: dragnet-ransomware-2025-5769 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: ff410776-c954-5ca3-9464-438e5608f4e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
