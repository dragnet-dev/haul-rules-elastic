// Dragnet [Ransomware]: dragnet-ransomware-2025-4430 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c94a690b-2342-5d66-98ed-fab73639122c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
