// Dragnet [Ransomware]: dragnet-ransomware-2025-6865 — Recovery Inhibition (bravox)
// Status: experimental | Level: high | ID: be59ffda-76e9-560e-8991-5354266bd33f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
