// Dragnet [Ransomware]: dragnet-ransomware-2025-0698 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 84b70d0c-d7ab-594e-a9ad-366e3c697da0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
