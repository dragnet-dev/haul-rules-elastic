// Dragnet [Ransomware]: dragnet-ransomware-2025-1117 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c1f27395-1291-5306-bda2-a09252dae7cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
