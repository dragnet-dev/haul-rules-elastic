// Dragnet [Ransomware]: dragnet-ransomware-2025-4401 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 759f9ea4-1daa-500b-92e9-247e67f48717

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
