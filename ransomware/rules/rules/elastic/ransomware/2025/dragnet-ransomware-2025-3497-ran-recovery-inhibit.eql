// Dragnet [Ransomware]: dragnet-ransomware-2025-3497 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 08baf808-954f-53e6-98c9-dba90648f052

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
