// Dragnet [Ransomware]: dragnet-ransomware-2025-0082 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: 14c6074f-5b4d-53e7-8a8b-caeef88fb561

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
