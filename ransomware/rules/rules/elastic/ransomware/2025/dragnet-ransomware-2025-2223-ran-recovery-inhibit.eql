// Dragnet [Ransomware]: dragnet-ransomware-2025-2223 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 8f8fcfbb-7477-569e-b354-ee5aab060d0f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
