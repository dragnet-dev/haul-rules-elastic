// Dragnet [Ransomware]: dragnet-ransomware-2025-2617 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 7f871af2-35e6-5e11-a997-91c19e9729d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
