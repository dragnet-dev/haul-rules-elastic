// Dragnet [Ransomware]: dragnet-ransomware-2025-3594 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: c7fb4a36-e77e-5b3b-b1a3-1245453e213a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
