// Dragnet [Ransomware]: dragnet-ransomware-2025-7072 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: aaaeb648-8369-5302-92ef-05d11029ad6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
