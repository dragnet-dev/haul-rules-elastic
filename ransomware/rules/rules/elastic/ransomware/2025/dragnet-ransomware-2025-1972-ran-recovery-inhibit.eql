// Dragnet [Ransomware]: dragnet-ransomware-2025-1972 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 18434579-a945-59f5-b5fd-3b537f042ef0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
