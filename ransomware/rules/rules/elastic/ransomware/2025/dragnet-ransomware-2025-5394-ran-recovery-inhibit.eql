// Dragnet [Ransomware]: dragnet-ransomware-2025-5394 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b3658514-d941-5798-91f5-e6e13d11bd7d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
