// Dragnet [Ransomware]: dragnet-ransomware-2025-7473 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 294639de-5236-5294-baaa-61af68fc16f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
