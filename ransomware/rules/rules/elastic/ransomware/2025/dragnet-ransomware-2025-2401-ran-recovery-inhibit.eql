// Dragnet [Ransomware]: dragnet-ransomware-2025-2401 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: ca0e21de-806b-59d2-a8c5-6c8b5ed0edf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
