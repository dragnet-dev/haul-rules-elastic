// Dragnet [Ransomware]: dragnet-ransomware-2025-6097 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 52ec7b00-64f8-5f50-a4bc-8f95558dd37f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
