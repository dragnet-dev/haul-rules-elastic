// Dragnet [Ransomware]: dragnet-ransomware-2025-4301 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 49c3e0ae-13d3-5b23-a83d-f84839bcb962

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
