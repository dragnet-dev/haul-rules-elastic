// Dragnet [Ransomware]: dragnet-ransomware-2025-4176 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: cf2febfa-123c-5005-bfe4-9b55487428d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
