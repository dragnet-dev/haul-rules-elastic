// Dragnet [Ransomware]: dragnet-ransomware-2025-0591 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: ba611ea7-3307-5c4f-9670-828d130cc464

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
