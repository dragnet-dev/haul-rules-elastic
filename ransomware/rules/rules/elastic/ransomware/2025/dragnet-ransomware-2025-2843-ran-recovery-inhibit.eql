// Dragnet [Ransomware]: dragnet-ransomware-2025-2843 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 9a2d0daf-3f94-52dd-8bc5-809197e82b04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
