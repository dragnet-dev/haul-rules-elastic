// Dragnet [Ransomware]: dragnet-ransomware-2025-4144 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f88a5c13-d3cf-559f-a31f-3ec036066fd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
