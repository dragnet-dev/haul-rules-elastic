// Dragnet [Ransomware]: dragnet-ransomware-2025-2850 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 23bf5bde-39bf-5c38-a1df-6b6ab6983dae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
