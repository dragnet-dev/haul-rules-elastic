// Dragnet [Ransomware]: dragnet-ransomware-2025-1487 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 7eac919e-75da-5c70-96b4-f032bbcae69b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
