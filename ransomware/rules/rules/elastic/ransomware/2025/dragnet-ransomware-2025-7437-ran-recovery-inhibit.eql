// Dragnet [Ransomware]: dragnet-ransomware-2025-7437 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 5d166efe-b066-5725-b9b2-e41d3ad892d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
