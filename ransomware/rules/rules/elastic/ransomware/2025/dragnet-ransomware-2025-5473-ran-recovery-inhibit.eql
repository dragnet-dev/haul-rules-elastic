// Dragnet [Ransomware]: dragnet-ransomware-2025-5473 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: f021b25a-4d21-5344-8623-915090271ea3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
