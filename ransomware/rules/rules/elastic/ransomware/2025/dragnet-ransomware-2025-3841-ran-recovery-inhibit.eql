// Dragnet [Ransomware]: dragnet-ransomware-2025-3841 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1a8da624-889d-5725-b499-b526c9226bbd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
