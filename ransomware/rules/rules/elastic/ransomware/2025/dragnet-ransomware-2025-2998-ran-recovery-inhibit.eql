// Dragnet [Ransomware]: dragnet-ransomware-2025-2998 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: ce9a359c-c67e-5e53-89f9-4750fc36aef1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
