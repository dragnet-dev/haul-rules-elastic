// Dragnet [Ransomware]: dragnet-ransomware-2025-2734 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 4b2153fb-040d-571c-86db-e238569f4061

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
