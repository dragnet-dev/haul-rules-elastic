// Dragnet [Ransomware]: dragnet-ransomware-2025-7182 — Recovery Inhibition (brotherhood)
// Status: deprecated | Level: high | ID: 2e839992-35ec-549a-95c6-b96780b8c97f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
