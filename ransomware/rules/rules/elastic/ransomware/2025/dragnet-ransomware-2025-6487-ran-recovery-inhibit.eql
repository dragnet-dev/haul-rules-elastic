// Dragnet [Ransomware]: dragnet-ransomware-2025-6487 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 303f1eb7-55c7-5ec0-ba21-088cffa54392

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
