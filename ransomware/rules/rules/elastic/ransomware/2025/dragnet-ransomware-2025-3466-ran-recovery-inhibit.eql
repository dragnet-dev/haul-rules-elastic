// Dragnet [Ransomware]: dragnet-ransomware-2025-3466 — Recovery Inhibition (nightspire)
// Status: experimental | Level: high | ID: c7d12f4b-88ce-5c03-b06d-cb7b3a02db5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
