// Dragnet [Ransomware]: dragnet-ransomware-2025-3114 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: da4c7970-8abd-533c-883c-29bc50f789f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
