// Dragnet [Ransomware]: dragnet-ransomware-2025-6717 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: aac1b7b4-4c32-59f6-a845-8b7328466a0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
