// Dragnet [Ransomware]: dragnet-ransomware-2025-2586 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: caf9bac9-6ced-5dc8-b6f5-60aff3d13a75

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
