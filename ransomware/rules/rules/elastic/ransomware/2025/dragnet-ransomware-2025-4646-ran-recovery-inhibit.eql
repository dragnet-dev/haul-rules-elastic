// Dragnet [Ransomware]: dragnet-ransomware-2025-4646 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 723d4170-17f4-54dd-bf9c-daf2021b6cb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
