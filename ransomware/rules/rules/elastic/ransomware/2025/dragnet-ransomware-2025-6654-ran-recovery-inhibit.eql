// Dragnet [Ransomware]: dragnet-ransomware-2025-6654 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 44b81054-1bb3-5e16-9458-fd9b6592b0d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
