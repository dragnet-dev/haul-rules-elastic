// Dragnet [Ransomware]: dragnet-ransomware-2025-1148 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: e512d489-7ed4-5378-b525-06fe3dc4b9b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
