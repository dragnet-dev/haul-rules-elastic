// Dragnet [Ransomware]: dragnet-ransomware-2025-3306 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 92e00a7e-e1d7-5835-927e-f0facb6c8442

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
