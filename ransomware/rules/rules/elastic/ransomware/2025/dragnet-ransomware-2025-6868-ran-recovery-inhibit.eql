// Dragnet [Ransomware]: dragnet-ransomware-2025-6868 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 22d3470d-acad-567e-a78b-5bc5e9a75834

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
