// Dragnet [Ransomware]: dragnet-ransomware-2025-4607 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 8b89e189-2a2e-558f-a558-d1bff562fac2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
