// Dragnet [Ransomware]: dragnet-ransomware-2025-3932 — Recovery Inhibition (radar)
// Status: deprecated | Level: high | ID: 21f01041-9f86-5b10-9356-312145659b12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
