// Dragnet [Ransomware]: dragnet-ransomware-2025-6794 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8117c334-325c-5a00-9e93-e512b7ef4089

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
