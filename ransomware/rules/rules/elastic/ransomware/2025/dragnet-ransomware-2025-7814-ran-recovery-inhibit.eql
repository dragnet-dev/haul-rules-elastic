// Dragnet [Ransomware]: dragnet-ransomware-2025-7814 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 3e4daba7-65f7-5dfe-8001-071a9dc3ea0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
