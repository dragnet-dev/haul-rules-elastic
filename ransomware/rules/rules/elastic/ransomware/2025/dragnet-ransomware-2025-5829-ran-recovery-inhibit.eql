// Dragnet [Ransomware]: dragnet-ransomware-2025-5829 — Recovery Inhibition (anubis)
// Status: experimental | Level: high | ID: b68da3f5-72b9-5fbb-9094-533163483925

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
