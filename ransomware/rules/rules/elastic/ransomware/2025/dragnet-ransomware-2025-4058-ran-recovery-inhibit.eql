// Dragnet [Ransomware]: dragnet-ransomware-2025-4058 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 388514b5-a98a-5114-86c0-23739c8396c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
