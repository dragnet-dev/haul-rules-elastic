// Dragnet [Ransomware]: dragnet-ransomware-2025-6612 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 6f966cda-ed4a-563f-950c-58accaf236df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
