// Dragnet [Ransomware]: dragnet-ransomware-2025-7177 — Recovery Inhibition (warlock)
// Status: experimental | Level: high | ID: 240c0472-dde9-5987-92c5-cffde1d6643f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
