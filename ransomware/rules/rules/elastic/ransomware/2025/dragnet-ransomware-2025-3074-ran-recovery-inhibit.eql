// Dragnet [Ransomware]: dragnet-ransomware-2025-3074 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 7251ea71-4d94-5eca-a63b-77bd4134371c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
