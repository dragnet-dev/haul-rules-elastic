// Dragnet [Ransomware]: dragnet-ransomware-2025-1025 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 4979a498-4d41-57c2-9f31-67aa9b9a4834

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
