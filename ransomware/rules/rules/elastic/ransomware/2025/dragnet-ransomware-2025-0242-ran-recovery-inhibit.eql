// Dragnet [Ransomware]: dragnet-ransomware-2025-0242 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 94202348-66fa-553a-9af4-a99013fd5bb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
