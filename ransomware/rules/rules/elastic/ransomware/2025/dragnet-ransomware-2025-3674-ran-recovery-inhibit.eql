// Dragnet [Ransomware]: dragnet-ransomware-2025-3674 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: e03dd5b5-33c3-5727-81f4-56e8b30e4e91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
