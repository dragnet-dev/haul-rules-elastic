// Dragnet [Ransomware]: dragnet-ransomware-2025-1154 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: c1f555b1-4d76-57ec-a8e9-671f8c95429a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
