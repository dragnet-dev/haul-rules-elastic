// Dragnet [Ransomware]: dragnet-ransomware-2025-7287 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 5a005271-9eb7-5a20-a6c1-c2f2b60d9370

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
