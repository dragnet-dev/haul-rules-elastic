// Dragnet [Ransomware]: dragnet-ransomware-2025-0512 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 5e037579-a230-576b-8157-d0eccdde62df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
