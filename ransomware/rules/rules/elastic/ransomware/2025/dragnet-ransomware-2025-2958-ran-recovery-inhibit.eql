// Dragnet [Ransomware]: dragnet-ransomware-2025-2958 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: 88f2056e-966b-5574-acad-8c89c7195ae0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
