// Dragnet [Ransomware]: dragnet-ransomware-2025-1142 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: b59a230c-fdbd-5bd8-a5bc-172ea1de0e9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
