// Dragnet [Ransomware]: dragnet-ransomware-2025-7341 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1df144d4-9c10-5517-a489-1d42ac81a04f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
