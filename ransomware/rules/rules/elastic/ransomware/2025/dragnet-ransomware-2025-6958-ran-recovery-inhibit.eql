// Dragnet [Ransomware]: dragnet-ransomware-2025-6958 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 42deb608-843b-54f9-a370-7dbdfaea45ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
