// Dragnet [Ransomware]: dragnet-ransomware-2025-7820 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: f99db554-0394-5b12-ac99-3975fd8e4c0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
