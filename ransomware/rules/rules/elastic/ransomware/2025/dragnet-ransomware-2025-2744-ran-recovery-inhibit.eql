// Dragnet [Ransomware]: dragnet-ransomware-2025-2744 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e8f45e0d-5a2d-5077-baf3-c7f359df9a82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
