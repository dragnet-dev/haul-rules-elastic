// Dragnet [Ransomware]: dragnet-ransomware-2025-1552 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: dff79739-f8db-5168-a76b-f77e217a3982

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
