// Dragnet [Ransomware]: dragnet-ransomware-2025-5582 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 61cd5ecf-e976-5252-95a7-d1886f96e812

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
