// Dragnet [Ransomware]: dragnet-ransomware-2025-1846 — Recovery Inhibition (brotherhood)
// Status: experimental | Level: high | ID: be8fbbc2-a15e-5d96-bea3-4479d071217d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
