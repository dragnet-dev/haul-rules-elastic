// Dragnet [Ransomware]: dragnet-ransomware-2025-4101 — Recovery Inhibition (moneymessage)
// Status: experimental | Level: high | ID: a4c139c1-5777-57c4-87cf-b831724d7795

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
