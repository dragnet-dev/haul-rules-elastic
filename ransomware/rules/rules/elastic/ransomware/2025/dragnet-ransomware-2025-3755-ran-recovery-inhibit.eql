// Dragnet [Ransomware]: dragnet-ransomware-2025-3755 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 192a25cd-b96e-5af4-81cf-c02dbd328335

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
