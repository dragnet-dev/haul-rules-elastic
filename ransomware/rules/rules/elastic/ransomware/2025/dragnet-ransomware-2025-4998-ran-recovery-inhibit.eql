// Dragnet [Ransomware]: dragnet-ransomware-2025-4998 — Recovery Inhibition (skira)
// Status: experimental | Level: high | ID: 2123e51c-bd2b-5a37-9077-669e05e3e3f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
