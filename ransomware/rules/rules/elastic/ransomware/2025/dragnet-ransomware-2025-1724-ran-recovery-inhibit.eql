// Dragnet [Ransomware]: dragnet-ransomware-2025-1724 — Recovery Inhibition (termite)
// Status: experimental | Level: high | ID: 53f127bc-baba-555c-9e64-dbd2f7437ccc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
