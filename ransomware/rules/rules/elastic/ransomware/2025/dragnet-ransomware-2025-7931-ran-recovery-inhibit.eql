// Dragnet [Ransomware]: dragnet-ransomware-2025-7931 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: cebe50bd-76c8-5047-b6eb-62f38c0e6ffe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
