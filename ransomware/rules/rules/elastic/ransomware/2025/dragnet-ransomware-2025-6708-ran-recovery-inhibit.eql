// Dragnet [Ransomware]: dragnet-ransomware-2025-6708 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2f6b9060-2000-57d7-9afe-f3a9aa468d12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
