// Dragnet [Ransomware]: dragnet-ransomware-2025-5180 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 1f4d9b9a-8890-5382-8d61-b010efabfde7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
