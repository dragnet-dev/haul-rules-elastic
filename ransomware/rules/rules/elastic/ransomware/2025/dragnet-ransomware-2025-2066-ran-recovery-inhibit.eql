// Dragnet [Ransomware]: dragnet-ransomware-2025-2066 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: cea3de36-a54c-5aa3-98f0-132e80ac4c31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
