// Dragnet [Ransomware]: dragnet-ransomware-2025-5408 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: c3012392-2e85-564f-9da4-9091e25aa8b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
