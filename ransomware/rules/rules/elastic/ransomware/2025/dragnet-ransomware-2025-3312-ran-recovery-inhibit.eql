// Dragnet [Ransomware]: dragnet-ransomware-2025-3312 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: e05db718-7ab1-5533-9e2d-a480672642d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
