// Dragnet [Ransomware]: dragnet-ransomware-2025-5463 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 1a87ff53-7ab6-59e4-96e5-13a0c392c1d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
