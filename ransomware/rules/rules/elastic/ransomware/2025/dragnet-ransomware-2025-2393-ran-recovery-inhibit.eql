// Dragnet [Ransomware]: dragnet-ransomware-2025-2393 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: d80085bd-4a42-5602-860f-c8fd316440fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
