// Dragnet [Ransomware]: dragnet-ransomware-2025-5674 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d394878e-6060-5899-95c4-d728c6933bf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
