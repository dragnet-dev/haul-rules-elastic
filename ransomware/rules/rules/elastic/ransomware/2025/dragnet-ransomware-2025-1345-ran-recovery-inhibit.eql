// Dragnet [Ransomware]: dragnet-ransomware-2025-1345 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b0d44914-42c8-53e9-bdcd-312afa13922d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
