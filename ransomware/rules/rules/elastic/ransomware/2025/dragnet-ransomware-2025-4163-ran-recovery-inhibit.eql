// Dragnet [Ransomware]: dragnet-ransomware-2025-4163 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: e5c0bf30-91ed-5c1f-a18a-4b7a725ceac3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
