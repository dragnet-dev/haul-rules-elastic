// Dragnet [Ransomware]: dragnet-ransomware-2025-2110 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 1ba41356-e43b-52c5-9179-e39de3d3934f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
