// Dragnet [Ransomware]: dragnet-ransomware-2025-2163 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 8db9b62c-6209-57a7-b73e-2d05ecc50c30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
