// Dragnet [Ransomware]: dragnet-ransomware-2025-2559 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 5c4bc118-82b9-5431-a3e5-a48b7d70436c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
