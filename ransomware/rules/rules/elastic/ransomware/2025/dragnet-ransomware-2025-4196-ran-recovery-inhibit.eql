// Dragnet [Ransomware]: dragnet-ransomware-2025-4196 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: c42a69e8-a8fa-5a93-b6fd-b820aa8f0471

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
