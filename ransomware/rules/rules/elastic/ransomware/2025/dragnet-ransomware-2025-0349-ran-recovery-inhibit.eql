// Dragnet [Ransomware]: dragnet-ransomware-2025-0349 — Recovery Inhibition (crazyhunter)
// Status: experimental | Level: high | ID: a789bc5f-d0ed-5b52-809d-e457cdf93558

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
