// Dragnet [Ransomware]: dragnet-ransomware-2025-2981 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d4e4a564-edcb-5822-9cb2-d587d6ddd823

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
