// Dragnet [Ransomware]: dragnet-ransomware-2025-2020 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4555b76d-bda5-57c9-856c-091d602a1935

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
