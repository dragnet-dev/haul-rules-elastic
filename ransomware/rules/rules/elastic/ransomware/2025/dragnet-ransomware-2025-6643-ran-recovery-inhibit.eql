// Dragnet [Ransomware]: dragnet-ransomware-2025-6643 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 13a9c46c-dbea-5697-9d78-0915744353f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
