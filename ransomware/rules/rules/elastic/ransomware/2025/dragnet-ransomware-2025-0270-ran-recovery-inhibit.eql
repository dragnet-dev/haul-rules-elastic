// Dragnet [Ransomware]: dragnet-ransomware-2025-0270 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: e708cc0d-774d-5361-a67b-bd2787cf73cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
