// Dragnet [Ransomware]: dragnet-ransomware-2025-6778 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 14852464-5249-5be0-a1d8-4ee7ba0bc5b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
