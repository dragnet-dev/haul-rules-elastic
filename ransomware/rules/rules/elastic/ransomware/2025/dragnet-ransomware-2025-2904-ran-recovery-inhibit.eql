// Dragnet [Ransomware]: dragnet-ransomware-2025-2904 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: b78dd879-0bfa-53e7-ad90-d1840dbbf7af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
