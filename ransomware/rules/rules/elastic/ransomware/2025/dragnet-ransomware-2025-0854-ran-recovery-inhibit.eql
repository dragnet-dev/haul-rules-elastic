// Dragnet [Ransomware]: dragnet-ransomware-2025-0854 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 25e00c52-27b6-5dd4-89e6-41dc741d783d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
