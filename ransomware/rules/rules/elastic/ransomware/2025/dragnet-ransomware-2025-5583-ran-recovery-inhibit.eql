// Dragnet [Ransomware]: dragnet-ransomware-2025-5583 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f6eb2f5e-865d-56af-bd90-21670b2fd8e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
