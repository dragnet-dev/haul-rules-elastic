// Dragnet [Ransomware]: dragnet-ransomware-2025-6769 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: c4a91d68-6ea3-54a7-a427-ce82962b9c9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
