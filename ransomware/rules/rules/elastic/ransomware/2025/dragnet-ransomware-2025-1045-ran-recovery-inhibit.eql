// Dragnet [Ransomware]: dragnet-ransomware-2025-1045 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9cd3095d-228e-5d4b-bbe3-90242f07f867

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
