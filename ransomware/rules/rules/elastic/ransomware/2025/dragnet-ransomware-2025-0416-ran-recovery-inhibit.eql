// Dragnet [Ransomware]: dragnet-ransomware-2025-0416 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 96f8fadf-7e7e-5afa-91d2-c3e66354530d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
