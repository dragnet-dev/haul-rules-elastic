// Dragnet [Ransomware]: dragnet-ransomware-2025-4416 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: e98a9c2e-38bd-5bf2-8e90-cbdcd10ebd3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
