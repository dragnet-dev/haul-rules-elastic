// Dragnet [Ransomware]: dragnet-ransomware-2025-3434 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: fdd0b81e-b54a-5ddc-8a9c-c1056533a3aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
