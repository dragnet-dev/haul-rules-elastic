// Dragnet [Ransomware]: dragnet-ransomware-2025-5178 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 68e526bb-09b9-5dbf-a81f-23ab18f49794

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
