// Dragnet [Ransomware]: dragnet-ransomware-2025-2221 — Recovery Inhibition (spacebears)
// Status: test | Level: high | ID: e3c409c5-9a76-530a-9ef8-2240b8b0bc55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
