// Dragnet [Ransomware]: dragnet-ransomware-2025-5320 — Recovery Inhibition (datacarry)
// Status: deprecated | Level: high | ID: 28d7a2fc-5ace-587e-a4c8-02a76fe9688a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
