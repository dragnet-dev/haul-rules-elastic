// Dragnet [Ransomware]: dragnet-ransomware-2025-4973 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 940db76b-0fc1-5a1c-8013-5a72cc33535c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
