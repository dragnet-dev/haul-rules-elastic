// Dragnet [Ransomware]: dragnet-ransomware-2025-1310 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 420fc9b5-91cc-5727-885d-29ca696e12f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
