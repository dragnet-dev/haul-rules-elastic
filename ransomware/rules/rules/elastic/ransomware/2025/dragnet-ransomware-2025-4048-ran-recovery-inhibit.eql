// Dragnet [Ransomware]: dragnet-ransomware-2025-4048 — Recovery Inhibition (securotrop)
// Status: experimental | Level: high | ID: 6afb3ce3-d298-53e2-8955-7ed72ddcd89c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
