// Dragnet [Ransomware]: dragnet-ransomware-2025-6027 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 401b56c3-d28d-5360-837b-860982e11e6c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
