// Dragnet [Ransomware]: dragnet-ransomware-2025-3720 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 14d42881-bd27-5f47-a7da-a95c7c17092a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
