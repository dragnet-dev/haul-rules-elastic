// Dragnet [Ransomware]: dragnet-ransomware-2025-0745 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 4e2c3d82-d9c3-5c63-a42d-9da61b44b585

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
