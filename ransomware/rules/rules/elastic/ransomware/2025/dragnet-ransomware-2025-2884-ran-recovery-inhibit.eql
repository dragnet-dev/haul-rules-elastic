// Dragnet [Ransomware]: dragnet-ransomware-2025-2884 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: aadc0a1f-cd62-542c-a6ec-44eb1f58d7de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
