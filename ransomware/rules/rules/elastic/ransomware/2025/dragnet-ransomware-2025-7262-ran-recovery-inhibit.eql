// Dragnet [Ransomware]: dragnet-ransomware-2025-7262 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e094ccd5-e450-5bdb-9bd1-93552e7cb88d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
