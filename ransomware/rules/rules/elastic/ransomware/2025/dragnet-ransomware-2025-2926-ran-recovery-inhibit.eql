// Dragnet [Ransomware]: dragnet-ransomware-2025-2926 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 933084db-1941-5ce5-ac97-ce2562b43612

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
