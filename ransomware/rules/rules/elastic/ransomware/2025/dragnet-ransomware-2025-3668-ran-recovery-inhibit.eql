// Dragnet [Ransomware]: dragnet-ransomware-2025-3668 — Recovery Inhibition (kraken)
// Status: experimental | Level: high | ID: a8e1f305-89ab-57e3-b86a-9c16c25405da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
