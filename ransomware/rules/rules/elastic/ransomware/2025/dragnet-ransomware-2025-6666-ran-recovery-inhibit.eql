// Dragnet [Ransomware]: dragnet-ransomware-2025-6666 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8dc2c7cb-a50f-590a-ab37-ad3731d5ec38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
