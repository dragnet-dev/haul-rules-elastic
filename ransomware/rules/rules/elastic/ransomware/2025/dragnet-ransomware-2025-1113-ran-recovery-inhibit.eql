// Dragnet [Ransomware]: dragnet-ransomware-2025-1113 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: d1c861f8-2781-5d58-9497-2fe210bbedd4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
