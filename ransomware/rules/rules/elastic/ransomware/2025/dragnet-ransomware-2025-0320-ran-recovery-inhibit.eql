// Dragnet [Ransomware]: dragnet-ransomware-2025-0320 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: dce6ee3d-1ad4-5d83-8bbf-0baca3e40fac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
