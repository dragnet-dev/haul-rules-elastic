// Dragnet [Ransomware]: dragnet-ransomware-2025-7703 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9dc46280-2cc5-5d5a-8a58-897c17aa9979

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
