// Dragnet [Ransomware]: dragnet-ransomware-2025-6439 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 6598cc0c-8309-5d6b-a9bc-1fd694299a2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
