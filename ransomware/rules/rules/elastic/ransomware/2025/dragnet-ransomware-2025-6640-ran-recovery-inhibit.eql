// Dragnet [Ransomware]: dragnet-ransomware-2025-6640 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: e815cb24-0e67-5b78-9068-83caa1157ead

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
