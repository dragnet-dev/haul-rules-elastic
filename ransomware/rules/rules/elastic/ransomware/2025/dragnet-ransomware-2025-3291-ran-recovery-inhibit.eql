// Dragnet [Ransomware]: dragnet-ransomware-2025-3291 — Recovery Inhibition (datacarry)
// Status: deprecated | Level: high | ID: b72d0278-b3bc-5455-9adc-2f34c690d09c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
