// Dragnet [Ransomware]: dragnet-ransomware-2025-1998 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: 24dc1dad-484b-5d0d-8d94-750a557feee0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
