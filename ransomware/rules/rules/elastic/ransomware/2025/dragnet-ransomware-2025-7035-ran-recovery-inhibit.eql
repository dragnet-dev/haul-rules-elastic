// Dragnet [Ransomware]: dragnet-ransomware-2025-7035 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 1cf138ed-1909-5e80-b114-8111da74ca13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
