// Dragnet [Ransomware]: dragnet-ransomware-2025-0232 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: e074a1f2-1dcb-564c-9e5d-ead30d2ee6e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
