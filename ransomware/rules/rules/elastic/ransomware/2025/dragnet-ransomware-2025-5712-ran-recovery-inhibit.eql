// Dragnet [Ransomware]: dragnet-ransomware-2025-5712 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 160b9d43-8e03-59a3-9081-a582c4023165

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
