// Dragnet [Ransomware]: dragnet-ransomware-2025-0403 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: efc37195-fe41-5cf3-9598-222c0177f059

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
