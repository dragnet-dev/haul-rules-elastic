// Dragnet [Ransomware]: dragnet-ransomware-2025-0703 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 1e1ce950-981a-5310-8032-6b918bae8e15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
