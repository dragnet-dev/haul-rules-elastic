// Dragnet [Ransomware]: dragnet-ransomware-2025-0339 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 09d6f324-aea0-5d4b-a291-7ca9240e59da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
