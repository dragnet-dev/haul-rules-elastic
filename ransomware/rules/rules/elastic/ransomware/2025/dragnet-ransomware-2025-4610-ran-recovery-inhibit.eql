// Dragnet [Ransomware]: dragnet-ransomware-2025-4610 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: c60b7aad-ba73-5fb9-8907-a21f17005e54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
