// Dragnet [Ransomware]: dragnet-ransomware-2025-0363 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: fc839a3e-ca3a-5c73-835e-3b790f350b36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
