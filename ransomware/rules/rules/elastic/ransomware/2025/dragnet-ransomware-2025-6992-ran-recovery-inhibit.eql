// Dragnet [Ransomware]: dragnet-ransomware-2025-6992 — Recovery Inhibition (insomnia)
// Status: test | Level: high | ID: 067ad44a-8538-5e5a-94d8-39f5e4ef4162

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
