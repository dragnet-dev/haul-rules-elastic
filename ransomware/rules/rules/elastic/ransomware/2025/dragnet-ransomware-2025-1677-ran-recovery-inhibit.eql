// Dragnet [Ransomware]: dragnet-ransomware-2025-1677 — Recovery Inhibition (ralord)
// Status: experimental | Level: high | ID: 18317cf4-28d3-50a4-b52b-91ab0c0f5449

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
