// Dragnet [Ransomware]: dragnet-ransomware-2025-5524 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 6af804a6-92cb-55cd-88a3-a8e9fdfbb5c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
