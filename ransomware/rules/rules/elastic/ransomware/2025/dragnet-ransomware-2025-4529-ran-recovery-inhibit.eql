// Dragnet [Ransomware]: dragnet-ransomware-2025-4529 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a334a447-ae06-5f67-a4f5-f417d301edd4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
