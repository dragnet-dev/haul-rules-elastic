// Dragnet [Ransomware]: dragnet-ransomware-2025-4007 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: cff6f48e-e990-5afd-903d-9af84dedaa90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
