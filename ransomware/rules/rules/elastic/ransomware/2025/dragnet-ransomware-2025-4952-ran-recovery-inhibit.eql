// Dragnet [Ransomware]: dragnet-ransomware-2025-4952 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7d388ff8-5836-5e7d-975c-bb3925133f37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
