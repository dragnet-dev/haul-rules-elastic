// Dragnet [Ransomware]: dragnet-ransomware-2025-6681 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a7bb5a85-a51a-5f29-be2f-9ed26157b8cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
