// Dragnet [Ransomware]: dragnet-ransomware-2025-2076 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 9a0ff940-6627-528b-8923-344309e317b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
