// Dragnet [Ransomware]: dragnet-ransomware-2025-2022 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 1b2b6792-3e86-514f-8664-8bfab56e5d02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
