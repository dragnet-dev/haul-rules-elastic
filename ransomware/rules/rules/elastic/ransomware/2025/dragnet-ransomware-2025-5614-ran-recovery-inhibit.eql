// Dragnet [Ransomware]: dragnet-ransomware-2025-5614 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 756062e5-c961-541e-acb6-2a3ceb2c978e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
