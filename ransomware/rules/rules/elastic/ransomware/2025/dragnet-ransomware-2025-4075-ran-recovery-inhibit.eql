// Dragnet [Ransomware]: dragnet-ransomware-2025-4075 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 486b78e8-2305-5ba2-a21d-79c1161f2ef1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
