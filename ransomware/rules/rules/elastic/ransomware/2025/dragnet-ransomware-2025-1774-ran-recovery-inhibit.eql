// Dragnet [Ransomware]: dragnet-ransomware-2025-1774 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 669f4e74-3e32-552d-a118-8d87bbd1afe7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
