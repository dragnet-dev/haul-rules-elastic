// Dragnet [Ransomware]: dragnet-ransomware-2025-3091 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: edfe8253-1d26-53b5-87a1-4c5536970760

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
