// Dragnet [Ransomware]: dragnet-ransomware-2025-3357 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 51b8639e-a9a6-5235-98f9-f9cc6915e360

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
