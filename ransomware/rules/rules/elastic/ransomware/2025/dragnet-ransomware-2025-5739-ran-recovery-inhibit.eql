// Dragnet [Ransomware]: dragnet-ransomware-2025-5739 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 7a7673d8-54be-5781-bc02-3f7ac1c59c04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
