// Dragnet [Ransomware]: dragnet-ransomware-2025-3090 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 2323c183-6517-510d-acad-5c148348b271

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
