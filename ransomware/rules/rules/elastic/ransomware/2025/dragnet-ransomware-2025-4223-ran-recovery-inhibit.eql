// Dragnet [Ransomware]: dragnet-ransomware-2025-4223 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: d1f9f853-5dab-5abb-9298-7206cdc14e38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
