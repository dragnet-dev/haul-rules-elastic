// Dragnet [Ransomware]: dragnet-ransomware-2025-7914 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: ecdfb161-67ba-58bb-a79a-35793eb1b663

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
