// Dragnet [Ransomware]: dragnet-ransomware-2025-5590 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: fcf27671-8828-5663-94a5-d871a65c9129

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
