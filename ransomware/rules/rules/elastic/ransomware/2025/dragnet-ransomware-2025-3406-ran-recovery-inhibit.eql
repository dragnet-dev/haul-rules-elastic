// Dragnet [Ransomware]: dragnet-ransomware-2025-3406 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e427579b-8e64-5f97-882a-c4a9b8a3addc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
