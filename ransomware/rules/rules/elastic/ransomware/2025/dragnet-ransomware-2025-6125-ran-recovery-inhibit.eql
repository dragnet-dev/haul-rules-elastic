// Dragnet [Ransomware]: dragnet-ransomware-2025-6125 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 32bf1bdb-926b-5446-a8a7-7ae40b113298

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
