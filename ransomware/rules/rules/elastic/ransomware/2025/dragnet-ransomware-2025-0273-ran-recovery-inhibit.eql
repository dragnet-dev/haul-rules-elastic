// Dragnet [Ransomware]: dragnet-ransomware-2025-0273 — Recovery Inhibition (anubis)
// Status: experimental | Level: high | ID: 34afe346-e39f-5e13-8ff3-76ba8c72a931

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
