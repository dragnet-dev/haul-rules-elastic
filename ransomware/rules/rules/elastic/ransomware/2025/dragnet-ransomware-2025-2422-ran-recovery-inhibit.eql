// Dragnet [Ransomware]: dragnet-ransomware-2025-2422 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: a779ea3e-999a-5198-acc5-ebdde481b2dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
