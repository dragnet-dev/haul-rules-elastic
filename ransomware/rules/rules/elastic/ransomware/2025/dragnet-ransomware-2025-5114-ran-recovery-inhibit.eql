// Dragnet [Ransomware]: dragnet-ransomware-2025-5114 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7f41f626-8973-5a8f-8c05-e3a56e70d46e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
