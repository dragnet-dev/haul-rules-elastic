// Dragnet [Ransomware]: dragnet-ransomware-2025-5354 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 14af21cb-3ae4-599b-8f50-c9727c47875f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
