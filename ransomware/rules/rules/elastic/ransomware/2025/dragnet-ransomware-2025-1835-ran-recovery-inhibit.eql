// Dragnet [Ransomware]: dragnet-ransomware-2025-1835 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 4cd8bd5f-247c-5981-8bb0-c6c8f32f3da7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
