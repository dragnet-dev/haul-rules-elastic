// Dragnet [Ransomware]: dragnet-ransomware-2025-6994 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: e79cac23-7e77-51ef-ad6c-84460b5c64d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
