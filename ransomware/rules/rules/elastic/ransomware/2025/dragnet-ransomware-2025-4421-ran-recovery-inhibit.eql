// Dragnet [Ransomware]: dragnet-ransomware-2025-4421 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2e3c28b9-737a-572e-9568-6700f6796c9c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
