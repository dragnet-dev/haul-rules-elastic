// Dragnet [Ransomware]: dragnet-ransomware-2025-0943 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 866a09f7-c0a3-5bde-9de2-628d1f3440a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
