// Dragnet [Ransomware]: dragnet-ransomware-2025-3441 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 89227846-65da-533a-871f-f1907a903f2b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
