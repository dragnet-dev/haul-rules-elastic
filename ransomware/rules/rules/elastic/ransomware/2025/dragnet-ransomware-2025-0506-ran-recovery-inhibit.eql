// Dragnet [Ransomware]: dragnet-ransomware-2025-0506 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: b384e0fc-903c-54cb-ba0a-b656d0396a13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
