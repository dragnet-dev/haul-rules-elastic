// Dragnet [Ransomware]: dragnet-ransomware-2025-4949 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: d58917d4-453a-5cf1-a77f-585bad13e4c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
