// Dragnet [Ransomware]: dragnet-ransomware-2025-7806 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 6f5686a2-cfbd-5bbd-b036-cd5a35a06541

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
