// Dragnet [Ransomware]: dragnet-ransomware-2025-4909 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 20cbaa86-2b4b-5fc5-a707-73dd06415ad3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
