// Dragnet [Ransomware]: dragnet-ransomware-2025-4957 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: c6f6c94b-7621-5bc9-98b8-44ae5015c5ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
