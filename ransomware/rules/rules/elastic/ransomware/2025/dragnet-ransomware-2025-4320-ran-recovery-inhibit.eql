// Dragnet [Ransomware]: dragnet-ransomware-2025-4320 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 89352ecb-f29a-52ab-bb97-623ba92a04ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
