// Dragnet [Ransomware]: dragnet-ransomware-2025-6347 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 3adad007-63e1-568d-9d22-14601c0d27e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
