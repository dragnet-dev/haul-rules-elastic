// Dragnet [Ransomware]: dragnet-ransomware-2025-4015 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 6a3acae8-99fc-5daf-97a6-ada57df10e58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
