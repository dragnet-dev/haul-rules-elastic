// Dragnet [Ransomware]: dragnet-ransomware-2025-3378 — Recovery Inhibition (anubis)
// Status: experimental | Level: high | ID: 58c8054d-ac2f-5cdc-affe-39fa5b41da65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
