// Dragnet [Ransomware]: dragnet-ransomware-2025-1147 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a121b452-7053-5e13-adf5-24e7ced88770

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
