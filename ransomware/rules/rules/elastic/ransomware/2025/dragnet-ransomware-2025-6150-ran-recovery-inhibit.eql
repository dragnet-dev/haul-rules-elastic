// Dragnet [Ransomware]: dragnet-ransomware-2025-6150 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: cd9f0715-bf41-5752-8159-065fbc4e4285

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
