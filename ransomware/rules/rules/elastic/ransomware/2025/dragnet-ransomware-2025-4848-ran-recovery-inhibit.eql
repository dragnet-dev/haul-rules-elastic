// Dragnet [Ransomware]: dragnet-ransomware-2025-4848 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: a55b0006-e06b-5191-b2ec-921532ce2a17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
