// Dragnet [Ransomware]: dragnet-ransomware-2025-0997 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: f4a147fb-21e4-59c8-8bba-96ea043788f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
