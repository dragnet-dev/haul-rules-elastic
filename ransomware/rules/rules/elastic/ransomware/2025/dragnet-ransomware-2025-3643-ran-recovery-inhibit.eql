// Dragnet [Ransomware]: dragnet-ransomware-2025-3643 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 5f5c1a77-fe53-5661-bfbe-4b2a6e32afb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
