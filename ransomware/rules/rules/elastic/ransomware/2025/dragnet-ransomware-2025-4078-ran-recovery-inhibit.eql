// Dragnet [Ransomware]: dragnet-ransomware-2025-4078 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 3097e2b5-117d-5f61-8432-bda4ffafc270

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
