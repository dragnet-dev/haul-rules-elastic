// Dragnet [Ransomware]: dragnet-ransomware-2025-5128 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 8743c7af-e9f3-51f3-8715-1cd19ff9db67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
