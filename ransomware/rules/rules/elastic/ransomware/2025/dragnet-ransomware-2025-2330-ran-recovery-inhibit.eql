// Dragnet [Ransomware]: dragnet-ransomware-2025-2330 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: c45315b8-ad71-5e4d-aedb-a2b0ec5185fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
