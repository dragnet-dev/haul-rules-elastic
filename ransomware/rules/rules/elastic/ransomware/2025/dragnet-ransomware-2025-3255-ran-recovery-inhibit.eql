// Dragnet [Ransomware]: dragnet-ransomware-2025-3255 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 41fdec2b-f339-5840-a1ac-dfb9bc3a0a76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
