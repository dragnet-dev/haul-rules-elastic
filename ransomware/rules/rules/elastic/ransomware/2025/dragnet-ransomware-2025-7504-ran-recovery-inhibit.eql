// Dragnet [Ransomware]: dragnet-ransomware-2025-7504 — Recovery Inhibition (obscura)
// Status: experimental | Level: high | ID: cac050bb-6fb0-502d-a835-ebeda1ea542a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
