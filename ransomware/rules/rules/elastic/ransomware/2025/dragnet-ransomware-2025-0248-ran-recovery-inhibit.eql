// Dragnet [Ransomware]: dragnet-ransomware-2025-0248 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: faa3a21e-e64b-53fa-ae35-844b49d22190

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
