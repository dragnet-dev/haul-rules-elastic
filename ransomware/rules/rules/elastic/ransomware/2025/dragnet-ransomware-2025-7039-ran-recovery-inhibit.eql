// Dragnet [Ransomware]: dragnet-ransomware-2025-7039 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 85b1cecf-f4cb-5237-9124-e8cd880db768

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
