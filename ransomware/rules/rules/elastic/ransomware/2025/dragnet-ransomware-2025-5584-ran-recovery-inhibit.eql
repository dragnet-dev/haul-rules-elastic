// Dragnet [Ransomware]: dragnet-ransomware-2025-5584 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 23797ee1-8765-5661-a855-953bcc5f8ecf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
