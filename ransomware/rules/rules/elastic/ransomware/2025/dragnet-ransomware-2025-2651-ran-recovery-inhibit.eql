// Dragnet [Ransomware]: dragnet-ransomware-2025-2651 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 02ac6e1d-d774-559e-a0ac-7316c33dfc2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
