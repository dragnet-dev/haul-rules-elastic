// Dragnet [Ransomware]: dragnet-ransomware-2025-7405 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f2f44c88-f2b8-51c1-98de-cf37155f82c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
