// Dragnet [Ransomware]: dragnet-ransomware-2025-0282 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d49ffdce-a60a-5833-94b0-844bbe545bc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
