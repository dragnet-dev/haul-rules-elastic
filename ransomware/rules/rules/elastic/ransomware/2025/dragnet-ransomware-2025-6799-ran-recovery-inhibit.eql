// Dragnet [Ransomware]: dragnet-ransomware-2025-6799 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: a1a4ee42-a5f4-5271-a693-97cdfb145d80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
