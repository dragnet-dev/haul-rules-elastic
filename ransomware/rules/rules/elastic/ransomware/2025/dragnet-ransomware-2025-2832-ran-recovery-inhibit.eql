// Dragnet [Ransomware]: dragnet-ransomware-2025-2832 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 8330cfa3-95cc-5fd9-9eb1-107893936f50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
