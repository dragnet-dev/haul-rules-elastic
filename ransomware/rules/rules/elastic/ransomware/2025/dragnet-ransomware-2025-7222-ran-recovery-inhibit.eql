// Dragnet [Ransomware]: dragnet-ransomware-2025-7222 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 133a75a0-9256-5a86-8adb-6d0936401d1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
