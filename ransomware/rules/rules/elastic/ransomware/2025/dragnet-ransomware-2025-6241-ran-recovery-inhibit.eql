// Dragnet [Ransomware]: dragnet-ransomware-2025-6241 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b1c0e6a0-671a-58c1-8f8a-99e75afa369c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
