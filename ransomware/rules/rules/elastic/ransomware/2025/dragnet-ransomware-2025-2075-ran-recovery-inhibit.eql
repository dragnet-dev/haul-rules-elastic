// Dragnet [Ransomware]: dragnet-ransomware-2025-2075 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: ea5d84ed-5b78-5a0e-ba48-6eacaf709491

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
