// Dragnet [Ransomware]: dragnet-ransomware-2025-5066 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: fec5a2eb-b74e-51a7-92de-b7027354ea69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
