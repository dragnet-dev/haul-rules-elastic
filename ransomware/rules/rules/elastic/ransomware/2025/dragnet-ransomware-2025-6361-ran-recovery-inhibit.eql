// Dragnet [Ransomware]: dragnet-ransomware-2025-6361 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: 63e9b6a8-a36a-5445-b245-e82795e09ee5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
