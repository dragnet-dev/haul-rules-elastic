// Dragnet [Ransomware]: dragnet-ransomware-2025-7274 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 28b26e07-3ac4-5192-a3af-b1a45cedbc72

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
