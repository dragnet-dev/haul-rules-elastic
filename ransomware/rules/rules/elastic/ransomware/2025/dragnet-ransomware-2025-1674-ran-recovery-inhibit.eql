// Dragnet [Ransomware]: dragnet-ransomware-2025-1674 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: f3b7a68a-213a-59d6-bc08-17f02bfb02bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
