// Dragnet [Ransomware]: dragnet-ransomware-2025-7631 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: ec79c278-f5dc-51b4-805a-fa5c69f9ce02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
