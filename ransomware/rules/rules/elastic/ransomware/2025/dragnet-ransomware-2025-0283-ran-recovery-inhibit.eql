// Dragnet [Ransomware]: dragnet-ransomware-2025-0283 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: f248f4b2-313f-5c41-a64a-0accc4399a59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
