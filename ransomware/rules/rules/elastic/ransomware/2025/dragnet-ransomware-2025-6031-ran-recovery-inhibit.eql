// Dragnet [Ransomware]: dragnet-ransomware-2025-6031 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 310774b9-15e6-5b3f-a3e9-09469f68f1da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
