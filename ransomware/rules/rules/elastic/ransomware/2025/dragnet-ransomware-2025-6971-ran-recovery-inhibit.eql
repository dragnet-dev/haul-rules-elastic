// Dragnet [Ransomware]: dragnet-ransomware-2025-6971 — Recovery Inhibition (securotrop)
// Status: experimental | Level: high | ID: 8f737a9a-0ccd-5211-b894-f7cee18e702f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
