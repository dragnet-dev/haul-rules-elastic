// Dragnet [Ransomware]: dragnet-ransomware-2025-1925 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: bb235498-fffb-514f-9255-db08dcc60cee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
