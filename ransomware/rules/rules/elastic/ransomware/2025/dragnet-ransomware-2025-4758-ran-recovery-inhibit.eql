// Dragnet [Ransomware]: dragnet-ransomware-2025-4758 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 93ede241-55ef-5e48-8dad-b3e12864fa0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
