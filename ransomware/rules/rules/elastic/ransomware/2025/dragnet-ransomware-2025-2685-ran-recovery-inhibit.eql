// Dragnet [Ransomware]: dragnet-ransomware-2025-2685 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 9dcc036e-6027-52ae-8312-f08df2089f69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
