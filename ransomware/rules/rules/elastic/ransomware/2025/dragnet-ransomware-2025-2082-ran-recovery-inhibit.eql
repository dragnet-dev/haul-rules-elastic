// Dragnet [Ransomware]: dragnet-ransomware-2025-2082 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 79b65350-e723-545f-af3c-c01531da243a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
