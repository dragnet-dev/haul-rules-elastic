// Dragnet [Ransomware]: dragnet-ransomware-2025-1871 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: e4da8694-26e7-5c3f-bb0e-e50c68e1346b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
