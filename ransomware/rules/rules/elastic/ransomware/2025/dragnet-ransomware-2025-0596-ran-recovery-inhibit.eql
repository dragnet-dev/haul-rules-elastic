// Dragnet [Ransomware]: dragnet-ransomware-2025-0596 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 627af137-0b26-5d27-81ef-e01df876e9cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
