// Dragnet [Ransomware]: dragnet-ransomware-2025-7875 — Recovery Inhibition (nitrogen)
// Status: experimental | Level: high | ID: 0f53d2bf-96c5-5afc-b8a3-8da00d94a09f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
