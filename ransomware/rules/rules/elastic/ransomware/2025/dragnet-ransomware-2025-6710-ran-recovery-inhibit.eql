// Dragnet [Ransomware]: dragnet-ransomware-2025-6710 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 6fad6f28-2148-532e-bbe0-e046cacad7b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
