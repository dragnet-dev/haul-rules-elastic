// Dragnet [Ransomware]: dragnet-ransomware-2025-0848 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 4390828c-4f6e-53e7-b865-c8bb88f27f20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
