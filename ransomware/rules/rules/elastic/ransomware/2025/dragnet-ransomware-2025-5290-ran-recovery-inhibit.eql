// Dragnet [Ransomware]: dragnet-ransomware-2025-5290 — Recovery Inhibition (obscura)
// Status: deprecated | Level: high | ID: 5524aa17-74f7-5f13-854b-3dea4f07a618

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
