// Dragnet [Ransomware]: dragnet-ransomware-2025-1356 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: bb451433-567a-5274-8d32-a22e42f72063

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
