// Dragnet [Ransomware]: dragnet-ransomware-2025-5262 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 8d335673-e2fa-51d1-a89a-92006df3fac5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
