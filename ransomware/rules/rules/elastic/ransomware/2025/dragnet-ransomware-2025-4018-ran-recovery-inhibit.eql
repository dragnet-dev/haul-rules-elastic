// Dragnet [Ransomware]: dragnet-ransomware-2025-4018 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: aea3b862-b3c6-59d4-bab5-ad9dee5e3f54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
