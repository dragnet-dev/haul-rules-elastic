// Dragnet [Ransomware]: dragnet-ransomware-2025-6653 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 9d76a906-62d5-56da-b3ac-1866c66422d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
