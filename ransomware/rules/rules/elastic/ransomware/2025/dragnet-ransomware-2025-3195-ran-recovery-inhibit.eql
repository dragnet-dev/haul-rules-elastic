// Dragnet [Ransomware]: dragnet-ransomware-2025-3195 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 6c1bf87b-8f86-5682-bb8d-67530d659d56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
