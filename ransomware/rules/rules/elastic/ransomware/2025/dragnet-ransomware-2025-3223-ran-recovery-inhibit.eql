// Dragnet [Ransomware]: dragnet-ransomware-2025-3223 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: db2e1188-a4d4-5b6e-b70e-313062db5a0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
