// Dragnet [Ransomware]: dragnet-ransomware-2025-6483 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 11929ed0-b246-5d03-b03d-0358acd73c15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
