// Dragnet [Ransomware]: dragnet-ransomware-2025-7296 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c42445ce-7237-5913-8e10-7a67036043ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
