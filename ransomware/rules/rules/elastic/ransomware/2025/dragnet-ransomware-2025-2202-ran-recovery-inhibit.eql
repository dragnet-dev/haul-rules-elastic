// Dragnet [Ransomware]: dragnet-ransomware-2025-2202 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 8b910871-c631-58ae-afaf-36ac74c63aef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
