// Dragnet [Ransomware]: dragnet-ransomware-2025-1958 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 0c495eef-77c1-5b95-92d8-0997fbebd699

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
