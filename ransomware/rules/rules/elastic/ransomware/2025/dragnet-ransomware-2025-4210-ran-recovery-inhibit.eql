// Dragnet [Ransomware]: dragnet-ransomware-2025-4210 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 1dc432a8-9780-5d90-97e7-ed16ae9fbdba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
