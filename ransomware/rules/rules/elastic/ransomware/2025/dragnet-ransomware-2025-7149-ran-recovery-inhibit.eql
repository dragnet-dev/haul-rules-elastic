// Dragnet [Ransomware]: dragnet-ransomware-2025-7149 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 758b7042-d881-5501-91b9-602f298071f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
