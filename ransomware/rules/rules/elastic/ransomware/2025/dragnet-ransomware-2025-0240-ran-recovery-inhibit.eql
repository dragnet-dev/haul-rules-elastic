// Dragnet [Ransomware]: dragnet-ransomware-2025-0240 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 306475ec-83b6-5569-bd28-efbd173366d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
