// Dragnet [Ransomware]: dragnet-ransomware-2025-7918 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: f5f9eb38-f963-5dda-ae6f-f28d0b317763

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
