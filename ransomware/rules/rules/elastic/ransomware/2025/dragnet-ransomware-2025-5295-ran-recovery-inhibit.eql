// Dragnet [Ransomware]: dragnet-ransomware-2025-5295 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: f4f86983-13cf-50e5-95e4-03a68822b08b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
