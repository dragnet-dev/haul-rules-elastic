// Dragnet [Ransomware]: dragnet-ransomware-2025-2567 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: c0e998f3-ef7d-51ca-a4bf-b637d8fef7dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
