// Dragnet [Ransomware]: dragnet-ransomware-2025-7226 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 25e174fa-d68c-537f-a75b-66f24afcb465

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
