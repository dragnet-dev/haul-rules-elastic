// Dragnet [Ransomware]: dragnet-ransomware-2025-1418 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 8dc15924-bb4c-5a4a-9a2c-3afeb4408496

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
