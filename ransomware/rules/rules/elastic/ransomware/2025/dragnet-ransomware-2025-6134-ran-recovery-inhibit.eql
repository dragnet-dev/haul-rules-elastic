// Dragnet [Ransomware]: dragnet-ransomware-2025-6134 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: dcbd2ce9-be2f-5aaf-b3e4-a9e10921adde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
