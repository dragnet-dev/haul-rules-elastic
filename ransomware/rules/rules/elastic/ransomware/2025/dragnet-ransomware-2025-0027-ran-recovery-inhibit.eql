// Dragnet [Ransomware]: dragnet-ransomware-2025-0027 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: bfc19a23-ba4d-5b65-a339-0978df8cb928

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
