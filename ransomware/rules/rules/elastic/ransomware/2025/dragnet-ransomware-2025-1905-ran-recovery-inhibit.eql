// Dragnet [Ransomware]: dragnet-ransomware-2025-1905 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f5c48e11-795b-5904-a296-083a7232cd8f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
