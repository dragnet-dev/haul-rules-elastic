// Dragnet [Ransomware]: dragnet-ransomware-2025-3348 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: eedc2894-e6e0-5d9f-813a-99084975a2e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
