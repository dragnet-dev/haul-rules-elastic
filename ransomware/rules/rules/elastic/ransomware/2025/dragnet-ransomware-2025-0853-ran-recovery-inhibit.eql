// Dragnet [Ransomware]: dragnet-ransomware-2025-0853 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f4ff9114-adad-5774-b56b-5707678518b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
