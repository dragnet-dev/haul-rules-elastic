// Dragnet [Ransomware]: dragnet-ransomware-2025-0927 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 331618b4-3b2b-57c8-affb-ad83e8d1eaa5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
