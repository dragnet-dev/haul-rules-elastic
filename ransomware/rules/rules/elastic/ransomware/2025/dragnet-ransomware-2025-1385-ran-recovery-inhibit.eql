// Dragnet [Ransomware]: dragnet-ransomware-2025-1385 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 01500ccd-8199-5bde-bb5f-24e4934dee68

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
