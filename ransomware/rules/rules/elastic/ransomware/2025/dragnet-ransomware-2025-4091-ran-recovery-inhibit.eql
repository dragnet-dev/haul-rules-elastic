// Dragnet [Ransomware]: dragnet-ransomware-2025-4091 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: b8934387-8004-541f-be0c-44db220f34d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
