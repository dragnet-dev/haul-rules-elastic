// Dragnet [Ransomware]: dragnet-ransomware-2025-1006 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 53555180-83d1-58b1-b4cc-309353625b54

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
