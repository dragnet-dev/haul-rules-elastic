// Dragnet [Ransomware]: dragnet-ransomware-2025-3310 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a3f017ad-f677-54b4-837e-95a62f57a995

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
