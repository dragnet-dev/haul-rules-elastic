// Dragnet [Ransomware]: dragnet-ransomware-2025-0543 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 6255931b-6d19-574a-a370-c2734ba4064d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
