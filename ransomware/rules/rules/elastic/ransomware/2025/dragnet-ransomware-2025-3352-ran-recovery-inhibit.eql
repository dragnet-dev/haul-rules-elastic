// Dragnet [Ransomware]: dragnet-ransomware-2025-3352 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4b639c78-d761-53e2-9089-325fd46d0d53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
