// Dragnet [Ransomware]: dragnet-ransomware-2025-7056 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: 6d6e2ae5-d525-5c71-993d-8b343a399b19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
