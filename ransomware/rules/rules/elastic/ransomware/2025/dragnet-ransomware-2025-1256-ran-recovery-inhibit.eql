// Dragnet [Ransomware]: dragnet-ransomware-2025-1256 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 40b69884-ce7b-59ec-bc73-a95b430c55c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
