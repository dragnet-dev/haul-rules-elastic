// Dragnet [Ransomware]: dragnet-ransomware-2025-1915 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9b17f0de-8b61-5c08-befd-18c27b3a09fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
