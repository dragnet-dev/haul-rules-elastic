// Dragnet [Ransomware]: dragnet-ransomware-2025-0164 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3d7d07d6-4791-5608-8dc7-58856f1ac3a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
