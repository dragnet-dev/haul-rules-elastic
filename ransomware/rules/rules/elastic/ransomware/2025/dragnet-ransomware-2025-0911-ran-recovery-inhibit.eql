// Dragnet [Ransomware]: dragnet-ransomware-2025-0911 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: b2e7e902-7001-570c-9966-136b84d18e08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
