// Dragnet [Ransomware]: dragnet-ransomware-2025-5533 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 77fd7f7b-b51e-510d-a002-41f026fc1b9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
