// Dragnet [Ransomware]: dragnet-ransomware-2025-6630 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: 58077686-dd3a-50aa-b7ae-68efeea56e04

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
