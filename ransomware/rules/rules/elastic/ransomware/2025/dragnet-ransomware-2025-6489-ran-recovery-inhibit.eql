// Dragnet [Ransomware]: dragnet-ransomware-2025-6489 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 5a29c8e7-310a-5c1f-a1b1-c9f801bf9afb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
