// Dragnet [Ransomware]: dragnet-ransomware-2025-5857 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 0f1cf23c-d9da-56b4-a814-24993ee42ea0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
