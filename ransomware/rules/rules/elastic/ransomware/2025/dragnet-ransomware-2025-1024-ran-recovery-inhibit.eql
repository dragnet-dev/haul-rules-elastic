// Dragnet [Ransomware]: dragnet-ransomware-2025-1024 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 456c671b-2a40-541b-a68a-22b32985bcae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
