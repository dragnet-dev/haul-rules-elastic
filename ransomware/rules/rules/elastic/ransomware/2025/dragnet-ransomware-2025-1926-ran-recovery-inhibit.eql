// Dragnet [Ransomware]: dragnet-ransomware-2025-1926 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 78063496-0585-5733-8eca-5e4016fc1618

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
