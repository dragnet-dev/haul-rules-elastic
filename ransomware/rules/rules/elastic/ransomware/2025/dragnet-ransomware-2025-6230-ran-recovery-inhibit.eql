// Dragnet [Ransomware]: dragnet-ransomware-2025-6230 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 98f23bf7-9a4f-538b-8c13-be562e32e806

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
