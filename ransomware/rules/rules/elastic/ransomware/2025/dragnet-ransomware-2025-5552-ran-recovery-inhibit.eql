// Dragnet [Ransomware]: dragnet-ransomware-2025-5552 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: ae51dbfd-364e-53d1-acaf-487e717cb9c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
