// Dragnet [Ransomware]: dragnet-ransomware-2025-2534 — Recovery Inhibition (insomnia)
// Status: experimental | Level: high | ID: 84cb29f6-8ea8-5170-b558-d32d4976d969

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
