// Dragnet [Ransomware]: dragnet-ransomware-2025-6152 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 5b87e87a-270c-5c2d-908a-de32eb4a68b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
