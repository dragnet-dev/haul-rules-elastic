// Dragnet [Ransomware]: dragnet-ransomware-2025-2031 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 3fa19208-15ca-57f6-b14b-4da0dd5a2857

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
