// Dragnet [Ransomware]: dragnet-ransomware-2025-7170 — Recovery Inhibition (anubis)
// Status: experimental | Level: high | ID: 51861ce7-bfa0-5d64-bde0-3a0202e70c5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
