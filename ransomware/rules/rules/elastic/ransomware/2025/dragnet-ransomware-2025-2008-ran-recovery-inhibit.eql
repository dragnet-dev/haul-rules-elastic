// Dragnet [Ransomware]: dragnet-ransomware-2025-2008 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: b6521b89-540f-5ed2-adbe-dfa79998ffcb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
