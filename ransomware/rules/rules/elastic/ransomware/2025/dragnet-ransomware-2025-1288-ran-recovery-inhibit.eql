// Dragnet [Ransomware]: dragnet-ransomware-2025-1288 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 692518b6-50db-51d6-a76d-c14ef38dfea1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
