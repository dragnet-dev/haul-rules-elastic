// Dragnet [Ransomware]: dragnet-ransomware-2025-5605 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 671e3fbe-9206-53a2-bd5d-2916935ec80b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
