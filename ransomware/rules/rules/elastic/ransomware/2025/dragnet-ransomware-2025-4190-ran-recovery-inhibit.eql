// Dragnet [Ransomware]: dragnet-ransomware-2025-4190 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 06f7c164-4409-509a-b214-2088fa664eb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
