// Dragnet [Ransomware]: dragnet-ransomware-2025-5936 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4bc7b75a-bb75-54c1-b5fc-71cad03c6144

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
