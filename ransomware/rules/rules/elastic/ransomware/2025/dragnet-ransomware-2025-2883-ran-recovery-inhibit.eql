// Dragnet [Ransomware]: dragnet-ransomware-2025-2883 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: cc991e36-5ba4-5ce5-8bf4-c1d0530d3c78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
