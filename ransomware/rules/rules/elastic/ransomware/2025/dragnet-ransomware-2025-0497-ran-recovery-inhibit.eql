// Dragnet [Ransomware]: dragnet-ransomware-2025-0497 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c9e28915-808c-5712-9f31-3c9022ce8b47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
