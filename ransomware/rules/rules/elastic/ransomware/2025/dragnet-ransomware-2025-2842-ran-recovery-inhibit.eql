// Dragnet [Ransomware]: dragnet-ransomware-2025-2842 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 039d7641-fee5-532d-85b0-5124861d02dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
