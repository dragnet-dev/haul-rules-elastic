// Dragnet [Ransomware]: dragnet-ransomware-2025-1573 — Recovery Inhibition (VanHelsing)
// Status: experimental | Level: high | ID: da0d2420-ff1b-528e-a96b-fada74946a82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
