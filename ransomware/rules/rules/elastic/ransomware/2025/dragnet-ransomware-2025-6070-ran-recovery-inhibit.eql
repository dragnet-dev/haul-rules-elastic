// Dragnet [Ransomware]: dragnet-ransomware-2025-6070 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: fa4e5350-18d8-5d02-aff6-d2e1c94d460f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
