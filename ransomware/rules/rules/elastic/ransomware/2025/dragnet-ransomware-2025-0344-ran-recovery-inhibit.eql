// Dragnet [Ransomware]: dragnet-ransomware-2025-0344 — Recovery Inhibition (kawa4096)
// Status: deprecated | Level: high | ID: cc4c570e-8f86-54b2-91b5-00362f13a978

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
