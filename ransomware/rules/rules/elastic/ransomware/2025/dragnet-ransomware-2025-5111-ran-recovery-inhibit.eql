// Dragnet [Ransomware]: dragnet-ransomware-2025-5111 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 45afabb0-b368-5595-87b6-43c78f1ab50d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
