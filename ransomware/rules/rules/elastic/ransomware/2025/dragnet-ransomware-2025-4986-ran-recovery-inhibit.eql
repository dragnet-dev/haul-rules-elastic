// Dragnet [Ransomware]: dragnet-ransomware-2025-4986 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 497a385d-94d7-59fe-afd8-c866ae0d308d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
