// Dragnet [Ransomware]: dragnet-ransomware-2025-5517 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c2cf76dd-9bb3-5105-9289-967d14b414b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
