// Dragnet [Ransomware]: dragnet-ransomware-2025-6088 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 688cd8fd-d371-548e-a52d-f6b3376db48f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
