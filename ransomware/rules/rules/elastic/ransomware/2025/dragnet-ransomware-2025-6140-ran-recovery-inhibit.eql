// Dragnet [Ransomware]: dragnet-ransomware-2025-6140 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: b189da1e-8283-5b2b-a664-9bd44384b5f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
