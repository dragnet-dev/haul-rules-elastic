// Dragnet [Ransomware]: dragnet-ransomware-2025-6541 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: d17e6848-7cf1-503f-942c-89df3dfd5573

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
