// Dragnet [Ransomware]: dragnet-ransomware-2025-6836 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: bbf8ebf6-9f57-504f-a1ab-88ba7999d993

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
