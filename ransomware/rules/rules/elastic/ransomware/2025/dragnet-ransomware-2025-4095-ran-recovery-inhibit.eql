// Dragnet [Ransomware]: dragnet-ransomware-2025-4095 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: fd443e6f-7b54-5ef5-ac26-6f1fea992b2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
