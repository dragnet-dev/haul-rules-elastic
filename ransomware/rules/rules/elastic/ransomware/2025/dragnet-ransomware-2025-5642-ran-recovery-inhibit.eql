// Dragnet [Ransomware]: dragnet-ransomware-2025-5642 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 71559f35-529f-5a3e-9233-8f16a81b87aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
