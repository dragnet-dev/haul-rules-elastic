// Dragnet [Ransomware]: dragnet-ransomware-2025-4665 — Recovery Inhibition (kawa4096)
// Status: experimental | Level: high | ID: bbef2068-4f1e-5415-9f8c-0068d0fd885e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
