// Dragnet [Ransomware]: dragnet-ransomware-2025-5023 — Recovery Inhibition (radar)
// Status: deprecated | Level: high | ID: 68eaeb68-3c7c-5cbd-bc0d-9870c0b991d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
