// Dragnet [Ransomware]: dragnet-ransomware-2025-1281 — Recovery Inhibition (radiant)
// Status: experimental | Level: high | ID: 9603b654-1c85-5fb5-a979-5811b4d41a5a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
