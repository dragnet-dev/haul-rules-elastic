// Dragnet [Ransomware]: dragnet-ransomware-2025-6607 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 31a43cb5-78f9-5767-a210-d798de510400

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
