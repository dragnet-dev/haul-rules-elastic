// Dragnet [Ransomware]: dragnet-ransomware-2025-7379 — Recovery Inhibition (morpheus)
// Status: deprecated | Level: high | ID: 9c8dfe57-532a-5df5-8e05-77d2f701e9c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
