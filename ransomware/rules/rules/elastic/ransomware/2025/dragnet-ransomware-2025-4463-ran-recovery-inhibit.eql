// Dragnet [Ransomware]: dragnet-ransomware-2025-4463 — Recovery Inhibition (anubis)
// Status: experimental | Level: high | ID: c92aaaf9-9101-5706-bbfd-cf7d58e50ca5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
