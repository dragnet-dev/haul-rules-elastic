// Dragnet [Ransomware]: dragnet-ransomware-2025-1804 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: ae9aaa59-eca7-5f16-9a4f-b481d874375d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
