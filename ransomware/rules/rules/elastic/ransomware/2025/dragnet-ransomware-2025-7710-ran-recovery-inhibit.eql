// Dragnet [Ransomware]: dragnet-ransomware-2025-7710 — Recovery Inhibition (ralord)
// Status: experimental | Level: high | ID: a6305cf9-035e-543b-8a4b-0b853a7a5263

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
