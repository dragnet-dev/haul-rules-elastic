// Dragnet [Ransomware]: dragnet-ransomware-2025-4862 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 9b643414-5480-54b6-99e5-1531520820d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
