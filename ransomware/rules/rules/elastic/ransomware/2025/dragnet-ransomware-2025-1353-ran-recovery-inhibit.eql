// Dragnet [Ransomware]: dragnet-ransomware-2025-1353 — Recovery Inhibition (obscura)
// Status: experimental | Level: high | ID: be18d8a0-88a5-5e87-98c3-417a3205e9d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
