// Dragnet [Ransomware]: dragnet-ransomware-2025-6562 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: a4d985b4-8d0b-522e-ac28-09311620fc00

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
