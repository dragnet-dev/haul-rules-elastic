// Dragnet [Ransomware]: dragnet-ransomware-2025-4809 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e0caa850-fe7a-5c3f-872b-8898e950aecf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
