// Dragnet [Ransomware]: dragnet-ransomware-2025-0096 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b72e5dfc-ff46-581e-a8fa-45817fe4a492

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
