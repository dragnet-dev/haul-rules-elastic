// Dragnet [Ransomware]: dragnet-ransomware-2025-7435 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 614fb1e3-a890-5c1b-8811-b72483f12214

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
