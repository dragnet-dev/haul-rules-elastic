// Dragnet [Ransomware]: dragnet-ransomware-2025-2922 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: a88cba23-fd3c-5c2b-b5db-3fb05a826788

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
