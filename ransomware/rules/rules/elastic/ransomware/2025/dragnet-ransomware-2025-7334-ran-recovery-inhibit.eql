// Dragnet [Ransomware]: dragnet-ransomware-2025-7334 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: a88d89e8-b683-51d1-b097-e01950388467

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
