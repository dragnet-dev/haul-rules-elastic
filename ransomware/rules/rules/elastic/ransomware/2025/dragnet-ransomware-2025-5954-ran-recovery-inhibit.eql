// Dragnet [Ransomware]: dragnet-ransomware-2025-5954 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 0ba126b7-8922-5476-853a-40cfdc5bfed7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
