// Dragnet [Ransomware]: dragnet-ransomware-2025-3470 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: cc88cc12-58d5-560e-a37b-068b3d34e149

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
