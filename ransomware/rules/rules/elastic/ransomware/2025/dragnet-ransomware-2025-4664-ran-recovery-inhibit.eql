// Dragnet [Ransomware]: dragnet-ransomware-2025-4664 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: e74dfabb-6bfa-58b1-aca1-d1aa9837fa4e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
