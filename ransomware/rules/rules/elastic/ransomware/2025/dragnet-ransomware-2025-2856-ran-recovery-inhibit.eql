// Dragnet [Ransomware]: dragnet-ransomware-2025-2856 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: da05d854-01a2-5675-afb1-1a781aefa2c9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
