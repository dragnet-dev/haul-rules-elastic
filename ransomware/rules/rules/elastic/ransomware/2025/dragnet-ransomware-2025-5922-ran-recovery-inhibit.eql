// Dragnet [Ransomware]: dragnet-ransomware-2025-5922 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: ce4b207f-e6c6-549e-b247-aaf3c02fbd15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
