// Dragnet [Ransomware]: dragnet-ransomware-2025-1888 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 3948f28b-3e11-5e1b-b349-6a9c003bed93

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
