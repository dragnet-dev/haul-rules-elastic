// Dragnet [Ransomware]: dragnet-ransomware-2025-7105 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 89fef122-f597-56d7-bfc1-f20bc0f8e1fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
