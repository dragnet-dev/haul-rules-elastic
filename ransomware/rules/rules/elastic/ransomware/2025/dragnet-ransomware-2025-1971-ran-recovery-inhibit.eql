// Dragnet [Ransomware]: dragnet-ransomware-2025-1971 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: c77b3d56-9260-5083-b031-66d845817a42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
