// Dragnet [Ransomware]: dragnet-ransomware-2025-6103 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 53507f29-9877-5938-9aec-a4debd1d033d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
