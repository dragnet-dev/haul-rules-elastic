// Dragnet [Ransomware]: dragnet-ransomware-2025-5025 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 35fcf251-7d8c-5476-b7f3-8ce5346ef7a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
