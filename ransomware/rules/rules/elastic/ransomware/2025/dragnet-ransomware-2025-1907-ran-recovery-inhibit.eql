// Dragnet [Ransomware]: dragnet-ransomware-2025-1907 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 1ac87a98-e193-5aa1-906f-7d2070e05ba3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
