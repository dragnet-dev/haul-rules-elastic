// Dragnet [Ransomware]: dragnet-ransomware-2025-7343 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ecc3c979-a183-59dc-a405-e9c85c6b6c9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
