// Dragnet [Ransomware]: dragnet-ransomware-2025-4704 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7034ddbe-eb11-5c55-9151-297ba51bc76b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
