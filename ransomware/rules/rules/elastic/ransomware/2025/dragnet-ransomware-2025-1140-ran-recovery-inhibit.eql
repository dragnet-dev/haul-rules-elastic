// Dragnet [Ransomware]: dragnet-ransomware-2025-1140 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 22872eaf-bf78-533f-89a6-82609d33fc35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
