// Dragnet [Ransomware]: dragnet-ransomware-2025-7481 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: ff4d11c1-7f6b-5fac-9c5e-bfaf83a78427

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
