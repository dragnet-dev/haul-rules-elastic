// Dragnet [Ransomware]: dragnet-ransomware-2025-4209 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 27f33dd7-675a-5923-b813-4e839f5d525a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
