// Dragnet [Ransomware]: dragnet-ransomware-2025-0511 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 7a9f9c86-51e9-5990-9c8f-8a08e1b6d7aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
