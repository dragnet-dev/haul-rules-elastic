// Dragnet [Ransomware]: dragnet-ransomware-2025-7529 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 9ab53460-d2f6-5295-b847-417736035434

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
