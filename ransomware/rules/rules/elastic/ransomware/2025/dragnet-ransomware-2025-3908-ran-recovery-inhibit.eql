// Dragnet [Ransomware]: dragnet-ransomware-2025-3908 — Recovery Inhibition (chaos)
// Status: test | Level: high | ID: 80776169-ed1a-56a4-9d57-07ed611f047a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
