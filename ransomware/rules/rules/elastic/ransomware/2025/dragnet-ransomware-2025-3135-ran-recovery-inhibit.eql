// Dragnet [Ransomware]: dragnet-ransomware-2025-3135 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: c99ddc16-73eb-52c7-ad54-bddff39b40c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
