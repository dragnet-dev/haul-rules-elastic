// Dragnet [Ransomware]: dragnet-ransomware-2025-6997 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 35136a28-6d08-5d15-b1e6-e540b8b70a21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
