// Dragnet [Ransomware]: dragnet-ransomware-2025-2649 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 56f40838-28e5-5058-b860-239686f75e9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
