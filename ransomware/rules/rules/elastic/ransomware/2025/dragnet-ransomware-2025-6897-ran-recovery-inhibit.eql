// Dragnet [Ransomware]: dragnet-ransomware-2025-6897 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 9978b5d1-38ae-5543-91e8-1a133b985ac5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
