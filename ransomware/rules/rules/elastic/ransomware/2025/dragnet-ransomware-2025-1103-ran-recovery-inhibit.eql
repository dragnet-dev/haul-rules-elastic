// Dragnet [Ransomware]: dragnet-ransomware-2025-1103 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: c6b329a7-8664-5782-a6b7-f196d6d37a48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
