// Dragnet [Ransomware]: dragnet-ransomware-2025-2217 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: dc2b6a96-d0a5-5e5f-ad65-f5916e5f6841

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
