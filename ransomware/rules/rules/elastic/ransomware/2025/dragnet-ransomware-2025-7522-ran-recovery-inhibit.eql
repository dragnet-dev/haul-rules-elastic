// Dragnet [Ransomware]: dragnet-ransomware-2025-7522 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 6cb9479d-74e7-5fbd-9df3-d9775c7089ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
