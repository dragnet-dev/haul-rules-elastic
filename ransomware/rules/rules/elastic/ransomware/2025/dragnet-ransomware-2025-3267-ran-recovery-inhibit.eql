// Dragnet [Ransomware]: dragnet-ransomware-2025-3267 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d1cbafae-7078-5abd-95db-ea69ca4b33de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
