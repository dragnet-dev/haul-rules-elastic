// Dragnet [Ransomware]: dragnet-ransomware-2025-3915 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8755a154-28b0-5aa8-8d26-c93cd586def2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
