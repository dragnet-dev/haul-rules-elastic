// Dragnet [Ransomware]: dragnet-ransomware-2025-3764 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 650e5b97-e786-5bc3-ac50-f8e0d5aae0ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
