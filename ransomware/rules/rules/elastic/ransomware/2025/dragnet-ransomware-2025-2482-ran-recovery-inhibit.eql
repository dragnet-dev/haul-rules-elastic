// Dragnet [Ransomware]: dragnet-ransomware-2025-2482 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: c86ab678-d40f-58ef-bb49-78799c062ae6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
