// Dragnet [Ransomware]: dragnet-ransomware-2025-3300 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 80d946d9-24ca-5979-bab8-ddcc6dfee85e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
