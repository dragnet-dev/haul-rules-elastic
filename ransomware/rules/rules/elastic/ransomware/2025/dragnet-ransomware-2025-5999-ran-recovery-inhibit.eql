// Dragnet [Ransomware]: dragnet-ransomware-2025-5999 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 70ad9203-2136-597d-a03a-d0384c1d5197

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
