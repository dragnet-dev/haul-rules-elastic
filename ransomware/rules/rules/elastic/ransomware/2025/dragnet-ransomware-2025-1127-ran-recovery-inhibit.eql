// Dragnet [Ransomware]: dragnet-ransomware-2025-1127 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: 2750f351-a94a-5cf0-8790-bbb886926195

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
