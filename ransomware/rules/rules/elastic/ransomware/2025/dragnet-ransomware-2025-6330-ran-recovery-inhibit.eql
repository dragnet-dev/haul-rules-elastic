// Dragnet [Ransomware]: dragnet-ransomware-2025-6330 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: df8b3dd8-d800-5081-a9f7-ceca6a7bf7e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
