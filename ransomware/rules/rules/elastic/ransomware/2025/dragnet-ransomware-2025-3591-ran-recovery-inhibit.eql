// Dragnet [Ransomware]: dragnet-ransomware-2025-3591 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 5898c588-6530-5ea1-b4ce-7cb08ed6d794

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
