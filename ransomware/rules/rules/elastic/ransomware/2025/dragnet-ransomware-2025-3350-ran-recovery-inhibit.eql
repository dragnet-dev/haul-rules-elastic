// Dragnet [Ransomware]: dragnet-ransomware-2025-3350 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 8e73b784-e436-5b9f-9891-6123b91b2c0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
