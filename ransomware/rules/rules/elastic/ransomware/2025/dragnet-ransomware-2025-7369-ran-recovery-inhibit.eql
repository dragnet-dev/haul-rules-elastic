// Dragnet [Ransomware]: dragnet-ransomware-2025-7369 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: d39b4f49-11aa-5d8a-9bae-ceb5669e6296

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
