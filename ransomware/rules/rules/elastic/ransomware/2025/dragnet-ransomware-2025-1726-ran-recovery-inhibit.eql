// Dragnet [Ransomware]: dragnet-ransomware-2025-1726 — Recovery Inhibition (weyhro)
// Status: experimental | Level: high | ID: ca946c0a-2347-5edb-b6e1-b1a7811f24a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
