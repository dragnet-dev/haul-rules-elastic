// Dragnet [Ransomware]: dragnet-ransomware-2025-1524 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 48a4fe88-d51d-542b-ae57-8e403b863f41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
