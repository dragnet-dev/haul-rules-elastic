// Dragnet [Ransomware]: dragnet-ransomware-2025-3117 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 2791511a-e4bb-5e31-b5ca-907525758c6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
