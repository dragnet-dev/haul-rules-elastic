// Dragnet [Ransomware]: dragnet-ransomware-2025-1884 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 30e41843-75b1-5d6d-87c4-2dc287be04f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
