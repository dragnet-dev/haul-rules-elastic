// Dragnet [Ransomware]: dragnet-ransomware-2025-2167 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bfd8e4b7-2ce8-567c-a1e4-5c30d03ccfbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
