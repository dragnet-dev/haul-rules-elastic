// Dragnet [Ransomware]: dragnet-ransomware-2025-3604 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 605e3035-413d-5fde-ad1b-60d5536f3bdb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
