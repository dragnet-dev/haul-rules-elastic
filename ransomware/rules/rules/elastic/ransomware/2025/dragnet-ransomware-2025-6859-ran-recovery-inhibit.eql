// Dragnet [Ransomware]: dragnet-ransomware-2025-6859 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: b09858a4-c272-5729-a3e3-59fb3e140278

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
