// Dragnet [Ransomware]: dragnet-ransomware-2025-7476 — Recovery Inhibition (darkvault)
// Status: experimental | Level: high | ID: 8e901585-bc60-55c3-8c07-2b5bef272f8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
