// Dragnet [Ransomware]: dragnet-ransomware-2025-6737 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 902e9f62-9f3c-5323-bb69-165c34b3735f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
