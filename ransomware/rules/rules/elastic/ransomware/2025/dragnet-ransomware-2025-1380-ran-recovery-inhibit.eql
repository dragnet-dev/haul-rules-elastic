// Dragnet [Ransomware]: dragnet-ransomware-2025-1380 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e2faad33-3b18-599a-aa26-dddea06f0359

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
