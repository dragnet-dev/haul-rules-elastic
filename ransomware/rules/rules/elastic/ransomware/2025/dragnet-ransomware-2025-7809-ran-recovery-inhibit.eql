// Dragnet [Ransomware]: dragnet-ransomware-2025-7809 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3952c9f4-6489-5b6a-b06a-b1fe7dacd66e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
