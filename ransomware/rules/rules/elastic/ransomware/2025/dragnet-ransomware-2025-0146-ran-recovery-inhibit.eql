// Dragnet [Ransomware]: dragnet-ransomware-2025-0146 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b40a0ddf-98a0-5ef3-8ac4-5681852a8a8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
