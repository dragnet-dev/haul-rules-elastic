// Dragnet [Ransomware]: dragnet-ransomware-2025-6730 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cb9681df-7201-5dcf-a33c-21484ae83022

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
