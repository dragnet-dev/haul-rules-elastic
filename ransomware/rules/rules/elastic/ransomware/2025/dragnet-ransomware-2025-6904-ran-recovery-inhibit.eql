// Dragnet [Ransomware]: dragnet-ransomware-2025-6904 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 8badb678-0e09-5cb1-93af-d3442035d922

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
