// Dragnet [Ransomware]: dragnet-ransomware-2025-1549 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4859904c-b4e6-594b-8249-ec240bc2e914

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
