// Dragnet [Ransomware]: dragnet-ransomware-2025-0169 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2a209cbd-cdb8-5594-861c-151686673d48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
