// Dragnet [Ransomware]: dragnet-ransomware-2025-4680 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: a6374b4f-7f0c-573c-bed0-dbdb786f7079

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
