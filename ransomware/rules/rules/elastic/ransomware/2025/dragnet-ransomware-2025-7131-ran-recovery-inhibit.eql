// Dragnet [Ransomware]: dragnet-ransomware-2025-7131 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: fbef14e4-c8a2-599c-891c-140053996845

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
