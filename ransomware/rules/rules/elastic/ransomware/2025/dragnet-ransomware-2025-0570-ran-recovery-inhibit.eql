// Dragnet [Ransomware]: dragnet-ransomware-2025-0570 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 82d7fcea-e560-5d88-9dca-3038c945c926

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
