// Dragnet [Ransomware]: dragnet-ransomware-2025-5793 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 431d7a0b-cb8b-5e5f-8f2c-e7b9aae32d37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
