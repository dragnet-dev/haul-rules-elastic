// Dragnet [Ransomware]: dragnet-ransomware-2025-5086 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 99736628-d825-5822-95e8-3f09ea7e3d8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
