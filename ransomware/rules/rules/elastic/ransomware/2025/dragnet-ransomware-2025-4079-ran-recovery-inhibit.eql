// Dragnet [Ransomware]: dragnet-ransomware-2025-4079 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: e665bd0f-6d44-5c8b-a7b5-ab508a309f50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
