// Dragnet [Ransomware]: dragnet-ransomware-2025-4549 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 4e2adacd-f643-5943-950a-a55417260e66

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
