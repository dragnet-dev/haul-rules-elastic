// Dragnet [Ransomware]: dragnet-ransomware-2025-7826 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 58c709ac-45d6-5a36-baaf-2e2bb8ec1320

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
