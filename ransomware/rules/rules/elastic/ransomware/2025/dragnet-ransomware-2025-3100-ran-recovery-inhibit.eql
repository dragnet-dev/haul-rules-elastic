// Dragnet [Ransomware]: dragnet-ransomware-2025-3100 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b56f133d-901e-5ba2-ba83-3de70bd1b64f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
