// Dragnet [Ransomware]: dragnet-ransomware-2025-4534 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 97f05a7c-e236-5284-b17f-16510f3bd2c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
