// Dragnet [Ransomware]: dragnet-ransomware-2025-5137 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 1fc70769-37cb-5976-9a5e-7a55122fd537

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
