// Dragnet [Ransomware]: dragnet-ransomware-2025-5131 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 66034a27-fa8c-53e2-b770-7bdd9fa11132

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
