// Dragnet [Ransomware]: dragnet-ransomware-2025-1246 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 32466ec7-7e44-5d33-a526-9403a56ccd59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
