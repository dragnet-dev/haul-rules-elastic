// Dragnet [Ransomware]: dragnet-ransomware-2025-5701 — Recovery Inhibition (morpheus)
// Status: deprecated | Level: high | ID: 46d4cc78-3590-5971-bfec-a2fa419932dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
