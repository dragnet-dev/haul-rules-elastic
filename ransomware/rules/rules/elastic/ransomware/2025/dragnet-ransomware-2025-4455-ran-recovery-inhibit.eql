// Dragnet [Ransomware]: dragnet-ransomware-2025-4455 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: da44f9a5-99ce-59e5-8774-b76ebd100585

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
