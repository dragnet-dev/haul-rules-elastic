// Dragnet [Ransomware]: dragnet-ransomware-2025-4054 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 59907c20-1455-58a3-a9d2-38ba8412435a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
