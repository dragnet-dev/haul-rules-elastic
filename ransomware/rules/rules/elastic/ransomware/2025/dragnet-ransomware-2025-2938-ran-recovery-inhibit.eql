// Dragnet [Ransomware]: dragnet-ransomware-2025-2938 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 4e48a91f-168e-58d7-b688-abb1f8c95fdf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
