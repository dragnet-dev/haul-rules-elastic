// Dragnet [Ransomware]: dragnet-ransomware-2025-2647 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 2576e5d9-2092-538b-ba58-099310831559

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
