// Dragnet [Ransomware]: dragnet-ransomware-2025-6553 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 48c0ba6d-ea6a-5d51-9b9f-ecbb66fa5933

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
