// Dragnet [Ransomware]: dragnet-ransomware-2025-1041 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 38faa4a5-f5d6-5e07-9b8b-428bc77d6b46

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
