// Dragnet [Ransomware]: dragnet-ransomware-2025-5123 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c79567d0-fc08-53a8-8ae5-a6973f783e14

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
