// Dragnet [Ransomware]: dragnet-ransomware-2025-3941 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: baa5f74c-1342-519e-8abe-ff355f306ccd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
