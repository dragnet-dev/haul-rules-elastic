// Dragnet [Ransomware]: dragnet-ransomware-2025-3530 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 8199b541-114c-5cfa-b2d3-f472b82fb13c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
