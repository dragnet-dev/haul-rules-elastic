// Dragnet [Ransomware]: dragnet-ransomware-2025-5571 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 76f7da10-4f89-51b5-a59c-507b48e91454

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
