// Dragnet [Ransomware]: dragnet-ransomware-2025-6168 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1e460c76-9e1c-5a86-addd-0fb6e3dcb1a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
