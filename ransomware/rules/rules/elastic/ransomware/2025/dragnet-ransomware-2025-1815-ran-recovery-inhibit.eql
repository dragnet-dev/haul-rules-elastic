// Dragnet [Ransomware]: dragnet-ransomware-2025-1815 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: bcf05746-e11f-5722-b23d-bba4ec453124

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
