// Dragnet [Ransomware]: dragnet-ransomware-2025-6947 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 816736a9-258e-5a60-9059-e2bae8bc6189

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
