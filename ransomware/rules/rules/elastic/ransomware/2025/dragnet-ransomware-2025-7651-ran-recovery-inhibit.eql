// Dragnet [Ransomware]: dragnet-ransomware-2025-7651 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: d63a511f-64c0-56c6-92bc-22f7260d8ac3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
