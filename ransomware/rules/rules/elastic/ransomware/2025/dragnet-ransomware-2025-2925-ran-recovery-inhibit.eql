// Dragnet [Ransomware]: dragnet-ransomware-2025-2925 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: a624e1f7-4e62-5b56-8eca-ad8e60adce20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
