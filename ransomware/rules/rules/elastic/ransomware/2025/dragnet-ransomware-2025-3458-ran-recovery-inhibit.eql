// Dragnet [Ransomware]: dragnet-ransomware-2025-3458 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 61e6eb94-d04c-5c6a-8f84-9dcf3d8e23fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
