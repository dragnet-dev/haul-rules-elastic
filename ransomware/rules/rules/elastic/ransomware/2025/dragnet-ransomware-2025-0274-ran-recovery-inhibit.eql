// Dragnet [Ransomware]: dragnet-ransomware-2025-0274 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 0a037107-e059-552c-8cb3-5221bfe827ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
