// Dragnet [Ransomware]: dragnet-ransomware-2025-6993 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1f636068-b702-5585-af8d-d09a13653dfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
