// Dragnet [Ransomware]: dragnet-ransomware-2025-7853 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 945a0364-429f-5ff2-8ab7-3e25ac7cd87b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
