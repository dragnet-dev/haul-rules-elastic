// Dragnet [Ransomware]: dragnet-ransomware-2025-6082 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 92925d7f-cb2b-56c5-8e42-42616c61da47

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
