// Dragnet [Ransomware]: dragnet-ransomware-2025-3765 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d4100a50-0c43-5e0b-a6e2-b92ff685cdfe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
