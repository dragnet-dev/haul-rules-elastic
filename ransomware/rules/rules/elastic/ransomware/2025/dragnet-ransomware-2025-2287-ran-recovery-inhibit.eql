// Dragnet [Ransomware]: dragnet-ransomware-2025-2287 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 1b0d54fc-57b6-500f-bdda-91789837d3b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
