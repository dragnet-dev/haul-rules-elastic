// Dragnet [Ransomware]: dragnet-ransomware-2025-7326 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9f3a9e32-1b93-5cf2-81ab-2eaf69d1c85a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
