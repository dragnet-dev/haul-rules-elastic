// Dragnet [Ransomware]: dragnet-ransomware-2025-6587 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d22a12bf-4f57-5b5c-b3c5-22562c746eae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
