// Dragnet [Ransomware]: dragnet-ransomware-2025-2900 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9f0b93ed-5113-5b38-9a66-cf8a08e8d95e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
