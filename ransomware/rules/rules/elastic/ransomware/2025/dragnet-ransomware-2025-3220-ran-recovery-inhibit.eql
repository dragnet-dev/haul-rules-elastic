// Dragnet [Ransomware]: dragnet-ransomware-2025-3220 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e1843ddb-1b98-54ea-a7a4-3dd1b1382dff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
