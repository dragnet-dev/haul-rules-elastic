// Dragnet [Ransomware]: dragnet-ransomware-2025-4926 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0d299f5f-eb46-550e-8605-65def164f5ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
