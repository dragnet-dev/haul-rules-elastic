// Dragnet [Ransomware]: dragnet-ransomware-2025-5145 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 294e67f5-e10e-579c-a555-4937d38d22fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
