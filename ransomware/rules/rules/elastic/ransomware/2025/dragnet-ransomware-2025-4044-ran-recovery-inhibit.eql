// Dragnet [Ransomware]: dragnet-ransomware-2025-4044 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: cd7d758c-605a-529e-a424-9d4dd4dee651

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
