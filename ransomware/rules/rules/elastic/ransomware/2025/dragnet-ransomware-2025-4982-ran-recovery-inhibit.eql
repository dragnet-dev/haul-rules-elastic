// Dragnet [Ransomware]: dragnet-ransomware-2025-4982 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 3ed4a489-8493-5db3-9dc1-2d9f6e98899d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
