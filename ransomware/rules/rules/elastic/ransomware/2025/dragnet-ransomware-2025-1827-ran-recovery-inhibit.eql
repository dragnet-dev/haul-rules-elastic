// Dragnet [Ransomware]: dragnet-ransomware-2025-1827 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 22e3430a-4129-544b-9725-5666c2e185e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
