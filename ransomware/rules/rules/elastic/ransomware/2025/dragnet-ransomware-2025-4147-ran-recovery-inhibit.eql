// Dragnet [Ransomware]: dragnet-ransomware-2025-4147 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: de45a4df-ce57-51af-9cf4-ba7675c2aec9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
