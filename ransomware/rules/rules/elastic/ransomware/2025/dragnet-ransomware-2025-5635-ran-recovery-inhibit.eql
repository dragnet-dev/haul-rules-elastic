// Dragnet [Ransomware]: dragnet-ransomware-2025-5635 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: d2e2c024-8eec-562e-8513-14a70199bf1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
