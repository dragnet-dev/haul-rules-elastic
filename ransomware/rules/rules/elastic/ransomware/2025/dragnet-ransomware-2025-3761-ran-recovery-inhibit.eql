// Dragnet [Ransomware]: dragnet-ransomware-2025-3761 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: 1b7dfb66-4623-5384-8675-b02af26725c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
