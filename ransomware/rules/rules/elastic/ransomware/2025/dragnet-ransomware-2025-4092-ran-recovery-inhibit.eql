// Dragnet [Ransomware]: dragnet-ransomware-2025-4092 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 13725531-cea5-5d62-b770-0375b0a53f3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
