// Dragnet [Ransomware]: dragnet-ransomware-2025-1755 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 63603421-245f-58be-881b-808f500d6316

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
