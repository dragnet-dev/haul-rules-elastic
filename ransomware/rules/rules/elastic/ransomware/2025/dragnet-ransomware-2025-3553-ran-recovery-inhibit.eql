// Dragnet [Ransomware]: dragnet-ransomware-2025-3553 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 00dfb0c8-40ff-59c4-a677-4a150a054385

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
