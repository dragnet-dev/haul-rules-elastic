// Dragnet [Ransomware]: dragnet-ransomware-2025-6890 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9ba35d47-a2c1-54e9-b84a-3852ffa6a49d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
