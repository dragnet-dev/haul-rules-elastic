// Dragnet [Ransomware]: dragnet-ransomware-2025-1220 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 93b09666-e334-52ad-a69e-ddb98dfaa238

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
