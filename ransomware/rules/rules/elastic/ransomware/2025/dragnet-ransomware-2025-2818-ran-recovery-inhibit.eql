// Dragnet [Ransomware]: dragnet-ransomware-2025-2818 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 6493ccb7-222e-5316-919c-ede5f4c2cc87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
