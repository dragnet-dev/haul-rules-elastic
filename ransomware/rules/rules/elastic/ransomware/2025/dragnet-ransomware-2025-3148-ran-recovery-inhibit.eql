// Dragnet [Ransomware]: dragnet-ransomware-2025-3148 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: c83072b8-b983-51f8-8471-8bae8159bbda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
