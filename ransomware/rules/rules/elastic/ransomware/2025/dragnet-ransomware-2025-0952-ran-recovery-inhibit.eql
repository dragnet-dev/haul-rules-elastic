// Dragnet [Ransomware]: dragnet-ransomware-2025-0952 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 900909f1-1d45-527d-8b9a-97eb26107a0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
