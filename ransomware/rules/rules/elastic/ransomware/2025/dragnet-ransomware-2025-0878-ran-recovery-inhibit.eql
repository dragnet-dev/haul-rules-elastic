// Dragnet [Ransomware]: dragnet-ransomware-2025-0878 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 7f4f8f55-307a-5fa5-b028-3a47fce06742

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
