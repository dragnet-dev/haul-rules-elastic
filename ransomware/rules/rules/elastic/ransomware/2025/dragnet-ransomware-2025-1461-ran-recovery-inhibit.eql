// Dragnet [Ransomware]: dragnet-ransomware-2025-1461 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 18a921e9-6ca1-5f3b-9eda-6146a4c877e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
