// Dragnet [Ransomware]: dragnet-ransomware-2025-1887 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: f2d82c84-5aa4-55a4-b28b-6bc02350f0cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
