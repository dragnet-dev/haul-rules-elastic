// Dragnet [Ransomware]: dragnet-ransomware-2025-2833 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3a43733a-1866-5871-89cc-81eb096e92c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
