// Dragnet [Ransomware]: dragnet-ransomware-2025-7252 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 66e65d46-0702-5b94-b7e6-4889d004d12c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
