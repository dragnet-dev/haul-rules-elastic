// Dragnet [Ransomware]: dragnet-ransomware-2025-3162 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: a3715148-5935-5d0a-9204-5de8cf39f878

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
