// Dragnet [Ransomware]: dragnet-ransomware-2025-2234 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 3a7bcaaa-b488-57c3-a787-3ea4ca1ae1e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
