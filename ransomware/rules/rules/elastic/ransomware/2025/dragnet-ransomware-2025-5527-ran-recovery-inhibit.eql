// Dragnet [Ransomware]: dragnet-ransomware-2025-5527 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: b8a12541-327d-5f35-a27a-0e2bc41691cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
