// Dragnet [Ransomware]: dragnet-ransomware-2025-2935 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3503f4d9-b2c7-5321-89e7-0fbf67e83985

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
