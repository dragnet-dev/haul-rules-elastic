// Dragnet [Ransomware]: dragnet-ransomware-2025-1047 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: 673fd9d3-42dc-524a-96de-f000aa3b394e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
