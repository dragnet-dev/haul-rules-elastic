// Dragnet [Ransomware]: dragnet-ransomware-2025-7150 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: d5cc35e9-6e10-5785-89d5-278ec55be9a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
