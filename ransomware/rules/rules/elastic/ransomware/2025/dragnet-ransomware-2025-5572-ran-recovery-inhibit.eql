// Dragnet [Ransomware]: dragnet-ransomware-2025-5572 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 3beb1278-2e21-52db-8091-1b122fceee76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
