// Dragnet [Ransomware]: dragnet-ransomware-2025-6941 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 684c0710-f6fb-5ceb-bd70-852c3305dbb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
