// Dragnet [Ransomware]: dragnet-ransomware-2025-5781 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: d5b1ae50-7a6e-5517-84dd-c73f50645142

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
