// Dragnet [Ransomware]: dragnet-ransomware-2025-5378 — Recovery Inhibition (hellcat)
// Status: deprecated | Level: high | ID: fd271574-2848-5a29-8ab6-e068f779aa44

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
