// Dragnet [Ransomware]: dragnet-ransomware-2025-0351 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: fc03f37e-4547-5091-85ef-50016ca2113c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
