// Dragnet [Ransomware]: dragnet-ransomware-2025-1761 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 2b32f1cb-e0e0-52b7-858b-7b38a7922974

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
