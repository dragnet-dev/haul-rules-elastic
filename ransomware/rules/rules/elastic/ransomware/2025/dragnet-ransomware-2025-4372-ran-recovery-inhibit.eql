// Dragnet [Ransomware]: dragnet-ransomware-2025-4372 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 352e9772-b0c9-537a-9a50-0bc77b6f0077

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
