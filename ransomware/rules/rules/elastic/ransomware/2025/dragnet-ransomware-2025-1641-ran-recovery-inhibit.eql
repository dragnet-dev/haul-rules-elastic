// Dragnet [Ransomware]: dragnet-ransomware-2025-1641 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 4f94ad3f-c321-57ed-b8f3-f654310b6391

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
