// Dragnet [Ransomware]: dragnet-ransomware-2025-6617 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 2009964c-7801-5e16-8aa4-4965aa545a74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
