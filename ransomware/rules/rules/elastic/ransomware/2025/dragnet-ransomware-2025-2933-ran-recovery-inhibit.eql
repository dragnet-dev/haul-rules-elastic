// Dragnet [Ransomware]: dragnet-ransomware-2025-2933 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: d6140219-9eb6-54e9-8fa6-cf99784c5896

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
