// Dragnet [Ransomware]: dragnet-ransomware-2025-4742 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: cdc99871-b6f6-58fe-9259-9812e038f27d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
