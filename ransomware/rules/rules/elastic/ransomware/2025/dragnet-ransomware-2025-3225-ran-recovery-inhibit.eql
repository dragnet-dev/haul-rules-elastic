// Dragnet [Ransomware]: dragnet-ransomware-2025-3225 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 62861f88-2066-5a17-984e-7f91081c3193

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
