// Dragnet [Ransomware]: dragnet-ransomware-2025-5893 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: dc4a0a09-b3cb-5cc4-ac07-99317022d478

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
