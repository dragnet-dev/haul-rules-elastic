// Dragnet [Ransomware]: dragnet-ransomware-2025-4020 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8c0aebc3-6f33-5ea5-8b0d-7a434c8ad806

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
