// Dragnet [Ransomware]: dragnet-ransomware-2025-7429 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: cf4149ff-387a-5aed-8e1e-c3a0dcf37dbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
