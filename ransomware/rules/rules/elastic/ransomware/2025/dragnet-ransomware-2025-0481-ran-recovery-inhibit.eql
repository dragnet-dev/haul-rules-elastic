// Dragnet [Ransomware]: dragnet-ransomware-2025-0481 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1dac737f-4a36-5fb3-95fa-befc8535e104

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
