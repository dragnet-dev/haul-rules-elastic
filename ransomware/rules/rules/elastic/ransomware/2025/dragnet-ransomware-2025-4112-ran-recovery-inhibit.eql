// Dragnet [Ransomware]: dragnet-ransomware-2025-4112 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7289c373-d3b4-5192-8633-29de456483ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
