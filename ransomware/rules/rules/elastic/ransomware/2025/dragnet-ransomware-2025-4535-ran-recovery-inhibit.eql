// Dragnet [Ransomware]: dragnet-ransomware-2025-4535 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d00fb188-eda9-5357-b053-3246533571f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
