// Dragnet [Ransomware]: dragnet-ransomware-2025-5122 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: b5e41f37-09e4-5a1b-8d3f-e632ad3bafc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
