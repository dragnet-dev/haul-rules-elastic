// Dragnet [Ransomware]: dragnet-ransomware-2025-3853 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 74754a65-4578-56fd-9e99-a3fad41b4557

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
