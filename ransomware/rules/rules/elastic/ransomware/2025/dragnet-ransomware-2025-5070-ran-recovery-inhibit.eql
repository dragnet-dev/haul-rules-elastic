// Dragnet [Ransomware]: dragnet-ransomware-2025-5070 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: cc16071e-c648-5c8c-8057-a7c40dc0d811

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
