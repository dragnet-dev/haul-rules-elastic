// Dragnet [Ransomware]: dragnet-ransomware-2025-5550 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: b93d85d8-31cd-58d7-b36f-fde22e6a3931

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
