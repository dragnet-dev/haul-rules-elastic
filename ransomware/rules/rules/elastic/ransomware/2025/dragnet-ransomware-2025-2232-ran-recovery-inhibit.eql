// Dragnet [Ransomware]: dragnet-ransomware-2025-2232 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: bbccb5c3-d4a0-5031-9339-fcf5f0a8e58d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
