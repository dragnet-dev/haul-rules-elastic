// Dragnet [Ransomware]: dragnet-ransomware-2025-7161 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: b012c8a4-5fc1-5208-a0e5-56ababf39b6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
