// Dragnet [Ransomware]: dragnet-ransomware-2025-5039 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d907c326-63d3-59e8-8573-c700e5a7fcc1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
