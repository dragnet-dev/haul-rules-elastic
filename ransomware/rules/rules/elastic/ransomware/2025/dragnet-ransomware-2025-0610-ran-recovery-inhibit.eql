// Dragnet [Ransomware]: dragnet-ransomware-2025-0610 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 46d85db3-4886-5e98-982e-9c712ae38f36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
