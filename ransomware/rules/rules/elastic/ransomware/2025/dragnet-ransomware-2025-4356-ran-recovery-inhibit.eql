// Dragnet [Ransomware]: dragnet-ransomware-2025-4356 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8038502b-9705-53d0-88ae-248295add1cb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
