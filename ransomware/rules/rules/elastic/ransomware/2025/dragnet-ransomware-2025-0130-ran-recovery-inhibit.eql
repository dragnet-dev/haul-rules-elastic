// Dragnet [Ransomware]: dragnet-ransomware-2025-0130 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: c8e64517-a114-5366-a3ed-9778c3423a73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
