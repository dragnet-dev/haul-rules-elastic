// Dragnet [Ransomware]: dragnet-ransomware-2025-5846 — Recovery Inhibition (gunra)
// Status: experimental | Level: high | ID: 731c1fe1-dcd5-558c-9e67-9c1fc241cfc9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
