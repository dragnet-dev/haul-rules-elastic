// Dragnet [Ransomware]: dragnet-ransomware-2025-1920 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0a9cb005-cd82-5744-8764-0dfe2c8c29b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
