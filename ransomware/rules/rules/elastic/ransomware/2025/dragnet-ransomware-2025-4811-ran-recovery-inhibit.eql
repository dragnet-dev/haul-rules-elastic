// Dragnet [Ransomware]: dragnet-ransomware-2025-4811 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: daf320e4-dd58-56b9-952a-e341256e668f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
