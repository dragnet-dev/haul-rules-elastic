// Dragnet [Ransomware]: dragnet-ransomware-2025-7845 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 45b3f909-6095-5112-b08e-9669398f25df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
