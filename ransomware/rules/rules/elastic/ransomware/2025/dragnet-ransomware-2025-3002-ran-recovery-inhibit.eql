// Dragnet [Ransomware]: dragnet-ransomware-2025-3002 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 04bc83b1-3f98-554a-8014-a18b5e975ff6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
