// Dragnet [Ransomware]: dragnet-ransomware-2025-3731 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 6482511d-c15a-5f2a-92d4-151f38c13c2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
