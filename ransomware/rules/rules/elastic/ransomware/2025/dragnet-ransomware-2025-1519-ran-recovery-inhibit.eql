// Dragnet [Ransomware]: dragnet-ransomware-2025-1519 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: ad23f410-2ebb-50df-9d66-c900435ed644

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
