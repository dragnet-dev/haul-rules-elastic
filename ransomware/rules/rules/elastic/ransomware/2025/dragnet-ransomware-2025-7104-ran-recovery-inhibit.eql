// Dragnet [Ransomware]: dragnet-ransomware-2025-7104 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: b4d91762-cd34-58a1-a101-ff0d7f9a3ca3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
