// Dragnet [Ransomware]: dragnet-ransomware-2025-5229 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 5ddf0a48-ab47-5331-b5f5-d6bdf6069fcd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
