// Dragnet [Ransomware]: dragnet-ransomware-2025-6155 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 6a17de2c-bf4c-5157-a865-640c61cd3d8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
