// Dragnet [Ransomware]: dragnet-ransomware-2025-0008 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: a5907349-797e-5c5e-aa08-9be0ccfb97a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
