// Dragnet [Ransomware]: dragnet-ransomware-2025-6604 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 3376ad16-fa65-5b4c-ac15-282ad42ab2fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
