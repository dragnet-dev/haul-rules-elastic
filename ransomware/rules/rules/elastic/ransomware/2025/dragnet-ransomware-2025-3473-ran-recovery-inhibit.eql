// Dragnet [Ransomware]: dragnet-ransomware-2025-3473 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 30718e57-0cea-5582-99a8-ce6e59ebcd73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
