// Dragnet [Ransomware]: dragnet-ransomware-2025-4555 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 907ea989-551e-5860-894e-9757d7ce4d67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
