// Dragnet [Ransomware]: dragnet-ransomware-2025-0960 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 8fed0f8c-0ec0-592b-8243-7b6ea1bab35d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
