// Dragnet [Ransomware]: dragnet-ransomware-2025-1584 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: dc5096b8-1293-5bb9-8ebf-42fe6f8f6224

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
