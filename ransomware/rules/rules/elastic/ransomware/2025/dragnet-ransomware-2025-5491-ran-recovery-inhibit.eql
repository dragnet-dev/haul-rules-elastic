// Dragnet [Ransomware]: dragnet-ransomware-2025-5491 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: c5c66e5e-4bd6-581f-a56e-0e89a52185d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
