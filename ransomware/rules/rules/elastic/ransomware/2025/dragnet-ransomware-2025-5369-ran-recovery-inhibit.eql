// Dragnet [Ransomware]: dragnet-ransomware-2025-5369 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 529aeb8c-4255-5511-a379-f57523387401

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
