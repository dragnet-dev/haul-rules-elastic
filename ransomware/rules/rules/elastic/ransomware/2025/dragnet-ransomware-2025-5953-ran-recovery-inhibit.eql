// Dragnet [Ransomware]: dragnet-ransomware-2025-5953 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: abea818b-ef71-561a-b109-0a6bff10743d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
