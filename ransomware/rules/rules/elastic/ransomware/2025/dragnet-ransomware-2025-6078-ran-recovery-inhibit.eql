// Dragnet [Ransomware]: dragnet-ransomware-2025-6078 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 647d8452-e797-5e03-b2b0-4bcc45b429e8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
