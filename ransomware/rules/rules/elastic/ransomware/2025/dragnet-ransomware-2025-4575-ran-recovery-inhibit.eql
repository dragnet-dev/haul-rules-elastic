// Dragnet [Ransomware]: dragnet-ransomware-2025-4575 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 73cfea89-e815-5923-9ef7-f2872445298d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
