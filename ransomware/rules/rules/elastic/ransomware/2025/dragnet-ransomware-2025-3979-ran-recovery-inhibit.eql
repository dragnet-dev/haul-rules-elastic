// Dragnet [Ransomware]: dragnet-ransomware-2025-3979 — Recovery Inhibition (VanHelsing)
// Status: experimental | Level: high | ID: 4f0df409-876e-5307-9cbe-96be308218e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
