// Dragnet [Ransomware]: dragnet-ransomware-2025-5009 — Recovery Inhibition (cephalus)
// Status: experimental | Level: high | ID: 3b2d411c-5a1e-52c1-b712-4872d7869df6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
