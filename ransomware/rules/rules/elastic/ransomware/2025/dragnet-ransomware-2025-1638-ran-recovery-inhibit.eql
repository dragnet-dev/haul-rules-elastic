// Dragnet [Ransomware]: dragnet-ransomware-2025-1638 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 5911217b-240c-5646-af64-0680489da63d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
