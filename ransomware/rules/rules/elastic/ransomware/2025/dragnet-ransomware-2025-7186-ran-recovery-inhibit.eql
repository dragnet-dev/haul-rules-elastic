// Dragnet [Ransomware]: dragnet-ransomware-2025-7186 — Recovery Inhibition (insomnia)
// Status: test | Level: high | ID: 742a875e-4a0c-590c-b067-8a7ea1a076e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
