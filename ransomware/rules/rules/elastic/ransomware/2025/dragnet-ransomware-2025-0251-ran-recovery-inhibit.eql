// Dragnet [Ransomware]: dragnet-ransomware-2025-0251 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: e13c8d20-741a-58a2-a131-e0158c39610e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
