// Dragnet [Ransomware]: dragnet-ransomware-2025-1312 — Recovery Inhibition (radar)
// Status: deprecated | Level: high | ID: a9836cc1-1aef-56e2-837b-69b0b38e5f32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
