// Dragnet [Ransomware]: dragnet-ransomware-2025-0460 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 386c885e-df1c-5a81-92ec-804457daa6d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
