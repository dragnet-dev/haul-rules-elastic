// Dragnet [Ransomware]: dragnet-ransomware-2025-6410 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 53fbf080-af54-5ad2-9dc4-505ae5389891

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
