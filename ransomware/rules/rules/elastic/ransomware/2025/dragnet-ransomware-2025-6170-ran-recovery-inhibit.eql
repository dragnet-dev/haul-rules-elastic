// Dragnet [Ransomware]: dragnet-ransomware-2025-6170 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7e84f8f0-d8bb-5e73-b534-a504334b349c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
