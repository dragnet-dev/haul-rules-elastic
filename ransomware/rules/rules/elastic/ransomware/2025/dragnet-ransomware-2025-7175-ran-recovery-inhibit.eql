// Dragnet [Ransomware]: dragnet-ransomware-2025-7175 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ffe7d880-da46-5d40-9e96-418ddf2e7716

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
