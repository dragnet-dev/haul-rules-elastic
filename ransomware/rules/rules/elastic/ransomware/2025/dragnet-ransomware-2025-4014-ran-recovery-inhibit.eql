// Dragnet [Ransomware]: dragnet-ransomware-2025-4014 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 03e0819a-6521-5471-81fc-648995b347d4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
