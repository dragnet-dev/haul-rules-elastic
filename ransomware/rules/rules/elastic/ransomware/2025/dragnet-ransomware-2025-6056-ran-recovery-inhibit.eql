// Dragnet [Ransomware]: dragnet-ransomware-2025-6056 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 673fa2c6-b55a-56fb-9446-30c9722b6100

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
