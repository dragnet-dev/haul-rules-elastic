// Dragnet [Ransomware]: dragnet-ransomware-2025-0287 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: eb8a2520-a0a0-5924-bff7-8e9f982eabe4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
