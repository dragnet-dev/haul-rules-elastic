// Dragnet [Ransomware]: dragnet-ransomware-2025-7374 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: adbfefff-6d99-593e-bf92-c0ffd0e12e70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
