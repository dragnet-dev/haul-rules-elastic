// Dragnet [Ransomware]: dragnet-ransomware-2025-1780 — Recovery Inhibition (bqtlock)
// Status: experimental | Level: high | ID: 5f5be3fb-724b-5f6d-afce-724f5415e8f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
