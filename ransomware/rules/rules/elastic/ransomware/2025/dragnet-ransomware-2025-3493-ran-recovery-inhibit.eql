// Dragnet [Ransomware]: dragnet-ransomware-2025-3493 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 3363b429-64c5-54f2-8b45-1f4a160fadf9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
