// Dragnet [Ransomware]: dragnet-ransomware-2025-7311 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: 073e1548-22c1-5387-9dab-d8070e5c13e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
