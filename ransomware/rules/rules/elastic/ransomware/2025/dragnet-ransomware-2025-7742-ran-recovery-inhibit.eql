// Dragnet [Ransomware]: dragnet-ransomware-2025-7742 — Recovery Inhibition (crazyhunter)
// Status: experimental | Level: high | ID: c7fec9df-4fa4-5ec0-a253-c2855675a82c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
