// Dragnet [Ransomware]: dragnet-ransomware-2025-7227 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 693a4b44-72d9-5b71-8c36-396ae7b9a665

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
