// Dragnet [Ransomware]: dragnet-ransomware-2025-4153 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9033b17b-252d-532c-b518-20cd516a66c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
