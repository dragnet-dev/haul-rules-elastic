// Dragnet [Ransomware]: dragnet-ransomware-2025-6517 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c5521f2c-8350-5023-8728-bec1534eed3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
