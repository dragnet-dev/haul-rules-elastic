// Dragnet [Ransomware]: dragnet-ransomware-2025-0612 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 7ac76abd-cbdb-5347-8bf0-c94722477706

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
