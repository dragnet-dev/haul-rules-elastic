// Dragnet [Ransomware]: dragnet-ransomware-2025-6777 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: bdcc1816-2515-5eee-8d15-f3139188af94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
