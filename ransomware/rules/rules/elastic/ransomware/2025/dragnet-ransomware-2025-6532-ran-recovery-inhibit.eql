// Dragnet [Ransomware]: dragnet-ransomware-2025-6532 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7c5c3311-3f55-539a-978c-43086d0fff01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
