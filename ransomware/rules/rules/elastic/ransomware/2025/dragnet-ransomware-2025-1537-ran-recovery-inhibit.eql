// Dragnet [Ransomware]: dragnet-ransomware-2025-1537 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 1accaee7-6be3-509b-8244-848cb5e5fdb3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
