// Dragnet [Ransomware]: dragnet-ransomware-2025-5727 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: c867dec8-e1d8-5918-b8e3-b6629d11f34b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
