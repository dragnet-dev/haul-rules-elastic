// Dragnet [Ransomware]: dragnet-ransomware-2025-3828 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d2f25eb9-7658-551e-bc02-126c4806ab7c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
