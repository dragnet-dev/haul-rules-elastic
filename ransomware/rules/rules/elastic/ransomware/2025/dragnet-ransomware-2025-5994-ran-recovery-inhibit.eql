// Dragnet [Ransomware]: dragnet-ransomware-2025-5994 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: e0302822-f5b1-515b-b3b0-cf201ffaeb52

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
