// Dragnet [Ransomware]: dragnet-ransomware-2025-4994 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: d1f4bd4d-acf4-58ce-a39c-ad5f3d8c6b3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
