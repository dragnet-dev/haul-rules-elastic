// Dragnet [Ransomware]: dragnet-ransomware-2025-3215 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: f42496f2-ade2-5f46-938c-49142f6fee55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
