// Dragnet [Ransomware]: dragnet-ransomware-2025-6372 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 26d4bdc1-b2c8-519a-b4e7-f244d4409522

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
