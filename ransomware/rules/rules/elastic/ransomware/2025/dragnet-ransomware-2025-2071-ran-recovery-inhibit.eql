// Dragnet [Ransomware]: dragnet-ransomware-2025-2071 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 09563384-5796-5e4c-8d6e-3d8c97f1f3ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
