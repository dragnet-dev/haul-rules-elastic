// Dragnet [Ransomware]: dragnet-ransomware-2025-2306 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 5bfbcd93-7d22-5696-8f29-7768cd39c0ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
