// Dragnet [Ransomware]: dragnet-ransomware-2025-4623 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 48823682-2ef6-5bf0-9ca5-ed365c25649f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
