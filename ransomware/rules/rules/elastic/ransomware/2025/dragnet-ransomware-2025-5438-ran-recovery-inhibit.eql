// Dragnet [Ransomware]: dragnet-ransomware-2025-5438 — Recovery Inhibition (tridentlocker)
// Status: experimental | Level: high | ID: 37fe1cd7-3d9e-5bc4-abe3-61a09075f55f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
