// Dragnet [Ransomware]: dragnet-ransomware-2025-0391 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 4cb90330-117c-590d-8036-2ddc83140484

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
