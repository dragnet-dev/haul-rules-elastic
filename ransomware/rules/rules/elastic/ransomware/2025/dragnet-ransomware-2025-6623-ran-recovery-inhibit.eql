// Dragnet [Ransomware]: dragnet-ransomware-2025-6623 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 52e6047d-5e2f-5b85-ae49-4f8a15cbe60b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
