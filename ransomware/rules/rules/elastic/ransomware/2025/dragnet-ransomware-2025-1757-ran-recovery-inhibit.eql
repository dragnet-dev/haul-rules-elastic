// Dragnet [Ransomware]: dragnet-ransomware-2025-1757 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 0db9bab6-771b-5dad-adaa-4c332c5b8cb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
