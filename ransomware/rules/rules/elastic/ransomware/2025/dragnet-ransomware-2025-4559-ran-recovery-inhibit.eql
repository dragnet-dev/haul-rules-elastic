// Dragnet [Ransomware]: dragnet-ransomware-2025-4559 — Recovery Inhibition (skira)
// Status: experimental | Level: high | ID: 7d055c27-9b0b-5bf7-b073-4746c4c24cd1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
