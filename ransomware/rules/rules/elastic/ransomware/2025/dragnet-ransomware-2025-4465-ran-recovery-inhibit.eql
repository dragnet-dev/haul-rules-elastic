// Dragnet [Ransomware]: dragnet-ransomware-2025-4465 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: fdf35158-bafe-52d8-8798-ce8057883c79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
