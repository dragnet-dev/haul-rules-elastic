// Dragnet [Ransomware]: dragnet-ransomware-2025-5915 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 9f4d7601-2122-5620-8dae-61b6a461ebde

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
