// Dragnet [Ransomware]: dragnet-ransomware-2025-2758 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 3fff1086-85ab-547a-ae38-7ba076d69c77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
