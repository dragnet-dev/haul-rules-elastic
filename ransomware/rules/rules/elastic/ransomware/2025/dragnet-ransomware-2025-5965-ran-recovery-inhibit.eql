// Dragnet [Ransomware]: dragnet-ransomware-2025-5965 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 70dafd24-1c4e-5792-b5fc-db2b29208be1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
