// Dragnet [Ransomware]: dragnet-ransomware-2025-7184 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 1516b00c-7658-577c-ae8d-0adf42b78737

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
