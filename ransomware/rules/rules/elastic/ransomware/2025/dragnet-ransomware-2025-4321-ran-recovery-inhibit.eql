// Dragnet [Ransomware]: dragnet-ransomware-2025-4321 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 56962e91-490a-5b7f-95ae-e73357da704f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
