// Dragnet [Ransomware]: dragnet-ransomware-2025-2501 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 510de531-5753-5ce9-8e6e-428cde6c79e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
