// Dragnet [Ransomware]: dragnet-ransomware-2025-5311 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: aa82f428-c15c-5b63-bfc5-bc04f1cd749d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
