// Dragnet [Ransomware]: dragnet-ransomware-2025-1872 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 248c2376-d535-50ef-bcdb-554910926efc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
