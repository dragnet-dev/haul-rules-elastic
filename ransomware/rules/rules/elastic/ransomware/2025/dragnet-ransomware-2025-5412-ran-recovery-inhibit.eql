// Dragnet [Ransomware]: dragnet-ransomware-2025-5412 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: fb392eb7-d261-5255-bbbc-08ba672de135

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
