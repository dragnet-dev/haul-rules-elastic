// Dragnet [Ransomware]: dragnet-ransomware-2025-2194 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 6c9d4187-50f4-5033-98c0-db9467028151

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
