// Dragnet [Ransomware]: dragnet-ransomware-2025-1466 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 83061211-dd83-5e8e-9732-682fe6dbc475

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
