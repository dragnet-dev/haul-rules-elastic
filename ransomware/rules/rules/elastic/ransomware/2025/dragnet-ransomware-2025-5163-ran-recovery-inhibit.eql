// Dragnet [Ransomware]: dragnet-ransomware-2025-5163 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 789c6cd3-2367-5613-a396-d64fd2816f61

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
