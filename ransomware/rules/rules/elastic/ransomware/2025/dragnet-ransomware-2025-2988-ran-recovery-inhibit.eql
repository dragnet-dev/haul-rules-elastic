// Dragnet [Ransomware]: dragnet-ransomware-2025-2988 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1064134e-3ea0-5fd7-8519-1d71227f73c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
