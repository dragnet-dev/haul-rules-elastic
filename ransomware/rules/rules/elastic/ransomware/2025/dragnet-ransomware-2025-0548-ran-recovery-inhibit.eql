// Dragnet [Ransomware]: dragnet-ransomware-2025-0548 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: aed8c4bd-73fc-5959-abaf-137e5102688f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
