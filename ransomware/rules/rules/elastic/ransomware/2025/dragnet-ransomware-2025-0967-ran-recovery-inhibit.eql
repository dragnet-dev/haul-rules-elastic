// Dragnet [Ransomware]: dragnet-ransomware-2025-0967 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 0369ff6b-2b02-5536-aa76-37a3a7a4445b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
