// Dragnet [Ransomware]: dragnet-ransomware-2025-1282 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 80e3965f-cd56-5042-853e-238f1ba79b8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
