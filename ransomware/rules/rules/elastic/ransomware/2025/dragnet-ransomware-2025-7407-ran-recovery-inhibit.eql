// Dragnet [Ransomware]: dragnet-ransomware-2025-7407 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 47552bd4-bc58-5f7a-ab03-7ea075aba477

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
