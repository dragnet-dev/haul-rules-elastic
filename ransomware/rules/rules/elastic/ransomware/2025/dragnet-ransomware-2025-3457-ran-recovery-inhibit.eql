// Dragnet [Ransomware]: dragnet-ransomware-2025-3457 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1d1db5e9-f459-54f2-85ee-a7996dcb4829

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
