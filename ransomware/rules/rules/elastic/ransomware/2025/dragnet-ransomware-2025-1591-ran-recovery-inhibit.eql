// Dragnet [Ransomware]: dragnet-ransomware-2025-1591 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8f90f5b8-28a0-5906-8c83-0d0d5a0faaf1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
