// Dragnet [Ransomware]: dragnet-ransomware-2025-1808 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: ce209ad3-1dc3-5c03-a2b1-396a87a96cbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
