// Dragnet [Ransomware]: dragnet-ransomware-2025-5944 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: 37289260-167c-5693-b116-be531e1581b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
