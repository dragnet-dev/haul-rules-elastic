// Dragnet [Ransomware]: dragnet-ransomware-2025-0881 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 11e58d53-cb92-5e53-871c-76bdd701834f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
