// Dragnet [Ransomware]: dragnet-ransomware-2025-0672 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 80b2ca47-1c82-5997-8c7b-b69e0fceebb1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
