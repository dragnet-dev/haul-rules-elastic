// Dragnet [Ransomware]: dragnet-ransomware-2025-2593 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: f86ac592-79c1-5fda-8d45-b3f405193abc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
