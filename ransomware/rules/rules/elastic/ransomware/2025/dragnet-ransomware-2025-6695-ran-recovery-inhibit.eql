// Dragnet [Ransomware]: dragnet-ransomware-2025-6695 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 40387471-2e1b-5f91-a9e6-3020388a876b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
