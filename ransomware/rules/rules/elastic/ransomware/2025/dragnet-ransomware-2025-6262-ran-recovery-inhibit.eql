// Dragnet [Ransomware]: dragnet-ransomware-2025-6262 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1e27c05a-3839-5698-b061-c9ab5773b9f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
