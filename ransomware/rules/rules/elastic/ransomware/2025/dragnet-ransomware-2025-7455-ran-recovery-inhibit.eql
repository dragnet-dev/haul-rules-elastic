// Dragnet [Ransomware]: dragnet-ransomware-2025-7455 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 4f0b9633-76fd-5cbb-8463-423e423804a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
