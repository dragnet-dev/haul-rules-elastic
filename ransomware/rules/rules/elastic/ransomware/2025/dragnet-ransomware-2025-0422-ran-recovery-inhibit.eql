// Dragnet [Ransomware]: dragnet-ransomware-2025-0422 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: afa1ce3d-3fd8-51f1-82c2-802f44b83f9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
