// Dragnet [Ransomware]: dragnet-ransomware-2025-6558 — Recovery Inhibition (interlock)
// Status: test | Level: high | ID: 2ee8c504-80be-54d7-9871-10a194698496

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
