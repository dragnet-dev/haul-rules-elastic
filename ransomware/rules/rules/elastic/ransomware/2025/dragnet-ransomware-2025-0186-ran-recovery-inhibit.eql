// Dragnet [Ransomware]: dragnet-ransomware-2025-0186 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: 3b80ae94-174e-5857-8d1d-161af07e510e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
