// Dragnet [Ransomware]: dragnet-ransomware-2025-6824 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: ff0f454e-54bd-51f2-9526-5ed925179e35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
