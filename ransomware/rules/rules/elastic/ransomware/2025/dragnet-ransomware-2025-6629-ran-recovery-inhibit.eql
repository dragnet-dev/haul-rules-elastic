// Dragnet [Ransomware]: dragnet-ransomware-2025-6629 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: de18fb92-dd3b-540e-bb8f-49e9c31eb333

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
