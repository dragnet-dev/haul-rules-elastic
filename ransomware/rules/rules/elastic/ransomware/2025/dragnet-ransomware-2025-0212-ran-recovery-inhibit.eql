// Dragnet [Ransomware]: dragnet-ransomware-2025-0212 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 654645d3-a840-5b16-aa97-6974591a2be0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
