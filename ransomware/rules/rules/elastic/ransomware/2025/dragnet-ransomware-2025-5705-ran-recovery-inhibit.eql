// Dragnet [Ransomware]: dragnet-ransomware-2025-5705 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 78f932a3-b000-5b20-adf7-c59d0cbe6adc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
