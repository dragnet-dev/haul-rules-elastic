// Dragnet [Ransomware]: dragnet-ransomware-2025-6461 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: dc1962c3-4545-560f-829b-706b237a1c10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
