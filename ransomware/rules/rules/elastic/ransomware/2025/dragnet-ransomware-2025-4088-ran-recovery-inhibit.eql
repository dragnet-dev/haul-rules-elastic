// Dragnet [Ransomware]: dragnet-ransomware-2025-4088 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 26ce4ec0-c6bd-57fe-ba46-d37ed56e01b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
