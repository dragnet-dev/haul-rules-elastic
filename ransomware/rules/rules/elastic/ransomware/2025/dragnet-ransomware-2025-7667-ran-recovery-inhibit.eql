// Dragnet [Ransomware]: dragnet-ransomware-2025-7667 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: 1515786a-d3af-59c2-9527-3de676f81111

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
