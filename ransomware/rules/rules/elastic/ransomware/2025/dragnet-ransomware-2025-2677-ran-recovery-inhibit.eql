// Dragnet [Ransomware]: dragnet-ransomware-2025-2677 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: d864f30d-1dfa-5e09-abf8-7cdc8ff145a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
