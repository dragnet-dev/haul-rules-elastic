// Dragnet [Ransomware]: dragnet-ransomware-2025-6546 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 6dd2fcf6-1390-51ee-9864-8f8c2d092f31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
