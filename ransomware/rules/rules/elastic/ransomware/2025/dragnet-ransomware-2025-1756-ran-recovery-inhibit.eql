// Dragnet [Ransomware]: dragnet-ransomware-2025-1756 — Recovery Inhibition (d4rk4rmy)
// Status: deprecated | Level: high | ID: 19304cd1-de61-5e89-a895-d651c226a303

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
