// Dragnet [Ransomware]: dragnet-ransomware-2025-0262 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: acc28129-df40-5356-afae-0e25d3f54c0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
