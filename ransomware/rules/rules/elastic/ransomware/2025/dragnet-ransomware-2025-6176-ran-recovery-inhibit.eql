// Dragnet [Ransomware]: dragnet-ransomware-2025-6176 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0267a645-5aee-59cf-bb87-a87020ef5dbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
