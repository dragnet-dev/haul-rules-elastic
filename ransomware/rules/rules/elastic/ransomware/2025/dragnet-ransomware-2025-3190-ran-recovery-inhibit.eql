// Dragnet [Ransomware]: dragnet-ransomware-2025-3190 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e89f07c1-e94b-500a-8216-19e3b0c3a5ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
