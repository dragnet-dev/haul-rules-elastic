// Dragnet [Ransomware]: dragnet-ransomware-2025-6441 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0c07a955-7320-5756-bb27-79c4b3fff3f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
