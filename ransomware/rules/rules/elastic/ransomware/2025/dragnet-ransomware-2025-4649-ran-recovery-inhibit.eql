// Dragnet [Ransomware]: dragnet-ransomware-2025-4649 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 0980d742-047b-506f-86ab-a371675ce55c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
