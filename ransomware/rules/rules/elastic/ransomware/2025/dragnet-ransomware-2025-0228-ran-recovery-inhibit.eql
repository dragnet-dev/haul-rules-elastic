// Dragnet [Ransomware]: dragnet-ransomware-2025-0228 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 91e48ea7-adc3-5e24-b285-7e9291a91feb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
