// Dragnet [Ransomware]: dragnet-ransomware-2025-0032 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 1439fb34-0567-520d-aaa0-1114f1566032

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
