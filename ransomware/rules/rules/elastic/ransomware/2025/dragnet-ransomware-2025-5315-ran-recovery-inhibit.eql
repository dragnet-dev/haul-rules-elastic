// Dragnet [Ransomware]: dragnet-ransomware-2025-5315 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 9af38425-6516-5453-a18d-bdcdeb4062e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
