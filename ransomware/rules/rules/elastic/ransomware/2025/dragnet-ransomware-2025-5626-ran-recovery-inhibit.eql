// Dragnet [Ransomware]: dragnet-ransomware-2025-5626 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 821bfb99-1c6d-5d63-b575-8fac7b716599

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
