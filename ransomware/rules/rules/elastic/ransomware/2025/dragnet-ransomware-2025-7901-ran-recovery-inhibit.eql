// Dragnet [Ransomware]: dragnet-ransomware-2025-7901 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: d2d0147a-13d5-5a14-994c-1806e8823761

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
