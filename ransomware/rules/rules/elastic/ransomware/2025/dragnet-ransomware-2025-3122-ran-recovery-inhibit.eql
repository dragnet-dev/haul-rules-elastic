// Dragnet [Ransomware]: dragnet-ransomware-2025-3122 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: a5cb96d3-3d02-5738-95e1-8e49858c539b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
