// Dragnet [Ransomware]: dragnet-ransomware-2025-7388 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 262859f1-f236-5593-a3f2-f0796879ce76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
