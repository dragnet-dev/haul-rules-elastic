// Dragnet [Ransomware]: dragnet-ransomware-2025-1067 — Recovery Inhibition (blackbyte)
// Status: deprecated | Level: high | ID: cbdd7f3c-470d-518b-810d-f08f7a74a7b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
