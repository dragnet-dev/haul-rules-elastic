// Dragnet [Ransomware]: dragnet-ransomware-2025-3204 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4f10b52d-9076-5dd6-89a9-c1b6b066babf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
