// Dragnet [Ransomware]: dragnet-ransomware-2025-5860 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: ac3c6ad8-dd99-5b7e-9094-7c7ab99c9bac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
