// Dragnet [Ransomware]: dragnet-ransomware-2025-4745 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 801b0abd-73bd-5c2d-b19d-f54903d16e82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
