// Dragnet [Ransomware]: dragnet-ransomware-2025-1772 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 12766b18-b493-55ae-a484-59250608389d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
