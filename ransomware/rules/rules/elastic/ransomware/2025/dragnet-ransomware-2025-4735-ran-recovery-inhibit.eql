// Dragnet [Ransomware]: dragnet-ransomware-2025-4735 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 08193915-134b-5fff-af45-21c86816baca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
