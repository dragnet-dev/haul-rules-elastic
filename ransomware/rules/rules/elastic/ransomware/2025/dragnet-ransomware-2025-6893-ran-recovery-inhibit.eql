// Dragnet [Ransomware]: dragnet-ransomware-2025-6893 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 42a3b57c-4be6-5d51-87b9-45c2decb41e0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
