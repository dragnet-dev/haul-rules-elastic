// Dragnet [Ransomware]: dragnet-ransomware-2025-4630 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1ff8e267-45c2-5e2e-b219-e2e6abcad63e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
