// Dragnet [Ransomware]: dragnet-ransomware-2025-0860 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a1c165be-3b38-5cfc-b30a-9a51fcf58a50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
