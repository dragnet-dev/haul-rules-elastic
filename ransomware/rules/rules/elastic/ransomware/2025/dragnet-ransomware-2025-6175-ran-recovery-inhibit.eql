// Dragnet [Ransomware]: dragnet-ransomware-2025-6175 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 20a1e2f9-dd19-5f7c-b127-0ffbb7efaad0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
