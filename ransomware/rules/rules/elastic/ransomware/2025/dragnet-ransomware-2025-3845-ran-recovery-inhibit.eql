// Dragnet [Ransomware]: dragnet-ransomware-2025-3845 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4b45cfd8-23cd-541e-8753-ccd0489d595b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
