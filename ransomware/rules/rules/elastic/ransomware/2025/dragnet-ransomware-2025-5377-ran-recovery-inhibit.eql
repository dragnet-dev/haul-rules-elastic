// Dragnet [Ransomware]: dragnet-ransomware-2025-5377 — Recovery Inhibition (trinity)
// Status: experimental | Level: high | ID: fd408c51-014d-52fa-974d-9fb469f9d1d9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
