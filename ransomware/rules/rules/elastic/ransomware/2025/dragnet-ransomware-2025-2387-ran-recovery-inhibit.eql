// Dragnet [Ransomware]: dragnet-ransomware-2025-2387 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 18bee8f2-b255-510d-838b-130f6980521e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
