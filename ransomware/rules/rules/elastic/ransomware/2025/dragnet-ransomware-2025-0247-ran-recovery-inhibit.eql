// Dragnet [Ransomware]: dragnet-ransomware-2025-0247 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: e0bdb46e-524a-5c23-87bb-788ef63b5b91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
