// Dragnet [Ransomware]: dragnet-ransomware-2025-6008 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 911ac3bd-3688-5dca-9fe3-350a5904b9f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
