// Dragnet [Ransomware]: dragnet-ransomware-2025-4133 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 9efc090e-8d18-5dae-902c-57b77e15c4c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
