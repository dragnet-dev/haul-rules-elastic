// Dragnet [Ransomware]: dragnet-ransomware-2025-5986 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: f5cc296f-883e-533f-8ce5-8f0ed8d24df3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
