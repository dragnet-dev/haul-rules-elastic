// Dragnet [Ransomware]: dragnet-ransomware-2025-1367 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: c73a1bec-ec71-5632-9388-a37dd8744912

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
