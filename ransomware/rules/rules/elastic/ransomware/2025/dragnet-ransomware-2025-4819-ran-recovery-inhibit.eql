// Dragnet [Ransomware]: dragnet-ransomware-2025-4819 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: d0a7ba53-96bd-5752-9c05-bc0d5b127744

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
