// Dragnet [Ransomware]: dragnet-ransomware-2025-7433 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 647f2830-875c-5c2d-9c79-3913ac69f063

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
