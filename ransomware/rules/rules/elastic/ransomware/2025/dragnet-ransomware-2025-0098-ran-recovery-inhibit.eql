// Dragnet [Ransomware]: dragnet-ransomware-2025-0098 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ad77c132-b4a6-5072-987f-ac6fcabd6a78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
