// Dragnet [Ransomware]: dragnet-ransomware-2025-4524 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 502a5df8-6b93-5f37-a551-6e88095a29b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
