// Dragnet [Ransomware]: dragnet-ransomware-2025-1360 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: a877816e-6c41-538f-8c8a-b8c86a8984b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
