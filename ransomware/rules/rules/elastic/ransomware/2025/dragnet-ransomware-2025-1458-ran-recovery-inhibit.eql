// Dragnet [Ransomware]: dragnet-ransomware-2025-1458 — Recovery Inhibition (kryptos)
// Status: deprecated | Level: high | ID: ad1c5f06-ef0b-59f0-8287-2a58c37cfba7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
