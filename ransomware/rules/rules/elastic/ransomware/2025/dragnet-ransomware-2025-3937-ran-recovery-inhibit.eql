// Dragnet [Ransomware]: dragnet-ransomware-2025-3937 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 6d176860-bf1b-5012-a8ed-c2656146c050

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
