// Dragnet [Ransomware]: dragnet-ransomware-2025-2321 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 366c2562-c300-536c-924b-fed43dab4c1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
