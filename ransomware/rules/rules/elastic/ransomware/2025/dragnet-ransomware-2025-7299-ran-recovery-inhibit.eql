// Dragnet [Ransomware]: dragnet-ransomware-2025-7299 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 822806c9-58ad-551c-8854-6ae3da1a9105

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
