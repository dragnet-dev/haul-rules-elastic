// Dragnet [Ransomware]: dragnet-ransomware-2025-6694 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0330abb6-a0a6-5830-af23-5e029e93e17d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
