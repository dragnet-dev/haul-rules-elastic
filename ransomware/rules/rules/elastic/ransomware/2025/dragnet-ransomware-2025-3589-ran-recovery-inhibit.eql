// Dragnet [Ransomware]: dragnet-ransomware-2025-3589 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 752e0986-e14c-51f2-a52c-37204cf7d8a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
