// Dragnet [Ransomware]: dragnet-ransomware-2025-0792 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: 49c0a9b6-6b9b-57d9-b2ae-f3de631754f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
