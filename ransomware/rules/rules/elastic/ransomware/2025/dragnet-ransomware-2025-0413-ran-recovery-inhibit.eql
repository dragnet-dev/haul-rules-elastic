// Dragnet [Ransomware]: dragnet-ransomware-2025-0413 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 00a3d884-f100-5e23-a3e4-e87567dfd71b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
