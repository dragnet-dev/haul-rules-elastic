// Dragnet [Ransomware]: dragnet-ransomware-2025-4008 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: c5f80da2-82c5-5723-8668-b1ff5e75c4c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
