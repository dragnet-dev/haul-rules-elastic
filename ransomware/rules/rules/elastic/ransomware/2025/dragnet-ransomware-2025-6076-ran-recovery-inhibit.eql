// Dragnet [Ransomware]: dragnet-ransomware-2025-6076 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 2e27241b-1780-585a-a022-9826eafb39f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
