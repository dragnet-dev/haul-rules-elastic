// Dragnet [Ransomware]: dragnet-ransomware-2025-7563 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: b75203dd-b7a2-5ab2-acbd-4535a51995b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
