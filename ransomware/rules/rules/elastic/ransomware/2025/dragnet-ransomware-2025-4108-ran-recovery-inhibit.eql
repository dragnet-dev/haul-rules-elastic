// Dragnet [Ransomware]: dragnet-ransomware-2025-4108 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 39b82ade-49be-5108-80d6-ea84134a133c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
