// Dragnet [Ransomware]: dragnet-ransomware-2025-5677 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 2002e230-c058-5545-91d0-04df06e70239

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
