// Dragnet [Ransomware]: dragnet-ransomware-2025-0494 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2cecc8d8-65a0-5e0c-8228-9ec273b84df3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
