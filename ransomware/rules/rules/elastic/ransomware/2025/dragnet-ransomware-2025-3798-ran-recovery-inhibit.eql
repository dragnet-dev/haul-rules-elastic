// Dragnet [Ransomware]: dragnet-ransomware-2025-3798 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 67543100-cb2a-54a1-9ed9-7132b47643f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
