// Dragnet [Ransomware]: dragnet-ransomware-2025-4496 — Recovery Inhibition (anubis)
// Status: experimental | Level: high | ID: a63f5c9e-e64e-578b-83f1-dd8772f04d26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
