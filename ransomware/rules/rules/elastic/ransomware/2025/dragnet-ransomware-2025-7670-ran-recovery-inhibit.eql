// Dragnet [Ransomware]: dragnet-ransomware-2025-7670 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 2ef4fdd3-8537-596c-897c-e56a20b735cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
