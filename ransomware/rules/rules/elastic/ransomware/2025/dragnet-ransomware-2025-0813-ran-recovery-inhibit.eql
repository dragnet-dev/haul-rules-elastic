// Dragnet [Ransomware]: dragnet-ransomware-2025-0813 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: d1f6f3ac-f906-5e05-9700-07cc36ddc710

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
