// Dragnet [Ransomware]: dragnet-ransomware-2025-0555 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 4a1e7db8-bb89-5ebe-80ac-69a946bc5780

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
