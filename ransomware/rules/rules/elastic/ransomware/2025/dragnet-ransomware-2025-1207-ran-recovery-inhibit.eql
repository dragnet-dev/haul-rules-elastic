// Dragnet [Ransomware]: dragnet-ransomware-2025-1207 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7406edb1-3221-5dcf-8c82-38b768221f06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
