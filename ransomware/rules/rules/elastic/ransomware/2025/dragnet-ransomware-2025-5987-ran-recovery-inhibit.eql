// Dragnet [Ransomware]: dragnet-ransomware-2025-5987 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9238cf34-8066-57af-8f17-eff2084b9bd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
