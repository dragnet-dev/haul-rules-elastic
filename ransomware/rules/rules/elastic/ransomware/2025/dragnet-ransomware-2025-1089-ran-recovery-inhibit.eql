// Dragnet [Ransomware]: dragnet-ransomware-2025-1089 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 289349e4-d6f4-582a-a076-a5eb893077e7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
