// Dragnet [Ransomware]: dragnet-ransomware-2025-3358 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 1ab366ba-bf7e-599d-be96-b516f1741bdf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
