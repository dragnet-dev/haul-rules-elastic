// Dragnet [Ransomware]: dragnet-ransomware-2025-5757 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 1c4869de-8cdf-5eca-81b5-ecd235e481bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
