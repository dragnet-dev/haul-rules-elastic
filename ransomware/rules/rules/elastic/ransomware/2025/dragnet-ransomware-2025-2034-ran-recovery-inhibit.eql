// Dragnet [Ransomware]: dragnet-ransomware-2025-2034 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 30cbe2b8-588e-5494-9fa4-67c62b6dd9fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
