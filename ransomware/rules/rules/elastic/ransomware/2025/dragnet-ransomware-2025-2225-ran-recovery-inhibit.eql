// Dragnet [Ransomware]: dragnet-ransomware-2025-2225 — Recovery Inhibition (weyhro)
// Status: experimental | Level: high | ID: 235ee0c8-24b0-5223-b628-0168e32b87be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
