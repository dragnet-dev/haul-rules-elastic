// Dragnet [Ransomware]: dragnet-ransomware-2025-6510 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 384ccd9a-c787-598b-b8e4-e473447900e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
