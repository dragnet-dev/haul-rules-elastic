// Dragnet [Ransomware]: dragnet-ransomware-2025-6274 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c76752ee-2574-5f31-8564-e51aeda42417

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
