// Dragnet [Ransomware]: dragnet-ransomware-2025-6678 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 3b40aff9-74ab-5352-be86-962848312408

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
