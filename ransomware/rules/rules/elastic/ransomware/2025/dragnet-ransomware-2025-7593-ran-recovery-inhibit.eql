// Dragnet [Ransomware]: dragnet-ransomware-2025-7593 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: d854424a-23f3-5229-b0a9-8a94ea155e8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
