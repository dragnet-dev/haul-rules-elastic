// Dragnet [Ransomware]: dragnet-ransomware-2025-4825 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 911a26d3-c4fd-5880-be82-93db8f82b1ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
