// Dragnet [Ransomware]: dragnet-ransomware-2025-1764 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: b6505f49-3278-5003-a1bc-b7cd70d8326b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
