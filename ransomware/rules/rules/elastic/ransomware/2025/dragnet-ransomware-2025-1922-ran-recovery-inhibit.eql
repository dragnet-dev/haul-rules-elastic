// Dragnet [Ransomware]: dragnet-ransomware-2025-1922 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 1a47580f-61f8-50ee-8af2-ad783a0417eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
