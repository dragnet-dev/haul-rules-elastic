// Dragnet [Ransomware]: dragnet-ransomware-2025-5509 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: d98b2a89-cfbb-5275-9b72-be9c39907de9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
