// Dragnet [Ransomware]: dragnet-ransomware-2025-1057 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: e7e2b281-8ac5-5220-8efd-49ec22c856f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
