// Dragnet [Ransomware]: dragnet-ransomware-2025-1821 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: c768a335-1498-5086-8c3e-88e871e4ddb3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
