// Dragnet [Ransomware]: dragnet-ransomware-2025-7243 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: b89b8e59-468b-582f-903b-88728b1eacfb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
