// Dragnet [Ransomware]: dragnet-ransomware-2025-7192 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 7eab937b-6b0b-5012-aa15-dd5c0f1a2043

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
