// Dragnet [Ransomware]: dragnet-ransomware-2025-2898 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: 46093bdd-b0ac-521d-9a71-6cd671f83241

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
