// Dragnet [Ransomware]: dragnet-ransomware-2025-1125 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 746ddcff-a415-53d9-b345-2b497477269f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
