// Dragnet [Ransomware]: dragnet-ransomware-2025-3783 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: 2ea0ef1c-4aa7-5f5b-be9e-5fc73a144457

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
