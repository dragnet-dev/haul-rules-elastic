// Dragnet [Ransomware]: dragnet-ransomware-2025-0059 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: b92239dc-b02c-590f-af27-1f113f2eb183

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
