// Dragnet [Ransomware]: dragnet-ransomware-2025-4661 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: ecc8dea4-d6b1-5317-a35e-013533441be2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
