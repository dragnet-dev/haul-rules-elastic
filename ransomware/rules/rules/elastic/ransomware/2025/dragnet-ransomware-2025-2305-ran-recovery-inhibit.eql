// Dragnet [Ransomware]: dragnet-ransomware-2025-2305 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 20b98d1e-f03a-5ffb-8766-16777bc6f841

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
