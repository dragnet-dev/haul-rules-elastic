// Dragnet [Ransomware]: dragnet-ransomware-2025-0230 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 44fc078c-03e6-5d9e-bfa8-77c37ab31ad0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
