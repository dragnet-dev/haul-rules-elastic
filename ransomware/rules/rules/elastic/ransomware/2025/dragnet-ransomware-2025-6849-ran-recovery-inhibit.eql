// Dragnet [Ransomware]: dragnet-ransomware-2025-6849 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: f7fdd92a-e51c-52d3-b78b-77dd8f11994a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
