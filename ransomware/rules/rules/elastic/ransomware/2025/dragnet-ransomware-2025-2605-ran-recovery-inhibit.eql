// Dragnet [Ransomware]: dragnet-ransomware-2025-2605 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: d16faca9-6649-5f23-a092-da5a89f0978e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
