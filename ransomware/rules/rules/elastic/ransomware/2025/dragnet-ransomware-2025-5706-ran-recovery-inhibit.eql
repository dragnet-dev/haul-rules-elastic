// Dragnet [Ransomware]: dragnet-ransomware-2025-5706 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 897cee78-97e8-5be0-95f0-276ed1ca475e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
