// Dragnet [Ransomware]: dragnet-ransomware-2025-1860 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: f16712fb-d653-5bad-808b-094aff19edc5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
