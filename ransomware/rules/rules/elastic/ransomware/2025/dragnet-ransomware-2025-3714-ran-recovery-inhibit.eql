// Dragnet [Ransomware]: dragnet-ransomware-2025-3714 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 931a55a4-ee76-511b-9411-67d414f2c15d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
