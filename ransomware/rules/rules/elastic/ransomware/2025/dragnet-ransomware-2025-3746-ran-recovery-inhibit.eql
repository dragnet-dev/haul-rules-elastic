// Dragnet [Ransomware]: dragnet-ransomware-2025-3746 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9abf578e-7403-5937-9359-d877ee89549a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
