// Dragnet [Ransomware]: dragnet-ransomware-2025-5399 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f39f8f62-f0ec-51ab-8a39-d7e57499e8e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
