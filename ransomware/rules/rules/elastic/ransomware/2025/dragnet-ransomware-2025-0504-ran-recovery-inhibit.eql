// Dragnet [Ransomware]: dragnet-ransomware-2025-0504 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 6431775f-61e8-51ac-905e-51c8a3c62892

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
