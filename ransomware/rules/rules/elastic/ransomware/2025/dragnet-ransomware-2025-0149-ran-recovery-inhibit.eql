// Dragnet [Ransomware]: dragnet-ransomware-2025-0149 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: 9237cedf-a58f-53fc-af60-8ee5a4640069

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
