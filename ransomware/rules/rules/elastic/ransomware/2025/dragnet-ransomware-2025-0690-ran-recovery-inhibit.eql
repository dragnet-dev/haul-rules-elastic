// Dragnet [Ransomware]: dragnet-ransomware-2025-0690 — Recovery Inhibition (weyhro)
// Status: experimental | Level: high | ID: 4ff82638-ef31-5742-9962-c392119e80dc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
