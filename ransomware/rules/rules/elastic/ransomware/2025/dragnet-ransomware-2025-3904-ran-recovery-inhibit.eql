// Dragnet [Ransomware]: dragnet-ransomware-2025-3904 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: ff6ebef6-79b4-5478-b0c6-72127644f6da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
