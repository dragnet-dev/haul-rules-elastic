// Dragnet [Ransomware]: dragnet-ransomware-2025-0303 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 75126940-e35e-5f07-8e2c-aa8298f4d831

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
