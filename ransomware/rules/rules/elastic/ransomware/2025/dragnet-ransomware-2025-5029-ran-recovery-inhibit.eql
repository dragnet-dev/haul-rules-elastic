// Dragnet [Ransomware]: dragnet-ransomware-2025-5029 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 36278a1b-14db-5814-a845-564ec1bd8b30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
