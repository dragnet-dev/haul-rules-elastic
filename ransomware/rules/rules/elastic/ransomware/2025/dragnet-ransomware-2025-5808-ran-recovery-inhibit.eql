// Dragnet [Ransomware]: dragnet-ransomware-2025-5808 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 288a1c40-bc93-5453-b5e2-957cf4cdcac6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
