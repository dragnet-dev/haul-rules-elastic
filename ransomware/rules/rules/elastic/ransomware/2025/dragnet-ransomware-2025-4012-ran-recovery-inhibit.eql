// Dragnet [Ransomware]: dragnet-ransomware-2025-4012 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: d239805f-f534-50c6-b438-aa6e8a154d56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
