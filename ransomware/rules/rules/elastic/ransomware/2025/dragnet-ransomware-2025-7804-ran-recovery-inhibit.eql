// Dragnet [Ransomware]: dragnet-ransomware-2025-7804 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b7a539dc-850e-58e8-9eab-58dd24926369

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
