// Dragnet [Ransomware]: dragnet-ransomware-2025-2845 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 4ef0288d-e463-5591-8749-aea9ce98cce4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
