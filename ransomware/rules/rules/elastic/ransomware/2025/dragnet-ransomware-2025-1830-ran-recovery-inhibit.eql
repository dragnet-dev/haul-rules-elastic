// Dragnet [Ransomware]: dragnet-ransomware-2025-1830 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 08972768-49b0-5301-8935-2f35beb33d77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
