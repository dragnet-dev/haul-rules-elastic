// Dragnet [Ransomware]: dragnet-ransomware-2025-6109 — Recovery Inhibition (tridentlocker)
// Status: experimental | Level: high | ID: 3bcd38d4-9d51-5e42-960d-efaaa71dfecd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
