// Dragnet [Ransomware]: dragnet-ransomware-2025-4741 — Recovery Inhibition (radiant)
// Status: deprecated | Level: high | ID: 1573e99c-89a5-59d7-85dd-f466b99cf8d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
