// Dragnet [Ransomware]: dragnet-ransomware-2025-0131 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d69f497c-1a03-59b6-b390-ad5e16bfe433

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
