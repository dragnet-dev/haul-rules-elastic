// Dragnet [Ransomware]: dragnet-ransomware-2025-2335 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: ffd3a037-cd67-5a9f-9125-bd9763cc5e8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
