// Dragnet [Ransomware]: dragnet-ransomware-2025-3137 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 939b2133-688e-53f1-bd76-c9a156444977

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
