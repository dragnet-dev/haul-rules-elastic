// Dragnet [Ransomware]: dragnet-ransomware-2025-2946 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 23baecbf-ecf0-51ce-b5fe-212eaba83fc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
