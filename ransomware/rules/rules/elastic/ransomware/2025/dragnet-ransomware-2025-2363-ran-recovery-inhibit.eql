// Dragnet [Ransomware]: dragnet-ransomware-2025-2363 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: 35a4feb0-c5e8-5d52-ba26-d1e5da1e4e2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
