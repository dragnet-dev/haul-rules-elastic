// Dragnet [Ransomware]: dragnet-ransomware-2025-7097 — Recovery Inhibition (handala)
// Status: test | Level: high | ID: 6b8a5d13-0234-51db-8de0-d775c4ba8e05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
