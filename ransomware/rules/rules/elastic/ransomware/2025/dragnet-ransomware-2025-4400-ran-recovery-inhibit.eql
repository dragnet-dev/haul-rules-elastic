// Dragnet [Ransomware]: dragnet-ransomware-2025-4400 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 222fbffd-4ae0-53ef-bd82-637c7993bfca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
