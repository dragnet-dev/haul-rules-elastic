// Dragnet [Ransomware]: dragnet-ransomware-2025-5947 — Recovery Inhibition (bert)
// Status: experimental | Level: high | ID: df33fd6f-0901-5bb0-8aa0-66eb8543e24e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
