// Dragnet [Ransomware]: dragnet-ransomware-2025-5274 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: bff73b7a-7939-5681-9177-b197b0416d11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
