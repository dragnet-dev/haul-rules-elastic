// Dragnet [Ransomware]: dragnet-ransomware-2025-0988 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: e82adb48-14f0-5957-85ac-6d55f0c317a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
