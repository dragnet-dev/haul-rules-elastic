// Dragnet [Ransomware]: dragnet-ransomware-2025-5340 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 3ca21e8a-ba04-5ef0-a882-781c5b3b9f29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
