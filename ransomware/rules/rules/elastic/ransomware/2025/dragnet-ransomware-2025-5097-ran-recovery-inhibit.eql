// Dragnet [Ransomware]: dragnet-ransomware-2025-5097 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b8441fe7-d474-57cf-9e8f-67c2797bd788

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
