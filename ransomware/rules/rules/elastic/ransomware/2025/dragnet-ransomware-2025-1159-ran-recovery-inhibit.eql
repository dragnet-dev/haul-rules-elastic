// Dragnet [Ransomware]: dragnet-ransomware-2025-1159 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 86dc6adf-8b83-5d84-9a82-81daebbb5849

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
