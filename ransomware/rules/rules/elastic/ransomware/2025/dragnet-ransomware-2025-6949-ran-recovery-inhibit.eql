// Dragnet [Ransomware]: dragnet-ransomware-2025-6949 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: bc7eb82a-a56a-5459-a5fc-709f496e4d2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
