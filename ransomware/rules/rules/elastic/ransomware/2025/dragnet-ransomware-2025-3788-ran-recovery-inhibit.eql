// Dragnet [Ransomware]: dragnet-ransomware-2025-3788 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 14a33066-87ab-5322-84d2-282c652fb558

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
