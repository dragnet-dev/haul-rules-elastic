// Dragnet [Ransomware]: dragnet-ransomware-2025-6447 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 8146cd66-02ad-5d6f-bf1c-61fac17ae44d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
