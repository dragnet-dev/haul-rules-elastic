// Dragnet [Ransomware]: dragnet-ransomware-2025-2809 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 06386e12-8f3d-5381-ab0f-41b8bdde8a07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
