// Dragnet [Ransomware]: dragnet-ransomware-2025-7705 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 080c5726-7cab-54de-b6bb-e08a30f3e648

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
