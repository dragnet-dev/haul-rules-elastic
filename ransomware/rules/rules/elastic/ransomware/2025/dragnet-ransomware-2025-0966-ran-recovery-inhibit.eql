// Dragnet [Ransomware]: dragnet-ransomware-2025-0966 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f4351628-b00e-59fe-b113-c765a264800f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
