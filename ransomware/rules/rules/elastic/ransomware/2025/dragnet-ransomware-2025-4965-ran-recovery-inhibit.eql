// Dragnet [Ransomware]: dragnet-ransomware-2025-4965 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: a9650825-cfe2-5807-8a69-3213cb97a031

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
