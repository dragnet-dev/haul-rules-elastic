// Dragnet [Ransomware]: dragnet-ransomware-2025-2829 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: d0fd6555-2681-5170-b3be-0ea35390cd0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
