// Dragnet [Ransomware]: dragnet-ransomware-2025-6072 — Recovery Inhibition (chaos)
// Status: test | Level: high | ID: 22e50849-be5f-5fa9-8562-6cf249d888ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
