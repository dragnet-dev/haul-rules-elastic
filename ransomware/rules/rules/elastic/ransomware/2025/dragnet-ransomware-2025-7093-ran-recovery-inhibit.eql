// Dragnet [Ransomware]: dragnet-ransomware-2025-7093 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 98f14c74-5a89-5743-a796-a35de1e4b259

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
