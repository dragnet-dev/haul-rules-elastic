// Dragnet [Ransomware]: dragnet-ransomware-2025-5038 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 43b2b45c-6437-57fb-9d88-694e65cf5eaf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
