// Dragnet [Ransomware]: dragnet-ransomware-2025-1327 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: 310572f6-fc80-55ad-8267-b398cf72d064

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
