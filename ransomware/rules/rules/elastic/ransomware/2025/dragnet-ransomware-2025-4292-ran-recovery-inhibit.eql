// Dragnet [Ransomware]: dragnet-ransomware-2025-4292 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: b1c6f2b2-063e-566c-9563-e824c7f8fccb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
