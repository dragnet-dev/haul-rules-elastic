// Dragnet [Ransomware]: dragnet-ransomware-2025-6101 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 57694063-412b-5074-9868-8787ddc40f9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
