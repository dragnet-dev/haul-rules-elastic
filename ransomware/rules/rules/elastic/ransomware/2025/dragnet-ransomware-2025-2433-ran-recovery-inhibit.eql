// Dragnet [Ransomware]: dragnet-ransomware-2025-2433 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: a4d1adf1-fe49-578d-a99f-ad3a0e9d2403

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
