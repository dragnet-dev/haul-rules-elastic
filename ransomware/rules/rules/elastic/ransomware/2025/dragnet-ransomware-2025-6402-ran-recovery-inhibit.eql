// Dragnet [Ransomware]: dragnet-ransomware-2025-6402 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 43321251-d9c2-50bf-9de1-7488785322fb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
