// Dragnet [Ransomware]: dragnet-ransomware-2025-6687 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: b3a99677-9e3e-51af-8cec-373ea45f6dd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
