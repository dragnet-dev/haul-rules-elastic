// Dragnet [Ransomware]: dragnet-ransomware-2025-4634 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 507338ef-9cd8-5653-bf39-d14da76fcff9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
