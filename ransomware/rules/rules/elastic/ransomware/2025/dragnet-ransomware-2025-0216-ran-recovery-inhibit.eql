// Dragnet [Ransomware]: dragnet-ransomware-2025-0216 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: d7fb7027-00eb-59f2-80ce-e1b0007d992c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
