// Dragnet [Ransomware]: dragnet-ransomware-2025-1136 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 4fc3aef8-ace8-587b-b247-c84472dfd3cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
