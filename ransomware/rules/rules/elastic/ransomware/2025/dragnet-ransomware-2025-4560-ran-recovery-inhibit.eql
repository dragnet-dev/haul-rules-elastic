// Dragnet [Ransomware]: dragnet-ransomware-2025-4560 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6e86e011-c2c4-56c8-af90-1e1f3e71feda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
