// Dragnet [Ransomware]: dragnet-ransomware-2025-5460 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 37c9da42-17f9-5167-b66f-48b1a55ae3ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
