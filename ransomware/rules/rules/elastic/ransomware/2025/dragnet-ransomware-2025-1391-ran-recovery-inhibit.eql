// Dragnet [Ransomware]: dragnet-ransomware-2025-1391 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 0efb19a0-c4b6-5c86-965e-6204803a0331

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
