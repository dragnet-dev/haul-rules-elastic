// Dragnet [Ransomware]: dragnet-ransomware-2025-2475 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 00f6d239-b9fb-5ca2-9196-28ad36bddb88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
