// Dragnet [Ransomware]: dragnet-ransomware-2025-0163 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: fe6f0ace-7a23-5e87-9b47-5c0dbf9ff53d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
