// Dragnet [Ransomware]: dragnet-ransomware-2025-0171 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 400123f8-c0e7-523b-bee9-168ba9fe68a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
