// Dragnet [Ransomware]: dragnet-ransomware-2025-2611 — Recovery Inhibition (weyhro)
// Status: experimental | Level: high | ID: e7b98666-7f33-5a51-be1f-1fa26c8b1ace

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
