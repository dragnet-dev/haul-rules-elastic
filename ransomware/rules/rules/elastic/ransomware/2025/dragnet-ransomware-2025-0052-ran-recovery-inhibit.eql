// Dragnet [Ransomware]: dragnet-ransomware-2025-0052 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 886c2721-c3ca-5e78-91ed-e78a67df1538

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
