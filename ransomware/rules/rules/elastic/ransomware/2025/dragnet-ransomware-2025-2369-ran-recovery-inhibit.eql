// Dragnet [Ransomware]: dragnet-ransomware-2025-2369 — Recovery Inhibition (ElDorado)
// Status: deprecated | Level: high | ID: 2a14660d-5180-5fd8-8322-2e99a991840e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
