// Dragnet [Ransomware]: dragnet-ransomware-2025-3691 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 1b94ff92-a6d1-5c05-acf1-c370ab3bf980

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
