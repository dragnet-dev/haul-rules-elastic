// Dragnet [Ransomware]: dragnet-ransomware-2025-4762 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 425e2ccd-ae55-51e2-91b3-914b1fdee1fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
