// Dragnet [Ransomware]: dragnet-ransomware-2025-7322 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1c0c77bb-b06b-5241-bb14-48c78031ef55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
