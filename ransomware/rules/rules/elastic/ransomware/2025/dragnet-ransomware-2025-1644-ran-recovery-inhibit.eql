// Dragnet [Ransomware]: dragnet-ransomware-2025-1644 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0f9dff74-0a72-5924-8343-af40dce38e1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
