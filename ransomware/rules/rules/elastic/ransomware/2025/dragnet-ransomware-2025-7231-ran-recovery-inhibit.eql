// Dragnet [Ransomware]: dragnet-ransomware-2025-7231 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: f55dc40e-6b5e-51ba-81cf-b331fc3ac5a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
