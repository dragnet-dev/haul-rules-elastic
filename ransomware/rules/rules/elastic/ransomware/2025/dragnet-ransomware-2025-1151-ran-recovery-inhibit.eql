// Dragnet [Ransomware]: dragnet-ransomware-2025-1151 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 855378ac-67b1-5919-b32b-f569ab37c38d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
