// Dragnet [Ransomware]: dragnet-ransomware-2025-4676 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 9c902e17-081c-5ecc-8658-3035da329be0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
