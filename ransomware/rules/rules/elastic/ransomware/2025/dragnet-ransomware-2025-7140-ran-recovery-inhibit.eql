// Dragnet [Ransomware]: dragnet-ransomware-2025-7140 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 6a09d07e-3b25-5793-97a6-0f7bbe27056c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
