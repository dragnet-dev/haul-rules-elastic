// Dragnet [Ransomware]: dragnet-ransomware-2025-6203 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 90b9dda9-cf2a-5c7e-bc4a-d2eedb64ff71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
