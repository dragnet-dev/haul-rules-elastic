// Dragnet [Ransomware]: dragnet-ransomware-2025-7053 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6cc0199e-e714-5c73-93ca-43551d319aab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
