// Dragnet [Ransomware]: dragnet-ransomware-2025-6627 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: 69d04c9e-abe4-5a6d-a906-2451ae8c08a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
