// Dragnet [Ransomware]: dragnet-ransomware-2025-4442 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 47f963f5-a22f-514e-b4b3-dc9f096a2558

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
