// Dragnet [Ransomware]: dragnet-ransomware-2025-2435 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: f2378c66-861c-563b-be2f-0131b9cb76a6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
