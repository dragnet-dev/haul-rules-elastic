// Dragnet [Ransomware]: dragnet-ransomware-2025-6104 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 25f042d6-292e-52be-9aee-e623b95f0f08

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
