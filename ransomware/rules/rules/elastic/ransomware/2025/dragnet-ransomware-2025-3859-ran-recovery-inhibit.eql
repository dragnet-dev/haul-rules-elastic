// Dragnet [Ransomware]: dragnet-ransomware-2025-3859 — Recovery Inhibition (interlock)
// Status: test | Level: high | ID: 1f9c32ec-f8f2-5281-9579-d64bdd42f79c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
