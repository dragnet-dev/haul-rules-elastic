// Dragnet [Ransomware]: dragnet-ransomware-2025-3107 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: a2996c1e-4a41-58ea-a6b0-d4cae5515259

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
