// Dragnet [Ransomware]: dragnet-ransomware-2025-3973 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: b6c28c0f-171a-5c9e-bfde-0e4a06227db1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
