// Dragnet [Ransomware]: dragnet-ransomware-2025-1204 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7248a50e-36ba-5d15-860b-41cd45a53625

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
