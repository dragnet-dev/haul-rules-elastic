// Dragnet [Ransomware]: dragnet-ransomware-2025-3738 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: edf70b74-da5b-5543-b1ce-59648aa8be87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
