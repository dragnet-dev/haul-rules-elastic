// Dragnet [Ransomware]: dragnet-ransomware-2025-7796 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: b392822e-b87e-5405-80a8-e3fab6d89383

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
