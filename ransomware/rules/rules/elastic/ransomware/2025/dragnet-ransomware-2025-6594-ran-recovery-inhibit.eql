// Dragnet [Ransomware]: dragnet-ransomware-2025-6594 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 29c599d4-f77b-549d-9057-af68889a66cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
