// Dragnet [Ransomware]: dragnet-ransomware-2025-1223 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 82b04e10-9d1d-59cd-93bd-674d4d82d86a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
