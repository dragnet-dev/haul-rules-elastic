// Dragnet [Ransomware]: dragnet-ransomware-2025-1562 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3b7030c6-fd53-51c3-886f-25450b519d67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
