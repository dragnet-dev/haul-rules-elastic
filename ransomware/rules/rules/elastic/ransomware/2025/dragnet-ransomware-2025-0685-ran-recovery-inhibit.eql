// Dragnet [Ransomware]: dragnet-ransomware-2025-0685 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: ca912047-0b17-5e53-9afb-c087c214de83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
