// Dragnet [Ransomware]: dragnet-ransomware-2025-3454 — Recovery Inhibition (termite)
// Status: experimental | Level: high | ID: 239258c4-4314-549e-9b4d-3ea96f85d7ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
