// Dragnet [Ransomware]: dragnet-ransomware-2025-2175 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: a6695c4b-26f7-53a7-af8a-274d05fba243

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
