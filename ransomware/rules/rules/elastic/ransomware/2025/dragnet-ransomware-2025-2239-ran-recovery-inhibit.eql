// Dragnet [Ransomware]: dragnet-ransomware-2025-2239 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 6e9e2b88-061e-5b4d-9abd-33f3c4ea25a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
