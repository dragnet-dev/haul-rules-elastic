// Dragnet [Ransomware]: dragnet-ransomware-2025-5360 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 1b0cb7c2-4d40-58d0-ac1d-f80961112791

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
