// Dragnet [Ransomware]: dragnet-ransomware-2025-6549 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 7833ba89-867a-54de-9275-b036a463cb20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
