// Dragnet [Ransomware]: dragnet-ransomware-2025-4820 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 00305407-a512-5070-8b44-8b0cd4f91846

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
