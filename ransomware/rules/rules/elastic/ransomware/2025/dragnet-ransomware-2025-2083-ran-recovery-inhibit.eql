// Dragnet [Ransomware]: dragnet-ransomware-2025-2083 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 81562506-082b-5200-80e0-f05bf7149555

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
