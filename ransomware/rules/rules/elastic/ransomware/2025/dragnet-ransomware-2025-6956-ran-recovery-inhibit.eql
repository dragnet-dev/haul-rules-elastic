// Dragnet [Ransomware]: dragnet-ransomware-2025-6956 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: dfe4dfcf-0e0b-5b2b-8865-0980631b9e67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
