// Dragnet [Ransomware]: dragnet-ransomware-2025-4305 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6282120f-3a52-50a8-ae06-768e051b1bc9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
