// Dragnet [Ransomware]: dragnet-ransomware-2025-4197 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: e19fdb95-5aca-5526-8c31-c3076f07e96e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
