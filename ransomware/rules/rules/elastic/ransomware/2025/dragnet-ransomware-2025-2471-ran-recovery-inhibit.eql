// Dragnet [Ransomware]: dragnet-ransomware-2025-2471 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 85da9d17-5fec-5e46-9d24-01b64a5d65eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
