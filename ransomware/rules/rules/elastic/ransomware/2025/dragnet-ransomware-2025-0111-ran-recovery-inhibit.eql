// Dragnet [Ransomware]: dragnet-ransomware-2025-0111 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 3db66ed9-b90b-5ab7-9ce8-42eec44971ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
