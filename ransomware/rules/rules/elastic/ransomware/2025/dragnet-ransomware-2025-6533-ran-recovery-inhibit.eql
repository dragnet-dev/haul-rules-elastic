// Dragnet [Ransomware]: dragnet-ransomware-2025-6533 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: 0e3415ca-e0bf-540b-8bff-460a90333cdf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
