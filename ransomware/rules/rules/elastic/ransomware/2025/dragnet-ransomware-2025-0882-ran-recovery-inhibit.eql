// Dragnet [Ransomware]: dragnet-ransomware-2025-0882 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 8b40481e-16af-581d-90c2-120e54150636

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
