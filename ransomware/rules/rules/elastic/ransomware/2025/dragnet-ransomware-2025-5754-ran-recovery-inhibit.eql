// Dragnet [Ransomware]: dragnet-ransomware-2025-5754 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: dd413532-d973-5838-9b02-979b154dcfdf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
