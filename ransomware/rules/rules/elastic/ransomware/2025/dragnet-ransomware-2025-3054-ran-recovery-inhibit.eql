// Dragnet [Ransomware]: dragnet-ransomware-2025-3054 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8e62fab0-f1f5-564a-8f10-9fe1e945be39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
