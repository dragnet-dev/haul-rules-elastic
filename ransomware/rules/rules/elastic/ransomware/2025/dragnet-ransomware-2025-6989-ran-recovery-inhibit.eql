// Dragnet [Ransomware]: dragnet-ransomware-2025-6989 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 24d0002b-eea2-57e9-8be0-9a608267bb37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
