// Dragnet [Ransomware]: dragnet-ransomware-2025-6379 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 6b267322-e2de-56d8-a96f-10c7fa90e418

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
