// Dragnet [Ransomware]: dragnet-ransomware-2025-4796 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f0db3e3f-1e89-5d77-b6a0-383086d06dad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
