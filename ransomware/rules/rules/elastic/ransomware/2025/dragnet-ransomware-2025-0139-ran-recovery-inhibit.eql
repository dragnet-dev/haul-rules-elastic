// Dragnet [Ransomware]: dragnet-ransomware-2025-0139 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e134e30a-d3a4-53e2-957d-5a4339dffab7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
