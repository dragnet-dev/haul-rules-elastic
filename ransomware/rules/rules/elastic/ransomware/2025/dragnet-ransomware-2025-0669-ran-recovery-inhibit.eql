// Dragnet [Ransomware]: dragnet-ransomware-2025-0669 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 2cb89300-b547-5473-b264-6cd0f1a31eea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
