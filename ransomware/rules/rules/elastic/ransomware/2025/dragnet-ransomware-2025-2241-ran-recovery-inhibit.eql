// Dragnet [Ransomware]: dragnet-ransomware-2025-2241 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 4b7c85c4-71e9-5992-b7bc-f5d7c0ee8482

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
