// Dragnet [Ransomware]: dragnet-ransomware-2025-4660 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: b21e234b-c43a-5630-9912-045a45961451

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
