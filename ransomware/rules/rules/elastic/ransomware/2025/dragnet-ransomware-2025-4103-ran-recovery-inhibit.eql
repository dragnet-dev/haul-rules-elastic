// Dragnet [Ransomware]: dragnet-ransomware-2025-4103 — Recovery Inhibition (moneymessage)
// Status: experimental | Level: high | ID: f8f706ea-ac0c-5e6f-ae7c-82dbf5d622c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
