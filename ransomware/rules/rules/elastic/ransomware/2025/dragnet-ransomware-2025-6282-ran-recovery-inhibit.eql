// Dragnet [Ransomware]: dragnet-ransomware-2025-6282 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 71b54bb3-d46c-55b8-8137-794e59ea0a7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
