// Dragnet [Ransomware]: dragnet-ransomware-2025-3700 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 6ce03cbc-e92e-5087-ac75-2ea4a521c5c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
