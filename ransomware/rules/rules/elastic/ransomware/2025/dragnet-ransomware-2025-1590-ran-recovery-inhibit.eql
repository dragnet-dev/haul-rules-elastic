// Dragnet [Ransomware]: dragnet-ransomware-2025-1590 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 41972c4d-7a3a-5c14-a001-558e552a322c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
