// Dragnet [Ransomware]: dragnet-ransomware-2025-1422 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 58a14542-ad8a-5312-825a-4ccdc2a13324

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
