// Dragnet [Ransomware]: dragnet-ransomware-2025-5046 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: dd6440dd-7a64-5a55-8a59-23a6f7fc792d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
