// Dragnet [Ransomware]: dragnet-ransomware-2025-4688 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: a870abad-7418-5e93-a246-1f8898439ab0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
