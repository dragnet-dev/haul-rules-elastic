// Dragnet [Ransomware]: dragnet-ransomware-2025-3567 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 5b5af06d-ff60-5a2f-a00d-3e8190484bc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
