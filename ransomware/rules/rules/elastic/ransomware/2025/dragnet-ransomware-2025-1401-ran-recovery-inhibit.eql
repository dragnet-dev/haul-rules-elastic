// Dragnet [Ransomware]: dragnet-ransomware-2025-1401 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 98202e08-f2ef-5de5-affc-8afce688a52c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
