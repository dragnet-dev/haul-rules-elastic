// Dragnet [Ransomware]: dragnet-ransomware-2025-7883 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 650ece95-63b3-5d7d-852e-5ca02067eb0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
