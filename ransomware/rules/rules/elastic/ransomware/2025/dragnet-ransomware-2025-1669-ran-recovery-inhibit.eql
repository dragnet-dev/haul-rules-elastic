// Dragnet [Ransomware]: dragnet-ransomware-2025-1669 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f86e9147-d3dc-5e39-86e5-4c96be6ff642

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
