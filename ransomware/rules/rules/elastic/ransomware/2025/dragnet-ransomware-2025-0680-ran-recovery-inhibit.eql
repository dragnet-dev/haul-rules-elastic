// Dragnet [Ransomware]: dragnet-ransomware-2025-0680 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 4f4d722c-9e20-53e5-8d47-881c3661af1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
