// Dragnet [Ransomware]: dragnet-ransomware-2025-3630 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 7a7c7b40-e134-5483-b023-e0adf752e743

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
