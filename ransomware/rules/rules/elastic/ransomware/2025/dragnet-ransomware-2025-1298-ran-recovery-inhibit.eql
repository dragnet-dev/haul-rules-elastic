// Dragnet [Ransomware]: dragnet-ransomware-2025-1298 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2be830f7-4412-5e29-be6d-900bf9613e0a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
