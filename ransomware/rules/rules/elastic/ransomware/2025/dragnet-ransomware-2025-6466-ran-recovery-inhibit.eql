// Dragnet [Ransomware]: dragnet-ransomware-2025-6466 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: 34b949f1-13f0-5827-9f31-96fb96b56663

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
