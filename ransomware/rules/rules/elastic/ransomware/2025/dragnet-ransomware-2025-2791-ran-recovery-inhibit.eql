// Dragnet [Ransomware]: dragnet-ransomware-2025-2791 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: 20ccc42a-7651-5ed7-9bab-312d0583bbb9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
