// Dragnet [Ransomware]: dragnet-ransomware-2025-7859 — Recovery Inhibition (teamxxx)
// Status: experimental | Level: high | ID: 81c143fa-7657-55f1-83ba-cdb4cce94ede

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
