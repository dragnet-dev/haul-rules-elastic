// Dragnet [Ransomware]: dragnet-ransomware-2025-0849 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 513d365a-4b95-506c-af82-5164ae598c78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
