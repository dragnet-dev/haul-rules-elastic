// Dragnet [Ransomware]: dragnet-ransomware-2025-1213 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 50409a37-a87f-5e9c-9a43-2c10ab7b7c3c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
