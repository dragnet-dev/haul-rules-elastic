// Dragnet [Ransomware]: dragnet-ransomware-2025-5147 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 4797fec9-f8b7-5205-8494-37eff85f8e70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
