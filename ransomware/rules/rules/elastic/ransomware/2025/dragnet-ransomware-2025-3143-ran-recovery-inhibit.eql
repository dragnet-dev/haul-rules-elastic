// Dragnet [Ransomware]: dragnet-ransomware-2025-3143 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 9ff8c445-a18b-5479-b675-0b6734b5511f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
