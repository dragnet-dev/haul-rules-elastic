// Dragnet [Ransomware]: dragnet-ransomware-2025-1182 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 4493b1f6-9e4a-56cf-babc-c0566ce8e119

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
