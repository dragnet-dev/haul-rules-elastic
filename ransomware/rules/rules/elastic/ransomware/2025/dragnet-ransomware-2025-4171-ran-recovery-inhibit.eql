// Dragnet [Ransomware]: dragnet-ransomware-2025-4171 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: caf9ce66-5fd6-5969-8181-0b9f855fda0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
