// Dragnet [Ransomware]: dragnet-ransomware-2025-0201 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 7954a281-fb52-570d-963f-63c312176dfb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
