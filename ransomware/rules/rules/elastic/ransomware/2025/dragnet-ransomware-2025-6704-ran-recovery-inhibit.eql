// Dragnet [Ransomware]: dragnet-ransomware-2025-6704 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 3eadf3dd-b5ec-5eaf-811d-24c526c22973

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
