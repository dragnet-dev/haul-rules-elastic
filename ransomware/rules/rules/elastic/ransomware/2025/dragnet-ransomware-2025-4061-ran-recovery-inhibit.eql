// Dragnet [Ransomware]: dragnet-ransomware-2025-4061 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bccfd3a6-1119-5e79-9e65-db1327782147

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
