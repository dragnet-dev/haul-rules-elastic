// Dragnet [Ransomware]: dragnet-ransomware-2025-4250 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 2530a6d1-fb48-5712-aad9-eec2f0ba8c53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
