// Dragnet [Ransomware]: dragnet-ransomware-2025-5034 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 42392487-45af-5eb1-b4a2-7777f9b603e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
