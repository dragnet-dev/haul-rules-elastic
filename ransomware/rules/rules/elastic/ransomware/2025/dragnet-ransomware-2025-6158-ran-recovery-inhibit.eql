// Dragnet [Ransomware]: dragnet-ransomware-2025-6158 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6880aa96-fc5a-5fc8-a500-71f1758ad198

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
