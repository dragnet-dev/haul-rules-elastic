// Dragnet [Ransomware]: dragnet-ransomware-2025-0318 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 8fc4c7a0-92d5-5884-ab34-6f068695f1a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
