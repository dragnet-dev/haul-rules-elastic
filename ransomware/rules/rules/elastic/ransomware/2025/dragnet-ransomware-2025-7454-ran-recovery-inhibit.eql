// Dragnet [Ransomware]: dragnet-ransomware-2025-7454 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e18c7c90-ad84-5edb-8de8-d74b80492ca7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
