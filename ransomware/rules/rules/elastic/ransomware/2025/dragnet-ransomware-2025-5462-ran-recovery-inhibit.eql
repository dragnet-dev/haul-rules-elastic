// Dragnet [Ransomware]: dragnet-ransomware-2025-5462 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 50c3d5fa-dba6-50ef-a9b2-525bcbd3a890

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
