// Dragnet [Ransomware]: dragnet-ransomware-2025-4085 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 1d4ce2e8-bf11-5194-9b01-d0eaadf9152c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
