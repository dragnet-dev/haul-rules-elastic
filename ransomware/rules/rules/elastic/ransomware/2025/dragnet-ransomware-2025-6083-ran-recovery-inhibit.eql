// Dragnet [Ransomware]: dragnet-ransomware-2025-6083 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 7f48ba6b-76f8-5cd1-8fff-f41fb7660e20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
