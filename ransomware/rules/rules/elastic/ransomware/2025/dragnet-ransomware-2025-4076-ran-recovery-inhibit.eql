// Dragnet [Ransomware]: dragnet-ransomware-2025-4076 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9ac7644a-3532-58d8-a74a-5cae08655f79

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
