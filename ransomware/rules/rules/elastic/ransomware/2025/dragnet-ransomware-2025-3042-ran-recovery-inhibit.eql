// Dragnet [Ransomware]: dragnet-ransomware-2025-3042 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: db975d39-49f8-51f7-831f-e173920dca62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
