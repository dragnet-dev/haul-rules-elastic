// Dragnet [Ransomware]: dragnet-ransomware-2025-5091 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: fc514508-e47a-5f61-9ab3-d768db9a8620

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
