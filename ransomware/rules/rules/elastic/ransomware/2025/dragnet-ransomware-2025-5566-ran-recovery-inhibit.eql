// Dragnet [Ransomware]: dragnet-ransomware-2025-5566 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 20c4dfff-06ce-5f9a-be0b-616367386fcc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
