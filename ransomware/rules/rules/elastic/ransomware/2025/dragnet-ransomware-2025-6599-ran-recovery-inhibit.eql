// Dragnet [Ransomware]: dragnet-ransomware-2025-6599 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: f7ea3c94-d9bf-5108-a1f7-1c9cc71a7c64

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
