// Dragnet [Ransomware]: dragnet-ransomware-2025-0095 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 5c3e9daf-722b-57d1-8d51-5fac44d45f26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
