// Dragnet [Ransomware]: dragnet-ransomware-2025-5682 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: fcef2c96-dc06-5b89-89df-a5760344d575

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
