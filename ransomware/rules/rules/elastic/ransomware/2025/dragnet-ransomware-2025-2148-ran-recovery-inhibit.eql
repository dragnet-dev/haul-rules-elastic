// Dragnet [Ransomware]: dragnet-ransomware-2025-2148 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: bfc0ce71-6959-5d42-a111-9e7c79fadb83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
