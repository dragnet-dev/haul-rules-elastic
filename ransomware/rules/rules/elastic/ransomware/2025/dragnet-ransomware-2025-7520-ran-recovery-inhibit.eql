// Dragnet [Ransomware]: dragnet-ransomware-2025-7520 — Recovery Inhibition (chaos)
// Status: test | Level: high | ID: a019b21a-f243-56eb-85c2-ce075c9132b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
