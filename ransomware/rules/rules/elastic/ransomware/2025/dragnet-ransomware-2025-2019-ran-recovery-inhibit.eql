// Dragnet [Ransomware]: dragnet-ransomware-2025-2019 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: 3eafd0fe-bedb-57de-af8d-4461419acfe4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
