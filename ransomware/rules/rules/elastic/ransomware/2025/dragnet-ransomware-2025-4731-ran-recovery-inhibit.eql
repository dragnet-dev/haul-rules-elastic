// Dragnet [Ransomware]: dragnet-ransomware-2025-4731 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: c1a747f2-3fa9-56c2-add3-74f3413a7d29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
