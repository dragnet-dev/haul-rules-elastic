// Dragnet [Ransomware]: dragnet-ransomware-2025-0585 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 2a5f59e2-28e0-5a5b-8d12-e7c617fb96e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
