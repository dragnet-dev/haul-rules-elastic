// Dragnet [Ransomware]: dragnet-ransomware-2025-4154 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 281611a6-dff8-5066-830e-a7d9fa492c07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
