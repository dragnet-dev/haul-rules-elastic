// Dragnet [Ransomware]: dragnet-ransomware-2025-5770 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 877fce62-c55e-513b-9819-0532a6cf732b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
