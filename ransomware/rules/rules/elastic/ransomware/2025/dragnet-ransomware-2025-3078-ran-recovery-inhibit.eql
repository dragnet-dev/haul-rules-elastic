// Dragnet [Ransomware]: dragnet-ransomware-2025-3078 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: c36efbb2-d4a3-5e56-8d4e-1ee0016699b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
