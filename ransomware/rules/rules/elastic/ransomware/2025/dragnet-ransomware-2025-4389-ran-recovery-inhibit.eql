// Dragnet [Ransomware]: dragnet-ransomware-2025-4389 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: 7c647176-5f31-5d95-99f3-4aa76ebae97d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
