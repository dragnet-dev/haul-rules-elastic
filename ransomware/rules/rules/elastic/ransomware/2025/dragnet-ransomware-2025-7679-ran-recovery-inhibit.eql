// Dragnet [Ransomware]: dragnet-ransomware-2025-7679 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: d5acafc8-4a2d-59ef-b6a4-a88b8555bdd3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
