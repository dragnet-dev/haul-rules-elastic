// Dragnet [Ransomware]: dragnet-ransomware-2025-6953 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: aaaebe51-23d4-5dcd-8d5d-4dde8657bfd0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
