// Dragnet [Ransomware]: dragnet-ransomware-2025-4509 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: cdc543e7-04dc-5f0e-9eb9-e4f87868ec85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
