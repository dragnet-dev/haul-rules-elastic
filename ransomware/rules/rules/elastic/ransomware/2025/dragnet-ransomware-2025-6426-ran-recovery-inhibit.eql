// Dragnet [Ransomware]: dragnet-ransomware-2025-6426 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 7c8a02b5-6b89-5638-bc97-181ee06a11da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
