// Dragnet [Ransomware]: dragnet-ransomware-2025-1751 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: d06e2347-693e-54d1-a36b-9a700c1dbb1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
