// Dragnet [Ransomware]: dragnet-ransomware-2025-3850 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: eeb4946b-856b-5ef7-95b3-59f64529a794

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
