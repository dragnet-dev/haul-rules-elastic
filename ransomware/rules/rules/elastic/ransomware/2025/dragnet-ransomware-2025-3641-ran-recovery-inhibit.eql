// Dragnet [Ransomware]: dragnet-ransomware-2025-3641 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: ec596514-99de-5a07-bf7d-d52d72703087

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
