// Dragnet [Ransomware]: dragnet-ransomware-2025-3033 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 3387eb52-e508-57c6-a560-bad328376f32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
