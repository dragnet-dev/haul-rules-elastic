// Dragnet [Ransomware]: dragnet-ransomware-2025-7363 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b798e2be-baa5-51f9-8e55-18530a9f89b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
