// Dragnet [Ransomware]: dragnet-ransomware-2025-6398 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 320ef905-a090-5641-8a28-bcd56e66adb5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
