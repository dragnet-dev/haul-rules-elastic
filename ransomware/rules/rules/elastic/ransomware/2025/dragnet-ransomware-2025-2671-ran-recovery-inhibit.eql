// Dragnet [Ransomware]: dragnet-ransomware-2025-2671 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5d709fca-81cd-52b7-9a89-4a2a0744192c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
