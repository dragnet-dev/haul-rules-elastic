// Dragnet [Ransomware]: dragnet-ransomware-2025-7349 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 619904d6-1354-57ea-a8bc-66264dd1cd50

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
