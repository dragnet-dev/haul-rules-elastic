// Dragnet [Ransomware]: dragnet-ransomware-2025-6938 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 898062fd-3aaa-5c1f-ad45-2d1135c44c7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
