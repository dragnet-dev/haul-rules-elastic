// Dragnet [Ransomware]: dragnet-ransomware-2025-6851 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: ef0ad595-4342-59b4-867f-98351f6334de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
