// Dragnet [Ransomware]: dragnet-ransomware-2025-5588 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 22151ee6-0858-53e1-b8dc-c8502512d885

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
