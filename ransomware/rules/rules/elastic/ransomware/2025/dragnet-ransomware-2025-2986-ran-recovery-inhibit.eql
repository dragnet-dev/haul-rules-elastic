// Dragnet [Ransomware]: dragnet-ransomware-2025-2986 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 03949b11-95f4-5372-976b-551bddafa082

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
