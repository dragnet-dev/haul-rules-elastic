// Dragnet [Ransomware]: dragnet-ransomware-2025-7144 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f0a0e41f-ff3b-57aa-b45b-53b10a5c08ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
