// Dragnet [Ransomware]: dragnet-ransomware-2025-4005 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: e4c3700b-b774-5fe8-8a49-dbea2d031f9c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
