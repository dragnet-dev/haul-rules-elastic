// Dragnet [Ransomware]: dragnet-ransomware-2025-5301 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: c65aee2f-b00c-5aed-9f99-4d4b579d7379

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
