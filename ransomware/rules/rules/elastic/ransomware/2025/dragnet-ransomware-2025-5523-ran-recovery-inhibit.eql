// Dragnet [Ransomware]: dragnet-ransomware-2025-5523 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 6e0d72e3-60ee-5a7c-8517-8c0795359bcb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
