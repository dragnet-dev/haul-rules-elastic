// Dragnet [Ransomware]: dragnet-ransomware-2025-1727 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 30e66c04-eae9-5f91-81fa-0928e1795863

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
