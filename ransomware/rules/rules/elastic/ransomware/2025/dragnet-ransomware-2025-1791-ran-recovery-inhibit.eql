// Dragnet [Ransomware]: dragnet-ransomware-2025-1791 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 875b6a8b-2abe-584e-a420-95da2762fca8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
