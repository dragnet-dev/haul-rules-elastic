// Dragnet [Ransomware]: dragnet-ransomware-2025-2694 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: b67e9324-ac6e-5f58-b6e1-d8f50c34c653

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
