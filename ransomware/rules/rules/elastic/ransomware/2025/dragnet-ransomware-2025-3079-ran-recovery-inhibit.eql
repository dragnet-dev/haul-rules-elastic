// Dragnet [Ransomware]: dragnet-ransomware-2025-3079 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0c932802-1bd5-5018-a0e9-1d4270a197c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
