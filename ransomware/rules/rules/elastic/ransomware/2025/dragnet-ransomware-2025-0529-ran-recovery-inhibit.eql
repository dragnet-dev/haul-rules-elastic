// Dragnet [Ransomware]: dragnet-ransomware-2025-0529 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 496dd82f-6ecc-5dc4-a34c-ccfc2348a1b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
