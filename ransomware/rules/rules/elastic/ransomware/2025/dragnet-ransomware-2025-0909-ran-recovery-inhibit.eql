// Dragnet [Ransomware]: dragnet-ransomware-2025-0909 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 07f3faf7-0180-5b94-afe3-40f97cbe67fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
