// Dragnet [Ransomware]: dragnet-ransomware-2025-5216 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: fd494f9b-cd25-5299-bd05-641e770b1ecb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
