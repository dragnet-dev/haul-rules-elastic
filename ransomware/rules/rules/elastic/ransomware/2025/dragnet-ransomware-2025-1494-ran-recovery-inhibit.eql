// Dragnet [Ransomware]: dragnet-ransomware-2025-1494 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 002e6ac7-c668-556b-b36a-dea65dad8cb7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
