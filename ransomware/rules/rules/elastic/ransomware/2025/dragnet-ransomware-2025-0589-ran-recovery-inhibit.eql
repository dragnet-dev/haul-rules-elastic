// Dragnet [Ransomware]: dragnet-ransomware-2025-0589 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: 5d70f27e-21a7-550c-add1-8bd25070e808

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
