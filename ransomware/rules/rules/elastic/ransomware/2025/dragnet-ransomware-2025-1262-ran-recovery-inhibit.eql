// Dragnet [Ransomware]: dragnet-ransomware-2025-1262 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 44ed9c76-e44d-5e29-a45e-191f2def01e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
