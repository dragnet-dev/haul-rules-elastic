// Dragnet [Ransomware]: dragnet-ransomware-2025-0475 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 7c6ab1cd-5b8e-5cce-a73d-723e4f872407

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
