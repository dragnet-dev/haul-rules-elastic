// Dragnet [Ransomware]: dragnet-ransomware-2025-4083 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: db60f4ac-bec8-58fe-89c5-2b5c863453f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
