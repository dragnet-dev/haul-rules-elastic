// Dragnet [Ransomware]: dragnet-ransomware-2025-6226 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 214a7b73-0c7c-5095-ba51-2fb9c438c7e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
