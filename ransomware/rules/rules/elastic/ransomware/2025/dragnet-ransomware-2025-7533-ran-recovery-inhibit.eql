// Dragnet [Ransomware]: dragnet-ransomware-2025-7533 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: faede4ae-18e4-5480-9f26-fafa84db4552

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
