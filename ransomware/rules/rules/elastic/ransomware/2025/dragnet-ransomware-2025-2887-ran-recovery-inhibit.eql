// Dragnet [Ransomware]: dragnet-ransomware-2025-2887 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c28ebb89-27f7-5a9f-aff9-c98482eef46d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
