// Dragnet [Ransomware]: dragnet-ransomware-2025-5162 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 55a0de32-09ef-5526-92fc-2dc32b2be1ed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
