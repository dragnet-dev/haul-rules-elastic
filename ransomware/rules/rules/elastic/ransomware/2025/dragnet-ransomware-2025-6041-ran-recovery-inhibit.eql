// Dragnet [Ransomware]: dragnet-ransomware-2025-6041 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 81206ce5-83ec-5e27-bc60-ee01b59bb37c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
