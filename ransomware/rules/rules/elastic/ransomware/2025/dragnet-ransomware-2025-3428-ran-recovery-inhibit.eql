// Dragnet [Ransomware]: dragnet-ransomware-2025-3428 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: c6587a16-7e58-5e9b-aeab-409a66266dd4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
