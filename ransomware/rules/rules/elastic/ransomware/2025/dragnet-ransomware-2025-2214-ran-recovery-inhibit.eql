// Dragnet [Ransomware]: dragnet-ransomware-2025-2214 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: e762cc90-0561-5e5a-9650-22affddcf300

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
