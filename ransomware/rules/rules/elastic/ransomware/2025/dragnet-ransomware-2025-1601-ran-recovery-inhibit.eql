// Dragnet [Ransomware]: dragnet-ransomware-2025-1601 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 9ee174f8-3532-572f-b046-3253ac959a60

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
