// Dragnet [Ransomware]: dragnet-ransomware-2025-2861 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 142603cd-ba9a-5695-a876-2be6cc7bfe58

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
