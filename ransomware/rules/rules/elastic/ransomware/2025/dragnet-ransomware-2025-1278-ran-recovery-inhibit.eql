// Dragnet [Ransomware]: dragnet-ransomware-2025-1278 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7d53f4f8-8e6c-5b31-ae1b-c425754aaa38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
