// Dragnet [Ransomware]: dragnet-ransomware-2025-6891 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a1e98086-c737-5582-8003-415df33b65f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
