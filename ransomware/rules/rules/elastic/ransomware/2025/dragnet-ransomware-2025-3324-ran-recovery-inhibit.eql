// Dragnet [Ransomware]: dragnet-ransomware-2025-3324 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f1758aab-7b32-56ab-87f0-d916f8bb7c10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
