// Dragnet [Ransomware]: dragnet-ransomware-2025-4997 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b0b55104-e472-5a3c-b552-8bc531a83983

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
