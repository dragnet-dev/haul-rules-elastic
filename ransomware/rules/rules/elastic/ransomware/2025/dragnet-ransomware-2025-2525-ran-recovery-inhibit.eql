// Dragnet [Ransomware]: dragnet-ransomware-2025-2525 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 11e7f23b-da83-56c7-8802-ffc4e7f91d95

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
