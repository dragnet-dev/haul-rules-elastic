// Dragnet [Ransomware]: dragnet-ransomware-2025-3661 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: c92be94b-907f-52d7-afc3-25a5f5fca3b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
