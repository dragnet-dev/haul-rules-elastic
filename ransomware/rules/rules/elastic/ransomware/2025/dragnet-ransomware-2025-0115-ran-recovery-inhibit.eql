// Dragnet [Ransomware]: dragnet-ransomware-2025-0115 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: fa75546a-0b5c-5b57-9a67-9dec59afeb07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
