// Dragnet [Ransomware]: dragnet-ransomware-2025-3575 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 28504796-c4f7-5f1b-9b20-f51fd98519a2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
