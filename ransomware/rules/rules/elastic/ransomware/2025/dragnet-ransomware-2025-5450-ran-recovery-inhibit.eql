// Dragnet [Ransomware]: dragnet-ransomware-2025-5450 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: c26128d0-1adf-59f1-afb9-b68b9547c70d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
