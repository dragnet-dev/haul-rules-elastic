// Dragnet [Ransomware]: dragnet-ransomware-2025-4511 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 93289985-3c79-5c05-8565-accce60c9c3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
