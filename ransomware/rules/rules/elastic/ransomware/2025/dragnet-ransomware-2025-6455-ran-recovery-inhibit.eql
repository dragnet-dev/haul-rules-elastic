// Dragnet [Ransomware]: dragnet-ransomware-2025-6455 — Recovery Inhibition (benzona)
// Status: deprecated | Level: high | ID: 441043dd-205d-51ca-adc1-a6895ac86af5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
