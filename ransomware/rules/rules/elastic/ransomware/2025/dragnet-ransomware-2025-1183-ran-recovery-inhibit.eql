// Dragnet [Ransomware]: dragnet-ransomware-2025-1183 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 17feb922-0b5e-5f54-91ee-a29ffe496421

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
