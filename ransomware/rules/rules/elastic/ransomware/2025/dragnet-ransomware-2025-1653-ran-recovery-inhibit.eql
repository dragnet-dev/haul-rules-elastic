// Dragnet [Ransomware]: dragnet-ransomware-2025-1653 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: 40a0284e-eb1b-5ce4-ba1a-1671603ef2c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
