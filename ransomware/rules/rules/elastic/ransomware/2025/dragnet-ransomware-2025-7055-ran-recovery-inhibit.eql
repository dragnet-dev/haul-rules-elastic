// Dragnet [Ransomware]: dragnet-ransomware-2025-7055 — Recovery Inhibition (d4rk4rmy)
// Status: experimental | Level: high | ID: bfa1dc17-e38d-53ed-b317-d4019a10b7a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
