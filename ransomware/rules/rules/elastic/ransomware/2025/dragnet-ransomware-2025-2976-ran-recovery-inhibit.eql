// Dragnet [Ransomware]: dragnet-ransomware-2025-2976 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: e7d43e87-9c65-5cbc-94d2-3de7daa332cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
