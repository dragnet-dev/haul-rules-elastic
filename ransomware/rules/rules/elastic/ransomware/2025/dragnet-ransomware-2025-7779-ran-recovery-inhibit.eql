// Dragnet [Ransomware]: dragnet-ransomware-2025-7779 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 2f3e9360-6a53-5293-b490-9a80da82cc5b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
