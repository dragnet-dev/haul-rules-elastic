// Dragnet [Ransomware]: dragnet-ransomware-2025-2030 — Recovery Inhibition (shinyhunters)
// Status: experimental | Level: high | ID: 98acf49f-f3a7-5cf5-b752-dc8c1de027de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
