// Dragnet [Ransomware]: dragnet-ransomware-2025-4300 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: b1c03299-5439-5ad5-aa2a-59eabbf39bf8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
