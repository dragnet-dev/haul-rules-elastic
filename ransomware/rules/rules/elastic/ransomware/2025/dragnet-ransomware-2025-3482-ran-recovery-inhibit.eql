// Dragnet [Ransomware]: dragnet-ransomware-2025-3482 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: db6275f0-ec72-58b5-ac5f-245d3610ed02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
