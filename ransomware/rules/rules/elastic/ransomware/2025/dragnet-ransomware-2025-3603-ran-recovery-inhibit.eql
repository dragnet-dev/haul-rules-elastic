// Dragnet [Ransomware]: dragnet-ransomware-2025-3603 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 73c67539-f287-55fd-bf0b-813a0dbf103f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
