// Dragnet [Ransomware]: dragnet-ransomware-2025-4003 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 5e4ec8c4-57d9-5a1b-a254-ca723653d497

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
