// Dragnet [Ransomware]: dragnet-ransomware-2025-4310 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 36de9039-7eb0-5813-a77a-66c00139c859

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
