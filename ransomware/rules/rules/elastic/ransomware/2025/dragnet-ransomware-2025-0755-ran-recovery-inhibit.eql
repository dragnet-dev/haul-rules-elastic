// Dragnet [Ransomware]: dragnet-ransomware-2025-0755 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 17b5e533-481f-52dd-a694-fce8f60811b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
