// Dragnet [Ransomware]: dragnet-ransomware-2025-7747 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 33dfe6c4-cabc-5b80-811d-32e9f3a8e288

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
