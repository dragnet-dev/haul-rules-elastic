// Dragnet [Ransomware]: dragnet-ransomware-2025-7616 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9bfbc129-8f6f-5f78-a2f1-85150c6d6fff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
