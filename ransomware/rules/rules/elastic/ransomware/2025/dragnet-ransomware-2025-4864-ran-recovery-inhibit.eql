// Dragnet [Ransomware]: dragnet-ransomware-2025-4864 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: df7617de-57fa-55b3-aba8-13cab34b047e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
