// Dragnet [Ransomware]: dragnet-ransomware-2025-5869 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: aa195ecc-febf-5b5e-a172-3d29da8c898b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
