// Dragnet [Ransomware]: dragnet-ransomware-2025-6920 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8f2ff52b-d51a-5b2e-8997-4e196cd2aaa5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
