// Dragnet [Ransomware]: dragnet-ransomware-2025-0218 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: b4b1fda8-332b-5125-81b3-a409f1e03775

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
