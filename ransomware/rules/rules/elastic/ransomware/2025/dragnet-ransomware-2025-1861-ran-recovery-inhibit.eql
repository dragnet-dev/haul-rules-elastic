// Dragnet [Ransomware]: dragnet-ransomware-2025-1861 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 9c58be00-13aa-5015-8058-4cbc65e62a01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
