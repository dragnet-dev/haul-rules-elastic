// Dragnet [Ransomware]: dragnet-ransomware-2025-4586 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 53b6d5a5-29f9-5969-a6ab-a13d666fd1f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
