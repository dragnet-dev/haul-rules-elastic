// Dragnet [Ransomware]: dragnet-ransomware-2025-7009 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: cf48ae6d-03b4-5c24-9791-1994c9938d86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
