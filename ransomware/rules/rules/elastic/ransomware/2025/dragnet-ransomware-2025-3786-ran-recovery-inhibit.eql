// Dragnet [Ransomware]: dragnet-ransomware-2025-3786 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1d6a8aa0-f9f5-51b4-a15b-b283fce3a985

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
