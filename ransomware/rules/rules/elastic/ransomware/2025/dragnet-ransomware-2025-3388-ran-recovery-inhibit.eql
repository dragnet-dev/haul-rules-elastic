// Dragnet [Ransomware]: dragnet-ransomware-2025-3388 — Recovery Inhibition (cephalus)
// Status: experimental | Level: high | ID: 74c04d61-37e0-5a73-8a72-94c4126cfc48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
