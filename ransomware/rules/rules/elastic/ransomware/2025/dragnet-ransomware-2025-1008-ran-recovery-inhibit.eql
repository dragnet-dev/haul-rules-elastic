// Dragnet [Ransomware]: dragnet-ransomware-2025-1008 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: b02ccb00-60fc-521c-a759-b71f15c6641a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
