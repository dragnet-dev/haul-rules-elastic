// Dragnet [Ransomware]: dragnet-ransomware-2025-4826 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d2495309-ed37-5949-aee3-64c9945761ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
