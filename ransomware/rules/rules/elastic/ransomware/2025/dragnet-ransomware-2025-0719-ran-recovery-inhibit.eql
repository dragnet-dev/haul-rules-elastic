// Dragnet [Ransomware]: dragnet-ransomware-2025-0719 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: dc159470-e7d2-5f4a-b3a0-d5a719684d41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
