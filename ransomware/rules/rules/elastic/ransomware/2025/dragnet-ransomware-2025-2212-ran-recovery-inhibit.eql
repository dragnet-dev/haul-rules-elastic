// Dragnet [Ransomware]: dragnet-ransomware-2025-2212 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 307b8a5d-58bd-584a-adb8-3eb5e18cf05e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
