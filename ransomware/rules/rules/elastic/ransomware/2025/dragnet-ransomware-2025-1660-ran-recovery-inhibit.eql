// Dragnet [Ransomware]: dragnet-ransomware-2025-1660 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: b833970a-bf04-5afd-b04a-7214815c924e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
