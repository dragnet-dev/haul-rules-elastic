// Dragnet [Ransomware]: dragnet-ransomware-2025-1654 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 54a0b8b6-1f67-5ccf-9d72-9dde51f6d414

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
