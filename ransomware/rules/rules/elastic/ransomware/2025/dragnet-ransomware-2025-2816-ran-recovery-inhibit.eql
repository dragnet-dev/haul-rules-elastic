// Dragnet [Ransomware]: dragnet-ransomware-2025-2816 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 5ac6ee7b-9243-52db-9996-d115c5b312ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
