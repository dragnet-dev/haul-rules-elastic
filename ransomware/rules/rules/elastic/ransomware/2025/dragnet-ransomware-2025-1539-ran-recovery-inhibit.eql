// Dragnet [Ransomware]: dragnet-ransomware-2025-1539 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e2428788-ab49-523d-83d3-44a22e6bd368

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
