// Dragnet [Ransomware]: dragnet-ransomware-2025-7304 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 46bd000d-8285-5be0-9d78-93a7ff5380d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
