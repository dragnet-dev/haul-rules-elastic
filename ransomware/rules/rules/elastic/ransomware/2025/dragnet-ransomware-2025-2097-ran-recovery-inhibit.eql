// Dragnet [Ransomware]: dragnet-ransomware-2025-2097 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: b5dd6c96-b27c-5464-83c8-c4cf738aef2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
