// Dragnet [Ransomware]: dragnet-ransomware-2025-3843 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: c45e80e5-b446-5618-b4d6-bf8e05754b11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
