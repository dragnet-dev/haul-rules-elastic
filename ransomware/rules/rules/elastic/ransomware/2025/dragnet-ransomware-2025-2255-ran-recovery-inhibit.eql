// Dragnet [Ransomware]: dragnet-ransomware-2025-2255 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 43a2614d-5620-564b-beaa-0372becec79c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
