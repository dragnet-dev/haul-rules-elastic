// Dragnet [Ransomware]: dragnet-ransomware-2025-6193 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 81a94695-8486-5de9-9e30-eebb55065602

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
