// Dragnet [Ransomware]: dragnet-ransomware-2025-2104 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: c9c9c179-3d0f-5cf0-b461-3d2a33148adf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
