// Dragnet [Ransomware]: dragnet-ransomware-2025-4867 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 00bb6bc9-6c5b-56ee-a2a2-da1fbf25ca21

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
