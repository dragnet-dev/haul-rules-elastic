// Dragnet [Ransomware]: dragnet-ransomware-2025-6113 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 5e69adad-df8e-5d0e-85d5-a10a9fbb5b1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
