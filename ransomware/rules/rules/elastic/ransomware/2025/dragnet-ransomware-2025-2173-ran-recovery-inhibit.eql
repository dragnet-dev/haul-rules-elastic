// Dragnet [Ransomware]: dragnet-ransomware-2025-2173 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 45409573-12f7-5fa9-aeb0-06aa74ce2a55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
