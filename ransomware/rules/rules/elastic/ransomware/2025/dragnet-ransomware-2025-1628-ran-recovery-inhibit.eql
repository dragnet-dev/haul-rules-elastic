// Dragnet [Ransomware]: dragnet-ransomware-2025-1628 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 6ad57588-7097-5ff6-bbba-9ecdd7aa4b71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
