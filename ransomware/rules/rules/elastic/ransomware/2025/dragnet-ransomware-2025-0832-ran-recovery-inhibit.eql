// Dragnet [Ransomware]: dragnet-ransomware-2025-0832 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: a70d0783-4911-556b-8641-724485dfcf41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
