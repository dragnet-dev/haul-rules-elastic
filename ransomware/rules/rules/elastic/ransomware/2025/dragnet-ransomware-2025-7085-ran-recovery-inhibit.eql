// Dragnet [Ransomware]: dragnet-ransomware-2025-7085 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 85898422-941f-53ca-965f-88d38532b5d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
