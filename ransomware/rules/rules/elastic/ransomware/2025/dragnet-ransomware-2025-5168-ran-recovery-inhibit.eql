// Dragnet [Ransomware]: dragnet-ransomware-2025-5168 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 1a07ec00-50bd-5b97-97c7-ed517d47281a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
