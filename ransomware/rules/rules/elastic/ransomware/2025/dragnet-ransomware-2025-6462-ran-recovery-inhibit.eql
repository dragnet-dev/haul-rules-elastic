// Dragnet [Ransomware]: dragnet-ransomware-2025-6462 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: 2b56e88c-bd82-5009-b434-9aa8b7c2f4c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
