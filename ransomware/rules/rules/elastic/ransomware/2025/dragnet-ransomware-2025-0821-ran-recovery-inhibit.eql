// Dragnet [Ransomware]: dragnet-ransomware-2025-0821 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 0dcb99da-f574-5ae4-b148-14f7ba36bb1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
