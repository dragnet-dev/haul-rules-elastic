// Dragnet [Ransomware]: dragnet-ransomware-2025-4297 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 201e8735-6b60-58c6-a396-9b5b6f735262

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
