// Dragnet [Ransomware]: dragnet-ransomware-2025-4718 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 49f026e6-ad74-5c4a-a334-660e3b866cca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
