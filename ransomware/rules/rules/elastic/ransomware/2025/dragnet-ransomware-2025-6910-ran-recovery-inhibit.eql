// Dragnet [Ransomware]: dragnet-ransomware-2025-6910 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 2501c4b4-d295-54b2-99bb-e86d136c2c01

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
