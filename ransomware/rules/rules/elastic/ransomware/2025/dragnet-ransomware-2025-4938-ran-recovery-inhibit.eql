// Dragnet [Ransomware]: dragnet-ransomware-2025-4938 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: c2f2de94-c9ef-5e73-abdd-eff233caab3b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
