// Dragnet [Ransomware]: dragnet-ransomware-2025-4010 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 0fc8bffa-0163-5756-ae86-fcd286599057

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
