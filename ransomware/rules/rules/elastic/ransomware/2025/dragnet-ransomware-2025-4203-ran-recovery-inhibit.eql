// Dragnet [Ransomware]: dragnet-ransomware-2025-4203 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5bba2dec-43b6-5544-8ac9-0334eb70ea19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
