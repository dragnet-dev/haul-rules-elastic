// Dragnet [Ransomware]: dragnet-ransomware-2025-1446 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: d79e7d5f-613f-5f3f-9e11-c3de33c37cbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
