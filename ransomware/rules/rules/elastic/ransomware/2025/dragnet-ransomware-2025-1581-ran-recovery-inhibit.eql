// Dragnet [Ransomware]: dragnet-ransomware-2025-1581 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 8673032d-a5ee-5492-8aeb-53389f72c6ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
