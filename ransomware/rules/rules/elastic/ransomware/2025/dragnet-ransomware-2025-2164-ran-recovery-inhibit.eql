// Dragnet [Ransomware]: dragnet-ransomware-2025-2164 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 5ec6160d-0d98-5a09-91a4-bfd1b88d16ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
