// Dragnet [Ransomware]: dragnet-ransomware-2025-0756 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 1cf22fcc-ca3c-5ffd-b1fe-a7512d9aa9db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
