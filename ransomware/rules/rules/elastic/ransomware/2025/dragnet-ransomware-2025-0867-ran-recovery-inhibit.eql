// Dragnet [Ransomware]: dragnet-ransomware-2025-0867 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 6bf9af48-fa58-55ff-8cda-55c80786df0b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
