// Dragnet [Ransomware]: dragnet-ransomware-2025-0018 — Recovery Inhibition (radar)
// Status: experimental | Level: high | ID: 3232a136-5f90-5f5a-91dc-2a7688bee719

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
