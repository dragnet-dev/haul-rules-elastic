// Dragnet [Ransomware]: dragnet-ransomware-2025-1740 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: 495434ea-6095-5729-9e20-6fa6adcd21d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
