// Dragnet [Ransomware]: dragnet-ransomware-2025-0446 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 86029fee-f32d-5415-801e-3022e4e86e02

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
