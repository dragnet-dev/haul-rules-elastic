// Dragnet [Ransomware]: dragnet-ransomware-2025-4854 — Recovery Inhibition (IMNCrew)
// Status: experimental | Level: high | ID: ce9659d7-e413-5e86-b674-068221416cdd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
