// Dragnet [Ransomware]: dragnet-ransomware-2025-2968 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b2ba0dc4-3283-533c-8d31-cb78d9e488ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
