// Dragnet [Ransomware]: dragnet-ransomware-2025-7772 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 8b51125b-2f18-5123-93a1-2b236066d667

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
