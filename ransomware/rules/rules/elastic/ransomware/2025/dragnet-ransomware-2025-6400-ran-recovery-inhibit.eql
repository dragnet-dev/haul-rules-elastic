// Dragnet [Ransomware]: dragnet-ransomware-2025-6400 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 9182537e-1073-5b68-943d-1bf7b6ff7bed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
