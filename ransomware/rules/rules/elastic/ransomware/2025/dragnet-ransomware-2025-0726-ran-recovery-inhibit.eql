// Dragnet [Ransomware]: dragnet-ransomware-2025-0726 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: a5b4812a-e9f5-50eb-8f64-cd3aad5bdcfc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
