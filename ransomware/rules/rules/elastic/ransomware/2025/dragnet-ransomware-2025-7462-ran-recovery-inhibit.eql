// Dragnet [Ransomware]: dragnet-ransomware-2025-7462 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 6b7f9f56-70c2-59a9-a2d0-9a1f7eb76779

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
