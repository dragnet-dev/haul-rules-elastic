// Dragnet [Ransomware]: dragnet-ransomware-2025-5083 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: b1d915e6-d646-5c61-8364-1c4f80307625

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
