// Dragnet [Ransomware]: dragnet-ransomware-2025-0781 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 415f473a-f816-5b71-a992-dd912123c888

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
