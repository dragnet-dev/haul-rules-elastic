// Dragnet [Ransomware]: dragnet-ransomware-2025-1443 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: ebf40252-082e-5b53-a3e2-48783e44831c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
