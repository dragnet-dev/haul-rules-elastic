// Dragnet [Ransomware]: dragnet-ransomware-2025-0305 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: 6e379508-0a5c-5b58-8361-1562fef4533b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
