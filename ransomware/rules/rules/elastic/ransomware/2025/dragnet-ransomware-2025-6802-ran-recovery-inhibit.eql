// Dragnet [Ransomware]: dragnet-ransomware-2025-6802 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 80b8c20e-71ae-5d17-94bc-7c883950505e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
