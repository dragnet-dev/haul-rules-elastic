// Dragnet [Ransomware]: dragnet-ransomware-2025-4873 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 530b879a-954d-5032-b4bc-7070a7afd4f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
