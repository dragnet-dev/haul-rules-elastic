// Dragnet [Ransomware]: dragnet-ransomware-2025-6771 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: dd22a863-0aa0-50a4-817d-0c7830aa0b11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
