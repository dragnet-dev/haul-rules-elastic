// Dragnet [Ransomware]: dragnet-ransomware-2025-6839 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 2bf86330-8809-5f4c-855e-a8cd20c19718

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
