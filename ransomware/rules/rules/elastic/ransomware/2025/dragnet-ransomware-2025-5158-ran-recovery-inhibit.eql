// Dragnet [Ransomware]: dragnet-ransomware-2025-5158 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: ff8b583f-ad04-5763-b1a4-5c22a1dc76a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
