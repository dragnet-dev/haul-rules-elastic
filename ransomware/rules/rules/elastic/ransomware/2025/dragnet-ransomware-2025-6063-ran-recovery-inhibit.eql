// Dragnet [Ransomware]: dragnet-ransomware-2025-6063 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: dda0013c-3be8-5077-8d9d-1d8671be844a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
