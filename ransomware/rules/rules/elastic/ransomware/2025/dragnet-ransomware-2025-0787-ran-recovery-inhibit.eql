// Dragnet [Ransomware]: dragnet-ransomware-2025-0787 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: d89d929f-b6e9-5b9c-abae-88aa7d33eab8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
