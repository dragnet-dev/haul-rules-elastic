// Dragnet [Ransomware]: dragnet-ransomware-2025-7822 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: a2987e1d-c395-5510-b668-f46f9c884198

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
