// Dragnet [Ransomware]: dragnet-ransomware-2025-7036 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 91477a12-5415-562d-802d-41d2a2814ab9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
