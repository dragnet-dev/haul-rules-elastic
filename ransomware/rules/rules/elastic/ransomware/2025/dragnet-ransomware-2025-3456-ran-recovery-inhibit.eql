// Dragnet [Ransomware]: dragnet-ransomware-2025-3456 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 989d723d-0253-5026-ae8e-2a5d77452fae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
