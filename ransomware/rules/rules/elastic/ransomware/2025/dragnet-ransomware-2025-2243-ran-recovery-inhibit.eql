// Dragnet [Ransomware]: dragnet-ransomware-2025-2243 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 5cea96aa-b37c-5da6-bc7f-0eca83685e7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
