// Dragnet [Ransomware]: dragnet-ransomware-2025-4140 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: c1e49454-0c60-569e-b78f-8b5a5eabee69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
