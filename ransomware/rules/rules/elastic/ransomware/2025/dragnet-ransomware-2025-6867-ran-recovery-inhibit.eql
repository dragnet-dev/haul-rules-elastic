// Dragnet [Ransomware]: dragnet-ransomware-2025-6867 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: 4c21a9b3-eb7f-58cd-bdde-ca3e209d7e8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
