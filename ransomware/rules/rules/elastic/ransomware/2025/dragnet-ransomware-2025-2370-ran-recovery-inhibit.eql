// Dragnet [Ransomware]: dragnet-ransomware-2025-2370 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: dc255c92-6f82-56c6-87fa-5491110944cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
