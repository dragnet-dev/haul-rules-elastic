// Dragnet [Ransomware]: dragnet-ransomware-2025-7645 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: cd1cfd42-9e22-58cb-aaf6-0b5ef932133d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
