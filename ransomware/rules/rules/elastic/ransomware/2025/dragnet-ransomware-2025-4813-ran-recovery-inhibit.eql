// Dragnet [Ransomware]: dragnet-ransomware-2025-4813 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: bb67ac2f-7783-5512-b35e-dff9749060f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
