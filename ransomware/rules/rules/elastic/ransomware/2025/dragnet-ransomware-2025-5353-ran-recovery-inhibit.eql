// Dragnet [Ransomware]: dragnet-ransomware-2025-5353 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 9bcbe358-2be7-570f-ae72-8af0fec5baba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
