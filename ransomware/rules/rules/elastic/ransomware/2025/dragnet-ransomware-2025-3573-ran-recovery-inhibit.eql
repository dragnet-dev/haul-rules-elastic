// Dragnet [Ransomware]: dragnet-ransomware-2025-3573 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: fb061496-b319-5abc-965d-4a1f6347e181

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
