// Dragnet [Ransomware]: dragnet-ransomware-2025-3632 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 2a22fd11-0272-5535-b044-aa50486a3a3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
