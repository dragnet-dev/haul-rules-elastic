// Dragnet [Ransomware]: dragnet-ransomware-2025-2437 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 24a22ccb-1f5f-51bf-9f28-1b6ae1837644

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
