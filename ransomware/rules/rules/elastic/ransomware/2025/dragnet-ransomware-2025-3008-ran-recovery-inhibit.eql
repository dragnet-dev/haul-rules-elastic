// Dragnet [Ransomware]: dragnet-ransomware-2025-3008 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: a7eef402-f823-577d-ad50-2ca016c89a29

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
