// Dragnet [Ransomware]: dragnet-ransomware-2025-4439 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 40323b9a-3950-505a-acd3-96a372b4256a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
