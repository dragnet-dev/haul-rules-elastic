// Dragnet [Ransomware]: dragnet-ransomware-2025-2750 — Recovery Inhibition (teamxxx)
// Status: experimental | Level: high | ID: 91fbd39a-892b-5714-87e7-f3f29d78395f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
