// Dragnet [Ransomware]: dragnet-ransomware-2025-6021 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: bef16640-ca07-5013-adc0-5d00631bb8e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
