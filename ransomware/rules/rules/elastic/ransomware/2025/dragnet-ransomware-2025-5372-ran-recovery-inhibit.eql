// Dragnet [Ransomware]: dragnet-ransomware-2025-5372 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 115455d4-6c1d-5e69-81d4-42bd582f2a85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
