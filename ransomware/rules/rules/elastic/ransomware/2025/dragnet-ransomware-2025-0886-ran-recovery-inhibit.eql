// Dragnet [Ransomware]: dragnet-ransomware-2025-0886 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 84b25009-73b6-5aa0-9669-1c2bde94e934

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
