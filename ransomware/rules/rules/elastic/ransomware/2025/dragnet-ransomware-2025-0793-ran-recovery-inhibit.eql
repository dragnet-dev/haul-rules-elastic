// Dragnet [Ransomware]: dragnet-ransomware-2025-0793 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: cf18ee1e-cd1c-5612-9614-ed2d3c1ae0c8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
