// Dragnet [Ransomware]: dragnet-ransomware-2025-5419 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 80cca2c0-9b05-58f9-a1da-540732247322

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
