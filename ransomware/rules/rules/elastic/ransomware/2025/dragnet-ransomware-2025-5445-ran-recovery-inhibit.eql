// Dragnet [Ransomware]: dragnet-ransomware-2025-5445 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: adf54dd4-9a2a-5007-8c46-bf4eafae50be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
