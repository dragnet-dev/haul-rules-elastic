// Dragnet [Ransomware]: dragnet-ransomware-2025-6939 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 31e658e2-6dd4-5ca5-aaa7-c2df1d42ad69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
