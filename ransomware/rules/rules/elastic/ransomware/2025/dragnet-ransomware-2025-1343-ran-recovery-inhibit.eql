// Dragnet [Ransomware]: dragnet-ransomware-2025-1343 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 47f104dd-e36a-5984-9b25-68cfaf1f24b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
