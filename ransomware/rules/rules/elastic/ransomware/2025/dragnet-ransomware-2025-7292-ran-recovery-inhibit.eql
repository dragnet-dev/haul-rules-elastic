// Dragnet [Ransomware]: dragnet-ransomware-2025-7292 — Recovery Inhibition (frag)
// Status: deprecated | Level: high | ID: 5149e7f5-e4ad-500a-a128-71714ad63108

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
