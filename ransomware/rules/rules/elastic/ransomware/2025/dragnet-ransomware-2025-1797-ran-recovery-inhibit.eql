// Dragnet [Ransomware]: dragnet-ransomware-2025-1797 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: deceda7f-f0dc-5708-9763-f54f4594cb36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
