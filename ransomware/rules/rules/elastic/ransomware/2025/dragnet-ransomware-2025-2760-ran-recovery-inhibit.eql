// Dragnet [Ransomware]: dragnet-ransomware-2025-2760 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: 8f1b04f0-b0c2-53ad-8655-e2f081540b78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
