// Dragnet [Ransomware]: dragnet-ransomware-2025-2509 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 30615883-42a6-5c7f-a603-bc9dcd854b96

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
