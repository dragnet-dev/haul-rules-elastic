// Dragnet [Ransomware]: dragnet-ransomware-2025-6217 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 7a601cfb-2cb6-5f0a-9fb3-7a3575ab4313

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
