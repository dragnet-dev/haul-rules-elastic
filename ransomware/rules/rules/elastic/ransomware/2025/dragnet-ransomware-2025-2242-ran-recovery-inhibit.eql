// Dragnet [Ransomware]: dragnet-ransomware-2025-2242 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6ca62f6f-3765-5b7d-bf0c-ee0c6572d610

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
