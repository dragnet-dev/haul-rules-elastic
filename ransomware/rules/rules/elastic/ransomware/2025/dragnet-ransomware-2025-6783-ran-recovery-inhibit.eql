// Dragnet [Ransomware]: dragnet-ransomware-2025-6783 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 56a8b483-e11e-5a70-b23d-01dc27922c2f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
