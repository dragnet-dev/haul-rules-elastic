// Dragnet [Ransomware]: dragnet-ransomware-2025-4870 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 2c7d2e63-64b1-5337-8b95-9de901f191ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
