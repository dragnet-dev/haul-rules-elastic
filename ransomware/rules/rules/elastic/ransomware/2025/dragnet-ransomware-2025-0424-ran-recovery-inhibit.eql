// Dragnet [Ransomware]: dragnet-ransomware-2025-0424 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4db10397-0809-585a-928a-622daf30beb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
