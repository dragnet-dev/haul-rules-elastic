// Dragnet [Ransomware]: dragnet-ransomware-2025-6343 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 586a555b-6178-5d82-b6c4-23c1e69d0148

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
