// Dragnet [Ransomware]: dragnet-ransomware-2025-1137 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 9a1c061b-7c3e-5265-9933-52909d986904

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
