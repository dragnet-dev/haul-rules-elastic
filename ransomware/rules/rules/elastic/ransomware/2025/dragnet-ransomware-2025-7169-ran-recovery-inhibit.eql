// Dragnet [Ransomware]: dragnet-ransomware-2025-7169 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 1919981b-6f82-57b2-9d72-83f062009ea8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
