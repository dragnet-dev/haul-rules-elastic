// Dragnet [Ransomware]: dragnet-ransomware-2025-3353 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: f19827a4-62de-52e3-aa5d-e8f3ec0bb7f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
