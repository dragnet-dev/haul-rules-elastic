// Dragnet [Ransomware]: dragnet-ransomware-2025-0420 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 685c5c9a-f063-5e53-9454-5efb7a0de9df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
