// Dragnet [Ransomware]: dragnet-ransomware-2025-2263 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 16d54458-4d7b-50b6-a5f8-0609f4e45a9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
