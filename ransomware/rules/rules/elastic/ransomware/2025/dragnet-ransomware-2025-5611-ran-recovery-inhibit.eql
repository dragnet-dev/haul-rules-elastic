// Dragnet [Ransomware]: dragnet-ransomware-2025-5611 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 62c6a0c1-b5ec-570f-92d1-a4c976e60ef9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
