// Dragnet [Ransomware]: dragnet-ransomware-2025-3460 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: 40948161-d049-57d4-b6c8-029b60adad39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
