// Dragnet [Ransomware]: dragnet-ransomware-2025-7076 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 18227f4c-079c-51bb-892e-52c2760cf8ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
