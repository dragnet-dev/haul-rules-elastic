// Dragnet [Ransomware]: dragnet-ransomware-2025-5843 — Recovery Inhibition (gunra)
// Status: experimental | Level: high | ID: 7bdcd486-9ba3-5ee0-b2db-02c9383d49a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
