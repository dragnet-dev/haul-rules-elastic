// Dragnet [Ransomware]: dragnet-ransomware-2025-3645 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: e2240ac7-ad68-5691-8cdc-b4f3398f4c57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
