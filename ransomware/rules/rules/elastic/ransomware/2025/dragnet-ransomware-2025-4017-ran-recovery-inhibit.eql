// Dragnet [Ransomware]: dragnet-ransomware-2025-4017 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ee533de7-e70f-5317-b804-76069579afdc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
