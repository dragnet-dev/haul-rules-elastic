// Dragnet [Ransomware]: dragnet-ransomware-2025-0671 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d910db74-34f9-5543-aafa-d21e9809dc8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
