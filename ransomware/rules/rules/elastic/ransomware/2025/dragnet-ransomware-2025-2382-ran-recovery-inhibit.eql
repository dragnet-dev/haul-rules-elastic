// Dragnet [Ransomware]: dragnet-ransomware-2025-2382 — Recovery Inhibition (obscura)
// Status: experimental | Level: high | ID: db2cfb5f-d1ba-5fe0-b6f3-1ebdddefbdfa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
