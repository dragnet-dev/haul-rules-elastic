// Dragnet [Ransomware]: dragnet-ransomware-2025-0561 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: 4c1547cf-ec5f-5d43-bfa5-4e707b324ea9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
