// Dragnet [Ransomware]: dragnet-ransomware-2025-6429 — Recovery Inhibition (skira)
// Status: experimental | Level: high | ID: 49533f92-38e7-528e-80e1-34185de8329f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
