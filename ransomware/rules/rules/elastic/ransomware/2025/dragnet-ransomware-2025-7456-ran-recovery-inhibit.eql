// Dragnet [Ransomware]: dragnet-ransomware-2025-7456 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 680ef35c-0050-56f7-a821-093e82cd70fd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
