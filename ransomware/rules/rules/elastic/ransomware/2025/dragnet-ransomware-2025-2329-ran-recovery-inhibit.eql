// Dragnet [Ransomware]: dragnet-ransomware-2025-2329 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 730362f1-4e93-5010-b43c-cbb9f39fe720

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
