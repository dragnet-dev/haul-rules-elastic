// Dragnet [Ransomware]: dragnet-ransomware-2025-4681 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 7fe4dfa5-aeef-55e8-b41d-ea24bd2512f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
