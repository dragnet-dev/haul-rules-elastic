// Dragnet [Ransomware]: dragnet-ransomware-2025-6536 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: f1ea2383-fc17-5af5-8e3d-164ae5c0c240

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
