// Dragnet [Ransomware]: dragnet-ransomware-2025-2631 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: b1fd0431-c70d-5ede-b8fb-d10dba64a5a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
