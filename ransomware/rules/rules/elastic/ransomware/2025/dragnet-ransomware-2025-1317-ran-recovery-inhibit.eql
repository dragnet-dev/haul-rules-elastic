// Dragnet [Ransomware]: dragnet-ransomware-2025-1317 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 27975c75-52c1-5786-a681-792072a8d63e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
