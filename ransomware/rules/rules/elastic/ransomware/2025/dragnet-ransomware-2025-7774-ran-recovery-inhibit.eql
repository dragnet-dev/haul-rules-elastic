// Dragnet [Ransomware]: dragnet-ransomware-2025-7774 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: f22c472c-816c-530d-879c-654a00552a55

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
