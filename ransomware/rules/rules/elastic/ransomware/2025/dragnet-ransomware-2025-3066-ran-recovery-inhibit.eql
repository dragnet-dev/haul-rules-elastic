// Dragnet [Ransomware]: dragnet-ransomware-2025-3066 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 39cb71b0-1755-5593-8d2f-91c07232d6aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
