// Dragnet [Ransomware]: dragnet-ransomware-2025-6089 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 707c1b8c-dd79-529b-967d-4193afe9a297

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
