// Dragnet [Ransomware]: dragnet-ransomware-2025-5788 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 30edb91a-0b53-5b69-a140-6f6edec3eb9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
