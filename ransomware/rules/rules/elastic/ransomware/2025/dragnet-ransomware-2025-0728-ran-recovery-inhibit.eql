// Dragnet [Ransomware]: dragnet-ransomware-2025-0728 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 5f8a182b-1855-553b-b808-079b8c98a0c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
