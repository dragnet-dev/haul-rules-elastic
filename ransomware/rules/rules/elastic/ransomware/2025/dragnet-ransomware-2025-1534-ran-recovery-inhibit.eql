// Dragnet [Ransomware]: dragnet-ransomware-2025-1534 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 5fd3716c-1c43-5224-8c62-8ea90376d105

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
