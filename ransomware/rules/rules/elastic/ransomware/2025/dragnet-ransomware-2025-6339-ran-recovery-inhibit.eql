// Dragnet [Ransomware]: dragnet-ransomware-2025-6339 — Recovery Inhibition (ALP-001)
// Status: experimental | Level: high | ID: 10ea0f6c-61a5-5adf-b268-e63455e7928c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
