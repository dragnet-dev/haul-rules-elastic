// Dragnet [Ransomware]: dragnet-ransomware-2025-4505 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: b5d4a671-1393-54be-bedc-304340c1b273

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
