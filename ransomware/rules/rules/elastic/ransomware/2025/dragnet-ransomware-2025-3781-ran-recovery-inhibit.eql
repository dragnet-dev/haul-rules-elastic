// Dragnet [Ransomware]: dragnet-ransomware-2025-3781 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b88b36d6-3a6a-5df9-b518-b9fc3833e56c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
