// Dragnet [Ransomware]: dragnet-ransomware-2025-4100 — Recovery Inhibition (moneymessage)
// Status: experimental | Level: high | ID: 11c89f2b-c0c6-5686-b1ad-431ac3e1436a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
