// Dragnet [Ransomware]: dragnet-ransomware-2025-5385 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: b2967fa5-746c-557a-9d10-de128087d85b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
