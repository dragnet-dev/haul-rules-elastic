// Dragnet [Ransomware]: dragnet-ransomware-2025-4648 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 47c83978-5dc5-52af-b955-e606c5648b32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
