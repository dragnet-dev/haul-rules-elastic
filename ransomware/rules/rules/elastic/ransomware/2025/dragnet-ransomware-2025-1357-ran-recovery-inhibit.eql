// Dragnet [Ransomware]: dragnet-ransomware-2025-1357 — Recovery Inhibition (worldleaks)
// Status: test | Level: high | ID: 1399879b-3149-55bb-a33f-58510f7d93e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
