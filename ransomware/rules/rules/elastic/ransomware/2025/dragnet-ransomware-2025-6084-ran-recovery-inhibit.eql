// Dragnet [Ransomware]: dragnet-ransomware-2025-6084 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 53f47136-f0ea-5e10-ad87-12d63fe0dbf6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
