// Dragnet [Ransomware]: dragnet-ransomware-2025-4231 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 750a7c78-0d2c-5299-a853-7c3733ee338e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
