// Dragnet [Ransomware]: dragnet-ransomware-2025-4768 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 15c2cadb-4ddd-5d3c-8c44-ca81e49cc9c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
