// Dragnet [Ransomware]: dragnet-ransomware-2025-6621 — Recovery Inhibition (genesis)
// Status: test | Level: high | ID: 845bc36b-9e94-5471-9a74-d5cfd73c5228

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
