// Dragnet [Ransomware]: dragnet-ransomware-2025-3475 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: ea7b53a6-6e41-5062-9e4c-755d06e12680

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
