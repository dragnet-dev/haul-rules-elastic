// Dragnet [Ransomware]: dragnet-ransomware-2025-1260 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9ec546e9-f99c-5dc0-9cfe-ea5359968651

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
