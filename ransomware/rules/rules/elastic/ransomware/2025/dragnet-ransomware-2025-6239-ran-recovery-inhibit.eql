// Dragnet [Ransomware]: dragnet-ransomware-2025-6239 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 3c205b63-b4d0-5693-892e-8dc0b80e0f20

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
