// Dragnet [Ransomware]: dragnet-ransomware-2025-0633 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c93faede-fd7f-52c7-84b9-a014d2c3d3cc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
