// Dragnet [Ransomware]: dragnet-ransomware-2025-0704 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: ee3c9d5f-8bf2-5851-b7e0-30a5691ed904

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
