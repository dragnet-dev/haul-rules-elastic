// Dragnet [Ransomware]: dragnet-ransomware-2025-1668 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cfcb1ece-e343-5eb5-8877-efb86cd73287

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
