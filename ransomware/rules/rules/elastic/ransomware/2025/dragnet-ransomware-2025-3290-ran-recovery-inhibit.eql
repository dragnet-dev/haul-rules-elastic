// Dragnet [Ransomware]: dragnet-ransomware-2025-3290 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 082a9d0d-9ba6-56da-a404-f79041d15f33

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
