// Dragnet [Ransomware]: dragnet-ransomware-2025-7626 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 60f472bd-d560-5309-98c3-f99f3e4f1537

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
