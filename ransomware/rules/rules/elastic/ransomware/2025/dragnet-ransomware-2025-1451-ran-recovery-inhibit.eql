// Dragnet [Ransomware]: dragnet-ransomware-2025-1451 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 2c4f5ef3-ceda-55ad-9e36-421c4b37a593

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
