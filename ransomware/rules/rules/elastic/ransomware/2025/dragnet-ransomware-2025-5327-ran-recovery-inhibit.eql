// Dragnet [Ransomware]: dragnet-ransomware-2025-5327 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a0de4f7c-13d9-58d3-be2e-6c5a7d7b5aaf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
