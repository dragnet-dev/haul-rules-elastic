// Dragnet [Ransomware]: dragnet-ransomware-2025-4258 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6d236e58-4083-5421-89f1-896fd71d7677

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
