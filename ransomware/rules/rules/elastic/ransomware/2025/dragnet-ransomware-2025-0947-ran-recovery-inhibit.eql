// Dragnet [Ransomware]: dragnet-ransomware-2025-0947 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: ecadbd46-79d5-5215-bd0a-3e0fb61325aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
