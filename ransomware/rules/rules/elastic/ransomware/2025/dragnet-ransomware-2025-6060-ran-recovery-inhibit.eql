// Dragnet [Ransomware]: dragnet-ransomware-2025-6060 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9e763ea9-199e-5f1a-999b-b387f3ad72d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
