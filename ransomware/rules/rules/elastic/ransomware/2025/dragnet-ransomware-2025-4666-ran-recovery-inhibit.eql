// Dragnet [Ransomware]: dragnet-ransomware-2025-4666 — Recovery Inhibition (genesis)
// Status: experimental | Level: high | ID: 310df274-0cc9-511a-8918-210f246fe8b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
