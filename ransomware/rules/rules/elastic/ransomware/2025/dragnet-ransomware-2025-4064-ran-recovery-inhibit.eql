// Dragnet [Ransomware]: dragnet-ransomware-2025-4064 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 97a8ff48-23cb-597f-a680-f18959175095

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
