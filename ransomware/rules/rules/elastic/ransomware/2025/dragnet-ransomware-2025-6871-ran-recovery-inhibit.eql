// Dragnet [Ransomware]: dragnet-ransomware-2025-6871 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 0162e599-160b-5f10-b451-7c64a34cf970

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
