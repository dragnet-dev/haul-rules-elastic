// Dragnet [Ransomware]: dragnet-ransomware-2025-0962 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 9b249a82-fe3f-53a5-9ce1-c33e90883411

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
