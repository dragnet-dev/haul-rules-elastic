// Dragnet [Ransomware]: dragnet-ransomware-2025-3983 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0bc7e022-840e-555a-a097-6b46b242cf3d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
