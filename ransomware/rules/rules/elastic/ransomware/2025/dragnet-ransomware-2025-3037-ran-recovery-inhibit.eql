// Dragnet [Ransomware]: dragnet-ransomware-2025-3037 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: de18da09-f626-5f15-b368-a17a9cce704e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
