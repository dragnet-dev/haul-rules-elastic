// Dragnet [Ransomware]: dragnet-ransomware-2025-2960 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 614ddc86-d7e3-5dc2-84af-df0cf4395517

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
