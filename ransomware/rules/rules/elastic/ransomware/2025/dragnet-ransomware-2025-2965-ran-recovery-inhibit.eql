// Dragnet [Ransomware]: dragnet-ransomware-2025-2965 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 5e76f7cb-bf16-5f94-a38e-fe533e2bf946

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
