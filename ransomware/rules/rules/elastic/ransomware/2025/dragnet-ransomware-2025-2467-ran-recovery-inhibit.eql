// Dragnet [Ransomware]: dragnet-ransomware-2025-2467 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 95fe57bc-3090-5c9d-b616-43d6a66b0f94

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
