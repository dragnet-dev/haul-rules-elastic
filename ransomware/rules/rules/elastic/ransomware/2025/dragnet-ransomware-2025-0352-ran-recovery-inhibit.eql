// Dragnet [Ransomware]: dragnet-ransomware-2025-0352 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 39e9acd2-f663-5da1-9133-a369888497a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
