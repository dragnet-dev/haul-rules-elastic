// Dragnet [Ransomware]: dragnet-ransomware-2025-1069 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 14b6b213-77b9-518f-8233-a8211615aba9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
