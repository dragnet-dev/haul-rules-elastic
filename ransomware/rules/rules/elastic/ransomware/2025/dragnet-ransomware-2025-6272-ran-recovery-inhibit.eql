// Dragnet [Ransomware]: dragnet-ransomware-2025-6272 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: da5a8bc9-89c2-555f-abd6-6fe9a332f0a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
