// Dragnet [Ransomware]: dragnet-ransomware-2025-0918 — Recovery Inhibition (ransomhouse)
// Status: test | Level: high | ID: ac979afc-b313-5392-a8ab-bda84b5be982

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
