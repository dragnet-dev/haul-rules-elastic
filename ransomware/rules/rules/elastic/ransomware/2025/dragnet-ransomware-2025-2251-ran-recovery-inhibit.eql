// Dragnet [Ransomware]: dragnet-ransomware-2025-2251 — Recovery Inhibition (RunSomeWares)
// Status: experimental | Level: high | ID: 7c5f9654-2dc5-56ca-a809-a9c450e451aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
