// Dragnet [Ransomware]: dragnet-ransomware-2025-3940 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: b6810bd8-230a-56cd-8012-a026e04c5ace

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
