// Dragnet [Ransomware]: dragnet-ransomware-2025-5100 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 5321685f-7be3-5e8f-940d-9133ec9d6d9c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
