// Dragnet [Ransomware]: dragnet-ransomware-2025-3552 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 1b18798f-89f7-5400-a4f9-f55e61a8eaf0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
