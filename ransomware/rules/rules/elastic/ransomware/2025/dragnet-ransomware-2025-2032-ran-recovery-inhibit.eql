// Dragnet [Ransomware]: dragnet-ransomware-2025-2032 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 31fa7756-680f-5c98-8433-3dde8e078eb0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
