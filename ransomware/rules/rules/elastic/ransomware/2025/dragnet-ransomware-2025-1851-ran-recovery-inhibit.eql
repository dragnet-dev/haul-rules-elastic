// Dragnet [Ransomware]: dragnet-ransomware-2025-1851 — Recovery Inhibition (brotherhood)
// Status: experimental | Level: high | ID: d1d12a79-764d-5f0e-875e-af68d6638524

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
