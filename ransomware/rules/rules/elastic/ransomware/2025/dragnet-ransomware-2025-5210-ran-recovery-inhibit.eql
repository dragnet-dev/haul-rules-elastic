// Dragnet [Ransomware]: dragnet-ransomware-2025-5210 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 99d826e1-a54e-5fec-ad2f-7afa71f59a6a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
