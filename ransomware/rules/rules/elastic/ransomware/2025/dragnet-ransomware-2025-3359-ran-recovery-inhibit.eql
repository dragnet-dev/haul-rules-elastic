// Dragnet [Ransomware]: dragnet-ransomware-2025-3359 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: fafe4248-3316-556e-839c-fe3627ec1b31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
