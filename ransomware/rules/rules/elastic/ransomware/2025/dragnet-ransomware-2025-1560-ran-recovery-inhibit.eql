// Dragnet [Ransomware]: dragnet-ransomware-2025-1560 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: ad260a4e-5962-5374-b631-883b9970de8b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
