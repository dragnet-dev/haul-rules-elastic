// Dragnet [Ransomware]: dragnet-ransomware-2025-0558 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: da37f62a-8442-513d-a8b5-9e5ad0cdac9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
