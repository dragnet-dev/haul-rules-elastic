// Dragnet [Ransomware]: dragnet-ransomware-2025-2497 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3df232af-20a6-533f-bf73-7eb6e1ce0638

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
