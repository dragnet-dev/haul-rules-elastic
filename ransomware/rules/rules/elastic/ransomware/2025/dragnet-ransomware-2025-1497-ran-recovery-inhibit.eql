// Dragnet [Ransomware]: dragnet-ransomware-2025-1497 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 9c3adfd0-bd58-5ad9-8faf-7f4f78c32622

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
