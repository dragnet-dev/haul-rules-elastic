// Dragnet [Ransomware]: dragnet-ransomware-2025-6586 — Recovery Inhibition (stormous)
// Status: deprecated | Level: high | ID: 89027db1-ef8f-55e3-8606-49f0b91c1395

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
