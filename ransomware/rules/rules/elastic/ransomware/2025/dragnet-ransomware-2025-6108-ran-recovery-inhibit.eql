// Dragnet [Ransomware]: dragnet-ransomware-2025-6108 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 73d852fc-025a-5c15-8634-6382ef504e7e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
