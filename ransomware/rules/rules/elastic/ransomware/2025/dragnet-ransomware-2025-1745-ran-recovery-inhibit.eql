// Dragnet [Ransomware]: dragnet-ransomware-2025-1745 — Recovery Inhibition (radar)
// Status: deprecated | Level: high | ID: cc643e05-7ace-50f7-8160-95f148f3a461

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
