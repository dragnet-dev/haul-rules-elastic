// Dragnet [Ransomware]: dragnet-ransomware-2025-6200 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 58d5734e-e898-5e8f-92f5-afdcffe2e051

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
