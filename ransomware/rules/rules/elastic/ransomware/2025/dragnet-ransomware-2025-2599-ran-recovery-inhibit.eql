// Dragnet [Ransomware]: dragnet-ransomware-2025-2599 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 9c538815-b358-5a46-b94c-6400633001da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
