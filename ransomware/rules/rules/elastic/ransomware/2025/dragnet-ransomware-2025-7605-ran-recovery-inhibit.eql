// Dragnet [Ransomware]: dragnet-ransomware-2025-7605 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 48b26ae1-cc06-5a60-a2be-eeabaf7758e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
