// Dragnet [Ransomware]: dragnet-ransomware-2025-5522 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 20945859-77fb-5782-b230-475b810f4df9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
