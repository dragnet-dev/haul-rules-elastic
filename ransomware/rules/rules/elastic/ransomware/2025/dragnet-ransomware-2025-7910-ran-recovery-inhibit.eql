// Dragnet [Ransomware]: dragnet-ransomware-2025-7910 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 09536f21-67b6-5920-8350-7e7d7755fb3e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
