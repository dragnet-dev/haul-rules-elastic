// Dragnet [Ransomware]: dragnet-ransomware-2025-5149 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: e9b00b79-d4ee-547e-8b79-8e8685d07c88

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
