// Dragnet [Ransomware]: dragnet-ransomware-2025-1652 — Recovery Inhibition (stormous)
// Status: experimental | Level: high | ID: c9a64177-c599-50f4-a6ae-a990870d0f9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
