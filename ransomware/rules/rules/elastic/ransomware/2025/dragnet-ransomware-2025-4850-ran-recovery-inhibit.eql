// Dragnet [Ransomware]: dragnet-ransomware-2025-4850 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0e3c0387-dcbb-54f6-b6a2-55ec789a9de9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
