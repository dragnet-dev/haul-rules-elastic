// Dragnet [Ransomware]: dragnet-ransomware-2025-6149 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: 034b6f0e-d54d-5d16-a49f-76ba0cc1b7ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
