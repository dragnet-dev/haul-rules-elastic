// Dragnet [Ransomware]: dragnet-ransomware-2025-2367 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: f5d6246b-c222-5df6-ad7d-53903b5c5a87

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
