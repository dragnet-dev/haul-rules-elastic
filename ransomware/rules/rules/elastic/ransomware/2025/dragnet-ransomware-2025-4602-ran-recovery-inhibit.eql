// Dragnet [Ransomware]: dragnet-ransomware-2025-4602 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 9d942c47-1f6c-5211-8535-db1bb5aadf2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
