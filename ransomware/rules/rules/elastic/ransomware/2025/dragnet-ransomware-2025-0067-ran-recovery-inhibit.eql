// Dragnet [Ransomware]: dragnet-ransomware-2025-0067 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 51e9796f-d798-5c00-80b1-801f3b0fd378

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
