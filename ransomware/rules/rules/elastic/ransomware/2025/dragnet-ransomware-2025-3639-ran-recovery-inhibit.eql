// Dragnet [Ransomware]: dragnet-ransomware-2025-3639 — Recovery Inhibition (cactus)
// Status: deprecated | Level: high | ID: 92e32d4e-a878-534b-8b4b-739898983f32

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
