// Dragnet [Ransomware]: dragnet-ransomware-2025-6061 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ad103bcb-0465-526d-9b2d-414d8676e096

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
