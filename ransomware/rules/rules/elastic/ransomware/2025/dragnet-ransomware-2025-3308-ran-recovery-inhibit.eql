// Dragnet [Ransomware]: dragnet-ransomware-2025-3308 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 8150eb83-299f-568e-9b22-f5c5f3efe165

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
