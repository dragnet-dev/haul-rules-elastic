// Dragnet [Ransomware]: dragnet-ransomware-2025-4663 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 083fe22d-0715-5503-8d3d-45d12705497f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
