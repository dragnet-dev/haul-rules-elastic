// Dragnet [Ransomware]: dragnet-ransomware-2025-7698 — Recovery Inhibition (benzona)
// Status: deprecated | Level: high | ID: 4c6dd651-8cc8-5d7d-bf2e-3bcac6586a53

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
