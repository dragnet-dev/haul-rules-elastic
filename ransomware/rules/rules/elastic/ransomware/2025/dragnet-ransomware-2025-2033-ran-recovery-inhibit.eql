// Dragnet [Ransomware]: dragnet-ransomware-2025-2033 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 962359a9-90aa-5e11-96f2-ae42d81b17b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
