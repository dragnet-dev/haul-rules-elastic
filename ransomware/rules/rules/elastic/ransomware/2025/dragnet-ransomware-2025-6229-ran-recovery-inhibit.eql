// Dragnet [Ransomware]: dragnet-ransomware-2025-6229 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: a33211e2-e231-5fc4-a3fe-53c0a03bfa49

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
