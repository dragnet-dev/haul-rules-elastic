// Dragnet [Ransomware]: dragnet-ransomware-2025-5834 — Recovery Inhibition (trinity)
// Status: experimental | Level: high | ID: 360a445b-cbdf-5236-a641-2a8a47c97e71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
