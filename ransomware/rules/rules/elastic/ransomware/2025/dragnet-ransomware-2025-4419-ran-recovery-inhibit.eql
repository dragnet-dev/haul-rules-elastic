// Dragnet [Ransomware]: dragnet-ransomware-2025-4419 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1a2bf06f-5da3-506e-bc79-6a0cdf4b2ed2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
