// Dragnet [Ransomware]: dragnet-ransomware-2025-0954 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4f33ef33-c7e0-5d16-960b-622d07bda6bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
