// Dragnet [Ransomware]: dragnet-ransomware-2025-6064 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 0acce119-dd63-5d8c-8636-4055dc3e0118

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
