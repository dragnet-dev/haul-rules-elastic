// Dragnet [Ransomware]: dragnet-ransomware-2025-6774 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 14dacfc9-4a14-54ce-a77c-9629b1dad5c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
