// Dragnet [Ransomware]: dragnet-ransomware-2025-6574 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3106f06f-bd72-57af-b0c4-b1edf742145f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
