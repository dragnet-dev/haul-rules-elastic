// Dragnet [Ransomware]: dragnet-ransomware-2025-2188 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 9ccb86e9-c468-5cf2-9fdb-291ccfaf8048

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
