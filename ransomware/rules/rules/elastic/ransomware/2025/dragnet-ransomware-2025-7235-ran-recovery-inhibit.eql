// Dragnet [Ransomware]: dragnet-ransomware-2025-7235 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: 0571670e-bc82-5389-aeb9-a349d976db30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
