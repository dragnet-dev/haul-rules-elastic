// Dragnet [Ransomware]: dragnet-ransomware-2025-0916 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 912dbec7-28d3-59bc-a809-ac7cd2f658d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
