// Dragnet [Ransomware]: dragnet-ransomware-2025-2377 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 6794bb3b-7f01-56be-a4a7-5ca000c22442

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
