// Dragnet [Ransomware]: dragnet-ransomware-2025-1101 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: a487a5d4-6558-5c0e-bf35-8ff96f81debd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
