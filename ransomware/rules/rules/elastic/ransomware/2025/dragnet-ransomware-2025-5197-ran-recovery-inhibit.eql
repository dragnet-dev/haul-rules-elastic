// Dragnet [Ransomware]: dragnet-ransomware-2025-5197 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 54d07fcc-0586-58db-a402-29ccaa628296

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
