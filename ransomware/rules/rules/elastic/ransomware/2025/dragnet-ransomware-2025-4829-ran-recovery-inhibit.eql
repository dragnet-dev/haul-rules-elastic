// Dragnet [Ransomware]: dragnet-ransomware-2025-4829 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 47de3de9-09ac-5e58-91cc-f7b8cf8d05dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
