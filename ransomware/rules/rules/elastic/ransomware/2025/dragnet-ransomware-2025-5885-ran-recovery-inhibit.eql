// Dragnet [Ransomware]: dragnet-ransomware-2025-5885 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 56a20d11-0128-5663-b127-a783ca6c8db7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
