// Dragnet [Ransomware]: dragnet-ransomware-2025-4208 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: ab5e4863-b3cd-5aaa-89d5-9283920fdf92

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
