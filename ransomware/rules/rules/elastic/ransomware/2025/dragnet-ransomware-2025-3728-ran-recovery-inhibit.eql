// Dragnet [Ransomware]: dragnet-ransomware-2025-3728 — Recovery Inhibition (apos)
// Status: deprecated | Level: high | ID: 2c3632a7-713a-5684-a702-460f05c3a800

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
