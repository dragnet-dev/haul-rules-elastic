// Dragnet [Ransomware]: dragnet-ransomware-2025-4357 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 08fba748-21e8-5028-b45b-e8469d90590b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
