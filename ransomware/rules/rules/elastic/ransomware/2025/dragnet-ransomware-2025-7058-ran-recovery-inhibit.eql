// Dragnet [Ransomware]: dragnet-ransomware-2025-7058 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b2c556ea-64f2-5681-bec9-3c64aa05c0c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
