// Dragnet [Ransomware]: dragnet-ransomware-2025-7693 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: b9eaa988-e7d4-5a0d-8805-ce74bd99b85b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
