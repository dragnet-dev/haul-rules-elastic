// Dragnet [Ransomware]: dragnet-ransomware-2025-4908 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 12cfc0b8-5930-5a21-bbee-18f4784151f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
