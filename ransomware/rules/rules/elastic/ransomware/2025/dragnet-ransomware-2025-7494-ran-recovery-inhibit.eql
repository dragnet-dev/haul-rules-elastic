// Dragnet [Ransomware]: dragnet-ransomware-2025-7494 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ac2e67ce-8854-58fe-8af8-d3f974df02a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
