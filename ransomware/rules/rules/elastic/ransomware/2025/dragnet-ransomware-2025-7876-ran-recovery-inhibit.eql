// Dragnet [Ransomware]: dragnet-ransomware-2025-7876 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 0ddecdf4-0e23-56b7-b440-e2a5ea3bd8de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
