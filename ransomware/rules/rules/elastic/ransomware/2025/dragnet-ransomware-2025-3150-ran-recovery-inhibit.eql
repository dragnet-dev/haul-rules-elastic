// Dragnet [Ransomware]: dragnet-ransomware-2025-3150 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e62234e7-34d1-5d9f-8216-2a61aa65e5f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
