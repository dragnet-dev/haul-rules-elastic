// Dragnet [Ransomware]: dragnet-ransomware-2025-6603 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 19e89c01-f043-5e2f-8f47-67eb690823c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
