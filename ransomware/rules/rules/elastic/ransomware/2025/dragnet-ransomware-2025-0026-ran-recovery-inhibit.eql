// Dragnet [Ransomware]: dragnet-ransomware-2025-0026 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: d09c97c4-abf7-5adf-b745-6fe7d5b730df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
