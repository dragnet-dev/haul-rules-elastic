// Dragnet [Ransomware]: dragnet-ransomware-2025-3241 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 91eb710b-7522-5170-8e41-69547aecf5ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
