// Dragnet [Ransomware]: dragnet-ransomware-2025-4869 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 48fe7e14-24a6-5f98-b66a-6173c7c71cc6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
