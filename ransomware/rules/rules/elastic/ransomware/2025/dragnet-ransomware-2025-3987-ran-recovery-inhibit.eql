// Dragnet [Ransomware]: dragnet-ransomware-2025-3987 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d9301e7b-23d9-529d-9648-e4b9f312cacd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
