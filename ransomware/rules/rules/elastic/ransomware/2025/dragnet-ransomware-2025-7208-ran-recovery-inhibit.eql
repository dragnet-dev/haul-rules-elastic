// Dragnet [Ransomware]: dragnet-ransomware-2025-7208 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 58097cab-f2c6-5b93-a400-f22dbc2bccff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
