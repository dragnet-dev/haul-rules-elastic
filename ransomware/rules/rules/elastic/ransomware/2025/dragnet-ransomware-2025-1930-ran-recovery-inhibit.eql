// Dragnet [Ransomware]: dragnet-ransomware-2025-1930 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4b3504fa-0e4f-5907-8129-583c0d577439

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
