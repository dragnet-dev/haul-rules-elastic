// Dragnet [Ransomware]: dragnet-ransomware-2025-2572 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ce55533f-3b5b-5ee6-8a87-c99a0ce09e9e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
