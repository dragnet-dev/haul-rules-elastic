// Dragnet [Ransomware]: dragnet-ransomware-2025-1383 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 980d2003-2b9c-534c-ba08-e01471628809

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
