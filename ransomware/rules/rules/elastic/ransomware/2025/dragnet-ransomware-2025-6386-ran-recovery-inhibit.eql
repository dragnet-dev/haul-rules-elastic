// Dragnet [Ransomware]: dragnet-ransomware-2025-6386 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 88b39fec-71fc-553f-baaa-1daa5b823839

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
