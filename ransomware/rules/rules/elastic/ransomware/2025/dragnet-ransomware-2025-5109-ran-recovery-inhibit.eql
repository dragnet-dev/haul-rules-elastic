// Dragnet [Ransomware]: dragnet-ransomware-2025-5109 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 8f49324f-5588-5957-830a-e217cac64c35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
