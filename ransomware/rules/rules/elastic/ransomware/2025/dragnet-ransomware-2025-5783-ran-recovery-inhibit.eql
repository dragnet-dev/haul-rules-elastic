// Dragnet [Ransomware]: dragnet-ransomware-2025-5783 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 993bc131-24ef-5fad-be51-8c37b38655e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
