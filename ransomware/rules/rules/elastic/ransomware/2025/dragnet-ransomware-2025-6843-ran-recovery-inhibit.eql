// Dragnet [Ransomware]: dragnet-ransomware-2025-6843 — Recovery Inhibition (desolator)
// Status: experimental | Level: high | ID: d439654d-f472-5055-8b9b-fb02467deb8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
