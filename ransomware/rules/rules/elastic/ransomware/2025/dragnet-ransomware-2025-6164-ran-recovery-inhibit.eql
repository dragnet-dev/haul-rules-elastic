// Dragnet [Ransomware]: dragnet-ransomware-2025-6164 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: ffbb672c-248f-58ff-aa83-a1e87d66a6a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
