// Dragnet [Ransomware]: dragnet-ransomware-2025-0551 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3932bca9-f26c-5cb9-8b27-644d270052bb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
