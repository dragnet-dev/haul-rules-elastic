// Dragnet [Ransomware]: dragnet-ransomware-2025-3495 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 8869bf56-80ee-510d-bae0-c1a156414a41

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
