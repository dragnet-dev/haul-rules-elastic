// Dragnet [Ransomware]: dragnet-ransomware-2025-2523 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 835ffdea-b74d-5f85-95e0-d08ce1291f6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
