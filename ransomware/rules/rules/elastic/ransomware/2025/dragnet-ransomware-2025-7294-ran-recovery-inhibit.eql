// Dragnet [Ransomware]: dragnet-ransomware-2025-7294 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: d53502df-dadb-5d82-9a92-d4c2a05348ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
