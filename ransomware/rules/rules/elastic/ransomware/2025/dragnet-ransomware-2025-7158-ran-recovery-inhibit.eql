// Dragnet [Ransomware]: dragnet-ransomware-2025-7158 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: eb7235c1-383c-5b61-b3ac-98344c9de8a7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
