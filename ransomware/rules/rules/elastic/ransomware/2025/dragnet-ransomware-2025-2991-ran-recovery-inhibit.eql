// Dragnet [Ransomware]: dragnet-ransomware-2025-2991 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 7b54dbf5-b21c-5539-9af2-e528f6e86c9a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
