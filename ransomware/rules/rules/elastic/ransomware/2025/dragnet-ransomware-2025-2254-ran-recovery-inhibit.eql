// Dragnet [Ransomware]: dragnet-ransomware-2025-2254 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 9efcf151-d986-590b-9655-290328ef58c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
