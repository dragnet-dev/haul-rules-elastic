// Dragnet [Ransomware]: dragnet-ransomware-2025-7628 — Recovery Inhibition (blackshrantac)
// Status: test | Level: high | ID: cd2c43dd-9ab9-5e4b-8653-afb96add3b4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
