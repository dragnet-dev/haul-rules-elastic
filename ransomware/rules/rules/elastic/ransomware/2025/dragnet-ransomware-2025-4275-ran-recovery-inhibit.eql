// Dragnet [Ransomware]: dragnet-ransomware-2025-4275 — Recovery Inhibition (termite)
// Status: experimental | Level: high | ID: 8bc26ed7-4209-5b0e-8f62-804925f1a0ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
