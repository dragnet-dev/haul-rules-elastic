// Dragnet [Ransomware]: dragnet-ransomware-2025-0068 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6df9d44c-e517-516b-badd-8a105034b4c3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
