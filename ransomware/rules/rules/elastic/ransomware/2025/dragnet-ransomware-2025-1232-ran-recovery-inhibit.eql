// Dragnet [Ransomware]: dragnet-ransomware-2025-1232 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 73dfaa0a-8d7e-5cde-bae0-222fe43865cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
