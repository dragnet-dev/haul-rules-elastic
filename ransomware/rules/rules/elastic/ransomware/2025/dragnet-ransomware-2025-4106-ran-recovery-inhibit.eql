// Dragnet [Ransomware]: dragnet-ransomware-2025-4106 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ab5e510c-98c5-52a3-8126-58c10f29036f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
