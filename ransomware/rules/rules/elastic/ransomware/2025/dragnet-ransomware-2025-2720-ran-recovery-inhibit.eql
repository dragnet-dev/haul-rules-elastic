// Dragnet [Ransomware]: dragnet-ransomware-2025-2720 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 37baf88f-5ebf-5d13-bb41-7825dd42f5df

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
