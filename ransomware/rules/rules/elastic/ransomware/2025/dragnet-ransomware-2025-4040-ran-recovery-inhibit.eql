// Dragnet [Ransomware]: dragnet-ransomware-2025-4040 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: adfdb75a-23f5-5e9d-b4de-b91bf33079f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
