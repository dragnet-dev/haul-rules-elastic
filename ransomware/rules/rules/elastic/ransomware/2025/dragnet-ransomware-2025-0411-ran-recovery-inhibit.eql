// Dragnet [Ransomware]: dragnet-ransomware-2025-0411 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: ebf41ca8-1c3d-54cf-a8c3-689319c8dc4b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
