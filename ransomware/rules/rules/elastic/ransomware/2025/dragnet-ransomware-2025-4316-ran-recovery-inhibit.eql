// Dragnet [Ransomware]: dragnet-ransomware-2025-4316 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 369abefe-4723-5b34-b376-9f56ac7740bd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
