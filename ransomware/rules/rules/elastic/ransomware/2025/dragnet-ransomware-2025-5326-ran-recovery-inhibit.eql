// Dragnet [Ransomware]: dragnet-ransomware-2025-5326 — Recovery Inhibition (obscura)
// Status: experimental | Level: high | ID: 1df5220d-1158-5733-abc9-913ca6ef59c5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
