// Dragnet [Ransomware]: dragnet-ransomware-2025-2703 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a82b7825-5dda-563d-8def-a0a4c40aa448

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
