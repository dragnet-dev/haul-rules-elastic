// Dragnet [Ransomware]: dragnet-ransomware-2025-6069 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 7d926d91-f2a3-55e0-93ff-0a66369d2860

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
