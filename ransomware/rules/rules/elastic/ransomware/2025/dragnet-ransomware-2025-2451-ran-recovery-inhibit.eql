// Dragnet [Ransomware]: dragnet-ransomware-2025-2451 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 96647326-c955-53b2-8d60-f6464026b5fa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
