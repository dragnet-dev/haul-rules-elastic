// Dragnet [Ransomware]: dragnet-ransomware-2025-3964 — Recovery Inhibition (medusalocker)
// Status: experimental | Level: high | ID: 9920292f-c2d6-52f6-ab68-689113b93324

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
