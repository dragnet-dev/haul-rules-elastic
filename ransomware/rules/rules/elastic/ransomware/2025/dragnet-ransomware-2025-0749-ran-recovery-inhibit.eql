// Dragnet [Ransomware]: dragnet-ransomware-2025-0749 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bf2eda2e-cf15-53d5-851a-de4edc5bcbbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
