// Dragnet [Ransomware]: dragnet-ransomware-2025-4200 — Recovery Inhibition (nightspire)
// Status: experimental | Level: high | ID: 195fceb6-d625-584e-8a95-8475b23275f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
