// Dragnet [Ransomware]: dragnet-ransomware-2025-2574 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 26cbed01-4d72-54a6-b8ce-8b315e2049cf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
