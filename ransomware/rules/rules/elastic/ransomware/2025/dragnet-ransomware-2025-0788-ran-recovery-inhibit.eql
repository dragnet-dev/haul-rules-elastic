// Dragnet [Ransomware]: dragnet-ransomware-2025-0788 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: ea2ab276-03d8-5a4d-a3dd-54ad3290f2eb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
