// Dragnet [Ransomware]: dragnet-ransomware-2025-1813 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 32476722-306b-5383-a218-03ed39cd0473

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
