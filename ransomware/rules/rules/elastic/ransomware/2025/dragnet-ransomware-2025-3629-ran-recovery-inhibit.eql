// Dragnet [Ransomware]: dragnet-ransomware-2025-3629 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 756e6be4-e916-5f42-b151-6d310de06659

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
