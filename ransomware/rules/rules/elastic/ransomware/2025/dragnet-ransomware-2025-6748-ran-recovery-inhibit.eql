// Dragnet [Ransomware]: dragnet-ransomware-2025-6748 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 79979237-59df-5999-afea-51cd5958f240

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
