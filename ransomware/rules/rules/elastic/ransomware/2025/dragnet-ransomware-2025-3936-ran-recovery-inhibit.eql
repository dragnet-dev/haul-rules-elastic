// Dragnet [Ransomware]: dragnet-ransomware-2025-3936 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 38186477-3062-5d15-9957-54042940256f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
