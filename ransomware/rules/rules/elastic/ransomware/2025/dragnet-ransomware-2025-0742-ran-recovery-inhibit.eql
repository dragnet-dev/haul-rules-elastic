// Dragnet [Ransomware]: dragnet-ransomware-2025-0742 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: d068ea51-9d09-596d-8337-1600aec168dd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
