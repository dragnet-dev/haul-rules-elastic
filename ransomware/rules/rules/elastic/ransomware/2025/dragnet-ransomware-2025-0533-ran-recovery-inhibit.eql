// Dragnet [Ransomware]: dragnet-ransomware-2025-0533 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: dff7ed90-cdfd-551f-b64f-d1a9bc9411f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
