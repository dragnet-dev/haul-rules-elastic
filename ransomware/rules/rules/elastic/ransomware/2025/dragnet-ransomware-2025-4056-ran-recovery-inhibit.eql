// Dragnet [Ransomware]: dragnet-ransomware-2025-4056 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 34217433-474a-58d9-8b8b-b229058e631e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
