// Dragnet [Ransomware]: dragnet-ransomware-2025-6747 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 12689e1a-867f-5603-8607-1e025b416e22

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
