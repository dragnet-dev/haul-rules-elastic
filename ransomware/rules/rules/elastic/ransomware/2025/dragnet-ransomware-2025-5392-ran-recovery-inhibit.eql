// Dragnet [Ransomware]: dragnet-ransomware-2025-5392 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 58a77fa5-93ad-5445-8bda-45750fc6f13b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
