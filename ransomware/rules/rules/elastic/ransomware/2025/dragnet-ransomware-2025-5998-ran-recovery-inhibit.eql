// Dragnet [Ransomware]: dragnet-ransomware-2025-5998 — Recovery Inhibition (desolator)
// Status: experimental | Level: high | ID: a7320717-5f06-5ac0-bcee-d3716c5fe4d2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
