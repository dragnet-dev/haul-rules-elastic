// Dragnet [Ransomware]: dragnet-ransomware-2025-7491 — Recovery Inhibition (obscura)
// Status: experimental | Level: high | ID: 31572dbf-e1e0-5dc3-9b44-3c7768c141f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
