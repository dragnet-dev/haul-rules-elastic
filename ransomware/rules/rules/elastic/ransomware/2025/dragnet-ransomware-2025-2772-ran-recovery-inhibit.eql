// Dragnet [Ransomware]: dragnet-ransomware-2025-2772 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: d8a3357f-df01-5216-bcd6-815db673dddf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
