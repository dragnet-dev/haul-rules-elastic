// Dragnet [Ransomware]: dragnet-ransomware-2025-5685 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: b49fdc48-cefc-5fa8-9bc4-9d7f1da3f9c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
