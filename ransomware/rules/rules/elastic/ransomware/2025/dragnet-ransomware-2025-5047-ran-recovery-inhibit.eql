// Dragnet [Ransomware]: dragnet-ransomware-2025-5047 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: ad999a9d-3281-5931-bd04-b6cad8263798

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
