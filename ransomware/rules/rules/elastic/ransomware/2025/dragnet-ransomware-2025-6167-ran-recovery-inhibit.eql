// Dragnet [Ransomware]: dragnet-ransomware-2025-6167 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 33b1b419-ea54-5fb4-9deb-54f7b26ee3ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
