// Dragnet [Ransomware]: dragnet-ransomware-2025-2771 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 25ea2cd4-1b47-5998-b1de-87e1c1c2b5a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
