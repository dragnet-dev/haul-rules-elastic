// Dragnet [Ransomware]: dragnet-ransomware-2025-5434 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: a984f7bb-fe02-552d-8181-c27e270bfce6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
