// Dragnet [Ransomware]: dragnet-ransomware-2025-7155 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: d83079a1-9e77-5e75-be21-118ddf8e7501

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
