// Dragnet [Ransomware]: dragnet-ransomware-2025-1948 — Recovery Inhibition (securotrop)
// Status: experimental | Level: high | ID: 255525fe-fa06-5379-bb84-9627507bcd85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
