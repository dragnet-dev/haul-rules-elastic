// Dragnet [Ransomware]: dragnet-ransomware-2025-5494 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 89af0bae-e135-5ce7-8015-0c9a738d0d3a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
