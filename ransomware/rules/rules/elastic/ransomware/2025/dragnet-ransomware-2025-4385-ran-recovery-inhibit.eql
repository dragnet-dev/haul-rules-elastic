// Dragnet [Ransomware]: dragnet-ransomware-2025-4385 — Recovery Inhibition (everest)
// Status: test | Level: high | ID: e13a425e-4891-572b-a5f8-2327966c3100

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
