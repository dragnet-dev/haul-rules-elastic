// Dragnet [Ransomware]: dragnet-ransomware-2025-3295 — Recovery Inhibition (killsec)
// Status: deprecated | Level: high | ID: 25ae3556-80df-5210-9ffc-cf39a35bb35c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
