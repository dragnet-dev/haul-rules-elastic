// Dragnet [Ransomware]: dragnet-ransomware-2025-7589 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 63389647-affd-5e97-8e56-4299a54a1577

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
