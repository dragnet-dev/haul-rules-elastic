// Dragnet [Ransomware]: dragnet-ransomware-2025-5459 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: f3f373f3-1a54-534a-bc6e-2732599d1fe6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
