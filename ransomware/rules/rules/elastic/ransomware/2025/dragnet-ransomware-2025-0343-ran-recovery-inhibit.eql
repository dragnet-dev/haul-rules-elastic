// Dragnet [Ransomware]: dragnet-ransomware-2025-0343 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 848c5564-964a-59e8-bf59-e88253d63071

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
