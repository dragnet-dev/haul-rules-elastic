// Dragnet [Ransomware]: dragnet-ransomware-2025-1845 — Recovery Inhibition (brotherhood)
// Status: experimental | Level: high | ID: e587af93-748e-5724-8ba9-9a327cb3280c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
