// Dragnet [Ransomware]: dragnet-ransomware-2025-7882 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 256f42d8-c4b8-5c2c-883a-f249b9858e38

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
