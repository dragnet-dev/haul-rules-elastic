// Dragnet [Ransomware]: dragnet-ransomware-2025-6805 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 0edd02e3-7b87-5eba-83a6-eb10dfe1ce0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
