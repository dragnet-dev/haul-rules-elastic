// Dragnet [Ransomware]: dragnet-ransomware-2025-3822 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8cb700fa-47f9-5bf0-acf0-251c68b93008

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
