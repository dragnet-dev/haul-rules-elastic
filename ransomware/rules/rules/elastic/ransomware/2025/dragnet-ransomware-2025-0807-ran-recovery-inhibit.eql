// Dragnet [Ransomware]: dragnet-ransomware-2025-0807 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: a22dd760-6f11-5c27-b4f1-1bc25dfb9337

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
