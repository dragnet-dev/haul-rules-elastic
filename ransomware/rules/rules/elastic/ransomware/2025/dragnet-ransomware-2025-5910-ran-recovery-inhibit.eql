// Dragnet [Ransomware]: dragnet-ransomware-2025-5910 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: c0346a1b-e2db-5abd-9f8f-9cfdaa5fdcce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
