// Dragnet [Ransomware]: dragnet-ransomware-2025-1939 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 23a76995-4e07-51e6-ae94-68ec3bff9cbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
