// Dragnet [Ransomware]: dragnet-ransomware-2025-5668 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8c48349a-4b05-513a-bba4-e8927a71ad67

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
