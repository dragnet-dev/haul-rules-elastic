// Dragnet [Ransomware]: dragnet-ransomware-2025-4892 — Recovery Inhibition (handala)
// Status: test | Level: high | ID: 7c927848-4120-59ef-ba22-d795c29e7485

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
