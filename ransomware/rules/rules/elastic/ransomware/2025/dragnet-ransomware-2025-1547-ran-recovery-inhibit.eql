// Dragnet [Ransomware]: dragnet-ransomware-2025-1547 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 1fb62109-2c8b-541c-ae05-67933260e188

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
