// Dragnet [Ransomware]: dragnet-ransomware-2025-2670 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 5374f2a8-0d4a-5311-815f-400c3ecf986e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
