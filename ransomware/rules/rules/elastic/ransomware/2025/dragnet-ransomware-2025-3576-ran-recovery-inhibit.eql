// Dragnet [Ransomware]: dragnet-ransomware-2025-3576 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 3dd7c93b-9106-589d-a5b9-5e3a459b7813

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
