// Dragnet [Ransomware]: dragnet-ransomware-2025-7238 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 99ac0fb3-4876-57e3-ba22-1de6dfb7c887

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
