// Dragnet [Ransomware]: dragnet-ransomware-2025-0449 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 14ecbde3-8227-5b54-851e-4fe19fbddb11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
