// Dragnet [Ransomware]: dragnet-ransomware-2025-6002 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 49743e65-24ac-59cd-ad2f-f879b17a35af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
