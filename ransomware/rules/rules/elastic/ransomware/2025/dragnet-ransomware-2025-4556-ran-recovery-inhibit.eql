// Dragnet [Ransomware]: dragnet-ransomware-2025-4556 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: a586e9c0-f8b5-568e-ad22-cb60bcfdf7bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
