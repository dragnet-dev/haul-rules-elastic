// Dragnet [Ransomware]: dragnet-ransomware-2025-3886 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 0dba7d39-b5c1-5be3-a356-13d3c99284f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
