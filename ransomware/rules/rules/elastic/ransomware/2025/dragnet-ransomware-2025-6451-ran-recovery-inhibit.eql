// Dragnet [Ransomware]: dragnet-ransomware-2025-6451 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 1cf00214-1e89-5e52-b824-674af6550de8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
