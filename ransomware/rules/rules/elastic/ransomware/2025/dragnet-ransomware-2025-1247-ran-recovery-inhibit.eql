// Dragnet [Ransomware]: dragnet-ransomware-2025-1247 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5fdf3cdc-436c-52b9-9c0c-46a4dec59017

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
