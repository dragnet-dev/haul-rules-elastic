// Dragnet [Ransomware]: dragnet-ransomware-2025-7680 — Recovery Inhibition (blackshrantac)
// Status: test | Level: high | ID: 97b7ef73-21c3-5230-b6cd-89bd24ebec70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
