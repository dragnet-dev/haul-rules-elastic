// Dragnet [Ransomware]: dragnet-ransomware-2025-2480 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 268b3598-de3b-549f-875a-b02a9a9ce6f0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
