// Dragnet [Ransomware]: dragnet-ransomware-2025-4725 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: de27aa47-8047-53b1-95b7-33013b9ce7e9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
