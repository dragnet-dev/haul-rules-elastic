// Dragnet [Ransomware]: dragnet-ransomware-2025-6736 — Recovery Inhibition (apt73)
// Status: experimental | Level: high | ID: a7b331ee-2aea-5b9c-b15f-85a19330a63f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
