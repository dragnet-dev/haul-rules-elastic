// Dragnet [Ransomware]: dragnet-ransomware-2025-4361 — Recovery Inhibition (ransomexx)
// Status: experimental | Level: high | ID: f150510e-4feb-5102-915e-0a0dffbcd377

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
