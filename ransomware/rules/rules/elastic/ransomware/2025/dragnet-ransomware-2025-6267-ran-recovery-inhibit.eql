// Dragnet [Ransomware]: dragnet-ransomware-2025-6267 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: b356ab2e-3f60-5ac4-861e-d4939189e01f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
