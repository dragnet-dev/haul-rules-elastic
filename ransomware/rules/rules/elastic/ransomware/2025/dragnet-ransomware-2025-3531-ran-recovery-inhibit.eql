// Dragnet [Ransomware]: dragnet-ransomware-2025-3531 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 0fb9fed7-779f-5f11-9288-caea5e59ae7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
