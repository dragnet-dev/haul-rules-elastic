// Dragnet [Ransomware]: dragnet-ransomware-2025-7080 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: d315838b-9b66-5d20-9a99-3405e30df9b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
