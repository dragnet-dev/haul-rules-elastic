// Dragnet [Ransomware]: dragnet-ransomware-2025-3194 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a7b78fdd-373e-50e0-b418-8d1054054ef5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
