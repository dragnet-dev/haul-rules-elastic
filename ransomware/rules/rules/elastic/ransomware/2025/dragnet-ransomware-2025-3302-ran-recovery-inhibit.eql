// Dragnet [Ransomware]: dragnet-ransomware-2025-3302 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 446a3333-be09-5dfb-a377-4facfd3a83ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
