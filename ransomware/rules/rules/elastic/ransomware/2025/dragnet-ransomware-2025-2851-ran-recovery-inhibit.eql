// Dragnet [Ransomware]: dragnet-ransomware-2025-2851 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0f917eb9-aa37-5257-8e49-7647708beefa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
