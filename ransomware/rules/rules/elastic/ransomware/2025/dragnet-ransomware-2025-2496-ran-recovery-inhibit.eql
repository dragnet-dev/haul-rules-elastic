// Dragnet [Ransomware]: dragnet-ransomware-2025-2496 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: fb4d2d6b-8974-566c-8f60-038f53c5c8b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
