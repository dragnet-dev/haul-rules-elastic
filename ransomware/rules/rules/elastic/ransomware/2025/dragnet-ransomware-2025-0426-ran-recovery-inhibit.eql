// Dragnet [Ransomware]: dragnet-ransomware-2025-0426 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 9dc239df-7a4d-5faa-a6c7-f64f8d40aa48

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
