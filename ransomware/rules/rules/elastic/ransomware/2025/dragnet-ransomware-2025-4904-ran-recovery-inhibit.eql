// Dragnet [Ransomware]: dragnet-ransomware-2025-4904 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: ab029a31-19a8-5bc2-9cd2-ef66d2b57160

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
