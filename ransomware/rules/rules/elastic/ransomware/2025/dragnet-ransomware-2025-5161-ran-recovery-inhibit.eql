// Dragnet [Ransomware]: dragnet-ransomware-2025-5161 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 1661b1f3-b3ba-57e7-8e27-4f4606247678

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
