// Dragnet [Ransomware]: dragnet-ransomware-2025-7183 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 2484e891-061b-5106-994f-df423e113484

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
