// Dragnet [Ransomware]: dragnet-ransomware-2025-1561 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3868339e-5fc5-5c87-ad43-a9875fff531d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
