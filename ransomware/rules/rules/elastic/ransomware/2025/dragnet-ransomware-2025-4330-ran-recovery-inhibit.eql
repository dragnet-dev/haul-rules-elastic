// Dragnet [Ransomware]: dragnet-ransomware-2025-4330 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: c0d35380-3aa4-5aa0-8566-f830e92cacba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
