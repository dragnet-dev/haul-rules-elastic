// Dragnet [Ransomware]: dragnet-ransomware-2025-7163 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a1f87006-d664-5742-b8bd-0b3a68367689

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
