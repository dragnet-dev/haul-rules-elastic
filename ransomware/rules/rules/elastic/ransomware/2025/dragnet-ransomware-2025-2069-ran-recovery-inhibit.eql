// Dragnet [Ransomware]: dragnet-ransomware-2025-2069 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 953e1cec-d040-5755-8a6f-7530aa944174

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
