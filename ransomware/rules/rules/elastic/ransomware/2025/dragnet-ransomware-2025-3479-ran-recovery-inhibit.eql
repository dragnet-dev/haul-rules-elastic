// Dragnet [Ransomware]: dragnet-ransomware-2025-3479 — Recovery Inhibition (warlock)
// Status: experimental | Level: high | ID: 6b4eabe6-10ae-5bb8-8187-ff291a0f19db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
