// Dragnet [Ransomware]: dragnet-ransomware-2025-3833 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 5361d3b9-51b9-5e23-986c-a4366f46d531

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
