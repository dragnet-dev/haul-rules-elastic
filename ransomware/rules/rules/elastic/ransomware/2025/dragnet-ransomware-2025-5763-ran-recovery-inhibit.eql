// Dragnet [Ransomware]: dragnet-ransomware-2025-5763 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: bdac0afc-d2ad-5d19-9ca5-6ce4bd54ecf6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
