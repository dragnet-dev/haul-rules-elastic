// Dragnet [Ransomware]: dragnet-ransomware-2025-6454 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d15108e4-f553-5bea-b6f2-224050936d1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
