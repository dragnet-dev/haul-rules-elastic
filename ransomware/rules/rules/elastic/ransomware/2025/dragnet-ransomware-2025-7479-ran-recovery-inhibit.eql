// Dragnet [Ransomware]: dragnet-ransomware-2025-7479 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: 6789edce-0954-5180-a731-daeba021f99e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
