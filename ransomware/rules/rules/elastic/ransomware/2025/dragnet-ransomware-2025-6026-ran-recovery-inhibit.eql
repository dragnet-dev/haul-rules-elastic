// Dragnet [Ransomware]: dragnet-ransomware-2025-6026 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: cb3fade2-8f58-59e1-ab25-d3d0562d85d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
