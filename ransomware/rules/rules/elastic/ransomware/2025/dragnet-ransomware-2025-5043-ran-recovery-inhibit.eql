// Dragnet [Ransomware]: dragnet-ransomware-2025-5043 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 3528c44e-b268-5bd4-b5c5-253a60de03de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
