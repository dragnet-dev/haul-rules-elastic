// Dragnet [Ransomware]: dragnet-ransomware-2025-4915 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 86f74b67-8a9d-5fc3-b83b-36f9a7754b6b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
