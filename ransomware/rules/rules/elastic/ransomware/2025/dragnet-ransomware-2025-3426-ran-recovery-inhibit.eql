// Dragnet [Ransomware]: dragnet-ransomware-2025-3426 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: b09ce8bd-2d9b-5453-8ab7-df5ff4a5968b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
