// Dragnet [Ransomware]: dragnet-ransomware-2025-0188 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: cb30d604-ab18-5590-8ef1-bd488f88a089

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
