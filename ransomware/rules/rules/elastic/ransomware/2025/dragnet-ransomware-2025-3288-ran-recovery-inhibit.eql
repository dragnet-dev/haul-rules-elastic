// Dragnet [Ransomware]: dragnet-ransomware-2025-3288 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 7dc92ce9-8ea1-55b8-962e-9fe9fd8dbdd9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
