// Dragnet [Ransomware]: dragnet-ransomware-2025-0045 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 2af82684-ad51-50c8-91b7-97333ad941d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
