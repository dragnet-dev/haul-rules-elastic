// Dragnet [Ransomware]: dragnet-ransomware-2025-6898 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 245a7254-8533-5fce-b253-6fcd2e0502b8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
