// Dragnet [Ransomware]: dragnet-ransomware-2025-4738 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 9e0237f3-b09a-5d43-97fa-b703548955ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
