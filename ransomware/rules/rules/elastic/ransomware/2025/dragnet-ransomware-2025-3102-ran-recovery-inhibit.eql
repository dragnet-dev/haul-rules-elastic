// Dragnet [Ransomware]: dragnet-ransomware-2025-3102 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: dd3d500b-2125-5aec-a988-1d60f5fbc473

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
