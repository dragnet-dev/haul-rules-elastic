// Dragnet [Ransomware]: dragnet-ransomware-2025-6261 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a5f531ff-3b14-5ef0-b9c0-c362c9cb3e8e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
