// Dragnet [Ransomware]: dragnet-ransomware-2025-6490 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 1b5680bc-3d01-50af-ba69-9e581212a877

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
