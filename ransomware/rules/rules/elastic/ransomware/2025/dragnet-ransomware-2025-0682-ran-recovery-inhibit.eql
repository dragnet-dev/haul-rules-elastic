// Dragnet [Ransomware]: dragnet-ransomware-2025-0682 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a5cae29e-d89f-5a5b-ae81-2923457701ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
