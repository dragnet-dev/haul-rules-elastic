// Dragnet [Ransomware]: dragnet-ransomware-2025-2297 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6a67f01f-f55f-5414-aca4-84bf5b7d957c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
