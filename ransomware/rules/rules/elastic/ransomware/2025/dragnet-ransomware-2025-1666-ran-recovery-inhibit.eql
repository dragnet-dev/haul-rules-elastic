// Dragnet [Ransomware]: dragnet-ransomware-2025-1666 — Recovery Inhibition (apos)
// Status: deprecated | Level: high | ID: 4df76789-4a24-5c1d-aa07-2b0232b5af91

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
