// Dragnet [Ransomware]: dragnet-ransomware-2025-0691 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 60ec6e88-d633-5048-9baf-4d5d33105d51

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
