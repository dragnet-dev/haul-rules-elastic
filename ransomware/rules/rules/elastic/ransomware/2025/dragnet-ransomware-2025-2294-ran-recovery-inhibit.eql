// Dragnet [Ransomware]: dragnet-ransomware-2025-2294 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 6b434c90-93a3-5471-99ab-e5e96e769baa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
