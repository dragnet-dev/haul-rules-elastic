// Dragnet [Ransomware]: dragnet-ransomware-2025-7526 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: ed31f594-6e90-5fc4-8be8-eb03d5b3f465

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
