// Dragnet [Ransomware]: dragnet-ransomware-2025-7185 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: eabae9bb-165a-53eb-90d2-b148183773fc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
