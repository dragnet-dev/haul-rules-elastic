// Dragnet [Ransomware]: dragnet-ransomware-2025-2132 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 3cff8315-d4cf-5b64-9ec2-eb4b10fe9bbb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
