// Dragnet [Ransomware]: dragnet-ransomware-2025-6908 — Recovery Inhibition (tengu)
// Status: experimental | Level: high | ID: cc186517-3f1c-5539-8bd2-892af37a9b15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
