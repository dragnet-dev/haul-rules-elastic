// Dragnet [Ransomware]: dragnet-ransomware-2025-5594 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: d4e57ee1-2803-518c-bbeb-b1880fbecb10

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
