// Dragnet [Ransomware]: dragnet-ransomware-2025-6010 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 909ecfe6-3a96-555b-9ee8-a78feb47c080

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
