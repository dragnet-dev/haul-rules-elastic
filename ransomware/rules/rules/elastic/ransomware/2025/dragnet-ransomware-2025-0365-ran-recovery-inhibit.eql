// Dragnet [Ransomware]: dragnet-ransomware-2025-0365 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b434c460-c206-5434-9907-701ebb39eb73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
