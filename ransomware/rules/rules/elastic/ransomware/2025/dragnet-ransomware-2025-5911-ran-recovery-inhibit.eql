// Dragnet [Ransomware]: dragnet-ransomware-2025-5911 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 8284d4ed-8f08-5a08-b6aa-5c396aad2e8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
