// Dragnet [Ransomware]: dragnet-ransomware-2025-6895 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: 12482efc-3cb1-526f-81d7-cf565134d977

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
