// Dragnet [Ransomware]: dragnet-ransomware-2025-4686 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 4d829617-3d74-552d-9993-6da6360cb247

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
