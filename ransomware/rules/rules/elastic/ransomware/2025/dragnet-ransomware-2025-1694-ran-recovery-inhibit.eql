// Dragnet [Ransomware]: dragnet-ransomware-2025-1694 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 939362a4-b01b-5884-b2de-d16b207ab7b6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
