// Dragnet [Ransomware]: dragnet-ransomware-2025-5383 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 5c74f118-2124-59c6-a6a7-1e873cad6d8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
