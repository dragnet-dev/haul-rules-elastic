// Dragnet [Ransomware]: dragnet-ransomware-2025-0080 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: fd6d14b3-181d-52e0-8345-18dbf1363034

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
