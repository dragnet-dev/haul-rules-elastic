// Dragnet [Ransomware]: dragnet-ransomware-2025-1482 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5df02588-7222-5071-a125-6ce4b46dd332

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
