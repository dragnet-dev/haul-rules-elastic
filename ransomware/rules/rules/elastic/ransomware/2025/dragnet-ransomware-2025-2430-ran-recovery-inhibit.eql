// Dragnet [Ransomware]: dragnet-ransomware-2025-2430 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: fcc40d04-fc18-5e8e-9148-827d9af7589b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
