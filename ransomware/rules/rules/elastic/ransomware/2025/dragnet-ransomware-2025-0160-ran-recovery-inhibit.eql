// Dragnet [Ransomware]: dragnet-ransomware-2025-0160 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4b587960-f52b-5508-8702-01adf3dee5b3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
