// Dragnet [Ransomware]: dragnet-ransomware-2025-6507 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 2cf74e96-17d7-5247-bad7-267da08d172e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
