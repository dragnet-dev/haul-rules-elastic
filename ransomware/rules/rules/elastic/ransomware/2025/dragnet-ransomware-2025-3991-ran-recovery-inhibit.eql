// Dragnet [Ransomware]: dragnet-ransomware-2025-3991 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 7b19220d-d855-5b87-bd9d-c9e8e1444d26

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
