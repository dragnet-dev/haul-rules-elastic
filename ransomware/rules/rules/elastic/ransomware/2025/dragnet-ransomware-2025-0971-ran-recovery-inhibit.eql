// Dragnet [Ransomware]: dragnet-ransomware-2025-0971 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 9783c7f1-6956-54fc-aa2d-570174dcb2f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
