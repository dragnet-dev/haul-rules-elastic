// Dragnet [Ransomware]: dragnet-ransomware-2025-2311 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: d66d22a0-91ed-5da7-8dbc-23552d21890d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
