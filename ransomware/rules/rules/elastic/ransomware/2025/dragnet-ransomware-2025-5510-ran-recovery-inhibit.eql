// Dragnet [Ransomware]: dragnet-ransomware-2025-5510 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 801e955a-6c20-5ef9-9414-c59d70b33a2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
