// Dragnet [Ransomware]: dragnet-ransomware-2025-5476 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 2accdc60-bf81-5244-8b61-84a245234073

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
