// Dragnet [Ransomware]: dragnet-ransomware-2025-0507 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 01b54a06-75c6-516a-8c4b-badc5c8ac3d7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
