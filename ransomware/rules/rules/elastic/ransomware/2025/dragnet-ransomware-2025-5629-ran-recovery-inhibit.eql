// Dragnet [Ransomware]: dragnet-ransomware-2025-5629 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9b3ef044-7e5a-5ce5-9971-ab9a4e1cf05e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
