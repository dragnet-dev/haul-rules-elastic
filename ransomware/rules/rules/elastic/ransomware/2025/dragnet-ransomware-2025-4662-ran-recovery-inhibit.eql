// Dragnet [Ransomware]: dragnet-ransomware-2025-4662 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: c2347b73-645c-5e9b-9670-b23fd63a1ce2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
