// Dragnet [Ransomware]: dragnet-ransomware-2025-7867 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: b51fe02b-52eb-5f06-b054-f4b7b607aefb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
