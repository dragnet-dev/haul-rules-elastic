// Dragnet [Ransomware]: dragnet-ransomware-2025-0806 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 6048eb1a-a5e7-5b2c-b4eb-07135663b87d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
