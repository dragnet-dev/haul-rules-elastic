// Dragnet [Ransomware]: dragnet-ransomware-2025-2602 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: bc1d90e1-7f1b-5c6e-b860-4a5df7e439f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
