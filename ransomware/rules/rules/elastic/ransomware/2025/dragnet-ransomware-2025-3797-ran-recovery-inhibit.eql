// Dragnet [Ransomware]: dragnet-ransomware-2025-3797 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6dc58b34-c862-5f6a-91a4-9a0ae92ca269

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
