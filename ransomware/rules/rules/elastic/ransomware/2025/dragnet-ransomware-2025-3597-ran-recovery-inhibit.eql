// Dragnet [Ransomware]: dragnet-ransomware-2025-3597 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ce6073f7-a755-5e57-8813-bef17c23c4e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
