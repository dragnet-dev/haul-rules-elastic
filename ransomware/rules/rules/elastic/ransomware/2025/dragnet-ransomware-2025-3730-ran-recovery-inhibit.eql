// Dragnet [Ransomware]: dragnet-ransomware-2025-3730 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 0d594a11-200f-5b6c-89d5-03ff12c1c830

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
