// Dragnet [Ransomware]: dragnet-ransomware-2025-7143 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 778b106e-528b-5471-88ec-585400862676

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
