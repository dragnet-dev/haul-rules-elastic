// Dragnet [Ransomware]: dragnet-ransomware-2025-7913 — Recovery Inhibition (kazu)
// Status: experimental | Level: high | ID: 64097d37-b03d-5b63-a41e-020e697a8332

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
