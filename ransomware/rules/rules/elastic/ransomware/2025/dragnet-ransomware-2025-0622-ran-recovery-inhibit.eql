// Dragnet [Ransomware]: dragnet-ransomware-2025-0622 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 9e489e26-4523-53b2-8b93-4bd60f4c5077

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
