// Dragnet [Ransomware]: dragnet-ransomware-2025-3592 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 479a54ef-bc5c-55db-89c9-254498be5622

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
