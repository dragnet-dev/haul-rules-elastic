// Dragnet [Ransomware]: dragnet-ransomware-2025-2249 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 626b92c0-09b0-5e5b-a339-2917f0e3ead9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
