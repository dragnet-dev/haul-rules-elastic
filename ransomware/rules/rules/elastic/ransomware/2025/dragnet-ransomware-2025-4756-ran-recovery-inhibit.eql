// Dragnet [Ransomware]: dragnet-ransomware-2025-4756 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 3a50240c-44e0-504a-a893-08fb6778b1be

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
