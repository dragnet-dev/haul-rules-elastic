// Dragnet [Ransomware]: dragnet-ransomware-2025-7223 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: f7271443-e8a7-5f92-a633-b677746fa1d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
