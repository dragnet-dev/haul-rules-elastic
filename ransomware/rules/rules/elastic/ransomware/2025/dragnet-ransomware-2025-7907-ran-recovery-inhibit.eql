// Dragnet [Ransomware]: dragnet-ransomware-2025-7907 — Recovery Inhibition (blackshrantac)
// Status: experimental | Level: high | ID: e8af3db4-9deb-5dc9-9459-41829c66bdd2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
