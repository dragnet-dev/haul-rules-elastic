// Dragnet [Ransomware]: dragnet-ransomware-2025-2835 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3a71ce9e-cecd-5b4e-9746-40e6bd587837

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
