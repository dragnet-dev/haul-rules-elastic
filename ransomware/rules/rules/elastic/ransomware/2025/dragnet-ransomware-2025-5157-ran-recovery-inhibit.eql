// Dragnet [Ransomware]: dragnet-ransomware-2025-5157 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 717af10c-3656-580d-95a3-5f0be438dfbf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
