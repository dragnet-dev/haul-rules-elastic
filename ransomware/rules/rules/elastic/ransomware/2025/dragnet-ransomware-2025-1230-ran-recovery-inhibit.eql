// Dragnet [Ransomware]: dragnet-ransomware-2025-1230 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: d59dafd2-2ff9-586f-8dfc-dd60adba7f4c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
