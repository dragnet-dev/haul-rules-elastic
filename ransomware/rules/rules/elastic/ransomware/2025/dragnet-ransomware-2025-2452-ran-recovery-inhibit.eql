// Dragnet [Ransomware]: dragnet-ransomware-2025-2452 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: d00c1cca-e1f2-5d5e-893b-e9def2317c99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
