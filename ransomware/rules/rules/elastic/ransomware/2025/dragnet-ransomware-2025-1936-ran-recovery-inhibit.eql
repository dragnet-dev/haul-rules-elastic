// Dragnet [Ransomware]: dragnet-ransomware-2025-1936 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 94c00766-6ec2-5326-8d4b-9520f5fd159d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
