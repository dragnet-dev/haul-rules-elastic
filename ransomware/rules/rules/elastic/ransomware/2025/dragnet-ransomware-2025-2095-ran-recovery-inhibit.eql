// Dragnet [Ransomware]: dragnet-ransomware-2025-2095 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 61aeaf2f-a95a-58e6-92e4-eadf28458393

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
