// Dragnet [Ransomware]: dragnet-ransomware-2025-3943 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: a837da1e-5db2-5d6b-9925-0287c3cb9964

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
