// Dragnet [Ransomware]: dragnet-ransomware-2025-3253 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: fc4b8c22-969d-5fc1-ae01-99e058777cdc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
