// Dragnet [Ransomware]: dragnet-ransomware-2025-7615 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 53e6f703-ac3f-51a8-95a4-390c2e2390f3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
