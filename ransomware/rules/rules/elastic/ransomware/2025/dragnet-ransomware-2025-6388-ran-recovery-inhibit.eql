// Dragnet [Ransomware]: dragnet-ransomware-2025-6388 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: e3b2e54f-11de-5832-a9a4-5bed53338e1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
