// Dragnet [Ransomware]: dragnet-ransomware-2025-4230 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 24bba930-fdbb-503e-b2e4-c60395689285

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
