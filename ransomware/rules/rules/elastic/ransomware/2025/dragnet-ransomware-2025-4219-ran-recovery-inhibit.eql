// Dragnet [Ransomware]: dragnet-ransomware-2025-4219 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: 9e98f876-bbd4-56a0-9f39-6753436c3e12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
