// Dragnet [Ransomware]: dragnet-ransomware-2025-3760 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 8c6656de-7001-5d98-a826-1e4333ae03a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
