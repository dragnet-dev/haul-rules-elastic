// Dragnet [Ransomware]: dragnet-ransomware-2025-4131 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ae1da01d-471d-5b98-a758-4f8167bb8962

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
