// Dragnet [Ransomware]: dragnet-ransomware-2025-7662 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: 4684e25a-893b-51fb-94ff-e0e0a7cd4b09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
