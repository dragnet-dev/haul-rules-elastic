// Dragnet [Ransomware]: dragnet-ransomware-2025-1403 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 83d5fb7d-2cb0-5506-b905-e630ba27fa37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
