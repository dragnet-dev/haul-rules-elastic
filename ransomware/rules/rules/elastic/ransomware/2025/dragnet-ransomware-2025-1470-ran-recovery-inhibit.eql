// Dragnet [Ransomware]: dragnet-ransomware-2025-1470 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: b67742f9-5022-5af8-8749-f009d0dc344e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
