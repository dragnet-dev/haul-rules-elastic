// Dragnet [Ransomware]: dragnet-ransomware-2025-3554 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 2b0b1c24-673e-51ed-8951-944251171873

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
