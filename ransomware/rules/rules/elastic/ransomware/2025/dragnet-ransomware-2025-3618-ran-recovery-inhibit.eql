// Dragnet [Ransomware]: dragnet-ransomware-2025-3618 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: ae5ac08b-1369-5db1-933c-c831e2ed0724

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
