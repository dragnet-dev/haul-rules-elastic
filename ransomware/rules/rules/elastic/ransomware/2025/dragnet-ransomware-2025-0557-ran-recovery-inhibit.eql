// Dragnet [Ransomware]: dragnet-ransomware-2025-0557 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: cc9ad0f8-2fef-5c31-b61f-61f2c51790c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
