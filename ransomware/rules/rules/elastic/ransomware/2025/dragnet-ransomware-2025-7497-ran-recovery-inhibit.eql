// Dragnet [Ransomware]: dragnet-ransomware-2025-7497 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 9336e77d-e309-5dec-bfea-1d8ff814e0c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
