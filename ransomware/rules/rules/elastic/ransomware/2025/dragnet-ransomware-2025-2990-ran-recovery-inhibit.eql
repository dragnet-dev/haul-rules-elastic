// Dragnet [Ransomware]: dragnet-ransomware-2025-2990 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 02b78d7c-c987-5e1a-bb54-63ff377da2f5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
