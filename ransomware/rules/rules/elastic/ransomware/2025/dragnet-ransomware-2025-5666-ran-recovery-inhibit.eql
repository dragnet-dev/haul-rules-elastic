// Dragnet [Ransomware]: dragnet-ransomware-2025-5666 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 398beae2-12f2-5307-9c0f-16523f05faa9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
