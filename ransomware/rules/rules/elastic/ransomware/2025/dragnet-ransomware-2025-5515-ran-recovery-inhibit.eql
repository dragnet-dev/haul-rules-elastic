// Dragnet [Ransomware]: dragnet-ransomware-2025-5515 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: ddbb16b0-6618-5b2d-a11f-7acdfaa44d76

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
