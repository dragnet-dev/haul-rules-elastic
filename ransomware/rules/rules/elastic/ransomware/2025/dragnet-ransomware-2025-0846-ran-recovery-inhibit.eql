// Dragnet [Ransomware]: dragnet-ransomware-2025-0846 — Recovery Inhibition (blacksuit)
// Status: experimental | Level: high | ID: 4602052f-902a-5d49-a2bf-384e5d8b1cf2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
