// Dragnet [Ransomware]: dragnet-ransomware-2025-2774 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 8d599f93-1f5d-5353-9504-bacebd6e081c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
