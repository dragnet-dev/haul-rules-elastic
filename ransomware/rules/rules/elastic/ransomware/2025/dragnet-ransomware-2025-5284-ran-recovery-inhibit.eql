// Dragnet [Ransomware]: dragnet-ransomware-2025-5284 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: fe5b630a-6146-541e-9201-968b9841b445

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
