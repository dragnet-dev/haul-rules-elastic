// Dragnet [Ransomware]: dragnet-ransomware-2025-6445 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 816f57c8-d897-57f8-9adf-8e3448e73d4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
