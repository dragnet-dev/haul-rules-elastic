// Dragnet [Ransomware]: dragnet-ransomware-2025-1893 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 988b7950-7838-59d1-b5d4-583abedad4d3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
