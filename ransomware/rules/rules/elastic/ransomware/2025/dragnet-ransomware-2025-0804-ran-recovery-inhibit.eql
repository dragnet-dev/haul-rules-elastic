// Dragnet [Ransomware]: dragnet-ransomware-2025-0804 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 86704c10-4cb8-5db7-b710-1141465a0e7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
