// Dragnet [Ransomware]: dragnet-ransomware-2025-6202 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: d6fc6522-311b-54e2-bda5-07d91247dc36

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
