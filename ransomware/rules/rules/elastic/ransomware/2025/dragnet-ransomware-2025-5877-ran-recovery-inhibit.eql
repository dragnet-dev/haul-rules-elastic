// Dragnet [Ransomware]: dragnet-ransomware-2025-5877 — Recovery Inhibition (silent)
// Status: experimental | Level: high | ID: f51646dc-7037-53d4-a4d7-bf5f270b2e8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
