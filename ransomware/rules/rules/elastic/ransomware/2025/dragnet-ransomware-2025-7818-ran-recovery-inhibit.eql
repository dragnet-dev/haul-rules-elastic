// Dragnet [Ransomware]: dragnet-ransomware-2025-7818 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 608461fd-460c-5358-b425-b06de5d49244

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
