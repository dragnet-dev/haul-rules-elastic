// Dragnet [Ransomware]: dragnet-ransomware-2025-1085 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 1fa05fd2-062e-58f0-b948-ab7a58b2af25

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
