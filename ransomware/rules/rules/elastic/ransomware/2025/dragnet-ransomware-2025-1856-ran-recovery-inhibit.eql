// Dragnet [Ransomware]: dragnet-ransomware-2025-1856 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 053f3a95-dc9d-5662-b551-3e37733c5259

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
