// Dragnet [Ransomware]: dragnet-ransomware-2025-5173 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 4c049d1e-f824-566d-9cac-8ce7b917d2b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
