// Dragnet [Ransomware]: dragnet-ransomware-2025-1492 — Recovery Inhibition (skira)
// Status: experimental | Level: high | ID: 3cac9a2f-df19-5c72-ba92-8ca71731224f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
