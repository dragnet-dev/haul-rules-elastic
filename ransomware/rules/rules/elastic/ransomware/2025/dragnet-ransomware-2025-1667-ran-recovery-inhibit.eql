// Dragnet [Ransomware]: dragnet-ransomware-2025-1667 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: e3a65787-02c0-5f2e-98f1-778752a9a761

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
