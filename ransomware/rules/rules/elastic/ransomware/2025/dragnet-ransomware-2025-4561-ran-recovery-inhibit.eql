// Dragnet [Ransomware]: dragnet-ransomware-2025-4561 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a37f0554-3487-5921-87fb-848479585fab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
