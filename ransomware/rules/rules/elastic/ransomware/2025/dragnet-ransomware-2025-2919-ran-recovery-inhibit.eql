// Dragnet [Ransomware]: dragnet-ransomware-2025-2919 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: b52ab8ce-0364-5909-9e45-a72a8512cf78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
