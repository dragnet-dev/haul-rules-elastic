// Dragnet [Ransomware]: dragnet-ransomware-2025-3279 — Recovery Inhibition (incransom)
// Status: test | Level: high | ID: 62fe7771-d3ca-5671-8a0b-f5d6631c3cdc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
