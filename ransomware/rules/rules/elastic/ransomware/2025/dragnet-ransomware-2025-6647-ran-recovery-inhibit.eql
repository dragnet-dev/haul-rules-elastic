// Dragnet [Ransomware]: dragnet-ransomware-2025-6647 — Recovery Inhibition (BrainCipher)
// Status: experimental | Level: high | ID: ec52a27c-897b-5e36-91f0-3f51050bd5a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
