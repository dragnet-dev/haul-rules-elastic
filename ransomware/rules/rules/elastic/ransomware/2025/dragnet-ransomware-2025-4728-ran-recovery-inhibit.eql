// Dragnet [Ransomware]: dragnet-ransomware-2025-4728 — Recovery Inhibition (blackshrantac)
// Status: experimental | Level: high | ID: 445c7fb7-d97e-5a7f-901c-ea4baf1bc346

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
