// Dragnet [Ransomware]: dragnet-ransomware-2025-0377 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: f2d5e1ac-b50d-5c5f-a435-322a7fc99467

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
