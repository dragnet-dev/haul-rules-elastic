// Dragnet [Ransomware]: dragnet-ransomware-2025-2138 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 6b889511-b46f-5f4e-9562-a6c45eee8afa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
