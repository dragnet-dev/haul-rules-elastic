// Dragnet [Ransomware]: dragnet-ransomware-2025-6367 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: c4c687d9-190a-50ca-9b0c-6752064f7627

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
