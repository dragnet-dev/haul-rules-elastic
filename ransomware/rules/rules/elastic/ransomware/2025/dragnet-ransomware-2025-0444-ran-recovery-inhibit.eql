// Dragnet [Ransomware]: dragnet-ransomware-2025-0444 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 0170da99-b51e-5d88-93d5-67d1f334d7a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
