// Dragnet [Ransomware]: dragnet-ransomware-2025-1865 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: c942aeb3-bbed-5563-8508-96a978535c57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
