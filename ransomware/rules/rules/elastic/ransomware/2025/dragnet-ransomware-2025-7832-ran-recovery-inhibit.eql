// Dragnet [Ransomware]: dragnet-ransomware-2025-7832 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 539a01eb-1fa3-553c-8bf7-8f0bbaaf211d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
