// Dragnet [Ransomware]: dragnet-ransomware-2025-6781 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1a68f146-8e6c-5948-8f83-577c8268a731

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
