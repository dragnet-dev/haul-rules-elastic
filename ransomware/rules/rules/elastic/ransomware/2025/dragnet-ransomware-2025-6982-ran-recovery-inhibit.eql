// Dragnet [Ransomware]: dragnet-ransomware-2025-6982 — Recovery Inhibition (securotrop)
// Status: experimental | Level: high | ID: a0a70f8e-5411-549f-963a-3a1c7bc0d20c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
