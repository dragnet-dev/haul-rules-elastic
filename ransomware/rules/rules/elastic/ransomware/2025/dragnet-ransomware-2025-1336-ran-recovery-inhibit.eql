// Dragnet [Ransomware]: dragnet-ransomware-2025-1336 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: da642e4f-375f-5452-af87-bb58a0c30cfa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
