// Dragnet [Ransomware]: dragnet-ransomware-2025-1193 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 57a5aebe-14fe-574d-897d-3296149659ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
