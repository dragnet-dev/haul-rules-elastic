// Dragnet [Ransomware]: dragnet-ransomware-2025-7253 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 481eb72f-9b3e-54bc-8496-88c0b4420d07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
