// Dragnet [Ransomware]: dragnet-ransomware-2025-6684 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 37b38da4-40dc-550b-be32-d6e81cecb6d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
