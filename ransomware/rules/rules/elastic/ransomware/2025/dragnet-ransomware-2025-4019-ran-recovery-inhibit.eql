// Dragnet [Ransomware]: dragnet-ransomware-2025-4019 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: d5800ecd-812c-5b7a-b95e-3f372a19695b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
