// Dragnet [Ransomware]: dragnet-ransomware-2025-6732 — Recovery Inhibition (coinbasecartel)
// Status: test | Level: high | ID: cb6e1a36-efdc-5825-8387-8b32bf37009a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
