// Dragnet [Ransomware]: dragnet-ransomware-2025-7101 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: bb0b582b-9cdb-57b7-9816-622afe11912b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
