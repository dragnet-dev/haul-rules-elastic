// Dragnet [Ransomware]: dragnet-ransomware-2025-4470 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: a27e795a-7320-59f4-87e6-2928f8c4565c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
