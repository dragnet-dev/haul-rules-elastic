// Dragnet [Ransomware]: dragnet-ransomware-2025-4838 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: 49d14722-116f-5d65-a1cc-13df13c6a125

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
