// Dragnet [Ransomware]: dragnet-ransomware-2025-6491 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 7004e7cc-1501-57d3-bace-9049d2830e35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
