// Dragnet [Ransomware]: dragnet-ransomware-2025-2389 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 96417d61-e148-57f5-b4be-566f0eb16caa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
