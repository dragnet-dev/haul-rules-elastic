// Dragnet [Ransomware]: dragnet-ransomware-2025-3333 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 626df993-b298-574b-bd3f-372722aa01d6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
