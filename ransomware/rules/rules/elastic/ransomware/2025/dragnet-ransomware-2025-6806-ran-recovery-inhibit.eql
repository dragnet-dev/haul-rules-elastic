// Dragnet [Ransomware]: dragnet-ransomware-2025-6806 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: a112f5d0-5a1d-53c8-8523-6610c89243ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
