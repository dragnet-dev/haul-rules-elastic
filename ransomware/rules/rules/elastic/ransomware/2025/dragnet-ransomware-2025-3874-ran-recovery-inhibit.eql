// Dragnet [Ransomware]: dragnet-ransomware-2025-3874 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 1713fc6e-884c-59d8-acb8-f469c6c03866

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
