// Dragnet [Ransomware]: dragnet-ransomware-2025-3507 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 8bc79ad7-bcd4-54db-b8d9-8391800cdddc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
