// Dragnet [Ransomware]: dragnet-ransomware-2025-3050 — Recovery Inhibition (anubis)
// Status: test | Level: high | ID: 729ae2c5-3bdf-5174-8f0d-7bc84ce74195

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
