// Dragnet [Ransomware]: dragnet-ransomware-2025-1020 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 6589c032-fb9e-5446-9140-7163a95d3ec9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
