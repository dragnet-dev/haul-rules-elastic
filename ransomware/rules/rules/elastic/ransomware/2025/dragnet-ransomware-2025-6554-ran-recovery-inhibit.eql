// Dragnet [Ransomware]: dragnet-ransomware-2025-6554 — Recovery Inhibition (hellcat)
// Status: deprecated | Level: high | ID: 7773dc2d-4cf6-5cb2-a9f0-119affdabbed

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
