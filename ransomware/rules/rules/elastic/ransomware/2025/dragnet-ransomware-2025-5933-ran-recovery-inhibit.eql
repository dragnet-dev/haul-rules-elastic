// Dragnet [Ransomware]: dragnet-ransomware-2025-5933 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 6f185c10-0f87-54be-9e14-414c1a09c3d5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
