// Dragnet [Ransomware]: dragnet-ransomware-2025-1596 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: 4013d8e1-5d4e-5fbf-89b0-d88be4ea47ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
