// Dragnet [Ransomware]: dragnet-ransomware-2025-6065 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: ad212e1a-03a2-58eb-8e6f-81bba6b38e65

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
