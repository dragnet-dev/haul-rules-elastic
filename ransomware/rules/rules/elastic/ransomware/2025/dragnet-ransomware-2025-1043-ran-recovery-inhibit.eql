// Dragnet [Ransomware]: dragnet-ransomware-2025-1043 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 0a8836db-a6c3-5917-99e3-5010df193d80

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
