// Dragnet [Ransomware]: dragnet-ransomware-2025-1162 — Recovery Inhibition (underground)
// Status: experimental | Level: high | ID: 02096826-f5d0-5bde-8e79-9feb204df9de

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
