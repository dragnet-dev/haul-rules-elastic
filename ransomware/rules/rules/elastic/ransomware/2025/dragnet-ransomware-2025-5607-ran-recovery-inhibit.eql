// Dragnet [Ransomware]: dragnet-ransomware-2025-5607 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: f97f959b-043d-53fc-9313-aad914178edf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
