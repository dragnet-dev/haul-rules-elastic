// Dragnet [Ransomware]: dragnet-ransomware-2025-6291 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: da555af4-e7c5-5ed5-b0fc-3c4a19a66a39

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
