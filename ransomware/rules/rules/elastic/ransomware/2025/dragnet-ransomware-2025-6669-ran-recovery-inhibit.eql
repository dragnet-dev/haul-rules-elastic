// Dragnet [Ransomware]: dragnet-ransomware-2025-6669 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 024e10af-f41a-58dd-b9a3-4e04341bda8a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
