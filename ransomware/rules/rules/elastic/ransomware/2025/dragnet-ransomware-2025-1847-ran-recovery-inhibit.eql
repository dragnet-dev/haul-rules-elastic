// Dragnet [Ransomware]: dragnet-ransomware-2025-1847 — Recovery Inhibition (brotherhood)
// Status: experimental | Level: high | ID: d38bc993-d7b3-5ee7-b06c-209e63f79b42

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
