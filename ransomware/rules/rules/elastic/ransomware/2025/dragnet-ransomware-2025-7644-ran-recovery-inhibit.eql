// Dragnet [Ransomware]: dragnet-ransomware-2025-7644 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: d21598e9-b578-5ccc-b892-98c94cadcebe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
