// Dragnet [Ransomware]: dragnet-ransomware-2025-1675 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 21a66668-e237-5c49-b5ab-a3565bc970f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
