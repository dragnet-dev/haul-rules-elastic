// Dragnet [Ransomware]: dragnet-ransomware-2025-6110 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6c0c26a7-cd79-50d1-bf1c-629820649d0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
