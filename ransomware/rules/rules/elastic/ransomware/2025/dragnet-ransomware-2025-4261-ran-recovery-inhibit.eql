// Dragnet [Ransomware]: dragnet-ransomware-2025-4261 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: e2b9ac09-f72e-516f-b663-13f64408919f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
