// Dragnet [Ransomware]: dragnet-ransomware-2025-3412 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: a36bd430-7b30-5b3d-9544-5869ed95b9f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
