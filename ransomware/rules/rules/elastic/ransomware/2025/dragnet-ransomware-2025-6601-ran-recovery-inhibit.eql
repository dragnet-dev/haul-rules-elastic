// Dragnet [Ransomware]: dragnet-ransomware-2025-6601 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 0da70cf9-628b-54f3-85cd-ec80ed87bba8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
