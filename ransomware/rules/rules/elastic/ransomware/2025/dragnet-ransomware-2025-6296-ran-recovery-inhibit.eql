// Dragnet [Ransomware]: dragnet-ransomware-2025-6296 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3a5165d8-7cc1-51da-abf7-f5722ed88051

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
