// Dragnet [Ransomware]: dragnet-ransomware-2025-3606 — Recovery Inhibition (beast)
// Status: experimental | Level: high | ID: 7821a625-2969-51a1-87fa-5f53b600f610

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
