// Dragnet [Ransomware]: dragnet-ransomware-2025-2500 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 6fc35455-7531-5447-93b4-4b162d6441ee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
