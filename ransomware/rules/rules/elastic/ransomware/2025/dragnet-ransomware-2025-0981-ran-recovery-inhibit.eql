// Dragnet [Ransomware]: dragnet-ransomware-2025-0981 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 3b581f90-7a7c-53de-b50c-b83bb67ccb74

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
