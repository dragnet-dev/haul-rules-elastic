// Dragnet [Ransomware]: dragnet-ransomware-2025-6405 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 3a01b3f3-f1a9-5f0f-970a-061b01c7387b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
