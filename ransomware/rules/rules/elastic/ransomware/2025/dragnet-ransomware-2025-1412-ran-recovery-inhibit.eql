// Dragnet [Ransomware]: dragnet-ransomware-2025-1412 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 631cb3d4-e615-5d44-bae3-41649ddcfc9d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
