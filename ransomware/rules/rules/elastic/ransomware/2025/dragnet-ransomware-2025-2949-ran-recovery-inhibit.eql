// Dragnet [Ransomware]: dragnet-ransomware-2025-2949 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 98e78ba6-26e9-5cc3-9271-51036ce12406

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
