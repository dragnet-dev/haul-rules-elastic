// Dragnet [Ransomware]: dragnet-ransomware-2025-7756 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: c88893d8-3c1b-59a4-9084-8c1aa24fb008

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
