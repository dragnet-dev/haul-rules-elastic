// Dragnet [Ransomware]: dragnet-ransomware-2025-7740 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: c6352c29-30c4-5516-9641-1d480c0fa27a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
