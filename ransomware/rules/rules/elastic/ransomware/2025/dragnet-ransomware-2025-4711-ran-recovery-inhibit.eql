// Dragnet [Ransomware]: dragnet-ransomware-2025-4711 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: a2cad4a7-6f6b-5913-baae-5c1bf1cd1c19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
