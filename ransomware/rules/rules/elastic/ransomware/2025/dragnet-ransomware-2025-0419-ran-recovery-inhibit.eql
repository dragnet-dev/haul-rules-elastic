// Dragnet [Ransomware]: dragnet-ransomware-2025-0419 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: 0b0be688-af38-5945-a149-2f3cd540671d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
