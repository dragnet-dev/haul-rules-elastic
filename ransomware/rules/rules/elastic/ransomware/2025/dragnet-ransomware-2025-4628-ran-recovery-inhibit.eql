// Dragnet [Ransomware]: dragnet-ransomware-2025-4628 — Recovery Inhibition (monti)
// Status: experimental | Level: high | ID: abead203-a290-5c89-8114-37e53ee2d166

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
