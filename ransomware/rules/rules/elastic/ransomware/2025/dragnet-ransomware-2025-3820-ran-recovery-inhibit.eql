// Dragnet [Ransomware]: dragnet-ransomware-2025-3820 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8671acfc-4032-5444-ad50-680248381a11

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
