// Dragnet [Ransomware]: dragnet-ransomware-2025-5495 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: 9b4e9df7-e867-56f3-b7ee-529f5b000e82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
