// Dragnet [Ransomware]: dragnet-ransomware-2025-5907 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b4dcc252-889d-506d-9f99-2e9209b9548a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
