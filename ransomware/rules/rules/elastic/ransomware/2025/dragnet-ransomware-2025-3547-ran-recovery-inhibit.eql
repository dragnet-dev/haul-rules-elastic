// Dragnet [Ransomware]: dragnet-ransomware-2025-3547 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 3b433bee-8246-5a5e-8b5f-08d1d4028459

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
