// Dragnet [Ransomware]: dragnet-ransomware-2025-7308 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: d4fb8e18-7e5e-53dc-9053-96049e3713b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
