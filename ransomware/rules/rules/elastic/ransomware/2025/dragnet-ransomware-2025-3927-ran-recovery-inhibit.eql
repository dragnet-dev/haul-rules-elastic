// Dragnet [Ransomware]: dragnet-ransomware-2025-3927 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 120b132e-2ada-5cb3-8fa6-f6d6e5ea23a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
