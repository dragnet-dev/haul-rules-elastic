// Dragnet [Ransomware]: dragnet-ransomware-2025-4539 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 392d5a21-d644-5a0a-b33c-d015c6d89e78

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
