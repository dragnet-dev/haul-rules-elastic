// Dragnet [Ransomware]: dragnet-ransomware-2025-7373 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: df5d1905-0fc8-525e-bd24-0953e447c083

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
