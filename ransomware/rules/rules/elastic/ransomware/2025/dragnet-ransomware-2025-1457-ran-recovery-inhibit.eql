// Dragnet [Ransomware]: dragnet-ransomware-2025-1457 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 25316ec6-ed6c-5c89-b64b-9fc6ad43af13

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
