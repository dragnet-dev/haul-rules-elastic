// Dragnet [Ransomware]: dragnet-ransomware-2025-6705 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 73dfda2a-0d44-5363-b2ed-d975e0d8a8c1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
