// Dragnet [Ransomware]: dragnet-ransomware-2025-0824 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 066e9f86-3c51-501c-8a21-1c336373b252

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
