// Dragnet [Ransomware]: dragnet-ransomware-2025-7173 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: c0644069-1910-5040-b666-f45c7dd51253

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
