// Dragnet [Ransomware]: dragnet-ransomware-2025-1833 — Recovery Inhibition (cicada3301)
// Status: experimental | Level: high | ID: 8c26f183-8773-51a4-80bb-821d69171224

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
