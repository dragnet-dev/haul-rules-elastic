// Dragnet [Ransomware]: dragnet-ransomware-2025-4110 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 698181d7-febf-5dbe-bef9-d4c41b93250b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
