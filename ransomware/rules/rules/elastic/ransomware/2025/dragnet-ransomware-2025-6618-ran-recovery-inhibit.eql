// Dragnet [Ransomware]: dragnet-ransomware-2025-6618 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 734c2721-1b6d-5a49-a6b9-1d043efc90ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
