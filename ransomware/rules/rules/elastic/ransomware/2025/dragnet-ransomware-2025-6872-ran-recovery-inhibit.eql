// Dragnet [Ransomware]: dragnet-ransomware-2025-6872 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 083f31fa-0bbb-56bd-b120-c66fd8f50614

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
