// Dragnet [Ransomware]: dragnet-ransomware-2025-4652 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 8c59a580-5f33-5c1a-ba22-c36da2f44398

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
