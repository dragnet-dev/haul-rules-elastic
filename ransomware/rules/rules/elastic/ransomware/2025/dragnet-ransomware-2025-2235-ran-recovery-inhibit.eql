// Dragnet [Ransomware]: dragnet-ransomware-2025-2235 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 7058a154-22d2-5fbc-baee-37188d692cc2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
