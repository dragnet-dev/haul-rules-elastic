// Dragnet [Ransomware]: dragnet-ransomware-2025-6324 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 0c642d5f-0aae-5883-a697-918db45255d1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
