// Dragnet [Ransomware]: dragnet-ransomware-2025-6014 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: de205699-7e08-53a6-8ab2-4ddae43afc9c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
