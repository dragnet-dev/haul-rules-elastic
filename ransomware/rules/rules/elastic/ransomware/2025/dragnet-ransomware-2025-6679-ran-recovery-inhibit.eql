// Dragnet [Ransomware]: dragnet-ransomware-2025-6679 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1e264699-57c1-5eee-8ceb-1e1ec993d39d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
