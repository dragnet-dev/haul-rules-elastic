// Dragnet [Ransomware]: dragnet-ransomware-2025-0915 — Recovery Inhibition (cloak)
// Status: deprecated | Level: high | ID: 4f132b66-b154-551a-9cdd-ebf602d2101d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
