// Dragnet [Ransomware]: dragnet-ransomware-2025-6518 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 010e10cf-fd93-5e46-842b-955983d39860

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
