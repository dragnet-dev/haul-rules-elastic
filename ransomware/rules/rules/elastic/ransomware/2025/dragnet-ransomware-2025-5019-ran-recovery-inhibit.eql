// Dragnet [Ransomware]: dragnet-ransomware-2025-5019 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: b1fc844a-d444-5f8d-ac47-c29f81f95c24

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
