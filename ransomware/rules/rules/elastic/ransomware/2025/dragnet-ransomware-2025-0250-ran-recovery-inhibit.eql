// Dragnet [Ransomware]: dragnet-ransomware-2025-0250 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 74164049-09e1-5b01-a3de-90fa92466098

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
