// Dragnet [Ransomware]: dragnet-ransomware-2025-2464 — Recovery Inhibition (thegentlemen)
// Status: test | Level: high | ID: 9c203524-dcc9-52e6-bd4e-f9bd17e20e6f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
