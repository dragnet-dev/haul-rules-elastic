// Dragnet [Ransomware]: dragnet-ransomware-2025-0285 — Recovery Inhibition (arcusmedia)
// Status: experimental | Level: high | ID: 092bcd4f-313d-5303-84b7-0525370570ca

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
