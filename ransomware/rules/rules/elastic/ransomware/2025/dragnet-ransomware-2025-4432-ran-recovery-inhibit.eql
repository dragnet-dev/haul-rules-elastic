// Dragnet [Ransomware]: dragnet-ransomware-2025-4432 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 79d6b303-d51c-5381-b01e-e6e6c51956e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
