// Dragnet [Ransomware]: dragnet-ransomware-2025-6320 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 71be322f-c4c0-5da6-92ad-2a0ef60c8dd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
