// Dragnet [Ransomware]: dragnet-ransomware-2025-1945 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 33a77104-1e5b-50a6-b0b3-f66331109474

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
