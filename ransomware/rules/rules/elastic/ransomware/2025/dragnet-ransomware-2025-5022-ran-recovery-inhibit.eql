// Dragnet [Ransomware]: dragnet-ransomware-2025-5022 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 43f204e5-d582-5967-b3e2-a48e61812be9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
