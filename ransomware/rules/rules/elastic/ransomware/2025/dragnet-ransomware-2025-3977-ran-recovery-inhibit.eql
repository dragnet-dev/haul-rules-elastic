// Dragnet [Ransomware]: dragnet-ransomware-2025-3977 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 271ea19e-850b-5f45-abcc-8e0e39e3746d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
