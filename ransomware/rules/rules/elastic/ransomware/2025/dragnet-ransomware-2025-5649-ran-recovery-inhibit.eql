// Dragnet [Ransomware]: dragnet-ransomware-2025-5649 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 106602ed-cf55-517a-8dd6-a35a33ab37b7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
