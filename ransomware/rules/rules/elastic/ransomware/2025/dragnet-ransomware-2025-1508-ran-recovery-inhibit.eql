// Dragnet [Ransomware]: dragnet-ransomware-2025-1508 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 733bd571-e665-5583-8f43-3880b7456a57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
