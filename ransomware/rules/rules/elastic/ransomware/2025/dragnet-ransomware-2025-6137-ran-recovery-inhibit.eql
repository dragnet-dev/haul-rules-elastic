// Dragnet [Ransomware]: dragnet-ransomware-2025-6137 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 448f46db-27f9-597c-a6ae-87aa1b7ed40a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
