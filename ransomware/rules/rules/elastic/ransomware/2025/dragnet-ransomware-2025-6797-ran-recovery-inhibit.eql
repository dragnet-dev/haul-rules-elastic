// Dragnet [Ransomware]: dragnet-ransomware-2025-6797 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 41ab3c8b-0f06-58e9-95fd-d6973b5ffa23

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
