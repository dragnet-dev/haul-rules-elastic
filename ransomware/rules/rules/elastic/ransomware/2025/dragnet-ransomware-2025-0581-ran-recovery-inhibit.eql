// Dragnet [Ransomware]: dragnet-ransomware-2025-0581 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: c51080cd-8871-5541-983d-e408e1fda5f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
