// Dragnet [Ransomware]: dragnet-ransomware-2025-0683 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: b3e7595c-61c7-5031-9696-db5eb7d73a99

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
