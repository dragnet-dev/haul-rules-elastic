// Dragnet [Ransomware]: dragnet-ransomware-2025-4204 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: bfd9836e-3bf7-5574-8c0d-1d3e0d1d4d73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
