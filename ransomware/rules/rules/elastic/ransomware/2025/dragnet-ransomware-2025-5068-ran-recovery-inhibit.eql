// Dragnet [Ransomware]: dragnet-ransomware-2025-5068 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 8e15ea4c-fb66-59d4-aea6-b444ecd68e7b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
