// Dragnet [Ransomware]: dragnet-ransomware-2025-1697 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: bf219e0c-710e-57f0-ac35-a5ebd373b9f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
