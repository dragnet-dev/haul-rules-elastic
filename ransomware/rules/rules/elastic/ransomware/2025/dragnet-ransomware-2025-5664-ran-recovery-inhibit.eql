// Dragnet [Ransomware]: dragnet-ransomware-2025-5664 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: bca1e52e-4f56-5a3b-8562-28f72f9fad1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
