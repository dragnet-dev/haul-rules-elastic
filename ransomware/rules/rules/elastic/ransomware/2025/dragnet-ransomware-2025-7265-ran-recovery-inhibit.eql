// Dragnet [Ransomware]: dragnet-ransomware-2025-7265 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: acc63a80-510e-5450-89c4-0ce324efd9b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
