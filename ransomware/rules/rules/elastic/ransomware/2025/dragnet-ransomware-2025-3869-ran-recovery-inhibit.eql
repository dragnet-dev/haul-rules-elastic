// Dragnet [Ransomware]: dragnet-ransomware-2025-3869 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 8f978672-5a31-5bfe-ac12-a545c12bc762

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
