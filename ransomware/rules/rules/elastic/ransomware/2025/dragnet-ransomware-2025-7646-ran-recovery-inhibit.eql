// Dragnet [Ransomware]: dragnet-ransomware-2025-7646 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: ea4172f1-40e2-5430-a812-656afaffe673

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
