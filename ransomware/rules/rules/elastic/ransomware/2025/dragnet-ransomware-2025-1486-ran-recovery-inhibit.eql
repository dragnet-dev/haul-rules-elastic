// Dragnet [Ransomware]: dragnet-ransomware-2025-1486 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 94423f83-3899-5f4a-ae71-19f418baa6b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
