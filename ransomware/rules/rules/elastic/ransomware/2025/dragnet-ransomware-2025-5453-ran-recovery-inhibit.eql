// Dragnet [Ransomware]: dragnet-ransomware-2025-5453 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 292e7892-52af-584b-a02a-f9e26faa8383

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
