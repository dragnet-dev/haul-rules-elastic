// Dragnet [Ransomware]: dragnet-ransomware-2025-4417 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 153189da-a33a-5efe-a1be-256d6c01b884

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
