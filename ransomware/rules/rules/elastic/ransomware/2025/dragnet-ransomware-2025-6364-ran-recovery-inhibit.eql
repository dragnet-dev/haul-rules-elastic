// Dragnet [Ransomware]: dragnet-ransomware-2025-6364 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0a14c117-d93c-51c3-9eca-a74042855c56

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
