// Dragnet [Ransomware]: dragnet-ransomware-2025-3725 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: dd9af78b-6ee6-5d57-865e-2fb2aafd70b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
