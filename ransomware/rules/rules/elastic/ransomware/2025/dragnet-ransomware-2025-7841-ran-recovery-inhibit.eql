// Dragnet [Ransomware]: dragnet-ransomware-2025-7841 — Recovery Inhibition (handala)
// Status: test | Level: high | ID: 75f012e6-78cf-55eb-893d-7c079452d27f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
