// Dragnet [Ransomware]: dragnet-ransomware-2025-0969 — Recovery Inhibition (rhysida)
// Status: deprecated | Level: high | ID: 2096d21b-fe22-5bc0-b282-8d9db90cd4af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
