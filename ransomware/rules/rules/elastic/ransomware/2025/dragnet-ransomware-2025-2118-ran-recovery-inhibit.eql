// Dragnet [Ransomware]: dragnet-ransomware-2025-2118 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 0525fa28-1078-51f2-9d96-b1a16e12c6f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
