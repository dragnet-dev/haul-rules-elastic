// Dragnet [Ransomware]: dragnet-ransomware-2025-4674 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: bc1c2ad7-bf64-5348-9f5a-e0a2beb73563

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
