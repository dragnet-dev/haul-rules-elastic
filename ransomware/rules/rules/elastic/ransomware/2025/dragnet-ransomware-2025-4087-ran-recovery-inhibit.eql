// Dragnet [Ransomware]: dragnet-ransomware-2025-4087 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 2316ff21-fecb-5673-8103-5bb95e1df01d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
