// Dragnet [Ransomware]: dragnet-ransomware-2025-0575 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: e23e861a-2aa5-58b2-8446-f025883b3db0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
