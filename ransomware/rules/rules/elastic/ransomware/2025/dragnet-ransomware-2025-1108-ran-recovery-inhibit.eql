// Dragnet [Ransomware]: dragnet-ransomware-2025-1108 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: bdfed470-d968-59c4-8bb4-a76acdca19c7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
