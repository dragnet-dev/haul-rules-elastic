// Dragnet [Ransomware]: dragnet-ransomware-2025-2375 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: c1cd0c75-aa0e-5596-9c64-7f6911c5c887

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
