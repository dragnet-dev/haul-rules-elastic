// Dragnet [Ransomware]: dragnet-ransomware-2025-6954 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d3eee47b-cc8f-5de0-bab1-d837652c16c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
