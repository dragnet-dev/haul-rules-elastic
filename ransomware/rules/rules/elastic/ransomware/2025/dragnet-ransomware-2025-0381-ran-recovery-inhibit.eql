// Dragnet [Ransomware]: dragnet-ransomware-2025-0381 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 39e8c445-fe4e-5074-a4ac-2078f7b98fd5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
