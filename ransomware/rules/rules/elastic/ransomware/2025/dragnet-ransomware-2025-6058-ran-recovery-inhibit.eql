// Dragnet [Ransomware]: dragnet-ransomware-2025-6058 — Recovery Inhibition (pear)
// Status: experimental | Level: high | ID: 87fb80a7-e008-5f3e-a749-aec2ca523ff6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
