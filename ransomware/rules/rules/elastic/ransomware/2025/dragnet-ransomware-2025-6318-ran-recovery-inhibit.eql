// Dragnet [Ransomware]: dragnet-ransomware-2025-6318 — Recovery Inhibition (hunters)
// Status: experimental | Level: high | ID: 18408ac3-7847-54bd-9781-079d92cf09f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
