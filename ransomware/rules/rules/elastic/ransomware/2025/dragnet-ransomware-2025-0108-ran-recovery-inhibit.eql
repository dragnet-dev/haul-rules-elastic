// Dragnet [Ransomware]: dragnet-ransomware-2025-0108 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 5ab298b2-ad07-5cba-8f19-36aece9bf637

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
