// Dragnet [Ransomware]: dragnet-ransomware-2025-0101 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 138a6417-9ea6-5a10-867a-f474e7d54ad8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
