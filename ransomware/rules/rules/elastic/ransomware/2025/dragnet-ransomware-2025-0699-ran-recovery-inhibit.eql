// Dragnet [Ransomware]: dragnet-ransomware-2025-0699 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 562f0ad9-197d-5cf6-8908-63033acacd0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
