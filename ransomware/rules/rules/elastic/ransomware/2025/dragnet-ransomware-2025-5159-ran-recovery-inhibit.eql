// Dragnet [Ransomware]: dragnet-ransomware-2025-5159 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 4483c415-06a8-5e92-862c-5f91bd9bb3a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
