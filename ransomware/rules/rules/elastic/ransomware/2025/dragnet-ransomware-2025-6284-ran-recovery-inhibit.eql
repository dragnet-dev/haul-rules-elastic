// Dragnet [Ransomware]: dragnet-ransomware-2025-6284 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 6161ae18-000b-5462-92a8-86246574a505

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
