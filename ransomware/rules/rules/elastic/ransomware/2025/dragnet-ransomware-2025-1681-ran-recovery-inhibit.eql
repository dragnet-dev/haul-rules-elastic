// Dragnet [Ransomware]: dragnet-ransomware-2025-1681 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 0842b7b8-cba3-526b-8fcb-4ab8a8f537a9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
