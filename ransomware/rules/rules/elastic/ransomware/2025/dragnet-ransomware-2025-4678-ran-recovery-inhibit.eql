// Dragnet [Ransomware]: dragnet-ransomware-2025-4678 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 7fa01056-8c56-58a3-ba09-fb5d49ee469a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
