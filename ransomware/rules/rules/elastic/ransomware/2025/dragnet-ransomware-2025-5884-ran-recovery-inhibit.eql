// Dragnet [Ransomware]: dragnet-ransomware-2025-5884 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 391bb85b-eff8-55f2-8e8c-362088e645b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
