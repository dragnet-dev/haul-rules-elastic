// Dragnet [Ransomware]: dragnet-ransomware-2025-6746 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 3a174cbd-f8e8-569d-b0c4-fa8f3f9d9eda

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
