// Dragnet [Ransomware]: dragnet-ransomware-2025-5969 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: f45be597-ab76-5d4c-b5ff-277468e432a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
