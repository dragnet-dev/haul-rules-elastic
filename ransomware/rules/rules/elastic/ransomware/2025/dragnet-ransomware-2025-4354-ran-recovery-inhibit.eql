// Dragnet [Ransomware]: dragnet-ransomware-2025-4354 — Recovery Inhibition (payoutsking)
// Status: experimental | Level: high | ID: 3d794221-a7ca-5f3a-8b8b-edfed7e14dfa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
