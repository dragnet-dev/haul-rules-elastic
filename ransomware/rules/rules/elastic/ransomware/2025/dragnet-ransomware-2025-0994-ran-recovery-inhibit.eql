// Dragnet [Ransomware]: dragnet-ransomware-2025-0994 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 9600ad16-b585-5d85-aad6-0c3a58f9f37b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
