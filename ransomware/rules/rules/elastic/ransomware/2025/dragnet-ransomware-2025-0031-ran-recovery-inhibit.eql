// Dragnet [Ransomware]: dragnet-ransomware-2025-0031 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 21e9dd41-cf6e-5352-b835-c7f69cc76247

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
