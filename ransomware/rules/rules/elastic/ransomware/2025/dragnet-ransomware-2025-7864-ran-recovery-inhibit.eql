// Dragnet [Ransomware]: dragnet-ransomware-2025-7864 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 54541558-895c-5788-8705-cba469bda838

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
