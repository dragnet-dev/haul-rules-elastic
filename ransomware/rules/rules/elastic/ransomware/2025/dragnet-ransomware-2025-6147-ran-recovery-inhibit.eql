// Dragnet [Ransomware]: dragnet-ransomware-2025-6147 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ca1324ae-2f4b-5725-a168-fcc4bab9720f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
