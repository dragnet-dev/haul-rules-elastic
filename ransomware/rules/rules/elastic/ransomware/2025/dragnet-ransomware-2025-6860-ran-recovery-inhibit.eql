// Dragnet [Ransomware]: dragnet-ransomware-2025-6860 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: d58934d1-e6bb-5550-9beb-3d1b6dc80184

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
