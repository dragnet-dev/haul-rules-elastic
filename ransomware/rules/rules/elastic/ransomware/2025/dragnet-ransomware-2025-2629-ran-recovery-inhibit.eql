// Dragnet [Ransomware]: dragnet-ransomware-2025-2629 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 6ffab779-f1e2-5962-a9c4-938b93b370e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
