// Dragnet [Ransomware]: dragnet-ransomware-2025-5422 — Recovery Inhibition (arkana)
// Status: experimental | Level: high | ID: 118267ab-df6c-5155-8de1-1a5c9d885ad9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
