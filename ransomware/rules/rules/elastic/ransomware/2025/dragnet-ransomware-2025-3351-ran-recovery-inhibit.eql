// Dragnet [Ransomware]: dragnet-ransomware-2025-3351 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 35b49573-5f13-59d1-a490-927fdd6d1fa7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
