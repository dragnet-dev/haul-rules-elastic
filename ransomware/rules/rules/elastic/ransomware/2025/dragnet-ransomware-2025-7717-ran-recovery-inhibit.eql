// Dragnet [Ransomware]: dragnet-ransomware-2025-7717 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 2721da61-4fb9-5d70-9d64-3e5586c55819

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
