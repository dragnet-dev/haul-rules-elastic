// Dragnet [Ransomware]: dragnet-ransomware-2025-7348 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 11dd1c84-3449-53bf-9776-a5ddf1a7241b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
