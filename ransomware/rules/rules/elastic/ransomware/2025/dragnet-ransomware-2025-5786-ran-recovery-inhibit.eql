// Dragnet [Ransomware]: dragnet-ransomware-2025-5786 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 25f3a129-2da0-5649-a722-d36094b07c86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
