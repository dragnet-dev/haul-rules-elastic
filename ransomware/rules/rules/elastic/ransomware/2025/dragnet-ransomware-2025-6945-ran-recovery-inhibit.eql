// Dragnet [Ransomware]: dragnet-ransomware-2025-6945 — Recovery Inhibition (blacknevas)
// Status: experimental | Level: high | ID: cbb31c29-66c3-5a8c-811e-21ba93b4f64b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
