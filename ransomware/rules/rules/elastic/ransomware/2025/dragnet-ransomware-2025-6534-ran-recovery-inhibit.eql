// Dragnet [Ransomware]: dragnet-ransomware-2025-6534 — Recovery Inhibition (crypto24)
// Status: deprecated | Level: high | ID: 40b97ef0-2965-53d5-a16f-13f1c9bf895f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
