// Dragnet [Ransomware]: dragnet-ransomware-2025-1498 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: b50af105-8d1e-58dd-8a55-75c8a5826a2c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
