// Dragnet [Ransomware]: dragnet-ransomware-2025-7739 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: d228db8a-d7b0-500d-83ed-9ae9acad2960

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
