// Dragnet [Ransomware]: dragnet-ransomware-2025-6344 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 0d52bc88-5ead-5e5f-9498-378d5d123232

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
