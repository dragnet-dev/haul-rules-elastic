// Dragnet [Ransomware]: dragnet-ransomware-2025-6663 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6323eb0a-019c-549a-92df-927defdb87a3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
