// Dragnet [Ransomware]: dragnet-ransomware-2025-2646 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 4fde73e4-bff5-5d12-9d4c-ed1a5c35a21e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
