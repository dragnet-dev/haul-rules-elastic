// Dragnet [Ransomware]: dragnet-ransomware-2025-5420 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 073d560c-20ee-5f14-9747-7707d91a5a9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
