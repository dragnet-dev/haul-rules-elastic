// Dragnet [Ransomware]: dragnet-ransomware-2025-7033 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 549c05e4-a82a-57d1-9e3d-4f3709ed06ba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
