// Dragnet [Ransomware]: dragnet-ransomware-2025-7602 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9e918891-e603-5471-904c-3ae3f8b54c2e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
