// Dragnet [Ransomware]: dragnet-ransomware-2025-7614 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 32d043be-8b05-5a79-aa16-543affecd890

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
