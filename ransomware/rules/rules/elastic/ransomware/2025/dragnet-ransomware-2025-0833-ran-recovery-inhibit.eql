// Dragnet [Ransomware]: dragnet-ransomware-2025-0833 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 7dc95a8f-1dbd-5be7-a5c2-8882ea06eb15

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
