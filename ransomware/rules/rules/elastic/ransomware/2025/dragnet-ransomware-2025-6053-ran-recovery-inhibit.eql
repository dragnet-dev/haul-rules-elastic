// Dragnet [Ransomware]: dragnet-ransomware-2025-6053 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 583c4f88-0b25-54c9-a72f-0ab527ca2139

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
