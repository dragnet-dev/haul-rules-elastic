// Dragnet [Ransomware]: dragnet-ransomware-2025-5818 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e41bcf66-af85-5b7b-80c1-2a37601b9994

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
