// Dragnet [Ransomware]: dragnet-ransomware-2025-1332 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: c559c44e-0f57-5a06-a095-949c01ebd45b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
