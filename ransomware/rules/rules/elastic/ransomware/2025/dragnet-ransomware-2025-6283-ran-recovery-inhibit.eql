// Dragnet [Ransomware]: dragnet-ransomware-2025-6283 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: b9d4ee56-5a6a-514e-a308-7811ed1608c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
