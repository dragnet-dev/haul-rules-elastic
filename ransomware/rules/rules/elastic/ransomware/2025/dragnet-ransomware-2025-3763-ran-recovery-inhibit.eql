// Dragnet [Ransomware]: dragnet-ransomware-2025-3763 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cea5822f-c774-5ccc-9c25-da4a016b9344

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
