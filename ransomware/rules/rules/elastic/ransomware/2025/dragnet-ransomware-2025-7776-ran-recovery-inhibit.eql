// Dragnet [Ransomware]: dragnet-ransomware-2025-7776 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: bdb2aa3b-1bce-55c5-b8a9-a764c4df3506

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
