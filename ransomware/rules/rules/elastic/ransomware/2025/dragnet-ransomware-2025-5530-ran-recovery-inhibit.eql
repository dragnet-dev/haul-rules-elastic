// Dragnet [Ransomware]: dragnet-ransomware-2025-5530 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: f9768977-868f-5887-8c36-e4381dc9dd8d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
