// Dragnet [Ransomware]: dragnet-ransomware-2025-7355 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8868dc8d-5e2b-580f-a7ee-ba5c1abee7b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
