// Dragnet [Ransomware]: dragnet-ransomware-2025-5874 — Recovery Inhibition (silent)
// Status: experimental | Level: high | ID: b690087b-bce0-5f6f-bebd-88b08b1b17d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
