// Dragnet [Ransomware]: dragnet-ransomware-2025-2298 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 852e74a1-b4e7-5196-8530-f648339625f4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
