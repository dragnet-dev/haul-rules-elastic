// Dragnet [Ransomware]: dragnet-ransomware-2025-5317 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: f20e53ed-d756-561c-a881-8c604e7b5284

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
