// Dragnet [Ransomware]: dragnet-ransomware-2025-4992 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: e15c56f7-9fe9-548a-9cb4-c8223a55c31c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
