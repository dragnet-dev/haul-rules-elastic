// Dragnet [Ransomware]: dragnet-ransomware-2025-2504 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 356246ed-4691-59e7-8d48-c7378fa9af1d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
