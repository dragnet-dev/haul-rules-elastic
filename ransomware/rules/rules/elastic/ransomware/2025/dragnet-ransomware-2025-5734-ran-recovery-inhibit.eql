// Dragnet [Ransomware]: dragnet-ransomware-2025-5734 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 413227de-aed0-5601-b757-be7469439153

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
