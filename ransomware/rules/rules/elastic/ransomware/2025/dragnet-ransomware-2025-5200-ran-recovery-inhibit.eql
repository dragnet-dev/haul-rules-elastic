// Dragnet [Ransomware]: dragnet-ransomware-2025-5200 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 8581040a-7bf7-5254-96c8-c4e2af173f07

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
