// Dragnet [Ransomware]: dragnet-ransomware-2025-3864 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: e3bd49c0-318d-5f7e-aafc-1c4c108be6a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
