// Dragnet [Ransomware]: dragnet-ransomware-2025-5746 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: ea81b5a0-f5a1-5c7a-a5ff-c6fe37b6445d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
