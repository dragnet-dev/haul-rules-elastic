// Dragnet [Ransomware]: dragnet-ransomware-2025-7676 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 12862d8a-8316-5a7c-b361-baa3f56a97b9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
