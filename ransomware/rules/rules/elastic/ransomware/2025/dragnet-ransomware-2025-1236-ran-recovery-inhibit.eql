// Dragnet [Ransomware]: dragnet-ransomware-2025-1236 — Recovery Inhibition (AiLock)
// Status: deprecated | Level: high | ID: e38bc5be-b869-5850-81bc-1f421cd29a09

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
