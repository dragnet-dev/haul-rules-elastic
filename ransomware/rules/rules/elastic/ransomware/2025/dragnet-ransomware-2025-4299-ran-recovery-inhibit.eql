// Dragnet [Ransomware]: dragnet-ransomware-2025-4299 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f81134e8-fdcd-53aa-9755-f813f1c4c5da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
