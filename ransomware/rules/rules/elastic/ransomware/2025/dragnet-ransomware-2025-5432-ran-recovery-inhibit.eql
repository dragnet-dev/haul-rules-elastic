// Dragnet [Ransomware]: dragnet-ransomware-2025-5432 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: be71dfe5-02c0-5baf-a7dd-73853bd5a3e3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
