// Dragnet [Ransomware]: dragnet-ransomware-2025-7652 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 626fcbe2-dbcd-5dd2-a74d-8156beb3c3c4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
