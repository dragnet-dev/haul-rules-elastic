// Dragnet [Ransomware]: dragnet-ransomware-2025-4988 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 49d4f4f9-21b7-5250-83bf-f0558dfde00c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
