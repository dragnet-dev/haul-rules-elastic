// Dragnet [Ransomware]: dragnet-ransomware-2025-5008 — Recovery Inhibition (VanHelsing)
// Status: experimental | Level: high | ID: 3301dd74-2a84-5787-93ba-ecf2412b0180

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
