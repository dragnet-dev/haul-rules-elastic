// Dragnet [Ransomware]: dragnet-ransomware-2025-0004 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: e34fe823-ebb0-5302-82d0-a484ec2e1564

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
