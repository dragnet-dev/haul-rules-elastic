// Dragnet [Ransomware]: dragnet-ransomware-2025-7130 — Recovery Inhibition (threeam)
// Status: experimental | Level: high | ID: aea2047f-86ff-5ce5-8fea-3a1737a7a3f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
