// Dragnet [Ransomware]: dragnet-ransomware-2025-3807 — Recovery Inhibition (ciphbit)
// Status: deprecated | Level: high | ID: a4a281f8-d0a3-5cfd-83f4-307adcc71ea4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
