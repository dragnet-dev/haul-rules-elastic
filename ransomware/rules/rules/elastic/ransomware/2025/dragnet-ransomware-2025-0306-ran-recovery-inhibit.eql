// Dragnet [Ransomware]: dragnet-ransomware-2025-0306 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 2ea373ce-ef6b-5193-b10f-bba9ad18c5b5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
