// Dragnet [Ransomware]: dragnet-ransomware-2025-1344 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 949b881d-3bc7-5fbf-86b3-27a310124df9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
