// Dragnet [Ransomware]: dragnet-ransomware-2025-6584 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: fc9bbba5-10aa-5331-a655-64383b5f48a0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
