// Dragnet [Ransomware]: dragnet-ransomware-2025-6142 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 476fd759-2c97-5abd-a8fa-59cdb03d6fd7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
