// Dragnet [Ransomware]: dragnet-ransomware-2025-0904 — Recovery Inhibition (gunra)
// Status: test | Level: high | ID: 45092781-4f3b-5e85-8c7f-d13b54ccf139

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
