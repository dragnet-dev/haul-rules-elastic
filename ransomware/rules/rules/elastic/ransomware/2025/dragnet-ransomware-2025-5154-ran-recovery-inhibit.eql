// Dragnet [Ransomware]: dragnet-ransomware-2025-5154 — Recovery Inhibition (warlock)
// Status: deprecated | Level: high | ID: 24d7b78f-9ce3-5336-816b-d93f3894b0f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
