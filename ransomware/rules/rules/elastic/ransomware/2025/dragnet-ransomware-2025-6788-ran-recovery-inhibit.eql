// Dragnet [Ransomware]: dragnet-ransomware-2025-6788 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 0a3abc84-fdc3-5cae-96b9-d805b3d20729

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
