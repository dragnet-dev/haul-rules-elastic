// Dragnet [Ransomware]: dragnet-ransomware-2025-0733 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 987a6287-6927-5f9a-8c88-8c97e79aef30

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
