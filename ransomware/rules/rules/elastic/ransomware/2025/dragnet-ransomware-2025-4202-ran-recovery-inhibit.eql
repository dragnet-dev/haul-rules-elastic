// Dragnet [Ransomware]: dragnet-ransomware-2025-4202 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 310557a7-bfc0-5c6d-9b7e-077e4cd6856d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
