// Dragnet [Ransomware]: dragnet-ransomware-2025-1645 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 4ddcd44c-2cc1-5680-ab37-3ae9e59b6666

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
