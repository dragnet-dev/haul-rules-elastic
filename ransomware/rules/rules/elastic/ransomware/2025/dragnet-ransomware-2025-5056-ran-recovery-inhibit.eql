// Dragnet [Ransomware]: dragnet-ransomware-2025-5056 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: e4262d4b-9dc4-5eba-8ecf-898922a6b9fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
