// Dragnet [Ransomware]: dragnet-ransomware-2025-4941 — Recovery Inhibition (devman)
// Status: deprecated | Level: high | ID: 8e90bd7b-544f-5e86-9f25-06571bb08c63

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
