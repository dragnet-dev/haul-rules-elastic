// Dragnet [Ransomware]: dragnet-ransomware-2025-6789 — Recovery Inhibition (coinbasecartel)
// Status: experimental | Level: high | ID: 1a112de9-cc53-5911-954e-fea48c300c71

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
