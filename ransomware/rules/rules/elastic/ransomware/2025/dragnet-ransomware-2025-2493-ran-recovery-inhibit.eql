// Dragnet [Ransomware]: dragnet-ransomware-2025-2493 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 0f3c9a59-4fc3-51e7-bfff-5dda7d6e365a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
