// Dragnet [Ransomware]: dragnet-ransomware-2025-4913 — Recovery Inhibition (brotherhood)
// Status: deprecated | Level: high | ID: 697489b7-b127-535f-be1a-369474efd427

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
