// Dragnet [Ransomware]: dragnet-ransomware-2025-7736 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: 15295109-014a-5b6d-b13c-50ef24562986

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
