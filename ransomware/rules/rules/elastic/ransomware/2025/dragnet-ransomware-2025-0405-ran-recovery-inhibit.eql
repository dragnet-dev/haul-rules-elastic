// Dragnet [Ransomware]: dragnet-ransomware-2025-0405 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 1ce5e05c-008d-53fa-9dae-313c0ca9d5e2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
