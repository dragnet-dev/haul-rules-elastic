// Dragnet [Ransomware]: dragnet-ransomware-2025-7486 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 611c0b42-d6ab-58ff-b112-12d665242e0d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
