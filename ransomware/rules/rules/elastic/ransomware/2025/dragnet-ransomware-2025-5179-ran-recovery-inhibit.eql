// Dragnet [Ransomware]: dragnet-ransomware-2025-5179 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9acf54bb-ae3c-5f92-b1ce-ce9e5ec92674

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
