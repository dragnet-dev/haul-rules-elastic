// Dragnet [Ransomware]: dragnet-ransomware-2025-0126 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: adc2eb9b-a060-54c0-906e-f56af12a3971

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
