// Dragnet [Ransomware]: dragnet-ransomware-2025-7578 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 5048c6f8-3284-5465-9ce4-c554ac68c74c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
