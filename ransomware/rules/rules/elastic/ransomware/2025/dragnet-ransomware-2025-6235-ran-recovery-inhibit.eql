// Dragnet [Ransomware]: dragnet-ransomware-2025-6235 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 21beb3a1-a740-5f4d-b26d-1849071843bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
