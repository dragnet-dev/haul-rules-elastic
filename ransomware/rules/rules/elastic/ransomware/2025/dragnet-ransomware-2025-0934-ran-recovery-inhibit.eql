// Dragnet [Ransomware]: dragnet-ransomware-2025-0934 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: ed5a67ee-a818-5b33-baca-23539ad76c73

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
