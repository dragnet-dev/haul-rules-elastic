// Dragnet [Ransomware]: dragnet-ransomware-2025-4373 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 25fca613-8ad3-5365-ab2e-bdc8a89e336b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
