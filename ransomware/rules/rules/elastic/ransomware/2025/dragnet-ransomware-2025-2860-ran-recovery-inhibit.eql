// Dragnet [Ransomware]: dragnet-ransomware-2025-2860 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 38f274b9-f932-5170-b4e0-0c97336ea88e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
