// Dragnet [Ransomware]: dragnet-ransomware-2025-5708 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 92128a5a-1502-5320-8efd-b35434144121

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
