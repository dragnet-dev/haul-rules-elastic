// Dragnet [Ransomware]: dragnet-ransomware-2025-0614 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: f9a0d80b-0d49-55da-89d5-957adeaa09f9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
