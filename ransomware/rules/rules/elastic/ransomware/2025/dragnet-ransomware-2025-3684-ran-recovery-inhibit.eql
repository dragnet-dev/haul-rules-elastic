// Dragnet [Ransomware]: dragnet-ransomware-2025-3684 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3748bc23-de9f-557c-8095-90b18a0038ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
