// Dragnet [Ransomware]: dragnet-ransomware-2025-0340 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: b87ed3e2-198f-5b01-a045-d0d0c79aa889

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
