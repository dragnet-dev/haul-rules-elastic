// Dragnet [Ransomware]: dragnet-ransomware-2025-2624 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 81985ef4-1eae-502d-876d-27746546c970

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
