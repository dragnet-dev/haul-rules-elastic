// Dragnet [Ransomware]: dragnet-ransomware-2025-3109 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 51feb172-b4c0-5482-90dc-977bdb5ea77c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
