// Dragnet [Ransomware]: dragnet-ransomware-2025-2741 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: ace079f2-a2c0-5782-bf4a-063a87bce5ae

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
