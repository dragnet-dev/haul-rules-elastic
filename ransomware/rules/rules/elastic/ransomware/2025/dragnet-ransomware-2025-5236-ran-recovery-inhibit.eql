// Dragnet [Ransomware]: dragnet-ransomware-2025-5236 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 6533fce9-a6a0-5317-952d-fb9244141401

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
