// Dragnet [Ransomware]: dragnet-ransomware-2025-4188 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 3b1db0bf-844b-5b64-8904-593bcfe5fe98

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
