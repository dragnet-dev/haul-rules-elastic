// Dragnet [Ransomware]: dragnet-ransomware-2025-5410 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 04fc3362-5172-5a8c-9ce3-79b84648efa0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
