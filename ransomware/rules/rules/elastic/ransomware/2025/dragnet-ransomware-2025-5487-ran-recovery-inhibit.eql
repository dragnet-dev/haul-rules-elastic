// Dragnet [Ransomware]: dragnet-ransomware-2025-5487 — Recovery Inhibition (devman)
// Status: test | Level: high | ID: e205a827-acc1-51bd-bf69-fc0bbbde13af

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
