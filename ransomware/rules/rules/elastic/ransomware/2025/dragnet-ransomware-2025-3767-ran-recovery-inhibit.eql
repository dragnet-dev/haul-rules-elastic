// Dragnet [Ransomware]: dragnet-ransomware-2025-3767 — Recovery Inhibition (metaencryptor)
// Status: experimental | Level: high | ID: 09b7b9f1-ab68-597d-a650-aea4e140663a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
