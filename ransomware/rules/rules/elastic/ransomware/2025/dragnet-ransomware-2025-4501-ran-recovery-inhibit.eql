// Dragnet [Ransomware]: dragnet-ransomware-2025-4501 — Recovery Inhibition (bianlian)
// Status: experimental | Level: high | ID: a17c3eea-db8c-5c0b-9fc9-081a5f317ec0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
