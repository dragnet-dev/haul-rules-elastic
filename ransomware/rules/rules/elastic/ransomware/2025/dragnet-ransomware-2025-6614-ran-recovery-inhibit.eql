// Dragnet [Ransomware]: dragnet-ransomware-2025-6614 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: bc50d7ce-2e27-5c7d-8588-dbe56f8771ac

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
