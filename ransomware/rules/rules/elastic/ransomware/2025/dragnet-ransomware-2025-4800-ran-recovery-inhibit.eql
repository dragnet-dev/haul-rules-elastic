// Dragnet [Ransomware]: dragnet-ransomware-2025-4800 — Recovery Inhibition (blacknevas)
// Status: test | Level: high | ID: 6de11107-4ba9-51c1-987f-0e4d43291011

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
