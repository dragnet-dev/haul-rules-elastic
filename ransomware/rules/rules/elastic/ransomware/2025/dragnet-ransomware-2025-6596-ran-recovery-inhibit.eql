// Dragnet [Ransomware]: dragnet-ransomware-2025-6596 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 4347e9db-2b53-5cf5-9ad1-66bfd3643227

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
