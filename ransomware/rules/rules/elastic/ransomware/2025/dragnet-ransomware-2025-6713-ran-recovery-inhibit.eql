// Dragnet [Ransomware]: dragnet-ransomware-2025-6713 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 6caa8853-343d-52fd-9fb4-39e56cfcbfb4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
