// Dragnet [Ransomware]: dragnet-ransomware-2025-5165 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: d07ea219-8c26-5c1d-937d-7992ce4508db

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
