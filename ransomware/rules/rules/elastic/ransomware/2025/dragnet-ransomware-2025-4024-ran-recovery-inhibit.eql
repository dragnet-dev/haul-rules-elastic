// Dragnet [Ransomware]: dragnet-ransomware-2025-4024 — Recovery Inhibition (cephalus)
// Status: deprecated | Level: high | ID: ca6471ce-38d8-541a-9ff0-0d18f1ce3ba1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
