// Dragnet [Ransomware]: dragnet-ransomware-2025-6358 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8fa21112-3344-513b-9d53-d761bde9f455

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
