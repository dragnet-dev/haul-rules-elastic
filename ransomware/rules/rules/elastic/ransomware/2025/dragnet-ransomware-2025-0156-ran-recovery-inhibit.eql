// Dragnet [Ransomware]: dragnet-ransomware-2025-0156 — Recovery Inhibition (obscura)
// Status: deprecated | Level: high | ID: 45b6564c-7455-5201-bb79-dc7aabfb3e19

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
