// Dragnet [Ransomware]: dragnet-ransomware-2025-1578 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: ee41a12a-4d4e-5eda-9d1e-4c46ff40a4c6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
