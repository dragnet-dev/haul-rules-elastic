// Dragnet [Ransomware]: dragnet-ransomware-2025-5787 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 02d50875-784f-5224-9006-caa599264542

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
