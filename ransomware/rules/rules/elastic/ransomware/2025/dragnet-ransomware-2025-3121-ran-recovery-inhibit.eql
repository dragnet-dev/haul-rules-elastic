// Dragnet [Ransomware]: dragnet-ransomware-2025-3121 — Recovery Inhibition (blacklock)
// Status: experimental | Level: high | ID: 42837b93-5420-5487-b5d8-4d3cac6875b4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
