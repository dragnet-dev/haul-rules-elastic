// Dragnet [Ransomware]: dragnet-ransomware-2025-7315 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: e6c8826f-e8bb-5183-959d-8a9c31c96c70

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
