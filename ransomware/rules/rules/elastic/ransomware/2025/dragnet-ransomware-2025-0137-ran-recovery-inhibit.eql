// Dragnet [Ransomware]: dragnet-ransomware-2025-0137 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 67d4342a-7c0c-5666-a0e1-a2cbe0f324ce

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
