// Dragnet [Ransomware]: dragnet-ransomware-2025-6569 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: 0fa6ee2d-1b37-5605-8c56-0452f43d4809

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
