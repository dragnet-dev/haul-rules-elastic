// Dragnet [Ransomware]: dragnet-ransomware-2025-3541 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: 25451828-ed3f-5432-a66c-8e79efb77504

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
