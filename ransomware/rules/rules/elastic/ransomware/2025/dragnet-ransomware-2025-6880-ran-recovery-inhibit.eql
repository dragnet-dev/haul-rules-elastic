// Dragnet [Ransomware]: dragnet-ransomware-2025-6880 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 59d058de-bb0b-5ba2-a79a-4a8d932ffa3f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
