// Dragnet [Ransomware]: dragnet-ransomware-2025-1976 — Recovery Inhibition (obscura)
// Status: experimental | Level: high | ID: 15ad71bd-0f49-532a-96ab-d4c49b81832e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
