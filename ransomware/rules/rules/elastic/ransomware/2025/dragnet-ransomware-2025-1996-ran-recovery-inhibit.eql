// Dragnet [Ransomware]: dragnet-ransomware-2025-1996 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: db6003d3-a4f5-58ed-b9fd-641ff65279bc

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
