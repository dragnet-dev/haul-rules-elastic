// Dragnet [Ransomware]: dragnet-ransomware-2025-4641 — Recovery Inhibition (nova)
// Status: experimental | Level: high | ID: 1fda7d82-23cd-5043-8875-ea4f6df68f40

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
