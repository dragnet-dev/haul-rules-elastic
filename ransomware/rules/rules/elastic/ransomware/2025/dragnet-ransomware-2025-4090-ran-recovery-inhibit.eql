// Dragnet [Ransomware]: dragnet-ransomware-2025-4090 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 99d944d7-8052-544e-a3d4-743c7cbbb468

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
