// Dragnet [Ransomware]: dragnet-ransomware-2025-2023 — Recovery Inhibition (sarcoma)
// Status: deprecated | Level: high | ID: a3dc68a7-48ae-56a0-b71c-a53781393099

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
