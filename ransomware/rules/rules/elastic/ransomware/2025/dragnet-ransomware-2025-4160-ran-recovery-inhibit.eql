// Dragnet [Ransomware]: dragnet-ransomware-2025-4160 — Recovery Inhibition (SilentRansomGroup)
// Status: deprecated | Level: high | ID: ab3501e7-9819-54e7-a117-db97b0154959

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
