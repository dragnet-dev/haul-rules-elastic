// Dragnet [Ransomware]: dragnet-ransomware-2025-5078 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 0248980e-59ca-5ab7-82f2-4af7b443d36c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
