// Dragnet [Ransomware]: dragnet-ransomware-2025-0984 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 581a0ad9-fcc0-520a-8a97-9a7672a04e8c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
