// Dragnet [Ransomware]: dragnet-ransomware-2025-1160 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 82b3ea31-d181-5905-a031-128c4dc9e5a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
