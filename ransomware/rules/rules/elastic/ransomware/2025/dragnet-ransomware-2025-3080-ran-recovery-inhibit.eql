// Dragnet [Ransomware]: dragnet-ransomware-2025-3080 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 859b1fd5-859d-5134-8663-4690daee6bbe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
