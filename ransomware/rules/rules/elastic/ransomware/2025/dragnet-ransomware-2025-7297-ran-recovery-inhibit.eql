// Dragnet [Ransomware]: dragnet-ransomware-2025-7297 — Recovery Inhibition (embargo)
// Status: experimental | Level: high | ID: 510682a9-f802-5a37-a0f7-1521363e5602

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
