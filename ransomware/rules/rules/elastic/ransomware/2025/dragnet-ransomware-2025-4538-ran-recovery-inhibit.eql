// Dragnet [Ransomware]: dragnet-ransomware-2025-4538 — Recovery Inhibition (radiant)
// Status: experimental | Level: high | ID: f301629f-44bf-5bfa-bd38-863f7dd62184

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
