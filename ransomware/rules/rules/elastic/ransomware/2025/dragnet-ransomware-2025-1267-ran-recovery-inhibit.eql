// Dragnet [Ransomware]: dragnet-ransomware-2025-1267 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 70ce9879-6c1f-5a94-bb00-a03ac5cbe7ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
