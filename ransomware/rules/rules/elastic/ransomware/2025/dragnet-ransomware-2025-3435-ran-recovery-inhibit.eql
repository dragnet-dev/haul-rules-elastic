// Dragnet [Ransomware]: dragnet-ransomware-2025-3435 — Recovery Inhibition (ransomhouse)
// Status: experimental | Level: high | ID: a400dd9a-4d1d-50b0-a82a-43fb95254854

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
