// Dragnet [Ransomware]: dragnet-ransomware-2025-0865 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 94d27795-868f-516a-b9b4-653a09f7650c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
