// Dragnet [Ransomware]: dragnet-ransomware-2025-1588 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: 427d1317-9765-5073-bbb5-c3884419ad83

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
