// Dragnet [Ransomware]: dragnet-ransomware-2025-7086 — Recovery Inhibition (sinobi)
// Status: test | Level: high | ID: 75965ed2-d81e-58e2-b3ac-35bff47b02f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
