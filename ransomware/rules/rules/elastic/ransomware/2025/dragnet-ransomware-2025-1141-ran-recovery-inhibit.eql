// Dragnet [Ransomware]: dragnet-ransomware-2025-1141 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: 5adbac83-f33c-5167-97ed-ad907f6f8c17

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
