// Dragnet [Ransomware]: dragnet-ransomware-2025-4770 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: cc3a2122-79ab-5bb5-9e73-ede04662f107

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
