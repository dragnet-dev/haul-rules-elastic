// Dragnet [Ransomware]: dragnet-ransomware-2025-0766 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: a635c691-62b2-5127-a14d-e8b02a47c1f6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
