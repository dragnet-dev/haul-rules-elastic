// Dragnet [Ransomware]: dragnet-ransomware-2025-2546 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 225ff4b7-84e4-5d56-a343-d8d2ffbea37d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
