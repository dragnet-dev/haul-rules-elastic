// Dragnet [Ransomware]: dragnet-ransomware-2025-5271 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 18736f4a-e1e0-560b-82b1-6cea2d5921e1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
