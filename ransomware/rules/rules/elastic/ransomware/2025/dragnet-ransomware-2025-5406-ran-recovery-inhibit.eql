// Dragnet [Ransomware]: dragnet-ransomware-2025-5406 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 751b581a-d66b-55a7-8656-9206b2d058a4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
