// Dragnet [Ransomware]: dragnet-ransomware-2025-1219 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6ba2498d-b317-57c0-a6ca-34a030c1134b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
