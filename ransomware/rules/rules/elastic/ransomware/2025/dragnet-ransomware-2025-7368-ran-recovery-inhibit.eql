// Dragnet [Ransomware]: dragnet-ransomware-2025-7368 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 878d95e6-2f99-5f59-abe2-0dd0076a00e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
