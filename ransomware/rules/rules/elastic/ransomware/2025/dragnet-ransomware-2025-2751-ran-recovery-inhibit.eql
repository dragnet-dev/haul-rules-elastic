// Dragnet [Ransomware]: dragnet-ransomware-2025-2751 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 68231360-99d6-501d-ac76-6f9eab53dcba

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
