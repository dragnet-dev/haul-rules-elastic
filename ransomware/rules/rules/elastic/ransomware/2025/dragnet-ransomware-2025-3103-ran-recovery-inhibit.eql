// Dragnet [Ransomware]: dragnet-ransomware-2025-3103 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 78585568-bb87-5175-becd-392b04549af0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
