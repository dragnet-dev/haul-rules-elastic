// Dragnet [Ransomware]: dragnet-ransomware-2025-0973 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: afe6ebf2-e2f9-52e3-a831-0d67cbe250f1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
