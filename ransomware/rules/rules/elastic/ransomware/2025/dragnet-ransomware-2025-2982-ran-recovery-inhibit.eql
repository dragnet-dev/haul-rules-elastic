// Dragnet [Ransomware]: dragnet-ransomware-2025-2982 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 5789d13b-47f0-586d-8451-a02afd41cf9f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
