// Dragnet [Ransomware]: dragnet-ransomware-2025-5092 — Recovery Inhibition (lockbit5)
// Status: experimental | Level: high | ID: aa1f3e86-8c7d-5dda-b67a-45a13a1e31c2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
