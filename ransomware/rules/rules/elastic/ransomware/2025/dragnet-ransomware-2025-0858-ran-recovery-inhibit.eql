// Dragnet [Ransomware]: dragnet-ransomware-2025-0858 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: c74e3202-bda2-5a08-85f1-66b33ba9c207

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
