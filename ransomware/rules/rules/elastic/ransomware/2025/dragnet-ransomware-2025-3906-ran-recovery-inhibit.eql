// Dragnet [Ransomware]: dragnet-ransomware-2025-3906 — Recovery Inhibition (cephalus)
// Status: deprecated | Level: high | ID: 24d52abb-f190-528b-bda4-53f584a8cab4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
