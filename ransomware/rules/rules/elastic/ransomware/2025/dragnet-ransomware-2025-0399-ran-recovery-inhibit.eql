// Dragnet [Ransomware]: dragnet-ransomware-2025-0399 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 6de0aca9-e18d-50c7-b3f9-50bc5d348ead

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
