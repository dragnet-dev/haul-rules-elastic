// Dragnet [Ransomware]: dragnet-ransomware-2025-0885 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: b6680f65-4438-52ae-8091-6347c4393a1a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
