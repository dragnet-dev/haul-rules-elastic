// Dragnet [Ransomware]: dragnet-ransomware-2025-1932 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 4f574ae4-6e81-5ea1-83db-acd1522728b2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
