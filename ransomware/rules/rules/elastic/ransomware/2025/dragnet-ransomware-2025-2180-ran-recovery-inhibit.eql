// Dragnet [Ransomware]: dragnet-ransomware-2025-2180 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 53d71983-b54f-502a-b5c5-ff765ddd2059

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
