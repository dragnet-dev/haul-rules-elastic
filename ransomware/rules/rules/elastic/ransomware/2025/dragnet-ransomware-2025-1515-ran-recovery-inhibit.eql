// Dragnet [Ransomware]: dragnet-ransomware-2025-1515 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 93d9dbe3-9cbe-50ed-bc89-0e0484cc77f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
