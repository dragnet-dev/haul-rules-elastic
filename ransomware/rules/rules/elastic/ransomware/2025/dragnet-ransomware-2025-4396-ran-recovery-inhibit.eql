// Dragnet [Ransomware]: dragnet-ransomware-2025-4396 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 360e103a-ce73-519f-b09d-bd20f249417a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
