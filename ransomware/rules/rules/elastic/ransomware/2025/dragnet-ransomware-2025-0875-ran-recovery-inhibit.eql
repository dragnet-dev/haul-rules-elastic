// Dragnet [Ransomware]: dragnet-ransomware-2025-0875 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: c28897df-4cf5-5e3c-9b30-556c2019cc85

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
