// Dragnet [Ransomware]: dragnet-ransomware-2025-6105 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 56b2e4ff-1a73-54d0-bd7f-2be4aebffe6e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
