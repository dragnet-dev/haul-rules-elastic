// Dragnet [Ransomware]: dragnet-ransomware-2025-6310 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 544a3e03-6e70-5e9e-8e1f-326ab9a09fc7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
