// Dragnet [Ransomware]: dragnet-ransomware-2025-1106 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 016fb963-50e3-5191-bd3a-90c49292b977

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
