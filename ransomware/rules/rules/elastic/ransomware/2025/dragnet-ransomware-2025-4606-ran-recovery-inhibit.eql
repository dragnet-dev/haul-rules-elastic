// Dragnet [Ransomware]: dragnet-ransomware-2025-4606 — Recovery Inhibition (kairos)
// Status: deprecated | Level: high | ID: a1c79457-5db3-5c37-a994-eb5c33629a9b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
