// Dragnet [Ransomware]: dragnet-ransomware-2025-6363 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 45aa7bb1-8f42-5e54-b877-91d3a663dbe4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
