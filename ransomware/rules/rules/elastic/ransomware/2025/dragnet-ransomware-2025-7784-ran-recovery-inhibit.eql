// Dragnet [Ransomware]: dragnet-ransomware-2025-7784 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: efd572e9-352a-5dc6-bab5-a9a77e12761d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
