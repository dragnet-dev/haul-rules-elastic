// Dragnet [Ransomware]: dragnet-ransomware-2025-6255 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: f216fb7f-da6e-5047-bb93-a02a20961839

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
