// Dragnet [Ransomware]: dragnet-ransomware-2025-1012 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 433a3933-398a-5a65-b2b1-579f55b1ca84

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
