// Dragnet [Ransomware]: dragnet-ransomware-2025-4207 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 3274591a-2731-5829-8949-16e55db731a5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
