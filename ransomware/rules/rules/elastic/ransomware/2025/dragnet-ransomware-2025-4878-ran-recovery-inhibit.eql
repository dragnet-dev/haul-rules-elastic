// Dragnet [Ransomware]: dragnet-ransomware-2025-4878 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 8db05a03-59d0-55a7-bd49-45bb78201afe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
