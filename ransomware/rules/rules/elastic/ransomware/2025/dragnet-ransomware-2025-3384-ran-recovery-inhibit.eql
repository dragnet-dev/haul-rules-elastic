// Dragnet [Ransomware]: dragnet-ransomware-2025-3384 — Recovery Inhibition (tridentlocker)
// Status: experimental | Level: high | ID: 468cc2a4-5603-5e70-8f63-8fb55bc62e31

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
