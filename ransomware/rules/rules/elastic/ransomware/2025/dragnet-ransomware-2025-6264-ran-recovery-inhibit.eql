// Dragnet [Ransomware]: dragnet-ransomware-2025-6264 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: ab503955-a777-5cba-8375-838d15412feb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
