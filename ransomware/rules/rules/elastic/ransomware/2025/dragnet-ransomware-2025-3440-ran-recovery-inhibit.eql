// Dragnet [Ransomware]: dragnet-ransomware-2025-3440 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 5735731b-5906-5b19-9a6e-2794444fe1e5

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
