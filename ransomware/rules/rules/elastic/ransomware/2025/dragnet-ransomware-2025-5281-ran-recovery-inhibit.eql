// Dragnet [Ransomware]: dragnet-ransomware-2025-5281 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: b6f342c0-be45-571f-b2d4-0ed33de1812f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
