// Dragnet [Ransomware]: dragnet-ransomware-2025-3517 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 04835b3d-b080-5bed-ad06-0180de67ea1e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
