// Dragnet [Ransomware]: dragnet-ransomware-2025-2503 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: d55e0fa8-b884-52e9-ab00-64093a7b9009

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
