// Dragnet [Ransomware]: dragnet-ransomware-2025-6227 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 6e529465-ce0d-5757-a87d-898f1d5f6ff6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
