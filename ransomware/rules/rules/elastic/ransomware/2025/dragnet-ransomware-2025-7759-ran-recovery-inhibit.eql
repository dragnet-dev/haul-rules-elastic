// Dragnet [Ransomware]: dragnet-ransomware-2025-7759 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 93d1be39-463b-54a2-b978-4c872f5f4890

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
