// Dragnet [Ransomware]: dragnet-ransomware-2025-0521 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: d9405fb9-48e1-5bea-a9ae-4781d92a2126

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
