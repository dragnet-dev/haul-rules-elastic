// Dragnet [Ransomware]: dragnet-ransomware-2025-5579 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: a0177aa0-673e-5ae2-8630-41806f7a07ab

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
