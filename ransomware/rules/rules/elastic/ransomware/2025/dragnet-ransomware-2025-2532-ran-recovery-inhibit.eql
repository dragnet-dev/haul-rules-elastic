// Dragnet [Ransomware]: dragnet-ransomware-2025-2532 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 540bfad6-e815-54b8-976e-94916d69ea37

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
