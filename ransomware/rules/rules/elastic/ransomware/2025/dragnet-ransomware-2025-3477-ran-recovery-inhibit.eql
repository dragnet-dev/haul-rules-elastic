// Dragnet [Ransomware]: dragnet-ransomware-2025-3477 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 76cd7942-9a96-575e-a061-582b273db7ec

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
