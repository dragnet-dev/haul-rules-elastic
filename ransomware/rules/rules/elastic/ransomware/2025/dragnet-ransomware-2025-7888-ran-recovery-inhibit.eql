// Dragnet [Ransomware]: dragnet-ransomware-2025-7888 — Recovery Inhibition (medusa)
// Status: experimental | Level: high | ID: f96f91c9-6bc2-5497-abb1-cf42cd5bda2d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
