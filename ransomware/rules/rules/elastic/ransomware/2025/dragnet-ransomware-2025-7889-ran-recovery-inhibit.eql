// Dragnet [Ransomware]: dragnet-ransomware-2025-7889 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 8933cdb3-1655-5965-aacb-18ebcb5c0306

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
