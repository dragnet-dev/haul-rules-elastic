// Dragnet [Ransomware]: dragnet-ransomware-2025-2895 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 5e14472e-7136-5c05-8caa-4e6229c15ab1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
