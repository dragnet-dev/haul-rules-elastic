// Dragnet [Ransomware]: dragnet-ransomware-2025-6539 — Recovery Inhibition (sinobi)
// Status: experimental | Level: high | ID: 6ed6528f-459d-5886-a59f-1cfde7ac67c0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
