// Dragnet [Ransomware]: dragnet-ransomware-2025-1421 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a96becb7-ca04-54bc-94d0-3a2d0e988470

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
