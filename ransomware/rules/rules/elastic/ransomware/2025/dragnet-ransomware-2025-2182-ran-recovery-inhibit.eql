// Dragnet [Ransomware]: dragnet-ransomware-2025-2182 — Recovery Inhibition (abyss)
// Status: deprecated | Level: high | ID: 7bbe14ce-c980-558b-8ef9-d7605b72d0a1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
