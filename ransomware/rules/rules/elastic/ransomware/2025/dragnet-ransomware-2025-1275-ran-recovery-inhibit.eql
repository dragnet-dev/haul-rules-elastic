// Dragnet [Ransomware]: dragnet-ransomware-2025-1275 — Recovery Inhibition (cactus)
// Status: experimental | Level: high | ID: 8db3c291-cc50-5d80-9add-3e15cb2e5728

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
