// Dragnet [Ransomware]: dragnet-ransomware-2025-0428 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 62dd35ac-d450-5ca8-84c7-3e7ee1e9c661

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
