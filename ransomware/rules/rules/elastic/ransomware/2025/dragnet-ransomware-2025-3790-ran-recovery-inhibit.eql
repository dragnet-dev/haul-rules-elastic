// Dragnet [Ransomware]: dragnet-ransomware-2025-3790 — Recovery Inhibition (worldleaks)
// Status: experimental | Level: high | ID: 97aed7de-cec8-533f-91ce-84b39d0adb03

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
