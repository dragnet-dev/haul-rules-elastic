// Dragnet [Ransomware]: dragnet-ransomware-2025-0712 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 110a4142-f632-5c4c-a2a2-cb4f588ca58f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
