// Dragnet [Ransomware]: dragnet-ransomware-2025-7236 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 9eebc37f-74bb-5197-834d-b8dd9dfc88e6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
