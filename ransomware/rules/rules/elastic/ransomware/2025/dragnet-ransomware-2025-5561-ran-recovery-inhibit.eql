// Dragnet [Ransomware]: dragnet-ransomware-2025-5561 — Recovery Inhibition (crazyhunter)
// Status: experimental | Level: high | ID: e2760fe8-3695-5721-a8f4-fe3f8a4f7dc3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
