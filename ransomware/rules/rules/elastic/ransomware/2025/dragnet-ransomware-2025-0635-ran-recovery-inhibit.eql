// Dragnet [Ransomware]: dragnet-ransomware-2025-0635 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 263df685-1c1e-58fa-adac-eb4722fc640c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
