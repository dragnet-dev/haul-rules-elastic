// Dragnet [Ransomware]: dragnet-ransomware-2025-6062 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: a4bdfd9a-4ffa-5b5a-85d3-1b5e911f1033

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
