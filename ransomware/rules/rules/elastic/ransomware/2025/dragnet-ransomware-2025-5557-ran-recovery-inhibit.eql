// Dragnet [Ransomware]: dragnet-ransomware-2025-5557 — Recovery Inhibition (everest)
// Status: experimental | Level: high | ID: 24dc0c08-bfb3-535e-9f3a-bc7f69f4ff12

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
