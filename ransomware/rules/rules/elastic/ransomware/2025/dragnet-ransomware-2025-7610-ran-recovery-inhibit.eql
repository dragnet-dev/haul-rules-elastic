// Dragnet [Ransomware]: dragnet-ransomware-2025-7610 — Recovery Inhibition (J)
// Status: experimental | Level: high | ID: 993d3bb8-bce9-5f74-bd97-85ecda2ed0d8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
