// Dragnet [Ransomware]: dragnet-ransomware-2025-7221 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 21ef3862-10b6-52f2-8d4f-3fa55315ca0e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
