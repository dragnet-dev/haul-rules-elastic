// Dragnet [Ransomware]: dragnet-ransomware-2025-4397 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: d2f6cf8f-4267-53ae-ae65-417d40a91bd8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
