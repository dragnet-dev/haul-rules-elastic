// Dragnet [Ransomware]: dragnet-ransomware-2025-2805 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 38664040-5a92-59c3-8458-667995ba9c05

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
