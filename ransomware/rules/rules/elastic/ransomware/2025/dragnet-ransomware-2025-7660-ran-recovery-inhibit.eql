// Dragnet [Ransomware]: dragnet-ransomware-2025-7660 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: d05ec10c-f84b-5cdc-b7ee-023d232cbc28

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
