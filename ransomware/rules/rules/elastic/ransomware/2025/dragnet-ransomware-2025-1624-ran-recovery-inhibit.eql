// Dragnet [Ransomware]: dragnet-ransomware-2025-1624 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: fa270501-90cf-5bf1-8d58-4dadcc742ba6

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
