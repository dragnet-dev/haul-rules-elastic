// Dragnet [Ransomware]: dragnet-ransomware-2025-6592 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 9eff731b-076b-5333-9365-68503b94056c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
