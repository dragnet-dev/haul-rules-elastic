// Dragnet [Ransomware]: dragnet-ransomware-2025-1535 — Recovery Inhibition (lynx)
// Status: experimental | Level: high | ID: 4fbe2ea2-0e10-5280-be65-ac8c19d238a8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
