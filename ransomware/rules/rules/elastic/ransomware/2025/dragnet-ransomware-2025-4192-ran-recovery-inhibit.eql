// Dragnet [Ransomware]: dragnet-ransomware-2025-4192 — Recovery Inhibition (chaos)
// Status: experimental | Level: high | ID: 9439ef6e-d114-56cb-a7fe-297c2d28f22b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
