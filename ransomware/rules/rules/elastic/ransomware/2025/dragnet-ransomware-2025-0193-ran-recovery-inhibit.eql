// Dragnet [Ransomware]: dragnet-ransomware-2025-0193 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 51cfbaa5-5a00-5c88-ac1d-f3fbc4fe4534

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
