// Dragnet [Ransomware]: dragnet-ransomware-2025-4156 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 5298a97d-d0f5-5077-8d84-acdfe680d0fe

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
