// Dragnet [Ransomware]: dragnet-ransomware-2025-7206 — Recovery Inhibition (flocker)
// Status: experimental | Level: high | ID: 68631d6b-fe01-58c2-900c-9b505edf17da

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
