// Dragnet [Ransomware]: dragnet-ransomware-2025-1625 — Recovery Inhibition (kairos)
// Status: experimental | Level: high | ID: 7796b412-0778-5626-9536-c608ab12440d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
