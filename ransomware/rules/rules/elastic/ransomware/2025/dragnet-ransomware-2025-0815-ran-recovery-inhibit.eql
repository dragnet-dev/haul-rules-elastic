// Dragnet [Ransomware]: dragnet-ransomware-2025-0815 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 265b4b83-7a44-5edc-b543-e804b91948ef

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
