// Dragnet [Ransomware]: dragnet-ransomware-2025-7469 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: fc7e0326-29ae-5256-b44e-7bc4d735aa90

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
