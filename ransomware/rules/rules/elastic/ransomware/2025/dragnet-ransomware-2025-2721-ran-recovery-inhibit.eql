// Dragnet [Ransomware]: dragnet-ransomware-2025-2721 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 8f27954c-2d44-5b7b-8e03-39e09a6a998d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
