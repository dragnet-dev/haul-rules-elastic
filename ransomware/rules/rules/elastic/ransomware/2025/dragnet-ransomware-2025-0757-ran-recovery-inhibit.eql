// Dragnet [Ransomware]: dragnet-ransomware-2025-0757 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 51820e67-bf89-5d90-aa1b-863838651bf3

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
