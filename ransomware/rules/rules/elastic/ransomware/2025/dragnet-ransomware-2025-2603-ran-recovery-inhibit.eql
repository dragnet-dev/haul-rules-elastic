// Dragnet [Ransomware]: dragnet-ransomware-2025-2603 — Recovery Inhibition (interlock)
// Status: experimental | Level: high | ID: 4ca46e15-c90f-55a3-bead-bff003ed2b4a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
