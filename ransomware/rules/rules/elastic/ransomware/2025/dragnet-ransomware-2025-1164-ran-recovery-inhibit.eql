// Dragnet [Ransomware]: dragnet-ransomware-2025-1164 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 0684e38e-b8a1-53eb-b5db-e17f6c189ace

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
