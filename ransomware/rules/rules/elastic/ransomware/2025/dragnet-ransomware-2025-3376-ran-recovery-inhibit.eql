// Dragnet [Ransomware]: dragnet-ransomware-2025-3376 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 8c314e56-9a34-500b-9b36-8fa7b4051252

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
