// Dragnet [Ransomware]: dragnet-ransomware-2025-2600 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 1289746d-a2fb-5a25-a022-eed039663595

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
