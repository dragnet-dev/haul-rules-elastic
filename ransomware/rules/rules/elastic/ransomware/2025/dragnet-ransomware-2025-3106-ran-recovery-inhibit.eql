// Dragnet [Ransomware]: dragnet-ransomware-2025-3106 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 8b0bb569-2f3f-5915-89ba-727f007da0d0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
