// Dragnet [Ransomware]: dragnet-ransomware-2025-4978 — Recovery Inhibition (funksec)
// Status: experimental | Level: high | ID: fb48872a-9f86-587b-a582-f66d93eac874

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
