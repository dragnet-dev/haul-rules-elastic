// Dragnet [Ransomware]: dragnet-ransomware-2025-1602 — Recovery Inhibition (devman)
// Status: experimental | Level: high | ID: beddfd25-c65a-5531-85c7-734095de7d57

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
