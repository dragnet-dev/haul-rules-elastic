// Dragnet [Ransomware]: dragnet-ransomware-2025-7851 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: da86089e-3a7c-554b-9080-87b9887819ea

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
