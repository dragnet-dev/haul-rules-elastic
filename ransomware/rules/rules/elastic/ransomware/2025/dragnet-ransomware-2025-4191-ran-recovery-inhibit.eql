// Dragnet [Ransomware]: dragnet-ransomware-2025-4191 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: b2b49a7a-9f5c-5b29-b48f-793844d48aad

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
