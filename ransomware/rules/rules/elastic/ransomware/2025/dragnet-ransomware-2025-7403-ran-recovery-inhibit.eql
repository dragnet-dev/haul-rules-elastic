// Dragnet [Ransomware]: dragnet-ransomware-2025-7403 — Recovery Inhibition (killsec)
// Status: experimental | Level: high | ID: a93dcf5e-69aa-5fef-8600-22ded614d1b1

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
