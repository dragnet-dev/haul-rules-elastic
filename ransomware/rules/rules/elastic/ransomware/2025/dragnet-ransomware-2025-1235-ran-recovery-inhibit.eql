// Dragnet [Ransomware]: dragnet-ransomware-2025-1235 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: af023338-7669-5875-a05b-da491407419f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
