// Dragnet [Ransomware]: dragnet-ransomware-2025-7333 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: f9ea17ef-155f-504d-815b-10d9d9f9f63e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
