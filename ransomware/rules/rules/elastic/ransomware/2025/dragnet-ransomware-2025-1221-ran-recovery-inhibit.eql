// Dragnet [Ransomware]: dragnet-ransomware-2025-1221 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: a2d4e678-785e-5e17-b2ad-60950ca4b4e4

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
