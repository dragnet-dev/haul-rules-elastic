// Dragnet [Ransomware]: dragnet-ransomware-2025-1472 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 1bacf2e7-221c-50ef-a319-504ec426cb62

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
