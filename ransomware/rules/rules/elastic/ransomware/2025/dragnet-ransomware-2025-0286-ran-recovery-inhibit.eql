// Dragnet [Ransomware]: dragnet-ransomware-2025-0286 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 50fe2da5-b9d4-5c07-ab10-a0b4fc41eb1c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
