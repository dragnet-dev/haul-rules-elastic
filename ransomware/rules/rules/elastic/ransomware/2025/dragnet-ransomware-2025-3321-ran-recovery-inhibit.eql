// Dragnet [Ransomware]: dragnet-ransomware-2025-3321 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: 9f63dd50-db30-5b0f-9399-d62146c21d06

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
