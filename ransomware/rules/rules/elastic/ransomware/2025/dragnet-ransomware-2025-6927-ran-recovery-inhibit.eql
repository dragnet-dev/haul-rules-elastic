// Dragnet [Ransomware]: dragnet-ransomware-2025-6927 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: ecbc7e0f-e143-51f4-8761-c09b8c3c77cd

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
