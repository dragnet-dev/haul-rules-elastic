// Dragnet [Ransomware]: dragnet-ransomware-2025-0081 — Recovery Inhibition (dragonforce)
// Status: test | Level: high | ID: 08a03692-81d1-5127-a98d-44ea6a7bc997

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
