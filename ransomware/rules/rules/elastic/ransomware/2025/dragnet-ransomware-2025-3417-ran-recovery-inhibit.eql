// Dragnet [Ransomware]: dragnet-ransomware-2025-3417 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 368a80cb-0cf7-5c59-91e4-34a23e07fe35

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
