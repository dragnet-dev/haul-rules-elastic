// Dragnet [Ransomware]: dragnet-ransomware-2025-7391 — Recovery Inhibition (direwolf)
// Status: experimental | Level: high | ID: d1ecb666-619f-5365-acb6-9f5612fa1964

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
