// Dragnet [Ransomware]: dragnet-ransomware-2025-3627 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: f9786ccb-abbf-590f-8b76-0aec8590ab77

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
