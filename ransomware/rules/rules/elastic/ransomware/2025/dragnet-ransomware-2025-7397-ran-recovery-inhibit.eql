// Dragnet [Ransomware]: dragnet-ransomware-2025-7397 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 762e8f00-6b5a-5bd2-bdfa-4220b5063984

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
