// Dragnet [Ransomware]: dragnet-ransomware-2025-2046 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 56741bcc-3d80-5769-8176-6afcf4a3fc0c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
