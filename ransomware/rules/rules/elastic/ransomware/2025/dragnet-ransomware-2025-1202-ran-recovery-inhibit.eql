// Dragnet [Ransomware]: dragnet-ransomware-2025-1202 — Recovery Inhibition (thegentlemen)
// Status: deprecated | Level: high | ID: 757dc332-8b00-544a-ba6d-e9bd954d7876

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
