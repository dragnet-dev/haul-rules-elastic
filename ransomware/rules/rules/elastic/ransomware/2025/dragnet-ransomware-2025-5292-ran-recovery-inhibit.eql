// Dragnet [Ransomware]: dragnet-ransomware-2025-5292 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: da428b0a-b070-5b52-a61a-1fd6dbd05f86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
