// Dragnet [Ransomware]: dragnet-ransomware-2025-0266 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: 005409f3-f063-5107-aa02-54fa32b34df2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
