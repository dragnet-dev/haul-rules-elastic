// Dragnet [Ransomware]: dragnet-ransomware-2025-2355 — Recovery Inhibition (global)
// Status: deprecated | Level: high | ID: bace7513-ead1-518a-ab17-f840573ff656

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
