// Dragnet [Ransomware]: dragnet-ransomware-2025-2950 — Recovery Inhibition (handala)
// Status: experimental | Level: high | ID: 92324263-a4d7-5ceb-bd83-b416335b3c4d

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
