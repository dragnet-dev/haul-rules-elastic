// Dragnet [Ransomware]: dragnet-ransomware-2025-5978 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 6e63a8bb-7def-5e6c-ade4-13cc5b3e034c

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
