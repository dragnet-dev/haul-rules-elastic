// Dragnet [Ransomware]: dragnet-ransomware-2025-5112 — Recovery Inhibition (worldleaks)
// Status: test | Level: high | ID: a717bfcb-ff48-591a-b7b2-0be1868651ff

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
