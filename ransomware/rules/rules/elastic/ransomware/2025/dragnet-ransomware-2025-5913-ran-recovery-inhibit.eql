// Dragnet [Ransomware]: dragnet-ransomware-2025-5913 — Recovery Inhibition (safepay)
// Status: experimental | Level: high | ID: 0f3e4dea-a620-58ab-a422-ea6564336212

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
