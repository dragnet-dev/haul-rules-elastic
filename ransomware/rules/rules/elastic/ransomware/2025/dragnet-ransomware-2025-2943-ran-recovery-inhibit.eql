// Dragnet [Ransomware]: dragnet-ransomware-2025-2943 — Recovery Inhibition (spacebears)
// Status: experimental | Level: high | ID: 575be8f6-1de3-52ab-9c22-09e05487e894

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
