// Dragnet [Ransomware]: dragnet-ransomware-2025-0667 — Recovery Inhibition (rhysida)
// Status: experimental | Level: high | ID: e1d76849-f110-5613-b8f4-74e8c6371623

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
