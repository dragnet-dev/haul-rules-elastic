// Dragnet [Ransomware]: dragnet-ransomware-2025-2060 — Recovery Inhibition (clop)
// Status: deprecated | Level: high | ID: 56c3de72-f973-546d-9392-9aa51b86c008

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
