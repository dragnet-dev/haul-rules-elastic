// Dragnet [Ransomware]: dragnet-ransomware-2025-1316 — Recovery Inhibition (akira)
// Status: deprecated | Level: high | ID: 38b07e1c-0c80-5639-96f3-fe08419aacfb

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
