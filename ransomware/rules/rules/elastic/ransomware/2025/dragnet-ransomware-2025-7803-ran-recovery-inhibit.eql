// Dragnet [Ransomware]: dragnet-ransomware-2025-7803 — Recovery Inhibition (lockbit3)
// Status: experimental | Level: high | ID: 01bfa643-74be-5589-b5c5-75d429106cb9

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
