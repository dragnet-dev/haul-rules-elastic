// Dragnet [Ransomware]: dragnet-ransomware-2025-6090 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 71dec3ce-e154-5e59-b9f2-f33b0197ce69

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
