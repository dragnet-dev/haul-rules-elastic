// Dragnet [Ransomware]: dragnet-ransomware-2025-1525 — Recovery Inhibition (alphalocker)
// Status: experimental | Level: high | ID: f3635ae2-2ddf-53d7-a6aa-78c80be06a82

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
