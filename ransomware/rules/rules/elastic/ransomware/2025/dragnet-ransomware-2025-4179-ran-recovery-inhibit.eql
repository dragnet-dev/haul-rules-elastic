// Dragnet [Ransomware]: dragnet-ransomware-2025-4179 — Recovery Inhibition (safepay)
// Status: test | Level: high | ID: 1aed2243-55c4-55c4-9d2e-5559cb2bcc7a

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
