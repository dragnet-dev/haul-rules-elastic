// Dragnet [Ransomware]: dragnet-ransomware-2025-3450 — Recovery Inhibition (lockbit5)
// Status: test | Level: high | ID: 35039683-06ab-5197-a89b-923ab24be4bf

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
