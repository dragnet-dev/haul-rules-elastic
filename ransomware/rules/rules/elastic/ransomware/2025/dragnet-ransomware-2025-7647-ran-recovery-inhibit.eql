// Dragnet [Ransomware]: dragnet-ransomware-2025-7647 — Recovery Inhibition (ransomhub)
// Status: experimental | Level: high | ID: 08b4ce34-369a-5b6d-82af-782ee2928517

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
