// Dragnet [Ransomware]: dragnet-ransomware-2025-5623 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 92e29e70-dd71-5ce8-a6b7-2cee9ef3ba45

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
