// Dragnet [Ransomware]: dragnet-ransomware-2025-6809 — Recovery Inhibition (qilin)
// Status: test | Level: high | ID: 71a34c30-6b80-545b-b63e-c2abfeecec59

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
