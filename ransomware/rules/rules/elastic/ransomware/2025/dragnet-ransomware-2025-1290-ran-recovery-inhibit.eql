// Dragnet [Ransomware]: dragnet-ransomware-2025-1290 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: f0a11ce4-6dca-519e-b512-c3d4833ee0b0

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
