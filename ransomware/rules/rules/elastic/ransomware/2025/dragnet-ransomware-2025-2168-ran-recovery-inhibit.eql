// Dragnet [Ransomware]: dragnet-ransomware-2025-2168 — Recovery Inhibition (dragonforce)
// Status: experimental | Level: high | ID: dff9b32a-39c0-55a0-a796-1a4f9e353013

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
