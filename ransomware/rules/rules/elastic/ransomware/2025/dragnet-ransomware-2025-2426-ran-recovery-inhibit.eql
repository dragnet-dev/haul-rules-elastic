// Dragnet [Ransomware]: dragnet-ransomware-2025-2426 — Recovery Inhibition (thegentlemen)
// Status: experimental | Level: high | ID: 0f0bdbff-fced-50b3-8968-84533546931b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
