// Dragnet [Ransomware]: dragnet-ransomware-2025-4546 — Recovery Inhibition (clop)
// Status: experimental | Level: high | ID: 0abaf20a-7680-53bb-b327-a5a4c6f582f7

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
