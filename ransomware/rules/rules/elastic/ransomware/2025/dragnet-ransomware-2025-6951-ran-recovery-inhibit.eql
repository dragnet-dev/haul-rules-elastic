// Dragnet [Ransomware]: dragnet-ransomware-2025-6951 — Recovery Inhibition (nightspire)
// Status: deprecated | Level: high | ID: 4fab91d4-92d5-5251-b142-3935871d900f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
