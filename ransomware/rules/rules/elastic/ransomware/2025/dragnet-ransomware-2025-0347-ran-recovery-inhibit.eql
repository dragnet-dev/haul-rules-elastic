// Dragnet [Ransomware]: dragnet-ransomware-2025-0347 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 7c75c597-0975-57bf-98fc-488f14a83b86

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
