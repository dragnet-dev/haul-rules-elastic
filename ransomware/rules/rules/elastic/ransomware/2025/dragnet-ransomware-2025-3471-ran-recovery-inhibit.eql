// Dragnet [Ransomware]: dragnet-ransomware-2025-3471 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: 96aad6a7-6c11-5d25-8367-905f928a27f8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
