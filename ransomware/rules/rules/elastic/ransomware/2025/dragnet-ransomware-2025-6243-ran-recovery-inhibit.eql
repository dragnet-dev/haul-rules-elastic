// Dragnet [Ransomware]: dragnet-ransomware-2025-6243 — Recovery Inhibition (play)
// Status: experimental | Level: high | ID: fecfd293-303c-56c7-80a3-fd5b67a299aa

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
