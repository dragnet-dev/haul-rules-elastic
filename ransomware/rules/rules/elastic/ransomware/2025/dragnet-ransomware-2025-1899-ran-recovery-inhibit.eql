// Dragnet [Ransomware]: dragnet-ransomware-2025-1899 — Recovery Inhibition (babuk2)
// Status: experimental | Level: high | ID: 646b9bd3-4d9e-5f78-ad99-341b1f76fab8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
