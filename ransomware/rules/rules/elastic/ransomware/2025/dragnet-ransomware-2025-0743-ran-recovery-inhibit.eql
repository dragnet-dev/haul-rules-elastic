// Dragnet [Ransomware]: dragnet-ransomware-2025-0743 — Recovery Inhibition (8base)
// Status: experimental | Level: high | ID: ccf1170a-0c69-51f9-9e1e-9dd65b15b6f2

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
