// Dragnet [Ransomware]: dragnet-ransomware-2025-7891 — Recovery Inhibition (incransom)
// Status: experimental | Level: high | ID: 698e294e-3b08-5abe-bb3f-22f70dedbdc8

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
