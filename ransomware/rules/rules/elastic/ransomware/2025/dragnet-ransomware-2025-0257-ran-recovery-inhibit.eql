// Dragnet [Ransomware]: dragnet-ransomware-2025-0257 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: a0bfa81f-9019-5376-8398-850a3ec20fee

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
