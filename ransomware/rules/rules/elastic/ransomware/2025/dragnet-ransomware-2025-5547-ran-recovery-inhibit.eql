// Dragnet [Ransomware]: dragnet-ransomware-2025-5547 — Recovery Inhibition (qilin)
// Status: experimental | Level: high | ID: 1e3b7ea7-b9dc-5dae-9a3f-b389d69dc05e

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
