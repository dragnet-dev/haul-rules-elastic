// Dragnet [Ransomware]: dragnet-ransomware-2025-6397 — Recovery Inhibition (fog)
// Status: experimental | Level: high | ID: 6caae4cb-7ac7-5718-96b1-41800e33869b

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
