// Dragnet [Ransomware]: dragnet-ransomware-2025-5752 — Recovery Inhibition (direwolf)
// Status: test | Level: high | ID: 772b8eb7-ab52-58d3-afcd-804f8a2ff30f

process where
  ((process.command_line like~ "*recoveryenabled no*" or process.command_line like~ "*bootstatuspolicy ignoreallfailures*")) and
  (process.executable like~ "*\bcdedit.exe")
