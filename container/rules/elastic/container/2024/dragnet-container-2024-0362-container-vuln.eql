// Dragnet [Container]: dragnet-container-2024-0362 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0c064c49-964c-5686-b18d-dfb9d1b4e6e0

any where
  (process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
