// Dragnet [Container]: dragnet-container-2024-0328 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d0440d6a-8980-5aa2-9c82-167c8a465bf1

any where
  (process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:19.04*" or process.executable like~ "*ubuntu:19.10*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:20.10*")
