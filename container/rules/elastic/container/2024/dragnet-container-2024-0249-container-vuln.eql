// Dragnet [Container]: dragnet-container-2024-0249 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4e5d353a-295f-5ef9-b3a2-0ac24f72b05a

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
