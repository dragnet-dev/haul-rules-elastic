// Dragnet [Container]: dragnet-container-2024-0078 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 44008165-35d6-5852-a67b-99fb2d71c7d5

any where
  (process.executable like~ "*alpine:3.13*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:9*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:18.04-ESM*")
