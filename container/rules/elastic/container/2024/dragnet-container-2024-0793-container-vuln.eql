// Dragnet [Container]: dragnet-container-2024-0793 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 883883ee-59a7-53e5-b50d-3e10b5710e0d

any where
  (process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*ubuntu:20.04*")
