// Dragnet [Container]: dragnet-container-2024-0144 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8752a3d5-ed70-558c-a8e9-21fd4f24a7a0

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*photon os:2.0*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
