// Dragnet [Container]: dragnet-container-2024-0101 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 441d1502-b5b9-5849-b7b6-6a671846144e

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:19.04*" or process.executable like~ "*ubuntu:19.10*")
