// Dragnet [Container]: dragnet-container-2024-0787 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6a67ded2-0fcc-54b4-81b4-2409ad5079ce

any where
  (process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:17.04*" or process.executable like~ "*ubuntu:17.10*" or process.executable like~ "*ubuntu:18.04*")
