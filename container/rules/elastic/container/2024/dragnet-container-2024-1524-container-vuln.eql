// Dragnet [Container]: dragnet-container-2024-1524 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 587a4eb3-0c0b-550d-933d-c3b89b3d214b

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:18.04*")
