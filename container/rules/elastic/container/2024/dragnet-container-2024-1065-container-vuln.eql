// Dragnet [Container]: dragnet-container-2024-1065 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d4dc016a-ede3-5850-b321-7018f1f779fc

any where
  (process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*photon os:5.0*" or process.executable like~ "*redhat/ubi9:*")
