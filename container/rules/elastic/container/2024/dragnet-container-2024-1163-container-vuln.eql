// Dragnet [Container]: dragnet-container-2024-1163 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 392de257-597d-569c-8956-3fab7c51b11a

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*photon os:2.0*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*redhat/ubi9:*")
