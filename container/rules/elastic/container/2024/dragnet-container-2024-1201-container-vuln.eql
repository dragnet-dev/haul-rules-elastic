// Dragnet [Container]: dragnet-container-2024-1201 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5bff6859-80c5-5fbe-b9e2-173e22ab2512

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:2.0*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*photon os:5.0*")
