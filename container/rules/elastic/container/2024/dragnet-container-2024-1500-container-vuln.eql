// Dragnet [Container]: dragnet-container-2024-1500 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c8d14554-2ff5-527e-b94a-0564032deda6

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*")
