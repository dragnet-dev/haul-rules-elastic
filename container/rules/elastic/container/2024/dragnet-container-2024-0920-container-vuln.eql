// Dragnet [Container]: dragnet-container-2024-0920 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 04c328f5-a5da-5e89-a956-f4c6769e4322

any where
  (process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*azure linux:3.0*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
