// Dragnet [Container]: dragnet-container-2024-0374 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 860b0705-12ce-5fae-9447-0b7f69903a91

any where
  (process.executable like~ "*debian:12*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
