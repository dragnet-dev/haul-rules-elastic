// Dragnet [Container]: dragnet-container-2024-0184 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 867f89ea-fb3f-559a-a6c4-723443450cf1

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:18.10*" or process.executable like~ "*ubuntu:19.04*")
