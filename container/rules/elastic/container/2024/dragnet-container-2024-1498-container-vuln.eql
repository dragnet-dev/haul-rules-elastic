// Dragnet [Container]: dragnet-container-2024-1498 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 12ed3cc1-ed98-5c0d-adbc-534f11b96b5f

any where
  (process.executable like~ "*alpine:3.16*" or process.executable like~ "*alpine:3.17*" or process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*")
