// Dragnet [Container]: dragnet-container-2024-1462 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0942bc81-2c47-59ac-8c8e-bc8d7cfb0930

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*redhat/ubi9:*")
