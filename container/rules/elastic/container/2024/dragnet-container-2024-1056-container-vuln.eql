// Dragnet [Container]: dragnet-container-2024-1056 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b40cd5c5-8aca-5f9b-9baa-a660840c2df4

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
