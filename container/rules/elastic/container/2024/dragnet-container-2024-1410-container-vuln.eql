// Dragnet [Container]: dragnet-container-2024-1410 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d5605f2f-c7fc-56c2-a862-1e90281f0f29

any where
  (process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*")
