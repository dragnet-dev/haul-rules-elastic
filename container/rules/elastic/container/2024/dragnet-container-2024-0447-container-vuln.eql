// Dragnet [Container]: dragnet-container-2024-0447 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 443c6508-d3e4-52cf-8aea-b4c5311cefea

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*")
