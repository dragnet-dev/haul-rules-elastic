// Dragnet [Container]: dragnet-container-2024-0148 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a1130515-aa7f-5f7c-9f91-50edbb5696b1

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:17.10*")
