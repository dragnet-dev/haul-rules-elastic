// Dragnet [Container]: dragnet-container-2024-0373 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 85f7aabe-ddb0-532d-a242-edfe5cf609ed

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*")
