// Dragnet [Container]: dragnet-container-2024-1458 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 924a63ca-f572-5aa1-803b-bb82b450413a

any where
  (process.executable like~ "*almalinux:9*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*")
