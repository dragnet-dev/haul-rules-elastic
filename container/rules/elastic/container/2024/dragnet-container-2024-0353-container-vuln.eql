// Dragnet [Container]: dragnet-container-2024-0353 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6c561caf-4df3-5d9b-b2c1-fb60ab6e3845

any where
  (process.executable like~ "*chainguard:*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*wolfi:*")
