// Dragnet [Container]: dragnet-container-2024-0303 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cf1f85f5-5aaa-5376-bf7d-7f40230552c2

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*")
