// Dragnet [Container]: dragnet-container-2024-0647 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3f916bf0-cfe4-57db-b685-365bfa48fd49

any where
  (process.executable like~ "*azure linux:3.0*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*redhat/ubi9:*")
