// Dragnet [Container]: dragnet-container-2024-0013 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 36abb012-3f80-5a67-baaa-da00e00faba8

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
