// Dragnet [Container]: dragnet-container-2024-0173 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d77c7db5-26d4-52bf-aca0-71eff53bc811

any where
  (process.executable like~ "*alpine:3.8*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
