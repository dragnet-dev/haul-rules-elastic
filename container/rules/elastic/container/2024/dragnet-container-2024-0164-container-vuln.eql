// Dragnet [Container]: dragnet-container-2024-0164 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 61f6419c-52cf-51f7-91ab-34353532cc65

any where
  (process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:17.10*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
