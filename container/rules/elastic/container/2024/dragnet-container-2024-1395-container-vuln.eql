// Dragnet [Container]: dragnet-container-2024-1395 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 75ab147e-0a0f-51dd-be16-3da3d90020f0

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*")
