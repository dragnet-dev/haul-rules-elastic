// Dragnet [Container]: dragnet-container-2024-1461 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1fec085c-5af1-5a4b-ae4a-1ecee0f644aa

any where
  (process.executable like~ "*alpine:3.16*" or process.executable like~ "*alpine:3.17*" or process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
