// Dragnet [Container]: dragnet-container-2024-0990 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: aa50684b-2082-5225-b837-c394f18edeca

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:17.10*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.10*")
