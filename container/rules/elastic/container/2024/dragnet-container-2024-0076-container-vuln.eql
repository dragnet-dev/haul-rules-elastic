// Dragnet [Container]: dragnet-container-2024-0076 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8aeb06e1-aab7-5769-b2de-bc2f1173973a

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
