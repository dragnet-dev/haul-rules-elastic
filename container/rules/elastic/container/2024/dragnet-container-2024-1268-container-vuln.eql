// Dragnet [Container]: dragnet-container-2024-1268 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 39f0017f-d25c-59ec-adb6-a8ae3dd58779

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
