// Dragnet [Container]: dragnet-container-2024-1028 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cdd02d6c-aa77-5058-94b1-c358d43daf22

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
