// Dragnet [Container]: dragnet-container-2024-1194 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b425ff65-1f5c-5947-a7de-2e830c17834f

any where
  (process.executable like~ "*alpine:3.10*" or process.executable like~ "*alpine:3.8*" or process.executable like~ "*alpine:3.9*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:19.04*" or process.executable like~ "*ubuntu:19.10*")
