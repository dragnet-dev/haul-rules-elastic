// Dragnet [Container]: dragnet-container-2024-0179 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 92b347c0-e5a8-5335-9b10-caba32af58f9

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
