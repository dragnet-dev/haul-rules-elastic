// Dragnet [Container]: dragnet-container-2024-1423 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0776c2e0-d642-59be-8262-aa42333b10f3

any where
  (process.executable like~ "*alpine:3.15*" or process.executable like~ "*alpine:3.16*" or process.executable like~ "*alpine:3.17*" or process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*photon os:4.0*")
