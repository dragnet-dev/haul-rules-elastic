// Dragnet [Container]: dragnet-container-2024-0413 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3ac977cc-4bc4-5626-8fc7-18f15513a205

any where
  (process.executable like~ "*azure linux:3.0*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
