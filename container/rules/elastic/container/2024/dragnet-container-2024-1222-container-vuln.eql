// Dragnet [Container]: dragnet-container-2024-1222 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e270a9bf-7378-5ffc-9bc4-cd7dcaad51c3

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:7*")
