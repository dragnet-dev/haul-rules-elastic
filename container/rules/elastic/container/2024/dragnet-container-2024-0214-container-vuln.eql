// Dragnet [Container]: dragnet-container-2024-0214 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: edbd08ac-87ef-5749-9ea3-a1c5b0abfa98

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*")
