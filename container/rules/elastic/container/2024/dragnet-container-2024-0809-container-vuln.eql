// Dragnet [Container]: dragnet-container-2024-0809 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 65ff9e33-9987-500f-8c6f-24bc8d18ddb2

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*")
