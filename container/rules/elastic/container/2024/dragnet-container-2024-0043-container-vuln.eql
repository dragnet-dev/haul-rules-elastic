// Dragnet [Container]: dragnet-container-2024-0043 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fe0bbc81-db87-5414-867e-272a7924b75f

any where
  (process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:24.04*")
