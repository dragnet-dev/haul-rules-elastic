// Dragnet [Container]: dragnet-container-2024-0140 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c6e15455-4087-5457-95fe-0c85dffabe87

any where
  (process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*ubuntu:20.04-ESM*")
