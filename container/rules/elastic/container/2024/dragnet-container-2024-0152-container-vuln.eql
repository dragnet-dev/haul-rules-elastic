// Dragnet [Container]: dragnet-container-2024-0152 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 933b1ebc-e6dc-551f-894a-f0318cd254a1

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*")
