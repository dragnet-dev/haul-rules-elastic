// Dragnet [Container]: dragnet-container-2024-0728 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 09dabb0e-fc28-5055-89f3-99e80ccdb03c

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:21.04*")
