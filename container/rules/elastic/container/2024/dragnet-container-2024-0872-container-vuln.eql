// Dragnet [Container]: dragnet-container-2024-0872 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fc8b8021-112b-561b-98e3-4da212f46b29

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*photon os:2.0*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
