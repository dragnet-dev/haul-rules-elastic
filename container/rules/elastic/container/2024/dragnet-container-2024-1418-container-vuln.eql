// Dragnet [Container]: dragnet-container-2024-1418 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f34eef6a-cde5-53c0-a7eb-ea2aa67c3183

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:17.04*" or process.executable like~ "*ubuntu:17.10*")
