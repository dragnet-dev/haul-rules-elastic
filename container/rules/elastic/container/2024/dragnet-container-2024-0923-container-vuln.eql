// Dragnet [Container]: dragnet-container-2024-0923 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d8288c47-ea76-51fa-bbe6-0b91a0cda30b

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:17.10*")
