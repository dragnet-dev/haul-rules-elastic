// Dragnet [Container]: dragnet-container-2024-0061 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1af1a451-cbfc-5ff0-a3be-2b55afa5c5ef

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:13*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
