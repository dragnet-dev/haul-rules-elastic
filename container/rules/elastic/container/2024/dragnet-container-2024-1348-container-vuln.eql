// Dragnet [Container]: dragnet-container-2024-1348 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3207d843-40e8-5286-ad50-cf5b1f0bbebe

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
