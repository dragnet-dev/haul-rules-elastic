// Dragnet [Container]: dragnet-container-2024-0656 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 86e013c6-3791-5f6e-a0e2-50ccc2cd3050

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:18.04-ESM*")
