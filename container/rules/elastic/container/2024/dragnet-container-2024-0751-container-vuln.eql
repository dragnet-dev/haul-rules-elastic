// Dragnet [Container]: dragnet-container-2024-0751 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 67773532-fbac-5fac-ae07-2b909821fe1e

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*alpine:3.14*" or process.executable like~ "*alpine:3.15*" or process.executable like~ "*amazonlinux:2022*" or process.executable like~ "*debian:11*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:21.10*" or process.executable like~ "*ubuntu:22.04*")
