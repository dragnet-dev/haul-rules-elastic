// Dragnet [Container]: dragnet-container-2024-1133 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0e32cf62-f415-54ae-9717-601e5b17d5b1

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*amazonlinux:2022*" or process.executable like~ "*cbl-mariner:1.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*photon os:2.0*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*")
