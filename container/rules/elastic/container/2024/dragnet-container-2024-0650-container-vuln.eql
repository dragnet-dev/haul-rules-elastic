// Dragnet [Container]: dragnet-container-2024-0650 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 566a62c8-79f0-5954-9ff7-ccc6d659e77c

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
