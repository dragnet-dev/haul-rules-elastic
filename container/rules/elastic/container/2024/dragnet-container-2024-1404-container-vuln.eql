// Dragnet [Container]: dragnet-container-2024-1404 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: aa846562-4151-5f3f-9198-6197a4ece387

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04-ESM*")
