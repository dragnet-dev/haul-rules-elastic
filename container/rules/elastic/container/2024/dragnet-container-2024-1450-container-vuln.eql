// Dragnet [Container]: dragnet-container-2024-1450 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 013b589a-2e61-5d5b-8c60-ef023685fe4e

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:16.04-ESM*")
