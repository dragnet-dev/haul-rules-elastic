// Dragnet [Container]: dragnet-container-2024-1449 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b1314d48-b117-5d01-83fc-42534f09f5e9

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*redhat/ubi9:*")
