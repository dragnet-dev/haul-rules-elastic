// Dragnet [Container]: dragnet-container-2024-0749 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bc940c49-6370-5f38-8294-da9da3bdc2d0

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*photon os:2.0*")
