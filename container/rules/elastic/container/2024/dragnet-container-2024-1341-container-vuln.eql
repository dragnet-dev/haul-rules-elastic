// Dragnet [Container]: dragnet-container-2024-1341 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b828ce61-43e1-5f55-9a9a-df49e4529ea7

any where
  (process.executable like~ "*alpine:3.18*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*photon os:5.0*")
