// Dragnet [Container]: dragnet-container-2024-1465 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0a5e5586-1374-5121-b0de-959654a8851c

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*")
