// Dragnet [Container]: dragnet-container-2024-0479 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cb61efa8-4be0-5f78-859f-a6d2a533d241

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
