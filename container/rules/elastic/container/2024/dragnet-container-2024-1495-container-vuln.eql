// Dragnet [Container]: dragnet-container-2024-1495 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b440d563-5428-52d6-a558-178dfbd7cd6d

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*")
