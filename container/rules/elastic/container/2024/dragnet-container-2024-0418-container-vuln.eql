// Dragnet [Container]: dragnet-container-2024-0418 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 405897a6-bdf2-5710-bab2-bf3714641c37

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:18.10*")
