// Dragnet [Container]: dragnet-container-2024-0807 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cbd82c4c-8bca-5154-90ff-0bcb0cada9f4

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
