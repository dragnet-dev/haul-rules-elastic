// Dragnet [Container]: dragnet-container-2024-1550 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d3c85508-56a6-5c39-82bd-9839adbce8e4

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*cbl-mariner:1.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:21.04*" or process.executable like~ "*ubuntu:21.10*")
