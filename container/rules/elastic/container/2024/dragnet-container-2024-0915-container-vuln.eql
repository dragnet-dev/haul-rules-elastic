// Dragnet [Container]: dragnet-container-2024-0915 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d396bab9-fd7a-5aa6-9996-b46553cb8f51

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*redhat/ubi9:*")
