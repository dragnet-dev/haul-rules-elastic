// Dragnet [Container]: dragnet-container-2024-1425 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3d602a8c-7e05-5be6-84db-a2c2520aef09

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*")
