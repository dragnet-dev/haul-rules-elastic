// Dragnet [Container]: dragnet-container-2024-0414 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4eb3a0a6-dd93-5430-b777-e8416d1f00cf

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
