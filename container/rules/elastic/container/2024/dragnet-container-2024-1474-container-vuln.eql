// Dragnet [Container]: dragnet-container-2024-1474 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9d9aca59-6a54-5f83-bf49-6829339fca0b

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*wolfi:*")
