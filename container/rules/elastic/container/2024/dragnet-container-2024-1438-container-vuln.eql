// Dragnet [Container]: dragnet-container-2024-1438 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c458f4b7-1d7b-5689-a394-e697e9036aa8

any where
  (process.executable like~ "*alpine:3.5*" or process.executable like~ "*alpine:3.6*" or process.executable like~ "*alpine:3.7*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*photon os:2.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
