// Dragnet [Container]: dragnet-container-2024-0435 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 440b6572-4af5-55c8-b963-35eb1d0571ed

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
