// Dragnet [Container]: dragnet-container-2024-1288 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fe3bc18c-ec93-5689-bbc8-e3ad95a8bd9e

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:17.10*")
