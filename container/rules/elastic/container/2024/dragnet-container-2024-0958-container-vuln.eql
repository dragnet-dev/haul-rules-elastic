// Dragnet [Container]: dragnet-container-2024-0958 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 75b0f2b0-f0b4-5610-8285-d84e352a7601

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:20.04-ESM*")
