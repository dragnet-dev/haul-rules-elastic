// Dragnet [Container]: dragnet-container-2024-0460 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d6568bfc-fb21-51a1-9898-91143d380922

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:18.10*")
