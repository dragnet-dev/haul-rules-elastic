// Dragnet [Container]: dragnet-container-2024-1467 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8e956176-c20c-5495-acfb-569e3b0139d9

any where
  (process.executable like~ "*alpine:3.15*" or process.executable like~ "*alpine:3.16*" or process.executable like~ "*amazonlinux:1*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
