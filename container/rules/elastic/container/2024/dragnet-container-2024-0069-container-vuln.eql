// Dragnet [Container]: dragnet-container-2024-0069 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c032cfc9-0b34-5565-94eb-a95e9a7efa50

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*")
