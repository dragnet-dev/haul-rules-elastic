// Dragnet [Container]: dragnet-container-2024-0271 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e1df02ff-8c4d-5e1b-b2ca-161908587d89

any where
  (process.executable like~ "*alpine:3.10*" or process.executable like~ "*alpine:3.11*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:20.10*")
