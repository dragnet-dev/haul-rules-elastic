// Dragnet [Container]: dragnet-container-2024-1398 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1131eb62-9004-5989-b5b8-ab67299ce51d

any where
  (process.executable like~ "*debian:14*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*photon os:2.0*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*redhat/ubi9:*")
