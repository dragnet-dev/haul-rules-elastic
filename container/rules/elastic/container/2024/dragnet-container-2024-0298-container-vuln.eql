// Dragnet [Container]: dragnet-container-2024-0298 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 30fceabb-e9ea-50f7-8a7d-9c1839ec3afa

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*")
