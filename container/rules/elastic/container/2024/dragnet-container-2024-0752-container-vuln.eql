// Dragnet [Container]: dragnet-container-2024-0752 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e885a0f6-344a-5d03-9157-59e56a05c058

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:9*")
