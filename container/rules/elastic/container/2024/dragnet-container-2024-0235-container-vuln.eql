// Dragnet [Container]: dragnet-container-2024-0235 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4f176776-d4eb-5647-8f56-a15f56d5cd7c

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*")
