// Dragnet [Container]: dragnet-container-2024-0549 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3a03eca5-fac2-5428-b712-136c48f92e7c

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:20.04-ESM*")
