// Dragnet [Container]: dragnet-container-2024-0783 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5ea76393-4343-5f26-b567-8a6376da1600

any where
  (process.executable like~ "*alpine:3.11*" or process.executable like~ "*alpine:3.12*" or process.executable like~ "*alpine:3.13*" or process.executable like~ "*alpine:3.14*" or process.executable like~ "*alpine:3.15*" or process.executable like~ "*amazonlinux:1*")
