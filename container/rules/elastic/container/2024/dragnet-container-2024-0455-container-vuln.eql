// Dragnet [Container]: dragnet-container-2024-0455 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cc2dbefe-4260-5682-874c-b5f5091e3504

any where
  (process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
