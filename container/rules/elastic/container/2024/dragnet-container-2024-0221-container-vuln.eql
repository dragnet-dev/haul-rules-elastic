// Dragnet [Container]: dragnet-container-2024-0221 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: aced6eae-d537-563e-b438-874ecc02b5c4

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
