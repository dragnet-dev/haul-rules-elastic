// Dragnet [Container]: dragnet-container-2024-0573 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dc832ee4-189d-548f-9018-b580e4da2650

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:18.04*")
