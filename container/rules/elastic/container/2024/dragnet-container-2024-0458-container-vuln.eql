// Dragnet [Container]: dragnet-container-2024-0458 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b62128b8-eb84-56e1-9de7-253e2349c476

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:18.04-ESM*")
