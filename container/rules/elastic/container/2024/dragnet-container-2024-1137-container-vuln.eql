// Dragnet [Container]: dragnet-container-2024-1137 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 0d9a2a53-afc8-5162-9918-740dfadb1dd6

any where
  (process.executable like~ "*alpine:3.15*" or process.executable like~ "*alpine:3.16*" or process.executable like~ "*alpine:3.17*" or process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*redhat/ubi9:*")
