// Dragnet [Container]: dragnet-container-2025-0602 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d118fa90-d016-542c-9964-b0ed3c34f270

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*")
