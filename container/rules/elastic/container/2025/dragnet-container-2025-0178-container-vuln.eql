// Dragnet [Container]: dragnet-container-2025-0178 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7996261d-54f3-53a0-abf3-23c415278e1b

any where
  (process.executable like~ "*chainguard:*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*wolfi:*")
