// Dragnet [Container]: dragnet-container-2025-0543 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: b7310cc4-bcce-5ca7-80f1-b77704b38944

any where
  (process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*")
