// Dragnet [Container]: dragnet-container-2025-0706 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1d27b27e-653c-55bf-90f1-5cd08cf030a0

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:18.04*")
