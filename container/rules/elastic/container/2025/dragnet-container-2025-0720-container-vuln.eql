// Dragnet [Container]: dragnet-container-2025-0720 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2cab03b5-8c13-5474-83d8-5c89c4a30f43

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*")
