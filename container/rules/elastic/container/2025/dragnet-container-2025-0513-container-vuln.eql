// Dragnet [Container]: dragnet-container-2025-0513 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1cc8ecc5-90f9-5a14-aac9-e12d2fb267e6

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:22.04*")
