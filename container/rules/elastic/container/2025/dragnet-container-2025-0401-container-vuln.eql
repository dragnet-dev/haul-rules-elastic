// Dragnet [Container]: dragnet-container-2025-0401 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dde07c18-8f29-54f9-8443-fee05dcf59ba

any where
  (process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:24.04*")
