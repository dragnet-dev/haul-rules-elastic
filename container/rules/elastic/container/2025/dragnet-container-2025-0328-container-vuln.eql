// Dragnet [Container]: dragnet-container-2025-0328 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e8123605-ca51-5174-828d-58b9e70b4875

any where
  (process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04-ESM*")
