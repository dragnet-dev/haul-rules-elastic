// Dragnet [Container]: dragnet-container-2025-0724 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4c1babb2-2a52-5d5d-aeae-c424081b8568

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*")
