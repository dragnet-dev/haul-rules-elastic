// Dragnet [Container]: dragnet-container-2025-0323 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a1442e3f-a413-5340-9306-e30a54339940

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*")
