// Dragnet [Container]: dragnet-container-2025-0267 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3162d632-636f-5a32-897f-e852d119f53b

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:25.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*" or process.executable like~ "*wolfi:*")
