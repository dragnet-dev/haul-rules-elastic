  (process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*azure linux:3.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:5.0*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:24.10*" or process.executable like~ "*ubuntu:25.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
