// Dragnet [Container]: dragnet-container-2025-0108 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 552a5486-c2e6-50ce-bcbe-159fc5669d1b

any where
  (process.executable like~ "*azure linux:3.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
