// Dragnet [Container]: dragnet-container-2025-0097 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5f6d6fa9-ac57-5c8c-803c-6a3b0a6340e4

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.10*" or process.executable like~ "*ubuntu:17.04*" or process.executable like~ "*ubuntu:17.10*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.10*")
