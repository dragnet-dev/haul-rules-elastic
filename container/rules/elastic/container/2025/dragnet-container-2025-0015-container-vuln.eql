// Dragnet [Container]: dragnet-container-2025-0015 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 522c4ff9-172b-5376-94de-9827715b0e49

any where
  (process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
