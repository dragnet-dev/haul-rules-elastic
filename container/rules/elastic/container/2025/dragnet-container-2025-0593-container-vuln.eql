// Dragnet [Container]: dragnet-container-2025-0593 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bdfb12dd-f38d-5a61-861b-f772131524cc

any where
  (process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*azure linux:3.0*")
