// Dragnet [Container]: dragnet-container-2025-0246 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 80b1015c-366b-5b2f-bf3e-428390a07ee7

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:17.10*" or process.executable like~ "*ubuntu:18.04*")
