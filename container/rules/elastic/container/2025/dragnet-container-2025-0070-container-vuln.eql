// Dragnet [Container]: dragnet-container-2025-0070 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 534ca1dc-7029-51b4-98b4-91f4ad8a9e8d

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*chainguard:*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*photon os:5.0*" or process.executable like~ "*wolfi:*")
