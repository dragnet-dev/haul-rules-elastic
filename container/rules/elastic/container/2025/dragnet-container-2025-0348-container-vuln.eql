// Dragnet [Container]: dragnet-container-2025-0348 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bc6b2fe0-0048-591b-b6f4-8c457f3a3e67

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*ubuntu:20.04-ESM*")
