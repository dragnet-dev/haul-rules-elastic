// Dragnet [Container]: dragnet-container-2025-0208 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 59c02450-493b-5aa5-94b5-50de64442ab0

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:23.04*" or process.executable like~ "*ubuntu:23.10*")
