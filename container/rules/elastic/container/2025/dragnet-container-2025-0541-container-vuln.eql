// Dragnet [Container]: dragnet-container-2025-0541 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8867e6c6-9009-5ba5-b566-de4640453f38

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
