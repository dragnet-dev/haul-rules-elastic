// Dragnet [Container]: dragnet-container-2025-0492 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 41005efe-db87-548a-892c-842a52109c05

any where
  (process.executable like~ "*almalinux:9*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:9*")
