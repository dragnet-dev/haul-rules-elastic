// Dragnet [Container]: dragnet-container-2025-0670 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8fbc4c9e-dbff-5053-84a9-980271c27ef1

any where
  (process.executable like~ "*debian:13*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:24.10*")
