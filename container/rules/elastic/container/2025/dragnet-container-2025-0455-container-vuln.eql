// Dragnet [Container]: dragnet-container-2025-0455 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f787747e-cd48-557c-9d34-2993f7cb46d4

any where
  (process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
