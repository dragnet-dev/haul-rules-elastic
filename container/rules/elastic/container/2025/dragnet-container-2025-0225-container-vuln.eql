// Dragnet [Container]: dragnet-container-2025-0225 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 86f27c67-cb0f-5d03-8644-942d883ce620

any where
  (process.executable like~ "*alpine:3.17*" or process.executable like~ "*cbl-mariner:1.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
