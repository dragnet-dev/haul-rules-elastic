// Dragnet [Container]: dragnet-container-2025-0443 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4d766498-7fcd-54a0-863d-94be761d357c

any where
  (process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*")
