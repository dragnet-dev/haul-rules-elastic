// Dragnet [Container]: dragnet-container-2025-0278 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 49ad7764-b171-58d6-ad08-a66514582589

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:17.10*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
