// Dragnet [Container]: dragnet-container-2025-0650 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c3d3e5f1-1772-57f1-8892-48166a551c2d

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*wolfi:*")
