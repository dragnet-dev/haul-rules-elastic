// Dragnet [Container]: dragnet-container-2025-0229 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ef5f95b4-4437-5d65-a081-36953a8b8a2f

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*azure linux:3.0*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*photon os:5.0*")
