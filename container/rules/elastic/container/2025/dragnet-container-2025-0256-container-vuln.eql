// Dragnet [Container]: dragnet-container-2025-0256 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f90c02eb-0d53-5ca3-95be-4fe94f0d0c30

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:18.04-ESM*")
