// Dragnet [Container]: dragnet-container-2025-0607 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 31ea81fd-9656-513d-a884-b10f6d1e0957

any where
  (process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*")
