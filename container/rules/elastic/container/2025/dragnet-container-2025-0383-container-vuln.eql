// Dragnet [Container]: dragnet-container-2025-0383 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1310540d-3476-53d9-a4cc-da896a2f1e78

any where
  (process.executable like~ "*alpine:3.16*" or process.executable like~ "*alpine:3.17*" or process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:21.10*")
