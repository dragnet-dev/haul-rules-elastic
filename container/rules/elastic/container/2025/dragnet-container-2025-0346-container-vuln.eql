// Dragnet [Container]: dragnet-container-2025-0346 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3dfaf16f-5920-57ee-baf3-367f98776483

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:24.10*")
