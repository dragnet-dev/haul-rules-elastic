// Dragnet [Container]: dragnet-container-2025-0477 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: c27852d7-2b83-5e58-9e55-e3e697e18882

any where
  (process.executable like~ "*azure linux:3.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*wolfi:*")
