// Dragnet [Container]: dragnet-container-2025-0409 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 38d68970-0585-5891-9d51-e8868b75d2a1

any where
  (process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:22.04*")
