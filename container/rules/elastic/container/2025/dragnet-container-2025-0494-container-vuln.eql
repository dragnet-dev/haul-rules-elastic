// Dragnet [Container]: dragnet-container-2025-0494 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6061a6c2-6c2a-5e24-a32c-dcaa5003a1da

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*azure linux:3.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
