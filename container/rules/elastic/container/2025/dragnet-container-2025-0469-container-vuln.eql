// Dragnet [Container]: dragnet-container-2025-0469 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 24462236-9485-507f-8254-1a66b54a4554

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:23.10*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:24.10*" or process.executable like~ "*ubuntu:25.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
