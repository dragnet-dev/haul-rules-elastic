// Dragnet [Container]: dragnet-container-2025-0683 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4d5df555-8310-5a38-ba27-df639a6bbdf3

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:20.04*")
