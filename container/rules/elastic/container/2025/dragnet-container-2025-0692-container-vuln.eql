// Dragnet [Container]: dragnet-container-2025-0692 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ac11ee18-59e2-5eb5-8af9-a3c378b986bf

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
