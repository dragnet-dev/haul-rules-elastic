  (process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*ubuntu:22.04*")
