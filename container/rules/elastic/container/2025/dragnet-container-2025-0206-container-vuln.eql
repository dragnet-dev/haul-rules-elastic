// Dragnet [Container]: dragnet-container-2025-0206 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0df15c5e-0073-53f7-a962-c804e19e6565

any where
  (process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:17.04*" or process.executable like~ "*ubuntu:17.10*")
