// Dragnet [Container]: dragnet-container-2025-0351 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 06d90be1-f97b-50ad-b14a-eae030bdcd32

any where
  (process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*wolfi:*")
