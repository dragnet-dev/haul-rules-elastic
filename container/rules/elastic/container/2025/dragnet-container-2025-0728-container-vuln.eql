// Dragnet [Container]: dragnet-container-2025-0728 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 42c0527e-ed71-5a2a-9ea5-3498b0cd448e

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
