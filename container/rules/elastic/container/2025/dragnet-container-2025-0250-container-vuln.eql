// Dragnet [Container]: dragnet-container-2025-0250 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3fa2dc18-9ec0-5a1d-a11a-da0de0a13632

any where
  (process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
