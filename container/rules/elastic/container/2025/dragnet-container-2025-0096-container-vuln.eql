// Dragnet [Container]: dragnet-container-2025-0096 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0d7232f9-b852-5b4e-8451-6c3df6b64209

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
