// Dragnet [Container]: dragnet-container-2025-0407 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 06306147-07df-5c11-bd4c-d845dbfae390

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*")
