// Dragnet [Container]: dragnet-container-2025-0283 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e20fcd4e-7132-5a11-8b48-a7a4c0c1f1d7

any where
  (process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*" or process.executable like~ "*wolfi:*")
