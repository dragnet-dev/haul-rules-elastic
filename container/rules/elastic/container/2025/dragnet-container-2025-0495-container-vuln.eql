// Dragnet [Container]: dragnet-container-2025-0495 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bcc0cc4e-5e63-5397-a78c-6437737aaac9

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2022*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:21.04*" or process.executable like~ "*ubuntu:21.10*")
