// Dragnet [Container]: dragnet-container-2025-0176 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 636b4d06-7414-55ed-ae96-cf3da080743b

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.10*")
