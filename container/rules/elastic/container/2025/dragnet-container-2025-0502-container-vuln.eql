// Dragnet [Container]: dragnet-container-2025-0502 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fbb09f8c-1d6d-5f74-bbd4-a7560d30a4e3

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*")
