// Dragnet [Container]: dragnet-container-2025-0603 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8cba0061-fbc9-50cd-bd59-7cc57eab0371

any where
  (process.executable like~ "*azure linux:3.0*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*")
