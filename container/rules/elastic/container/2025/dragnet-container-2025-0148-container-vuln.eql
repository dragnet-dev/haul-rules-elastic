// Dragnet [Container]: dragnet-container-2025-0148 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1f2f0500-cfbd-5740-946d-c6f1f78977b0

any where
  (process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:24.10*" or process.executable like~ "*wolfi:*")
