// Dragnet [Container]: dragnet-container-2025-0231 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8434b36a-c702-5eb5-b6c5-12ec8c7ac842

any where
  (process.executable like~ "*cbl-mariner:1.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:5.0*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:23.04*")
