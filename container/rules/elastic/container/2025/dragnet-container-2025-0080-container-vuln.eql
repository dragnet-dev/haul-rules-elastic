// Dragnet [Container]: dragnet-container-2025-0080 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8825b2be-69ab-55c2-9a42-cad7c9818100

any where
  (process.executable like~ "*azure linux:3.0*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*wolfi:*")
