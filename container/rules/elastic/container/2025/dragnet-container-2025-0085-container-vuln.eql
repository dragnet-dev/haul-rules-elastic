// Dragnet [Container]: dragnet-container-2025-0085 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 37859a3f-5288-5f77-ab1d-2b2916777de6

any where
  (process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*wolfi:*")
