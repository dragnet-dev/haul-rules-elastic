// Dragnet [Container]: dragnet-container-2026-1014 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e5bde582-b63c-50b5-91c3-7f8a0be3b526

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*")
