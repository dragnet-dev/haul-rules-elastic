// Dragnet [Container]: dragnet-container-2026-1803 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9ae4ff4c-2b9d-5f13-b1df-b67eb8c1f9ed

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*")
