// Dragnet [Container]: dragnet-container-2026-0225 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8662b5a1-5714-5bfd-b765-2412a89701e8

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:12.04*")
