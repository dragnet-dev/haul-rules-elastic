// Dragnet [Container]: dragnet-container-2026-0553 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6e081905-2580-553c-8b17-651d12abd07a

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:17.04*")
