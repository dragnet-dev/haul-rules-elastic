// Dragnet [Container]: dragnet-container-2026-0833 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e9e39aab-27fc-57d9-9f33-37874d4df4c4

any where
  (process.executable like~ "*almalinux:10*" or process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*wolfi:*")
