// Dragnet [Container]: dragnet-container-2026-0403 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 61969c80-828c-56f9-a549-e7029e7faab2

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*" or process.executable like~ "*ubuntu:15.10*")
