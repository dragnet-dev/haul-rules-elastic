// Dragnet [Container]: dragnet-container-2026-2856 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f509e82a-142b-5b33-88e1-4ee52d980a1d

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
