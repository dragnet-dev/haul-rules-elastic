// Dragnet [Container]: dragnet-container-2026-1676 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 52ac3977-3fe4-5f67-b1fa-67b882ca8018

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*")
