// Dragnet [Container]: dragnet-container-2026-1329 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 94653ee3-e4d9-556f-91d0-4b5820a8e8ad

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*" or process.executable like~ "*ubuntu:17.04*")
