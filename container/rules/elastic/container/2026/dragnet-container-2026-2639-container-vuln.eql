// Dragnet [Container]: dragnet-container-2026-2639 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cc204df9-a88c-5825-be8e-e20e03b21800

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.10*")
