// Dragnet [Container]: dragnet-container-2026-1291 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: bccabc83-ba1c-57f3-a08c-83c6f73104a6

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*" or process.executable like~ "*ubuntu:15.04*")
