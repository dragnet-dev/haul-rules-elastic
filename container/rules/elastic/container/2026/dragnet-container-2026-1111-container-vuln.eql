// Dragnet [Container]: dragnet-container-2026-1111 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 79f45a23-0ebf-5018-9ac8-9a61c3ab841e

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*")
