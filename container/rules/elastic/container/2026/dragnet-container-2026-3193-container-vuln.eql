// Dragnet [Container]: dragnet-container-2026-3193 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 787bbe25-aa14-5381-8d98-9c5958ff4ee2

any where
  (process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
