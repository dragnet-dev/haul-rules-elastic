// Dragnet [Container]: dragnet-container-2026-0277 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 1947454a-f139-56a9-810b-7dd218fd533d

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*chainguard:*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
