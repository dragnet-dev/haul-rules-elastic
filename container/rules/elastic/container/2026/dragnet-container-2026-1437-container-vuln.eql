// Dragnet [Container]: dragnet-container-2026-1437 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8ff1ef70-9d1b-53e3-b6fa-f66b8142380c

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.04*")
