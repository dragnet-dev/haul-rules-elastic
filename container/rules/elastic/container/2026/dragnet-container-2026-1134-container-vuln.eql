// Dragnet [Container]: dragnet-container-2026-1134 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 7e53a056-6545-50fe-b381-833e665cd8c1

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.10*" or process.executable like~ "*ubuntu:14.04*")
