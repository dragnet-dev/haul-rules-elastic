// Dragnet [Container]: dragnet-container-2026-0343 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 20483b1b-dc38-591d-ba82-98a2823e09d1

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.10*")
