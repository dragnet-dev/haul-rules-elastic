// Dragnet [Container]: dragnet-container-2026-2307 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2dd283f1-29a2-586a-bbf6-9438de305a5c

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
