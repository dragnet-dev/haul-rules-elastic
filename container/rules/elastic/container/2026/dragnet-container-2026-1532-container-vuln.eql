// Dragnet [Container]: dragnet-container-2026-1532 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 08e7ad90-d1d8-5878-bd15-d1847bda1283

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.10*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
