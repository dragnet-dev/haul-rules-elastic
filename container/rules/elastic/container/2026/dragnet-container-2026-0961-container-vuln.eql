// Dragnet [Container]: dragnet-container-2026-0961 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e579c0b7-ec29-5d75-8e03-2e838ec80a94

any where
  (process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
