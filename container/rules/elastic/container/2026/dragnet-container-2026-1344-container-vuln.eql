// Dragnet [Container]: dragnet-container-2026-1344 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ddd2bfa3-41c7-5b3c-ab68-90f3a90737ee

any where
  (process.executable like~ "*chainguard:*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*photon os:5.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:25.10*")
