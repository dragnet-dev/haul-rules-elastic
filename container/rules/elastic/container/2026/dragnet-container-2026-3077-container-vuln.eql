// Dragnet [Container]: dragnet-container-2026-3077 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 69c8f7e9-00ff-5a5e-acc5-8d3ebbd3883c

any where
  (process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*" or process.executable like~ "*ubuntu:13.10*")
