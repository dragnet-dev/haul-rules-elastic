// Dragnet [Container]: dragnet-container-2026-2847 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5b2feddc-3755-58f1-98cd-43e6e0e4dcfd

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
