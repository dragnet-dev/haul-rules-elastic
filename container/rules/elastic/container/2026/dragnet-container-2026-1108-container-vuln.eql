// Dragnet [Container]: dragnet-container-2026-1108 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6ce93f7b-abe2-5b37-a67a-80467fa012cf

any where
  (process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*wolfi:*")
