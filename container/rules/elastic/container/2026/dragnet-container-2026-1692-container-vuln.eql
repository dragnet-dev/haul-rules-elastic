// Dragnet [Container]: dragnet-container-2026-1692 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1489e159-1108-595d-87dd-bc1de94ee3e0

any where
  (process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*")
