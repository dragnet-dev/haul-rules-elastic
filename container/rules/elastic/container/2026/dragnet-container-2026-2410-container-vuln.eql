// Dragnet [Container]: dragnet-container-2026-2410 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 58ef1f44-252b-5542-9294-fcf235d6aa7f

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*")
