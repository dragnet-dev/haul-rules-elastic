// Dragnet [Container]: dragnet-container-2026-1912 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cf6a1c81-ec69-54e0-9156-c5f04f2d5a9d

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.04*" or process.executable like~ "*ubuntu:15.10*")
