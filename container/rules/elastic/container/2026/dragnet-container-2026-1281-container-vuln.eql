// Dragnet [Container]: dragnet-container-2026-1281 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 21c5bbbd-8daa-5f07-98d2-b753805492aa

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
