// Dragnet [Container]: dragnet-container-2026-0617 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 43e91dd7-5cb0-53f6-a6e4-d2dfa2ddfc85

any where
  (process.executable like~ "*alpine:3.4*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
