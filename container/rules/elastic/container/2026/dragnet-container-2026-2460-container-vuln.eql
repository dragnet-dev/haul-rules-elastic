// Dragnet [Container]: dragnet-container-2026-2460 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 0166a411-059c-556a-a997-9d3e3fd50ee5

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
