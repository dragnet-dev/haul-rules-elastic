// Dragnet [Container]: dragnet-container-2026-1970 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: b88e90e3-ea8c-5dcf-a7cf-6a6b7ffec537

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*chainguard:*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
