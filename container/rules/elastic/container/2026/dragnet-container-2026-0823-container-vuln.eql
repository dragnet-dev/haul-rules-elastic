// Dragnet [Container]: dragnet-container-2026-0823 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d65b82ee-3606-5105-a164-77d2b0f811fa

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*photon os:2.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
