// Dragnet [Container]: dragnet-container-2026-2952 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e25cac10-8eff-58a5-a164-3e1624cf1b25

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04-ESM*")
