// Dragnet [Container]: dragnet-container-2026-0593 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: acd765a7-3604-571e-b8dc-181692eac273

any where
  (process.executable like~ "*azure linux:3.0*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*")
