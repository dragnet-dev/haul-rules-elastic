// Dragnet [Container]: dragnet-container-2026-0304 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 458bc5d5-3175-571c-91a8-7f0c31400e5f

any where
  (process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*azure linux:3.0*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*photon os:5.0*")
