// Dragnet [Container]: dragnet-container-2026-2033 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 182db2ec-40d6-5b85-8ec1-669f4ffebf1d

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*")
