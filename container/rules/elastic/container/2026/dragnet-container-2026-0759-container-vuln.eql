// Dragnet [Container]: dragnet-container-2026-0759 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 4904d609-0107-53f7-b83c-a028d5dd9461

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*chainguard:*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*")
