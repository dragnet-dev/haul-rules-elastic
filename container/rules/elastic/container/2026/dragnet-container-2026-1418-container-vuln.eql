// Dragnet [Container]: dragnet-container-2026-1418 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 155363ef-da4d-5512-bb83-0c5e6b7a71d7

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:12.10*")
