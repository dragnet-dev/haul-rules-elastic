// Dragnet [Container]: dragnet-container-2026-2118 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 84e5b24f-b42e-5a57-aa5c-0499f234dc51

any where
  (process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*azure linux:3.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*wolfi:*")
