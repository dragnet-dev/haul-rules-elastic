// Dragnet [Container]: dragnet-container-2026-0176 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8811972f-455b-5a29-b1ca-d79b768e71a8

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*cbl-mariner:1.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*photon os:2.0*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
