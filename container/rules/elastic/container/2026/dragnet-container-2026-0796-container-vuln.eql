// Dragnet [Container]: dragnet-container-2026-0796 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: bbe13498-664b-5cc0-a894-a58cb9139780

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*" or process.executable like~ "*ubuntu:13.10*")
