// Dragnet [Container]: dragnet-container-2026-3019 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a742b195-75eb-5d5a-9afc-a77ca42e8f24

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
