// Dragnet [Container]: dragnet-container-2026-0740 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: fd9fa5f0-f9e8-5720-bcac-8a1859cbedb1

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*chainguard:*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*" or process.executable like~ "*ubuntu:13.10*")
