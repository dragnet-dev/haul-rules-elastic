// Dragnet [Container]: dragnet-container-2026-0033 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: b2402ad9-6d98-568b-bec0-3ea41ba58d27

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
