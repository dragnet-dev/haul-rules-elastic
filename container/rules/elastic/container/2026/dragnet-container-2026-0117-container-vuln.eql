// Dragnet [Container]: dragnet-container-2026-0117 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: dfbaa724-7763-593f-b4ba-101cecd54367

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*" or process.executable like~ "*ubuntu:13.10*")
