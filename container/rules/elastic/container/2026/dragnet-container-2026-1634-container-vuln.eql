// Dragnet [Container]: dragnet-container-2026-1634 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a6332e39-20a3-5601-b469-9cda1e652fb1

any where
  (process.executable like~ "*alpine edge:*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
