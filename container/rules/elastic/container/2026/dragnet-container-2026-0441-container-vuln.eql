// Dragnet [Container]: dragnet-container-2026-0441 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a502f5ae-8df4-5f34-93bb-376322dbca3d

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*")
