// Dragnet [Container]: dragnet-container-2026-2878 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: ea0e4134-47b4-5c10-8f32-c66818761396

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.10*")
