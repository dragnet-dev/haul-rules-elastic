// Dragnet [Container]: dragnet-container-2026-1631 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 95f8355c-80fb-5c11-93ae-7a5ec4e24c04

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*" or process.executable like~ "*ubuntu:15.04*")
