// Dragnet [Container]: dragnet-container-2026-0246 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 91350f95-7cda-5dad-a79f-54eba72d25bb

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.10*")
