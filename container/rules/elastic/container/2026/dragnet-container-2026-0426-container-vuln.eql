// Dragnet [Container]: dragnet-container-2026-0426 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 23c3c1ab-3148-5273-8718-a833cf449170

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*")
