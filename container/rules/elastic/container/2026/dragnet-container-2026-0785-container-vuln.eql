// Dragnet [Container]: dragnet-container-2026-0785 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 40974336-50de-5657-aff9-2c8019a143b3

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*")
