// Dragnet [Container]: dragnet-container-2026-2849 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6e7a28c5-5699-5c36-a0ba-a1205d119531

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:17.04*")
