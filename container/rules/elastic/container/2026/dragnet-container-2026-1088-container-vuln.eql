// Dragnet [Container]: dragnet-container-2026-1088 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 779b7540-043e-5767-888f-ec2ff7f9c504

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.04-ESM*" or process.executable like~ "*ubuntu:13.10*")
