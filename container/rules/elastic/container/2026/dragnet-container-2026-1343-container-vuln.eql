// Dragnet [Container]: dragnet-container-2026-1343 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5b28b671-2bbd-5566-ba6a-6e18f56c258a

any where
  (process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:24.10*" or process.executable like~ "*wolfi:*")
