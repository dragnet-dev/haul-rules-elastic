// Dragnet [Container]: dragnet-container-2026-0756 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c9f8c186-6c79-5602-90a3-0631b5f9c836

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*")
