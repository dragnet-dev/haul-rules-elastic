// Dragnet [Container]: dragnet-container-2026-2892 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 26b9f225-171c-5627-80fd-970e6b18b4bf

any where
  (process.executable like~ "*almalinux:10*" or process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*chainguard:*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*wolfi:*")
