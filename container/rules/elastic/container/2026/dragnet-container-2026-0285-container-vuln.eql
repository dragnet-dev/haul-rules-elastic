// Dragnet [Container]: dragnet-container-2026-0285 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 9bdf59ec-37f1-5b64-86e5-af85c18c494a

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*")
