// Dragnet [Container]: dragnet-container-2026-2804 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: c7bd5209-2dde-507c-9bc8-7d573fd48da5

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:6*")
