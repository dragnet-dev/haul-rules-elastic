// Dragnet [Container]: dragnet-container-2026-1586 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: dd401757-1728-56ba-b683-c4bd8eaa3cf5

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*")
