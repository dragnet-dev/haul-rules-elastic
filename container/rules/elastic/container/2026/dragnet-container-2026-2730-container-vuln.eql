// Dragnet [Container]: dragnet-container-2026-2730 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b8784be2-21c6-5f1c-8096-95b1873a84b4

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*" or process.executable like~ "*ubuntu:13.10*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*" or process.executable like~ "*ubuntu:15.04*" or process.executable like~ "*ubuntu:15.10*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.10*")
