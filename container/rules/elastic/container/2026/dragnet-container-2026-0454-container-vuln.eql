// Dragnet [Container]: dragnet-container-2026-0454 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2e139dd9-96ab-5a2c-93c3-feae35235ee4

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*")
