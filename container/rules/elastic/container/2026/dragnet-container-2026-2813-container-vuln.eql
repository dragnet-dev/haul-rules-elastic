// Dragnet [Container]: dragnet-container-2026-2813 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 353a5108-98b8-5da4-bd8f-950b0434b7c6

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.04*" or process.executable like~ "*ubuntu:15.10*")
