// Dragnet [Container]: dragnet-container-2026-3192 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c894bf7c-3b5b-5512-9490-264b545d30b8

any where
  (process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
