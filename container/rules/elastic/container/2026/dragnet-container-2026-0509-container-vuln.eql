// Dragnet [Container]: dragnet-container-2026-0509 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 97a53979-3ac9-5232-8db2-2e42c54707e6

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*redhat/ubi9:*")
