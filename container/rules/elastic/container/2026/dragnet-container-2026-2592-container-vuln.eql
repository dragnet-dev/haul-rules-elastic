// Dragnet [Container]: dragnet-container-2026-2592 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 58e035b7-cf70-55bc-afd1-a209b0033721

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
