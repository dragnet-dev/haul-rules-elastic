// Dragnet [Container]: dragnet-container-2026-2392 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: fdaa3023-421f-556a-b345-9e10322bf442

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*")
