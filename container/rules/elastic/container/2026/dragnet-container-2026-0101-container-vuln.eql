// Dragnet [Container]: dragnet-container-2026-0101 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b0a775be-c89c-5eea-a2ab-da2a513cb23c

any where
  (process.executable like~ "*alpine:3.3*" or process.executable like~ "*alpine:3.4*" or process.executable like~ "*alpine:3.5*" or process.executable like~ "*alpine:3.6*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*photon os:2.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
