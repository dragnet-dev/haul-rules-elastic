// Dragnet [Container]: dragnet-container-2026-1276 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dc8bef0a-e899-5e76-886b-4e0bc7ba6c65

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*")
