// Dragnet [Container]: dragnet-container-2026-1114 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f519fc70-6911-5370-9a11-f2ea910c8b33

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*")
