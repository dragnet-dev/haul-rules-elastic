// Dragnet [Container]: dragnet-container-2026-3124 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9178bb7d-d2f3-5c4d-a281-5f705981a59a

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*")
