// Dragnet [Container]: dragnet-container-2026-2604 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e7a49e1d-5b00-57f2-b2b9-8150e0173439

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.10*")
