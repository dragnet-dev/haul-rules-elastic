// Dragnet [Container]: dragnet-container-2026-1875 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5e6f2652-3a15-5bd2-be5c-84ef10875b0d

any where
  (process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*wolfi:*")
