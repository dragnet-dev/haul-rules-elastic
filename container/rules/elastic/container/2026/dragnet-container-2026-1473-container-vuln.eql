// Dragnet [Container]: dragnet-container-2026-1473 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c9dac4d8-47c2-5b0c-b412-2b27a1b5d43e

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*wolfi:*")
