// Dragnet [Container]: dragnet-container-2026-2762 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ec9bb11b-8f97-57b7-91b0-08fb59e4a3b7

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:9*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:17.04*")
