// Dragnet [Container]: dragnet-container-2026-0136 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cbbc1c15-2a55-5bc5-89ed-5690e5ff02aa

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*")
