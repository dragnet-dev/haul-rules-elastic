// Dragnet [Container]: dragnet-container-2026-0587 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7afe39d3-5c01-521e-b8b3-7703241f4e39

any where
  (process.executable like~ "*azure linux:3.0*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*wolfi:*")
