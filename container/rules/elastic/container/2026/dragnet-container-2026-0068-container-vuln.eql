// Dragnet [Container]: dragnet-container-2026-0068 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 41f43e0e-5f56-5e94-8738-fa0dc21c820b

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:18.04-ESM*")
