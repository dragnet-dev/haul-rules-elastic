// Dragnet [Container]: dragnet-container-2026-2132 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: ae664b78-fe5f-595e-94a9-aeac4be1d077

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:13.10*" or process.executable like~ "*ubuntu:14.04*")
