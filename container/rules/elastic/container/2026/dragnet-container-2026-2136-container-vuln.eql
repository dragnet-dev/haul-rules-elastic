// Dragnet [Container]: dragnet-container-2026-2136 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e03ee753-7dcf-5358-966e-55bbd45a1e6c

any where
  (process.executable like~ "*alpine:3.5*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.10*")
