// Dragnet [Container]: dragnet-container-2026-1958 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 49846e71-9a79-51ac-b7b7-8e5a4563f4c6

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:24.10*")
