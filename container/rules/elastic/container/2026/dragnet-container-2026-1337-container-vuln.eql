// Dragnet [Container]: dragnet-container-2026-1337 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 59dc1335-c173-575c-bd85-3469b66e8e35

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*" or process.executable like~ "*ubuntu:15.04*" or process.executable like~ "*ubuntu:15.10*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*" or process.executable like~ "*ubuntu:17.04*" or process.executable like~ "*ubuntu:17.10*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.10*")
