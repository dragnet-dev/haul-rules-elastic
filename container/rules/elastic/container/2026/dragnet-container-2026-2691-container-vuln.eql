// Dragnet [Container]: dragnet-container-2026-2691 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9461e292-5b0f-550d-aec3-ef2c87759916

any where
  (process.executable like~ "*azure linux:3.0*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*photon os:5.0*" or process.executable like~ "*redhat/ubi9:*")
