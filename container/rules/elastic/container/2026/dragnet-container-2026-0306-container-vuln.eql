// Dragnet [Container]: dragnet-container-2026-0306 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2457f5a9-17d6-5f63-acce-dc46f7ecabd8

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*")
