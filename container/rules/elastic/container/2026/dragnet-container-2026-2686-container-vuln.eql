// Dragnet [Container]: dragnet-container-2026-2686 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0d5a6732-2938-5235-8b38-c31200aea0dd

any where
  (process.executable like~ "*alpine:3.2*" or process.executable like~ "*alpine:3.3*" or process.executable like~ "*alpine:3.4*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*")
