// Dragnet [Container]: dragnet-container-2026-1402 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6390d0e1-74e9-528d-8899-b2f86273af54

any where
  (process.executable like~ "*almalinux:10*" or process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*")
