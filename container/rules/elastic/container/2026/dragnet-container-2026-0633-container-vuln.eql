// Dragnet [Container]: dragnet-container-2026-0633 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ad8d09b3-8070-5410-8355-adf0412efa43

any where
  (process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*photon os:5.0*" or process.executable like~ "*redhat/ubi9:*")
