// Dragnet [Container]: dragnet-container-2026-1050 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 062da5d5-c6fa-55b9-887d-412ae1e195d5

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*")
