// Dragnet [Container]: dragnet-container-2026-0716 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 531760be-61b2-5ac2-bec8-3c3b633af048

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*" or process.executable like~ "*ubuntu:13.10*")
