// Dragnet [Container]: dragnet-container-2026-3170 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8256ff23-490b-575b-9ae3-3449ea2153bb

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*")
