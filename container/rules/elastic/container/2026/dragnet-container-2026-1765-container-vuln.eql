// Dragnet [Container]: dragnet-container-2026-1765 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: df09d898-842c-58b7-91d6-aecceccafbc5

any where
  (process.executable like~ "*alpine:3.2*" or process.executable like~ "*alpine:3.3*" or process.executable like~ "*alpine:3.4*" or process.executable like~ "*alpine:3.5*" or process.executable like~ "*ubuntu:16.04-ESM*")
