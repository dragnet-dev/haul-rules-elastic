// Dragnet [Container]: dragnet-container-2026-1741 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 9fcb1724-8fdc-574b-b22e-bf1fd24e147e

any where
  (process.executable like~ "*chainguard:*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*")
