// Dragnet [Container]: dragnet-container-2026-2320 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6d9bad2f-e8b3-53fd-aa6e-172008443e7a

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*redhat/ubi9:*")
