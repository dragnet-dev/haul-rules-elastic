// Dragnet [Container]: dragnet-container-2026-0040 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c7021ef0-c069-5cd2-b88e-9dc091f9dcbd

any where
  (process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*")
