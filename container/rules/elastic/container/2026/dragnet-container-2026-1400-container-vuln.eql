// Dragnet [Container]: dragnet-container-2026-1400 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cd16d2f9-902a-5efa-8988-9dd85f87108d

any where
  (process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*")
