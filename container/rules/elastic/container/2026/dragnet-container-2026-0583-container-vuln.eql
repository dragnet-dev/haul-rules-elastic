// Dragnet [Container]: dragnet-container-2026-0583 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: df40c96d-f26d-563d-a336-279511245f12

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.10*")
