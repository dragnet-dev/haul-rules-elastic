// Dragnet [Container]: dragnet-container-2026-0015 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: e7dc99e9-9b34-5be3-a3da-467c1fc6dabb

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
