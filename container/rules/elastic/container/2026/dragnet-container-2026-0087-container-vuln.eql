// Dragnet [Container]: dragnet-container-2026-0087 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 39a9f12e-6563-5474-bbc5-64af20e60cbc

any where
  (process.executable like~ "*almalinux:10*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*oraclelinux:9*")
