// Dragnet [Container]: dragnet-container-2026-3079 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: c31869fe-2dea-5b15-b665-8d7a15cc281f

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*" or process.executable like~ "*ubuntu:13.10*")
