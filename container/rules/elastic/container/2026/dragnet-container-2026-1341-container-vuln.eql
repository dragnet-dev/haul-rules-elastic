// Dragnet [Container]: dragnet-container-2026-1341 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e2393700-396f-52d1-9b0e-dc1f3d6a90aa

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:17.04*" or process.executable like~ "*ubuntu:17.10*")
