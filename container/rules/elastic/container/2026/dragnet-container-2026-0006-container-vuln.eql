// Dragnet [Container]: dragnet-container-2026-0006 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 41d94f82-b210-5104-8341-50f54adc0ff7

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
