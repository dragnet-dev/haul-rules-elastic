// Dragnet [Container]: dragnet-container-2026-2834 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: dcf2b2eb-3ac4-5f93-8281-eae6086b6cea

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*")
