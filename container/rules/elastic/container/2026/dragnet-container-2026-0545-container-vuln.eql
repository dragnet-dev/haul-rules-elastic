// Dragnet [Container]: dragnet-container-2026-0545 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 80ee5042-d400-5429-8ed2-5a858dcb4df6

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.10*" or process.executable like~ "*ubuntu:15.04*")
