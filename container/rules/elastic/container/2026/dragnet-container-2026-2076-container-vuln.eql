// Dragnet [Container]: dragnet-container-2026-2076 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e1df67d2-09bf-58f4-a2af-1fdc44a50079

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
