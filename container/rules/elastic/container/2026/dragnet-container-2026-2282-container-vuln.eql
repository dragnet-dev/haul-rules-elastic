// Dragnet [Container]: dragnet-container-2026-2282 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 442bbe51-dffe-540d-938c-ea8c322ac6f8

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*")
