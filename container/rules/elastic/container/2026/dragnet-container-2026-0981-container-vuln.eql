// Dragnet [Container]: dragnet-container-2026-0981 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 9c147b04-b168-5c14-a549-7381ba793300

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine:3.24*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
