// Dragnet [Container]: dragnet-container-2026-2451 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bd0ea9ba-85f7-5147-82c2-ae82274cdef9

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*photon os:5.0*")
