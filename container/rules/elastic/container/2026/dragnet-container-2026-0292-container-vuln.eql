// Dragnet [Container]: dragnet-container-2026-0292 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 23ef6e03-1ffb-5466-9167-95510c96bccb

any where
  (process.executable like~ "*alpine:3.3*" or process.executable like~ "*alpine:3.4*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
