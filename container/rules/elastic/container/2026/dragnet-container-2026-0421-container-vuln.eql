// Dragnet [Container]: dragnet-container-2026-0421 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: c156478c-b2b6-559a-acbc-fd505e328b78

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
