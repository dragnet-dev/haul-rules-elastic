// Dragnet [Container]: dragnet-container-2026-3189 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 30262b87-d4aa-5395-ac8e-8c2290fd50b8

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
