// Dragnet [Container]: dragnet-container-2026-1063 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 29e13fa4-ea07-52af-b7ff-e02d27db3025

any where
  (process.executable like~ "*almalinux:10*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*")
