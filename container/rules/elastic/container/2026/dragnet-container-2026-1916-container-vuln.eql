// Dragnet [Container]: dragnet-container-2026-1916 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 52546254-adb1-5e81-b891-16fb6366df19

any where
  (process.executable like~ "*alpine:3.2*" or process.executable like~ "*alpine:3.3*" or process.executable like~ "*alpine:3.4*" or process.executable like~ "*alpine:3.5*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:16.04-ESM*")
