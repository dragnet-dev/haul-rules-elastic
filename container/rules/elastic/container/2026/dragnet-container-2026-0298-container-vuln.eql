// Dragnet [Container]: dragnet-container-2026-0298 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8bdfefbd-ba19-52d3-878f-d0f47ce1a1f3

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*")
