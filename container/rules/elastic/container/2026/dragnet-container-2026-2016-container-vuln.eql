// Dragnet [Container]: dragnet-container-2026-2016 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 571b643d-c934-5248-879f-825086ece5ea

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*chainguard:*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*")
