// Dragnet [Container]: dragnet-container-2026-2796 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fbdf9ae3-0927-56ca-9fba-56eef4611e15

any where
  (process.executable like~ "*alpine:3.3*" or process.executable like~ "*alpine:3.4*" or process.executable like~ "*alpine:3.5*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*")
