// Dragnet [Container]: dragnet-container-2026-0074 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 71d55367-b0ff-5607-8f15-a1f118a1b886

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*")
