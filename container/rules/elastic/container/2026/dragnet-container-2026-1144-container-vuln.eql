// Dragnet [Container]: dragnet-container-2026-1144 — Vulnerable Base Image Pull
// Status: deprecated | Level: medium | ID: 5a9a0057-4674-5c1e-a17f-817ee10b0861

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:24.10*" or process.executable like~ "*ubuntu:25.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
