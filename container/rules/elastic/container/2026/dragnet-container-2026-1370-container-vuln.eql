// Dragnet [Container]: dragnet-container-2026-1370 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 97d4c5d2-5d1a-5560-8cd2-30a606554eb0

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine:3.24*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*wolfi:*")
