// Dragnet [Container]: dragnet-container-2026-1034 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f3bbe9ca-3afa-5225-abc7-54a2d5fc9f9b

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.04*")
