// Dragnet [Container]: dragnet-container-2026-1998 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8eb7ae69-29a0-5d15-979d-0c1d2b2ae9a4

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:14.10*")
