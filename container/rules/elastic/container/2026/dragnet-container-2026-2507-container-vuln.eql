// Dragnet [Container]: dragnet-container-2026-2507 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5db97f71-598b-552c-b10e-f84e35831ab5

any where
  (process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*" or process.executable like~ "*ubuntu:17.04*")
