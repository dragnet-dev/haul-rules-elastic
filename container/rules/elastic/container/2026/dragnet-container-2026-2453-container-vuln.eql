// Dragnet [Container]: dragnet-container-2026-2453 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1b86b026-7801-5114-ae0e-786db95c6020

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.10*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
