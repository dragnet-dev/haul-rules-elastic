// Dragnet [Container]: dragnet-container-2026-1845 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c95623cf-7f61-545e-a219-cfdacc170070

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*")
