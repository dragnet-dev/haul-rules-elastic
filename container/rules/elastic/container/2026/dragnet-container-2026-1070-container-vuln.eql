// Dragnet [Container]: dragnet-container-2026-1070 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 78b5507d-2b03-5115-8557-2fca15ac4186

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*")
