// Dragnet [Container]: dragnet-container-2026-2104 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 15bcd9c1-03b6-5483-a833-ae4603b064c3

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*redhat/ubi9:*")
