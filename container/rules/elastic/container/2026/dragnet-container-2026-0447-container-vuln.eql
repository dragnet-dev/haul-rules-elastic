// Dragnet [Container]: dragnet-container-2026-0447 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 9c8043cb-482f-56c3-9705-e25ab7d3de58

any where
  (process.executable like~ "*oraclelinux:6*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*")
