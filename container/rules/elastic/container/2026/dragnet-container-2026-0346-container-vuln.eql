// Dragnet [Container]: dragnet-container-2026-0346 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ceb6f352-b2a9-5483-8704-c020881234ca

any where
  (process.executable like~ "*alpine:3.5*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.10*")
