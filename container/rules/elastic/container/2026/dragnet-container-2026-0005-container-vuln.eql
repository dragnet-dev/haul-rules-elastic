// Dragnet [Container]: dragnet-container-2026-0005 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 541461fb-e86d-5b53-a048-afddcb5caa28

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*")
