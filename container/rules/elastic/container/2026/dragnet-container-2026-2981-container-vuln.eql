// Dragnet [Container]: dragnet-container-2026-2981 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 6995094e-ce94-5b6f-885b-56b0d6aa819c

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*redhat/ubi9:*")
