// Dragnet [Container]: dragnet-container-2026-0078 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bc632bfa-60fd-54a4-b70f-9032a2365c0d

any where
  (process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
