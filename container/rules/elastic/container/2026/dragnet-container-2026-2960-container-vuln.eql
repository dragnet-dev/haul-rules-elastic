// Dragnet [Container]: dragnet-container-2026-2960 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 451a55fb-873a-5925-823c-b7c6056c1093

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*")
