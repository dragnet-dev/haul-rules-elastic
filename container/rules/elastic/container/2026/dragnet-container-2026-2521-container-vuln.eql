// Dragnet [Container]: dragnet-container-2026-2521 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: c6273e30-17d6-5abc-9fbe-8c7f31aa1f06

any where
  (process.executable like~ "*chainguard:*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*")
