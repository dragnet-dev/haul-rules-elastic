// Dragnet [Container]: dragnet-container-2026-1265 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 518f031c-f05f-54fc-b076-6ff18f925b95

any where
  (process.executable like~ "*almalinux:10*" or process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
