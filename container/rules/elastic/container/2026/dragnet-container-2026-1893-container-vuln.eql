// Dragnet [Container]: dragnet-container-2026-1893 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cb064bd3-dfb5-5935-b8aa-6697fe6b7d75

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.10*")
