// Dragnet [Container]: dragnet-container-2026-2150 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e632aaa5-55c6-5cd7-8c42-c879ab1ad4b6

any where
  (process.executable like~ "*alpine:3.2*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*")
