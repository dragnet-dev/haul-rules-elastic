// Dragnet [Container]: dragnet-container-2026-0155 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d54be3a0-f095-5105-84dd-4c7a2cbe98df

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.10*" or process.executable like~ "*ubuntu:14.04*")
