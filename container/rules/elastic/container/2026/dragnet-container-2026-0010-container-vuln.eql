// Dragnet [Container]: dragnet-container-2026-0010 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2a5d9364-f221-5e3a-b52a-b710e79307e2

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*" or process.executable like~ "*ubuntu:17.04*")
