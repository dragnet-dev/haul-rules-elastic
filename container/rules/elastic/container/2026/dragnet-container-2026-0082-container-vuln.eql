// Dragnet [Container]: dragnet-container-2026-0082 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: aedb4a12-4f08-5a66-abe0-cbfbc56936ac

any where
  (process.executable like~ "*alpine:3.3*" or process.executable like~ "*alpine:3.4*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*")
