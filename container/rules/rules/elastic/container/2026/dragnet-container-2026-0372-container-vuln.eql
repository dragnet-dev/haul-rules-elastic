// Dragnet [Container]: dragnet-container-2026-0372 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 22e0ee32-1499-562b-880a-4ddd9daffc0e

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
