// Dragnet [Container]: dragnet-container-2026-0864 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: eeb9db5c-21af-530b-a6e0-7c7175330f72

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:16.04-ESM*")
