// Dragnet [Container]: dragnet-container-2026-1358 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 80b94f4c-2738-5ece-9f49-10fd15e6b9aa

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04-ESM*")
