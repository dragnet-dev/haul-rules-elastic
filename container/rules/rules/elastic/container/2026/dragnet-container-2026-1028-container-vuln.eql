// Dragnet [Container]: dragnet-container-2026-1028 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 69b105cf-4eaf-538b-a1e7-0fd3c4788034

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*")
