// Dragnet [Container]: dragnet-container-2026-0724 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fccbb184-bf56-58b7-b100-c8c44a54eae6

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:9*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*redhat/ubi9:*")
