// Dragnet [Container]: dragnet-container-2026-0383 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ac84b685-75ec-5706-bccc-6b12fbd5abc5

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*" or process.executable like~ "*ubuntu:15.10*")
