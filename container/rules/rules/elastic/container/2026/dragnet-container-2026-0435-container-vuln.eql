// Dragnet [Container]: dragnet-container-2026-0435 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 71ff7b0a-dbaa-58cc-8343-64b4fa4f623b

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*")
