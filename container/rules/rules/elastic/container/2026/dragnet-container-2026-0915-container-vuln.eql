// Dragnet [Container]: dragnet-container-2026-0915 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f2c930e0-bffc-548d-8a85-3fc5a9fb5c12

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:14.10*" or process.executable like~ "*ubuntu:15.04*")
