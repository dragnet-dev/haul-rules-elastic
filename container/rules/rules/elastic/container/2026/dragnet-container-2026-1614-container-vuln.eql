// Dragnet [Container]: dragnet-container-2026-1614 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: c016b61d-62fa-5071-8d41-03f7ae1f32b5

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:24.10*" or process.executable like~ "*ubuntu:25.04*")
