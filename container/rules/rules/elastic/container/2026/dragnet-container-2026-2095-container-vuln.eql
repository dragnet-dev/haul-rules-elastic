// Dragnet [Container]: dragnet-container-2026-2095 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 235bbb26-bfb4-5028-aede-52fbccab6665

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
