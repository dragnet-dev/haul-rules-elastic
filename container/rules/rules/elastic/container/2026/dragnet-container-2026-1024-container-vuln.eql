// Dragnet [Container]: dragnet-container-2026-1024 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b6ba0dc3-5db6-55b5-ba60-ba642e222067

any where
  (process.executable like~ "*alpine:3.3*" or process.executable like~ "*alpine:3.4*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
