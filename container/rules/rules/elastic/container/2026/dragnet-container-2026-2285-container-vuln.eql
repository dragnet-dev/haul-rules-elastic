// Dragnet [Container]: dragnet-container-2026-2285 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6d29f206-ab12-5a8b-a859-657228a37ffb

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*")
