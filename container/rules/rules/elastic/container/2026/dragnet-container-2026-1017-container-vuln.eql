// Dragnet [Container]: dragnet-container-2026-1017 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b739edd1-b8e9-5171-90e8-38a8ff58c575

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*")
