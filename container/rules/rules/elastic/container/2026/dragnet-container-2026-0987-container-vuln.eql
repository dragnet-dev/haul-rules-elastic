// Dragnet [Container]: dragnet-container-2026-0987 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e0856f97-5500-572f-9a19-8e17277e74f4

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*")
