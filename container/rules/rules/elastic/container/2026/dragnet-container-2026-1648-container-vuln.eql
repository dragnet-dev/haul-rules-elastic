// Dragnet [Container]: dragnet-container-2026-1648 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8ff88e61-da42-5637-adda-15adbd5ad8b5

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*")
