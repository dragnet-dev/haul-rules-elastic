// Dragnet [Container]: dragnet-container-2026-1859 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 013bdce8-73f2-52ca-9bce-83c06256aab8

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
