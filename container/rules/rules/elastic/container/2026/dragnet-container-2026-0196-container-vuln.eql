// Dragnet [Container]: dragnet-container-2026-0196 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4e6a5a9b-97bc-5726-88b7-b3763d74ff1b

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.10*")
