// Dragnet [Container]: dragnet-container-2026-1965 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1876e909-01c5-540c-955a-db05d9db9069

any where
  (process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
