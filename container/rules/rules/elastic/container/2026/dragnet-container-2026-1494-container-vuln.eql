// Dragnet [Container]: dragnet-container-2026-1494 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d644e8d4-7733-57cd-9dd7-ffe966791a84

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
