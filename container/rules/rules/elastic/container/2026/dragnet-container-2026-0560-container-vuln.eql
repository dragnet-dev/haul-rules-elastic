// Dragnet [Container]: dragnet-container-2026-0560 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dfe627da-2bf8-5648-a5ae-5eaa4aeaa05c

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*")
