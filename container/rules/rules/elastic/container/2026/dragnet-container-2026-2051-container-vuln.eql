// Dragnet [Container]: dragnet-container-2026-2051 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7c3bc68b-44e6-5c48-9c5a-327f0029ffc6

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:17.04*")
