// Dragnet [Container]: dragnet-container-2026-0816 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 24b031e1-fa94-5b5d-a1c4-49d43dcbaca4

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
