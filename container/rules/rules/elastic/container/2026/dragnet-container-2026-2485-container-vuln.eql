// Dragnet [Container]: dragnet-container-2026-2485 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e1e895ca-52e2-5cf2-8b38-925e270c26a8

any where
  (process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
