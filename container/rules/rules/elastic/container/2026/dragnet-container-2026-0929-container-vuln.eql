// Dragnet [Container]: dragnet-container-2026-0929 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bbae86e2-852a-5954-83ae-27bfcff7a01b

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
