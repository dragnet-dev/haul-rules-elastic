// Dragnet [Container]: dragnet-container-2026-1368 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8941df6b-c44a-52e7-884d-50a80b6b2011

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*")
