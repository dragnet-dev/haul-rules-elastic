// Dragnet [Container]: dragnet-container-2026-0780 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 99624851-39d7-5e7a-a60f-94f692a3caa8

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:5.0*")
