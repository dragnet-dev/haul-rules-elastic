// Dragnet [Container]: dragnet-container-2026-1360 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8f62fa2e-7ede-5480-ad89-a06e8ccb9a3a

any where
  (process.executable like~ "*almalinux:10*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*azure linux:3.0*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*photon os:5.0*")
