// Dragnet [Container]: dragnet-container-2026-2903 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 13b73e4a-763b-592a-b98e-2ada47b45267

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*")
