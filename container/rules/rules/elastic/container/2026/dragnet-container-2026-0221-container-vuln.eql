// Dragnet [Container]: dragnet-container-2026-0221 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 123b83d7-6390-5c17-a197-aa48503241a4

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*")
