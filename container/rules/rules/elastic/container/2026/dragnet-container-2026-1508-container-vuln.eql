// Dragnet [Container]: dragnet-container-2026-1508 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a51497a9-c69b-5f22-a862-67fbc3c1c623

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*" or process.executable like~ "*ubuntu:15.10*" or process.executable like~ "*ubuntu:17.04*")
