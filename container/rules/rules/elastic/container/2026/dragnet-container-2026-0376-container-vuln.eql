// Dragnet [Container]: dragnet-container-2026-0376 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2aaa497f-a7db-567d-a574-44d96028fa2f

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.10*")
