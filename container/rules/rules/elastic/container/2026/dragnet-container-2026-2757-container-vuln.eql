// Dragnet [Container]: dragnet-container-2026-2757 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1fc17975-103d-5a43-b012-e0487b7c06d3

any where
  (process.executable like~ "*alpine:3.2*" or process.executable like~ "*alpine:3.3*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.10*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
