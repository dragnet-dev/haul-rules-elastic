// Dragnet [Container]: dragnet-container-2026-1544 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9a452be3-dd27-52f1-ba0b-85c84e56dada

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
