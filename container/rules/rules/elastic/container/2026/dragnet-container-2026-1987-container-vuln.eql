// Dragnet [Container]: dragnet-container-2026-1987 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 16dede21-5050-5268-a0f7-c88ad6193b5b

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.04*" or process.executable like~ "*ubuntu:15.10*")
