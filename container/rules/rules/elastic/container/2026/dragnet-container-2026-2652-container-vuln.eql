// Dragnet [Container]: dragnet-container-2026-2652 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 111e3e1b-8b3e-5c1a-9593-95125d86afce

any where
  (process.executable like~ "*almalinux:10*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*wolfi:*")
