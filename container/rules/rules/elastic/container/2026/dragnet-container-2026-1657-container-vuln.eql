// Dragnet [Container]: dragnet-container-2026-1657 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 51083f34-9049-502e-ab2d-98f51ab82495

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
