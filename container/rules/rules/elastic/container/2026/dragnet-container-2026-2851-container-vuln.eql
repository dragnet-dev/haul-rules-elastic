// Dragnet [Container]: dragnet-container-2026-2851 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 42eab05d-2e13-5688-8f87-fed366fab01f

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*")
