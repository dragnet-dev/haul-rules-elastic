// Dragnet [Container]: dragnet-container-2026-2262 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5d82717f-6d47-57d3-aabd-06115aa45283

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*" or process.executable like~ "*ubuntu:13.10*")
