// Dragnet [Container]: dragnet-container-2026-0605 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 207fefb2-90b8-563d-b660-e17ea65cce60

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
