// Dragnet [Container]: dragnet-container-2026-1708 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2b61f291-945a-54ba-9a9f-f6cd6821bd4d

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
