// Dragnet [Container]: dragnet-container-2026-0776 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4ffa2b5e-3491-562d-8de8-5eeee10cb263

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
