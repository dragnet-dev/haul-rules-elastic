// Dragnet [Container]: dragnet-container-2026-2972 — Vulnerable Base Image Pull
// Status: deprecated | Level: low | ID: 4b356de3-1234-536b-8e06-1d26a2a7e331

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*wolfi:*")
