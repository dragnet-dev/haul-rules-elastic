// Dragnet [Container]: dragnet-container-2026-2147 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 33d55fb3-987d-59bd-8ee0-fe165ca9dc10

any where
  (process.executable like~ "*alpine:3.2*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:8*")
