// Dragnet [Container]: dragnet-container-2026-3041 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1709f1fa-f99d-5267-a4b6-dd10312e8c61

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*")
