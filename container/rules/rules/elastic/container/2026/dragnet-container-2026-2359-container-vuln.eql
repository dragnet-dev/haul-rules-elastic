// Dragnet [Container]: dragnet-container-2026-2359 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 73085f67-4c1f-513c-b4c7-19171096ebbe

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:25.10*")
