// Dragnet [Container]: dragnet-container-2026-3055 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b3f710d7-507a-5ee0-85e4-5759f7d0df67

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:17.04*")
