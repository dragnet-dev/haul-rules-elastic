// Dragnet [Container]: dragnet-container-2026-2214 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 054dab27-4b85-566a-a6ff-adc2542f9547

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
