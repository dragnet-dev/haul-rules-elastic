// Dragnet [Container]: dragnet-container-2026-0495 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4f69e55a-8392-5c6c-9242-8532026b17fe

any where
  (process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
