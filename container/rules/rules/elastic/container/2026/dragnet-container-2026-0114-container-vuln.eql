// Dragnet [Container]: dragnet-container-2026-0114 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e3320248-0490-52cf-9bcd-c019ebd153ad

any where
  (process.executable like~ "*chainguard:*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*wolfi:*")
