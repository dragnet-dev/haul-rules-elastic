// Dragnet [Container]: dragnet-container-2026-1879 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0862962c-8354-583b-80a1-147ddada41c5

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*" or process.executable like~ "*ubuntu:13.10*")
