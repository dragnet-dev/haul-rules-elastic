// Dragnet [Container]: dragnet-container-2026-3166 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c8f7aa3e-421b-5eef-9aed-14f8e23ad8a8

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:14.10*" or process.executable like~ "*ubuntu:15.04*")
