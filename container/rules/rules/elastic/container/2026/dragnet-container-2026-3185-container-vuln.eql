// Dragnet [Container]: dragnet-container-2026-3185 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 40cc919e-70c3-520c-8bca-00afbb7fa4d4

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.10*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
