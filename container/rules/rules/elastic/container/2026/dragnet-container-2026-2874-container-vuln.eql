// Dragnet [Container]: dragnet-container-2026-2874 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7eb61565-4b1a-5f9f-87c8-ad65b06aaba8

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*")
