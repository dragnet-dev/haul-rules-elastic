// Dragnet [Container]: dragnet-container-2026-1398 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 359f485a-9f36-52fb-a392-18babba6d330

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*ubuntu:17.04*")
