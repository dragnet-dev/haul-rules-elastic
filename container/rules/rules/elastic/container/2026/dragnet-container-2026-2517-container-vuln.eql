// Dragnet [Container]: dragnet-container-2026-2517 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1c568040-c780-52a9-adc5-269f67777aac

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*")
