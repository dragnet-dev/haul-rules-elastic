// Dragnet [Container]: dragnet-container-2026-0579 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c934ebf9-93e9-56f3-97c1-815603e1bb03

any where
  (process.executable like~ "*alpine:3.4*" or process.executable like~ "*alpine:3.5*" or process.executable like~ "*alpine:3.7*" or process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:15.10*")
