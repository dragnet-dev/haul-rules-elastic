// Dragnet [Container]: dragnet-container-2026-1158 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 573095de-b49e-5401-93a8-5eb8bc4eb63e

any where
  (process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*ubuntu:18.04-ESM*")
