// Dragnet [Container]: dragnet-container-2026-0241 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b2214c2c-8355-5bca-b50e-0fef79898164

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
