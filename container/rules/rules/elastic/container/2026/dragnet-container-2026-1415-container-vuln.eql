// Dragnet [Container]: dragnet-container-2026-1415 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5d2bceff-0ef9-527e-8b49-19b4e53c1288

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*")
