// Dragnet [Container]: dragnet-container-2026-1559 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8d028fa3-e143-5d30-9f32-bc33b587e1ce

any where
  (process.executable like~ "*alpine:3.4*" or process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.10*")
