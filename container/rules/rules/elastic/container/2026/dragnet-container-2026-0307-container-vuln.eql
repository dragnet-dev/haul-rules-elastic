// Dragnet [Container]: dragnet-container-2026-0307 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ac627baa-b480-5939-a35f-393dba417922

any where
  (process.executable like~ "*azure linux:3.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
