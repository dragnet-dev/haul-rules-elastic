// Dragnet [Container]: dragnet-container-2026-0336 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c822f940-eff9-5b2b-83da-5bd79c84cf0e

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*" or process.executable like~ "*ubuntu:15.10*")
