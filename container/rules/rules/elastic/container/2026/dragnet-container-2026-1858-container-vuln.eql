// Dragnet [Container]: dragnet-container-2026-1858 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c3cbe26f-de41-5abb-bbb4-0893f3bf1b01

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
