// Dragnet [Container]: dragnet-container-2026-3118 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dfac7d75-5a4b-53ef-8cea-5b1c0e7749ed

any where
  (process.executable like~ "*almalinux:10*" or process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*wolfi:*")
