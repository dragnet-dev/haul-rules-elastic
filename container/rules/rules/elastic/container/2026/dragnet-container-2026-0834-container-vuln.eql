// Dragnet [Container]: dragnet-container-2026-0834 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cd7c908e-5d67-590a-817e-0afe48e121ab

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*")
