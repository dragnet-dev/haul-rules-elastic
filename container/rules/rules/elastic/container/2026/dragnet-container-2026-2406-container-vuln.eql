// Dragnet [Container]: dragnet-container-2026-2406 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e1b8b9c1-6d21-5f5c-9fd1-8d2cef3ce362

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*")
