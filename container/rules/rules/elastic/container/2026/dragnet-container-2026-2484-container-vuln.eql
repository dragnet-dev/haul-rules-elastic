// Dragnet [Container]: dragnet-container-2026-2484 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 154a68dd-29b3-527b-9cb9-75ae1ff726c2

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*")
