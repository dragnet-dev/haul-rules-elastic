// Dragnet [Container]: dragnet-container-2026-2255 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 72b5485f-12bc-59e3-971c-fb3fc7a7761c

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
