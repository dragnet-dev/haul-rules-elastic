// Dragnet [Container]: dragnet-container-2026-0069 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2b04b8c3-96c1-5172-ab40-af80c16a04e0

any where
  (process.executable like~ "*almalinux:9*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
