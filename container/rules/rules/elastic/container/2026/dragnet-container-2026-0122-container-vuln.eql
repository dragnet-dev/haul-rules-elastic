// Dragnet [Container]: dragnet-container-2026-0122 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d2a2132c-f4ce-5ecd-bb39-8a261f191064

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:17.10*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
