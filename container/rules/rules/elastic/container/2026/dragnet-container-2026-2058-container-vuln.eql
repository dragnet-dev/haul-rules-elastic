// Dragnet [Container]: dragnet-container-2026-2058 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: afa9518a-2b5b-5bf2-9dbd-e44de9900756

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.10*" or process.executable like~ "*ubuntu:16.04-ESM*")
