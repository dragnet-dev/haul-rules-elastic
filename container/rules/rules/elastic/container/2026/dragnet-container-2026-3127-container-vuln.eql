// Dragnet [Container]: dragnet-container-2026-3127 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 78656258-d979-5f3c-ba2a-7d7921841691

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*")
