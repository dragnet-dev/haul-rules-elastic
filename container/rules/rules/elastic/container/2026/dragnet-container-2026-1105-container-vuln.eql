// Dragnet [Container]: dragnet-container-2026-1105 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 846e112f-93ca-5492-8232-063aa3935d9a

any where
  (process.executable like~ "*alpine:3.2*" or process.executable like~ "*alpine:3.3*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*")
