// Dragnet [Container]: dragnet-container-2026-1641 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: eb88130c-ff5c-5fd2-a2f8-5669d2887131

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:17.04*")
