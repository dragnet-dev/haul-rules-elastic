// Dragnet [Container]: dragnet-container-2026-2846 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2892fa66-621c-59ab-b767-d4f5538d93bf

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*" or process.executable like~ "*ubuntu:15.10*")
