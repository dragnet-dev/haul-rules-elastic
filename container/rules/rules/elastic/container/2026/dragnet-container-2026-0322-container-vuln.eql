// Dragnet [Container]: dragnet-container-2026-0322 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5915a75d-3125-5964-a05a-dc1c0d60c64c

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*")
