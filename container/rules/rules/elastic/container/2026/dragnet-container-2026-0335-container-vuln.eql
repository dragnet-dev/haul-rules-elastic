// Dragnet [Container]: dragnet-container-2026-0335 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 247374cf-4de6-5231-8ae8-98bb28ad3b11

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*")
