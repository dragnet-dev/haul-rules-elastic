// Dragnet [Container]: dragnet-container-2026-0463 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 46258522-b5bc-5e10-a9e2-f8632793222f

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
