// Dragnet [Container]: dragnet-container-2026-2340 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1e3a4e7e-23e3-5265-9b8e-fb8922bd0b8f

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
