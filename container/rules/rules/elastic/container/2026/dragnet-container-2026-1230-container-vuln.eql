// Dragnet [Container]: dragnet-container-2026-1230 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 00700ce3-5c17-569d-a481-5f5969be661e

any where
  (process.executable like~ "*alpine:3.4*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*")
