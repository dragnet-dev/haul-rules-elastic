// Dragnet [Container]: dragnet-container-2026-0226 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 69f7b9b4-e53a-5e84-8a42-af79232dc959

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
