// Dragnet [Container]: dragnet-container-2026-1149 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 23dddffb-b5ef-5cd1-8c6d-d456bf127385

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*")
