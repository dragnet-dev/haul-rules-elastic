// Dragnet [Container]: dragnet-container-2026-2021 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 173354c1-5139-5c74-823e-808009b9a04c

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
