// Dragnet [Container]: dragnet-container-2026-0092 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d1901d18-df54-5616-92c6-82ced94b3682

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*" or process.executable like~ "*ubuntu:17.04*")
