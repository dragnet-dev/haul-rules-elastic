// Dragnet [Container]: dragnet-container-2026-1451 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e7fbaaed-1b12-5760-873e-4bfafa6b8d88

any where
  (process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*")
