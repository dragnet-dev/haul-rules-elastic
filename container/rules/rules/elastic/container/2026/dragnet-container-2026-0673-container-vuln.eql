// Dragnet [Container]: dragnet-container-2026-0673 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: eadf97a3-74fd-51f4-98bf-873ecd268c1d

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*")
