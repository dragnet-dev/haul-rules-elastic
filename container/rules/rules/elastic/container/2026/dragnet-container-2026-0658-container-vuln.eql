// Dragnet [Container]: dragnet-container-2026-0658 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 021d4306-adeb-59f3-9855-d04e31e61c92

any where
  (process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*")
