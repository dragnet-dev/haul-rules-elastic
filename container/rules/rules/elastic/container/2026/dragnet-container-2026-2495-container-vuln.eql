// Dragnet [Container]: dragnet-container-2026-2495 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 358e2263-06d8-5e8a-b7c6-792d0701a258

any where
  (process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
