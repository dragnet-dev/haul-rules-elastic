// Dragnet [Container]: dragnet-container-2026-0619 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dc727d8e-4eea-5335-b2c5-8ba5c4f898ff

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*")
