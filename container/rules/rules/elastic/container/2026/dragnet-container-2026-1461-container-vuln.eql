// Dragnet [Container]: dragnet-container-2026-1461 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d1d5d51f-164f-577b-962c-b79e6525450b

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
