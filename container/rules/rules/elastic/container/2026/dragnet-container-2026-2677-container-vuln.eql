// Dragnet [Container]: dragnet-container-2026-2677 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 179aa8a0-3f2f-513a-ba69-07429cc47056

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*")
