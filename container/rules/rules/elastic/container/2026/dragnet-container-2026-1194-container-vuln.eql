// Dragnet [Container]: dragnet-container-2026-1194 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 226d5558-00df-55f2-8fa5-5c445ee62c11

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
