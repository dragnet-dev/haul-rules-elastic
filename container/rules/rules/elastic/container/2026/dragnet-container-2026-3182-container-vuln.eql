// Dragnet [Container]: dragnet-container-2026-3182 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 57685a42-9207-5257-810e-3c25bcdab65e

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
