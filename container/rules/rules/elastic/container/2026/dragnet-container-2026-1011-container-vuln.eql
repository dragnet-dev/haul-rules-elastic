// Dragnet [Container]: dragnet-container-2026-1011 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: af4ace09-5831-5a8f-8b01-d13240814e2f

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*redhat/ubi9:*")
