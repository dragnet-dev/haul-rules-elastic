// Dragnet [Container]: dragnet-container-2026-0653 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: db4291fc-5755-54c0-9412-4012c495a1e2

any where
  (process.executable like~ "*alpine edge:*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:5.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*wolfi:*")
