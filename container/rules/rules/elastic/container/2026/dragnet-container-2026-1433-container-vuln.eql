// Dragnet [Container]: dragnet-container-2026-1433 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9361d3c3-6353-508e-951f-718d19fe3fe1

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.10*")
