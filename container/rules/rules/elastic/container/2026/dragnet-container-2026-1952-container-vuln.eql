// Dragnet [Container]: dragnet-container-2026-1952 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4d1e706a-64a2-51e3-84fa-05212f5671d4

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*")
