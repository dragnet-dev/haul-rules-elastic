// Dragnet [Container]: dragnet-container-2026-3103 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dfcff761-d283-5aeb-8c1a-d81f43f0da0f

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*" or process.executable like~ "*ubuntu:15.10*")
