// Dragnet [Container]: dragnet-container-2026-1130 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a43a7735-7662-526d-b91f-a0799c58cc8c

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*")
