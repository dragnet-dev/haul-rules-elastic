// Dragnet [Container]: dragnet-container-2026-2922 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 40ce5f10-c998-5696-8278-a18eb3e9bdca

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
