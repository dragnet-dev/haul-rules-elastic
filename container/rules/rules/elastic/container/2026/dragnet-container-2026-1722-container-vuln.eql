// Dragnet [Container]: dragnet-container-2026-1722 — Vulnerable Base Image Pull
// Status: deprecated | Level: medium | ID: 988dc855-c05e-5fbc-b26b-4d12ce9e41ce

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*ubuntu:14.04-ESM*")
