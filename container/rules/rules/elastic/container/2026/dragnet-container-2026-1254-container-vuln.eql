// Dragnet [Container]: dragnet-container-2026-1254 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 573d7d9f-2428-552e-adea-3328ce162619

any where
  (process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*wolfi:*")
