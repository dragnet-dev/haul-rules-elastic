// Dragnet [Container]: dragnet-container-2026-0345 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ffc57e0d-ef33-5834-8147-c2238e7dc5d7

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*")
