// Dragnet [Container]: dragnet-container-2026-1316 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d4b5bcda-ea3f-5df1-b9fb-c4f0457bdba2

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*")
