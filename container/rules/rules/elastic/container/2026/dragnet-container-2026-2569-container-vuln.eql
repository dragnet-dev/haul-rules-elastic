// Dragnet [Container]: dragnet-container-2026-2569 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a817a8be-e070-516c-bd54-185964b64fd8

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04-ESM*")
