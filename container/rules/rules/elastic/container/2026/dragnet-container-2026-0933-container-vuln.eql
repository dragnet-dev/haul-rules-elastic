// Dragnet [Container]: dragnet-container-2026-0933 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ce305f6c-3d63-5d9b-9b61-0676ddaf899c

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
