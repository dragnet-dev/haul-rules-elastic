// Dragnet [Container]: dragnet-container-2026-2640 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 148f1644-ce06-5284-b865-e886e200ab33

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*wolfi:*")
