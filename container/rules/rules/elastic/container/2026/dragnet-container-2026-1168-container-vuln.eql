// Dragnet [Container]: dragnet-container-2026-1168 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 86560bee-31e5-5fe2-b133-f27afde70a6b

any where
  (process.executable like~ "*almalinux:10*" or process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*")
