// Dragnet [Container]: dragnet-container-2026-2476 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8ceb4064-2f46-5223-8300-89a33dbd3e21

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
