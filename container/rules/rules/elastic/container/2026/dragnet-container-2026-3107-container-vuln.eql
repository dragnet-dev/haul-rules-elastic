// Dragnet [Container]: dragnet-container-2026-3107 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 49f5dd5e-a591-5bf0-ba28-57c1e4afa3c1

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*wolfi:*")
