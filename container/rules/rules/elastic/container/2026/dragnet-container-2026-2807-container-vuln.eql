// Dragnet [Container]: dragnet-container-2026-2807 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0f694df1-a360-5e05-ab89-b7de866ec615

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.10*")
