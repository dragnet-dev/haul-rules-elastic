// Dragnet [Container]: dragnet-container-2026-0085 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 89ea8d17-07ec-5911-bda0-6cf0bfe163ef

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*wolfi:*")
