// Dragnet [Container]: dragnet-container-2026-2864 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 459ab193-0f53-5150-9bb6-948172a9d135

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.10*" or process.executable like~ "*ubuntu:14.04*")
