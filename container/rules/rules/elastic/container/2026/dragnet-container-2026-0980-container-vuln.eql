// Dragnet [Container]: dragnet-container-2026-0980 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a518beae-5a76-5910-ac88-f6be0aeda9aa

any where
  (process.executable like~ "*azure linux:3.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:24.10*" or process.executable like~ "*ubuntu:25.04*")
