// Dragnet [Container]: dragnet-container-2026-0842 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4a302435-ae40-5ebc-ae3e-9a500cb6140b

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*")
