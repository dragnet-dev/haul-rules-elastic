// Dragnet [Container]: dragnet-container-2026-0866 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 67cfa7c7-73cd-5c8e-ab23-ab0ed02088c5

any where
  (process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.10*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
