// Dragnet [Container]: dragnet-container-2026-2233 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0657e589-05b9-5169-b148-0f0257bfc30e

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*")
