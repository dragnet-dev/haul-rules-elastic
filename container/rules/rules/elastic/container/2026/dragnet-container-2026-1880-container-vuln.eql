// Dragnet [Container]: dragnet-container-2026-1880 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 73c6d26d-e998-5517-b364-f2d546fab569

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*")
