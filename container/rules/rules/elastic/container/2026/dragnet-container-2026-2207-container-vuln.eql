// Dragnet [Container]: dragnet-container-2026-2207 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4c866c8c-c708-5127-8183-298cff1890ff

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:15.04*")
