// Dragnet [Container]: dragnet-container-2026-2481 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dce06583-bab9-5875-bcda-f0d1d1f11574

any where
  (process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*photon os:5.0*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.04*" or process.executable like~ "*ubuntu:25.10*")
