// Dragnet [Container]: dragnet-container-2026-0137 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 92cfa20e-52d9-5617-ad7f-9bc8b7c7c6d6

any where
  (process.executable like~ "*alpine edge:*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*wolfi:*")
