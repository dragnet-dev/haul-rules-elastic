// Dragnet [Container]: dragnet-container-2026-2570 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b2c84d00-51e7-5494-9129-6e15a3f54cc6

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*")
