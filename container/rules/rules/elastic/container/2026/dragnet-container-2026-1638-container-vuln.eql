// Dragnet [Container]: dragnet-container-2026-1638 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 05baec31-daec-5839-bd88-e3f75a3ea3d6

any where
  (process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
