// Dragnet [Container]: dragnet-container-2026-2661 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 233d0ba9-aa2d-5904-831d-149a13290f8f

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*")
