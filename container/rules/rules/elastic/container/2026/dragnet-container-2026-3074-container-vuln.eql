// Dragnet [Container]: dragnet-container-2026-3074 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f76ad624-d2e9-5164-bd0a-c36c38ed7f3a

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.10*")
