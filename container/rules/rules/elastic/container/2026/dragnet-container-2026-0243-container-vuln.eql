// Dragnet [Container]: dragnet-container-2026-0243 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a84c5a3e-2083-577e-93ce-0e55cfe44d4c

any where
  (process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:21.10*")
