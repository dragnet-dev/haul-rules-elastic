// Dragnet [Container]: dragnet-container-2026-2081 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8ee938c3-43a6-5d90-aa50-8c7090008566

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
