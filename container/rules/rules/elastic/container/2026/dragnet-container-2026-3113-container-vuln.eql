  (process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*cbl-mariner:1.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*chainguard:*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*photon os:5.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:23.04*" or process.executable like~ "*wolfi:*")
