// Dragnet [Container]: dragnet-container-2026-2827 — Vulnerable Base Image Pull
// Status: deprecated | Level: medium | ID: 73a0214f-44b5-5ff3-8284-7982086d1758

any where
  (process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
