// Dragnet [Container]: dragnet-container-2026-3153 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1cdc45ab-248c-5eb5-a3bc-0bb875c8b622

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*ubuntu:12.04*")
