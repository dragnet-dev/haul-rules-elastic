// Dragnet [Container]: dragnet-container-2026-0760 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5841bb58-acfb-56e0-a371-09356798472e

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:13.10*" or process.executable like~ "*ubuntu:14.04*")
