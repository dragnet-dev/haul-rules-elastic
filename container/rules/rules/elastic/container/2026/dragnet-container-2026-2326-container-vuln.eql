// Dragnet [Container]: dragnet-container-2026-2326 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 78acf0bd-dffb-56bf-883e-4ac5fb653842

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.10*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
