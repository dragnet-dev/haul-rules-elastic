// Dragnet [Container]: dragnet-container-2026-1020 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3e5e1257-b947-51b7-9876-70d1f62fb224

any where
  (process.executable like~ "*almalinux:10*" or process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:22.04*")
