// Dragnet [Container]: dragnet-container-2026-3141 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 55a6776a-e843-548d-9ba8-6cab718b26c6

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:15.10*")
