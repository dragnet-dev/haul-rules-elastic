// Dragnet [Container]: dragnet-container-2026-0461 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ec3d5e10-2bc4-5fcf-b2c5-cd015b379cb1

any where
  (process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:12.10*" or process.executable like~ "*ubuntu:13.04*")
