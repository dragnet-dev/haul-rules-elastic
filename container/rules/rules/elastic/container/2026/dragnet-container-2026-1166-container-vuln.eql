// Dragnet [Container]: dragnet-container-2026-1166 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4f76353d-8d2c-57a3-aaae-9681269c8491

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:17.04*" or process.executable like~ "*ubuntu:17.10*")
