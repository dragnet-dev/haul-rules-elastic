// Dragnet [Container]: dragnet-container-2026-3031 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0fc72a2a-4f12-540a-a426-4f0fb10b0c5c

any where
  (process.executable like~ "*alpine:3.2*" or process.executable like~ "*alpine:3.3*" or process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*")
