// Dragnet [Container]: dragnet-container-2024-0349 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b633aa3c-48f2-52ba-851e-9fb6e3cee25f

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*")
