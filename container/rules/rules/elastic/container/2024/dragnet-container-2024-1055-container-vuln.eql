// Dragnet [Container]: dragnet-container-2024-1055 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 959c99df-bcdc-5961-a8c2-f387ffbceda7

any where
  (process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.10*" or process.executable like~ "*ubuntu:19.04*" or process.executable like~ "*ubuntu:19.10*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.10*" or process.executable like~ "*ubuntu:21.04*" or process.executable like~ "*ubuntu:21.10*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:22.10*" or process.executable like~ "*ubuntu:23.04*" or process.executable like~ "*ubuntu:23.10*" or process.executable like~ "*ubuntu:24.04*")
