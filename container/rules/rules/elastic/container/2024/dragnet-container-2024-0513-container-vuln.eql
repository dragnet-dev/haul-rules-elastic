// Dragnet [Container]: dragnet-container-2024-0513 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: eecee60f-a44a-53f3-b669-d641ea09bfa8

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
