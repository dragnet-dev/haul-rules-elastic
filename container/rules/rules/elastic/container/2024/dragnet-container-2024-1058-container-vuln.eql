// Dragnet [Container]: dragnet-container-2024-1058 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c598cca1-5cca-513f-8517-0fcc395ac5c8

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*photon os:2.0*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
