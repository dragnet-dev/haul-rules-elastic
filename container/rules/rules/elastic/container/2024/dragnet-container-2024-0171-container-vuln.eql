// Dragnet [Container]: dragnet-container-2024-0171 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 36dcf67d-033a-5fc1-b6a2-386245cc9500

any where
  (process.executable like~ "*amazonlinux:2022*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
