// Dragnet [Container]: dragnet-container-2024-1218 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 7917c1dd-da91-59ec-b7d9-36221101835c

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
