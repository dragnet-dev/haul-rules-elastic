// Dragnet [Container]: dragnet-container-2024-1494 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f3c158c4-535a-5ea6-9f79-9d113c877fd1

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:7*")
