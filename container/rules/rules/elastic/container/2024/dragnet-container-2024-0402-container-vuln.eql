// Dragnet [Container]: dragnet-container-2024-0402 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e66a8c62-5db4-52f4-9905-dd7c862a63b3

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
