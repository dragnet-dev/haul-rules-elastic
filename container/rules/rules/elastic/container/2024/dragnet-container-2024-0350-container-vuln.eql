// Dragnet [Container]: dragnet-container-2024-0350 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 27c1057f-ec2c-513f-bb7a-019f8456cace

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:18.04-ESM*")
