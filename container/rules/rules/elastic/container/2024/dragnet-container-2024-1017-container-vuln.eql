// Dragnet [Container]: dragnet-container-2024-1017 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7b289919-97bf-5104-96d7-cae786a475fb

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:20.10*" or process.executable like~ "*ubuntu:22.04*")
