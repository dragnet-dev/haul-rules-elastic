// Dragnet [Container]: dragnet-container-2024-0933 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7b4acc38-1679-5e6f-bff4-0f130f232ac3

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*photon os:2.0*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*redhat/ubi9:*")
