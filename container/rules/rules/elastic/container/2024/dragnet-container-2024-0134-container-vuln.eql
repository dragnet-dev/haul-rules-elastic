// Dragnet [Container]: dragnet-container-2024-0134 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e7fa7218-0ed5-5374-b7fb-6618ed011316

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*amazonlinux:1*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
