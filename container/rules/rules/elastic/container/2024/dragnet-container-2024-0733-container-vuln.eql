// Dragnet [Container]: dragnet-container-2024-0733 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2017651d-ded3-5614-8f0c-040991af8bb4

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*")
