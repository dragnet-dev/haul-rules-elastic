// Dragnet [Container]: dragnet-container-2024-0371 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6992cb1a-54ae-5688-aed9-8db6b5057aa1

any where
  (process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
