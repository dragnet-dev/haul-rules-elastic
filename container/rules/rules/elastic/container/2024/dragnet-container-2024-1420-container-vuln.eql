// Dragnet [Container]: dragnet-container-2024-1420 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a7004148-3273-5560-bcbf-d98c48ebaa9f

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*alpine:3.11*" or process.executable like~ "*alpine:3.12*" or process.executable like~ "*alpine:3.13*" or process.executable like~ "*alpine:3.14*" or process.executable like~ "*alpine:3.15*" or process.executable like~ "*alpine:3.16*" or process.executable like~ "*alpine:3.17*" or process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*cbl-mariner:1.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*photon os:4.0*")
