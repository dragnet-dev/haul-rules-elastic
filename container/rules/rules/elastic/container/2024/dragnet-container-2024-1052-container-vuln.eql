// Dragnet [Container]: dragnet-container-2024-1052 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b565b9dd-59b7-5551-9cbd-a5edf5846620

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*")
