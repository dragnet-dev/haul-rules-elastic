// Dragnet [Container]: dragnet-container-2024-1428 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ee074e47-80b8-5c59-82b4-bea2ac4a3512

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
