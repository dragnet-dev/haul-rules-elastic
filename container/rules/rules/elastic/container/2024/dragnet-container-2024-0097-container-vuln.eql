// Dragnet [Container]: dragnet-container-2024-0097 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8257564b-164d-5fd4-b3f1-0380fe6419c6

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
