// Dragnet [Container]: dragnet-container-2024-1539 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7af89aa5-d5d1-52ef-b69e-722c2185fd29

any where
  (process.executable like~ "*alpine:3.10*" or process.executable like~ "*alpine:3.11*" or process.executable like~ "*alpine:3.12*" or process.executable like~ "*alpine:3.13*" or process.executable like~ "*alpine:3.14*" or process.executable like~ "*alpine:3.15*" or process.executable like~ "*alpine:3.16*" or process.executable like~ "*alpine:3.17*" or process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*")
