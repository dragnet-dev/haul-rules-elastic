// Dragnet [Container]: dragnet-container-2024-1129 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 964df582-bd26-5af9-8510-aea1b1940317

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*azure linux:3.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*wolfi:*")
