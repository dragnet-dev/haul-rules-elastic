// Dragnet [Container]: dragnet-container-2024-1535 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2165956f-dd8a-518f-9475-13ab2efe8f17

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
