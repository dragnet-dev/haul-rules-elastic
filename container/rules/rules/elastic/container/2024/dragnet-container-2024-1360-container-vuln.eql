// Dragnet [Container]: dragnet-container-2024-1360 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 70a82ef0-b99e-51f0-810d-444c8b7f73bd

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:23.04*" or process.executable like~ "*ubuntu:23.10*" or process.executable like~ "*ubuntu:24.04*")
