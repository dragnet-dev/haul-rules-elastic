// Dragnet [Container]: dragnet-container-2024-1003 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d32a6846-2ada-5430-8f03-f893ef94bbf6

any where
  (process.executable like~ "*alpine:3.17*" or process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*")
