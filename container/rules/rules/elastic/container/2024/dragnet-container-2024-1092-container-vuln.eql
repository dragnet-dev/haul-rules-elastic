// Dragnet [Container]: dragnet-container-2024-1092 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6bde9dac-eaf3-5439-a512-53c755e3c5c3

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*")
