// Dragnet [Container]: dragnet-container-2024-0445 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: be4a5164-0904-58d8-8132-c9e6b265a0ff

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:2.0*" or process.executable like~ "*ubuntu:17.10*")
