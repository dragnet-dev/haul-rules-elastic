// Dragnet [Container]: dragnet-container-2024-0255 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 02d66dc4-9d01-51c2-b528-a5db163f4146

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*ubuntu:20.04-ESM*")
