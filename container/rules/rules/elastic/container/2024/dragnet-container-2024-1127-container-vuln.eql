// Dragnet [Container]: dragnet-container-2024-1127 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 624c6e7f-14f7-57f9-a299-a5488ee3450f

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
