// Dragnet [Container]: dragnet-container-2024-1253 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ccf97696-5054-53ba-b351-fbeb432762bb

any where
  (process.executable like~ "*chainguard:*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:18.04-ESM*")
