// Dragnet [Container]: dragnet-container-2024-1242 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cdc540a5-d1b3-551e-8a6a-16a7c1d0b6a2

any where
  (process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:16.10*" or process.executable like~ "*ubuntu:17.04*")
