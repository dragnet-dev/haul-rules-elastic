// Dragnet [Container]: dragnet-container-2024-1551 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 26565ddf-8ad7-5d1f-a204-0855363422c2

any where
  (process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:23.04*" or process.executable like~ "*ubuntu:23.10*")
