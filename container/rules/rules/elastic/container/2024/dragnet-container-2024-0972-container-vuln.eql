// Dragnet [Container]: dragnet-container-2024-0972 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f1b1fd8a-ab58-55dd-85b1-25ad026c83bb

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*")
