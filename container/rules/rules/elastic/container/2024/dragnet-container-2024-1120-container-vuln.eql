// Dragnet [Container]: dragnet-container-2024-1120 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6b7ecd5b-5bdd-539b-ac3c-d637d75c1b08

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
