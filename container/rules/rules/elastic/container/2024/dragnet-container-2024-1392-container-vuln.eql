// Dragnet [Container]: dragnet-container-2024-1392 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: eca95996-6ac9-59fb-a45d-56c6814deb67

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*")
