// Dragnet [Container]: dragnet-container-2024-1257 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 989e750e-9886-5cad-97a7-ef70952520bd

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*")
