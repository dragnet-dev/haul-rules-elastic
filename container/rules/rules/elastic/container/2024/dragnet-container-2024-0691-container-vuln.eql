// Dragnet [Container]: dragnet-container-2024-0691 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2dec5180-ecf5-5fbb-aa98-cd3daad59f99

any where
  (process.executable like~ "*chainguard:*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*")
