// Dragnet [Container]: dragnet-container-2024-1486 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5938da76-d7fa-5ea4-81c6-7d6aa2f18598

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:14.10*")
