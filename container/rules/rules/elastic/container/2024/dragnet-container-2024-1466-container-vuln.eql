// Dragnet [Container]: dragnet-container-2024-1466 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6d066394-cb8f-5976-bbe1-5b5e41a4f14c

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
