// Dragnet [Container]: dragnet-container-2024-0080 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c9b085ca-4a5c-5360-b3a6-912d3dfe2723

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*wolfi:*")
