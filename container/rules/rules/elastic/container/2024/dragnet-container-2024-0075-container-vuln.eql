// Dragnet [Container]: dragnet-container-2024-0075 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 061564a5-4d25-5706-88b7-a56f25e89809

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*")
