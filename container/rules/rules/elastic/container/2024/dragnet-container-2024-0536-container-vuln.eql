// Dragnet [Container]: dragnet-container-2024-0536 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 43128207-616d-5fa5-82d4-2cd631507ee0

any where
  (process.executable like~ "*alpine:3.4*" or process.executable like~ "*alpine:3.5*" or process.executable like~ "*alpine:3.6*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
