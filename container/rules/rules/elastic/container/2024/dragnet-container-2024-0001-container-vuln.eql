// Dragnet [Container]: dragnet-container-2024-0001 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3de99873-2618-58ba-b8ec-fd750db8b713

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:19.04*" or process.executable like~ "*ubuntu:19.10*")
