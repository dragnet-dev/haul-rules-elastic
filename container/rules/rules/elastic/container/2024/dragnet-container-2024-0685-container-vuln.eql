// Dragnet [Container]: dragnet-container-2024-0685 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6250e35c-434d-50a7-9b61-770cec1650ea

any where
  (process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.10*")
