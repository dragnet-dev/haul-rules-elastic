// Dragnet [Container]: dragnet-container-2024-1148 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1c12ae57-f172-5f47-874c-ff59279337bf

any where
  (process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
