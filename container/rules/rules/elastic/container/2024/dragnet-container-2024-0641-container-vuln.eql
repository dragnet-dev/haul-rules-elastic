// Dragnet [Container]: dragnet-container-2024-0641 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f52d16b9-a698-5e0d-9f51-3000eb22cae3

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:18.04-ESM*")
