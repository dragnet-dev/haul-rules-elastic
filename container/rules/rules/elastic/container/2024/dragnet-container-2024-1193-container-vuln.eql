// Dragnet [Container]: dragnet-container-2024-1193 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 27c26663-612b-5209-939f-aa51e2ebebac

any where
  (process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:17.10*" or process.executable like~ "*ubuntu:18.04*")
