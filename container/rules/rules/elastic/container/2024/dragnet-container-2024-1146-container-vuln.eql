// Dragnet [Container]: dragnet-container-2024-1146 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c15f041e-e53a-5788-9aa3-1c7307989df0

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
