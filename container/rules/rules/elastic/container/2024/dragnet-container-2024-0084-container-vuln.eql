// Dragnet [Container]: dragnet-container-2024-0084 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 32e4efdf-88e0-5578-8667-15a20f75ee53

any where
  (process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
