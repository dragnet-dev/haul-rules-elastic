// Dragnet [Container]: dragnet-container-2024-1511 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bd5f89a8-91a1-5fe9-ae47-2949b958dc43

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:19.04*" or process.executable like~ "*ubuntu:19.10*")
