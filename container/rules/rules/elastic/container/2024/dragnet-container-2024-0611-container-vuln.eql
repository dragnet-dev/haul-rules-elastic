// Dragnet [Container]: dragnet-container-2024-0611 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f8d5056e-d54b-56bd-9f0a-898881a55545

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
