// Dragnet [Container]: dragnet-container-2024-0686 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 25e24210-66ec-56ec-a863-d51e224d46b4

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*ubuntu:18.04-ESM*")
