// Dragnet [Container]: dragnet-container-2024-0696 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: fbd6a1ad-0a4b-5895-b3fc-2a2e372f3f9c

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:14.10*")
