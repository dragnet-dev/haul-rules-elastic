// Dragnet [Container]: dragnet-container-2024-0769 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 82a43682-3804-5eab-b394-03242f51ca41

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
