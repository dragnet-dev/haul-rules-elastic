// Dragnet [Container]: dragnet-container-2024-0079 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: c1512af2-b032-5840-9e55-b4a599ae9c96

any where
  (process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
