// Dragnet [Container]: dragnet-container-2024-0250 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1dc2c33b-c52a-589e-88d3-ec4679505418

any where
  (process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
