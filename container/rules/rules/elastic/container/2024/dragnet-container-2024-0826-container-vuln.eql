// Dragnet [Container]: dragnet-container-2024-0826 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 243c060d-de0f-5e92-b5f8-be8c976f7697

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
