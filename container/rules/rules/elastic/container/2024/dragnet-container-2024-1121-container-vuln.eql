// Dragnet [Container]: dragnet-container-2024-1121 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f955db2b-9aa2-5296-9019-01c3c0fb3174

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
