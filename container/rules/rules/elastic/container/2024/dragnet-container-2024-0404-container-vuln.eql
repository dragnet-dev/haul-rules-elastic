// Dragnet [Container]: dragnet-container-2024-0404 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 69c0a454-3092-563f-879a-399a1e6f027f

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:18.04-ESM*")
