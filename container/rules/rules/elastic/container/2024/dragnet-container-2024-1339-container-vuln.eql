// Dragnet [Container]: dragnet-container-2024-1339 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 85ca5ad9-b301-5445-b61c-900d31fec663

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:18.04-ESM*")
