// Dragnet [Container]: dragnet-container-2024-0635 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5674c65c-a9b0-5681-b9aa-e06cedf92a4a

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
