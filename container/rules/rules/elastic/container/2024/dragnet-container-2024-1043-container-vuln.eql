// Dragnet [Container]: dragnet-container-2024-1043 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 875fea07-ce25-52e3-9443-5b28c38c26b6

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*redhat/ubi9:*")
