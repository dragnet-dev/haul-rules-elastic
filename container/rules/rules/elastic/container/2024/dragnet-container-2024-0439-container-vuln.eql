// Dragnet [Container]: dragnet-container-2024-0439 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2f163425-c986-55bc-8525-70194797cbc0

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*")
