// Dragnet [Container]: dragnet-container-2024-1419 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d8ad0b75-2dec-5ed4-a49f-3f8ada941e6f

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
