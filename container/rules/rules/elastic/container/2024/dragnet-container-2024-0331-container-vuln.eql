// Dragnet [Container]: dragnet-container-2024-0331 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 71da2d15-34f1-5f0c-b5a8-3752e403616c

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*almalinux:9*" or process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*photon os:5.0*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:23.04*" or process.executable like~ "*ubuntu:23.10*")
