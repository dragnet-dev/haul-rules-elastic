// Dragnet [Container]: dragnet-container-2024-1008 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cc1145ed-be25-536d-a37c-33a98fb3b120

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
