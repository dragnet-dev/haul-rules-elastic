// Dragnet [Container]: dragnet-container-2024-1246 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 01fa6797-fbbf-5318-9d40-e7e0e4387676

any where
  (process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*")
