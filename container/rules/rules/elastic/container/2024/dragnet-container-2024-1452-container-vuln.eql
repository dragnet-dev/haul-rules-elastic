// Dragnet [Container]: dragnet-container-2024-1452 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0a77f04e-112a-5102-af9c-ca171edd5c06

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:18.10*")
