// Dragnet [Container]: dragnet-container-2024-0542 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9e344e12-694d-5583-8c6b-77b710c17915

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*")
