// Dragnet [Container]: dragnet-container-2024-0229 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 1e30c28e-ab49-5409-bd71-f56714d61766

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:18.10*" or process.executable like~ "*ubuntu:19.04*")
