// Dragnet [Container]: dragnet-container-2024-0694 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d5c5d2ab-a116-5fda-ab3d-2cee59cff3e1

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*")
