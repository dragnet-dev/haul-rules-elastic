// Dragnet [Container]: dragnet-container-2024-0126 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b4ffc93c-c70d-5576-a56e-f32cf5fbbb5f

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*")
