// Dragnet [Container]: dragnet-container-2024-0613 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 49d94efe-8ff2-54b6-8aa8-dfcb85959311

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
