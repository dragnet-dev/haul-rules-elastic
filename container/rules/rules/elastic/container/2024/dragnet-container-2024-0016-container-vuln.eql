// Dragnet [Container]: dragnet-container-2024-0016 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6827978a-1c70-5169-aad1-317effd3ab50

any where
  (process.executable like~ "*cbl-mariner:1.0*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
