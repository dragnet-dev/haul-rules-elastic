// Dragnet [Container]: dragnet-container-2024-0178 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3b885fc7-203f-5b6b-8c6d-486cca56bf38

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:17.10*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
