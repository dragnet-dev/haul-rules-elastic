// Dragnet [Container]: dragnet-container-2024-1571 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8e1fc6a8-1105-518b-b1d6-2692ca8c80eb

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*")
