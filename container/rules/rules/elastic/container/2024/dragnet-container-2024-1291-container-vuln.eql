// Dragnet [Container]: dragnet-container-2024-1291 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ee242fd7-5100-5cba-85fe-4b297c2cd41f

any where
  (process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*")
