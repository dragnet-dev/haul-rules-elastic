// Dragnet [Container]: dragnet-container-2024-1315 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 47173d55-7bcf-57c3-bbfd-cbde9d22e032

any where
  (process.executable like~ "*almalinux:9*" or process.executable like~ "*amazonlinux:1*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2022*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
