// Dragnet [Container]: dragnet-container-2024-0648 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0e8d2a53-24e1-5837-a3d0-a865baf54a3c

any where
  (process.executable like~ "*almalinux:9*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*azure linux:3.0*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:23.04*")
