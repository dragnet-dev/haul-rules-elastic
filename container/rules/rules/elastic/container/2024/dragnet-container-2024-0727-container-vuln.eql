// Dragnet [Container]: dragnet-container-2024-0727 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 636ba344-8b4a-53bd-92b1-e8fb8962acb6

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:18.10*" or process.executable like~ "*ubuntu:19.04*")
