// Dragnet [Container]: dragnet-container-2024-0437 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 316563e6-9047-5ecd-9e8d-c8e701c100b0

any where
  (process.executable like~ "*alpine:3.10*" or process.executable like~ "*alpine:3.11*" or process.executable like~ "*alpine:3.12*" or process.executable like~ "*alpine:3.13*" or process.executable like~ "*alpine:3.14*" or process.executable like~ "*alpine:3.15*" or process.executable like~ "*alpine:3.16*" or process.executable like~ "*alpine:3.7*" or process.executable like~ "*alpine:3.8*" or process.executable like~ "*alpine:3.9*" or process.executable like~ "*chainguard:*" or process.executable like~ "*redhat/ubi9:*")
