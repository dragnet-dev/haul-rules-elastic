// Dragnet [Container]: dragnet-container-2024-0931 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7164d691-9aa6-599a-aa08-3f401849e287

any where
  (process.executable like~ "*alpine:3.3*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
