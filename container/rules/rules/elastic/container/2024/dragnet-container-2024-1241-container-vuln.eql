// Dragnet [Container]: dragnet-container-2024-1241 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 277ce25d-2f69-5936-aff8-4472b51c1220

any where
  (process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*azure linux:3.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*photon os:5.0*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:23.04*" or process.executable like~ "*ubuntu:23.10*")
