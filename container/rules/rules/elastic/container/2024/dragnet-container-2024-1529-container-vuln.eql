// Dragnet [Container]: dragnet-container-2024-1529 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b86d48ce-e917-503b-8857-78d7bbec764f

any where
  (process.executable like~ "*alpine:3.8*" or process.executable like~ "*debian:9*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:19.04*" or process.executable like~ "*ubuntu:19.10*")
