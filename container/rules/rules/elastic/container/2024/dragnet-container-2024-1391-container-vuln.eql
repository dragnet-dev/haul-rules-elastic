// Dragnet [Container]: dragnet-container-2024-1391 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 091d6f03-09ee-5ac2-99ef-5a507324f174

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*")
