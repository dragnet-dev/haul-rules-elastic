// Dragnet [Container]: dragnet-container-2024-0553 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 918eac37-8264-5ac9-84be-d5df068d52fe

any where
  (process.executable like~ "*azure linux:3.0*" or process.executable like~ "*cbl-mariner:1.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
