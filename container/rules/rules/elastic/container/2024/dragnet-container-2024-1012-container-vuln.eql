// Dragnet [Container]: dragnet-container-2024-1012 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9017ce8c-1cc5-5a47-b12b-0286531afb4b

any where
  (process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*")
