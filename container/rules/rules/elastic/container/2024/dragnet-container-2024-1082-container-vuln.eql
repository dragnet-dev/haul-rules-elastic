// Dragnet [Container]: dragnet-container-2024-1082 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bb7122ea-e7de-569b-b9d6-27cd669015d9

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.10*")
