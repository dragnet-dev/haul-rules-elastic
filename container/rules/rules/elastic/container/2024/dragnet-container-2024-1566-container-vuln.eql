// Dragnet [Container]: dragnet-container-2024-1566 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 57fae667-b100-58f0-a97d-33c07feda967

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*")
