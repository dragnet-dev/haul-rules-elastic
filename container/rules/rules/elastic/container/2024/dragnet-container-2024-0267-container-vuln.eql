// Dragnet [Container]: dragnet-container-2024-0267 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 03d3dd40-7f0f-571c-bf22-3162c227072c

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:22.04*")
