// Dragnet [Container]: dragnet-container-2024-0188 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 459fbb27-64ca-5e88-9759-9480993a05f8

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
