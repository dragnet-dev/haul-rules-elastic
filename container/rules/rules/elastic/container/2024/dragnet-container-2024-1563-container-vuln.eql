// Dragnet [Container]: dragnet-container-2024-1563 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 14d13f61-286f-556a-973e-7e18ce203fdb

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*")
