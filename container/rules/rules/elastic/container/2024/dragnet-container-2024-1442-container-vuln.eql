// Dragnet [Container]: dragnet-container-2024-1442 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 0b4cce4b-b285-5bb6-9faa-d126ef272ce1

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
