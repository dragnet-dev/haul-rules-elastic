// Dragnet [Container]: dragnet-container-2024-0629 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 12f643ce-dc22-563d-ad48-e7915056d466

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*redhat/ubi9:*")
