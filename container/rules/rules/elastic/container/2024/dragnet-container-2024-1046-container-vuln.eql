// Dragnet [Container]: dragnet-container-2024-1046 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: bad909b0-6b6d-585a-ba38-167e8e53fb41

any where
  (process.executable like~ "*chainguard:*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*wolfi:*")
