// Dragnet [Container]: dragnet-container-2024-1349 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: faef4ede-0efe-51b3-bb72-d06c4dac9c6b

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*")
