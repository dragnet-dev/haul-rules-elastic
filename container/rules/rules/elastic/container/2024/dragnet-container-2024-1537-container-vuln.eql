// Dragnet [Container]: dragnet-container-2024-1537 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6ba060b0-1c08-5d6e-890f-b878bb96e02f

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
