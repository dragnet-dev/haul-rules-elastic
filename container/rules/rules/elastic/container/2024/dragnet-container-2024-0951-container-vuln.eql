// Dragnet [Container]: dragnet-container-2024-0951 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5394e742-b8f5-5775-a2f4-1ea7cc4bc385

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:7*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:12.04*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*")
