// Dragnet [Container]: dragnet-container-2024-1167 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 00078425-05a9-54c9-afba-0070d8aec1a8

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
