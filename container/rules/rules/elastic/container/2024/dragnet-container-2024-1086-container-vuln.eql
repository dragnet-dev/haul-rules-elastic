// Dragnet [Container]: dragnet-container-2024-1086 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 13c90f49-2591-512b-8da4-30caddc1ce0a

any where
  (process.executable like~ "*alpine:3.10*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:19.04*")
