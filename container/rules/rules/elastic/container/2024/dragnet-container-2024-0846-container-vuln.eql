// Dragnet [Container]: dragnet-container-2024-0846 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 357a62d9-045f-5e15-8f25-52db1274c421

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*cbl-mariner:1.0*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*photon os:2.0*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*redhat/ubi9:*")
