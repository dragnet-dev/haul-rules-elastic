// Dragnet [Container]: dragnet-container-2024-0683 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 073db039-33cd-5f20-aa9a-46531353131a

any where
  (process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:19.10*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*")
