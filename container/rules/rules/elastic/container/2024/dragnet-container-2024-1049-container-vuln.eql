// Dragnet [Container]: dragnet-container-2024-1049 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: a2d25741-8d97-520c-8907-f38cc8b354c1

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
