// Dragnet [Container]: dragnet-container-2024-0466 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 606d8b1e-4155-57a3-b44b-1162312d16a3

any where
  (process.executable like~ "*alpine:3.7*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
