// Dragnet [Container]: dragnet-container-2024-1372 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ada95d5d-6a3e-54cf-a579-60c6f0b28632

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:17.10*")
