// Dragnet [Container]: dragnet-container-2024-1307 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cd2f0768-c8c2-528e-85f9-8d2d14168d98

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:21.10*" or process.executable like~ "*ubuntu:22.04*")
