// Dragnet [Container]: dragnet-container-2024-0991 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cda4f237-d798-5330-ad40-da0db11c5f86

any where
  (process.executable like~ "*alpine:3.11*" or process.executable like~ "*alpine:3.12*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*")
