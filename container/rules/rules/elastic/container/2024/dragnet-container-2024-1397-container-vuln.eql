// Dragnet [Container]: dragnet-container-2024-1397 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 13ba1a8f-00bc-5492-8373-096c0497662d

any where
  (process.executable like~ "*alpine:3.13*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:9*" or process.executable like~ "*photon os:1.0*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
