// Dragnet [Container]: dragnet-container-2024-1509 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: eeaf443b-ea09-5701-bc16-7fce8c1f22d8

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*")
