// Dragnet [Container]: dragnet-container-2024-0266 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 2ccc6802-49da-5084-8329-63c4d1c8a71c

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:22.10*" or process.executable like~ "*ubuntu:23.04*" or process.executable like~ "*ubuntu:23.10*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:24.10*" or process.executable like~ "*ubuntu:25.04*")
