// Dragnet [Container]: dragnet-container-2024-0856 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d48cc3a4-fa8a-5cab-a87f-9d04c042d81a

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
