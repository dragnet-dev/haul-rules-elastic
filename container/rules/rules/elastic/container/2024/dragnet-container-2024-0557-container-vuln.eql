// Dragnet [Container]: dragnet-container-2024-0557 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7bc1714c-f571-59bf-9f7e-d5f8850af8fc

any where
  (process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*")
