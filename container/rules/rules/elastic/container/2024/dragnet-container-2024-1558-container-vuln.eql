// Dragnet [Container]: dragnet-container-2024-1558 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f0ee0304-79ab-5bc2-800e-22b0a16deccb

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
