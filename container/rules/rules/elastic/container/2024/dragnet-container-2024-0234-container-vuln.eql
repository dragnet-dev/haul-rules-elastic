// Dragnet [Container]: dragnet-container-2024-0234 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cbf587ae-c929-5eba-9bf5-d4e84c385bcb

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
