// Dragnet [Container]: dragnet-container-2024-1472 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 6fcbf5a9-7404-5fcb-906f-b8abbbab6ef0

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*")
