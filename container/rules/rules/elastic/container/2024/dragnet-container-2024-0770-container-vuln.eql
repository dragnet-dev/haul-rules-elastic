// Dragnet [Container]: dragnet-container-2024-0770 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 86877664-c3cc-5e44-9daa-6e4073683652

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*")
