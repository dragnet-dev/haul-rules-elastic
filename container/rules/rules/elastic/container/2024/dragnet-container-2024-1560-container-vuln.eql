// Dragnet [Container]: dragnet-container-2024-1560 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f5dd094a-cc03-54b4-a0b3-d0b84f243d96

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:14.04-ESM*")
