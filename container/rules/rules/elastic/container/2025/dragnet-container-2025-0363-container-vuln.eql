// Dragnet [Container]: dragnet-container-2025-0363 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: eb52cf93-b2e3-5576-b329-536b522bc536

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04-ESM*")
