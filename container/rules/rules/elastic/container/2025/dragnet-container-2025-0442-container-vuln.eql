// Dragnet [Container]: dragnet-container-2025-0442 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 545f8025-4dcc-51a0-a16c-20ea38c221c2

any where
  (process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
