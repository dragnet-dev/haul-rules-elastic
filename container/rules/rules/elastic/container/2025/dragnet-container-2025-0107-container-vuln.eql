// Dragnet [Container]: dragnet-container-2025-0107 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 4ebad0da-64ec-5ca1-92f7-8da800687d34

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*")
