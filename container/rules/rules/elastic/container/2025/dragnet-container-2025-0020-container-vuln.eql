// Dragnet [Container]: dragnet-container-2025-0020 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ebcbd66f-9cbb-5e2f-8c26-096b3bc140ee

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
