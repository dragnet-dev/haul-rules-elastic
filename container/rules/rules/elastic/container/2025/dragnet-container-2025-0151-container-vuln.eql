// Dragnet [Container]: dragnet-container-2025-0151 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7b203a94-2845-59df-8a04-a1034d54fa9c

any where
  (process.executable like~ "*almalinux:9*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:23.04*" or process.executable like~ "*ubuntu:23.10*")
