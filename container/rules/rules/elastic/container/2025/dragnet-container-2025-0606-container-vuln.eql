// Dragnet [Container]: dragnet-container-2025-0606 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f135b0fe-46c2-558c-9fe0-b5c8d93f59ed

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:18.04-ESM*")
