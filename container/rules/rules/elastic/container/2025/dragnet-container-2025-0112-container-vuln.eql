// Dragnet [Container]: dragnet-container-2025-0112 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: f1aeba98-01f7-5f4c-8898-e95ce9feead8

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:18.04*")
