// Dragnet [Container]: dragnet-container-2025-0182 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 64411d85-5d06-5f55-b533-69470bc4078e

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*azure linux:3.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*photon os:5.0*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
