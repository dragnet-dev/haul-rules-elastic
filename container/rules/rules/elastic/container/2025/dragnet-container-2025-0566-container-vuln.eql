// Dragnet [Container]: dragnet-container-2025-0566 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 49be29de-9695-58f1-8837-4c371657052b

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:21.10*" or process.executable like~ "*ubuntu:22.04*")
