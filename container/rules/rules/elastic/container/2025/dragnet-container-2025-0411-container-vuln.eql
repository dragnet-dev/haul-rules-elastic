// Dragnet [Container]: dragnet-container-2025-0411 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8ab279a5-f954-5d2a-9636-d59acfb7e151

any where
  (process.executable like~ "*almalinux:9*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:9*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
