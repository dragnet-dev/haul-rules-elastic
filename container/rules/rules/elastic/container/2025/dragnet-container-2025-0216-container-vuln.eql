// Dragnet [Container]: dragnet-container-2025-0216 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7a2dee05-0765-5747-9715-a62b84ccc450

any where
  (process.executable like~ "*alpine:3.15*" or process.executable like~ "*alpine:3.16*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*azure linux:3.0*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
