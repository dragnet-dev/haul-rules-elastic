// Dragnet [Container]: dragnet-container-2025-0268 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: af338e0c-727f-56e4-8bf6-faadcb8f7a26

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:3.0*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*ubuntu:18.04*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
