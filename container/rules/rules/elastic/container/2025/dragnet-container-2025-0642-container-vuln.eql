// Dragnet [Container]: dragnet-container-2025-0642 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: d1ccd2d2-7faf-5988-adfd-4397e3ce37ad

any where
  (process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
