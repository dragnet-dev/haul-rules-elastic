// Dragnet [Container]: dragnet-container-2025-0221 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: dec134f2-14e7-5ecf-9b46-8c13a977dc49

any where
  (process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.04*" or process.executable like~ "*wolfi:*")
