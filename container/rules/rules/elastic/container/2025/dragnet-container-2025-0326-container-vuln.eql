// Dragnet [Container]: dragnet-container-2025-0326 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ed1f567e-9639-540f-8897-d770b8c49c91

any where
  (process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*")
