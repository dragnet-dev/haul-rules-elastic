// Dragnet [Container]: dragnet-container-2025-0461 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9fd009eb-b1d9-58e4-918b-96d0715dbe92

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
