// Dragnet [Container]: dragnet-container-2025-0419 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ad837846-2c9b-56d5-b62e-93193ea64790

any where
  (process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:25.04*")
