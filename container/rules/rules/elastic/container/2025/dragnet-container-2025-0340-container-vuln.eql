// Dragnet [Container]: dragnet-container-2025-0340 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 73202963-ee2b-5171-9684-d07bf0257ec7

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*")
