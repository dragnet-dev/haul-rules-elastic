// Dragnet [Container]: dragnet-container-2025-0555 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 874da10b-fd08-5bb1-bd54-06c4d09c2e8d

any where
  (process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*")
