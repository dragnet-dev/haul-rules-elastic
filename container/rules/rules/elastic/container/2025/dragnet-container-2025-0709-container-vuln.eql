// Dragnet [Container]: dragnet-container-2025-0709 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8e20b19d-b6ca-5115-a2c7-35539ff222a0

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*wolfi:*")
