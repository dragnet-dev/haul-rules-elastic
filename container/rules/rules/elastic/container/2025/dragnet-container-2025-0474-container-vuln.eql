// Dragnet [Container]: dragnet-container-2025-0474 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 8a64595b-74d0-583e-b819-9d5280c185ff

any where
  (process.executable like~ "*chainguard:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*wolfi:*")
