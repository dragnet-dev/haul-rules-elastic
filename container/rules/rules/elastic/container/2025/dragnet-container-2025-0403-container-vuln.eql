// Dragnet [Container]: dragnet-container-2025-0403 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: cfbec67f-66ac-5979-bc87-ade9e6f12aea

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
