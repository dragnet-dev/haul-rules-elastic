// Dragnet [Container]: dragnet-container-2025-0694 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3839957c-6c52-5dd2-92aa-5b70f5585edd

any where
  (process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*chainguard:*" or process.executable like~ "*ubuntu:23.04*" or process.executable like~ "*wolfi:*")
