// Dragnet [Container]: dragnet-container-2025-0065 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 4f56bfa4-9b26-5c75-967d-9274396ea2ad

any where
  (process.executable like~ "*amazonlinux:2*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:23.04*")
