// Dragnet [Container]: dragnet-container-2025-0285 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 9dc1242a-550b-574f-9f6b-05d855955ccb

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:8*" or process.executable like~ "*debian:9*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:19.04*")
