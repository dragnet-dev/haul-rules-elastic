// Dragnet [Container]: dragnet-container-2025-0622 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 546d5ab8-bd49-506c-9d8e-ce3a79cad3f3

any where
  (process.executable like~ "*amazonlinux:1*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*debian:7*" or process.executable like~ "*debian:8*" or process.executable like~ "*oraclelinux:5*" or process.executable like~ "*oraclelinux:6*" or process.executable like~ "*oraclelinux:7*")
