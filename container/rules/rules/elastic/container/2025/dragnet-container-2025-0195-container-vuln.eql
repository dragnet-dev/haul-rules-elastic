// Dragnet [Container]: dragnet-container-2025-0195 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: e02d58dd-68c4-5d6b-8985-b2a42752e992

any where
  (process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.04*" or process.executable like~ "*ubuntu:25.10*" or process.executable like~ "*ubuntu:26.04*")
