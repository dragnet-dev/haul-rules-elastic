// Dragnet [Container]: dragnet-container-2025-0386 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 7aeea079-7e10-5f14-943b-aeae5d45ab5f

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:13*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*")
