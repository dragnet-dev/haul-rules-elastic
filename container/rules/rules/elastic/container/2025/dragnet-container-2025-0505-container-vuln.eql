// Dragnet [Container]: dragnet-container-2025-0505 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 939dfbdd-98ac-5abe-9c73-0614f2588a37

any where
  (process.executable like~ "*alpine:3.14*" or process.executable like~ "*alpine:3.15*" or process.executable like~ "*alpine:3.16*" or process.executable like~ "*alpine:3.17*" or process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*redhat/ubi9:*")
