// Dragnet [Container]: dragnet-container-2025-0006 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3603d79f-7eeb-500e-90f2-807e848d2a3e

any where
  (process.executable like~ "*chainguard:*" or process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:23.04*" or process.executable like~ "*ubuntu:23.10*" or process.executable like~ "*wolfi:*")
