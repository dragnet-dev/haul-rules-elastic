// Dragnet [Container]: dragnet-container-2025-0118 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 79165bce-5d6e-59dc-8eeb-01a2aedce002

any where
  (process.executable like~ "*alpine:3.18*" or process.executable like~ "*alpine:3.19*" or process.executable like~ "*alpine:3.20*" or process.executable like~ "*alpine:3.21*" or process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*")
