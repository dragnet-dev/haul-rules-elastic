// Dragnet [Container]: dragnet-container-2025-0255 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 32e8d887-330c-5abf-a722-b15edfa644c5

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:24.10*")
