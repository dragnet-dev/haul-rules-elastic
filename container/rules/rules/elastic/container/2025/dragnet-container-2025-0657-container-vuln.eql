// Dragnet [Container]: dragnet-container-2025-0657 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 288aaba3-4c6c-5df7-8901-39ccf6bb1551

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:22.10*")
