// Dragnet [Container]: dragnet-container-2025-0019 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 954fa156-2646-5e0d-a52b-c49b7a9d094f

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*")
