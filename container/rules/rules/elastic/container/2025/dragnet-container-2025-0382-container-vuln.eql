// Dragnet [Container]: dragnet-container-2025-0382 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: ec9b256e-f15a-556e-83e3-681398e81401

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*cbl-mariner:1.0*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*redhat/ubi9:*")
