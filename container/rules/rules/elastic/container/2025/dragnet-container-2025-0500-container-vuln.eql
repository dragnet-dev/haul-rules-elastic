// Dragnet [Container]: dragnet-container-2025-0500 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 05d7d8c0-a590-5009-a2fd-95ec2aff6804

any where
  (process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:14.04-ESM*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:17.04*" or process.executable like~ "*ubuntu:17.10*")
