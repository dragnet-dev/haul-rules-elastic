// Dragnet [Container]: dragnet-container-2025-0002 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 870aa7c3-8d68-5728-9310-486ffcf3a6cf

any where
  (process.executable like~ "*debian:10*" or process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*")
