// Dragnet [Container]: dragnet-container-2025-0249 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 3cb2e02f-f513-53fd-90cb-cc3fc9622341

any where
  (process.executable like~ "*oraclelinux:7*" or process.executable like~ "*ubuntu:14.04*" or process.executable like~ "*ubuntu:16.04*" or process.executable like~ "*ubuntu:16.10*" or process.executable like~ "*ubuntu:17.04*")
