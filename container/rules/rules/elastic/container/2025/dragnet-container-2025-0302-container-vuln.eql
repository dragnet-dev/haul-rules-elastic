// Dragnet [Container]: dragnet-container-2025-0302 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 5573c231-05e7-54ef-92cf-4923750c887d

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*photon os:4.0*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:16.04-ESM*" or process.executable like~ "*ubuntu:18.04-ESM*" or process.executable like~ "*ubuntu:20.04-ESM*")
