// Dragnet [Container]: dragnet-container-2025-0160 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: 346945c6-c636-51fd-a175-6a46fb6941ad

any where
  (process.executable like~ "*debian:11*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:20.04-ESM*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*ubuntu:25.10*")
