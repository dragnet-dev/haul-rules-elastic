// Dragnet [Container]: dragnet-container-2025-0599 — Vulnerable Base Image Pull
// Status: deprecated | Level: high | ID: 9ef45efd-5921-5c30-96ef-0daaf324d483

any where
  (process.executable like~ "*almalinux:8*" or process.executable like~ "*amazonlinux:2*" or process.executable like~ "*amazonlinux:2023*" or process.executable like~ "*azure linux:3.0*" or process.executable like~ "*cbl-mariner:2.0*" or process.executable like~ "*chainguard:*" or process.executable like~ "*debian:12*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*oraclelinux:8*" or process.executable like~ "*redhat/ubi9:*" or process.executable like~ "*ubuntu:22.04*" or process.executable like~ "*ubuntu:24.04*" or process.executable like~ "*wolfi:*")
