// Dragnet [Container]: dragnet-container-2025-0680 — Vulnerable Base Image Pull
// Status: deprecated | Level: critical | ID: b0ad3a54-18a3-5286-8f58-bb4331901f54

any where
  (process.executable like~ "*alpine:3.22*" or process.executable like~ "*alpine:3.23*" or process.executable like~ "*alpine edge:*" or process.executable like~ "*debian:13*" or process.executable like~ "*debian:14*" or process.executable like~ "*ubuntu:25.04*")
